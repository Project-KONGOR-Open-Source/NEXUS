<?xml version="1.0" encoding="UTF-8"?>
<package>

<template name="TMP_infopicker">
	<panel name="TMP_infopicker{id}" width="100@" height="100%" color=".8 .3 .3 .8"
		onclick="ShowOnly('current{id}'); ShowOnly('detailed_info_{target}_wrapper');"
	>
	
		<panel name="current{id}" group="TMP_pickerCurrent" color="1 .1 .1 .8" visible="false" />
		<frame color="invisible" borderthickness="2" bordercolor="0 0 0 1" noclick="true" />
		<frame color="invisible" borderthickness="1" bordercolor="1 1 1 1" noclick="true" />
		<label textalign="center" textvalign="center" font="dyn_10" color="1 1 1 1" shadow="true" noclick="true" content="{id}" />
	</panel>
</template>

<template name="closex_btn">
	<button
		name="{id}"
		x="{x}" y="{y}"		
		width="{width=1.9h}" height="{height=1.9h}"
		align="{align}"
		valign="{valign}"
		color="invisible"
		onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); {onclick}"
		onclicklua="{onclicklua}"
		onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
		interactive="true"
		watch="{btn_watch}" ontrigger="{btn_ontrigger}"
		noclick="{noclick=false}"
	>
		<widgetstate statename="up">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
			<image width="70%" height="70@" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
		</widgetstate>
		<widgetstate statename="over">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
			<image width="70%" height="70@" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />			
		</widgetstate>
		<widgetstate statename="down" x="1" y="1">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
			<image width="70%" height="70@" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
		</widgetstate>
	</button>
</template>

<template name="detailed_info_wrapper">
	<panel name="detailed_info_{id}_wrapper" group="detailed_infos" color="0 0 0 .7" onclicklua="Game_Walkthrough.ResumeGame(self)" visible="{visible=false}">
		<panel grow="true" width="{width=74.0h}" align="center" valign="center" noclick="true" >
			<frame texture="/ui/frames/rounded_bg_doubleedge.tga" borderthickness="1.0h" color=".08 .08 .08 .9" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" borderthickness="1.0h" color=".25 .25 .25 1" noclick="true" />		
			<panel grow="true" y="1.8h" width="-3.6h" align="center" float="bottom" noclick="true">		
				<!-- Title -->
				<panel height="2.4h" noclick="true">
					<label height="100%" textvalign="center" font="dyn_18" color="#ffaa00" outline="true" content="{title}" noclick="true" />
					<instance name="closex_btn" noclick="true" align="right" valign="center" />
				</panel>
				<panel height="1.6h" noclick="true" />		
				<!-- Content -->
				<instance name="{id}" noclick="true" />			
				<panel height="1.8h" noclick="true" />
			</panel>	
		</panel>
	</panel>
</template>

<template name="detailed_screenshot">
	<panel x="{x}" y="{y=0.4h}" width="{width}" height="{height}" noclick="true">
		<image resourcecontext="walkthroughScreenshots{texture}"
			onshowlua="Game_Walkthrough.LoadTextureForMoreInfoWidget(self, 'walkthroughScreenshots{texture}', '/ui/tutorial/screenshots/{texture}')"
			onhidelua="Game_Walkthrough.UnloadTextureForMoreInfoWidget(self, 'walkthroughScreenshots{texture}')"
			onloadlua="Game_Walkthrough.InitMoreInfoWidget(self, 'walkthroughScreenshots{texture}', '/ui/tutorial/screenshots/{texture}')"
		/>
		<frame color="invisible" bordercolor="0 0 0 1" borderthickness="2" noclick="true" />
		<frame color="invisible" bordercolor=".25 .25 .25 1" borderthickness="1" noclick="true" />
	</panel>
</template>

<!-- Rght click To Move -->
<template name="pregame1">
	<panel grow="true" width="100%" noclick="true">	
		<instance name="detailed_screenshot" width="36.0h" height="36.0h" texture="pregame1.tga" />		
		<panel grow="true" width="-38.0h" align="right" noclick="true">
			<label fity="true" wrap="true" font="dyn_14" color="1 1 1 1" shadow="true" noclick="true" 
				onshow="SetText(Translate('walkthrough_pregame_quest1_detail_desc', 'attackKey', GetKeybindButton('game', 'OrderAttack', ''), 'stopKey', GetKeybindButton('game', 'OrderStop', ''), 'holdKey', GetKeybindButton('game', 'OrderHold', ''), 'moveKey', GetKeybindButton('game', 'OrderMove', '')))"
			/>
		</panel>
	</panel>
</template>
