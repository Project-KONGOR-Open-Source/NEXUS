<!-- Camera Control -->
<template name="tip16">
	<panel grow="true" width="100%" noclick="true">	
		<instance name="detailed_screenshot" width="20.0h" height="20.0h" texture="tip16.tga" />		
		<panel grow="true" width="-22.0h" align="right" float="bottom" noclick="true" padding="2.5h">
			<label fity="true" wrap="true" font="dyn_14" color="1 1 1 1" shadow="true" content="walkthrough_tip16_moreInfoWidget_detail_desc" noclick="true" />
			<!-- Toggle center hero checkbox -->
			<panel grow="true" float="right" padding="1.0h"
				onclick=
				"
					Set('cg_lockCameraGame', !cg_lockCameraGame));
					Call('tip16_keybind_checkmark', 'If(cg_lockCameraGame, FadeIn(250), FadeOut(250));');
				"
				onshow="Call('tip16_keybind_checkmark', 'If(cg_lockCameraGame, FadeIn(250), FadeOut(250));');"
			>
				<panel width="1.8h" height="1.8h" noclick="true">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1" />
					<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
					<panel name="tip16_keybind_checkmark" x="0.2h" y="-0.1h" valign="bottom" align="center" width="140@" height="140%" nolclick="true" visible="true" noclick="1">
						<image x="1" y="1" texture="/ui/elements/check_mark_white.tga" color="0 0 0 1" noclick="1" />
						<image texture="/ui/elements/check_mark_white.tga" color="#40cd3c" noclick="1" />
					</panel>
				</panel>
				<label content="tip16_keybind_label" font="dyn_12" fitx="true" noclick="true"/>
			</panel>
			<!-- Button to catch the setting's cvar changes -->
			<button height="0" width="0" visible="false" cvar="cg_lockCameraGame" numstates="2" onbutton="Call('tip16_keybind_checkmark', 'If(cg_lockCameraGame, FadeIn(250), FadeOut(250));');" />
		</panel>
	</panel>
</template>
