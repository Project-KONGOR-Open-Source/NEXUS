<?xml version="1.0" encoding="UTF-8"?>
<package>
	<panel onloadlua="Set('ui_useOldBuffs', false, 'bool', true)" noclick="1" color="invisible"/>
	
	<lua file="/ui/scripts/ebuff.lua" />

	<!-- State Icons -->
	<template name="ebuff_stateicon">
		<panel
			name="ebuff_stateicon{group}{slot}"
			oninstantiatelua="HoN_Ebuffs:RegisterBuff(self, '{group}', '{slot}')"
			noclick="true"
		>
			<panel name="ebuff_{group}{slot}_sleeper" width="-0.4h" height="-0.4h" align="center" valign="center" noclick="true">
				<panel name="ebuff_{group}{slot}_labelpos" width="100%" height="100@" noclick="1">
					
					<!-- DEBUG: SET VISIBLE TO TEST BUFF POSITIONS -->
					<panel
						noclick="true"
						visible="false"
						color="white"
					>
						<piegraph
							start="270" end="-90"
							texture="/ui/elements/state_pie.tga"
							square="true"
							color="0 .6 0"
							noclick="true"
						/>
					</panel>
					
					
					<!-- Clickable frame -->
					<panel
						name="ebuff_iconframe{group}{slot}"
						passivechildren="true"
						onmouseoverlua="GetWidget('{tooltip}{slot}', 'game'):SetVisible(1)"
						onmouseoutlua="GetWidget('{tooltip}{slot}', 'game'):SetVisible(0)"
						onhidelua="GetWidget('{tooltip}{slot}', 'game'):SetVisible(0)"
						visible="false"
						canclick="true"
						onclicklua="if '{group}' == 'Active' and Input.IsAltDown() then SendGamePing('alt_buff',{slot}) end"
					>
						<panel
							name="ebuff_iconframe{group}{slot}_border1"
							align="center"
							valign="center"
						>
						
							<!-- Fade frame -->
							<panel
								name="ebuff_iconframe{group}{slot}_fadeframe"
								color="black"
							>
							
								<!-- black border -->
								<panel name="ebuff_{group}{slot}_borderblack" align="center" valign="center" >
									
									<piegraph
										name="ebuff_iconframe{group}{slot}_pie1"
										texture="/ui/ebuff_durationpie.png"
										square="true"
										start="270" end="-90"
									/>
									<piegraph
										name="ebuff_iconframe{group}{slot}_pie2"
										texture="/ui/ebuff_durationpie.png"
										square="true"
										start="270" end="-90"
									/>
									
									<!-- Colored border -->
									<panel name="ebuff_{group}{slot}_bordercolor" align="center" valign="center" >
									
										<!-- Square icon -->
										<panel name="ebuff_{group}{slot}_square" align="center">
											<image
												name="ebuff_texture{group}{slot}"
											/>
											<image texture="/ui/ebuff_iconfade.png"/>
											<panel
												name="ebuff_iconcharges{group}{slot}"
												noclick="true"
												passivechildren="true"
												height="40%"
												color="0 0 0 .7"
												valign="bottom"
											>
												
												<label 
													name="ebuff_iconframe{group}{slot}_charges"
													y="-2%" 
													height="70%"
													textalign="center" color="white" shadow="true" font="{font=dyn_8}"
												/>
												
											</panel>
										</panel>
										<!-- / Square icon -->
										
										<!-- Timer bar -->
										<panel
											name="ebuff_iconframe{group}{slot}_timebarmaster"
											valign="bottom"
											color="black"
										>
											<panel
												name="ebuff_iconframe{group}{slot}_timebarparent"
												align="center" valign="bottom"
											>
												<panel
													name="ebuff_iconframe{group}{slot}_timebar"
													color="0 0 0 0"
												/>
											</panel>
										</panel>
										<!-- / Timer bar -->
										
									</panel>
									<!-- / Colored border -->
									
								</panel>
								<!-- / black border -->
								
							</panel>
							<!-- /Fade frame -->
							
							<label 
								name="ebuff_iconframe{group}{slot}_time"
								width="200%"
								align="center"
								height="35@"
								textalign="center"
								textvalign="center"
								color="white"
								shadow="true"
								font="{font=dyn_12}"
							/>
							
						</panel>
						<!-- /Scale frame -->
						
					</panel>
					<!-- /Clickable frame -->
					
				</panel>
			</panel>
		</panel>
	</template>
	
	
	<template name="ebuff_group">

		<instance
			name="movf_frame"
			id="ebuff_{group}"
			textid="Enhanced Buffs ({group})"
			resizable="true"
			margin="0.2h"
			snap="true"
			minwidth="1/20"
			minheight="1/20"
			maxwidth="22"
			maxheight="22"
			align="{align=left}" valign="{valign=top}"
			reset_on_res="true"
		/>

		<panel name="ebuff_{group}" noclick="true"
			oninstantiatelua="HoN_Ebuffs:RegisterBuffGroup('{group}')"
			onrefreshlua="HoN_Ebuffs:UpdateBuffGroup('{group}')"			
			overridepos="true"
			x="{x}"
			y="{y}"
			width="{width}"
			height="{height}"
			align="{align=left}" valign="{valign=top}"
		>
			<panel name="ebuff_{group}_wrap" noclick="true" align="center" valign="center">
				<instance name="ebuff_stateicon" slot="13" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="14" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="15" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="16" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="17" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="18" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="19" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="20" group="{group}" tooltip="{tooltip}"/>
				<instance name="ebuff_stateicon" slot="21" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="22" group="{group}" tooltip="{tooltip}" />
				<instance name="ebuff_stateicon" slot="23" group="{group}" tooltip="{tooltip}" />
			</panel>
		</panel>
	
		<panel
			name="ebuff_{group}_frame"
			width="{width=}" height="{height=}"
			x="{x=}" y="{y=}"
			align="{align=left}" valign="{valign=top}"
			visible="false"
			noclick="true"
			passivechildren="true"
		/>		
		<panel onframe="RefreshWidget('ebuff_{group}'); DestroyWidget();" noclick="true" />		
	</template>
	
	<template name="ebuff_movf_group">
		<instance name="ebuff_group" group="Active" tooltip="state_tooltip"
			x="{x1=-12.6h}"
			y="{y1=-14.4h}"
			width="51.6h"
			height="6.6h"
			align="center" valign="bottom"
		/>
		<panel noclick="1" visible="false" watch0="SelectedVisible0 SelectedVisible1 movf_show" ontrigger0="SetVisible(SelectedVisible0 and !SelectedVisible1 or movf_show);"
			onload="CreateInt('minimap_last_position', ui_minimap_rightside);"
			watch1="MiniMapPosition"
			ontrigger1="
				If(
					minimap_last_position != ui_minimap_rightside,
					Split(
						Set('movf_ebuff_Selected_x', GetScreenWidth() - movf_ebuff_Selected_x),
						Call('movf_ebuff_Selected_frame', 'SetAbsoluteX(movf_ebuff_Selected_x - GetWidth());'),
						Call('movf_ebuff_Selected_overlay', 'SetAbsoluteX(movf_ebuff_Selected_x - GetWidth());'),
						Call('ebuff_Selected', 'SetAbsoluteX(movf_ebuff_Selected_x - GetWidth());'),
						Call('movf_ebuff_Selected_frame', 'Set(\'movf_ebuff_Selected_x\', GetAbsoluteX());'),
						Set('minimap_last_position', ui_minimap_rightside),
						Cmd('script HoN_Ebuffs:UpdateBuffGroup(\'Selected\')'),
						Trigger('movf_collectionrefresh')
					)
				);

			"
			watch2="movf_resetcall"
			ontrigger2lua="
				self:Sleep(0, function()
					if GetCvarBool('ui_minimap_rightside') then

						local x = GetScreenWidth() - GetCvarNumber('movf_ebuff_Selected_x')

						local interface = UIManager.GetActiveInterface()

						local w = interface:GetWidget('movf_ebuff_Selected_frame')
						w:SetAbsoluteX(x - w:GetWidth())

						w = interface:GetWidget('movf_ebuff_Selected_overlay')
						w:SetAbsoluteX(x - w:GetWidth())

						w = interface:GetWidget('ebuff_Selected')
						w:SetAbsoluteX(x - w:GetWidth())

						w = interface:GetWidget('movf_ebuff_Selected_frame')
						Set('movf_ebuff_Selected_x', w:GetAbsoluteX())

						HoN_Ebuffs:UpdateBuffGroup('Selected')

						Trigger('movf_collectionrefresh')
					end
				end)
			"
		>
			<instance name="ebuff_group" group="Selected" tooltip="state_info_tooltip"
				x="{x2=-1h}"
				y="{y2=-17.2h}"
				width="37.0h"
				height="5h"
				align="right" valign="bottom"
			/>
		</panel>
	</template>
	
</package>
