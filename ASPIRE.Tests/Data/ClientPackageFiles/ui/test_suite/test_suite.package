							<instance x="18h" name="test_suite_button" button="fake_grab_bag" width="-21.0h" content="test_client_fake_grab_bag"
								onclicklua="
									local theme = TestSuite.GetWidget('test_client_bag_theme'):GetValue()
									local names = ''
									local ids = ''
									local icons = ''
									local types = ''
									for i=1,5 do
										local name = TestSuite.GetWidget('test_client_bag_product_'..i):GetValue()
										if (NotEmpty(name)) then
											if (NotEmpty(names)) then
												names = names..'|'
												ids = ids..'|'
												icons = icons..'|'
												types = types..'|'
											end

											names = names..name
											ids = ids..TestSuite.GetWidget('test_client_bag_id_'..i):GetValue()
											icons = icons..TestSuite.GetWidget('test_client_bag_icon_'..i):GetValue()
											types = types..TestSuite.GetWidget('test_client_bag_type_'..i):GetValue()
										end
									end

									TestSuite.FakeGrabBag(theme, names, ids, icons, types)
								"
							/>
