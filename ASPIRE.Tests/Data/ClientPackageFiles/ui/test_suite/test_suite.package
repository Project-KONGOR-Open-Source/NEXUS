							onclicklua="TestSuite.AuditLog('') TestSuite.AuditTaunts()"
						/>
						<instance name="test_suite_button" button="audit_wards" width="100%" height="2.5h" content="test_client_audit_wards"
							onclicklua="TestSuite.AuditLog('') TestSuite.AuditWards()"
