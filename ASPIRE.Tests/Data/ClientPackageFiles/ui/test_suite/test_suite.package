					</panel>

					<!-- Audit Log -->
					<label align="right" y="0.25h" width="70h" height="2h" font="dyn_12" color="white" textalign="center" content="test_client_audit_log" />
					<textbuffer name="test_client_audit_log" x="-1h" y="2.5h" align="right" width="70h" height="40.5h" font="dyn_10" textcolor="white" shadow="1" anchorbottom="1" color="0 0 0 0.4" scrolltexture="/ui/test_suite/images/im.tga" />

					<panel height="12h" y="-1h" width="-2h" align="center" valign="bottom" >
