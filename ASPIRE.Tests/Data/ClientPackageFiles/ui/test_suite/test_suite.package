						</panel>

						<panel height="2.5h" y="-5.8h" valign="bottom" noclick="1" float="right" padding="0.5h" >
							<label font="dyn_12" color="white" content="test_client_audit_resources" fitx="1" fitxpadding="0.5h" />
							<instance name="test_suite_tip" tip="audit_resources" width="100@" content="test_client_audit_resources_tip" />

							<panel width="1h" noclick="1" />

							<instance name="test_suite_button" button="audit_hero_resources" height="2.5h" valign="bottom" content="test_client_hero"
