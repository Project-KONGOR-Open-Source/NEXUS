<?xml version="1.0" encoding="UTF-8"?>
<package >
	<!-- Templates -->
	<template name="test_suite_tab" >
		<button name="{tab}_tab" grow="1" regrow="1" growinvis="0" height="100%" width="{width=}" color="invisible"
			onclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') self:DoEvent()"
			oneventlua="{onclicklua}"
			onrightclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onrightclicklua}"
			onmouseoverlua="PlaySound('/ui/test_suite/sounds/button_over_01.ogg') {onmouseoverlua}"
			onbuttonlua="
				local interfaceName = self:GetInterface():GetName()
				local background = TestSuite.GetWidget('{tab}_tab_bg', true, interfaceName)
				local frame = TestSuite.GetWidget('{tab}_tab_frame', true, interfaceName)
				local icon = TestSuite.GetWidget('{tab}_tab_icon', true, interfaceName)
				local text = TestSuite.GetWidget('{tab}_tab_text', true, interfaceName)
				if (background and frame and icon and text) then
					if ((param0 == 'up') or (param0 == 'downoff') or (param0 == 'downrightoff')) then
						background:SetColor('{upColor=#065294}')
						background:SetBorderColor('{upColor=#065294}')
						frame:SetBorderColor('{upColor=#065294}')
						icon:SetX(0) icon:SetY(0)
						text:SetX(0) text:SetY(0)
					elseif ((param0 == 'down') or (param0 == 'downright')) then
						background:SetColor('{downColor=#06447A}')
						background:SetBorderColor('{downColor=#06447A}')
						frame:SetBorderColor('{downColor=#06447A}')
						icon:SetX(1) icon:SetY(1)
						text:SetX(1) text:SetY(1)
					elseif (param0 == 'over') then
						background:SetColor('{overColor=#3A87C9}')
						background:SetBorderColor('{overColor=#3A87C9}')
						frame:SetBorderColor('{overColor=#3A87C9}')
						icon:SetX(0) icon:SetY(0)
						text:SetX(0) text:SetY(0)
					elseif (param0 == 'disabled') then
						background:SetColor('{disabledColor=#737373}')
						background:SetBorderColor('{disabledColor=#737373}')
						frame:SetBorderColor('{disabledColor=#737373}')
						icon:SetX(0) icon:SetY(0)
						text:SetX(0) text:SetY(0)
					end
				end
			"
		>
			<panel height="100%" clip="1" >
				<frame name="{tab}_tab_bg" texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.8h" borderthickness="0.8h" color="{upColor=#065294}" />
				<frame name="{tab}_tab_frame" texture="/ui/test_suite/images/roundframe.tga" height="+0.8h" borderthickness="0.8h" bordercolor="{upColor=#065294}" />
			</panel>

			<panel float="right" grow="1" regrow="1" growinvis="0" height="100%" >
				<panel width="{iconWidth=100@}" oninstantiatelua="self:SetVisible('{icon}' ~= '')" sticky="1" stickytoinvis="0" clip="1" >
					<image name="{tab}_tab_icon" width="80%" height="90%" align="center" valign="bottom" texture="{icon}" />
				</panel>

				<panel grow="1" regrow="1" growinvis="0" height="100%" sticky="1" stickytoinvis="0"
					oninstantiatelua="self:SetVisible(Translate('{content}') ~= '')"
				>
					<label name="{tab}_tab_text" font="dyn_10" color="white" textvalign="center" textalign="center" fitxpadding="1h" fitx="1" shadow="1" content="{content}" />
				</panel>
			</panel>
		</button>
	</template>

	<template name="test_suite_button" >
		<button name="{button}_button" x="{x=}" y="{y=}" grow="1" regrow="1" growinvis="0" height="{height=100%}" width="{width=}" color="invisible" align="{align=left}" valign="{valign=top}"
			onclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') self:DoEvent()"
			oneventlua="{onclicklua}"
			onrightclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onrightclicklua}"
			onmouseoutlua="{onmouseoutlua}"
			onmouseoverlua="PlaySound('/ui/test_suite/sounds/button_over_01.ogg') {onmouseoverlua}"
			onbuttonlua="
				local interfaceName = self:GetInterface():GetName()
				local background = TestSuite.GetWidget('{button}_button_bg', true, interfaceName)
				local frame = TestSuite.GetWidget('{button}_button_frame', true, interfaceName)
				local icon = TestSuite.GetWidget('{button}_button_icon', true, interfaceName)
				local text = TestSuite.GetWidget('{button}_button_text', true, interfaceName)
				if (background and frame and icon and text) then
					if ((param0 == 'up') or (param0 == 'downoff') or (param0 == 'downrightoff')) then
						background:SetColor('{upColor=#065294}')
						background:SetBorderColor('{upColor=#065294}')
						frame:SetBorderColor('{upColor=#065294}')
						icon:SetX(0) icon:SetY(0)
						text:SetX(0) text:SetY(0)
					elseif ((param0 == 'down') or (param0 == 'downright')) then
						background:SetColor('{downColor=#06447A}')
						background:SetBorderColor('{downColor=#06447A}')
						frame:SetBorderColor('{downColor=#06447A}')
						icon:SetX(1) icon:SetY(1)
						text:SetX(1) text:SetY(1)
					elseif (param0 == 'over') then
						background:SetColor('{overColor=#3A87C9}')
						background:SetBorderColor('{overColor=#3A87C9}')
						frame:SetBorderColor('{overColor=#3A87C9}')
						icon:SetX(0) icon:SetY(0)
						text:SetX(0) text:SetY(0)
					elseif (param0 == 'disabled') then
						background:SetColor('{disabledColor=#737373}')
						background:SetBorderColor('{disabledColor=#737373}')
						frame:SetBorderColor('{disabledColor=#737373}')
						icon:SetX(0) icon:SetY(0)
						text:SetX(0) text:SetY(0)
					end
				end
			"
		>
			<frame name="{button}_button_bg" texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="{upColor=#065294}" />
			<frame name="{button}_button_frame" texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="{upColor=#065294}" />

			<panel float="right" grow="1" regrow="1" growinvis="0" height="100%" align="center" >
				<panel width="{iconWidth=100@}" oninstantiatelua="self:SetVisible('{icon}' ~= '')" sticky="1" stickytoinvis="0" clip="1" >
					<image name="{button}_button_icon" width="80%" height="80%" align="center" valign="center" texture="{icon}" />
				</panel>

				<panel grow="1" regrow="1" growinvis="0" height="100%" sticky="1" stickytoinvis="0"
					oninstantiatelua="self:SetVisible(Translate('{content}') ~= '')"
				>
					<label name="{button}_button_text" font="{font=dyn_10}" shadow="1" color="white" align="center" textvalign="center" textalign="center" fitxpadding="1h" fitx="1" content="{content}" />
				</panel>
			</panel>
		</button>
	</template>

	<template name="test_suite_tip" >
		<button x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" valign="{valign=top}" align="{align=left}" color="invisible"
			onbuttonlua="
				local interfaceName = self:GetInterface():GetName()
				local background = TestSuite.GetWidget('{tip}_tip_bg', true, interfaceName)
				local frame = TestSuite.GetWidget('{tip}_tip_frame', true, interfaceName)
				if (background and frame) then
					if ((param0 == 'up') or (param0 == 'downoff') or (param0 == 'downrightoff')) then
						background:SetColor('{upColor=#065294}')
						background:SetBorderColor('{upColor=#065294}')
						frame:SetBorderColor('{upColor=#065294}')
						TestSuite.GetWidget('test_suite_tip_floater', false, interfaceName):SetVisible(0)
					elseif (param0 == 'over') then
						background:SetColor('{overColor=#3A87C9}')
						background:SetBorderColor('{overColor=#3A87C9}')
						frame:SetBorderColor('{overColor=#3A87C9}')
						TestSuite.GetWidget('test_suite_tip_floater_text', false, interfaceName):SetText(Translate('{content}'))
						TestSuite.GetWidget('test_suite_tip_floater', false, interfaceName):BringToFront()
						TestSuite.GetWidget('test_suite_tip_floater', false, interfaceName):SetVisible(1)
					elseif (param0 == 'disabled') then
						background:SetColor('{disabledColor=#737373}')
						background:SetBorderColor('{disabledColor=#737373}')
						frame:SetBorderColor('{disabledColor=#737373}')
						TestSuite.GetWidget('test_suite_tip_floater', false, interfaceName):SetVisible(0)
					end
				end
			"

			onmouseoverlua="
				PlaySound('/ui/test_suite/sounds/button_over_01.ogg')
			"
		>
			<frame name="{tip}_tip_bg" texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="{upColor=#065294}" />
			<frame name="{tip}_tip_frame" texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="{upColor=#065294}" />

			<image texture="/ui/test_suite/images/question_mark.tga" noclick="1" width="90%" height="90%" align="center" valign="center" />
		</button>
	</template>

	<template name="test_suite_listitem_simple" >
		<label font="{font=dyn_12}" x="0.5h" width="-0.5h" color="white" shadow="1" textvalign="center" content="{content=}" />
	</template>

	<template name="test_suite_listitem_simple_oversized" >
		<panel width="100%" height="100%" clip="1" noclick="1" >
			<panel noclick="1" width="100%" height="100%" grow="1" regrow="1" align="right" >
				<label font="{font=dyn_12}" x="0.5h" width="-0.5h" color="white" shadow="1" textvalign="center" fitx="1" content="{content=}" />
			</panel>
		</panel>
	</template>

	<template name="test_suite_listitem_entity" >
		<image x="10@" width="80@" height="80%" valign="center" texture="{icon=$invis}" />
		<label font="{font=dyn_12}" x="110@" width="-110@" color="white" shadow="1" textvalign="center" content="{content=}" />
	</template>

	<template name="test_suite_combobox_state" >
		<widgetstate statename="{state}">
			<panel color="invisible">
				<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="{color}" rendermode="{rendermode=normal}" />
				<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="{bordercolor}" rendermode="{rendermode=normal}"/>

				<image x="-0.5h" width="65@" height="65%" rotation="90" align="right" valign="bottom" color="{arrowColor}" texture="/ui/test_suite/images/arrow.tga" rendermode="{rendermode=normal}" />
			</panel>
		</widgetstate>
	</template>

	<template name="test_suite_combobox" >
		<combobox name="{combobox}" x="{x=}" y="{y=}" height="{height=100%}" width="{width=100%}" align="{align=left}" valign="{valign=top}" exteriorscrollbars="false" color="invisible" itemheight="2h" handleheight="100@" handlewidth="100%" scrollbarsize="2h" scrolltexture="/ui/test_suite/images/im.tga" maxlistheight="{maxlistheight=8}"
			onclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onclicklua}"
			onrightclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onrightclicklua}"
			onmouseoverlua="PlaySound('/ui/test_suite/sounds/button_over_01.ogg') {onmouseoverlua}"
			onselectlua="{onselectlua=}"
			oninstantiatelua="{populate=}"
			onopenlua="{onopenlua=}"
			oncloselua="{oncloselua=}"
			onshowlua="{onshowlua=}"
			onhidelua="{onhidelua=}"
			taborder="{taborder=-1}"
			watch="{watch=}"
			ontriggerlua="{ontriggerlua=}"
			oneventlua="{oneventlua=}"

		>
			<instance name="test_suite_combobox_state" state="up" color="#065294" bordercolor="#065294" arrowColor="0.8 0.8 0.8" />
			<instance name="test_suite_combobox_state" state="over" color="#3A87C9" bordercolor="#065294" arrowColor="1 1 1" />
			<instance name="test_suite_combobox_state" state="down" color="#06447A" bordercolor="#065294" arrowColor="1 1 1" />
			<instance name="test_suite_combobox_state" state="disabled" color="#737373" bordercolor="#065294" arrowColor="0.8 0.8 0.8" />

			<widgetstate statename="listbg">
				<panel height="+{bgoffset=2h}" y="-{bgoffset=2h}" >
					<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="#06447A" />
					<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="#06447A" />
				</panel>
			</widgetstate>
		</combobox>
	</template>

	<template name="test_suite_product_type_combobox" >
		<combobox name="{comboboxName=}" height="{height=100%}" width="{width=}" itemheight="{itemheight=1.5h}" color="invisible" maxlistheight="{maxlistheight=8}" scrolltexture="/ui/test_suite/images/im.tga" taborder="{taborder=-1}" >

			<instance name="test_suite_combobox_state" state="up" color="0 0 0 .5" bordercolor="#A0A0A060" arrowColor="0.8 0.8 0.8" />
			<instance name="test_suite_combobox_state" state="over" color="0 0 0 .5" bordercolor="#A0A0A060" arrowColor="1 1 1" />
			<instance name="test_suite_combobox_state" state="down" color="0 0 0 .5" bordercolor="#A0A0A060" arrowColor="1 1 1" />
			<instance name="test_suite_combobox_state" state="disabled" color="0 0 0 .5" bordercolor="#A0A0A060" arrowColor="0.8 0.8 0.8" />

			<widgetstate statename="listbg">
				<panel height="+{bgoffset=2h}" y="-{bgoffset=2h}" >
					<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 .95" />
					<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="#A0A0A060" />
				</panel>
			</widgetstate>
			
			<listitem value="Bundle" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_bundle" /></listitem>
			<listitem value="Chat Color" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_cc" /></listitem>
			<listitem value="Chat Symbol" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_cs" /></listitem>
			<listitem value="Account Icon" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_ai" /></listitem>
			<listitem value="Alt Avatar" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_aa" /></listitem>
			<listitem value="Alt Announcement" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_av" /></listitem>
			<listitem value="Taunt" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_t" /></listitem>
			<listitem value="Couriers" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_c" /></listitem>
			<listitem value="Hero" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_h" /></listitem>
			<listitem value="EAP" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_eap" /></listitem>
			<listitem value="Status" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_s" /></listitem>
			<listitem value="Ward" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_w" /></listitem>
			<listitem value="Misc" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_misc" /></listitem>
			<listitem value="Enhancement" ><instance name="test_suite_listitem_simple" font="{font=dyn_12}" content="test_client_type_en" /></listitem>
		</combobox>
	</template>

	<template name="test_suite_checkbox" >
		<button name="{checkbox}" x="{x=}" y="{y=}" grow="1" regrow="1" growinvis="0" height="{height=100%}" width="{width=}" color="invisible" align="{align=left}" valign="{valign=top}" numstates="2" cvar="{cvar=}" state="{startenabled=0}" group="{radiogroup=}"
			onclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onclicklua=}
				self:DoEventN(9)
			"
			onevent7lua="{ondisablelua=}"
			onevent9lua="
				local state = self:GetButtonState()

				if (string.len('{radiogroup=}') ~= 0) then
					if ((state == 0) and (not AtoB('{allowradiodisable=false}'))) then
						self:SetButtonState(1)
						return
					end
				end

				if (state == 0) then
					{ondisablelua=}
				else
					if (string.len('{radiogroup=}') ~= 0) then
						local group = self:GetGroup('{radiogroup=}')
						for k,v in ipairs(group) do
							if (v ~= self) then
								if (v:GetButtonState() ~= 0) then
									v:SetButtonState(0)
									v:DoEventN(7)
								end
							end
						end
					end

					{onenablelua=}
				end
			"
			oneventlua="self:DoEventN(8) self:DoEventN(9)"
			onrightclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onrightclicklua=}"
			onmouseoverlua="PlaySound('/ui/test_suite/sounds/button_over_01.ogg') {onmouseoverlua=}"
			onshowlua="self:DoEventN(8) {onshowlua=}"
			onbuttonlua="
				local interfaceName = self:GetInterface():GetName()
				local background = TestSuite.GetWidget('{checkbox}_checkbox_bg', true, interfaceName)
				local frame = TestSuite.GetWidget('{checkbox}_checkbox_frame', true, interfaceName)
				local body = TestSuite.GetWidget('{checkbox}_checkbox_body', true, interfaceName)
				local text = TestSuite.GetWidget('{checkbox}_checkbox_text', true, interfaceName)
				
				if (background and frame and body and text) then
					if ((param0 == 'up') or (param0 == 'downoff') or (param0 == 'downrightoff')) then
						background:SetColor('{upColor=#065294}')
						background:SetBorderColor('{upColor=#065294}')
						frame:SetBorderColor('{upColor=#065294}')
						body:SetX(0) body:SetY(0)
					elseif ((param0 == 'down') or (param0 == 'downright')) then
						background:SetColor('{downColor=#06447A}')
						background:SetBorderColor('{downColor=#06447A}')
						frame:SetBorderColor('{downColor=#06447A}')
						body:SetX(1) body:SetY(1)
					elseif (param0 == 'over') then
						background:SetColor('{overColor=#3A87C9}')
						background:SetBorderColor('{overColor=#3A87C9}')
						frame:SetBorderColor('{overColor=#3A87C9}')
						body:SetX(0) body:SetY(0)
					elseif (param0 == 'disabled') then
						background:SetColor('{disabledColor=#737373}')
						background:SetBorderColor('{disabledColor=#737373}')
						frame:SetBorderColor('{disabledColor=#737373}')
						body:SetX(0) body:SetY(0)
					end
				end
				self:DoEventN(8)
			"
			onevent8lua="
				local interfaceName = self:GetInterface():GetName()
				local state = self:GetButtonState()
				local checkmark = TestSuite.GetWidget('{checkbox}_checkbox_checkmark', true, interfaceName)
				local text = TestSuite.GetWidget('{checkbox}_checkbox_text', true, interfaceName)

				if (text and checkmark) then
					checkmark:SetVisible(state == 1)
					if (state == 0) then
						text:SetColor('white')
					else
						text:SetColor('lime')
					end
				end
			"
		>
			<frame name="{checkbox}_checkbox_bg" texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="{upColor=#065294}" />
			<frame name="{checkbox}_checkbox_frame" texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="{upColor=#065294}" />

			<panel name="{checkbox}_checkbox_body" float="right" grow="1" regrow="1" growinvis="0" height="100%" align="center" >
				<panel width="{iconWidth=100@}" oninstantiatelua="self:SetVisible({showcheck=true})" sticky="1" stickytoinvis="0" clip="1" >
					<panel width="80%" height="80%" align="center" valign="center" noclick="1" >
						<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="white" />
						<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor=".5 .5 .5" />
						<image name="{checkbox}_checkbox_checkmark" y="-1" width="120%" height="120%" align="center" valign="center" color="lime" texture="/ui/test_suite/images/check_mark_white.tga" visible="{startenabled=0}" />
					</panel>
				</panel>

				<panel grow="1" regrow="1" growinvis="0" height="100%" sticky="1" stickytoinvis="0"
					oninstantiatelua="self:SetVisible(Translate('{content}') ~= '')"
				>
					<label name="{checkbox}_checkbox_text" font="{font=dyn_10}" color="white" align="center" textvalign="center" textalign="center" fitxpadding="1h" fitx="1" shadow="1" content="{content}"
						oninstantiatelua="if ({startenabled=0} == 0) then self:SetColor('white') else self:SetColor('lime') end"
					/>
				</panel>
			</panel>
		</button>
	</template>

	<template name="test_suite_basic_checkbox" >
		<button name="{checkbox}" x="{x=}" y="{y=}" height="{height=100%}" width="{width=100%}" color="invisible" align="{align=left}" valign="{valign=top}" numstates="2" cvar="{cvar=}" state="{startenabled=0}"
			onclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onclicklua=}
				local state = self:GetButtonState()
				if (state == 0) then
					{ondisablelua=}
				else
					{onenablelua=}
				end
			"
			onrightclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') {onrightclicklua=}"
			onmouseoverlua="PlaySound('/ui/test_suite/sounds/button_over_01.ogg') {onmouseoverlua=}"
			onshowlua="self:DoEvent()"
			onbuttonlua="
				local interfaceName = self:GetInterface():GetName()
				local body = TestSuite.GetWidget('{checkbox}_checkbox_body', true, interfaceName)
				local background = TestSuite.GetWidget('{checkbox}_checkbox_bg', true, interfaceName)
				
				if (body and background) then
					if ((param0 == 'up') or (param0 == 'downoff') or (param0 == 'downrightoff')) then
						background:SetBorderColor('.85 .85 .85')
						background:SetColor('.85 .85 .85')
						body:SetX(0) body:SetY(0)
					elseif ((param0 == 'down') or (param0 == 'downright')) then
						background:SetBorderColor('white')
						background:SetColor('white')
						body:SetX(1) body:SetY(1)
					elseif (param0 == 'over') then
						background:SetBorderColor('white')
						background:SetColor('white')
						body:SetX(0) body:SetY(0)
					elseif (param0 == 'disabled') then
						background:SetBorderColor('white')
						background:SetColor('white')
						body:SetX(0) body:SetY(0)
					end
				end
				self:DoEvent()
			"
			oneventlua="
				local interfaceName = self:GetInterface():GetName()
				local state = self:GetButtonState()
				local checkmark = TestSuite.GetWidget('{checkbox}_checkbox_checkmark', true, interfaceName)
				if (checkmark) then
					checkmark:SetVisible(state == 1)
				end
			"
		>
			<panel name="{checkbox}_checkbox_body" align="center" valign="center" noclick="1" >
				<frame name="{checkbox}_checkbox_bg" texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color=".85 .85 .85" />
				<frame name="{checkbox}_checkbox_frame" texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor=".5 .5 .5" />
				<image name="{checkbox}_checkbox_checkmark" y="-1" width="+20%" height="+20%" align="center" valign="center" color="lime" texture="/ui/test_suite/images/check_mark_white.tga" visible="{startenabled=0}" />
			</panel>
		</button>
	</template>

	<template name="test_suite_input" >
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" >
			<frame texture="/ui/test_suite/images/tooltip_bg.tga" color="0 0 0 0.5" borderthickness=".6h" />
			<frame texture="/ui/test_suite/images/roundframe.tga" color="#A0A0A060" borderthickness=".6h" />
			<textbox name="{textbox}" font="{font=dyn_12}" width="-0.5h" align="center" color="invisible" textcolor="white" onenter="DoEvent();" inputline="{inputline=}"
				oneventlua="{onenterlua=}"
				onshowlua="{onshowlua=}"
				watch="{watch=}"
				ontriggerlua="{ontriggerlua=}"
				onchangelua="{onchangelua=}"
				taborder="{taborder=-1}"
			/>
		</panel>
	</template>

	<template name="test_suite_slider" >
		<panel width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="1" >
			<panel width="100%" noclick="1"
				oninstantiatelua="
					if (AtoB('{showvalue}')) then
						self:SetWidth('-{valuewidth=17.5%}')
					end
				"
			>
				<frame texture="/ui/test_suite/images/tooltip_bg.tga" color="0 0 0 0.5" borderthickness=".6h" />
				<frame texture="/ui/test_suite/images/roundframe.tga" color="#A0A0A060" borderthickness=".6h" />

				<panel float="right" noclick="1" width="97%" height="97%" valign="center" align="center">
					<label name="{slider}_min_label" font="{font=dyn_10}" shadow="1" color="white" textvalign="center" fitx="1" content="{minlabel=}" sticky="1" />
					<slider name="{slider}" slotwidth="-1%" slotheight="0.6h" slotcolor="{color=#065294}" handlewidth="90@" handleheight="-10%" handlecolor="{color=#1672B4}" cvar="{cvar=}" minvalue="{minvalue=0}" maxvalue="{maxvalue=100}" step="{step=1}" texture="/ui/test_suite/images/slider_white.tga" sticky="1"
						onshowlua="
							local interfaceName = self:GetInterface():GetName()
							local width = TestSuite.GetWidget('{slider}_min_label', true, interfaceName):GetWidth() + TestSuite.GetWidget('{slider}_max_label', true, interfaceName):GetWidth()
							self:SetWidth(self:GetParent():GetWidth() - width)
							TestSuite.GetWidget('{slider}_value_label', true, interfaceName):SetText(string.format('%.{decimals=0}f', self:GetValue())..'{valueappend=}')
							{onshowlua=}
						"
						onselectlua="PlaySound('/ui/test_suite/sounds/button_over_02.ogg') {onselectlua=}"
						onchangelua="PlaySound('/ui/test_suite/sounds/button_over_02.ogg') TestSuite.GetWidget('{slider}_value_label', true, self:GetInterface():GetName()):SetText(string.format('%.{decimals=0}f', self:GetValue())..'{valueappend=}') {onchangelua=}"
						onhidelua="{onhidelua=}"
					/>
					<label name="{slider}_max_label" font="{font=dyn_10}" shadow="1" color="white" textvalign="center" fitx="1" content="{maxlabel=}" sticky="1" />
				</panel>
			</panel>

			<panel width="{valuewidth=17.5%}" align="right" noclick="1" visible="{showvalue=false}" >
				<frame texture="/ui/test_suite/images/tooltip_bg.tga" color="0 0 0 0.5" borderthickness=".6h" />
				<frame texture="/ui/test_suite/images/roundframe.tga" color="#A0A0A060" borderthickness=".6h" />

				<label name="{slider}_value_label" width="95%" height="95%" align="center" valign="center" textvalign="center" textalign="center" shadow="1" font="{font=dyn_10}" color="white" noclick="1" />
			</panel>	
		</panel>
	</template>

	<template name="test_suite_listbox" >
		<listbox name="{listbox}" x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" color="0 0 0 0.5" itemheight="{itemheight=1.5h}" hoverselect="false" hoverhighlight="true" highlight="under" interactive="false" scrollbarsize="{scrollbarsize=1.75h}"
			onshowlua="{onshowlua=}"
			onhidelua="{onhidelua=}"
			scrolltexture="/ui/test_suite/images/im.tga"
			selectedcolor="#00437533"
			onselect="DoEvent();"
			oneventlua="{onselectlua=}"
			onclicklua="{onclicklua=}"
		/>
	</template>

	<template name="test_suite_keybind" >
		<button name="{keybind}_keybind" group="test_suite_keybinds" x="{x=}" y="{y=}" grow="1" regrow="1" growinvis="0" height="{height=100%}" width="{width=}" color="invisible" align="{align=left}" valign="{valign=top}"
			onclicklua="PlaySound('/ui/test_suite/sounds/button_click_01.ogg') self:DoEvent()"
			oneventlua="{onclicklua}
				TestSuite.BeginBind('{bindtable=}', '{action=}', '{param=}', self)
			"
			onrightclicklua="
				PlaySound('/ui/test_suite/sounds/button_click_01.ogg')
				TestSuite.Unbind('{bindtable=}', '{action=}', '{param=}')
				self:DoEventN(9)
				{onrightclicklua}
			"
			onmouseoutlua="{onmouseoutlua}"
			onmouseoverlua="PlaySound('/ui/test_suite/sounds/button_over_01.ogg') {onmouseoverlua}"
			onshowlua="self:DoEventN(9)"
			onrefreshlua="self:DoEventN(9)"
			onevent9lua="
				local interfaceName = self:GetInterface():GetName()
				local text = TestSuite.GetWidget('{keybind}_keybind_text', true, interfaceName)

				if (text) then
					text:SetText(GetKeybindButton('{bindtable=}', '{action=}', '{param=}', 0))
					text:RecalculateSize()
				end
			"
			onbuttonlua="
				local interfaceName = self:GetInterface():GetName()
				local frame = TestSuite.GetWidget('{keybind}_keybind_frame', true, interfaceName)
				local text = TestSuite.GetWidget('{keybind}_keybind_text', true, interfaceName)
				if (frame and text) then
					if ((param0 == 'up') or (param0 == 'downoff') or (param0 == 'downrightoff')) then
						frame:SetBorderColor('0.8 0.8 0.8')
						frame:SetColor('0.8 0.8 0.8')
						text:SetX(0) text:SetY(0)
					elseif ((param0 == 'down') or (param0 == 'downright')) then
						frame:SetBorderColor('0.8 0.8 0.8')
						frame:SetColor('0.8 0.8 0.8')
						text:SetX(1) text:SetY(1)
					elseif (param0 == 'over') then
						frame:SetBorderColor('1.0 1.0 1.0')
						frame:SetColor('1.0 1.0 1.0')
						text:SetX(0) text:SetY(0)
					elseif (param0 == 'disabled') then
						frame:SetBorderColor('0.2 0.2 0.2')
						frame:SetColor('0.2 0.2 0.2')
						text:SetX(0) text:SetY(0)
					end
				end

				self:DoEventN(9)
			"
		>
			<frame name="{keybind}_keybind_frame" texture="/ui/test_suite/images/key.tga" borderthickness="0.6h" color="0.8 0.8 0.8" />

			<panel float="right" grow="{fitbind=0}" regrow="{fitbind=0}" growinvis="0" width="100%" height="100%" align="center" >
				<label name="{keybind}_keybind_text" font="{font=dyn_10}" shadow="1" color="white" align="center" textvalign="center" textalign="center" fitxpadding="1h" fitx="{fitbind=0}" />
			</panel>
		</button>
	</template>

	<!-- The floater for the tip, as a template so it can be included in the templates meant for different interfaces -->
	<template name="test_suite_tip_floater" >
		<floater name="test_suite_tip_floater" x="22" y="-22" grow="1" regrow="1" width="20h" visible="0"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/tooltip_bg.tga" color="0 0 0 .95" borderthickness=".6h" />
			<frame texture="/ui/test_suite/images/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />

			<label name="test_suite_tip_floater_text" textalign="center" shadow="1" textvalign="center" wrap="1" fity="1" fitypadding="1h" font="dyn_10" color="white" />
		</floater>
	</template>

	<!-- The prompt for keybinds, as a template so it can be included in the templates meant for different interfaces -->
	<template name="test_suite_keybind_prompt" >
		<panel name="test_suite_keybind_prompt" align="center" valign="center" width="35h" height="10h" visible="0"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/tooltip_bg.tga" color="0 0 0 .85" borderthickness=".6h" />
			<frame texture="/ui/test_suite/images/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />

			<label textalign="center" textvalign="center" height="8h" wrap="1" font="dyn_16" color="white" content="test_suite_keybind" />

			<panel height="2h" width="-2h" align="center" valign="bottom" y="-1h" noclick="1" >
				<instance name="test_suite_button" button="test_suite_cancel_keybind" width="49%" content="test_suite_cancel_keybind"
					onclicklua="TestSuite.GetWidget('test_suite_keybind_prompt', true, self:GetInterface():GetName()):SetVisible(0)"
				/>
				<instance name="test_suite_button" button="test_suite_clear_keybind" align="right" width="49%" content="test_suite_clear_keybind"
					onclicklua="TestSuite.FinalizeUnbind()"
				/>
			</panel>

			<buttoncatcher name="test_suite_catcher" color="invisible" noclick="1"
				onbuttonlua="TestSuite.FinalizeBind(param0)"
			/>
		</panel>
	</template>
	<!-- End Templates -->


	<!-- Client Test Functionality -->
	<template name="test_suite_client" >
		<panel name="test_suite_client" width="90h" height="60h" align="center" valign="center" cangrab="1" visible="0"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<!-- Tab Bodies -->
			<panel height="95%" valign="bottom" >
				<panel name="test_suite_client_audit" group="test_suite_client_tabs" visible="1" noclick="1" >
					<!-- Audit Buttons -->
					<panel valign="center" x="1.0h" y="1.0h" width="13h" float="bottom" padding="0.5h" >
						<instance name="test_suite_button" button="audit_product_list" width="100%" height="2.5h" content="test_client_audit_product_list"
							onclicklua="TestSuite.AuditLog('') TestSuite.AuditProductList()"
