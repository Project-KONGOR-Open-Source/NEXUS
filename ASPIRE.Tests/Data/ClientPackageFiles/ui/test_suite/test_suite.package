						<panel align="right" valign="bottom" grow="1" float="bottom" padding="0.5h" >
							<panel grow="1" noclick="1" float="right" padding="0.5h" >
								<label font="dyn_12" color="white" content="test_client_mount_world" fity="1" fitx="1" />
								<instance name="test_suite_tip" tip="mount_world" width="100@" content="test_client_mount_world_tip" />
							</panel>

							<instance name="test_suite_combobox" combobox="test_client_world" height="2h"
								populate="
									self:AddTemplateListItem('test_suite_listitem_simple', 'NONE', 'font', 'dyn_10', 'content', Translate('test_client_none'))
									local maps = GetMaps()
									for _,map in ipairs(maps) do
										self:AddTemplateListItem('test_suite_listitem_simple', map, 'font', 'dyn_10', 'content', map)
									end
									self:SetSelectedItemByValue('NONE', false)
								"
								onshowlua="self:DoEvent()"
								watch="GamePhase"
								ontriggerlua="self:DoEvent()"
								oneventlua="
									local currentMap = Testing.GetMountedWorld()
									if (string.len(currentMap) == 0) then
										self:SetSelectedItemByValue('NONE', false)
									else
										self:SetSelectedItemByValue(currentMap, false)
									end
								"
								onselectlua="TestSuite.AuditLog('') TestSuite.MountWorld(self:GetValue())"
							/>
						</panel>
					</panel>

