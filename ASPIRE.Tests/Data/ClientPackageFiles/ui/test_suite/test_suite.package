							onclicklua="TestSuite.AuditLog('') TestSuite.AuditAccountIcons()"
						/>
						<instance name="test_suite_button" button="audit_name_colors" width="100%" height="2.5h" content="test_client_audit_name_colors"
							onclicklua="TestSuite.AuditLog('') TestSuite.AuditNameColors()"
						/>
						<instance name="test_suite_button" button="audit_chat_symbols" width="100%" height="2.5h" content="test_client_audit_chat_symbols"
							onclicklua="TestSuite.AuditLog('') TestSuite.AuditChatSymbols()"
