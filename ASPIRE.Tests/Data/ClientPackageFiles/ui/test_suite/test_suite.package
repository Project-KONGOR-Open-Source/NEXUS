	<!-- Server (Advanced) Test Functionality -->
	<template name="test_suite_server_advanced" >
		<panel name="test_suite_server_advanced_auto_refresh" noclick="1" />
		<panel name="test_suite_server_advanced_track_modifiers" noclick="1" />
		<panel name="test_suite_server_advanced_track_possible_modifiers" noclick="1" />
		<panel name="test_suite_server_advanced_track_global_modifiers" noclick="1" />
		<panel name="test_suite_server_advanced_track_states" noclick="1" />

		<panel name="test_suite_server_advanced" width="75h" height="45h" align="center" valign="center" cangrab="1" visible="0"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<!-- Tab Bodies -->
			<panel height="93.58%" valign="bottom" >
				<panel name="test_suite_server_entities" group="test_suite_server_advanced_tabs" visible="1" noclick="1" >
					<panel width="-1.5h" height="-1.5h" align="center" valign="center" >
						<panel width="31.5%" noclick="1" float="bottom" padding="0.35h" >
							<panel height="2h" noclick="1" >
								<label font="dyn_14" color="white" shadow="1" fitx="1" textvalign="center" content="test_server_units_title" />
								<instance name="test_suite_tip" tip="server_entity_units" align="right" width="100@" content="test_server_entity_tip" />

								<instance name="test_suite_checkbox" checkbox="test_server_adv_all_units" align="right" x="-110@" content="test_server_all_units" startenabled="0" />
							</panel>

							<panel height="2h" noclick="1" >
								<instance name="test_suite_keybind" keybind="server_refresh" fitbind="1" bindtable="game" font="dyn_6" action="Cmd" param="Refresh #GetSelectedEntity()#" />
								<instance name="test_suite_button" button="server_refresh_adv" height="2h" width="-5h" align="right" content="test_server_refresh"
									onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.Refresh(unit) end)"
								/>
							</panel>

							<panel height="2.0h" noclick="1" >
								<panel width="49%" noclick="1" >
									<instance name="test_suite_keybind" keybind="server_kill" fitbind="1" font="dyn_6" bindtable="game" action="Cmd" param="Kill #GetSelectedEntity()#" />
									<instance name="test_suite_button" button="server_adv_kill" width="-5h" align="right" content="test_server_kill"
										onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.Kill(unit) end)"
									/>
								</panel>
								<instance name="test_suite_button" button="server_adv_delete" align="right" width="49%" content="test_server_delete"
									onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.Delete(unit) end)"
								/>
							</panel>

							<panel height="2.0h" noclick="1" >
								<instance name="test_suite_button" button="server_adv_clear_charges" width="49%" content="test_server_clear_charges"
									onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.ClearToolCharges(unit) end)"
								/>
								<instance name="test_suite_button" button="server_adv_max_charges" width="49%" align="right" content="test_server_max_charges"
									onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.MaxToolCharges(unit) end)"
								/>
							</panel>

							<panel height="2.0h" noclick="1" >
								<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_level" />
								<panel grow="1" regrow="1" float="right" align="right" height="100%" padding="0.25h" >
									<instance name="test_suite_button" button="server_adv_level_up" width="100@" content="+"
										onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.LevelUp(unit) end)"
									/>
									<instance name="test_suite_button" button="server_adv_level_reset" width="100@" content="test_server_reset"
										onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.ResetExperience(unit) end)"
									/>
									<instance name="test_suite_button" button="server_adv_level_max" width="100@" content="test_server_max"
										onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.LevelMax(unit) end)"
									/>
								</panel>
							</panel>

							<panel height="2.0h" noclick="1" >
								<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_exp" />
								<instance name="test_suite_input" textbox="test_server_adv_exp_amount" x="-3.25h" width="-10h" align="right" inputline="150" taborder="9031"
									onenterlua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.GiveExperience(unit, self:GetValue()) end)"
								/>
								<instance name="test_suite_button" button="server_adv_exp" align="right" width="100@" content="+"
									onclicklua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.GiveExperience(unit, TestSuite.GetWidget('test_server_adv_exp_amount'):GetValue()) end)"
								/>
							</panel>

							<panel height="2.0h" noclick="1" >
								<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_add_lifetime" />
								<instance name="test_suite_input" textbox="test_server_adv_lifetime_amount" x="-3.25h" width="-12h" align="right" inputline="5000" taborder="9032"
									onenterlua="TestSuite.DoSelectedUnitsAdvanced(function(unit) Testing.AddLifetime(unit, self:GetValue()) end)"
