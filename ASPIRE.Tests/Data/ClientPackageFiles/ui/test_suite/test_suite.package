							onclicklua="TestSuite.AuditLog('') TestSuite.AuditAll()"
						/>
					</panel>
					<!-- Matching tips for the audit buttons -->
					<panel valign="center" x="14.5h" y="1.0h" width="2.0h" float="bottom" padding="0.5h" >
						<instance name="test_suite_tip" tip="audit_product_list" width="2.5h" height="2.5h" content="test_client_audit_product_list_tip" />
						<instance name="test_suite_tip" tip="audit_entity_existance" width="2.5h" height="2.5h" content="test_client_audit_entity_existance_tip" />
						<!-- <instance name="test_suite_tip" tip="audit_entity_usage" width="2.5h" height="2.5h" content="test_client_audit_entity_usage_tip" /> -->
						<instance name="test_suite_tip" tip="audit_heroes_alts" width="2.5h" height="2.5h" content="test_client_audit_heroes_alts_tip" />
						<instance name="test_suite_tip" tip="audit_couriers" width="2.5h" height="2.5h" content="test_client_audit_couriers_tip" />
						<instance name="test_suite_tip" tip="audit_account_icons" width="2.5h" height="2.5h" content="test_client_audit_account_icons_tip" />
						<instance name="test_suite_tip" tip="audit_name_colors" width="2.5h" height="2.5h" content="test_client_audit_name_colors_tip" />
						<instance name="test_suite_tip" tip="audit_chat_symbols" width="2.5h" height="2.5h" content="test_client_audit_chat_symbols_tip" />
						<instance name="test_suite_tip" tip="audit_announcers" width="2.5h" height="2.5h" content="test_client_audit_announcers_tip" />
						<instance name="test_suite_tip" tip="audit_taunts" width="2.5h" height="2.5h" content="test_client_audit_taunts_tip" />
						<instance name="test_suite_tip" tip="audit_wards" width="2.5h" height="2.5h" content="test_client_audit_wards_tip" />
