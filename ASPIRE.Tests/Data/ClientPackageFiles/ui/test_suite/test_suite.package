							<instance name="test_suite_tip" tip="time_offset" width="2.5h" height="2.5h" content="test_client_time_offset_tip" />
							<instance name="test_suite_input" textbox="test_client_time" width="15h" taborder="9000"
								onenterlua="Cmd('ForceSetLocalServerTimeOffset '..self:GetValue())"
							/>
							<label font="dyn_12" color="white" shadow="1" textvalign="center"
								onshowlua="local this = self self:RegisterWatch('HostTime', function() this:DoEvent() end)"
								onhidelua="self:UnregisterWatch('HostTime')"
								oneventlua="
									local currTime = PreciseIntAdd(GetLocalServerTime(), -18000)
									local seconds, minutes, hours, days, months, years = TestSuite.UnixTimestampToNumeralTime(currTime)
									self:SetText(Translate('test_client_time_string')..' '..string.format('%02d/%02d/%04d - %02d:%02d:%02d', months, days, years, hours, minutes, seconds))
								"
							/>
