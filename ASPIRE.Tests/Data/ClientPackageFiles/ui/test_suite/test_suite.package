	<template name="test_suite_animation_viewer" >
		<panel name="test_suite_animation_viewer" width="25h" align="center" valign="center" cangrab="1" visible="0" grow="1" regrow="1"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<panel float="bottom" width="100%" grow="1" regrow="1" noclick="1" >
				<!-- Title -->
				<panel height="3h" noclick="1" >
					<!-- Grab/Drag using this -->
					<panel name="test_server_animation_viewer_title_bar" clip="1" noclick="1" >
						<frame texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.6h" borderthickness="0.6h" color="0.1 0.1 0.1 0.5" noclick="1" />
					</panel>

					<label font="dyn_16" color="white" textvalign="center" x="0.5h" shadow="1" content="test_server_animation_viewer" noclick="1" />

					<panel align="right" x="-12.5@" grow="1" height="75%" valign="center" noclick="1" >
						<instance name="test_suite_button" button="close_server_animation_viewer" icon="/ui/test_suite/images/close_button.tga" upColor="#E81A1A" overColor="#FF5757" downColor="#BA1111"
							onclicklua="TestSuite.GetWidget('test_suite_animation_viewer'):SetVisible(0)"
						/>
					</panel>

					<panel height="1" valign="bottom" color="0 0 0 0.5" />
				</panel>

				<!-- padding -->
				<panel height="2" noclick="1" />

				<!-- Body -->
				<panel width="100%" valign="bottom" grow="1" regrow="1" >
					<panel width="96%" align="center" float="bottom" padding="0.4h" grow="1" regrow="1"	>
						<instance name="test_suite_listbox" listbox="server_anim_list" height="25.5h" itemheight="1.5h"
							onshowlua="
								self:SetCallback('onframe', function(self)
									local anims = Testing.GetAnimationsFromEntity(Testing.GetSelectedEntity())
									local listItems = self:GetListItems()

									for i,value in ipairs(listItems) do
										local found = false
										for k,anim in ipairs(anims) do
											if (anim.name == value) then
												found = true
											end
										end

										if (not found) then
											self:EraseListItemByValue(value)
										end
									end

									if (table.getn(anims) == 0) then
										self:ClearItems()
										self:AddTemplateListItem('test_suite_listitem_simple', '-1', 'font', 'dyn_10', 'content', Translate('test_server_no_anims'))
									else
										for _,v in ipairs(anims) do
											if (not self:HasListItem(v.name)) then
												self:AddTemplateListItem('test_suite_listitem_simple', v.name, 'font', 'dyn_12', 'content', v.name)
											end
										end
									end
								end)
							"
							onhidelua="self:ClearCallback('onframe')"
						/>
						<instance name="test_suite_button" button="server_play_anim" width="100%" content="test_server_play_anim" height="2.5h"
							onclicklua="Testing.PlayAnimation(Testing.GetSelectedEntity(), TestSuite.GetWidget('server_anim_list'):GetValue())"
						/>
					</panel>
				</panel>

				<!-- padding -->
				<panel height="0.5h" width="100%" noclick="1" />
			</panel>
		</panel>
	</template>

	<template name="test_suite_effect_player" >
		<panel name="test_suite_effect_player" width="65h" align="center" valign="center" cangrab="1" visible="0" grow="1" regrow="1"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<panel float="bottom" width="100%" grow="1" regrow="1" noclick="1" >
				<!-- Title -->
				<panel height="3h" noclick="1" >
					<!-- Grab/Drag using this -->
					<panel name="test_server_effect_player_title_bar" clip="1" noclick="1" >
						<frame texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.6h" borderthickness="0.6h" color="0.1 0.1 0.1 0.5" noclick="1" />
					</panel>

					<label font="dyn_16" color="white" textvalign="center" x="0.5h" shadow="1" content="test_server_effect_player" noclick="1" />

					<panel align="right" x="-12.5@" grow="1" height="75%" valign="center" noclick="1" >
						<instance name="test_suite_button" button="close_server_effect_player" icon="/ui/test_suite/images/close_button.tga" upColor="#E81A1A" overColor="#FF5757" downColor="#BA1111"
							onclicklua="TestSuite.GetWidget('test_suite_effect_player'):SetVisible(0)"
						/>
					</panel>

					<panel height="1" valign="bottom" color="0 0 0 0.5" />
				</panel>

				<!-- padding -->
				<panel height="2" noclick="1" />

				<!-- Body -->
				<panel width="100%" valign="bottom" grow="1" regrow="1" >
					<panel width="98%" align="center" float="bottom" padding="0.4h" grow="1" regrow="1"	>
						<panel height="2h" noclick="1" >
							<instance name="test_suite_input" textbox="test_server_effect_search" width="75%"
								onshowlua="self:DoEvent()"
								onchangelua="self:Sleep(250, function(self) self:DoEvent() end)"
								onenterlua="TestSuite.PopulateEffectList(self:GetValue())"
							/>

							<instance name="test_suite_button" button="server_refresh_effects" width="24%" align="right" content="test_server_refresh_effects"
								onclicklua="TestSuite.ForceEffectCacheRebuild() TestSuite.GetWidget('test_server_effect_search'):DoEvent()"
							/>
						</panel>

						<instance name="test_suite_listbox" listbox="server_effect_list" height="20.5h" itemheight="1.5h" />

						<panel height="2h" noclick="1" >
							<panel noclick="1" float="right" padding="0.5h" >
								<label font="dyn_10" color="white" shadow="1" textvalign="center" content="test_server_effect_target" noclick="1" fitx="1" />
								<instance name="test_suite_input" textbox="test_server_effect_target" width="10h" />
								<instance name="test_suite_button" button="server_effect_target_use_selected" content="test_server_use_selected"
									onclicklua="TestSuite.GetWidget('test_server_effect_target'):SetInputLine(Testing.GetSelectedEntity())"
								/>
							</panel>

							<instance name="test_suite_tip" tip="effect_player_options" width="100@" align="right" content="test_server_effect_player_tip" />
						</panel>

						<panel height="2h" noclick="1" >
							<panel noclick="1" float="right" padding="0.5h" >
								<label font="dyn_10" color="white" shadow="1" textvalign="center" content="test_server_effect_source" noclick="1" fitx="1" />
								<instance name="test_suite_input" textbox="test_server_effect_source" width="10h" />
								<instance name="test_suite_button" button="server_effect_source_use_selected" content="test_server_use_selected"
									onclicklua="TestSuite.GetWidget('test_server_effect_source'):SetInputLine(Testing.GetSelectedEntity())"
								/>
							</panel>

							<panel float="right" padding="0.5h" height="2h" grow="1" align="right" >
								<label font="dyn_10" color="white" shadow="1" textvalign="center" content="test_server_effet_lifetime" noclick="1" fitx="1" />
								<instance name="test_suite_input" textbox="test_server_effect_lifetime" inputline="10000" width="10h" />

								<panel width="2h" noclick="1" /> <!-- Padding -->

								<instance name="test_suite_checkbox" checkbox="test_server_effect_ignore_cull" align="right" content="test_server_ignore_culling" />
							</panel>
						</panel>

						<instance name="test_suite_button" button="server_play_effect" width="100%" content="test_server_play_effect" height="2.5h"
							onclicklua="
								local lifetime = TestSuite.GetWidget('test_server_effect_lifetime'):GetValue()
								if (string.len(lifetime) == 0) then lifetime = -1 end

								local target = TestSuite.GetWidget('test_server_effect_target'):GetValue()
								if (string.len(target) == 0) then target = 0 end

								local source = TestSuite.GetWidget('test_server_effect_source'):GetValue()
								if (string.len(source) == 0) then source = 0 end

								Testing.PlayEffect(
									TestSuite.GetWidget('server_effect_list'):GetValue(),
									target,
									source,
									lifetime,
									TestSuite.CheckboxEnabled('test_server_effect_ignore_cull')
								)
							"
						/>
					</panel>
				</panel>

				<!-- padding -->
				<panel height="0.5h" width="100%" noclick="1" />
			</panel>
		</panel>
	</template>
	<!-- End Server (Advanced) Test Functionality -->

	<!-- Cinema Mode Extra Functionality -->
	<template name="test_suite_cinema_mode_replay_panel" >
		<panel name="test_suite_cinema_mode_replay_panel" width="25h" align="center" valign="center" cangrab="1" visible="0" grow="1" regrow="1"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<panel float="bottom" width="100%" grow="1" regrow="1" noclick="1" >
				<!-- Title -->
				<panel height="3h" noclick="1" >
					<!-- Grab/Drag using this -->
					<panel name="test_cinema_mode_replay_panel_title_bar" clip="1" noclick="1" >
						<frame texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.6h" borderthickness="0.6h" color="0.1 0.1 0.1 0.5" noclick="1" />
					</panel>

					<label font="dyn_16" color="white" textvalign="center" x="0.5h" shadow="1" content="test_server_camera_options" noclick="1" />

					<panel align="right" x="-12.5@" grow="1" height="75%" valign="center" noclick="1" >
						<instance name="test_suite_button" button="close_cinema_replay_options" icon="/ui/test_suite/images/close_button.tga" upColor="#E81A1A" overColor="#FF5757" downColor="#BA1111"
							onclicklua="TestSuite.GetWidget('test_suite_cinema_mode_replay_panel'):SetVisible(0)"
						/>
					</panel>

					<panel height="1" valign="bottom" color="0 0 0 0.5" />
				</panel>

				<!-- padding -->
				<panel height="2" noclick="1" />

				<!-- Body -->
				<panel width="95%" align="center" float="bottom" padding="0.4h" grow="1" regrow="1" >
					<instance name="test_suite_checkbox" checkbox="test_cinema_camera_mode" content="test_server_free_flight_cam" width="100%" height="2h"
						cvar="cam_mode"
					/>
					<instance name="test_suite_checkbox" checkbox="test_cinema_camera_smoothing" content="test_server_cam_smoothing" width="100%" height="2h"
						cvar="cg_cameraSmoothing"
					/>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_pos_smoothing" />
							<instance name="test_suite_button" button="cinema_reset_pos_smoothing" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('cam_smoothPositionHalfLife'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_position_smoothing" height="2h" minvalue="0.00" maxvalue="1.50" step="0.01" showvalue="1" decimals="2" valuewidth="20%" cvar="cam_smoothPositionHalfLife" />
					</panel>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_angle_smoothing" />
							<instance name="test_suite_button" button="cinema_reset_angle_smoothing" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('cam_smoothAnglesHalfLife'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_angle_smoothing" height="2h" minvalue="0.00" maxvalue="1.50" step="0.01" showvalue="1" decimals="2" valuewidth="20%" cvar="cam_smoothAnglesHalfLife" />
					</panel>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_fly_speed" />
							<instance name="test_suite_button" button="cinema_reset_fly_speed" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('cam_flySpeed'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_fly_speed" height="2h" minvalue="150" maxvalue="9950" step="50" showvalue="1" valuewidth="21%" cvar="cam_flySpeed" />
					</panel>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_scroll_speed" />
							<instance name="test_suite_button" button="cinema_reset_scroll_speed" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('cam_scrollSpeed'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_scroll_speed" height="2h" minvalue="150" maxvalue="9950" step="50" showvalue="1" valuewidth="21%" cvar="cam_scrollSpeed" />
					</panel>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_cam_fov" />
							<instance name="test_suite_button" button="cinema_reset_fov" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('g_camfov'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_fov" height="2h" minvalue="20" maxvalue="150" step=".01" showvalue="1" decimals="2" valuewidth="25%" cvar="g_camfov" />
					</panel>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_entity_cull_range" />
							<instance name="test_suite_button" button="cinema_reset_cull_range" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('cg_entityCullRange'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_cull_range" height="2h" minvalue="500" maxvalue="50000" step="250" showvalue="1" valuewidth="25%" cvar="cg_entityCullRange" />
					</panel>

					<panel height="3.5h" noclick="1" float="bottom" padding="1" >
						<panel height="1.5h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_cam_foliage_dis" />
							<instance name="test_suite_button" button="cinema_reset_foliage_distance" align="right" content="test_server_reset" font="dyn_8"
								onclicklua="Cvar.GetCvar('scene_foliageDrawDistance'):Reset()"
							/>
						</panel>
						<instance name="test_suite_slider" slider="test_cinema_foliage_distance" height="2h" minvalue="500" maxvalue="50000" step="250" showvalue="1" valuewidth="25%" cvar="scene_foliageDrawDistance" />
					</panel>

					<instance name="test_suite_checkbox" checkbox="test_cinema_camera_map_constraint" content="test_server_cam_map_constrain" width="100%" height="2h"
						cvar="cam_mapConstraints"
					/>

					<!-- padding -->
					<panel height="0.2h" width="100%" noclick="1" />
				</panel>
			</panel>
		</panel>
	</template>

	<!-- End Cinema Mode Extra Functionality -->

</package>