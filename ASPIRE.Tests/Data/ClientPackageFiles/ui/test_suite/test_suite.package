									<panel height="2.0h" float="right" noclick="1" >
										<label font="dyn_10" height="2.0h" width="9.5h" shadow="1" color="white" textvalign="center" content="test_client_list_dynamic" />
										<instance name="test_suite_input" textbox="test_client_product_list_dynamic" font="dyn_10" width="-9.5h" />
									</panel>
								</panel>
							</panel>
						</panel>
					</panel>
				</panel>

				<!-- <panel name="test_suite_client_models" group="test_suite_client_tabs" visible="0" noclick="1" >
				</panel> -->
			</panel>

			<!-- Tabs -->
			<panel height="5%" noclick="1" >
				<!-- Grab/Drag using this -->
				<panel name="test_client_title_bar" clip="1" noclick="1" >
					<frame texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.6h" borderthickness="0.6h" color="0.1 0.1 0.1 0.5" noclick="1" />
				</panel>

				<panel x="0.25h" float="right" valign="bottom" height="75%" noclick="1" padding="0.25h" >
					<instance name="test_suite_tab" tab="audit" content="test_client_audit" icon="/ui/test_suite/images/audit.tga"
						onclicklua="self:ShowOnly('test_suite_client_audit')"
					/>
					<instance name="test_suite_tab" tab="general" content="test_client_general"
						onclicklua="self:ShowOnly('test_suite_client_general')"
					/>
					<!-- <instance name="test_suite_tab" tab="test3" content="test_client_models"
						onclicklua="self:ShowOnly('test_suite_client_models')"
					/> -->
				</panel>

				<label font="dyn_16" content="test_suite_title" color="white" shadow="1" noclick="1" fitx="1" align="right" textvalign="center" fitxpadding="125@" />

				<panel align="right" x="-12.5@" grow="1" height="75%" valign="center" noclick="1" >
					<instance name="test_suite_button" button="close" icon="/ui/test_suite/images/close_button.tga" upColor="#E81A1A" overColor="#FF5757" downColor="#BA1111"
						onclicklua="TestSuite.GetWidget('test_suite_client'):SetVisible(0)"
					/>
				</panel>

				<panel height="1" valign="bottom" color="0 0 0 0.5" />
			</panel>

			<panel name="test_suite_client_progress_cover" visible="0" >
				<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 0.5" noclick="1" />
				<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

				<label name="test_suite_client_progress_title" font="dyn_18" height="10h" valign="center" textalign="center" color="white" shadow="1" noclick="1" />
				<panel noclick="1" width="75%" align="center" height="3h" valign="center" color="0 0 0 0.75" >
					<panel name="test_suite_client_progress_bar" width="0%" texture="/ui/test_suite/images/grad_vert.tga" color=".7 .7 .7 .5" noclick="1" />
					<label name="test_suite_client_progress_percent" font="dyn_16" textvalign="center" textalign="center" color="white" shadow="1" noclick="1" />
					<label name="test_suite_client_progress_count" x="-1h" font="dyn_10" textvalign="center" textalign="right" color="white" shadow="1" noclick="1" />
				</panel>

				<instance name="test_suite_button" button="cancel_progress" valign="center" align="center" y="4h" height="2.5h" content="test_client_cancel"
					onclicklua="TestSuite.CancelClientOperation()"
				/>
			</panel>
		</panel>
	</template>
	<!-- End Client Test Functionality -->

	<!-- Server (Basic- meant to be like the original Test++) Test Functionality -->
	<template name="test_suite_server_basic" >
		<panel name="test_suite_server_basic_auto_refresh" noclick="1" />

		<panel name="test_suite_server_basic" width="27h" x="3h" y="-5h" valign="center" cangrab="1" visible="0" grow="1" regrow="1"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<panel float="bottom" grow="1" regrow="1" width="100%" noclick="1" >
				<!-- Title -->
				<panel height="3.0h" noclick="1" >
					<!-- Grab/Drag using this -->
					<panel name="test_server_basic_title_bar" clip="1" noclick="1" >
						<frame texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.6h" borderthickness="0.6h" color="0.1 0.1 0.1 0.5" noclick="1" />
					</panel>

					<label font="dyn_16" color="white" textvalign="center" x="0.5h" shadow="1" content="test_suite_title" noclick="1" />

					<panel width="25%" align="right" valign="center" x="-125@" height="60%" grow="1"
						watch="EventEnterGame GamePhase"
						ontriggerlua="self:SetVisible(TestSuite.ServerAdvancedAccessible())"
					>
						<instance name="test_suite_button" button="server_go_advanced"  content="test_server_go_advanced" font="dyn_8"
							onclicklua="TestSuite.GetWidget('test_suite_server_advanced'):SetVisible(1)"
						/>
					</panel>

					<panel align="right" x="-12.5@" grow="1" height="75%" valign="center" noclick="1" >
						<instance name="test_suite_button" button="close_server_basic" icon="/ui/test_suite/images/close_button.tga" upColor="#E81A1A" overColor="#FF5757" downColor="#BA1111"
							onclicklua="TestSuite.GetWidget('test_suite_server_basic'):SetVisible(0)"
						/>
					</panel>

					<panel height="1" valign="bottom" color="0 0 0 0.5" />
				</panel>

				<!-- padding -->
				<panel height="2" noclick="1" />

				<!-- Body -->
				<panel valign="bottom" width="100%" grow="1" regrow="1" >
					<panel height="-0.8h" grow="1" regrow="1" valign="center" width="95%" align="center" float="bottom" padding="0.35h" >
						<panel height="2h" noclick="1" >
							<label font="dyn_12" color="white" height="2h" shadow="1" content="test_server_units" noclick="1" />
							<instance name="test_suite_checkbox" checkbox="test_server_all_units" align="right" x="-2.25h" height="2h" content="test_server_all_units" startenabled="0" />
							<instance name="test_suite_tip" tip="selected_units" width="2.0h" height="2.0h" align="right" content="test_server_units_tip" />
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_button" button="server_refresh" width="49%" content="test_server_refresh"
								onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.Refresh(unit) end)"
							/>
							<instance name="test_suite_checkbox" checkbox="test_server_auto_refresh" width="49%" align="right" content="test_server_auto_refresh"
								onclicklua="TestSuite.SetAutoRefresh(self:GetButtonState() == 1)"
							/>
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_button" button="server_kill" width="49%" content="test_server_kill"
								onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.Kill(unit) end)"
							/>
							<instance name="test_suite_button" button="server_delete" align="right" width="49%" content="test_server_delete"
								onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.Delete(unit) end)"
							/>
						</panel>

						<panel height="2.0h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_exp" />
							<instance name="test_suite_input" textbox="test_server_exp_amount" x="-3.25h" width="-10h" align="right" inputline="2000"
								onenterlua="TestSuite.DoSelectedUnits(function(unit) Testing.GiveExperience(unit, self:GetValue()) end)"
							/>
							<instance name="test_suite_button" button="server_exp" align="right" width="100@" content="+"
								onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.GiveExperience(unit, TestSuite.GetWidget('test_server_exp_amount'):GetValue()) end)"
							/>
						</panel>

						<panel height="2.0h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_level" />
							<panel grow="1" regrow="1" float="right" align="right" height="100%" padding="0.25h" >
								<instance name="test_suite_button" button="server_level_up" width="100@" content="+"
									onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.LevelUp(unit) end)"
								/>
								<instance name="test_suite_button" button="server_level_reset" width="100@" content="test_server_reset"
									onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.ResetExperience(unit) end)"
								/>
								<instance name="test_suite_button" button="server_level_max" width="100@" content="test_server_max"
									onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.LevelMax(unit) end)"
								/>
							</panel>
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_button" button="server_clear_charges" width="49%" content="test_server_clear_charges"
								onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.ClearToolCharges(unit) end)"
							/>
							<instance name="test_suite_button" button="server_max_charges" width="49%" align="right" content="test_server_max_charges"
								onclicklua="TestSuite.DoSelectedUnits(function(unit) Testing.MaxToolCharges(unit) end)"
							/>
						</panel>

						<panel height="2" noclick="1" float="bottom">
							<panel height="1" width="+0.75h" align="center" color="0.6 0.6 0.6 0.8" noclick="1" />
							<panel height="1" width="+0.75h" align="center" color="0.4 0.4 0.4 0.8" noclick="1" />
						</panel>

						<panel height="2.0h" noclick="1" >
							<label font="dyn_10" color="white" shadow="1" noclick="1" textvalign="center" content="test_server_gold" />
							
							<panel align="right" noclick="1" float="right" height="100%" grow="1" padding="0.25h" >
								<instance name="test_suite_input" textbox="test_server_gold_amount" width="10h" inputline="15000"
									onenterlua="Testing.GiveGold(GetLocalClientNumber(), self:GetValue())"
								/>
								<instance name="test_suite_button" button="server_gold" width="100@" content="+"
									onclicklua="Testing.GiveGold(GetLocalClientNumber(), TestSuite.GetWidget('test_server_gold_amount'):GetValue())"
								/>
								<instance name="test_suite_button" button="server_gold_603" width="100@" content="603"
									onclicklua="Testing.TakeGold(GetLocalClientNumber(), 65535) Testing.GiveGold(GetLocalClientNumber(), 603)"
								/>
								<instance name="test_suite_button" button="server_gold_853" width="100@" content="853"
									onclicklua="Testing.TakeGold(GetLocalClientNumber(), 65535) Testing.GiveGold(GetLocalClientNumber(), 853)"
								/>
							</panel>
						</panel>

						<label height="1.5h" font="dyn_10" shadow="1" color="white" textalign="center" textvalign="center" content="test_server_join_team" noclick="1" />
						<panel height="2h" noclick="1" >
							<panel grow="1" float="right" height="100%" align="center" padding=".25h" >
								<instance name="test_suite_button" button="test_server_team1" font="dyn_10" content="test_server_team1"
									onclicklua="Testing.SetClientTeam(GetLocalClientNumber(), 1)"
								/>
								<instance name="test_suite_button" button="test_server_team2" font="dyn_10" content="test_server_team2"
									onclicklua="Testing.SetClientTeam(GetLocalClientNumber(), 2)"
								/>
								<!-- <instance name="test_suite_button" button="test_server_team_neutral" font="dyn_8" content="test_server_team_neutral"
									onclicklua="Testing.SetClientTeam(GetLocalClientNumber(), -2)"
								/> -->
								<instance name="test_suite_button" button="test_server_team0" font="dyn_10" content="test_server_team0"
									onclicklua="
										local teamsWillBeEmpty = true
										local players = Testing.GetPlayers()
										for _,player in ipairs(players) do
											if (((player.teamID == 1) or (player.teamID == 2)) and (player.clientNumber ~= GetLocalClientNumber())) then
												teamsWillBeEmpty = false
												break
											end
										end

										if (teamsWillBeEmpty) then
											Testing.AddFakePlayer(1)
										end
										Testing.SetClientTeam(GetLocalClientNumber(), 0)
									"
								/>
							</panel>
						</panel>

						<panel height="2h" noclick="1" >
							<instance name="test_suite_button" button="server_respawn_hero" content="test_server_respawn_hero" width="49%" font="dyn_8"
								onclicklua="Testing.RespawnPlayerHero(GetLocalClientNumber())"
							/>

							<instance name="test_suite_button" button="server_respawn_set_hero" content="test_server_set_hero" align="right" width="49%" font="dyn_8"
								onclicklua="Testing.SetPlayerHero(GetLocalClientNumber(), Testing.GetSelectedEntity())"
							/>
						</panel>

						<instance name="test_suite_button" button="server_respawn_all_heroes" content="test_server_respawn_heroes" height="2h" font="dyn_10" width="100%"
							onclicklua="Testing.RespawnAllHeroes()"
						/>

						<panel height="2" noclick="1" float="bottom">
							<panel height="1" width="+0.75h" align="center" color="0.6 0.6 0.6 0.8" noclick="1" />
							<panel height="1" width="+0.75h" align="center" color="0.4 0.4 0.4 0.8" noclick="1" />
						</panel>

						<panel height="2.0h" noclick="1" float="right" padding="2" >
							<label font="dyn_10" color="white" width="40%" shadow="1" noclick="1" textvalign="center" content="test_server_creeps" />
							<instance name="test_suite_basic_checkbox" checkbox="test_server_creeps" width="100@" cvar="sv_spawnCreeps" />
							<instance name="test_suite_button" button="server_spawn_creeps" align="right" width="24.5%" content="test_server_spawn"
								onclicklua="Testing.SpawnCreeps()"
							/>
							<instance name="test_suite_button" button="server_kill_creeps" align="right" width="24.5%" content="test_server_kill"
								onclicklua="Testing.KillCreeps()"
							/>
						</panel>
						<panel height="2.0h" noclick="1" float="right" padding="2" >
							<label font="dyn_10" color="white" width="40%" shadow="1" noclick="1" textvalign="center" content="test_server_powerups" />
							<instance name="test_suite_basic_checkbox" checkbox="test_server_powerups" width="100@" cvar="sv_spawnPowerups" />
							<instance name="test_suite_button" button="test_server_powerups" align="right" width="24.5%" content="test_server_spawn"
								onclicklua="Testing.SpawnPowerups()"
							/>
							<instance name="test_suite_button" button="server_remove_powerups" align="right" width="24.5%" content="test_server_remove"
								onclicklua="Testing.RemovePowerups()"
							/>
						</panel>
						<panel height="2.0h" noclick="1" float="right" padding="2" >
							<label font="dyn_10" color="white" width="40%" shadow="1" noclick="1" textvalign="center" content="test_server_trees" />
							<instance name="test_suite_basic_checkbox" checkbox="test_server_trees" width="100@" cvar="sv_spawnTrees" />
							<instance name="test_suite_button" button="server_spawn_trees" align="right" width="24.5%" content="test_server_spawn"
								onclicklua="Testing.SpawnTrees()"
							/>
							<instance name="test_suite_button" button="server_kill_trees" align="right" width="24.5%" content="test_server_kill"
								onclicklua="Testing.KillTrees()"
							/>
						</panel>
						<panel height="2.0h" noclick="1" float="right" padding="2" >
							<label font="dyn_10" color="white" width="40%" shadow="1" noclick="1" textvalign="center" content="test_server_critters" />
							<instance name="test_suite_basic_checkbox" checkbox="test_server_critters" width="100@" cvar="sv_spawnCritters" />
							<instance name="test_suite_button" button="test_server_critters" align="right" width="24.5%" content="test_server_spawn"
								onclicklua="Testing.SpawnCritters()"
							/>
							<instance name="test_suite_button" button="server_kill_critters" align="right" width="24.5%" content="test_server_kill"
								onclicklua="Testing.KillCritters()"
							/>
						</panel>
						<panel height="2.0h" noclick="1" float="right" padding="2" >
							<label font="dyn_10" color="white" width="40%" shadow="1" noclick="1" textvalign="center" content="test_server_neutrals" />
							<instance name="test_suite_basic_checkbox" checkbox="test_server_neutrals" width="100@" cvar="g_spawnNeutrals" />
							<instance name="test_suite_button" button="test_server_neutrals" align="right" width="24.5%" content="test_server_spawn"
								onclicklua="
									local neutralCvar = Cvar.GetCvar('g_spawnNeutrals')
									local old = neutralCvar:GetString()
									neutralCvar:Set('true')

									Testing.SpawnNeutrals()

									neutralCvar:Set(old)
								"
							/>
							<instance name="test_suite_button" button="server_kill_neutrals" align="right" width="24.5%" content="test_server_kill"
								onclicklua="Testing.KillNeutrals()" height="4.35h"
							/>
						</panel>
						<panel height="2.0h" noclick="1" float="right" padding="2" >
							<label font="dyn_10" color="white" width="40%" shadow="1" noclick="1" textvalign="center" content="test_server_bosses" />
							<instance name="test_suite_basic_checkbox" checkbox="test_server_bosses" width="100@" cvar="g_spawnBosses" />
							<instance name="test_suite_button" button="test_server_bosses" align="right" width="24.5%" content="test_server_spawn"
								onclicklua="
									local bossCvar = Cvar.GetCvar('g_spawnBosses')
									local old = bossCvar:GetString()
									bossCvar:Set('true')

									Testing.SpawnBosses()

									bossCvar:Set(old)
								"
							/>
						</panel>
						<!-- <instance name="test_suite_button" button="server_kill_neutrals" content="test_server_kill_neutrals" width="100%" height="2h"
							onclicklua="Testing.KillNeutrals()"
						/> -->

						<panel height="2" noclick="1" float="bottom">
							<panel height="1" width="+0.75h" align="center" color="0.6 0.6 0.6 0.8" noclick="1" />
							<panel height="1" width="+0.75h" align="center" color="0.4 0.4 0.4 0.8" noclick="1" />
						</panel>

						<instance name="test_suite_checkbox" checkbox="test_server_fog_of_war" content="test_server_fow" width="100%" height="2h" cvar="g_disableFogOfWar" />
						<instance name="test_suite_checkbox" checkbox="test_server_cam_distance" content="test_server_cam_distance" width="100%" height="2h"
							ondisablelua="Cvar.GetCvar('g_camDistanceMax'):Reset() Cvar.GetCvar('g_camDistanceMin'):Reset() Cvar.GetCvar('g_camDistanceMaxSpectator'):Reset()"
							onenablelua="Cvar.GetCvar('g_camDistanceMax'):Set('5000.0') Cvar.GetCvar('g_camDistanceMin'):Set('250.0') Cvar.GetCvar('g_camDistanceMaxSpectator'):Set('5000.0')"
						/>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_checkbox" font="dyn_8" checkbox="test_server_max_hpmp" width="39%" content="test_server_max_hpmp"
								onenablelua="
									Cvar.GetCvar('hero_hpPerStr'):Set('250')
									Cvar.GetCvar('hero_mpPerInt'):Set('250')
								"
								ondisablelua="
									Cvar.GetCvar('hero_hpPerStr'):Reset()
									Cvar.GetCvar('hero_mpPerInt'):Reset()
								"
							/>
							<instance name="test_suite_checkbox" font="dyn_8" checkbox="test_server_max_attackspeed" width="59%" align="right" content="test_server_max_attackspeed"
								onenablelua="Cvar.GetCvar('hero_attackSpeedPerAgi'):Set('250')"
								ondisablelua="Cvar.GetCvar('hero_attackSpeedPerAgi'):Reset()"
							/>
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_checkbox" font="dyn_8" checkbox="test_server_max_regen" width="44%" content="test_server_max_regen"
								onenablelua="
									Cvar.GetCvar('hero_hpRegenPerStr'):Set('250')
									Cvar.GetCvar('hero_mpRegenPerInt'):Set('250')
								"
								ondisablelua="
									Cvar.GetCvar('hero_hpRegenPerStr'):Reset()
									Cvar.GetCvar('hero_mpRegenPerInt'):Reset()
								"
							/>
							<instance name="test_suite_checkbox" font="dyn_8" checkbox="test_server_max_movespeed" width="54%" align="right" content="test_server_max_movespeed"
								onenablelua="Cvar.GetCvar('g_unitMoveSpeedMin'):Set('2500')"
								ondisablelua="Cvar.GetCvar('g_unitMoveSpeedMin'):Reset()"
							/>
						</panel>

						<panel height="2" noclick="1" float="bottom">
							<panel height="1" width="+0.75h" align="center" color="0.6 0.6 0.6 0.8" noclick="1" />
							<panel height="1" width="+0.75h" align="center" color="0.4 0.4 0.4 0.8" noclick="1" />
						</panel>

						<label height="1.5h" font="dyn_10" shadow="1" color="white" textalign="center" textvalign="center" content="test_server_game_speed" noclick="1" />

						<panel height="2.0h" noclick="1" >
							<panel grow="1" float="right" height="100%" align="center" padding="1" >
								<instance name="test_suite_button" button="server_speed_10" font="dyn_7" content="10%"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('0.1')"
								/>
								<instance name="test_suite_button" button="server_speed_25" font="dyn_7" content="25%"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('0.25')"
								/>
								<instance name="test_suite_button" button="server_speed_50" font="dyn_7" content="50%"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('0.5')"
								/>
								<instance name="test_suite_button" button="server_speed_100" font="dyn_7" content="100%"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('1.0')"
								/>
								<instance name="test_suite_button" button="server_speed_200" font="dyn_7" content="200%"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('2.0')"
								/>
								<instance name="test_suite_button" button="server_speed_500" font="dyn_7" content="500%"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('5.0')"
								/>
								<instance name="test_suite_button" button="server_speed_MAX" font="dyn_7" content="test_server_max"
									onclicklua="Cvar.GetCvar('host_timeScale'):Set('100.0')"
								/>
							</panel>
						</panel>

						<label height="1.5h" font="dyn_10" shadow="1" color="white" textalign="center" textvalign="center" content="test_server_time" noclick="1" />

						<panel height="2.0h" noclick="1" >
							<panel grow="1" float="right" height="100%" align="center" padding="1" >
								<instance name="test_suite_button" button="server_time_5s" font="dyn_9" content="+5s"
									onclicklua="Testing.AdjustServerTime(5000)"
								/>
								<instance name="test_suite_button" button="server_time_10s" font="dyn_9" content="+10s"
									onclicklua="Testing.AdjustServerTime(10000)"
								/>
								<instance name="test_suite_button" button="server_time_30s" font="dyn_9" content="+30s"
									onclicklua="Testing.AdjustServerTime(30000)"
								/>
								<instance name="test_suite_button" button="server_time_1m" font="dyn_9" content="+1m"
									onclicklua="Testing.AdjustServerTime(60000)"
								/>
								<instance name="test_suite_button" button="server_time_5m" font="dyn_9" content="+5m"
									onclicklua="Testing.AdjustServerTime(300000)"
								/>
								<instance name="test_suite_button" button="server_time10m" font="dyn_9" content="+10m"
									onclicklua="Testing.AdjustServerTime(600000)"
								/>
							</panel>
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_checkbox" checkbox="test_server_game_pause" showcheck="false" width="49%" content="test_server_pause"
								onenablelua="Testing.SetServerPause(true)"
								ondisablelua="Testing.SetServerPause(false)"
							/>
							<instance name="test_suite_checkbox" checkbox="test_server_day_freeze" showcheck="false" width="49%" align="right" content="test_server_day_freeze"
								onenablelua="Testing.PauseDayNightCycle(true)"
								ondisablelua="Testing.PauseDayNightCycle(false)"
							/>
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_button" button="server_push_daynight" width="49%" content="test_server_advanced_dawn" font="dyn_8"
								onclicklua="Testing.SetTimeOfDawn(Testing.GetTimeOfDawn() + (Cvar.GetCvar('g_dayLength'):GetNumber() / 25.0))"
							/>
							<instance name="test_suite_button" button="server_toggle_daynight" width="49%" align="right" content="test_server_day_toggle" font="dyn_8"
								onclicklua="Testing.ToggleDayNight()"
							/>
						</panel>
						
						<panel height="2" noclick="1" float="bottom">
							<panel height="1" width="+0.75h" align="center" color="0.6 0.6 0.6 0.8" noclick="1" />
							<panel height="1" width="+0.75h" align="center" color="0.4 0.4 0.4 0.8" noclick="1" />
						</panel>

						<instance name="test_suite_input" textbox="test_server_replay_name" height="2h" inputline="unnamedReplay"
							onenterlua="
								local recordButton = TestSuite.GetWidget('test_server_replay_record')
								local state = recordButton:GetButtonState()
								if (state == 0) then
									recordButton:SetButtonState(1)
									recordButton:DoEvent()
								end
							"
						/>
						<instance name="test_suite_checkbox" checkbox="test_server_replay_record" height="2h" width="100%" content="test_server_replay_record" showcheck="0"
							onenablelua="
								GameMessage(Translate('test_server_record_start'))
								Cvar.CreateCvar('cg_replayPrecacheAll', 'bool', 'true')
								Testing.ReplayRecordStart(TestSuite.AppendDateTime(TestSuite.GetWidget('test_server_replay_name'):GetValue(), '.honreplay'))
							"
							ondisablelua="
								GameMessage(Translate('test_server_record_end'))
								Testing.ReplayRecordStop()
							"
						/>

						<panel height="2" noclick="1" float="bottom">
							<panel height="1" width="+0.75h" align="center" color="0.6 0.6 0.6 0.8" noclick="1" />
							<panel height="1" width="+0.75h" align="center" color="0.4 0.4 0.4 0.8" noclick="1" />
						</panel>

						<panel height="2.0h" noclick="1" >
							<instance name="test_suite_button" button="server_entity_spawner" width="49%" content="test_server_entities"
								onclicklua="TestSuite.GetWidget('test_suite_basic_spawner'):ToggleVisible()"
							/>
							<instance name="test_suite_button" button="server_item_spawner" width="49%" align="right" content="test_server_items"
								onclicklua="TestSuite.GetWidget('test_suite_basic_items'):ToggleVisible()"
							/>
						</panel>
					</panel>
				</panel>

				<!-- padding -->
				<panel height="0.5h" width="100%" noclick="1" />
			</panel>
		</panel>
	</template>

	<template name="test_suite_basic_items" >
		<panel name="test_suite_basic_items" width="30h" x="35h" valign="center" cangrab="1" visible="0" grow="1" regrow="1"
			onclicklua="self:BringToFront()"
			onshowlua="self:BringToFront()"
		>
			<frame texture="/ui/test_suite/images/rounded_bg_white.tga" borderthickness="0.6h" color="0.2 0.2 0.2 0.9" noclick="1" />
			<frame texture="/ui/test_suite/images/roundframe.tga" borderthickness="0.6h" bordercolor="0 0 0 0.9" noclick="1" />

			<panel float="bottom" width="100%" grow="1" regrow="1" noclick="1" >
				<!-- Title -->
				<panel height="3h" noclick="1" >
					<!-- Grab/Drag using this -->
					<panel name="test_server_basic_items_title_bar" clip="1" noclick="1" >
						<frame texture="/ui/test_suite/images/rounded_bg_white.tga" height="+0.6h" borderthickness="0.6h" color="0.1 0.1 0.1 0.5" noclick="1" />
					</panel>

					<label font="dyn_16" color="white" textvalign="center" x="0.5h" shadow="1" content="test_suite_title_items" noclick="1" />

					<panel align="right" x="-12.5@" grow="1" height="75%" valign="center" noclick="1" >
						<instance name="test_suite_button" button="close_server_basic_items" icon="/ui/test_suite/images/close_button.tga" upColor="#E81A1A" overColor="#FF5757" downColor="#BA1111"
							onclicklua="TestSuite.GetWidget('test_suite_basic_items'):SetVisible(0)"
						/>
					</panel>

					<panel height="1" valign="bottom" color="0 0 0 0.5" />
				</panel>

				<!-- padding -->
				<panel height="2" noclick="1" />

				<!-- Body -->
				<panel width="100%" valign="bottom" grow="1" regrow="1" >
					<panel width="96%" align="center" float="bottom" padding="0.4h" grow="1" regrow="1" >
						<instance name="test_suite_input" textbox="test_server_basic_item_search" height="2h"
							onshowlua="self:DoEvent() self:SetFocus(true)"
							onchangelua="self:Sleep(250, function(self) self:DoEvent() end)"
							onenterlua="TestSuite.PopulateBasicItemList(self:GetValue())"
						/>
						<panel height="2h" noclick="1" >
							<instance name="test_suite_checkbox" checkbox="test_server_items_replace_names" width="49%" content="test_server_replace_names" cvar="ui_testSuiteReplaceItemNames"
								onclicklua="TestSuite.PopulateBasicItemList(TestSuite.GetWidget('test_server_basic_item_search'):GetValue())"
							/>
							<instance name="test_suite_button" button="server_refresh_items" align="right" width="49%" content="test_server_refresh_items"
								onclicklua="
									TestSuite.ForceItemCacheRebuild()
									TestSuite.PopulateBasicItemList(TestSuite.GetWidget('test_server_basic_item_search'):GetValue())
								"
							/>
						</panel>
						<instance name="test_suite_listbox" listbox="client_server_basic_item_list" height="27.5h" itemheight="3h"
							onclicklua="
								local item = self:GetValue()
								TestSuite.GetWidget('test_server_basic_item_search'):SetFocus(false)
								TestSuite.DoSelectedUnits(function(unit) Testing.GiveItem(unit, item) end)
							"
						/>
						<instance name="test_suite_button" button="server_item_sell" width="100%" content="test_server_sell_items" height="2.5h"
							onclicklua="for i=0,5 do Sell(GetInventoryStartBackpack() + i) end"
						/>
					</panel>
				</panel>

				<!-- padding -->
				<panel height="0.5h" width="100%" noclick="1" />
			</panel>
		</panel>
	</template>

