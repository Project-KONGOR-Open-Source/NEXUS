						<panel width="28%" float="bottom" noclick="1" padding="0.5h" >
							<panel height="2h" noclick="1" >
								<panel align="center" height="100%" noclick="1" grow="1" float="right" padding="0.5h" >
									<label font="dyn_12" textalign="center" textvalign="center" color="white" shadow="1" fitx="1" content="test_server_taunts" />
									<instance name="test_suite_tip" tip="server_taunts" width="100@" content="test_server_taunts_tip" />
								</panel>
							</panel>
							
							<instance name="test_suite_listbox" listbox="test_server_taunts_list" height="-5.5h" itemheight="1.75h"
								onshowlua="
									local selected = self:GetValue()
									if (selected == '') then
										selected = 'standard_taunt'
									end

									self:ClearItems()
									local taunts = Testing.GetTaunts()
									for _,taunt in ipairs(taunts) do
										if (Testing.EntityExists('Ability_Taunt.'..taunt.modifier)) then
											self:AddTemplateListItem('test_suite_listitem_simple', taunt.modifier, 'font', 'dyn_10', 'content', taunt.name)
										else
											self:AddTemplateListItem('test_suite_listitem_simple', taunt.modifier, 'font', 'dyn_10', 'content', '^r'..taunt.name)
										end
									end

									self:SetSelectedItemByValue(selected, false)
								"
							/>

							<panel height="2h" noclick="1" >
								<instance name="test_suite_button" button="server_taunt" width="69%" content="test_server_do_taunt" font="dyn_10"
