<?xml version="1.0" encoding="UTF-8"?>
<package>
	<template name="attack_tooltip">
		<frame
			name="attack_tooltip"
			texture="/ui/frames/rounded_bg_white.tga"
			borderthickness="0.6h"
			color="0 0 0 .75"
			visible="false"
			align="right"
			valign="bottom"
			width="27h"
			height="5.0h"
			float="bottom"
			grow="1" regrow="1" growinvis="0"
		>
			<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#434d50"/>
			<anchor x="1.0h" y="0.6h" />

			<panel
				width="-2.0h"
				height="1.8h"
			>
				<label
					width="55%"
					textalign="left"
					font="dyn_10"
					color="white"
					watch="ActiveDamage"
					ontriggerlua="self:SetText(Translate('tooltip_damage') .. round(tonumber(param0) + tonumber(param2)) .. ' - ' .. round(tonumber(param1) + tonumber(param2)))"
				/>
				<label
					width="45%"
					align="right"
					textalign="left"
					font="dyn_10"
					color="white"
					watch="ActiveDamage"
					ontriggerlua="
						if (tonumber(param2) == 0.0) then
							self:ClearText()
						elseif(tonumber(param2) > 0.0) then
							self:SetText('^777(' .. round(param0) .. ' - ' .. round(param1) .. ' ^g+' .. round(param2) .. '^777)')
						else
							self:SetText('^777(' .. round(param0) .. ' - ' .. round(param1) .. ' ^r' .. round(param2) .. '^777)')
						end
					"
				/>
			</panel>

			<panel width="-2.0h" height="1.8h" />

			<panel
				width="-2.0h"
				height="1.8h"
			>
				<label
					width="55%"
					textalign="left"
					font="dyn_10"
					color="white"
					watch="ActiveAttackSpeed"
					ontriggerlua="self:SetText(Translate('tooltip_attack_speed') .. round(param1))"
				/>
				<label
					width="45%"
					align="right"
					textalign="left"
					font="dyn_10"
					color="white"
					watch="ActiveAttackSpeed"
					ontriggerlua="
						local diff = (tonumber(param1) - tonumber(param0))
						if (diff == 0.0) then
							self:ClearText()
						elseif (diff > 0.0) then
							self:SetText('^777(' .. Round(param0) .. ' ^g+' .. round(diff) .. '^777)')
						else
							self:SetText('^777(' .. Round(param0) .. ' ^r' .. round(diff) .. '^777)')
						end
					"
				/>
			</panel>
			
			<panel
				width="-2.0h"
				height="1.8h"
			>
				<label
					width="55%"
					textalign="left"
					font="dyn_10"
					color="white"
					watch="ActiveCastSpeed"
					ontriggerlua="self:SetText(Translate('tooltip_cast_speed') .. round(param1))"
				/>
				<label
					width="45%"
					align="right"
					textalign="left"
					font="dyn_10"
					color="white"
					watch="ActiveCastSpeed"
					ontriggerlua="
						local diff = (tonumber(param1) - tonumber(param0))
						if (diff == 0.0) then
							self:ClearText()
						elseif (diff > 0.0) then
							self:SetText('^777(' .. Round(param0) .. ' ^g+' .. round(diff) .. '^777)')
						else
							self:SetText('^777(' .. Round(param0) .. ' ^r' .. round(diff) .. '^777)')
						end
					"
				/>
			</panel>
			
			<panel width="-2.0h" height="1.8h" />

			<label
				width="-2.0h"
				height="1.8h"
				textalign="left"
				font="dyn_10"
				color="white"
				watch="ActiveAttackInfo"
				ontriggerlua="self:SetText(Translate('tooltip_attack_type') .. param0)"
			/>

			<label
				width="-2.0h"
				height="1.8h"
				textalign="left"
				font="dyn_10"
				color="white"
				watch="ActiveAttackRange"
					ontriggerlua="
						local diff = (tonumber(param1) - tonumber(param0))
						if (diff == 0.0) then
							self:SetText(Translate('tooltip_range') .. round(param0))
						elseif (diff > 0.0) then
							self:SetText(Translate('tooltip_range') .. round(param0) .. ' ^g+' .. round(diff) .. '^* = ^y' .. round(param1))
						else
							self:SetText(Translate('tooltip_range') .. round(param0) .. ' ^r' .. round(diff) .. '^* = ^y' .. round(param1))
						end
					"
			/>
			<label
				width="-2.0h"
				height="1.8h"
				textalign="left"
				font="dyn_10"
				color="white"
				watch="ActiveAttackCooldown"
				ontriggerlua="self:SetText(Translate('tooltip_base_attack_cooldown', 'time', FtoA2(tonumber(param0) / 1000, 0, 3)))"
			/>

			<panel width="-2.0h" height="1.8h" />

			<label
				width="-2.0h"
				height="1.8h"
				textalign="left"
				font="dyn_10"
				color="white"
				watch="ActiveAttackCooldown"
				ontriggerlua="self:SetText(Translate('tooltip_attack_cooldown', 'time', FtoA2(tonumber(param1) / 1000, 0, 3)))"
			/>
			<label
				width="-2.0h"
				height="1.8h"
				textalign="left"
				font="dyn_10"
				color="white"
				watch="ActiveAttackCooldown"
				ontriggerlua="self:SetText(Translate('tooltip_attacks_per_second', 'value', FtoA2(tonumber(1000) / param1, 0, 3)))"
			/>

			<panel width="-2.0h" height="0.55h" sticky="true" stickytoinvis="false" />
		</frame>
	</template>
</package>