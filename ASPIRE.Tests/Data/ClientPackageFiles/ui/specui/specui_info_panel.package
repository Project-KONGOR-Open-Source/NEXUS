			<instance id="6" name="specui_bottom_tab" />
			<instance id="7" name="specui_bottom_tab" />
			<instance id="8" name="specui_bottom_tab" />
		</panel>	
	
		<panel y="1.0h" noclick="1" valign="bottom" height="3.8h" float="right">
			<instance name="specui_bottom_header_tab" id="1" lbl="specui_tab_players" fittoplayers="true" />
			<instance name="specui_bottom_header_tab" id="2" lbl="specui_tab_stats" fittoplayers="true" />
			<instance name="specui_bottom_header_tab" id="3" lbl="specui_tab_gpm" />
