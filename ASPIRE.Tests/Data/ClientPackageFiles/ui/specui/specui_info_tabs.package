<?xml version="1.0" encoding="UTF-8"?>
<package>

	<template name="specui_datarow_sep">
		<panel name="specui_seperator_{id}_{index}" width="100%" height="0.3h" noclick="true" sticky="1" stickytoinvis="0">
			<panel color=".15 .15 .15 1" y="-1" width="-1.0h" align="center" height="1" valign="center" noclick="true" />
			<panel color="0 0 0 1" width="-1.0h" height="1" align="center" valign="center" noclick="true" />
		</panel>
	</template>

	<template name="specui_stats_slot_header">
		<panel width="100%" height="2.4h" padding="0.1h" noclick="1" sticky="1" stickytoinvis="0" color="1 0 1 0.0" >	
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="{headercolor=.5 .5 .5 1}"
				onloadlua="	if (GetCvarBool('specui_mini_mode1')) then
								if ('{headercolor=.5 .5 .5 1}' == '#460000CB') then
									self:SetBorderColor('#46000066')
									self:SetColor('#46000066')
								else
									self:SetBorderColor('#123d2566')
									self:SetColor('#123d2566')
								end
							end"
			/>
			<frame x="0" texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.6h" blockinput="false" noclick="true"/>	
			<panel float="right" padding="0.1h" noclick="true">			
			
				<!-- Spacer -->
				<panel width="3.8h" noclick="1" sticky="1" stickytoinvis="0"></panel>
				<!-- Murder Death Kills -->
				<panel width="8h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_kda', 'specui_kda_tip', '/ui/elements/stat_icons/kill_death_ratio.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.7h" height="1.7h" align="center" valign="center" noclick="1" visible="1"
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/elements/stat_icons/kill_death_ratio.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>
				<!-- XPPM -->
				<panel width="4.0h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_xp', 'specui_xp_tip', '/ui/specui/elements/PushMarkerExp.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" width="2.5h" height="2.5h" align="center" valign="center" noclick="1" visible="1"
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/specui/elements/PushMarkerExp.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>
				<!-- GPM -->
				<panel width="4.5h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_gm', 'specui_gm_tip', '/ui/specui/elements/PushMarkerGold.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" width="1.8h" height="1.8h" align="center" valign="center" noclick="1" visible="1"
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/specui/elements/PushMarkerGold.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>		

				<!-- Creep Kills -->
				<panel width="3.8h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_ck', 'specui_ck_tip', '/ui/elements/stat_icons/npc_kills.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.7h" height="1.7h" align="center" valign="center" noclick="1" visible="1"
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/elements/stat_icons/npc_kills.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>				
			
				<!-- Creep Denies -->
				<panel width="3.8h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_cd', 'specui_cd_tip', '/ui/elements/stat_icons/npc_kills.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.7h" height="1.7h" align="center" valign="center" noclick="1" visible="1" color="red" 
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/elements/stat_icons/npc_kills.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>	
			
				<!-- Player Dmg -->
				<panel width="4.1h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_hdmg', 'specui_hdmg_tip', '/ui/elements/stat_icons/player_damage.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.7h" height="1.7h" align="center" valign="center" noclick="1" visible="1"
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/elements/stat_icons/player_damage.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>				

				<!-- Building Dmg -->
				<panel width="4.2h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_bdmg', 'specui_bdmg_tip', '/ui/elements/stat_icons/razed.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.7h" height="1.7h" align="center" valign="center" noclick="1" visible="1"
						ontrigger9lua="ResourceManager.RegisterTexture('/ui/elements/stat_icons/razed.tga', 'specui', self)" resourcecontext="specui" watch9="SpecRegisterTextures"
					/>
				</panel>		
			</panel>		
		</panel>
	</template>
	
	<template name="specui_stats_slot">
		<panel name="stats_slot_{index}" width="100%" height="2.4h" float="right" padding="0.1h" noclick="1" sticky="1" stickytoinvis="0">	
			<!-- Level -->
			<label name="stats_slot_{index}_level" width="2.1h" x="-0.6h" textvalign="center" textalign="center" font="dyn_11" color="white" shadow="1" noclick="1"/>
			<!-- Icon -->
			<frame name="stats_slot_{index}_frame" width="100@" height="100%" align="left" valign="center" noclick="1"
			>
				<image name="stats_slot_{index}_icon" width="-2" height="-2" align="center" valign="center" noclick="0"
					onclick="SelectUnit(SpectatorHeroIndex{index});"
					onrightclick="If(GetSelectedEntity() != SpectatorHeroIndex{index}, Set(cg_lockCamera, 1), Set(cg_lockCamera, !cg_lockCamera)); SelectUnit(SpectatorHeroIndex{index}); "					
				/>
			</frame> 

			<!-- Murder Death Kills -->
			<panel width="7.6h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_mdks" textvalign="center" textalign="center" font="dyn_11" color="0.3 1.0 .3 1" shadow="1" noclick="1"/>
			</panel>
			<!-- XPPM -->
			<panel width="4.0h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_xpm" textvalign="center" textalign="center" font="dyn_11" color="0.7 0.5 1 1" shadow="1" noclick="1"/>
			</panel>
			<!-- GPM -->
			<panel width="4.5h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_gpm" textvalign="center" textalign="center" font="dyn_11" color="1 0.74 0 1" shadow="1" noclick="1"/>
			</panel>		
			
			<!-- Creep Kills -->
			<panel width="3.8h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_creepKills" textvalign="center" textalign="center" font="dyn_11" color="0.7 1.0 0.7 1" shadow="1" noclick="1"/>
			</panel>			
			
			<!-- Creep Denies -->
			<panel width="3.8h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_creepDenies" textvalign="center" textalign="center" font="dyn_11" color="1.0 0.7 0.7 1" shadow="1" noclick="1"/>
			</panel>				
			
			<!-- Player Dmg -->
			<panel width="4.2h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_playerDmg" textvalign="center" textalign="center" font="dyn_11" color="0.7 1.0 0.7 1" shadow="1"  noclick="1" />
			</panel>				
			
			<!-- Building Dmg -->
			<panel width="4.2h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="stats_slot_{index}_bldDmg" textvalign="center" textalign="center" font="dyn_11" color="1.0 0.7 0.7 1" shadow="1"  noclick="1" />
			</panel>				
			
		</panel>
	</template>			
	 
	<template name="specui_overview_slot_header">
		<panel width="100%" height="2.4h" noclick="1" sticky="1" stickytoinvis="0" color="0 1 1 0.0" >	
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="{headercolor=.5 .5 .5 1}"
				onloadlua="	if (GetCvarBool('specui_mini_mode1')) then
								if ('{headercolor=.5 .5 .5 1}' == '#460000CB') then
									self:SetBorderColor('#46000066')
									self:SetColor('#46000066')
								else
									self:SetBorderColor('#123d2566')
									self:SetColor('#123d2566')
								end
							end"
			/>
			<frame x="0" texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.6h" blockinput="false" noclick="true"/>	
			<panel float="right" padding="0.1h" noclick="true">
				<!-- Spacer -->
				<panel width="16.8h" noclick="1" sticky="1" stickytoinvis="0"></panel>
				<!-- Murder Death Kills -->
				<panel width="7.6h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_kda', 'specui_kda_tip', '/ui/elements/stat_icons/kill_death_ratio.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.7h" height="1.7h" align="center" valign="center" noclick="1" visible="1" texture="/ui/elements/stat_icons/kill_death_ratio.tga" />
				</panel>
				<!-- XPPM -->
				<panel width="4.0h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_xp', 'specui_xp_tip', '/ui/specui/elements/PushMarkerExp.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" width="2.5h" height="2.5h" align="center" valign="center" noclick="1" visible="1" texture="/ui/specui/elements/PushMarkerExp.tga" />
				</panel>
				<!-- GPM -->
				<panel width="4.5h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_gm', 'specui_gm_tip', '/ui/specui/elements/PushMarkerGold.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" width="1.8h" height="1.8h" align="center" valign="center" noclick="1" visible="1" texture="/ui/specui/elements/PushMarkerGold.tga" />
				</panel>		
				<panel width="2.25h" height="90%" noclick="0" onmouseoverlua="Trigger('SpecUITooltipUpdate', 'specui_bb', 'specui_bb_tip', '/ui/fe2/store/icons/hero_token2.tga', '', '', '')" onmouseoutlua="Trigger('SpecUITooltipUpdate', '', '', '', '', '', '')" sticky="1" stickytoinvis="0" color="invisible" >
					<image x="0.0" y="0.1h" width="1.8h" height="1.8h" align="center" valign="center" noclick="1" visible="1" texture="/ui/fe2/store/icons/hero_token2.tga" />
				</panel>
			</panel>
			
		</panel>
	</template>		
	<template name="specui_overview_slot">
		<panel name="overview_slot_{index}" width="100%" height="2.4h" float="right" padding="0.1h" noclick="1" sticky="1" stickytoinvis="0" >	
			<!-- Level -->
			<label name="overview_slot_{index}_level" width="2.1h" x="-0.6h" textvalign="center" textalign="center" font="dyn_11" color="white" shadow="1" noclick="1"/>
			<!-- Icon -->
			<image name="overview_slot_{index}_icon" width="90@" height="90%" align="left" valign="center"  noclick="0"
					onclick="SelectUnit(SpectatorHeroIndex{index});"
					onrightclick="If(GetSelectedEntity() != SpectatorHeroIndex{index}, Set(cg_lockCamera, 1), Set(cg_lockCamera, !cg_lockCamera)); SelectUnit(SpectatorHeroIndex{index}); "						
			/>
			<!-- Name -->
			<panel width="13h" noclick="1" sticky="1" stickytoinvis="0" >
				<label name="overview_slot_{index}_name" x=".3h" width="-0.3h" y="-0.2h" valign="top" textvalign="center" textalign="left" font="dyn_11" color="white" shadow="1" noclick="1"/>
			</panel>
			<!-- Murder Death Kills -->
			<panel width="7.6h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="overview_slot_{index}_mdks" textvalign="center" textalign="center" font="dyn_11" color="0.3 1.0 .3 1" shadow="1" noclick="1"/>
			</panel>
			<!-- XPPM -->
			<panel width="4.0h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="overview_slot_{index}_xpm" textvalign="center" textalign="center" font="dyn_11" color="0.7 0.5 1 1" shadow="1" noclick="1"/>
			</panel>
			<!-- GPM -->
			<panel width="4.5h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label name="overview_slot_{index}_gpm" textvalign="center" textalign="center" font="dyn_11" color="1 0.74 0 1" shadow="1" noclick="1"/>
			</panel>		
			<!-- Buyback
			<panel width="3.0h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<label textvalign="center" textalign="center" font="dyn_11" color="white" shadow="1" 
					watch="SpectatorHeroNumBuybacksRemaining{index}"  ontrigger="If(param0 lt 10, If(param0 gt 0, Split(SetColor('white'), SetText(param0)), Split(SetColor('red'), SetText(param0))), Split(SetColor('white'), SetText('')));" noclick="1"/>
			</panel>	
			 -->
			<panel width="2.25h" height="90%" noclick="1" sticky="1" stickytoinvis="0" color="invisible" >
				<image name="overview_slot_{index}_buyback1" x="0.0" y="-0.15h" width="1.5h" height="1.5h" align="left" valign="center" noclick="1" visible="1" texture="/ui/fe2/store/icons/hero_token2.tga" />
				<image name="overview_slot_{index}_buyback2" x="0.75h"  y="0.25h" width="1.5h" height="1.5h" align="left" valign="center" noclick="1" visible="1" texture="/ui/fe2/store/icons/hero_token2.tga"	/>
			</panel>				
		</panel>
	</template>			
	
	<template name="specui_bottom_tab_1" >
		<panel noclick="1" float="right" x="0.7%" height="100%" padding="1%" valign="bottom" color="0 1 1 0.0" >
			<panel noclick="1" float="bottom" padding="0.166h" width="48.7%" >
				<panel width="100%" height="0.2h" noclick="true" />
				<instance name="specui_overview_slot_header" team="0" headercolor="#123d25CB" /> 
				<instance name="specui_overview_slot" index="0" />
				<instance name="specui_datarow_sep" id="overview" index="1" />
				<instance name="specui_overview_slot" index="1" />
				<instance name="specui_datarow_sep" id="overview" index="2" />
				<instance name="specui_overview_slot" index="2" />
