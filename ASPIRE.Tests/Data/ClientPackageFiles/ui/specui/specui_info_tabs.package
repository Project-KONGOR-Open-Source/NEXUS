				<instance name="specui_datarow_sep" id="overview" index="4" />
				<instance name="specui_overview_slot" index="4" /> 			
			</panel>
			<panel noclick="1" float="bottom" padding="0.166h" width="48.7%" >
				<panel width="100%" height="0.2h" noclick="true" />
				<instance name="specui_overview_slot_header" team="1" headercolor="#460000CB" /> 
				<instance name="specui_overview_slot" index="5" />
				<instance name="specui_datarow_sep" id="overview" index="6" />
				<instance name="specui_overview_slot" index="6" /> 
				<instance name="specui_datarow_sep" id="overview" index="7" />
				<instance name="specui_overview_slot" index="7" /> 
				<instance name="specui_datarow_sep" id="overview" index="8" />
				<instance name="specui_overview_slot" index="8" /> 
				<instance name="specui_datarow_sep" id="overview" index="9" />
				<instance name="specui_overview_slot" index="9" /> 	
			</panel>
		</panel>
	</template>
	
	<template name="specui_bottom_tab_3" >
		<instance name="specui_stats_graph" graphName="gpm" stat="GpM" label="specui_graph_gpm" />
	</template>
	
	<template name="specui_bottom_tab_4" >
