									onload="SetText(GetKeybindButton('spectator', 'Cmd', 'SpecUIToggleUF'));" onshow="SetText(GetKeybindButton('spectator', 'Cmd', 'SpecUIToggleUF'));" noclick="1" 
								/>
							</panel>
							<panel noclick="1" width="1.3h" />
