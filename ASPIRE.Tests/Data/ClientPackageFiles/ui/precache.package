<?xml version="1.0" encoding="UTF-8"?>
<package>
	<!-- Texture Precaching Rules:
		Textures, models and effects must be defined here if not defined in a widget attribute in the UI
		Those defined outside the cg_precacheResources flag will be loaded on startup, those inside will not but will still be placed in the texture archive and loaded as needed
		Any textures defined as nocompress must be outside the cg_precacheResources flag
	-->

	<!-- Precache Main -->
	<if condition="cg_precacheResources" >

		<!-- alt info -->
		<texture file="/ui/elements/alt/afk.png"/>
