			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperText" content="mstore_buycoin_success_body"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="store2Button" texture="button5" width="14h" height="3.5h" align="center" color="#fffdf6" outlinecolor="#9c4404" label="general_ok" onclick="CallEvent('store_popup_buy_coin_success', 1);"/>
			</panel>
		</panel>
	</template>

	<template name="storePopupBuyCoinFriendSuccess">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperText" content="mstore_buycoin_friend_success_body"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="store2Button" texture="button5" width="14h" height="3.5h" align="center" color="#fffdf6" outlinecolor="#9c4404" label="general_ok" onclick="CallEvent('store_popup_buy_coin_friend_success', 1);"/>
			</panel>
		</panel>
	</template>

	<template name="storePopupBuyItemSuccess">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperText" content="mstore_buyitem_success_body"
				watch="MicroStoreResults"
				ontrigger="
					SetText(
						Translate(
							If(
								_microStore_Category == 3 or
								_microStore_Category == 4 or
								_microStore_Category == 5 or
								_microStore_Category == 6 or
								_microStore_Category == 16 or
								_microStore_Category == 27 or
								_microStore_Category == 59 or
								_microStore_Category == 60 or
								_microStore_Category == 61,
								'mstore_buyitem_success_body_vault',
								'mstore_buyitem_success_body'
							)
						)
					);

				"
			/>
			<panel grow="true" width="100%" regrow="true">
				<panel float="right" padding="0.5h" align="center" grow="true" height="3h" regrow="true" growinvis="false">
					<instance name="store2Button" buttonName="store_button_purchase_success_confirm" texture="button5" width="14h" height="3.5h" color="#fffdf6" outlinecolor="#9c4404" label="general_ok" onclick="CallEvent('store_popup_buy_item_success', 1);"/>
					<instance name="store2Button" texture="button5" width="14h" height="3.5h" color="#fffdf6" outlinecolor="#9c4404" label="mstore_openvault" visible="0"
						tip_id="mstore_tip_open_vault"
						watch="MicroStoreProcessing"
						ontrigger="SetEnabled(!param0);"
						watch1="MicroStoreResults"
						ontrigger1="
							SetVisible(
								(
								_microStore_Category == 3 or
								_microStore_Category == 4 or
								_microStore_Category == 5 or
								_microStore_Category == 6 or
								_microStore_Category == 16 or
								_microStore_Category == 27 or
								_microStore_Category == 59 or
								_microStore_Category == 60 or
								_microStore_Category == 61
								)
								and _microStore_SelectedID != 4606
							);
						"
						onclicklua="HoN_Store:OpenVaultAfterPurchase()"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storePopupResetStatsSuccess">
