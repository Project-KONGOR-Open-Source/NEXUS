			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperText" content="mstore_buycoin_success_upgrade_body"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="store2Button" texture="button5" width="14h" height="3.5h" align="center" color="#fffdf6" outlinecolor="#9c4404" label="general_ok" onclick="CallEvent('store_popup_buy_coin_success_upgrade', 1);"/>
			</panel>
		</panel>
	</template>

