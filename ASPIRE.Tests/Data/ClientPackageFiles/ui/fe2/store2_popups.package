	<template name="storePopupBuyAvatarNeedHero">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label width="100%" align="right" wrap="true" fity="true" fitypadding="1h" textvalign="center" font="dyn_12" style="microStorePaperText" content="mstore_buyavatar_needhero_desc"/>
			<panel grow="true" width="100%">
				<panel float="right" padding="0.75h" height="3h" grow="true" align="center">
					<instance name="store2Button" texture="button5" width="14h" height="3.5h" color="#fffdf6" outlinecolor="#9c4404" label="mstore_viewhero"
						onclicklua="
							local g = _G['HoN_Store']
							g:SwitchToHeroAvatarPanelFromBuyAvatarPopup()
							GetWidget('store_popup_buyavatar_needhero'):DoEventN(1)
						"
					/>
					<instance name="store2Button" texture="button4" width="14h" height="3.5h" color="#e9f2f6" outlinecolor="#2f7182" label="general_cancel"
						onclicklua="GetWidget('store_popup_buyavatar_needhero'):DoEventN(1)"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storePopupBuyFeaturedOwnedProduct">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label name="store_popup_buyfeatured_ownedproduct_body" width="100%" align="right" wrap="true" fity="true" fitypadding="1h" textvalign="center" textalign="center" font="dyn_12" style="microStorePaperText" content="mstore_featured_owned_body"/>
			<panel grow="true" width="100%">
				<panel float="right" padding="0.75h" height="3h" grow="true" align="center">
					<instance name="store2Button" texture="button5" width="14h" height="3.5h" color="#fffdf6" outlinecolor="#9c4404" label="general_continue"
						onclicklua="
							local g = _G['HoN_Store']
							Set('_microStore_overrideConfirmName', true)
							g:OnPurchase()
							Set('_microStore_overrideConfirmName', false)
							GetWidget('store_popup_buyfeatured_ownedproduct'):DoEventN(1)
						"
					/>
					<instance name="store2Button" texture="button4" width="14h" height="3.5h" color="#e9f2f6" outlinecolor="#2f7182" label="general_cancel"
						onclicklua="
							GetWidget('store_popup_buyfeatured_ownedproduct'):DoEventN(1)
						"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- it's used in /content/store_avatars.package -->
	<trigger name="StoreAvatarIsNewRequest"/>
	<trigger name="StoreAvatarIsNewResult"/>
	<template name="altAvatarPreviewPanel">
		<panel color="0 0 0 0.5" visible="false"
			group="storeAltAvatarInfoPanels"
			oneventlua="UIManager.GetInterface('main'):HoNStoreF('RegisterAltAvatar',
					{id=0},
					'{definition=}',
					{hasmodel=false},
					{hastexture=false},
					{haseffects=false},
					{hassounds=false},
					{hasanimations=false},
					{goldCollection=false},
					{limitedEdition=false},
					{holidayEdition=false},
					{collectorsEditionSet=0},
					{heroEntryID=1},
					{ultimateAvatar=false},
					{hasEnhancement=false},
					{hasnewanimations=true}
				)"
			watch3="StoreAvatarIsNewRequest"
			ontrigger3="
				Trigger('StoreAvatarIsNewResult', {id=0}, '{new=false}', '{ultimateAvatar=false}');
			"
		/>
	</template>
</package>
