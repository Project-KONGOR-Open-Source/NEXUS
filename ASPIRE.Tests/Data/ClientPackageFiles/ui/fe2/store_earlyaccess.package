			<panel align="{side=center}" width="50%" noclick="true" x="{xoffset}" name="eapHeroUpdateNotice{id=1}" visible="false">
				<panel align="center" valign="center" color="black" width="25h" grow="true">
					<frame color="invisible" bordercolor="{framecolor=#455166}" borderthickness="1" noclick="true" />
					<panel width="100%" float="bottom" noclick="true" padding="0.5h" grow="true">
						<instance name="header_bar" width="100%" height="2.8h" lbl="mstore_eapupdate" color="white" lbl_font="dyn_11" />
						<panel width="100%" grow="true">
							<panel width="-1h" align="center" grow="true">
								<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="{fetchbgcolor=1 1 1 .5}" noclick="1" />
								<frame color="invisible" bordercolor="{framecolor=#455166}" borderthickness="1" noclick="true" />
								<panel grow="true" width="-1h" align="center" float="bottom">
									<panel height="0.25h"/>
									<label color="white" shadow="true" width="100%" font="dyn_10" content="mstore_eapupdate_body" wrap="true" textalign="center" fity="true" />
									<panel height="0.5h"/>
								</panel>
							</panel>
						</panel>
						<panel height="0"/>
					</panel>
				</panel>
			</panel>

			<panel align="center" width="50%" noclick="true" x="{xoffset}" name="eapNotAvailable" visible="false">
				<panel align="center" valign="center" color="black" width="25h" grow="true">
					<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="true" />
					<panel width="100%" float="bottom" noclick="true" padding="0.5h" grow="true">
						<instance name="header_bar" width="100%" height="2.8h" lbl="mstore_eapnone" color="white" lbl_font="dyn_11" />
						<panel width="100%" grow="true">
							<panel width="-1h" align="center" grow="true">
								<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 .5" noclick="1" />
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="true" />
								<panel grow="true" width="-1h" align="center" float="bottom">
									<panel height="0.75h"/>
									<label color="white" shadow="true" width="100%" font="dyn_10" content="mstore_eapnone_body" wrap="true" textalign="center" fity="true" fitypadding="0.5h" />
									<panel height="0.5h"/>
								</panel>
							</panel>
						</panel>
						<panel height="0"/>
					</panel>
				</panel>
			</panel>
						
			<!-- Center Header -->
			<panel y="-0.5h" width="52.0h" height="7.0h" align="center" valign="top" noclick="true" name="store_eap_header_center" visible="false">			
				<frame texture="/ui/frames/rounded_bg_red.tga" borderthickness="0.6h" color=".1 .1 .1 .9" blockinput="false" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="#e28e1b" borderthickness="0.6h" blockinput="false" noclick="true"/>
				
					<panel y="-0.7h" width="-1.4h" height="-1.9h" align="center" valign="bottom" float="right" padding="0.6h" noclick="true">
					
						<!-- Icon -->
						<panel width="100@" height="100%">
							<image watch="populateEAPItem" ontrigger="
								##Echo(GetEntityIconPath(param2));##
								If(
									param0 == {id=1},
									If(
										param1 ge 1,
										Split(
											SetTexture(GetEntityIconPath(param2)),
											SetOnMouseOver(
												'
													GetHeroInfo(\''#param2#'\'); ShowWidget(\'hero_info\');
												'
											)
										),
										SetOnMouseOver('')
									)
								);
							"
							onmouseover=""
							onmouseoutlua="GetWidget('hero_info', 'main'):SetVisible(false)"
							onhide="
								##Call('eap_model_gears', 'SetEffect(\'\');');##
							"
							onhidelua="GetWidget('hero_info', 'main'):SetVisible(false)"
							/>							
							<frame color="invisible" bordercolor="#e28e1b" borderthickness="1" noclick="true" />
						</panel>
						
						<panel width="0.2h" height="100%" noclick="true">
							<panel width="50%" color="0 0 0 1" align="left" noclick="true" />
							<panel width="50%" color="1 1 1 .1" align="right" noclick="true" />
						</panel>
						
						<panel width="20.0h" height="100%" noclick="true" float="bottom" padding="0.1h">
							<!-- Hero Name -->
							<label y="-0.4h" fity="true" font="dyn_14" textvalign="center" color="1 1 1 1" outline="true" content="-" noclick="true" watch="populateEAPItem" ontrigger="If(param0 == {id=1}, If(param1 ge 1, SetText(GetEntityDisplayName(param2))));"/>
							<!-- Difficulty -->
							<panel height="1.7h" width="100%" float="right" padding="0.2h">
								<label fitx="true" fitxpadding="0.5h" textvalign="center" font="dyn_11" color=".6 .6 .6 1" content="mstore_difficulty" shadow="true" />						
								<panel grow="true" height="100%" noclick="true">
									<panel grow="true" growinvis="false" regrow="true" height="100%" float="right" padding="0.2h" noclick="true">
										<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="grayscale" color="1 1 1 .6" sticky="true" stickytoinvis="false"/>
										<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="grayscale" color="1 1 1 .6" sticky="true" stickytoinvis="false"/>
										<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="grayscale" color="1 1 1 .6" sticky="true" stickytoinvis="false"/>
										<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="grayscale" color="1 1 1 .6" sticky="true" stickytoinvis="false"/>
										<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="grayscale" color="1 1 1 .6" sticky="true" stickytoinvis="false"/>
									</panel>
									<panel grow="true" growinvis="false" regrow="true" height="100%" float="right" padding="0.2h" noclick="true">
										<instance name="heroDifficultyStarEAP" difficulty="1" id="{id=1}"/>
										<instance name="heroDifficultyStarEAP" difficulty="2" id="{id=1}"/>
										<instance name="heroDifficultyStarEAP" difficulty="3" id="{id=1}"/>
										<instance name="heroDifficultyStarEAP" difficulty="4" id="{id=1}"/>
										<instance name="heroDifficultyStarEAP" difficulty="5" id="{id=1}"/>
									</panel>
								</panel>						
								<panel width="0" noclick="true"/>
							</panel>
							<!-- Categories -->
							<label fity="true" width="100%" font="dyn_8" color="#00FF00" content="-" shadow="true" watch="populateEAPItem" ontrigger="If(param0 == {id=1}, If(param1 ge 1, SetText(GetHeroCategories(param2, 1)), SetText('')));" />							
						</panel>
						
						<panel width="0.2h" height="100%" noclick="true">
							<panel width="50%" color="0 0 0 1" align="left" noclick="true" />
							<panel width="50%" color="1 1 1 .1" align="right" noclick="true" />
						</panel>
						
						<!-- Abils -->
						<panel width="-34.0h" height="100%" noclick="true" float="bottom" padding="0.2h">
							<label y="-0.4h" fity="true" textalign="left" width="100%" font="dyn_11" color=".6 .6 .6 1" content="Hero Abilities" shadow="true" />
						
							<panel height="3.5h" float="right" padding="0.8h"
								watch="populateEAPItem"
								ontrigger="
									If(
										param0 == {id=1},
										If(
											param1 ge 1,
											SetOnMouseOver(
												'
													GetHeroInfo(\''#param2#'\'); Cmd(\'ShowWidget hero_info\');
												'
											),
											SetOnMouseOver('')
										)
									);
								"
								onmouseoutlua="GetWidget('hero_info', 'main'):SetVisible(false)"
								onhidelua="GetWidget('hero_info', 'main'):SetVisible(false)"
							>
								<instance name="storeEAPAbility" entity_path="{entity_path}" entity_name="{entity_name}" id="1" slotID="{id=1}" abilityPathPrefix="{abilityPathPrefix=ability_0}"/>
								<instance name="storeEAPAbility" entity_path="{entity_path}" entity_name="{entity_name}" id="2" slotID="{id=1}" abilityPathPrefix="{abilityPathPrefix=ability_0}"/>
								<instance name="storeEAPAbility" entity_path="{entity_path}" entity_name="{entity_name}" id="3" slotID="{id=1}" abilityPathPrefix="{abilityPathPrefix=ability_0}"/>
								<instance name="storeEAPAbility" entity_path="{entity_path}" entity_name="{entity_name}" id="4" slotID="{id=1}" abilityPathPrefix="{abilityPathPrefix=ability_0}"/>
							</panel>
						
						
						
							
						</panel>
						
						<panel width="0.2h" height="100%" noclick="true">
							<panel width="50%" color="0 0 0 1" align="left" noclick="true" />
							<panel width="50%" color="1 1 1 .1" align="right" noclick="true" />
						</panel>						
						
						<!-- Voices -->
						<panel width="90@" height="100%"
							onload="CreateString('_lastEAPSoundProduct{id=1}', '');"
						>
							<image width="100%" height="100@" valign="center" texture="/ui/elements/gamefeature_voip.tga" />							
							<instance name="EAPVoiceButton"
								onmouseover=""
								onmouseout=""
								watch="MicroStoreProcessing"
								ontrigger="SetEnabled(!param0);"
								watch1="populateEAPItem"
								ontrigger1="
									If(
										param0 == {id=1},
										If(
											param1 ge 1,
											Set('_lastEAPSoundProduct{id=1}', param2),
											Set('_lastEAPSoundProduct{id=1}', '')
										)
									);
								"
								onclick="
									If(
										!StringEmpty(_lastEAPSoundProduct{id=1}),
										PlayHeroPreviewSoundFromProduct(_lastEAPSoundProduct{id=1})
									);
								"
							/>
						</panel>
						
					
					</panel>
			</panel>
			
			<!-- Left Alt Header (swapped to right) -->
			<panel y="-0.5h" x="-42.5h" width="26.0h" height="5.5h" align="center" valign="top" noclick="true" name="store_eap_header_right" visible="0">
				<frame y="0" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 .7" blockinput="false" noclick="true"/>
				<frame y="0" texture="/ui/frames/roundframe.tga" color="#4c4c4c" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label y="1.0h" name="store_eap_header_right_label_1" fity="true" wrap="true" textalign="center" font="dyn_14" color=".9 .9 .9 1" outline="true" content="" noclick="true" />
				<label name="eap_right_avatar_subheader" y="3.0h" fity="true" textalign="center" font="dyn_12" color=".6 .6 .6 1" outline="true" content="mstore_eap_right_aa_1" noclick="true" />
			</panel>
			
			<!-- Right Alt Header (swapped to left) -->
			<panel y="-0.5h" x="42.5h" width="26.0h" height="5.5h" align="center" valign="top" noclick="true" name="store_eap_header_left" visible="0">
				<frame y="0" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 .7" blockinput="false" noclick="true"/>
				<frame y="0" texture="/ui/frames/roundframe.tga" color="#4c4c4c" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label y="1.0h" name="store_eap_header_left_label_1" fity="true" wrap="true" textalign="center" font="dyn_14" color=".9 .9 .9 1" outline="true" content="" noclick="true" />
				<label name="eap_left_avatar_subheader" y="3.0h" fity="true" textalign="center" font="dyn_12" color=".6 .6 .6 1" outline="true" content="mstore_eap_left_aa_1" noclick="true" />
			</panel>
			
			<!-- Footer -->
			<panel width="61.0h" height="6.4h" align="center" valign="bottom" noclick="true" name="store_eap_footer_center" visible="0">			
				<frame y="-0.2h" height="7.0h" texture="/ui/frames/rounded_bg_red.tga" borderthickness="0.6h" color=".1 .1 .1 .9" blockinput="false" noclick="true"/>
				<frame y="-0.2h" height="7.0h" texture="/ui/frames/roundframe.tga" color="#e28e1b" borderthickness="0.6h" blockinput="false" noclick="true"/>
				
				<!-- Bundle Price -->
				<panel name="eap_footer_left_bundle" x="7.0h" y="0.4h" width="16.5h" noclick="true">
					<label textalign="center" font="dyn_10" color=".7 .7 .7 1" shadow="true" content="mstore_eap_bundle_selected" noclick="true" />
					<!-- Selected -->
					<panel y="2.2h" height="3.0h" align="center" name="ms_eap_bundleselect_box"
						onclick="ShowWidget('ms_eap_bundleselect_dropup'); HideWidget('ms_eap_bundleselect_box');"
					>
						<frame texture="/ui/frames/rounded_bg_green.tga" borderthickness="0.6h" color="1 1 1 .8" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="#e28e1b" borderthickness="0.6h" blockinput="false" noclick="true"/>						
						
						<label name="mstore_eap_selected_bundle_label" x="1.0h" y="-0.2h" height="100%" textvalign="center" font="dyn_16" color="#FFFFFF" shadow="true" content="mstore_eap_bundle_3" noclick="true" />
												
						<panel grow="true" height="100%" align="right" float="right" padding="0.5h" noclick="true">
							<panel width="1" height="100%" valign="center" noclick="true">
								<panel height="95%" color="0 0 0 1" valign="center" noclick="true" />
							</panel>
							<panel grow="true" height="100%" noclick="true">
								<image width="40@" height="40%" valign="center" texture="/ui/elements/arrow_down.tga" noclick="true" />
							</panel>
							<panel width="1" height="100%" color="invisible"/>
						</panel>						
					</panel>
					
					<!-- Fake Combobox -->
					<panel y="-3.8h" height="9.0h" align="center" name="ms_eap_bundleselect_dropup" visible="0" onhide="ShowWidget('ms_eap_bundleselect_box');" >
					
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0 0 .8" blockinput="false" noclick="true"/>
						

						<button color="invisible"
							onmouseover=""
							onmouseout=""
							onclick="HideWidget('ms_eap_bundleselect_dropup');"	
							onclicklua="Store.SelectBundle(self, 1)"
							onmouseoverlua="Store.HoverBundle(self, 1)"
							onmouseoutlua="Store.RestoreHoverBundle(self, 1)"
							y="0" height="3.0h" align="center"
						>

							<widgetstate statename="up">
								<frame texture="/ui/frames/rounded_bg_green.tga" borderthickness="0" color="1 1 1 1" blockinput="false" noclick="true"/>					
							</widgetstate>
							<widgetstate statename="over">							
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0.8 0 1" blockinput="false" noclick="true"/>							
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0.8 0 1" blockinput="false" noclick="true"/>							
							</widgetstate>
							<label name="eap_bundle_name_label_1" x="1.0h" y="-0.1h" height="100%" textvalign="center" font="dyn_16" color="#FFFFFF" shadow="true" content="mstore_eap_bundle_1" noclick="true" />
						</button>
				
						<button color="invisible"
							onmouseover=""
							onmouseout=""
							onclick="HideWidget('ms_eap_bundleselect_dropup');"
							onclicklua="Store.SelectBundle(self, 2)"
							onmouseoverlua="Store.HoverBundle(self, 2)"
							onmouseoutlua="Store.RestoreHoverBundle(self, 2)"							
							y="3.0h" height="3.0h" align="center"
						>

							<widgetstate statename="up">
								<frame texture="/ui/frames/rounded_bg_green.tga" borderthickness="0" color="1 1 1 1" blockinput="false" noclick="true"/>					
							</widgetstate>
							<widgetstate statename="over">							
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0.8 0 1" blockinput="false" noclick="true"/>							
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0.8 0 1" blockinput="false" noclick="true"/>							
							</widgetstate>
							<label name="eap_bundle_name_label_2" x="1.0h" y="-0.1h" height="100%" textvalign="center" font="dyn_16" color="#FFFFFF" shadow="true" content="mstore_eap_bundle_2" noclick="true" />
						</button>	

						<button color="invisible"
							onmouseover=""
							onmouseout=""
							onclick="HideWidget('ms_eap_bundleselect_dropup');"
							onclicklua="Store.SelectBundle(self, 3)"
							onmouseoverlua="Store.HoverBundle(self, 3)"
							onmouseoutlua="Store.RestoreHoverBundle(self, 3)"
							y="6.0h" height="3.0h" align="center"
						>

							<widgetstate statename="up">
								<frame texture="/ui/frames/rounded_bg_green.tga" borderthickness="0" color="1 1 1 1" blockinput="false" noclick="true"/>					
							</widgetstate>
							<widgetstate statename="over">							
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0.8 0 1" blockinput="false" noclick="true"/>							
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0" color="0 0.8 0 1" blockinput="false" noclick="true"/>							
							</widgetstate>
							<label name="eap_bundle_name_label_3" x="1.0h" y="-0.1h" height="100%" textvalign="center" font="dyn_16" color="#FFFFFF" shadow="true" content="mstore_eap_bundle_3" noclick="true" />
						</button>	
						
						<frame color="invisible" borderthickness="1" bordercolor="#e28e1b" blockinput="false" noclick="true"/>
						
					</panel>
				</panel>
				
				<!-- Purchase Buttons -->
				<panel name="eap_footer_right_price" x="-7.0h" y="0.4h" width="16.5h" align="right" noclick="true"
					onload="CreateString('ui_eapSelectedBundleID', '-1');"
				>
					<panel name="mstore_eap_purchase_cost" height="1.6h" valign="top" align="center" x="35%" noclick="1" >
						<label name="mstore_eap_purchase_cost_label" x="2.0h" fitx="true" height="100%" textvalign="center" font="dyn_14" color="#FFCC00" shadow="true" content="---" noclick="true" />
						<image height="100%" width="100@" texture="/ui/fe2/store/gold_coins.tga" noclick="true"/>
					</panel>
					<panel y="1.8h" height="3.8h" align="center" noclick="true">

						<instance name="EAPPurchaseButton" label="mstore_purchased" enabled="false" visible="false"
							watch="populateEAPItem"
							ontrigger="
								If(
									param0 == {id=1},
									SetVisible(param1 ge 1 and microStoreAlreadyOwned{id=1})
								);
							"
						/>

						<instance name="EAPPurchaseButton" id="{id=1}" label="mstore_purchase"
							watch="MicroStoreProcessing"
							ontrigger="SetEnabled(!param0);"
							oneventlua="UIManager.GetInterface('main'):HoNStoreF('PurchaseEAP')"
							watch1="populateEAPItem"
							ontrigger1="
								If(
									param0 == {id=1},
									If(
										param1 ge 1 and !microStoreAlreadyOwned{id=1},
										Split(
											SetVisible(true),
											SetOnClick(
												'
													DoEvent();
												'
											)
										),
										Split(
											SetVisible(false),
											SetOnClick('')
										)
									)
								);
							"
						/>


					</panel>					
				</panel>				
				
				<!-- Release Date -->
				<panel x="-0.2h" y="0.4h" width="12.0h" align="center" float="bottom" padding="0.3h" noclick="true"
					onload="
						CreateInt('eapStartTime{id=1}', 0);
						CreateInt('eapEndTime{id=1}', 0);
					"		
					watch="splitEAPTimes"
					ontrigger="
						If(
							param0 == {id=1},
							Split(
								Set('eapStartTime{id=1}', param1),
								Set('eapEndTime{id=1}', param2)
							)
						);
					"					
				>
					<label fity="true" textalign="center" font="dyn_10" color=".7 .7 .7 1" shadow="true" content="mstore_releasedate" 
						watch1="populateEAPItem" ontrigger1="If(eapStartTime{id=1} gt 0,  SetText(Translate('mstore_releasedate')), SetText(Translate('mstore_playable')) );"			
					/>
					<label fity="true" textalign="center" font="dyn_14" color="white" shadow="true" content="--/--/----"
						onhide="SetWatch('');"
						watch=""
						ontrigger="
							If(
								microStoreID{id=1} ge 1,
								If(eapStartTime{id=1} gt 0, 
									SetText(
										GetDayFromTime(GetTimeDifference(eapEndTime{id=1}, GetLocalServerTime())) # ':' #
										GetHourFromTime(GetTimeDifference(eapEndTime{id=1}, GetLocalServerTime())) # ' - ' #
										GetMinuteFromTime(GetTimeDifference(eapEndTime{id=1}, GetLocalServerTime())) # ':' #
										GetSecondFromTime(GetTimeDifference(eapEndTime{id=1}, GetLocalServerTime()))
										
									),
									SetText(Translate('mstore_outnow'))
								)
							);
						"
						watch1="populateEAPItem"
						ontrigger1="
							If(
								param0 == {id=1},
								If(
									eapStartTime{id=1} gt 0,
									SetText(FormatDateTime(eapEndTime{id=1}, '%m/%d/%Y', true)),
									SetText(Translate('mstore_outnow'))
								)
							);
						"
					/>
				</panel>
				

				<!-- Left Rotation -->
				<panel x="-1.5h" y="-0.8h" width="120@" height="120%" align="left" noclick="true">
					<image width="100@" height="100%" texture="/ui/fe2/store/promo/store_sales.tga" hflip="true" noclick="true" />					
					<instance name="EARotationButton" width="5.2h" height="5.4h" align="center" x="-0.1h" y="1.3h"
						watch="MicroStoreProcessing"
						ontrigger="SetEnabled(!param0);"
						onmouseldown="
							CallEvent('storeEAPRotation', 4);
						"
						onmouselup="
							CallEvent('storeEAPRotation', 5);
						"
						onmouseout="
							CallEvent('storeEAPRotation', 5);
						"
					/>	
				</panel>
				
				<!-- Right Rotation -->
				<panel x="1.5h" y="-0.8h" width="120@" height="120%" align="right" noclick="true">
					<image width="100@" height="100%" texture="/ui/fe2/store/promo/store_sales.tga" noclick="true" />
					<instance name="EARotationButton" width="5.2h" height="5.4h" align="center" x="0.1h" y="1.3h" hflip="true"
						watch="MicroStoreProcessing"
						ontrigger="SetEnabled(!param0);"
						onmouseldown="
							CallEvent('storeEAPRotation', 3);
						"
						onmouselup="
							CallEvent('storeEAPRotation', 5);
						"
						onmouseout="
							CallEvent('storeEAPRotation', 5);
						"
					/>
				</panel>

			</panel>
			
			
			<!-- Left Alt Star (EA Exclusive Alt Av) -->
			<panel align="center" width="14h" height="14h" valign="bottom" x="-52.0h" y="-1h" noclick="true" name="store_eap_star_left">
				<panel name="ms_eap_left_star_1" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/price_star.tga" noclick="true"/>	
					<panel width="100%" float="bottom" noclick="true" valign="center" grow="true">
						<label name="eap_right_star_1_1" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_includes" noclick="true" />
						<label name="eap_right_star_1_2" fity="true" textalign="center" textvalign="center" font="dyn_14" color="#ffe400" shadow="true" content="mstore_noeap_bonus" noclick="true" />
						<label name="eap_right_star_1_3" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_alt_avatar" noclick="true" />
					</panel>
				</panel>
				<panel name="ms_eap_left_star_2" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/price_star.tga" rendermode="grayscale" noclick="true"/>
					<panel width="100%" float="bottom" noclick="true" valign="center" grow="true">
						<label name="eap_left_star_2_1" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_select" noclick="true" />
						<label name="eap_left_star_2_2" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_eap_bundle_2" noclick="true" />
						<label name="eap_left_star_2_3" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_to_unlock" noclick="true" />
					</panel>
				</panel>
			</panel>
			
			<!-- Right Alt Star (Regular Alt Av) -->
			<panel align="center" width="14h" height="14h" valign="bottom" x="52.0h" y="-1h" noclick="true"  name="store_eap_star_right">
				<panel name="ms_eap_right_star_1" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/price_star.tga" noclick="true"/>	
					<panel width="100%" float="bottom" noclick="true" valign="center" grow="true">
						<label name="eap_left_star_1_1" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_includes" noclick="true" />
						<label name="eap_left_star_1_2" fity="true" textalign="center" textvalign="center" font="dyn_14" color="#ffe400" shadow="true" content="mstore_noeap_exclusive" noclick="true" />
						<label name="eap_left_star_1_3" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_eap_only" noclick="true" />
						<label name="eap_left_star_1_4" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_alt_avatar" noclick="true" />
					</panel>
				</panel>
				<panel name="ms_eap_right_star_2" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/price_star.tga" rendermode="grayscale" noclick="true"/>
					<panel width="100%" float="bottom" noclick="true" valign="center" grow="true">
						<label name="eap_right_star_2_1" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_select" noclick="true" />
						<label name="eap_right_star_2_2" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_eap_bundle_3" noclick="true" />
						<label name="eap_right_star_2_3" fity="true" textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" content="mstore_noeap_to_unlock" noclick="true" />
					</panel>
				</panel>

			</panel>

			<!-- Non-Legacy Center Txt -->
			<panel align="center" valign="center" width="100%" height="100%" visible="false" color="0 0 0 .7" name="eap_text_non_legacy"
				onload="
					If(
						!VarExists('FeaturedHeroInfoDisplayed'),
						CreateBool('FeaturedHeroInfoDisplayed', false)
					);
				"
				watch="AccountInfo"
				ontrigger="
					If(
						!HasAllHeroes() and !FeaturedHeroInfoDisplayed,
						Split(
							SetVisible(true),
							SetSave('FeaturedHeroInfoDisplayed', true)
						),
						SetVisible(false)
					);
				"
			>
			
				<panel align="center" valign="center" width="32.0h" grow="true">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 1" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color=".4 .4 .4 1" borderthickness="0.6h" blockinput="false" noclick="true"/>			
					<panel width="-3.0h" grow="true" align="center" float="bottom">
						<panel height="1.0h"/>
						<panel width="100%" grow="true" float="bottom">
							<label color="#FFCC00" shadow="true" font="dyn_14" textvalign="center" height="1.75h" content="mstore_latestheroes"/>
							<panel height="1.0h"/>
							<label color="white" shadow="true" font="dyn_11" textvalign="center" wrap="true" fity="true" content="mstore_eapdesc_f2p"/>
							<panel height="1.0h"/>
						</panel>
						<panel width="100%" height="2.4h">
							<instance
								name="button2" button_name="unnamedButton251"
								label="general_close"
								font="dyn_10"
								width="12.0h"
								align="center"
								onclick="Call('eap_text_non_legacy', 'FadeOut(250);');"
							/>
						</panel>
						<panel height="1.5h"/>
					</panel>					
				</panel>				
			</panel>
			
			<!-- Legacy Center Txt -->
			<panel align="center" valign="center" width="100%" height="100%" visible="false" color="0 0 0 .7" name="eap_text_legacy"
				onload="
					If(
						!VarExists('EAPInfoDisplayed'),
						CreateBool('EAPInfoDisplayed', false)
					);
				"
				watch="AccountInfo"
				ontrigger="
					If(
						HasAllHeroes() and !EAPInfoDisplayed,
						Split(
							SetVisible(true),
							SetSave('EAPInfoDisplayed', true)
						),
						SetVisible(false)
					);
				"
			>
				<panel align="center" valign="center" width="32.0h" grow="true">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 1" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color=".4 .4 .4 1" borderthickness="0.6h" blockinput="false" noclick="true"/>			
					<panel width="-3.0h" grow="true" align="center" float="bottom">
						<panel height="1.0h"/>
						<panel width="100%" grow="true" float="bottom">
							<label color="#FFCC00" shadow="true" font="dyn_14" textvalign="center" height="1.75h" content="mstore_eap"/>
							<panel height="1.0h"/>
							<if condition="!cl_garenaEnable">
								<label color="white" shadow="true" font="dyn_11" textvalign="center" wrap="true" fity="true" content="mstore_eapdesc_legacy"/>
							</if>
							<if condition="cl_garenaEnable">
								<label color="white" shadow="true" font="dyn_11" textvalign="center" wrap="true" fity="true" content="mstore_eapdesc_garena"/>
							</if>
							<panel height="1.0h"/>
						</panel>
						<panel width="100%" height="2.4h">
							<instance
								name="button2" button_name="unnamedButton252"
								label="general_close"
								font="dyn_10"
								width="12.0h"
								align="center"
								onclick="Call('eap_text_legacy', 'FadeOut(250);');"
							/>
						</panel>
						<panel height="1.5h"/>
					</panel>					
				</panel>
			</panel>

			<panel color="black" width="20h"/>
			<panel color="black" width="20h" align="right"/>

			<image width="12h" height="100%" x="20h" texture="/ui/fe2/elements/shadow_hgradient.tga" noclick="true"/>
			<image width="12h" height="100%" x="-20h" texture="/ui/fe2/elements/shadow_hgradient.tga" noclick="true" align="right" hflip="true"/>
			
			
			<!-- View All / Back to Store Buttons -->
			<panel noclick="1" name="mstore_eap_back_to_store_holder" >
				<panel noclick="true" watch="AccountInfo" ontrigger="SetVisible(!HasAllHeroes());" visible="false">
					<instance button_name="store_button_ea_allheroes" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction', 17, true)" name="button2" align="center" valign="bottom" x="39.0h" y="-1.5h" width="12h" height="2.8h" 
						label="mstore_viewallheroes" onclick="Set('_microStore_Category', 71); Set('_microStore_RequestCode', 1); CallEvent('MicroStoreAction', 0);" luatable="1"
						watch1="MicroStoreProcessing" ontrigger1="SetEnabled(!param0);"
					/>
					<instance name="button2" button_name="unnamedButton253" valign="bottom" align="center" x="-39.0h" y="-1.5h" width="12h" height="2.8h" label="mstore_backtostore" onclick="Set('_microStore_Category', 0); Set('_microStore_RequestCode', 0); CallEvent('MicroStoreAction', 0);" watch1="MicroStoreProcessing" ontrigger1="SetEnabled(!param0);"/>
				</panel>			

				<instance name="button2" button_name="unnamedButton254" align="center" valign="bottom" x="-39.0h" y="-1.5h" width="12h" height="2.8h" label="mstore_backtostore" onclick="Set('_microStore_Category', 0); Set('_microStore_RequestCode', 0); CallEvent('MicroStoreAction', 0);" watch1="MicroStoreProcessing" ontrigger1="SetEnabled(!param0);" watch="AccountInfo" ontrigger="SetVisible(HasAllHeroes());"/>
			</panel>
		
			<panel width="124.8h" noclick="true" align="center">
				<instance name="mstore_btn_closex" width="2h" height="2h" align="right" x="-1h" y="1h"
					watch="MicroStoreProcessing"
					ontrigger="SetEnabled(!param0);"
					onclick="
						Set('_microStore_Category', If(HasAllHeroes(), 0, 71));
						Set('_microStore_RequestCode', If(HasAllHeroes(), 0, 1));
						CallEvent('MicroStoreAction', 0);
					"
				/>
			</panel>

		</panel>
	</template>

</package>