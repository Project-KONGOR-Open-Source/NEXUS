<?xml version="1.0" encoding="UTF-8"?>
<package>

	<trigger name="instantiateEAPAvatarData"/>
	<trigger name="getEAPAvatarData"/>
	<trigger name="EAPAvatarSelected"/>
	<trigger name="getEAPHeroInfo"/>

	<trigger name="NewEAPTimerCountdownDigit1"/>
	<trigger name="ClearEAPTimerCountdownDigit1"/>
	<trigger name="NewEAPTimerCountdownDigit2"/>
	<trigger name="ClearEAPTimerCountdownDigit2"/>
	<trigger name="EAPModelAngles"/>
	<trigger name="splitEAPTimes"/>

	<trigger name="populateEAPItem"/>
	<!--
		0 - slot ID
		1 - product id
		2 - hero_name
		3 - expiration hosttime
		4 - price
		5 - silver price
	-->
	
	<template name="heroDifficultyStarEAP">
		<panel width="100@" height="100%" sticky="true" stickytoinvis="false" visible="false" noclick="true"
			watch="populateEAPItem"
			ontrigger="
				If(
					param0 == {id=1},
					If(
						param1 ge 1,
						SetVisible(GetHeroDifficulty(param2) ge {difficulty=1} - 0.5),
						SetVisible(false)
					)
				);
			"
		>
			<panel width="50%" clip="true" noclick="true">
				<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="1 1 1 1" visible="false"
					watch="populateEAPItem"
					ontrigger="
						If(
							param0 == {id=1},
							If(
								param1 ge 1,
								SetVisible(GetHeroDifficulty(param2) lt {difficulty=1}),
								SetVisible(false)
							)
						);
					"
				/>
			</panel>
			<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/hero_popularity_pip.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="1 1 1 1" visible="false"
				watch="populateEAPItem"
				ontrigger="
					If(
						param0 == {id=1},
						If(
							param1 ge 1,
							SetVisible(GetHeroDifficulty(param2) ge {difficulty=1}),
							SetVisible(false)
						)
					);
					
				"
			/>
		</panel>
	</template>

	<template name="EAPVoiceButtonState">
		<widgetstate statename="{statename}" x="{x}" y="{y}">
			<frame texture="/ui/frames/circle.tga" color="1 .9 .9 .1" bordercolor="1 .9 .9 .1" borderthickness="33%" visible="{over=false}" />
			<frame texture="/ui/frames/circle.tga" color="0 0 0 .2" bordercolor="0 0 0 .2" borderthickness="33%" visible="{down=false}" />
		</widgetstate>
	</template>
	<template name="EAPVoiceButton">
		<button
			color="invisible"
			onmouseover="{onmouseover}"
			onmouseout="{onmouseout}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			onclick="{onclick}"
		>
			<instance name="EAPVoiceButtonState" statename="up"/>
			<instance name="EAPVoiceButtonState" statename="over" over="true"/>
			<instance name="EAPVoiceButtonState" statename="down" down="true"/>
			<instance name="EAPVoiceButtonState" statename="disabled"/>
		</button>
	</template>
	
	<template name="eapHeroInfo">
		<panel noclick="true" color="invisible"
			name="eapHeroInfo{product_id}"
			onevent0="
				Trigger('getEAPHeroInfo', param0, '{definition}', '{exclusivealt}', '{standardalt}');
			"
		>
		</panel>
	</template>

	<template name="eapAvatarIconState">
		<widgetstate statename="{statename}" x="{x}" y="{y}">
			<!-- Avatar Type Tag -->
			<panel x="100@" y="0" grow="true" height="100%" noclick="true">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color=".15 .15 .15 1" blockinput="false" noclick="true"/>				
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color=".4 0 0 1" blockinput="false" noclick="true" visible="{selected=false}" watch="EAPAvatarSelected" ontrigger="If(param0 == {slotID=1}, SetVisible(StringEquals(param1, '{product_id}')));"/>				
				<frame texture="/ui/frames/roundframe.tga" color="{frameBorderColor=#000000}" borderthickness="0.4h" blockinput="false" noclick="true"/>
				<label x="1.0h" fitx="true" fitxpadding="0.8h" textvalign="center" font="dyn_10" color="1 1 1 1" shadow="true" content="{avatarLabel}" noclick="true"/>
			</panel>
			<image width="210@" height="210%" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/avatars_display/subheader_icon.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" align="center" valign="center" group="featureIconBackers"/>
			<image oninstantiate="SetTexture('{icon_path}');" noclick="true"/>
			<frame color="invisible" bordercolor="{frameBorderColor=#455166}" borderthickness="1" noclick="true" />
			<frame color="invisible" bordercolor="{frameBorderColor=#FFCC00}" borderthickness="2" noclick="true" align="center" valign="center" width="+2" height="+2" visible="{selected=false}" watch="EAPAvatarSelected" ontrigger="If(param0 == {slotID=1}, SetVisible(StringEquals(param1, '{product_id}')));" />
		</widgetstate>
	</template>

	<template name="eapAvatarIcon">
		<panel width="100@" height="100%">
			<button
				name="eapAvatarIcon{product_id}"
				onmouseover="ShowWidget('mstore_tip_eap_altavatar');"
				onmouseout="HideWidget('mstore_tip_eap_altavatar');"
				onclick="
					DoEvent(0);
				"
				onevent0="
					Trigger('EAPAvatarSelected', {slotID=1}, '{product_id}');
					Set('_lastEAPSoundProduct{slotID=1}', '{product}');
					##
					CallEventParams(
						'eap_model_gears', {product_id}
					);
					##
				"
			>
				<instance name="eapAvatarIconState" avatarLabel="{avatarLabel}" product_id="{product_id}" icon_path="{icon_path}" slotID="{slotID=1}" selected="{selected=false}" statename="up"/>
				<instance name="eapAvatarIconState" avatarLabel="{avatarLabel}" product_id="{product_id}" icon_path="{icon_path}" slotID="{slotID=1}" selected="{selected=false}" frameBorderColor="#cccccc" statename="over"/>
				<instance name="eapAvatarIconState" avatarLabel="{avatarLabel}" product_id="{product_id}" icon_path="{icon_path}" slotID="{slotID=1}" selected="{selected=false}" statename="down" x="1" y="1"/>
			</button>
		</panel>
	</template>

	<template name="EARotationButton">
		<button
			color="invisible"
			width="{width}" height="{height}"
			align="{align}" valign="{valign}"
			x="{x}" y="{y}"
			onevent="{onevent}" onevent1="{onevent1}" onevent2="{onevent2}"
			watch="{watch}" ontrigger="{ontrigger}" watch1="{watch1}" ontrigger1="{ontrigger1}"
			onmouselup="{onmouselup}" onmouseldown="{onmouseldown}"
			onmouseover="{onmouseover}"
			onmouseout="{onmouseout}"
			
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/elements/rotation_up.tga" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>		
			<widgetstate statename="over">
				<image texture="/ui/fe2/elements/rotation_over.tga" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>			
			<widgetstate statename="down" x="1" y="1">				
				<image texture="/ui/fe2/elements/rotation_over.tga" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>
		</button>
	</template>
	
	<template name="EAPPurchaseButtonState">
		<widgetstate statename="{statename}" x="{x}" y="{y}">
			<image width="132%" height="33@" align="center" valign="center" texture="/ui/fe2/store/promo/storebtn_blank_{stateimage}.tga" noclick="true" />
			<label y="-0.2h" height="100%" textvalign="center" textalign="center" font="dyn_14" color="{labelcolor}" shadow="true" content="{label}" />
		</widgetstate>
	</template>

	<template name="EAPPurchaseButton">
		<button
			color="invisible"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); {onmouseover}"
			onmouseout="{onmouseout}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			enabled="{enabled=true}"
			oneventlua="{oneventlua}"
			visible="{visible}"
		>
			<instance name="EAPPurchaseButtonState" label="{label}" statename="up" stateimage="normal" labelcolor="#efa234" />
			<instance name="EAPPurchaseButtonState" label="{label}" statename="over" stateimage="over" labelcolor="#ffd08d" />
			<instance name="EAPPurchaseButtonState" label="{label}" statename="down" stateimage="down" labelcolor="#864f00" x="1" y="1" />
			<instance name="EAPPurchaseButtonState" label="{label}" statename="disabled" stateimage="normal" labelcolor="#414141" />
		</button>
	</template>

	<template name="storeEAPAbility">
		<panel width="100@" height="100%" noclick="true">
			<image noclick="true" watch="populateEAPItem" ontrigger="
					If(
						param0 == {slotID=1},
						If(
							param1 ge 1,
							SetTexture(GetEntityIconPath('Ability_' # SubString(param2, 5, -1) # '{id=1}'))
						)
					);
				"
			/>
		</panel>
	</template>

	<template name="storeEAPDisplay">
		<panel name="storeEAPDisplay" height="50h" width="178h" align="center" visible="false" color="black" onmouseldown="HideWidget('ms_eap_bundleselect_dropup');"
			onevent0="
				Call('store_cover', 'FadeIn(250);');
				SleepWidget(250, 'DoEvent(2);');
				PlayHeroPreviewSoundFromProduct('');
			"
			onevent1="
				Call('store_cover', 'FadeIn(250);');
				SleepWidget(250, 'DoEvent(3);');
			"

			onevent2="
				SetVisible(true);
				HideWidget('shopkeeperContainer');
				Call('store_cover', 'FadeOut(250);');
			"

			onevent3="
				SetVisible(false);
				ShowWidget('shopkeeperContainer');
				Call('store_cover', 'FadeOut(250);');
			"
			
			onevent4="
				## Populate with data ##
				ExplodeTrigger('splitEAPTimes', '-1,-1|-1,-1', '|', ',');
				ExplodeTrigger('splitEAPTimes', microStoreTimes, '|', ',');
				CallEventParamsX(name, 5, 1);
			"
			onevent5="
				
				If(
					*('microStoreID' # param0) ge 1,
					ExplodeTrigger('mstoreSplitAvatarProductCode', 'hero.' # *('microStoreCode' # param0), '|', '.')
				);

				If(
					*('microStoreID' # param0) ge 1,
					If(
						true, ##IsEarlyAccessHero(mstoreAvatarsHeroName) - allow non EAP ## 
						If(
							WidgetExists('eapHeroInfo' # *('microStoreID' # param0)),
							Split(
								CallEventParamsX('eapHeroInfo'  # *('microStoreID' # param0), 0, param0),
								GroupCall('eap_models_hero', 'SetVisible(1);'), ## show heroes ##
								HideWidget('eapHeroUpdateNotice' # param0),
								HideWidget('eapNotAvailable')
							),
							Split(
								HideWidget('store_eap_header_left'),
								HideWidget('store_eap_header_center'),
								HideWidget('store_eap_header_right'),
								HideWidget('store_eap_footer_center'),
								HideWidget('eapNotAvailable'),
								GroupCall('eap_models_hero', 'SetVisible(0);'),  ## hide heroes ##
								ShowWidget('eapHeroUpdateNotice' # param0)		## This is going to have to be a woops case in the even that the hero gets set up fully and yet isnt properly patched in ##
							)
						),
						Split(
							HideWidget('store_eap_header_left'),
							HideWidget('store_eap_header_center'),
							HideWidget('store_eap_header_right'),
							HideWidget('store_eap_footer_center'),
							GroupCall('eap_models_hero', 'SetVisible(0);'),  ## hide heroes ##
							ShowWidget('eapHeroUpdateNotice' # param0),
							HideWidget('eapNotAvailable')
						)
					),
					Split(
						HideWidget('store_eap_header_left'),
						HideWidget('store_eap_header_center'),
						HideWidget('store_eap_header_right'),
						HideWidget('store_eap_footer_center'),
						HideWidget('eapHeroUpdateNotice' # param0),
						GroupCall('eap_models_hero', 'SetVisible(0);'),   ## hide heroes ##
						DoEvent(6)
					)
				);


			"
			onevent6="
				## Show the NA if the button will be saying EA- else redir to heroes ##
				If(!HasAllHeroes(),
					ShowWidget('eapNotAvailable'),
					ShowWidget('eapNotAvailable')
				);
			"
			watch5="mstoreSplitAvatarProductCode2"
			ontrigger5="
				Set('mstoreEAPAvatarName2', param1);
				Set('mstoreEAPHeroName2', param0);
			"	
			watch6="mstoreSplitAvatarProductCode3"
			ontrigger6="
				Set('mstoreEAPAvatarName3', param1);
				Set('mstoreEAPHeroName3', param0);			
			"				
			watch0="getEAPHeroInfo"
			ontrigger0="
				LoadGameMechanics();
				If(!_entityDefinitionsLoaded, LoadEntityDefinitionsFromFolder(param1));
				ShowWidget('store_eap_header_left');
				ShowWidget('store_eap_header_center');
				ShowWidget('store_eap_header_right');
				ShowWidget('store_eap_footer_center');		
				ExplodeTrigger('mstoreSplitAvatarProductCode3', microStoreCode3, '.', '.');
				ExplodeTrigger('mstoreSplitAvatarProductCode2', microStoreCode2, '.', '.');
				ExplodeTrigger('mstoreSplitAvatarProductCode', 'hero.' # *('microStoreCode' # param0), '|', '.');		##Not really used as intended, just to grab out the middle portion ##
				Echo('mstoreAvatarsHeroName = ' # mstoreAvatarsHeroName);
				
				If(!StringEmpty(mstoreAvatarsHeroName),
					Trigger(
						'populateEAPItem',
						param0,
						*('microStoreID' # param0),
						mstoreAvatarsHeroName,
						-1,		## timestamp for expiration [ended up unused] ##
						*('microStorePrice' # param0),
						*('microStoreSilverPrice' # param0),
						mstoreEAPAvatarName2,
						mstoreEAPAvatarName3,
						*('microStoreID2'),
						Translate('mstore_product'#*('microStoreID2')#'_name'),
						*('microStorePrice2'),
						*('microStoreSilverPrice2'),
						*('microStoreID3'),
						Translate('mstore_product'#*('microStoreID3')#'_name'),
						*('microStorePrice3'),
						*('microStoreSilverPrice3')				
					)
				);
				
			"
			onshow="
				## CallEvent('EAPTestHelper', 0); ##
				SetWatch('HostTime');
			"
			onhide="
				SetWatch('');
			"
			onload="
				CreateFloat('eapModelAngleXPercent', 0);
				CreateFloat('eapModelAngleYPercent', 0);
				CreateFloat('eapModelTargXAngle', 0);
				CreateFloat('eapModelTargYAngle', 0);
				CreateFloat('eapModelAngleXCurPercent', 0);
				CreateFloat('eapModelAngleYCurPercent', 0);
				CreateString('mstoreEAPAvatarName2');
				CreateString('mstoreEAPHeroName2');
				CreateString('mstoreEAPAvatarName3');
				CreateString('mstoreEAPHeroName3');						
			"

			ontrigger="
				Set(
					'eapModelAngleXPercent',
					(
						Max(
							GetAbsoluteX(),
							Min(
								GetAbsoluteX() + GetWidth(),
								GetMouseX()
							)
						) - GetAbsoluteX()
					) / GetWidth()
				);

				Set(
					'eapModelAngleYPercent',
					(
						Max(
							GetAbsoluteY(),
							Min(
								GetAbsoluteY() + GetHeight(),
								GetMouseY()
							)
						) - GetAbsoluteY()
					) / GetHeight()
				);

				Set(
					'eapModelAngleXCurPercent',
					eapModelAngleXCurPercent + ((eapModelAngleXPercent - eapModelAngleXCurPercent) * (Frametime / 500))
				);


				Set(
					'eapModelAngleYCurPercent',
					eapModelAngleYCurPercent + ((eapModelAngleYPercent - eapModelAngleYCurPercent) * (Frametime / 500))
				);

				Set('eapModelTargYAngle', ((eapModelAngleYCurPercent * -6) + 8));
				Set('eapModelTargXAngle', ((eapModelAngleXCurPercent * -16) + 8));

				Trigger('EAPModelAngles', eapModelTargYAngle # ' 0 ' # eapModelTargXAngle);
			"
		>
			
			<!-- background with side gears etc -->
			<modelpanel
				ontrigger9lua="ResourceManager.RegisterModel('/ui/fe2/store/eap/gears/gears.mdf', 'store', self)" resourcecontext="store" watch9="MainRegisterModels"
				name="eap_model_center_background"
				group="eap_models"
				visible="1"
				noclick="true"
				anim="idle"
				cameradistance="0"
				lookat="false"
				camerapos="0 660 157"
				cameraangles="-3 0  180"
				camerafov="41"
				cameranear="1"
				carmerafar="5000"
				depthclear="true"
				depthcompress="true"
				sunazimuth="-85"
				sunaltitude="150"
				suncolor="1 1 1"
				effect="/ui/fe2/store/eap/gears/lights.effect"
				watch="EAPModelAngles"
				ontrigger="SetModelAngles(param);"
				onshow="
					GroupCall(
						'eap_models',
						'
							SetModelPos(\'0 -400 -25\');
						'
					);
					GroupCall(
						'eap_models_hero',
						'
							SetModelPos(\'0 -400 -25\');
						'
					);					
				"
			/>
			
			<panel noclick="true" color="invisible" name="storeEAPRotation"
				onload="
					CreateBool('eapRotationDirection', true);	## Clockwise ##
					CreateFloat('eapRotationPosition', 0);
				"
				onhide="DoEvent(5);"
				watch=""
				ontrigger="
					## Rotation calc ##
					Set(
						'eapRotationPosition',
						If(
							eapRotationDirection,
							(eapRotationPosition + (Frametime / 4000)),
							(eapRotationPosition - (Frametime / 4000))
						)
					);
					
					If(
						eapRotationPosition gt 1,
						Set('eapRotationPosition', eapRotationPosition % 1)
					);
					
					If(
						eapRotationPosition lt 0,
						Set('eapRotationPosition', 1 + eapRotationPosition)
					);
					
					DoEvent(6);
				"
				onevent3="
					## Start rotation clockwise ##
					GroupCall('eap_models', 'SetAnimSpeed(0);');
					Set('eapRotationDirection', true);
					##Call('eap_model_gears', 'Set(\'eapRotationPosition\', GetAnimOffsetTime());');##
					
					SetWatch('HostTime');
					SleepWidget(0, '');		## Clear existing sleepwidget ##
					Call('storeEAPRotation_heroes', 'DoEvent(3)');
				"
				onevent4="
					## Start rotation counterclockwise ##
					GroupCall('eap_models', 'SetAnimSpeed(0);');
					Set('eapRotationDirection', false);
					##Call('eap_model_gears', 'Set(\'eapRotationPosition\', GetAnimOffsetTime());');##
					SetWatch('HostTime');
					SleepWidget(0, '');		## Clear existing sleepwidget ##
					Call('storeEAPRotation_heroes', 'DoEvent(4)');
				"
				onevent5="
					## Disable ##
					SetWatch('');
					SleepWidget('2000', 'GroupCall(\'eap_models\', \'SetAnimSpeed(1);\');');
					Call('storeEAPRotation_heroes', 'DoEvent(5)');
				"
				onevent6="
					## Apply ##
					GroupCall('eap_models', 'SetAnimOffsetTime(eapRotationPosition);');
				"
				onevent7="
					## Reset (selecting a different model generally) ##
					Set('eapRotationPosition', 0);
					DoEvent(6);
					SleepWidget(0, '');		## Clear existing sleepwidget ##
					Call('storeEAPRotation_heroes', 'DoEvent(7)');
				"
			/>
					
			<panel name="storeEAPRotation_heroes" noclick="1"
				onload="
					CreateBool('heroPedestalDirection', true);	## Clockwise ##
					CreateFloat('heroPedestalPosition', 0);
					CreateFloat('heroPedestalSpeed', 0.1);
					GroupCall('eap_models_hero', 'SetAnimSpeed(0);');
				"
				onshow="GroupCall('eap_models_hero', 'SetAnimSpeed(0);'); SetWatch('HostTime');"
				onhide="DoEvent(5); SetWatch('');"
				watch=""
				ontrigger="
					## Rotation calc ##
					Set(
						'heroPedestalPosition',
						If(
							heroPedestalDirection,
							(heroPedestalPosition + (Frametime * heroPedestalSpeed / 2000)),
							(heroPedestalPosition - (Frametime * heroPedestalSpeed / 2000))
						)
					);
					
					If(
						heroPedestalPosition gt 1,
						Set('heroPedestalPosition', heroPedestalPosition % 1)
					);
					
					If(
						heroPedestalPosition lt 0,
						Set('heroPedestalPosition', 1 + heroPedestalPosition)
					);
					
					DoEvent(6);
				"
				onevent3="
					## Start rotation clockwise ##
					Set(heroPedestalSpeed, 1.0);
					Set('heroPedestalDirection', true);
					##SetWatch('HostTime');##
				"
				onevent4="
					## Start rotation counterclockwise ##
					Set(heroPedestalSpeed, 1.0);
					Set('heroPedestalDirection', false);
					##SetWatch('HostTime');##
				"
				onevent5="
					## Disable ##
					##SetWatch('');##
					Set(heroPedestalSpeed, 0.1);
				"
				onevent6="
					## Apply ##
					##SetAnimOffsetTime(heroPedestalPosition);##
					GroupCall('eap_models_hero', 'SetModelAngles(\'0 0 \' # (heroPedestalPosition * -360));');
				"
				onevent7="
					## Reset (selecting a different model generally) ##
					Set('heroPedestalPosition', 0);
					DoEvent(6);
				"
			/>			
					
			<!-- 3x Gears Single Model
			<modelpanel
				ontrigger9lua="ResourceManager.RegisterModel('/ui/fe2/store/eap/gears/gears_{side=left}.mdf', 'store', self)" resourcecontext="store" watch9="MainRegisterModels"
				name="eap_model_gears"
				group="eap_models"
				visible="1"
				noclick="true"
				anim="idle"
				cameradistance="0"
				lookat="false"
				camerapos="0 660 157"
				cameraangles="-3 0  180"
				camerafov="41"
				cameranear="1"
				carmerafar="5000"
				depthclear="true"
				depthcompress="true"
				sunazimuth="-85"
				sunaltitude="150"
				suncolor="1 1 1"
				effect=""
				watch="EAPModelAngles"
				ontrigger="SetModelAngles(param);"
			/>
			 -->
			 
			<!-- Hero Center Model -->
			<panel noclick="1" y="-17%" width="50%" height="200%" valign="center" align="center">
				<modelpanel name="store_eap_center_hero_model" group="eap_models_hero" resourcecontext="store"
					noclick="1"
					model="/shared/models/invis.mdf"
					scenebuffer="true"
					anim="idle_eap"
					cameranear="100.0"
					camerafar="10000.0"
					depthclear="true"
					depthcompress="false"
					lookat="false"
					cameradistance="30"
					camerapos="0 3000 80"
					cameraangles="0 0 180"
					camerafov="7"
					modelpos="0 0 0"
					modelangles="-15.0 0 0.0"
					modelscale="1.0"
					visible="0"
					cull="false"
					watch="populateEAPItem"
					ontrigger="
						SetVisible(1);
						
						SetTeamColor('1 0 0');									
						SetModel(GetHeroPreviewModelPathFromProduct(param2));
						##SetModelPos(GetHeroPreviewPosFromProduct(param2));##
						SetModelAngles(GetHeroPreviewAnglesFromProduct(param2));
						
						SetModelScale(GetHeroPreviewScaleFromProduct(param2));						
						
						SetEffect('/ui/fe2/store/eap/gears/gear_middle.effect');
						SetEffectIndexed('/shared/effects/glow.effect', 0);
						SetEffectIndexed(GetHeroPreviewPassiveEffectPathFromProduct(param2), 1);
					"
					watch1=""
					ontrigger1="SetModelAngles(param);"	
					sunazimuth="120"
					sunaltitude="50"
					suncolor="0.0 0.0 0.0"
					ambientcolor="0.65 0.65 0.65"
					posteffects="true"
					posteffect=""
					outline="false"
					postoutline="/core/post/outline.posteffect"
					outlinecolor=".25 .25 .25 1"	
					onevent1="
						## Highlight ##
						SetSunColor('1 1 1');
						SetAmbientColor('0.65 0.65 0.65');
						SetEffectIndexed('/shared/effects/glow.effect', 0);
						SetPostEffects(true);
						SetPostEffect('');
						SetPostEffectOutline('/core/post/outline.posteffect');
						SetModelPanelOutline(false);
						SetOutlineColor('.25 .25 .25 1');
					"
					onevent0="
						## Darken ##
						SetSunColor('0.0 0.0 0.0');
						SetAmbientColor('0.35 0.35 0.35');
						SetEffectIndexed('', 0);
						SetPostEffects(false);
						SetPostEffect('');
						SetPostEffectOutline('/core/post/outline.posteffect');
						SetModelPanelOutline(false);
						SetOutlineColor('.25 .25 .25 1');
					"										
					onevent2="
						## Hover ##
						SetModelPanelOutline(true);
						SetOutlineColor('.25 .25 .25 1');
					"
					onevent3="
						## Un-Hover ##
						SetModelPanelOutline(false);
						SetOutlineColor('.25 .25 .25 1');
					"		
				/>
			</panel>			
			
