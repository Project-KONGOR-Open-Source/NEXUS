						<instance name="vaultCategoryTab" onclick="Trigger('ShowHidePanelToggle', '', 'vaultSubCategories');" tip_id="mstore_tip_category16" category_id="16" width="100%" height="5.5h" label="mstore_category16"/><!-- Name Color -->
						<instance name="vaultCategoryTab" onclick="Trigger('ShowHidePanelToggle', '', 'vaultSubCategories');" tip_id="mstore_tip_category4" category_id="4" width="100%" height="5.5h" label="mstore_category4"/><!-- Symbols -->
