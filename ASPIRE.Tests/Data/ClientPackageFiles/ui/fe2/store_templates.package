<?xml version="1.0" encoding="UTF-8"?>
<package>

	<!-- ============================= STYLES, PRELOADED TEXTURES =============================  -->
	<style name="microStorePaperItem" color="#00a200"/>
	<style name="microStorePaperText" color="#9d5b1a"/>
	<style name="microStorePaperTitle" color="#774515"/>
	<style name="microStorePaperCost" color="#0471d6"/>
	<style name="microStoreMetalText" color="0.8 0.9 0.8 1" outlinecolor="0 0 0 0.6" outline="true" />

	<!-- ============================= PANEL CONTROLS =============================  -->

	<!-- Store resource context helper -->
	<trigger name="storeItemViewShelfSlideOut"/>
	<trigger name="storeItemViewBookSlideOut"/>
	<trigger name="storeItemViewBookAccIconsSlideOut"/>
	<trigger name="StoreDeleteCurrentItems"/>
	<trigger name="StoreFadingInItems"/>
	<trigger name="StoreImagePreviewInit"/>
	<trigger name="StoreImagePreviewVis"/>
	<panel noclick="true" color="invisible" name="StoreResourceHelper"
		watch2="StoreFadingInItems"
		ontrigger2="
			SleepWidget(param0, 'DoEvent(0);');
		"
		watch3="MicroStoreGetCDPrice"
		ontrigger3="
			If(
				param1 gt 0,
				If(
					microStoreTempCDGold == -1 and microStoreTempCDSilver le 0,
					Split(
						Set('microStoreTempCDGold', param2),
						Set('microStoreTempCDSilver', param4)
					),
					Split(
						If(
							param2 lt microStoreTempCDGold and param2 ge 1,
							Set('microStoreTempCDGold', param2)
						),
						If(
							param4 lt microStoreTempCDSilver and param4 ge 1,
							Set('microStoreTempCDSilver', param4)
						)
					)
				)
			);
		"
		watch4="MicroStoreSaveTempChargeData"
		ontrigger4="
			Set('mtoreCRemainTempQuantity', param1);
			Set('mtoreCRemainTempStartTime', param2);
			Set('mtoreCRemainTempEndtime', param3);
		"
	/>

	<!-- Global Panel Controls (supports groups, exclusive/nonexclusive show/hides, etc.) -->
	<trigger name="ShowHidePanelToggle"/>
	<template name="ShowHidePanelToggleHelper">
		<panel noclick="true" color="invisible"
			watch="ShowHidePanelToggle"
			ontrigger="
				If(
					!IsVisible('{panel}'),
					If(
						StringEquals('{panel}', param0),
						Split(
							{showcmd=''},
							If(
								{usecustomshow=false},
								{customshow=''},
								Call('{panel}', 'SleepWidget({showDelay=200}, \'SetVisible(1); Slide(\\\'{shownX=0}\\\', \\\'{shownY=0}\\\', {showTime=300});\');')
							)
						)
					),
					If(
						StringEquals('{panel}', param0) or ({exclusive=false} and StringEquals('{panelGroup=NoGroup}', param1)),
						Split(
							{hidecmd=''},
							If(
								{usecustomhide=false},
								{customhide=''},
								Call('{panel}', 'Slide(\'{hiddenX=-110%}\', \'{hiddenY=-110%}\', {hideDelay=200}); SleepWidget({hideDelay=200}, \'HideWidget(\\\'{panel}\\\');\');')
							)
						)
					)
				);
			"
		/>
	</template>

	<instance name="ShowHidePanelToggleHelper"
		panel="storeVanitySubCategory"
		usecustomshow="true"
		usecustomhide="true"
		customshow="If(WidgetExists('storeVanitySubCategory'), CallEvent('storeVanitySubCategory', 0))"
