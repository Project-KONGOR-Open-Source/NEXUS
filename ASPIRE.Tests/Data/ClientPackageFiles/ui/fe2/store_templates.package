						<label textalign="center" textvalign="center" noclick="true" shadow="true" color="white" font="dyn_14" watch="MicroStoreUpdatePackages" ontrigger="SetText(Translate('mstore_coinamount', 'coins', microStorePackageCoins2));" />
					</panel>
					<panel y="-3h" valign="bottom" color="0 0 0 0.75" height="2.25h" watch="MicroStoreUpdatePackages" visible="false" ontrigger="SetVisible(microStorePackageSpecial2);">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="true" />
						<label textalign="center" textvalign="center" noclick="true" shadow="true" color="0 1 0 1" font="dyn_10" content="mstore_specialoffer" />
					</panel>
					<panel y="3h" color="0 0 0 0.75" height="2.25h" visible="false" group="coinBundleBonusCoinsVisible2">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="true" />
						<label textalign="center" textvalign="center" noclick="true" shadow="true" color="0 1 0 1" font="dyn_10" content="mstore_bonuscoins" />
