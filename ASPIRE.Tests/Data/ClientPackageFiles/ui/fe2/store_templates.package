				<!-- Custom Icon -->
				<panel width="100%" height="59%" valign="bottom" noclick="true">
					<frame texture="/ui/frames/roundframe.tga" bordercolor="#9d5b1a" borderthickness="0.5h" noclick="true"/>

					<panel y="0.2h" grow="true" width="-1.6h" align="center">
						<image y="0.5h" width="6.0h" height="6.0h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/custom_icon.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
						<label width="-7.0h" align="right" font="dyn_16" color="#451607" shadow="true" shadowcolor="#d7b361" content="Upload a Custom Icon" />
						<label fity="true" y="2.6h" width="-7.0h" align="right" wrap="true" font="dyn_10" color="#2c0c02" content="Create your very own icon and beat an overused meme like a dead horse! You may purchase as many slots as you would like.*" />
					</panel>

					<panel y="-3.0h" height="3.2h" align="right" valign="bottom">
						<instance name="storeButton" tip_id="mstore_tip_purchase_item" x="-8.0h" align="right" width="16.4h" label="mstore_purchase_custom_btn"
							watch=""
							ontrigger=""
							onclick=""
							visible="true"
						/>
						<panel x="-0.5h" align="right" noclick="true">
							<label outline="true" width="-2.6h" textalign="right" textvalign="center" color="#ffcc00" font="dyn_12" shadow="true" content="3500" noclick="true"/>
							<image align="right" valign="center" width="70@" height="70%" x="-0.15h" y="0.1h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.9" />
							<image align="right" valign="center" width="70@" height="70%" x="-0.25h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
						</panel>
					</panel>

					<label y="-0.5h" textalign="center" textvalign="bottom" font="dyn_9" color="#2c0c02" content="*Once uploaded, you can not change a custom icon." noclick="true" />

					<!-- Empty Slot Indicator -->
					<panel x="0.8h" y="-3.0h" width="6.2h" height="7.0h" align="left" valign="bottom">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="0 0 0 .5" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" bordercolor="#9d5b1a" borderthickness="0.5h" noclick="true"/>
					</panel>

				</panel>

			</panel>

		</panel>
	</template>

	<template name="storeCategoryContainer">
		<panel height="8h" align="right" color="1 1 1 0.25" noclick="true" name="storeCategoryContainer" visible="false" x="5%"
			onevent0="
				SleepWidget(250, 'DoEvent(2);');
			"
			onevent1="
				DoEvent(3);
			"
			onevent2="
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent3="
				SlideX('5%', 250);
				FadeOut(200);
			"
		>
			<panel noclick="true" width="14h" y="7.8h" height="8h" x="15h" name="storeVanitySubCategoryHolder">
				<panel noclick="true" x="1.35h" grow="true" width="100%" visible="false"
					onload="
						SetY(GetHeight() * -1);
					"
					name="storeVanitySubCategory"
					onevent0="
						SetVisible(true);
						SlideY('0', 200);
					"
					onevent1="
						SlideY(GetHeight() * -1, 200);
						FadeOut(200);
