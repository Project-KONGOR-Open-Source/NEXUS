				</panel>
			</widgetstate>
		</button>
	</template>

	<template name="woodButtonImage">
		<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.5" borderthickness="0.3h" x="0.2h" y="0.2h" noclick="true"/>
		<panel color="white" align="center" width="-50@" utile="true" vtile="true" uscale="64p" vscale="64p" rendermode="{rendermode}" onload="SetUScale((GetHeight() * 2) # 'p'); SetVScale(GetHeight() # 'p');" texture="/ui/fe2/store/wood_button_center.tga" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/wood_button_center.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
		<image align="left" height="100%" width="50@" rendermode="{rendermode}" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/wood_button_left.tga', 'store', self)" texture="/ui/fe2/store/wood_button_left.tga" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
		<image align="right" height="100%" width="50@" rendermode="{rendermode}" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/wood_button_right.tga', 'store', self)" texture="/ui/fe2/store/wood_button_right.tga" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
	</template>

	<template name="storeButtonWidgetState">
		<panel noclick="true">
			<instance name="metalPlateImage" rendermode="{rendermode}"/>
			<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}" noclick="true"/>
			<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center" noclick="true">
				<instance name="woodButtonImage" rendermode="{rendermode=normal}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{highlight=false}" noclick="true"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="{darken=false}" noclick="true"/>
				<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.6" height="65%" width="-40@" align="center" valign="center" noclick="true"/>
				<label align="center" textvalign="center" textalign="{textalign=center}" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_9}" content="{label}" noclick="true"/>
			</panel>
		</panel>
	</template>

	<!-- Standard Store Button -->
	<template name="storeButton">
		<button
			name="{buttonName}"
			width="{width=100%}"
			height="{height=100%}"
			align="{align=left}"
			valign="{valign=top}"
			x="{x}"
			y="{y}"
			onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav'); {onclick}"
			onclicklua="{onclicklua}"
			color="invisible"
			visible="{visible=true}"
			enabled="{enabled=true}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			watch2="{watch2}"
			ontrigger2="{ontrigger2}"
			watch3="{watch3}"
			ontrigger3="{ontrigger3}"
			watch4="{watch4}"
			ontrigger4="{ontrigger4}"
			onevent="{onevent}"
			onevent0="{onevent0}"
			onevent1="{onevent1}"
			onevent2="{onevent2}"
			onevent3="{onevent3}"
			onevent4="{onevent4}"
			onevent5="{onevent5}"
			onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); {onmouseout}"
			onmouseoverlua="{onmouseoverlua}"
			onmouseoutlua="{onmouseoutlua}"
			onrightclick="{onrightclick}"
			mouseoverdisabled="{mouseoverdisabled=false}"
			mouseoutdisabled="{mouseoutdisabled=false}"
			onload="{onload}"
		>
			<widgetstate statename="up">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}"/>
			</widgetstate>
			<widgetstate statename="over">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}" highlight="true"/>
			</widgetstate>
			<widgetstate statename="down">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}" buttonwidth="-28@" buttonheight="-28%" darken="true"/>
			</widgetstate>
			<widgetstate statename="disabled" rendermode="grayscale">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=0.7 0.7 0.7 1}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" rendermode="grayscale" label="{label}"/>
			</widgetstate>
		</button>
	</template>

	<!-- ============================= MISC =============================  -->

	<template name="storeViewBookItemEntryLeft">
		<panel width="100%" height="3.2h"  name="{itemTemplateName=storeViewBookItem}{id}" group="{itemTemplateName=storeViewBookItem}s" visible="false"
			onevent0="
				If(
					microStoreID{id} ge 1,
					If(
						IsVisible('storeItemViewBook'),
						DoEvent(3),
						SleepWidget(450, 'DoEvent(3);')
					),
					DoEvent(1)
				);
			"
			onevent1="
				SleepWidget(({id=1} - 1) * 25, 'PlaySound(\'/ui/fe2/store/sounds/book_item_fadeout.wav\'); FadeOut(200);');
			"
			onevent2="
				If(
					microStoreID{id} ge 1,
					Split(
						##Call('{viewname=storeViewBook}Title{id}', 'SetText(Translate(\'mstore_product\' # microStoreID{id} # \'_name\'));'),##
						If(
							microStorePremium{id},
							ShowOnly('{viewname=storeViewBook}BackerPrem{id}'),
							ShowOnly('{viewname=storeViewBook}BackerReg{id}')
						),
						Call('{viewname=storeViewBook}Image{id}', 'DoEvent();'),
						CallEvent('{viewname=storeViewBook}BundlePrevButton{id}', 0),
						CallEvent('{viewname=storeViewBook}UnlockIconBtn{id}'),
						CallEvent('{viewname=storeViewBook}UnlockTauntBtn{id}'),
						DoEvent(9)
					)
				);
			"
			onevent2lua="
				if (GetCvarNumber('microStoreID{id}') > 0) then
					local nameWidget = GetWidget('{viewname=storeViewBook}Title{id}')
					local nameString = Translate('mstore_product' .. GetCvarNumber('microStoreID{id}') .. '_name')


					if GetCvarBool('microStoreAlreadyOwned{id}') then
						nameWidget:SetWidth('-635@')
					else
						nameWidget:SetWidth('-510@')
					end

					nameWidget:SetFont(GetFontSizeForWidth(nameString, nameWidget:GetWidth(), 11, 6))
					nameWidget:SetText(nameString)
				end
			"
			onevent3="
				SleepWidget(({id=1} - 1) * 25, 'DoEvent(5); FadeIn(200);');
			"
			onevent5="
				PlaySound('/ui/fe2/store/sounds/book_item_fadein.wav');
			"
			onevent9lua="
				Set('microStoreTempCDGold', '-1', 'int')
				Set('microStoreTempCDSilver', '-1', 'int')
				if (GetCvarBool('microStorePurchasable{id}')) then
					UIManager.GetInterface('main'):HoNStoreF('SetupBookPrice', '{id}', GetCvarString('microStoreID{id}'), GetCvarString('microStorePrice{id}'), GetCvarString('microStoreSilverPrice{id}'), '{viewname=storeViewBook}')
				end

				self:DoEventN(8)
			"
			onevent8="
				##
					{viewname=storeViewBook}BtnBuy{id}
					{viewname=storeViewBook}BtnNeedCoins{id}
					{viewname=storeViewBook}BtnOwned{id}

					CreateInt('microStoreGetCDPriceItem', -1);
					CreateInt('microStoreGetCDPriceView', -1);
				##
				
				Set('microStoreGetCDPriceView', 1);
				Set('microStoreGetCDPriceItem', {id=0});
				
				ExplodeTrigger('MicroStoreGetCDPrice', microStoreCharges{id}, ',', '~');
				ExplodeTrigger('MicroStoreGetCDPrice', microStoreDurations{id}, ',', '~');

				Call(
					'{viewname=storeViewBook}Cost{id}',
					'
						SetText(
							If(
								microStoreTempCDGold == 0 and microStoreTempCDSilver le 0 and microStorePurchasable{id},
								Translate(\'mstore_free\'),
								If(
									microStoreTempCDGold gt 0,
									FtoA(microStoreTempCDGold, 0, 0, \',\'),
									\'-\'
								)
							)
						);
					'
				);
				
				Call(
					'{viewname=storeViewBook}SilverCost{id}',
					'
						SetText(
							If(
								microStoreTempCDGold == 0 and microStoreTempCDSilver le 0 and microStorePurchasable{id},
								Translate(\'mstore_free\'),
								If(
									microStoreTempCDSilver gt 0,
									FtoA(microStoreTempCDSilver, 0, 0, \',\'),
									\'-\'
								)
							)
						);
					'
				);
				
				If(
					microStoreAlreadyOwned{id} and microStorePurchasable{id},
					ShowWidget('{viewname=storeViewBook}BtnOwned{id}'),
					HideWidget('{viewname=storeViewBook}BtnOwned{id}')
				);
				If(
					!microStoreAlreadyOwned{id} or (!microStorePurchasable{id} and (microStoreTempCDGold ge 1 or microStoreTempCDSilver ge 1)),
					If(
						_microStore_TotalCoins ge microStoreTempCDGold or (_microStore_TotalSilverCoins ge microStoreTempCDSilver and microStoreTempCDSilver ge 1),
						Split(
							ShowWidget('{viewname=storeViewBook}BtnBuy{id}'),
							HideWidget('{viewname=storeViewBook}BtnNeedCoins{id}')
						),
						Split(
							HideWidget('{viewname=storeViewBook}BtnBuy{id}'),
							ShowWidget('{viewname=storeViewBook}BtnNeedCoins{id}')
						)
					),
					Split(
						HideWidget('{viewname=storeViewBook}BtnBuy{id}'),
						HideWidget('{viewname=storeViewBook}BtnNeedCoins{id}')
					)
				);
			"
		>
			<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="0.5h" group="{viewname=storeViewBook}Backers{id}" name="{viewname=storeViewBook}BackerReg{id}" noclick="true"/>
			<image width="148%" height="19.5@" x="{premBG_x=-1.25h}" y="-0.25h" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/book_item_premium.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" group="{viewname=storeViewBook}Backers{id}" name="{viewname=storeViewBook}BackerPrem{id}"/><!-- Proportions be damned! -->
			<panel hmargin="0.25h" vmargin="0.25h">
				<instance name="storeItemImage" id="{id}" height="100%" width="100@" image_name="{viewname=storeViewBook}Image{id}" align="{imgalign=left}" hover_enlarge="true" noclick="false"/>
				<label x="{textx=110@}" style="microStorePaperText" font="dyn_10" textvalign="center" noclick="true" name="{viewname=storeViewBook}Title{id}" content="-" align="{textalign=left}" textalign="{textalign=left}" width="-510@" />

				<!-- Buy Button -->
				<panel align="{buttonalign=right}" width="10h" x="{buttonx=-4.8h}" noclick="true">
					<button color="invisible"
						onmouseover="
							If(
								!microStoreBundle{id},
								ShowWidget('mstore_tip_owned_item'),
								ShowWidget('mstore_tip_owned_bundle')
							);

						"
						onmouseout="
							HideWidget('mstore_tip_owned_item');
							HideWidget('mstore_tip_owned_bundle');
						"
						visible="false" name="{viewname=storeViewBook}BtnOwned{id}" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
						onrightclick="
							If(
								!microStoreBundle{id},
								Split(
									HideWidget('mstore_tip_owned_item'),
									HideWidget('mstore_tip_owned_bundle'),
									Trigger('ShopkeeperAction', 18),
									Set('_microStore_RequestCode', 2),
									##Set('_MicroStore_Category', 2),##
									CallEvent('MicroStoreAction', 0)
								)
							);

						">
						<label style="microStorePaperText" font="dyn_10" textalign="center" textvalign="center" content="mstore_purchased" noclick="true"/>
					</button>

					<panel name="{viewname=storeViewBook}BtnBuy{id}EligContainer" noclick="true">
						<instance name="storeButton" tip_id="mstore_tip_purchase_item" align="{buttonalign=right}" width="5h" label="mstore_buy" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
							onclick="
								Set('_microStore_SelectedID', microStoreID{id});
								Set('_microStore_SelectedItem', {id});
								Trigger('MicroStoreUpdateSelection');
								CallEvent('store_popup_confirm_purchase_choose', 0);
							"
							visible="false" buttonName="{viewname=storeViewBook}BtnBuy{id}"
						/>
					</panel>


					<panel name="{viewname=storeViewBook}BtnIneligible{id}" width="4h" visible="false" passivechildren="true"
						onmouseoverlua="UIManager.GetInterface('main'):HoNStoreF('HoverShelvedInelidgible', GetCvarString('microStoreID{id}'))"
						onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
						align="{buttonalign=right}"
					>
						<image width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/quests/textures/lock.tga"/>
					</panel>
					<!--
					<button color="invisible"
						name="{viewname=storeViewBook}BtnIneligible{id}"
						onmouseoverlua="UIManager.GetInterface('main'):HoNStoreF('HoverShelvedInelidgible', GetCvarString('microStoreID{id}'))"
						onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
						visible="false" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
						align="{buttonalign=right}"
					>
						<widgetstate statename="up">
							<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
						</widgetstate>
						<widgetstate statename="over">
							<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
						</widgetstate>
						<widgetstate statename="down">
							<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
						</widgetstate>
						<widgetstate statename="disabled">
							<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
						</widgetstate>
					</button>
					-->
					<instance name="storeButton" tip_id="mstore_tip_unlock_icons" label="mstore_needunlockicons" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false" buttonName="{viewname=storeViewBook}UnlockIconBtn{id}"
						onclick="
							Set('microStoreID999', 228);
							Set('_microStore_SelectedID', microStoreID999);
							Set('_microStore_SelectedItem', 999);
							Set('microStoreLocalContent999', 'ui/fe2/store/icons/unlock.tga');
							Set('microStorePrice999', _microStore_accIconUnlockCost);
							Set('microStoreSilverPrice999', _microStore_accIconUnlockSilverCost);
							Set('microStorePremium999', false);
							Trigger('MicroStoreUpdateSelection');
							CallEvent('store_popup_confirm_purchase_choose', 0);
						"
						onevent="SetVisible(StringEquals(SubString(microStoreCode{id}, 0, 2), 'ai') and !_microStore_iconsUnlocked and microStoreID{id} != 228);"
					/>
					<instance name="storeButton" tip_id="mstore_tip_unlock_taunt" label="mstore_needunlocktaunt" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false" buttonName="{viewname=storeViewBook}UnlockTauntBtn{id}"
						onclick="
							Set('microStoreID999', 91);
							Set('_microStore_SelectedID', microStoreID999);
							Set('_microStore_SelectedItem', 999);
							Set('microStoreLocalContent999', '/ui/legion/icons/taunt.tga');
							Set('microStorePrice999', _microStore_tauntUnlockCost);
							Set('microStoreSilverPrice999', _microStore_tauntUnlockSilverCost);
							Set('microStorePremium999', false);
							Trigger('MicroStoreUpdateSelection');
							CallEvent('store_popup_confirm_purchase_choose', 0);
						"
						onevent="SetVisible(StringEquals(SubString(microStoreCode{id}, 0, 2), 't.') and !_microStore_tauntUnlocked and microStoreID{id} != 91);"
					/>
					<instance name="storeButton" tip_id="mstore_tip_need_coins" label="mstore_needcoins" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false" buttonName="{viewname=storeViewBook}BtnNeedCoins{id}" onclick="Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"/>
				</panel>

				<!-- Mag Glass -->
				<instance name="magnifierButton" align="{buttonalign=right}" x="{magX=-14.65h}" width="100@" height="100%" visible="false" button_name="{viewname=storeViewBook}BundlePrevButton{id}" onevent0="If(microStoreBundle{id}, SetVisible(true), SetVisible(false));" onclick="Set('_microStore_SelectedID', microStoreID{id}); Set('_microStore_SelectedItem', {id}); Set('_microStore_RequestCode', 6); CallEvent('MicroStoreAction', 0);" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"/>
				
				<!-- Costs -->
				<panel width="4.6h" align="{costalign=right}" >
					<!-- Cost 1 -->
					<panel valign="top" height="50%" noclick="true">
						<image width="80@" height="80%" valign="center" align="right" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" />
						<label font="dyn_9" width="-86@" textalign="right" textvalign="center" name="{viewname=storeViewBook}Cost{id}" content="-" color="#FFCC00" outline="true" outlinecolor="#774515" outlinesize="0.1h"/>
					</panel>
					<!-- Cost 2 -->
					<panel valign="bottom" height="50%" noclick="true">
						<image width="80@" height="80%" valign="center" align="right" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" />
						<label font="dyn_9" width="-86@" textalign="right" textvalign="center" name="{viewname=storeViewBook}SilverCost{id}" content="-" color="#c0d5ed" outline="true" outlinecolor="#774515" outlinesize="0.1h"/>
					</panel>
				</panel>
				<frame name="{viewname=storeViewBook}PurchaseGlow{id}" color="invisible" visible="0" noclick="1" >
					<modelpanel
						noclick="1" align="center" valign="center"
						model=""
						anim="idle"
						camerapos="0 -1000 3"
						cameraangles="0 0 0"
						camerafov="4.42"
						carmerafar="5000"
						depthclear="false"
						depthcompress="true"
						sunazimuth="140"
						sunaltitude="10"
						suncolor="1 1 1 1"
						resourcecontext="store"
						onshow="SetModel('/ui/common/models/main/tut_highlight.mdf'); SetEffect('/ui/common/models/main/tut_highlight.effect');"
						onhide="SetModel(''); SetEffect('');"
					/>													
				</frame>
			</panel>
		
		</panel>

	
	</template>

	<template name="storeViewBookItemEntryRight">
		<instance name="storeViewBookItemEntryLeft" imgalign="right" textalign="right" textx="-110@" buttonalign="left" buttonx="4.8h" costalign="left" id="{id}" premBG_x="-1h" magX="10.4h" />
	</template>

	<template name="storeViewBookAccIconsItemEntryRight">
		<instance name="storeViewBookItemEntryLeft" imgalign="right" textalign="right" textx="-110@" buttonalign="left" buttonx="4.8h" costalign="left" id="{id}" premBG_x="-1h" magX="10.4h"  itemTemplateName="storeViewBookAccIconsItem" viewname="storeViewBookAccIcons" viewnamefull="storeItemViewBookAccIcons"/>
	</template>

	<template name="storeViewShelfItem">
		<panel width="28.5h" height="15.5h" x="{x=2h}" y="{y=1h}" align="{align=left}" valign="{valign=top}" name="storeViewShelfItem{id}" group="storeViewShelfItems" visible="false"
			onevent0="
				If(
					microStoreID{id} ge 1,
					If(
						IsVisible('storeItemViewShelves'),
						DoEvent(3),
						SleepWidget(450, 'DoEvent(3);')
					),
					DoEvent(1)
				);
			"
			onevent1="
				SleepWidget(
					({id=1} - 1) * 35,
					'
						FadeOut(200);
					'
				);
			"
			onevent2="
				If(
					microStoreID{id} ge 1,
					DoEvent(9)
				);
			
				If(
					microStoreID{id} ge 1,
					Split(
						Call(
							'storeViewShelfTitle{id}',
							'
								if(
									microStorePremium{id},
									Split(
										SetX(\'-1.4h\'),
										SetY(\'1.5h\')
									),
									Split(
										SetX(\'-1.9h\'),
										SetY(\'1.9h\')
									)
								);
							'
						),
						Call(
							'storeViewShelfDescBox{id}',
							'
								if(
									microStorePremium{id},
									Split(
										SetX(\'-0.25h\'),
										SetY(\'4.25h\')
									),
									Split(
										SetX(\'-1.25h\'),
										SetY(\'4.75h\')
									)
								);
							'
						),
						Call(
							'storeViewShelfGCostBox{id}',
							'
								if(
									microStorePremium{id},
									If(
										microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
										SetX(\'9.8h\'),
										SetX(\'11.65h\')
									),
									If(
										microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
										SetX(\'9h\'),
										SetX(\'10.5h\')
									)
								);
							'
						),
						Call(
							'storeViewShelfSCostBox{id}',
							'
								if(
									microStorePremium{id},
									SetX(\'-4.7h\'),
									SetX(\'-5.4h\')
								);
							'
						),
						Call(
							'storeShelfBuyBtnBox{id}',
							'
								if(
									microStorePremium{id},
									If(
										microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
										SetX(\'-8.5h\'),
										SetX(\'-6.1h\')
									),
									If(
										microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
										SetX(\'-8.7h\'),
										SetX(\'-7h\')
									)
								);
							'
						),
						If(
							microStorePremium{id},
							If(
								microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
								ShowOnly('storeViewShelfBackerPremGO{id}'),
								ShowOnly('storeViewShelfBackerPrem{id}')
							),
							If(
								microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
								ShowOnly('storeViewShelfBackerRegGO{id}'),
								ShowOnly('storeViewShelfBackerReg{id}')
							)
						),
						If(
							microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
							HideWidget('storeViewShelfSCostBox{id}'),
							ShowWidget('storeViewShelfSCostBox{id}')
						),
						Call(
							'storeViweShelfMagBtns{id}',
							'
								If(
									microStorePremium{id},
									Split(
										SetX(\'5.0h\'),
										SetWidth(\'3.4h\'),
										SetHeight(\'3.4h\')
									),
									Split(
										SetX(\'5.0h\'),
										SetWidth(\'3.4h\'),
										SetHeight(\'3.4h\')
									)
								);
							'
						),
						If(
							microStoreQuantity{id} ge 1,
							Call('storeViewShelfQuantity{id}', 'SetText(microStoreQuantity{id} # \' Left!\');'),
							Call('storeViewShelfQuantity{id}', '')
						),
						Call('storeViewShelfImage{id}', 'DoEvent();'),
						CallEvent('storeAvPreviewButton{id}', 0),
						CallEvent('storeBundlePreviewButton{id}', 0),
						CallEvent('storeVoicePreviewButton{id}', 0),
						CallEvent('storeViewShelfBtnRedeem{id}'),
						CallEvent('storeViewShelfUnlockIconBtn{id}'),
						CallEvent('storeViewShelfUnlockTauntBtn{id}')
					)
				);
			"
			onevent2lua="
				if (GetCvarNumber('microStoreID{id}') >= 1) then
					local labelWidget = GetWidget('storeViewShelfDescription{id}')
					local string = Translate('mstore_product'..GetCvarNumber('microStoreID{id}')..'_desc')
					labelWidget:SetFont(GetFontSizeForWidthHeight(string, labelWidget:GetWidth(), labelWidget:GetHeight(), 11, 6))
					labelWidget:SetText(string)

					local nameWidget = GetWidget('storeViewShelfTitle{id}')
					local nameString = Translate('mstore_product'..GetCvarNumber('microStoreID{id}')..'_name')
					nameWidget:SetFont(GetFontSizeForWidth(nameString, nameWidget:GetWidth(), 11, 6))
					nameWidget:SetText(nameString)
				end
			"
			onevent3="
				SleepWidget(
					({id=1} - 1) * 35,
					'FadeIn(200); DoEvent(5);'
				);
			"
			onevent5="
				PlaySound('/ui/fe2/store/sounds/shelf_item_fadein.wav');
			"
			onevent9lua="
				Set('microStoreTempCDGold', '-1', 'int')
				Set('microStoreTempCDSilver', '-1', 'int')
				if (GetCvarBool('microStorePurchasable{id}')) then
					UIManager.GetInterface('main'):HoNStoreF('SetupShelvedPrice', '{id}', GetCvarString('microStoreID{id}'), GetCvarString('microStorePrice{id}'), GetCvarString('microStoreSilverPrice{id}'))
				end

				self:DoEventN(8)
			"
			onevent8="
				##
					storeViewShelfBtnBuy{id}
					storeViewShelfBtnNeedCoins{id}
					storeViewShelfBtnOwned{id}

					CreateInt('microStoreCDPriceGold', -1);
					CreateInt('microStoreCDPriceSilver', -1);
					CreateInt('microStoreGetCDPriceItem', -1);
					CreateInt('microStoreGetCDPriceView', -1);
				##
				
				Set('microStoreGetCDPriceView', 1);
				Set('microStoreGetCDPriceItem', {id=0});
				
				ExplodeTrigger('MicroStoreGetCDPrice', microStoreCharges{id}, ',', '~');
				ExplodeTrigger('MicroStoreGetCDPrice', microStoreDurations{id}, ',', '~');
				
				Call(
					'storeViewShelfCost{id}',
					'
						SetText(
							If(
								microStoreTempCDGold == 0 and microStoreTempCDSilver le 0 and microStorePurchasable{id},
								Translate(\'mstore_free\'),
								If(
									microStoreTempCDGold gt 0,
									FtoA(microStoreTempCDGold, 0, 0, \',\'),
									\'-\'
								)
							)
						);
					'
				);
				
				Call(
					'storeViewShelfSilverCost{id}',
					'
						SetText(
							If(
								microStoreTempCDGold == 0 and microStoreTempCDSilver le 0 and microStorePurchasable{id},
								Translate(\'mstore_free\'),
								If(
									microStoreTempCDSilver gt 0,
									FtoA(microStoreTempCDSilver, 0, 0, \',\'),
									\'-\'
								)
							)
						);
					'
				);
				
				If(
					microStoreAlreadyOwned{id} and microStorePurchasable{id},
					ShowWidget('storeViewShelfBtnOwned{id}'),
					HideWidget('storeViewShelfBtnOwned{id}')
				);
				If(
					!microStoreAlreadyOwned{id} or (!microStorePurchasable{id} and (microStoreTempCDGold ge 1 or microStoreTempCDSilver ge 1)),
					If(
						_microStore_TotalCoins ge microStoreTempCDGold or (_microStore_TotalSilverCoins ge microStoreTempCDSilver and microStoreTempCDSilver ge 1),
						Split(
							ShowWidget('storeViewShelfBtnBuy{id}'),
							If(
								microStoreTargetPurchaseID == microStoreID{id},
								Split(
									Set('_microStore_SelectedID', microStoreID{id}),
									Set('_microStore_SelectedItem', {id}),
									Trigger('MicroStoreUpdateSelection'),
									CallEvent('store_popup_confirm_purchase_choose', 0),
									Set('microStoreTargetPurchaseID', -1)
								)
							),
							HideWidget('storeViewShelfBtnNeedCoins{id}')
						),
						Split(
							HideWidget('storeViewShelfBtnBuy{id}'),
							ShowWidget('storeViewShelfBtnNeedCoins{id}')
						)
					),
					Split(
						HideWidget('storeViewShelfBtnBuy{id}'),
						HideWidget('storeViewShelfBtnNeedCoins{id}')
					)
				);
			"
		>
			<panel x="0.75h" y="1.15h" width="7.5h" height="7.5h" align="{imgalign=left}" noclick="true" color="invisible">
				<instance name="storeItemImage" id="{id}" image_name="storeViewShelfImage{id}" width="100%" height="100%"/>
				<button color="invisible"

					onclick="
						If(
							StringEquals(SubString(microStoreCode{id}, 0, 3), 'aa.') and WidgetExists('altAvatarPreviewPanel' # microStoreID{id}),
							Split(
								Set('_microStore_SelectedID', microStoreID{id}),
								Set('_microStore_SelectedItem', {id}),
								CallEvent('altAvatarPreviewPanel' # microStoreID{id}, 2),
								CallEvent('altAvatarPreviewPanel' # microStoreID{id}, 0)
							)
						);
						If(
							StringEquals(SubString(microStoreCode{id}, 0, 3), 'av.'),
							Split(
								Set('_microStore_SelectedID', microStoreID{id}),
								Set('_microStore_SelectedItem', {id}),
								Trigger('MicroStoreVoicePreview'),
								CallEvent('store_popup_voice_preview', 0)
							)
						);

						If(
							microStoreBundle{id},
							Split(
								Set('_microStore_SelectedID', microStoreID{id}),
								Set('_microStore_SelectedItem', {id}),
								Set('_microStore_RequestCode', 6),
								CallEvent('MicroStoreAction', 0)
							)
						);
					"

					watch="MicroStoreProcessing"
					ontrigger="SetEnabled(!param0);"
				/>
			</panel>

			<image width="100%" height="100@" x="-0.5h" y="-0.75h" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/shelf_item.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" group="storeViewShelfBacker{id}" name="storeViewShelfBackerReg{id}"/>
			<image width="100%" height="100@" x="-0.5h" y="-0.75h" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/shelf_item_go.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" group="storeViewShelfBacker{id}" name="storeViewShelfBackerRegGO{id}"/>
			<image width="102%" height="102@" x="0.1h" y="-1.1h" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/premium_shelf_item.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" visible="false" group="storeViewShelfBacker{id}" name="storeViewShelfBackerPrem{id}"/>
			<image width="102%" height="102@" x="0.1h" y="-1.1h" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/premium_shelf_item_go.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" visible="false" group="storeViewShelfBacker{id}" name="storeViewShelfBackerPremGO{id}"/>
			<label align="right" x="-1.9h" y="1.9h" width="16.4h" height="2.5h" wrap="false" textvalign="center" textalign="center" font="dyn_11" color="0.8 0.9 0.8 1" outlinecolor="0 0 0 0.6" shadow="true" shadowoffset="2" outline="true" noclick="true" name="storeViewShelfTitle{id}" />
			
			<!-- Cost 1 -->
			<panel valign="bottom" align="center" height="2.95h" width="5.8h" x="-5h" y="-0.25h" noclick="true" name="storeViewShelfSCostBox{id}">
				<image width="60@" height="60%" valign="center" align="right" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" />
				<label width="-62@" height="100%" align="left" wrap="false" textalign="center" textvalign="center" color="#c0d5ed" outline="true" font="dyn_10" outlinecolor="0 0 0 0.5" content="-" name="storeViewShelfSilverCost{id}"/>
			</panel>
			
			<!-- Cost 2 -->
			<panel valign="bottom" align="center" height="2.95h" width="5.8h" x="11.65h" y="-0.25h" noclick="true" name="storeViewShelfGCostBox{id}">
				<image width="60@" height="60%" valign="center" align="right" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" />
				<label width="-62@" height="100%" align="left" wrap="false" textalign="center" textvalign="center" color="#FFCC00" outline="true" font="dyn_10" outlinecolor="0 0 0 0.5" content="-" name="storeViewShelfCost{id}"/>
			</panel>
			
			<panel align="right" x="-1.25h" y="4.75h" width="18h" height="6.25h" name="storeViewShelfDescBox{id}">
				<label wrap="true" font="dyn_10" color="1 0.95 0.7 1" shadow="true" outline="true" outlinecolor="0 0 0 0.75" noclick="true" name="storeViewShelfDescription{id}"/>
				<panel valign="bottom" height="1.5h" noclick="true">
					<label wrap="true" font="dyn_9" color="0 1 0 1" shadow="true" textalign="center" textvalign="center" noclick="true" name="storeViewShelfQuantity{id}"/>
				</panel>
			</panel>
			<panel align="right" valign="bottom" width="9.25h" height="3.25h" y="-0.1h" x="-6.1h" noclick="true" color="invisible" name="storeShelfBuyBtnBox{id}">
				<!-- This needs to be faked so the tooltip still works -->
				<button color="invisible"
					onmouseover="
						If(
							!microStoreBundle{id},
							ShowWidget('mstore_tip_owned_item'),
							ShowWidget('mstore_tip_owned_bundle')
						);
					"
					onmouseout="
						HideWidget('mstore_tip_owned_item');
						HideWidget('mstore_tip_owned_bundle');
					"
					visible="false" name="storeViewShelfBtnOwned{id}" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
					onrightclick="
						If(
							!microStoreBundle{id},
							Split(
								HideWidget('mstore_tip_owned_item'),
								HideWidget('mstore_tip_owned_bundle'),
								Trigger('ShopkeeperAction', 18),
								Set('_microStore_RequestCode', 2),
								##Set('_MicroStore_Category', 2),##
								CallEvent('MicroStoreAction', 0)

							)
						);
					">
					<widgetstate statename="up">
						<instance name="storeButtonWidgetState" label="mstore_purchased" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
					<widgetstate statename="over">
						<instance name="storeButtonWidgetState" label="mstore_purchased" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
					<widgetstate statename="down">
						<instance name="storeButtonWidgetState" label="mstore_purchased" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
					<widgetstate statename="disabled">
						<instance name="storeButtonWidgetState" label="mstore_purchased" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
				</button>


				<instance name="storeButton" label="mstore_redeem" visible="false"
					onevent="
						SetVisible(
							WidgetExists('vaultRedeemHelper' # *('microStoreID' # {id=0}) ) and
							microStoreAlreadyOwned{id} and
							(
								microStoreID{id} == 161 or
								microStoreID{id} == 162 or
								microStoreID{id} == 163 or
								microStoreID{id} == 492
							)
						);
					"
					buttonName="storeViewShelfBtnRedeem{id}"
					onclick="
						If(microStoreID{id} == 161, HideWidget('mstore_tip_redeem_nickchange'));
						If(microStoreID{id} == 162, HideWidget('mstore_tip_redeem_subaccount'));
						If(microStoreID{id} == 163, HideWidget('mstore_tip_redeem_statreset'));
						If(microStoreID{id} == 492, HideWidget('mstore_tip_redeem_mulligan'));
						Trigger('vaultConfigureProduct', microStoreID{id}, {id=0}, name);
					" watch="vaultRefreshConfigButtons" ontrigger="DoEvent();"
					onmouseover="
						If(microStoreID{id} == 161, ShowWidget('mstore_tip_redeem_nickchange'));
						If(microStoreID{id} == 162, ShowWidget('mstore_tip_redeem_subaccount'));
						If(microStoreID{id} == 163, ShowWidget('mstore_tip_redeem_statreset'));
						If(microStoreID{id} == 492, ShowWidget('mstore_tip_redeem_mulligan'));
					"
					onmouseout="
						If(microStoreID{id} == 161, HideWidget('mstore_tip_redeem_nickchange'));
						If(microStoreID{id} == 162, HideWidget('mstore_tip_redeem_subaccount'));
						If(microStoreID{id} == 163, HideWidget('mstore_tip_redeem_statreset'));
						If(microStoreID{id} == 492, HideWidget('mstore_tip_redeem_mulligan'));
					"
				/>
				<instance name="storeButton" tip_id="mstore_tip_purchase_item" align="center" valign="center" font="dyn_12" label="mstore_buy" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false"
					onclick="
						Set('_microStore_SelectedID', microStoreID{id});
						Set('_microStore_SelectedItem', {id});
						Trigger('MicroStoreUpdateSelection');
						CallEvent('store_popup_confirm_purchase_choose', 0);
					"
					buttonName="storeViewShelfBtnBuy{id}"/>
				<button color="invisible"
					name="storeViewShelfBtnIneligible{id}"
					onmouseoverlua="UIManager.GetInterface('main'):HoNStoreF('HoverShelvedInelidgible', GetCvarString('microStoreID{id}'))"
					onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
					visible="false" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
				>
					<widgetstate statename="up">
						<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
					<widgetstate statename="over">
						<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
					<widgetstate statename="down">
						<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
					<widgetstate statename="disabled">
						<instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
					</widgetstate>
				</button>
				<instance name="storeButton" tip_id="mstore_tip_unlock_icons" align="center" valign="center" font="dyn_12" label="mstore_needunlockicons" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false" 
					onclick="
						Set('microStoreID999', 228);
						Set('_microStore_SelectedID', microStoreID999);
						Set('_microStore_SelectedItem', 999);
						Set('microStoreLocalContent999', 'ui/fe2/store/icons/unlock.tga');
						Set('microStorePrice999', _microStore_accIconUnlockCost);
						Set('microStoreSilverPrice999', _microStore_accIconUnlockSilverCost);
						Set('microStorePremium999', false);
						Trigger('MicroStoreUpdateSelection');
						CallEvent('store_popup_confirm_purchase_choose', 0);
					" 
					buttonName="storeViewShelfUnlockIconBtn{id}"
					onevent="SetVisible(StringEquals(SubString(microStoreCode{id}, 0, 2), 'ai') and !_microStore_iconsUnlocked and microStoreID{id} != 228);"
				/>
				<instance name="storeButton" tip_id="mstore_tip_unlock_taunt" label="mstore_needunlocktaunt" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false" buttonName="storeViewShelfUnlockTauntBtn{id}"
					onclick="
						Set('microStoreID999', 91);
						Set('_microStore_SelectedID', microStoreID999);
						Set('_microStore_SelectedItem', 999);
						Set('microStoreLocalContent999', '/ui/legion/icons/taunt.tga');
						Set('microStorePrice999', _microStore_tauntUnlockCost);
						Set('microStoreSilverPrice999', _microStore_tauntUnlockSilverCost);
						Set('microStorePremium999', false);
						Trigger('MicroStoreUpdateSelection');
						CallEvent('store_popup_confirm_purchase_choose', 0);
					"
					onevent="SetVisible(StringEquals(SubString(microStoreCode{id}, 0, 2), 't.') and !_microStore_tauntUnlocked and microStoreID{id} != 91);"
				/>
				<instance name="storeButton" tip_id="mstore_tip_need_coins" align="center" valign="center" font="dyn_10" label="mstore_needcoins" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false" buttonName="storeViewShelfBtnNeedCoins{id}" onclick="Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"/>
			</panel>
			
			<!-- Mag Glass -->
			<panel name="storeViweShelfMagBtns{id}" align="left" valign="top" y="7.9h" x="7.0h" width="3.4h" height="3.4h">
				<instance name="magnifierButton" visible="false"
					width="100%"
					height="100%"
					button_name="storeVoicePreviewButton{id}"
					onevent0="If(StringEquals(SubString(microStoreCode{id}, 0, 2), 'av'), SetVisible(true), SetVisible(false));"
					onclick="
						Set('_microStore_SelectedID', microStoreID{id});
						Set('_microStore_SelectedItem', {id});
						Trigger('MicroStoreVoicePreview'); CallEvent('store_popup_voice_preview', 0);
					"
					watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
				/>
				<instance name="magnifierButton" visible="false"
					width="100%"
					height="100%"
					button_name="storeBundlePreviewButton{id}"
					onevent0="If(microStoreBundle{id}, SetVisible(true), SetVisible(false));"
					onclick="Set('_microStore_SelectedID', microStoreID{id}); Set('_microStore_SelectedItem', {id}); Set('_microStore_RequestCode', 6); CallEvent('MicroStoreAction', 0);"
					watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
				/>
				<instance name="magnifierButton" visible="false"
					width="100%"
					height="100%"
					button_name="storeAvPreviewButton{id}"
					onevent0="If(WidgetExists('altAvatarPreviewPanel' # microStoreID{id}), SetVisible(true), SetVisible(false));"
					onclick="Set('_microStore_SelectedID', microStoreID{id}); Set('_microStore_SelectedItem', {id}); CallEvent('altAvatarPreviewPanel' # microStoreID{id}, 2); CallEvent('altAvatarPreviewPanel' # microStoreID{id}, 0);"
					watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"
				/>
			</panel>
		</panel>
	</template>

	<template name="vaultViewShelfItem">
		<panel width="28.5h" height="15.5h" x="{x=0h}" y="{y=0h}" align="{align=left}" valign="{valign=top}" name="vaultViewShelfItem{id}" visible="true" group="vaultViewShelfItems"
			onevent0="
				If(
					IsVisible('vaultItemViewShelves'),
					If(
						microStoreID{id} ge 1,
						DoEvent(5),
						DoEvent(4)
					),
					If(
						microStoreID{id} ge 1,
						SleepWidget(600, 'DoEvent(5);'),
						DoEvent(4)
					)
				);
			"
			onevent1="
				SleepWidget(({id=1} - 1) * 90, 'DoEvent(4);');
			"
			
			onevent2="
				If(
					microStoreID{id} ge 1,
					If(
						StringEquals(microStoreID{id}, '999999005'),	## Blah at fail interger comparisons, have to do it this way! ##
						CallEvent('vaultViewShelfTokensPasses'),
						Split(
							If(
								{id} == 1,
								HideWidget('vaultViewShelfTokensPasses')
							),
							HideWidget('vaultViewShelfBtnSelected{id}'),
							HideWidget('vaultViewShelfBtnOwned{id}'),
							
							Call('vaultViewShelfImage{id}', 'DoEvent();'),
							ShowWidget('vaultViewShelfBtnConfig{id}'),
							If(
								StringEquals(microStoreCode{id}, 'ai') or
								StringEquals(microStoreCode{id}, 'cs') or
								StringEquals(microStoreCode{id}, 'av') or
								StringEquals(microStoreCode{id}, 'cc') or
								StringEquals(microStoreCode{id}, 'w') or
								StringEquals(microStoreCode{id}, 'c') or
								StringEquals(microStoreCode{id}, 'cr'),
								Split(
									HideWidget('vaultViewShelfBtnConfig{id}'),
									ShowWidget('vaultViewShelfBtnSelected{id}')
								),
								If(
									_microStore_Category == 75,
									Split(
										HideWidget('vaultViewShelfBtnConfig{id}'),
										ShowWidget('vaultViewShelfBtnOwned{id}')
									)
								)
	
							),
							Trigger('vaultRefreshConfigButtons')
						)
					)
				);
			"
			onevent2lua="
				if (GetCvarNumber('microStoreID{id}') >= 1) then
					local labelWidget = GetWidget('vaultViewShelfDescription{id}')
					local string = GetCvarString('microStoreDescription{id}')
					labelWidget:SetFont(GetFontSizeForWidthHeight(string, labelWidget:GetWidth(), labelWidget:GetHeight(), 11, 6))
					labelWidget:SetText(string)

					local nameWidget = GetWidget('vaultViewShelfTitle{id}')
					local nameString = GetCvarString('microStoreName{id}')
					nameWidget:SetFont(GetFontSizeForWidth(nameString, nameWidget:GetWidth(), 11, 6))
					nameWidget:SetText(nameString)

					local gcaWidget = GetWidget('vaultViewShelfGCA{id}')
					local codeString = GetCvarString('microStoreCode{id}')
					gcaWidget:SetVisible(IsGCABenifitUpgrades(codeString))
				end
			"
			onevent3="
				If(
					microStoreID{id} ge 1,
					Split(
						CallEvent('vaultViewShelfItem{id}_wheel', 0),
						CallEvent('vaultViewShelfItem{id}_door', 0),
						CallEvent('vaultViewShelfItem{id}_open', 0)
					)
				);
			"
			onevent4="
				CallEvent('vaultViewShelfItem{id}_wheel', 1);
				CallEvent('vaultViewShelfItem{id}_door', 1);
				CallEvent('vaultViewShelfItem{id}_open', 1);
			"
			onevent5="
				If(
					microStoreID{id} ge 1,
					SleepWidget(({id=1} - 1) * 90, 'DoEvent(3);')
				);
			"

			watch="refreshVaultViewShelfCfg"
			ontrigger="
				If(
					StringEquals(microStoreCode{id}, 'ai') or
					StringEquals(microStoreCode{id}, 'cs') or
					StringEquals(microStoreCode{id}, 'av') or
					StringEquals(microStoreCode{id}, 'cc') or
					StringEquals(microStoreCode{id}, 'w') or
					StringEquals(microStoreCode{id}, 'c') or
					StringEquals(microStoreCode{id}, 'cr'),
					Split(
						HideWidget('vaultViewShelfBtnConfig{id}'),
						If(
							microStoreID{id} != 228,
							ShowWidget('vaultViewShelfBtnSelected{id}')
						)
					),
					Split(
						If(
							microStoreID{id} != 228,
							ShowWidget('vaultViewShelfBtnConfig{id}')
						),
						HideWidget('vaultViewShelfBtnSelected{id}')
					)
				);
			"
		>
			<panel name="vaultViewShelfItem{id}_contents" x="0.5h" noclick="true">
				<image color="white" width="90%" height="90@" x="2h" y="" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_shelf_item.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
				<instance name="storeItemImage" id="{id}" x="2.4h" y="0.5h" width="4.7h" height="4.7h" image_name="vaultViewShelfImage{id}" align="{imgalign=left}"/>
				<label align="right" x="-2.1h" y="1h" width="18.25h" height="2.5h" wrap="false" textvalign="center" textalign="center" font="dyn_11" style="microStorePaperTitle" noclick="true" name="vaultViewShelfTitle{id}" />
				<panel align="right" x="-2.1h" y="3.25h" width="18.25h" height="6.75h" noclick="true">
					<label wrap="true" font="dyn_10" style="microStorePaperText" noclick="true" name="vaultViewShelfDescription{id}"/>
				</panel>
				<panel name="vaultViewShelfGCA{id}" x="2.5h" y="-0.5h" width="5h" height="5h" align="left" valign="bottom">
					<image texture="/ui/fe2/elements/gca/icon_3.tga" />
				</panel>
				<panel align="right" valign="bottom" width="18.25h" height="3.5h" y="-0.35h" x="-2.1h" noclick="true">
					<panel width="-4h" align="center">
						<instance name="storeButton" label="mstore_choose" visible="true" buttonName="vaultViewShelfBtnConfig{id}"
							onclick="
								HideWidget('mstore_tip_vault_choose' # _microStore_Category);
								Trigger('MicroStoreSetProcTrig', 'SelectUpgradesStatus');
								If(
									StringEquals(microStoreCode{id}, 'ai') or
									StringEquals(microStoreCode{id}, 'cs') or
									StringEquals(microStoreCode{id}, 'av') or
									StringEquals(microStoreCode{id}, 'cc') or
									StringEquals(microStoreCode{id}, 'w') or
									StringEquals(microStoreCode{id}, 'c') or
									StringEquals(microStoreCode{id}, 'cr'),
									ClearUpgrade(microStoreCode{id}),
									SelectUpgrade(microStoreCode{id})
								);
							"
							onmouseover="ShowWidget('mstore_tip_vault_choose' # _microStore_Category);"
							onmouseout="HideWidget('mstore_tip_vault_choose' # _microStore_Category);"
							watch="MicroStoreProcessing"
							ontrigger="SetEnabled(!param0);"
							watch1="MicroStoreSelectedUpgradeListed"
							ontrigger1="
								If(
									param0 == microStoreID{id},
									SetVisible(false)
								);

								If(
									StringEquals(microStoreCode{id}, 'ai') or
									StringEquals(microStoreCode{id}, 'cs') or
									StringEquals(microStoreCode{id}, 'av') or
									StringEquals(microStoreCode{id}, 'cc') or
									StringEquals(microStoreCode{id}, 'w') or
									StringEquals(microStoreCode{id}, 'c') or
									StringEquals(microStoreCode{id}, 'cr'),
									Split(
										HideWidget('vaultViewShelfBtnSelected{id}'),
										SetVisible(true)
									)

								);

							"
						/>


						<panel visible="false"
							watch="MicroStoreSelectedUpgradeListed"
							ontrigger="
								If(
									param0 == microStoreID{id},
									SetVisible(true)
								);
							"
							name="vaultViewShelfBtnSelected{id}"
							onevent="If(microStoreID{id} == 1792, SetVisible(true));"
							watch1="vaultRefreshConfigButtons" ontrigger1="DoEvent();"
						>
							<instance name="storeButtonWidgetState" label="mstore_item_selected" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/>
						</panel>


						<instance name="storeButton" label="mstore_redeem" visible="false" onevent="SetVisible(WidgetExists('vaultRedeemHelper' # *('microStoreID' # {id=0}) ));" buttonName="vaultViewShelfBtnRedeem{id}"
							onclick="
								If(microStoreID{id} == 161, HideWidget('mstore_tip_redeem_nickchange'));
								If(microStoreID{id} == 162, HideWidget('mstore_tip_redeem_subaccount'));
								If(microStoreID{id} == 163, HideWidget('mstore_tip_redeem_statreset'));
								If(microStoreID{id} == 492, HideWidget('mstore_tip_redeem_mulligan'));
								Trigger('vaultConfigureProduct', microStoreID{id}, {id=0}, name);
							" watch="vaultRefreshConfigButtons" ontrigger="DoEvent();"
							onmouseover="
								If(microStoreID{id} == 161, ShowWidget('mstore_tip_redeem_nickchange'));
								If(microStoreID{id} == 162, ShowWidget('mstore_tip_redeem_subaccount'));
								If(microStoreID{id} == 163, ShowWidget('mstore_tip_redeem_statreset'));
								If(microStoreID{id} == 492, ShowWidget('mstore_tip_redeem_mulligan'));
							"
							onmouseout="
								If(microStoreID{id} == 161, HideWidget('mstore_tip_redeem_nickchange'));
								If(microStoreID{id} == 162, HideWidget('mstore_tip_redeem_subaccount'));
								If(microStoreID{id} == 163, HideWidget('mstore_tip_redeem_statreset'));
								If(microStoreID{id} == 492, HideWidget('mstore_tip_redeem_mulligan'));
							"
						/>
						<instance name="storeButton" label="general_owned" visible="false" enabled="false" buttonName="vaultViewShelfBtnOwned{id}"/>
					</panel>
				</panel>
			</panel>
			<panel width="230@" height="115%" x="-9%" y="-7%" noclick="true">
				<image width="50@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_door_open_{row_name=top}.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" name="vaultViewShelfItem{id}_open" visible="true" />
			</panel>
			<panel width="230@" height="115%" x="-9%" y="-7%" noclick="true"
				onload="If({id} == 1, Instantiate('vaultViewShelfTokensPasses'));"
			>
			</panel>
			<panel width="230@" height="115%" x="-9%" y="-7%" noclick="true">
				<panel name="vaultViewShelfItem{id}_door"
					onevent0="
						SleepWidget(250, 'FadeOut(200); PlaySound(\'/ui/fe2/store/sounds/metal_door_open.wav\');');
					"
					onevent1="
						PlaySound('/ui/fe2/store/sounds/metal_door_close.wav');
						FadeIn(200);
					"
				>
					<image width="50@" height="100%"  ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_hinge_{row_name=top}.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
					<image width="200@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_door.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
					<image width="75@" height="75%" x="6@" y="1%" align="center" valign="center" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_door_wheel.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" name="vaultViewShelfItem{id}_wheel"
						onevent0="Rotate(-180, 200); PlaySound('/ui/fe2/store/sounds/metal_wheel_spin1.wav');"
						onevent1="SleepWidget(200, 'Rotate(0, 200);'); PlaySound('/ui/fe2/store/sounds/metal_wheel_spin2.wav');"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="vaultViewShelfTokensPasses">
		<panel width="28.5h" height="15.5h" x="{x=2.75h}" y="{y=1h}" align="{align=left}" valign="{valign=top}" name="vaultViewShelfTokensPasses" visible="false" group="vaultViewShelfItems"
			onevent="
				SetVisible(true);
				GroupCall('TokensPassesData', 'DoEvent(0);');	## Reset ##
				ExplodeTrigger(
					'MicroStorePopulateTokensPasses',
					microStore_vaultData72,
					'|', '`'
				);
			"
		>
			<panel name="vaultViewShelfTokensPasses{id}_contents" x="0.5h" noclick="true">
				<image width="90%" height="90@" x="2h" y="" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_shelf_tokens.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
								
				<panel x="5.0h" y="1.6h" width="72%" height="3.0h" float="bottom" padding="0" noclick="true">
				
					<label fity="true" width="100%" textalign="center" font="dyn_12" style="microStorePaperTitle" content="mstore_vault_tokens_pass_title" noclick="true" />
				
					<!-- Tokens -->
					<panel width="100%" height="2.7h" onmouseover="ShowWidget('mstore_tip_vault_tokens');" onmouseout="HideWidget('mstore_tip_vault_tokens');">
						<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/hero_token.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" />
						<label x="115@" height="100%" textvalign="center" font="dyn_10" style="microStorePaperText" content="mstore_vault_tokens_owned" noclick="true" />
						<label x="-1h" width="-1h" align="right" textvalign="center" textalign="right" font="dyn_10" style="microStorePaperCost" noclick="true" watch="GameTokens" ontrigger="SetText(param);"/>
					</panel>
					
					<!-- AR Pass -->
					<panel width="100%" height="2.7h" onmouseover="ShowWidget('mstore_tip_vault_ARpass');" onmouseout="HideWidget('mstore_tip_vault_ARpass');">
						<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/ARpass.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" group="TokensPassesData" onevent0="SetRenderMode(If(HasGamePass('allrandom'), 'normal', 'grayscale'));"/>
						<label x="115@" height="100%" textvalign="center" font="dyn_9" style="microStorePaperText" content="mstore_vault_passexpires" noclick="true" />
						<label x="-1h" width="-1h" align="right" textvalign="center" textalign="right" font="dyn_9" style="microStorePaperCost" noclick="true" group="TokensPassesData" onevent0="SetText('-');" content="-"
							onshow="SetWatch('CountdownSeconds');"
							onhide="SetWatch('');"
							watch1="MicroStorePopulateTokensPasses"
							ontrigger1="
								If(
									param1 == 662,
									SetText(FormatDateTime(param8, '%#m/%#d/%Y %#I:%M %p', true))
								);
							"
						/>
					</panel>
					
					<!-- BD Pass -->
					<panel width="100%" height="2.7h" onmouseover="ShowWidget('mstore_tip_vault_BDpass');" onmouseout="HideWidget('mstore_tip_vault_BDpass');">
						<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/BDpass.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" group="TokensPassesData" onevent0="SetRenderMode(If(HasGamePass('banningdraft'), 'normal', 'grayscale'));"/>/>
						<label x="115@" height="100%" textvalign="center" font="dyn_9" style="microStorePaperText" content="mstore_vault_passexpires" noclick="true" />
						<label x="-1h" width="-1h" align="right" textvalign="center" textalign="right" font="dyn_9" style="microStorePaperCost" noclick="true" group="TokensPassesData" onevent0="SetText('-');" content="-"
							onshow="SetWatch('CountdownSeconds');"
							onhide="SetWatch('');"
							watch1="MicroStorePopulateTokensPasses"
							ontrigger1="
								If(
									param1 == 661,
									SetText(FormatDateTime(param8, '%#m/%#d/%Y %#I:%M %p', true))
								);
							"
						/>
					</panel>
					
					<!-- SD Pass -->
					<panel width="100%" height="2.7h" onmouseover="ShowWidget('mstore_tip_vault_SDpass');" onmouseout="HideWidget('mstore_tip_vault_SDpass');">
						<image width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/SDpass.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true" group="TokensPassesData" onevent0="SetRenderMode(If(HasGamePass('singledraft'), 'normal', 'grayscale'));"/>/>
						<label x="115@" height="100%" textvalign="center" font="dyn_9" style="microStorePaperText" content="mstore_vault_passexpires" noclick="true" />
						<label x="-1h" width="-1h" align="right" textvalign="center" textalign="right" font="dyn_9" style="microStorePaperCost" noclick="true" group="TokensPassesData" onevent0="SetText('-');" content="-"
							onshow="SetWatch('CountdownSeconds');"
							onhide="SetWatch('');"
							watch1="MicroStorePopulateTokensPasses"
							ontrigger1="
								If(
									param1 == 660,
									SetText(FormatDateTime(param8, '%#m/%#d/%Y %#I:%M %p', true))
								);
							"
						/>
					</panel>
				
				</panel>

			</panel>
			<panel width="230@" height="115%" x="-9%" y="-7%" noclick="true">
				<image width="50@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_door_open_{row_name=top}.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" name="vaultViewShelfTokensPasses{id}_open" visible="true"/>
			</panel>
		</panel>
	
	</template>
	
	<template name="woodenPlankFrame">
		<panel>
			<frame texture="/ui/frames/squareglow.tga" borderthickness="1h" color="0 0 0 0.5" height="+4h" width="+3h" y="-0.5h" align="center" valign="center" />
			<panel color="white" align="center" valign="center" width="-4h" height="-4h" 					ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_center.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale((GetScreenHeight() / 6.25) # 'p'); SetVScale((GetScreenHeight() / 6.25) # 'p');"/>
			<panel color="white" height="16h" width="-10h" y="-8h" align="center" valign="top" 				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_top.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale((GetHeight() * 0.5) # 'p'); SetVScale(GetHeight() # 'p');"/>
			<panel color="white" height="8h" width="-10h" align="center" valign="bottom" 					ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_bottom.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale(GetHeight() # 'p'); SetVScale(GetHeight() # 'p');"/>
			<panel color="white" height="-10h" width="8h" align="left" valign="center" 						ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_left.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale(GetWidth() # 'p'); SetVScale(GetWidth() # 'p');"/>
			<panel color="white" height="-10h" width="8h" align="right" valign="center" 					ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_right.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale(GetWidth() # 'p'); SetVScale(GetWidth() # 'p');"/>
			<image width="8h" height="16h" y="-8h" align="left" valign="top" 				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_tl.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			<image width="8h" height="16h" y="-8h" align="right" valign="top" 				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_tr.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			<image width="8h" height="8h" align="left" valign="bottom" 						ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_bl.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			<image width="8h" height="8h" align="right" valign="bottom" 					ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_br.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			<image width="6h" height="24h" x="0.75h" y="-22.5h" valign="top" align="left" 	ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_chain.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			<image width="6h" height="24h" x="-0.75h" y="-22.5h" valign="top" align="right" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/plank_frame_chain.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
		</panel>
	</template>

	<template name="plankWindow">
		<panel color="{color=0 0 0 0.5}" visible="false" name="store_popup_{id}" noclick="{noclick=0}"
			group="{group=storePopupWindows}"
			onevent0="
				FadeIn(100);
				SleepWidget(101, 'CallEvent(name # \'_plank\', 0);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slidein.wav');
				{onshow=}
			"
			onevent1="
				{onhide=}
				CallEvent(name # '_plank', 1);
				SleepWidget(101, 'FadeOut(100);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slideout.wav');
			"
			onevent1lua="
				{onhidelua=}
			"
			onevent2="
				## So these can be groupcalled to hide anything visible when the store closes. ##
				If(
					IsVisibleSelf(),
					DoEvent(1)
				);
			"
			onload="If({debug=false}, DoEvent(0));"
		>
			<panel width="{width=40h}" grow="true" y="-110%" x="{x}" valign="center" align="center" name="store_popup_{id}_plank" regrow="{regrow=false}" noclick="{noclick=0}"
				onevent0="SleepWidget(1, 'SlideY(\'{y=0}\', 250); SetVisible(true);');"
				onevent1="SlideY('-110%', 250); SleepWidget(251, 'SetVisible(false);');"
			>
				<instance name="woodenPlankFrame"/>
				<panel height="11h"/><!-- This is about the minimum height that this thing can have -->
				<label width="100%" height="2.5h" y="3.5h" content="{title}" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperTitle" watch="{titlewatch}" ontrigger="{titleontrigger}"/>
				<instance visible="{show_close=false}" name="closexButtonPaper" y="4h" width="2h" height="2h" align="right" x="-3h" onclick="CallEvent('store_popup_{id}', 1);" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);"/>
				<panel width="-6h" align="center" grow="true" y="6h" float="bottom" regrow="{regrow=false}">
					<panel width="100%" grow="true" regrow="{regrow=false}">
						<instance name="{content}"/>
					</panel>
					<panel height="4h" width="100%"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="closexButtonPaperImage">
		<panel>
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="{bgcolor=#9d5b1a}" visible="{bgvisible=false}"/>
			<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="0.5h"/>
			<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/closex2.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="{xcolor=#774515}" align="center" valign="center" width="-30%" height="-30%"/>
		</panel>
	</template>

	<template name="closexButtonPaper">
		<button
			name="{buttonName}"
			width="{width=100%}"
			height="{height=100%}"
			align="{align=left}"
			valign="{valign=top}"
			x="{x}"
			y="{y}"
			onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); {onclick}"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
			color="invisible"
			visible="{visible=true}"
		>
			<widgetstate statename="up">
				<instance name="closexButtonPaperImage" textalign="{textalign=center}"/>
			</widgetstate>
			<widgetstate statename="over">
				<instance name="closexButtonPaperImage" textalign="{textalign=center}" bgvisible="true" xcolor="1 1 1 1"/>
			</widgetstate>
			<widgetstate statename="down" x=".1h" y=".1h">
				<instance name="closexButtonPaperImage" textalign="{textalign=center}" bgvisible="true" bgcolor="#774515" xcolor="1 1 1 1"/>
			</widgetstate>
			<widgetstate statename="disabled" rendermode="grayscale">
				<instance name="closexButtonPaperImage" textalign="{textalign=center}"/>
			</widgetstate>
		</button>
	</template>

	<template name="storeItemImage">
		<panel x="{x}" y="{y}" align="{align}" valign="{valign}" width="{width}" height="{height}" color="0 0 0 1" noclick="true">
			<panel color="0 0 0 0.5" x="1" y="1" noclick="true"/>
			<webimage name="{image_name}" noclick="{noclick=true}"
				resourcecontext="{resourcecontext=store}"
				onevent="
					If(
						!StringEquals(microStoreLocalContent{id}, '-1'),
						If(
							StringEquals(SubString(microStoreCode{id}, 3, 11), 'custom_icon') and StringEquals(microStoreLocalContent{id}, 'web'),
							SetTextureURL(
								GetICBURL()
								# '/' #
								'icons'
								# '/' #
								Floor(GetAccountID() / 1000000)
								# '/' #
								Floor((GetAccountID() - (Floor(GetAccountID() / 1000000) * 1000000)) / 1000)
								# '/' #
								GetAccountID()
								# '/' #
								SubString(microStoreCode{id}, 15, -1) #
								'.cai'
							),
							SetTexture(microStoreLocalContent{id})
						),
						If(
							!StringEquals(microStoreWebContent{id}, '-1'),
							SetTextureURL(microStoreWebContent{id}),
							SetTexture('/ui/legion/ability_coverup.tga')
						)
					);
					CallEvent('{image_name}_hover');
				"
				onload="DoEvent();"
				onmouseover="
					if(
						{hover_enlarge=false} and StringEquals(SubString(microStoreCode{id}, 2, 1), '.') and microStoreID{id} != 228,
						Split(
							Trigger(
								'StoreImagePreviewInit',
								GetWidth(),
								GetHeight(),
								GetAbsoluteX(),
								GetAbsoluteY(),
								(StringEquals(SubString(microStoreCode{id}, 3, 11), 'custom_icon') and StringEquals(microStoreLocalContent{id}, 'web')),
								If(
									StringEquals(SubString(microStoreCode{id}, 3, 11), 'custom_icon') and StringEquals(microStoreLocalContent{id}, 'web'),
									GetICBURL()
									# '/' #
									'icons'
									# '/' #
									Floor(GetAccountID() / 1000000)
									# '/' #
									Floor((GetAccountID() - (Floor(GetAccountID() / 1000000) * 1000000)) / 1000)
									# '/' #
									GetAccountID()
									# '/' #
									SubString(microStoreCode{id}, 15, -1) #
									'.cai',
									GetTexture()
								)

							),
							Trigger('StoreImagePreviewVis', true, '250%')
						)
					);

				"
				onmouseout="
					if(
						{hover_enlarge=false},
						DoEvent(1)
					);

				"
				onhide="
					if(
						{hover_enlarge=false},
						DoEvent(1)
					);

				"
				onevent1="
					Trigger('StoreImagePreviewVis', false, '100%');
				"
			/>
			<frame color="invisible" bordercolor="#FFCC00" borderthickness="1" noclick="true" />
			<webimage name="{image_name}_hover" align="center" valign="center"
				noclick="true"
				visible="false"
				resourcecontext="{resourcecontext=store}"
				onevent="
					If(
						!StringEquals(microStoreLocalContent{id}, '-1'),
						SetTexture(microStoreLocalContent{id}),
						If(
							!StringEquals(microStoreWebContent{id}, '-1'),
							SetTextureURL(microStoreWebContent{id}),
							SetTexture('/ui/legion/ability_coverup.tga')
						)
					);
				"
				onload="DoEvent();"
				onevent1="
					FadeIn(200);
					ScaleWidth('250%', 200);
					ScaleHeight('250%', 200);
				"
				onevent2="
					SleepWidget(201, 'DoEvent(3);');
				"
				onevent3="
					If(
						IsVisible(),
						Split(
							FadeOut(200),
							ScaleWidth('100%', 200),
							ScaleHeight('100%', 200)
						)
					);
				"
			/>
		</panel>
	</template>

	<template name="vaultViewBookItemEntryLeft">
		<panel width="100%" height="3.2h" name="{itemTemplateName=vaultViewBookItem}{id}" group="{itemTemplateName=vaultViewBookItem}s" visible="false"
			onevent0="
				If(
					microStoreID{id} ge 0,
					If(
						IsVisible('{viewnamefull=vaultItemViewBook}'),
						DoEvent(3),
						SleepWidget(450, 'DoEvent(3);')
					)
				);
			"
			onevent1="
				SleepWidget(({id=1} - 1) * 25, 'PlaySound(\'/ui/fe2/store/sounds/book_item_fadeout.wav\'); FadeOut(200);');
			"
			onevent2="
				If(
					microStoreID{id} ge 0,
					Split(
						If(
							microStoreID{id} == 228 or microStoreID{id} == 464,
							HideWidget('vaultViewBookBtnConfig{id}')
						),
						HideWidget('vaultViewBookBtnSelected{id}'),
						##Call('{viewname=vaultViewBook}Title{id}', 'SetText(microStoreName{id});'),##
						Call('{viewname=vaultViewBook}Image{id}', 'DoEvent();'),
						If(
							microStoreID{id} != 228 and microStoreID{id} != 464,
							ShowWidget('vaultViewBookBtnConfig{id}')
						),
						If(
							StringEquals(microStoreCode{id}, 'ai') or
							StringEquals(microStoreCode{id}, 'cs') or
							StringEquals(microStoreCode{id}, 'av') or
							StringEquals(microStoreCode{id}, 'cc') or
							StringEquals(microStoreCode{id}, 'w') or
							StringEquals(microStoreCode{id}, 'c') or
							StringEquals(microStoreCode{id}, 'cr'),
							Split(
								HideWidget('vaultViewBookBtnConfig{id}'),
								ShowWidget('vaultViewBookBtnSelected{id}')
							)
						),
						Trigger('vaultRefreshConfigButtons'),
						If(
							microStoreID{id} == 464,
							ShowWidget('vaultViewBookCustIconInfo{id}'),
							HideWidget('vaultViewBookCustIconInfo{id}')
						)
					)
				);
			"
			onevent2lua="
				if (GetCvarNumber('microStoreID{id}') >= 0) then
					local nameWidget = GetWidget('{viewname=vaultViewBook}Title{id}')
					local nameString = GetCvarString('microStoreName{id}')

					nameWidget:SetFont(GetFontSizeForWidth(nameString, nameWidget:GetWidth(), 11, 6))
					nameWidget:SetText(nameString)
				end
			"
			onevent3="
				SleepWidget(({id=1} - 1) * 25, 'DoEvent(5); FadeIn(200);');
			"
			onevent4="
				If(
					StringEquals(microStoreCode{id}, 'ai') or
					StringEquals(microStoreCode{id}, 'cs') or
					StringEquals(microStoreCode{id}, 'av') or
					StringEquals(microStoreCode{id}, 'cc') or
					StringEquals(microStoreCode{id}, 'w') or
					StringEquals(microStoreCode{id}, 'c') or
					StringEquals(microStoreCode{id}, 'cr'),
					Split(
						HideWidget('vaultViewBookBtnConfig{id}'),
						If(
							microStoreID{id} != 228,
							ShowWidget('vaultViewBookBtnSelected{id}')
						)

					),
					Split(
						If(
							microStoreID{id} != 228 and microStoreID{id} != 464,
							ShowWidget('vaultViewBookBtnConfig{id}')
						),
						HideWidget('vaultViewBookBtnSelected{id}')
					)
				);
			"
			onevent5="
				PlaySound('/ui/fe2/store/sounds/book_item_fadein.wav');
			"
			watch="refreshVaultViewBookCfg"
			ontrigger="
				If(
					StringEquals(microStoreCode{id}, 'ai') or
					StringEquals(microStoreCode{id}, 'cs') or
					StringEquals(microStoreCode{id}, 'av') or
					StringEquals(microStoreCode{id}, 'cc') or
					StringEquals(microStoreCode{id}, 'w') or
					StringEquals(microStoreCode{id}, 'c') or
					StringEquals(microStoreCode{id}, 'cr'),
					Split(
						HideWidget('vaultViewBookBtnConfig{id}'),
						If(
							microStoreID{id} != 228,
							ShowWidget('vaultViewBookBtnSelected{id}')
						)
					),
					Split(
						If(
							microStoreID{id} != 228 and microStoreID{id} != 464,
							ShowWidget('vaultViewBookBtnConfig{id}')
						),
						HideWidget('vaultViewBookBtnSelected{id}')
					)
				);
			"
		>
			<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="0.5h"/>
			<panel hmargin="0.25h" vmargin="0.25h">
				<instance name="storeItemImage" id="{id}" height="100%" width="100@" image_name="{viewname=vaultViewBook}Image{id}" align="{imgalign=left}" hover_enlarge="true" noclick="false"/>
				<label x="{textx=110@}" style="microStorePaperText" font="dyn_12" textvalign="center" noclick="true" name="{viewname=vaultViewBook}Title{id}" content="-" align="{textalign=left}" textalign="{textalign=left}" width="-510@" />
				<panel align="{buttonalign=right}" width="10h" x="{buttonx=0}">
					<label style="microStorePaperText" visible="false" font="dyn_10" textalign="center" textvalign="center" content="mstore_item_selected" noclick="true"
						watch="MicroStoreSelectedUpgradeListed"
						ontrigger="
							If(
								StringEquals(
									SubString(param0, 0, 11),
									'custom_icon'
								) and
								StringEquals(
									SubString(microStoreCode{id}, 3, 11),
									'custom_icon'
								),
								If(
									StringEquals(
										SubString(microStoreCode{id}, 15, -1),
										SubString(param0, 12, -1)
									),
									SetVisible(true)
								),
								If(
									param0 == microStoreID{id},
									SetVisible(true)
								)
							);
						"
						name="vaultViewBookBtnSelected{id}"
					/>
					<instance name="storeButton" label="mstore_choose" visible="true" buttonName="vaultViewBookBtnConfig{id}"
						onclick="
							HideWidget('mstore_tip_vault_choose' # _microStore_Category);
							Trigger('MicroStoreSetProcTrig', 'SelectUpgradesStatus');
							If(
								StringEquals(microStoreCode{id}, 'ai') or
								StringEquals(microStoreCode{id}, 'cs') or
								StringEquals(microStoreCode{id}, 'av') or
								StringEquals(microStoreCode{id}, 'cc') or
								StringEquals(microStoreCode{id}, 'w') or
								StringEquals(microStoreCode{id}, 'c') or
								StringEquals(microStoreCode{id}, 'cr'),
								ClearUpgrade(microStoreCode{id}),
								SelectUpgrade(microStoreCode{id})
							);
						"
						onmouseover="ShowWidget('mstore_tip_vault_choose' # _microStore_Category);"
						onmouseout="HideWidget('mstore_tip_vault_choose' # _microStore_Category);"
						watch="MicroStoreProcessing"
						ontrigger="SetEnabled(!param0);"
						watch1="MicroStoreSelectedUpgradeListed"
						ontrigger1="
								If(
									StringEquals(
										SubString(param0, 0, 11),
										'custom_icon'
									) and
									StringEquals(
										SubString(microStoreCode{id}, 3, 11),
										'custom_icon'
									),
									If(
										StringEquals(
											SubString(microStoreCode{id}, 15, -1),
											SubString(param0, 12, -1)
										),
										SetVisible(false)
									),
									If(
										param0 == microStoreID{id},
										SetVisible(false)
									)

								);

								If(
									StringEquals(microStoreCode{id}, 'ai') or
									StringEquals(microStoreCode{id}, 'cs') or
									StringEquals(microStoreCode{id}, 'av') or
									StringEquals(microStoreCode{id}, 'cc') or
									StringEquals(microStoreCode{id}, 'w') or
									StringEquals(microStoreCode{id}, 'c') or
									StringEquals(microStoreCode{id}, 'cr'),
									SetVisible(true)
								);

						"
					/>
					<instance name="storeButton" label="mstore_redeem" visible="false" onevent="SetVisible(WidgetExists('vaultRedeemHelper' # *('microStoreID' # {id=0}) ));" buttonName="vaultViewBookBtnRedeem{id}"
						onclick="
							If(microStoreID{id} == 161, HideWidget('mstore_tip_redeem_nickchange'));
							If(microStoreID{id} == 162, HideWidget('mstore_tip_redeem_subaccount'));
							If(microStoreID{id} == 163, HideWidget('mstore_tip_redeem_statreset'));
							If(microStoreID{id} == 492, HideWidget('mstore_tip_redeem_mulligan'));
							Trigger('vaultConfigureProduct', microStoreID{id}, {id=0}, name);
						" watch="vaultRefreshConfigButtons" ontrigger="DoEvent();"
						onmouseover="
							If(microStoreID{id} == 161, ShowWidget('mstore_tip_redeem_nickchange'));
							If(microStoreID{id} == 162, ShowWidget('mstore_tip_redeem_subaccount'));
							If(microStoreID{id} == 163, ShowWidget('mstore_tip_redeem_statreset'));
							If(microStoreID{id} == 492, ShowWidget('mstore_tip_redeem_mulligan'));
						"
						onmouseout="
							If(microStoreID{id} == 161, HideWidget('mstore_tip_redeem_nickchange'));
							If(microStoreID{id} == 162, HideWidget('mstore_tip_redeem_subaccount'));
							If(microStoreID{id} == 163, HideWidget('mstore_tip_redeem_statreset'));
							If(microStoreID{id} == 492, HideWidget('mstore_tip_redeem_mulligan'));
						"
					/>
					<panel visible="false" name="vaultViewBookCustIconInfo{id}" noclick="true" color="invisible">
						<label textalign="right" align="right" x="-2.5h" style="microStorePaperItem" font="dyn_12" textvalign="center" content="mstore_icon_await_upload" width="-2.5h" noclick="true"/>
						<instance name="tip_mark" tip_id="empty_custom_slot_tip" width="2h" height="2h" valign="center" align="right" />
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="vaultViewBookConfigEntry">
		<panel width="100%" height="3.2h" name="vaultViewBookConfigEntry" group="" visible="true">
			<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="0.5h"/>
		</panel>
	</template>

	<template name="vaultViewBookItemEntryRight">
		<instance name="vaultViewBookItemEntryLeft" imgalign="right" textalign="right" textx="-110@" buttonalign="left" buttonx="" costalign="left" id="{id}"/>
	</template>

	<template name="vaultViewBook15ItemEntryLeft">
		<instance name="vaultViewBookItemEntryLeft" id="{id}" itemTemplateName="vaultViewBook15Item" viewname="vaultViewBook15" viewnamefull="vaultItemViewBook15"/>
	</template>

	<template name="vaultViewBook15ItemEntryRight">
		<instance name="vaultViewBookItemEntryLeft" imgalign="right" textalign="right" textx="-110@" buttonalign="left" buttonx="" costalign="left" id="{id}" itemTemplateName="vaultViewBook15Item" viewname="vaultViewBook15" viewnamefull="vaultItemViewBook15"/>
	</template>

	<!--

	=======================================================================================
	SPLIT BETWEEN BUILDING BLOCK TEMPLATES AND STORE CHUNK TEMPLATES
	=======================================================================================

	-->

	<!-- Vault Item List (book style) -->
	<template name="vaultItemListBook">
		<panel width="-30h" height="-14.1h" y="8.1h" align="right" color="1 1 1 0.1" name="{viewName=vaultItemViewBook}" x="5%" visible="false" noclick="true"
			onevent0="
				If(
					IsVisible('{itemTemplateName=vaultViewBookItem}1') and _microStore_RequestCode == 2,
					SleepWidget(550, 'DoEvent(2);'),
					SleepWidget(250, 'DoEvent(2);')
				);
			"
			onevent1="
				If(
					IsVisible('{itemTemplateName=vaultViewBookItem}1') and _microStore_RequestCode == 2,
					SleepWidget(300, 'DoEvent(3);'),
					DoEvent(3)
				);
			"
			onevent2="
				PlaySound('/ui/fe2/store/sounds/ledger_open.wav');
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent3="
				PlaySound('/ui/fe2/store/sounds/ledger_close.wav');
				GroupCall('{itemTemplateName=vaultViewBookItem}s', 'FadeOut(199);');
				SlideX('5%', 250);
				FadeOut(200);
			"
			onevent4="
				If(
					!IsVisible('{itemTemplateName=vaultViewBookItem}1'),
					Split(
						DoEvent(7),
						DoEvent(5)
					),
					Split(
						DoEvent(6),
						SleepWidget(650, 'DoEvent(7); DoEvent(5);')
					)
				);
			"
			onevent5="
				GroupCall('{itemTemplateName=vaultViewBookItem}s', 'DoEvent(0);');
			"
			onevent6="
				GroupCall('{itemTemplateName=vaultViewBookItem}s', 'DoEvent(1);');
			"
			onevent7="
				Trigger('StoreDeleteCurrentItems', 1500);
				GroupCall('{itemTemplateName=vaultViewBookItem}s', 'DoEvent(2);');
				CallEvent('MicroStoreUpgCheck', 0);
			"
		>
			<panel color="white" height="50@" width="100%" y="-0.25@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_view_book.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
			<panel valign="center" width="35.75h" height="-7.2h" y="0" x="4.25h">
				<!--
					Instantiate oninstantiate?!  It's madness I tell you!
					Required because <if> is being a big baby when it comes to template {vars} in its condition
				-->
				<panel width="100%" grow="true" float="bottom" padding="0.25h"
					oninstantiate="
						If(
							{vaultConfigItem=false},
							Instantiate('vaultViewBookConfigEntry')
						);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 1);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 2);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 3);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 4);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 5);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 6);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 7);
						If(
							!({vaultConfigItem=false}),
							Instantiate('{itemTemplate=vaultViewBookItemEntry}Left', 'id', 8)
						);
					"
				/>
			</panel>
			<panel valign="center" align="right" width="35.75h" height="-7.2h" y="0" x="-4.25h">
				<panel width="100%" grow="true" float="bottom" padding="0.25h"
					oninstantiate="
						If(
							{vaultConfigItem=false},
							Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 8)
						);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 9);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 10);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 11);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 12);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 13);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 14);
						Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 15);
						If(
							!({vaultConfigItem=false}),
							Instantiate('{itemTemplate=vaultViewBookItemEntry}Right', 'id', 16)
						);
					"
				/>
			</panel>
		</panel>
	</template>

	<!-- Item List (book style) -->
	<template name="storeItemListBook">
		<panel width="-30h" height="-14.5h" y="8h" align="right" color="1 1 1 0.1" name="storeItemViewBook" x="5%" visible="false" noclick="true"
			onevent0="
				If(
					(
						IsVisible('storeViewShelfItem1') or
						IsVisible('storeViewBookAccIconsItem1')
					)
					and _microStore_RequestCode == 1,
					SleepWidget(550, 'DoEvent(2);'),
					SleepWidget(250, 'DoEvent(2);')
				);
			"
			onevent1="
				If(
					IsVisible('storeViewBookItem1') and _microStore_RequestCode == 1,
					SleepWidget(
						300,
						'
							Trigger(\'storeItemViewBookSlideOut\');
						'
					),
					Trigger('storeItemViewBookSlideOut')
				);
			"
			onevent2="
				PlaySound('/ui/fe2/store/sounds/book_open.wav');
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent4="
				If(
					!IsVisible('storeViewBookItem1'),
					Split(
						DoEvent(7),
						DoEvent(5)
					),
					Split(
						DoEvent(6),
						SleepWidget(650, 'DoEvent(7); DoEvent(5);')
					)
				);

			"
			onevent5="
				GroupCall('storeViewBookItems', 'DoEvent(0);');
			"
			onevent6="
				GroupCall('storeViewBookItems', 'DoEvent(1);');
			"
			onevent7="
				Trigger('StoreDeleteCurrentItems', 1500);
				GroupCall('storeViewBookItems', 'DoEvent(2);');
			"
			watch0="storeItemViewBookSlideOut"
			ontrigger0="
				PlaySound('/ui/fe2/store/sounds/book_close.wav');
				SlideX('5%', 250);
				SleepWidget(199, 'HideGroup(\'storeViewBookItems\');');
				FadeOut(200);
			"
		>
			<panel color="white" height="50@" width="100%" y="-0.25@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_view_book.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
			<panel valign="center" width="32.75h" height="-4.2h" y="-0.1h" x="6h">
				<panel width="100%" grow="true" valign="center" float="bottom" padding="0.25h">
					<instance name="storeViewBookItemEntryLeft" id="1"/>
					<instance name="storeViewBookItemEntryLeft" id="2"/>
					<instance name="storeViewBookItemEntryLeft" id="3"/>
					<instance name="storeViewBookItemEntryLeft" id="4"/>
					<instance name="storeViewBookItemEntryLeft" id="5"/>
					<instance name="storeViewBookItemEntryLeft" id="6"/>
					<instance name="storeViewBookItemEntryLeft" id="7"/>
					<instance name="storeViewBookItemEntryLeft" id="8"/>
					<instance name="storeViewBookItemEntryLeft" id="9"/>
				</panel>
			</panel>
			<panel valign="center" align="right" width="32.25h" height="-4.2h" y="-0.1h" x="-5.5h">
				<panel width="100%" grow="true" valign="center" float="bottom" padding="0.25h">
					<instance name="storeViewBookItemEntryRight" id="10"/>
					<instance name="storeViewBookItemEntryRight" id="11"/>
					<instance name="storeViewBookItemEntryRight" id="12"/>
					<instance name="storeViewBookItemEntryRight" id="13"/>
					<instance name="storeViewBookItemEntryRight" id="14"/>
					<instance name="storeViewBookItemEntryRight" id="15"/>
					<instance name="storeViewBookItemEntryRight" id="16"/>
					<instance name="storeViewBookItemEntryRight" id="17"/>
					<instance name="storeViewBookItemEntryRight" id="18"/>
				</panel>
			</panel>
		</panel>
	</template>



	<!-- Item List (book style) version for account icons [left side blurb] -->
	<template name="storeItemListBookAccIcons">
		<panel width="-30h" height="-14.5h" y="8h" align="right" color="1 1 1 0.1" name="storeItemViewBookAccIcons" x="5%" visible="false" noclick="true"
			onevent0="
				If(
					(
						IsVisible('storeViewShelfItem1') or
						IsVisible('storeViewBookItem1')
					)
					and _microStore_RequestCode == 1,
					SleepWidget(550, 'DoEvent(2);'),
					SleepWidget(250, 'DoEvent(2);')
				);
			"
			onevent1="
				If(
					IsVisible('storeViewBookAccIconsItem1') and _microStore_RequestCode == 1,
					SleepWidget(
						300,
						'
							Trigger(\'storeItemViewBookAccIconsSlideOut\');
						'
					),
					Trigger('storeItemViewBookAccIconsSlideOut')
				);
			"
			onevent2="
				PlaySound('/ui/fe2/store/sounds/book_open.wav');
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent4="
				If(
					!IsVisible('storeViewBookAccIconsItem1'),
					Split(
						DoEvent(7),
						DoEvent(5)
					),
					Split(
						DoEvent(6),
						SleepWidget(650, 'DoEvent(7); DoEvent(5);')
					)
				);

			"
			onevent5="
				GroupCall('storeViewBookAccIconsItems', 'DoEvent(0);');
			"
			onevent6="
				GroupCall('storeViewBookAccIconsItems', 'DoEvent(1);');
			"
			onevent7="
				Trigger('StoreDeleteCurrentItems', 1500);
				GroupCall('storeViewBookAccIconsItems', 'DoEvent(2);');
			"
			watch0="storeItemViewBookAccIconsSlideOut"
			ontrigger0="
				PlaySound('/ui/fe2/store/sounds/book_close.wav');
				SlideX('5%', 250);
				SleepWidget(199, 'HideGroup(\'storeViewBookAccIconsItems\');');
				FadeOut(200);
			"
		>
			<panel color="white" height="50@" width="100%" y="-0.25@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_view_book.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>



			<panel x="6.0h" y="3.0h" width="32.0h" height="29.8h" noclick="true">

				<!-- Open Slot -->
				<panel width="100%" height="42%" noclick="true">
					<frame texture="/ui/frames/roundframe.tga" bordercolor="#9d5b1a" borderthickness="0.5h" noclick="true"/>
					<panel y="0.2h" grow="true" width="-1.6h" align="center">
						<panel x="-0.2h" y="0.5h" width="6.2h" height="6.2h" noclick="true">
							<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/unlock.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
							<panel noclick="true" width="3.6h" height="3.6h" align="right" valign="bottom" visible="1"
								watch="##MicroStoreUpdateCategory##" ontrigger="If(_microStore_iconsUnlocked, FadeIn(250), FadeOut(250));"
							>
								<image noclick="true" align="center" valign="center" width="100@" height="100%" texture="/ui/elements/check_mark.tga" x="0.2h" y="0.2h" color="0 0 0 0.5"/>
								<image noclick="true" align="center" valign="center" width="100@" height="100%" texture="/ui/elements/check_mark.tga"/>
							</panel>
						</panel>
						<label width="-7.0h" align="right" font="dyn_16" color="#451607" shadow="true" shadowcolor="#d7b361" content="Unlock Icon Slot" />
						<label fity="true" y="2.4h" width="-7.0h" align="right" wrap="true" font="dyn_10" color="#2c0c02" content="mstore_unlock_body" />
					</panel>
				</panel>

				<!-- Custom Icon -->
				<panel width="100%" height="56%" valign="bottom" noclick="true">
					<frame texture="/ui/frames/roundframe.tga" bordercolor="#9d5b1a" borderthickness="0.5h" noclick="true"/>

					<panel y="0.2h" grow="true" width="-1.6h" align="center">
						<panel y="0.5h" width="6.0h" height="6.0h">
							<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/icons/custom_icon.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
							<panel
								noclick="true"
								width="3.6h" height="3.6h"
								align="right" valign="bottom"
								visible="false"
								watch="MicroStoreUpdateCategory"
								ontrigger="
									If(
										_microStore_custAccIconUnlocked,
										FadeIn(250),
										FadeOut(250)
									);
								"
							>
								<image noclick="true" align="center" valign="center" width="120@" height="120%" texture="/ui/elements/check_mark.tga" x="0.2h" y="0.2h" color="0 0 0 0.5"/>
								<image noclick="true" align="center" valign="center" width="120@" height="120%" texture="/ui/elements/check_mark.tga"/>
							</panel>
						</panel>
						<label width="-7.0h" align="right" font="dyn_16" color="#451607" shadow="true" shadowcolor="#d7b361" content="mstore_custom_upload" />
						<label fity="true" y="2.7h" width="-7.0h" align="right" wrap="true" font="dyn_10" color="#2c0c02" content="mstore_custom_detail" />
					</panel>

					<panel y="-3.4h" height="3.2h" align="right" valign="bottom">
						<instance name="storeButton" tip_id="mstore_tip_purchase_item" x="-8.0h" align="right" width="16.4h" label="mstore_purchase_custom_btn"
							watch="MicroStoreUpdateCategory"
							ontrigger="
								If(
									!_microStore_custAccIconUnlocked,
									FadeIn(250),
									FadeOut(250)
								);
							"
							onclick="
								Set('_microStore_SelectedID', 464);
								Set('_microStore_SelectedItem', 999);
								Set('microStoreID999', 464);
								Set('_microStore_SelectedID', microStoreID999);
								Set('microStoreLocalContent999', '/ui/fe2/store/icons/custom_icon.tga');
								Set('microStorePrice999', _microStore_custAccIconCost);
								Set('microStoreSilverPrice999', customAccountIconCostMMP);
								Set('microStorePremium999', true);
								Trigger('MicroStoreUpdateSelection');
								CallEvent('store_popup_confirm_purchase_choose', 0);

							"
							visible="true"
						/>
						<label x="-8h" width="14.7h"
							noclick="true"
							align="right"
							color="#00a200"
							content="mstore_purchased"
							font="dyn_12"
							watch="MicroStoreUpdateCategory"
							ontrigger="
								If(
									_microStore_custAccIconUnlocked,
									FadeIn(250),
									FadeOut(250)
								);
							"
							textalign="center" textvalign="center"
						/>

						<!-- Gold Only -->
						<panel x="-0.5h" align="right" noclick="true" visible="false"
							watch="MicroStoreUpdateCategory"
							ontrigger="SetVisible(_microStore_custAccIconCost gt 0 and customAccountIconCostMMP le 0);"
						>
							<label outline="true" width="-2.6h" textalign="right" textvalign="center" color="#ffcc00" font="dyn_12" shadow="true" watch="MicroStoreUpdateCategory" ontrigger="SetText(_microStore_custAccIconCost);" noclick="true"/>
							<image align="right" valign="center" width="70@" height="70%" x="-0.15h" y="0.1h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.9" />
							<image align="right" valign="center" width="70@" height="70%" x="-0.25h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
						</panel>

						<!-- Gold or Silver -->
						<panel x="-0.5h" align="right" noclick="true"
							watch="MicroStoreUpdateCategory"
							ontrigger="SetVisible(_microStore_custAccIconCost gt 0 and customAccountIconCostMMP gt 0);"
						>
							<panel y="-40%" noclick="true">
								<label outline="true" width="-2.6h" textalign="right" textvalign="center" color="#ffcc00" font="dyn_12" shadow="true" watch="MicroStoreUpdateCategory" ontrigger="SetText(_microStore_custAccIconCost);" noclick="true"/>
								<image align="right" valign="center" width="70@" height="70%" x="0.1h" y="0.1h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.9" />
								<image align="right" valign="center" width="70@" height="70%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
							</panel>
							<panel y="40%" noclick="true">
								<label outline="true" width="-2.6h" textalign="right" textvalign="center" outlinecolor="#2d1d0d" color="#c0d5ed" font="dyn_10" shadow="true" watch="MicroStoreUpdateCategory" ontrigger="SetText(customAccountIconCostMMP);" noclick="true"/>
								<panel align="right" valign="center" width="60@" height="60%">
									<image x="0.1h" y="0.1h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.9" />
									<image align="right" valign="center" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
								</panel>

							</panel>
						</panel>
					</panel>

					<panel y="-0.3h" height="2.0h" width="-0.6h" align="center" valign="bottom" noclick="true">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#ffcb29" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" bordercolor="#812800" borderthickness="0.5h" noclick="true"/>
						<label width="100%" height="100%" textalign="center" textvalign="center" font="dyn_10" color="#1e0a01" shadow="true" shadowcolor="#ffd554" content="mstore_custom_disclaimer" noclick="true" />
					</panel>

					<!-- If Not Purchased - FAQ -->
					<panel
						x="0.8h" y="4.9h" width="6.0h" height="3.9h" align="left" valign="top"
						onmouseover="ShowWidget('custom_slot_faq_tip');"
						onmouseout="HideWidget('custom_slot_faq_tip');"
						watch="MicroStoreUpdateCategory"
						ontrigger="
							SetVisible(!_microStore_custAccIconUnlocked);
						"
						onhide="HideWidget('custom_slot_faq_tip');"
					>
						<image x="0.5h" width="2.4h" height="2.4h" valign="top" align="right" texture="/ui/elements/tip_mark_up.tga" noclick="true" />
						<label y="-1" height="100%" width="100%" font="dyn_9" color="#006cff" textvalign="bottom" textalign="center" content="Icon FAQ" noclick="true" />
						<panel width="96%" height="1" align="center" valign="bottom" color="#006cff" noclick="true"/>
					</panel>

					<!-- Empty Slot Indicator -->
					<panel
						name="empty_custom_slot"
						x="0.8h" y="-3.5h" width="6.0h" height="6.0h" align="left" valign="bottom"
						onmouseover="ShowWidget('empty_custom_slot_tip');"
						onmouseout="HideWidget('empty_custom_slot_tip');"
						watch="MicroStoreUpdateCategory"
						ontrigger="
							SetVisible(_microStore_custAccIconUnlocked);
						"
						onhide="HideWidget('empty_custom_slot_tip');"
					>
						<image width="80%" height="80%" align="center" valign="top" texture="/ui/fe2/elements/comm_newmsg.tga" noclick="true" />
						<label y="-1" height="100%" width="100%" font="dyn_8" color="#006cff" textvalign="bottom" textalign="center" content="mstore_custom_tip_txt" noclick="true" />
						<panel width="100%" height="1" valign="bottom" color="#006cff" noclick="true"/>
					</panel>

				</panel>

			</panel>


			<panel valign="center" align="right" width="32.25h" height="-4.2h" y="-0.1h" x="-5.5h">
				<panel width="100%" grow="true" valign="center" float="bottom" padding="0.25h">
					<instance name="storeViewBookAccIconsItemEntryRight" id="1"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="2"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="3"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="4"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="5"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="6"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="7"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="8"/>
					<instance name="storeViewBookAccIconsItemEntryRight" id="9"/>
				</panel>
			</panel>
		</panel>
	</template>



	<template name="storeItemListShelf">
		<panel width="-30h" height="-14.5h" y="7.8h" align="right" color="1 1 1 0.1" name="storeItemViewShelves" x="5%" visible="false" noclick="true"
			onevent0="
				If(
					(
						IsVisible('storeViewBookItem1') or
						IsVisible('storeViewBookAccIconsItem1')
					)
					and _microStore_RequestCode == 1,
					SleepWidget(550, 'DoEvent(2);'),
					SleepWidget(250, 'DoEvent(2);')
				);
			"
			onevent1="
				If(
					IsVisible('storeViewShelfItem1') and _microStore_RequestCode == 1,
					SleepWidget(300, 'Trigger(\'storeItemViewShelfSlideOut\');'),
					Trigger('storeItemViewShelfSlideOut')
				);
			"
			onevent2="
				PlaySound('/ui/fe2/store/sounds/woodshelves_slidein.wav');
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent4="
				If(
					!IsVisible('storeViewShelfItem1'),
					Call(name, 'DoEvent(7); DoEvent(5);'),
					Split(
						DoEvent(6),
						SleepWidget(250, 'DoEvent(7); DoEvent(5);')
					)
				);
			"
			onevent5="
				GroupCall('storeViewShelfItems', 'DoEvent(0);');
			"
			onevent6="
				GroupCall('storeViewShelfItems', 'DoEvent(1);');
			"
			onevent7="
				Trigger('StoreDeleteCurrentItems', 1500);
				GroupCall('storeViewShelfItems', 'DoEvent(2);');
			"
			watch0="storeItemViewShelfSlideOut"
			ontrigger0="
				PlaySound('/ui/fe2/store/sounds/woodshelves_slideout.wav');
				SlideX('5%', 250);
				SleepWidget(199, 'HideGroup(\'storeViewShelfItems\');');
				FadeOut(200);
			"
		>
			<panel color="white" height="51@" width="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_view_shelves.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
			<instance name="storeViewShelfItem" id="1" align="left" />
			<instance name="storeViewShelfItem" id="2" align="center" x="-0.5h" />
			<instance name="storeViewShelfItem" id="3" align="right" x="-3h" />
			<instance name="storeViewShelfItem" id="4" y="-1.35h" valign="bottom" align="left" />
			<instance name="storeViewShelfItem" id="5" y="-1.35h" valign="bottom" align="center" x="-0.5h" />
			<instance name="storeViewShelfItem" id="6" y="-1.35h" valign="bottom" align="right" x="-3h" />
		</panel>
	</template>

	<template name="vaultItemListShelf">
		<panel width="-30h" height="-14.5h" y="8h" align="right" color="1 1 1 0.1" name="vaultItemViewShelves" x="5%" noclick="true" visible="false"
			onevent0="
				If(
					IsVisible('vaultViewShelfItem1') and _microStore_RequestCode == 2,
					SleepWidget(400, 'DoEvent(2);'),
					SleepWidget(250, 'DoEvent(2);')
				);
			"
			onevent1="
				DoEvent(3);
			"
			onevent2="
				PlaySound('/ui/fe2/store/sounds/vault_open.wav');
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent3="
				PlaySound('/ui/fe2/store/sounds/vault_close.wav');
				SlideX('5%', 250);
				FadeOut(200);
			"
			onevent4="
				If(
					!IsVisible('vaultViewShelfItem1'),
					Split(
						DoEvent(7),
						DoEvent(5)
					),
					Split(
						DoEvent(6),
						SleepWidget(500, 'DoEvent(7); DoEvent(5);')
					)
				);
			"
			onevent5="
				GroupCall('vaultViewShelfItems', 'DoEvent(0);');
			"
			onevent6="
				GroupCall('vaultViewShelfItems', 'DoEvent(1);');
			"
			onevent7="
				Trigger('StoreDeleteCurrentItems', 1500);
				GroupCall('vaultViewShelfItems', 'DoEvent(2);');
				CallEvent('MicroStoreUpgCheck', 0);
			"

		>
			<panel color="white" height="51@" y="-0.1h" width="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_shelves.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="true"/>
			<instance name="vaultViewShelfItem" id="1" y="0.75h" align="left" />
			<instance name="vaultViewShelfItem" id="2" y="0.75h" align="center" x="-0.5h" />
			<instance name="vaultViewShelfItem" id="3" y="0.75h" align="right" x="-3h" />
			<instance name="vaultViewShelfItem" id="4" y="-1.35h" valign="bottom" row_name="bottom" align="left" />
			<instance name="vaultViewShelfItem" id="5" y="-1.35h" valign="bottom" row_name="bottom" align="center" x="-0.5h" />
			<instance name="vaultViewShelfItem" id="6" y="-1.35h" valign="bottom" row_name="bottom" align="right" x="-3h" />			
		</panel>
	</template>

	<template name="storeCoinsDisplay">
		<panel width="28h" x="3h" height="23.5h" noclick="true" y="-13.5h"
			name="storeCoinDisplayChest"
			onevent0="
				If(ui_showCodeRedemption,
					SlideY('7.8h', 250),
					SlideY('10.0h', 250)
				);
			"
			onevent1="
				SlideY('-13.5h', 250);
			"
			onevent2="
				SlideY(0, 250);
			"
		>
			<panel name="microStoreCoinDisplay" noclick="true">
				<panel valign="bottom" width="100%" align="center" height="100@">
					<image valign="top" width="100%" height="50@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coin_display_top.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
					<panel width="60%" height="30@" align="center" y="-6.2h" valign="center">
						<panel y="4.9h" visible="false" watch="MicroStoreUpdateCoins" ontrigger="If(_microStore_TotalCoins gt 0, FadeIn(250), FadeOut(250));" watch2="StoreCoinsLerpTrigger" ontrigger2="
							SetY(
								(
									4.9 -
									(
										If(param gt 450, 450, param) / 450
									) * 4.9
								) # 'h'
							);
						">
							<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coin_display_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
							<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coin_display_glow.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="additive" color="1 1 1 0"
								watch="StoreCoinsLerpTrigger"
								ontrigger="
									SetColor('1 1 1 ' #  ( ( If( If( param lt 400, 400, param ) gt 450, 450, param ) - 400 ) / 75 ) );
								"
							/>
						</panel>
					</panel>
					<image valign="bottom" width="100%" height="100@" ontrigger9lua="
						if GetCvarBool('ui_showCodeRedemption') then
							ResourceManager.RegisterTexture('/ui/fe2/store/coin_display_bottom2.tga', 'store', self)
						else
							ResourceManager.RegisterTexture('/ui/fe2/store/coin_display_bottom.tga', 'store', self)
						end					
						" 
						resourcecontext="store" watch9="MainRegisterTextures" 
					/>
				</panel>
				<panel align="center" width="10.5h" height="5h" y="2h" color="0 0 0 0.6">
					<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="true" />
					<panel width="-0.5h" height="-0.5h" align="center" valign="center" y="-0.25h" noclick="true">
						<panel height="65%">
							<label outline="true" width="-2.5h" textalign="right" textvalign="center" color="#FFCC00" font="dyn_16" shadow="true" content="-" name="microStoreCoinCount" onshow="CreateLerp('StoreCoinsLerp', GoldCoins, 1000, 0, -1);" watch="GoldCoins" ontrigger="CreateLerp('StoreCoinsLerp', GoldCoins, 1000, 0, -1);" watch2="StoreCoinsLerpTrigger" ontrigger2="SetText(FtoA(Ceil(param), 0, 0, ','));" />
							<image align="right" valign="center" width="70@" height="70%" x="-0.15h" y="0.1h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.9" />
							<image align="right" valign="center" width="70@" height="70%" x="-0.25h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />

						</panel>
						<panel height="35%" valign="bottom">
							<label outline="true" width="-2.5h" textalign="right" textvalign="center" color="#c0d5ed" font="dyn_12" shadow="true" content="-" name="microStoreSilverCoinCount" onshow="CreateLerp('StoreSilverCoinsLerp', SilverCoins, 1000, 0, -1);" watch="SilverCoins" ontrigger="CreateLerp('StoreSilverCoinsLerp', SilverCoins, 1000, 0, -1);" watch2="StoreSilverCoinsLerpTrigger" ontrigger2="SetText(FtoA(Ceil(param), 0, 0, ','));" />
							<image align="right" valign="center" width="100@" height="100%" x="-0.15h" y="0.1h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.9" />
							<image align="right" valign="center" width="100@" height="100%" x="-0.25h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
						</panel>


					</panel>
				</panel>
				<instance name="metalButton" buttonName="mstore_front_buycoins_btn" tip_id="mstore_tip_buy_coins" width="13h" x="-0.2h" height="4.25h" valign="center" y="-0.8h" align="center" label="mstore_buycoins" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" font="dyn_14" onclick="Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0); " onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction', 2, true)" />
				<instance name="metalButton" buttonName="mstore_front_redeemcode_btn" tip_id="mstore_tip_redeem_code" width="13h" x="-0.2h" height="2.9h" valign="center" y="3.0h" align="center" label="mstore_redeem_code" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0); SetVisible(ui_showCodeRedemption);" font="dyn_10" onclick="CallEvent('store_popup_redeem_code', 0); " onclicklua="" />
			</panel>
		</panel>
	</template>


	<trigger name="VaultNavigationUpdate" />
	<trigger name="VaultNavigationUpdateEllipsis" />
	<template name="Vault_pageblock_ellipsis">
		<panel x="{x}" y="{y}" valign="bottom" height="3.2h" width="3.2h" align="right" noclick="1" color="invisible" visible="0" onload="BringToFront();"
			watch="VaultNavigationUpdateEllipsis"
			ontrigger="
			If(StringEquals('{id}', param0),
				If(GetX() != (Vault_nav_numButtons-param1) * -1 * GetXFromString('4.0h'), SlideX((Vault_nav_numButtons-param1) * -1 * GetXFromString('4.0h'), 250))
			);
			If(StringEquals('{id}', param0), If(param1 == -1, FadeOut(250), FadeIn(250)));
			"
		>
			<frame texture="/ui/info/button.tga" borderthickness="0.2h" rendermode="grayscale" x="0.2h" y="-0.8h" width="0.7h" height="0.8h" valign="bottom" align="left"/>
			<frame texture="/ui/info/button.tga" borderthickness="0.2h" rendermode="grayscale" y="-0.8h" width="0.7h" height="0.8h" valign="bottom" align="center"/>
			<frame texture="/ui/info/button.tga" borderthickness="0.2h" rendermode="grayscale" x="-0.2h" y="-0.8h" width="0.7h" height="0.8h" valign="bottom" align="right"/>
		</panel>
	</template>
	<template name="Vault_pageblock">
		<panel x="{x}" y="{y}" valign="center" height="3.2h" width="3.2h" align="right" noclick="1"
			watch="VaultNavigationUpdate"
			ontrigger="
			If(
				param2 ge {id} and {id} == param0,
				If(
					(GetX() != (Vault_nav_numButtons-{id}+param4) * -1 * GetXFromString('4.0h')),
					SlideX((Vault_nav_numButtons-{id}+param4) * -1 * GetXFromString('4.0h'), 250)
				)
			);
				If(
					{id} == param0,
					If(
							param1 == -1,
							SetVisible(0),
							SetVisible(1)
					)
				);
			"
		>
			<button color="invisible" onload="BringToFront();"
				watch="VaultNavigationUpdate"
				ontrigger="
					If({id} == param0,
						SetOnClick('
							##Echo(\'Clicked {id}\');##
							##
							Set(\'_microStore_RequestCode\', 1);
							Set(\'_microStore_currentPage\', '#param1#');
							CallEvent(\'MicroStoreAction\', 0);
							##
							Set(\'_microStore_currentPage\', '#param1#');
							Set(\'_microStore_nextAction\', 2);
							CallEvent(\'microStoreProcessResponse\', 0);
							Trigger(\'MicroStoreSetProcTrig\', \'MicroStoreVaultThrottle\');
							Trigger(\'MicroStoreVaultThrottle\', 1);
							Trigger(\'MicroStoreVaultThrottle\', 0);
						')
					);
				"
				watch1="MicroStoreProcessing" ontrigger1="SetEnabled(!param0);"
			>
				<widgetstate statename="up">
					<frame name="vault_page_buttonglow{id}" texture="/ui/frames/squareglow.tga" borderthickness="1.0h" color="#fabf51" width="114%" height="114%" align="center" valign="center" visible="false" />
					<frame texture="/ui/info/button.tga" borderthickness="0.5h" rendermode="grayscale" />
					<frame group="vault_page_button{id}" texture="/ui/info/button_down.tga" borderthickness="0.5h" color="1 1 1 1" visible="0" />
					<frame texture="/ui/frames/roundframe.tga" color="#0c2f37" borderthickness="0.5h" noclick="true"/>
					<frame name="vault_page_buttonframe{id}" texture="/ui/frames/roundframe.tga" color="#00d2ff" borderthickness="0.5h" noclick="true" visible="0" />
					<label textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" watch="VaultNavigationUpdate" content="-"
						ontrigger="
						If({id} == param0, SetText(Round(param1)));
						If({id} == param0, If(this == _microStore_currentPage,
							Split(
								Call('vault_page_buttonframe{id}', 'SetVisible(1);'),
								GroupCall('vault_page_button{id}', 'SetVisible(1);'),
								Call('vault_page_buttonglow{id}', 'SetVisible(1);'),
								SetColor('white'),
								SetFont('dyn_14')
							),
							Split(
								Call('vault_page_buttonframe{id}', 'SetVisible(0);'),
								GroupCall('vault_page_button{id}', 'SetVisible(0);'),
								Call('vault_page_buttonglow{id}', 'SetVisible(0);'),
								SetColor('.8 .8 .8 1'),
								SetFont('dyn_12')
							)
						));
						"
					/>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/squareglow.tga" borderthickness="1.0h" color="#fabf51" width="114%" height="114%" align="center" valign="center" />
					<frame texture="/ui/info/button_over.tga" borderthickness="0.5h" />
					<frame group="vault_page_button{id}" texture="/ui/info/button_down.tga" borderthickness="0.5h" color="1 1 1 1" visible="0" />
					<frame texture="/ui/frames/roundframe.tga" color="#00d2ff" borderthickness="0.5h" noclick="true"/>
					<label textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" watch="VaultNavigationUpdate" content="-"
						ontrigger="
						If({id} == param0, SetText(Round(param1)));
						If({id} == param0, If(this == _microStore_currentPage,
							Split(
								SetColor('white'),
								SetFont('dyn_14')
							),
							Split(
								SetColor('.8 .8 .8 1'),
								SetFont('dyn_12')
							)
						));
						"
					/>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/frames/squareglow.tga" borderthickness="1.0h" color="#fabf51" width="114%" height="114%" align="center" valign="center" />
					<frame texture="/ui/info/button_down.tga" borderthickness="0.5h" color="white"/>
					<frame group="vault_page_button{id}" texture="/ui/info/button_down.tga" borderthickness="0.5h" color="1 1 1 1" visible="0" />
					<frame texture="/ui/frames/roundframe.tga" color="#00d2ff" borderthickness="0.5h" noclick="true"/>
					<label textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" watch="VaultNavigationUpdate" content="-"
						ontrigger="
						If({id} == param0, SetText(Round(param1)));
						If({id} == param0, If(this == _microStore_currentPage,
							Split(
								SetColor('white'),
								SetFont('dyn_14')
							),
							Split(
								SetColor('.8 .8 .8 1'),
								SetFont('dyn_12')
							)
						));
						"
					/>
				</widgetstate>
			</button>
		</panel>
	</template>

	<trigger name="StoreNavigationUpdate" />
	<trigger name="StoreNavigationUpdateEllipsis" />
	<template name="Store_pageblock_ellipsis">
		<panel x="{x}" y="{y}" valign="bottom" height="3.2h" width="3.2h" align="right" noclick="1" color="invisible" visible="0" onload="BringToFront();"
			watch="StoreNavigationUpdateEllipsis"
			ontrigger="
			If(StringEquals('{id}', param0),
				If(GetX() != (store_nav_numButtons-param1) * -1 * GetXFromString('4.0h'), SlideX((store_nav_numButtons-param1) * -1 * GetXFromString('4.0h'), 250))
			);
			If(StringEquals('{id}', param0), If(param1 == -1, FadeOut(250), FadeIn(250)));
			"
		>
			<frame texture="/ui/info/button.tga" borderthickness="0.2h" rendermode="grayscale" x="0.2h" y="-0.8h" width="0.7h" height="0.8h" valign="bottom" align="left"/>
			<frame texture="/ui/info/button.tga" borderthickness="0.2h" rendermode="grayscale" y="-0.8h" width="0.7h" height="0.8h" valign="bottom" align="center"/>
			<frame texture="/ui/info/button.tga" borderthickness="0.2h" rendermode="grayscale" x="-0.2h" y="-0.8h" width="0.7h" height="0.8h" valign="bottom" align="right"/>
		</panel>
	</template>
	<template name="Store_pageblock">
		<panel x="{x}" y="{y}" valign="center" height="3.2h" width="3.2h" align="right" noclick="1"
			watch="StoreNavigationUpdate"
			ontrigger="
			If(
				(param2 ge {id}) and ({id} == param0),
				If(
					(GetX() != (store_nav_numButtons-{id}+param4) * -1 * GetXFromString('4.0h')),
					SlideX((store_nav_numButtons-{id}+param4) * -1 * GetXFromString('4.0h'), 250)
				)
			);
			If(
				{id} == param0,
				If(
					param1 == -1,
					SetVisible(0),
					SetVisible(1)
				)
			);
			"
		>
			<button color="invisible" onload="BringToFront();"
				watch="StoreNavigationUpdate"
				ontrigger="
					If({id} == param0,
						SetOnClick('
							##Echo(\'Clicked {id}\');##
							Set(\'_microStore_RequestCode\', 1);
							Set(\'_microStore_currentPage\', '#param1#');
							CallEvent(\'MicroStoreAction\', 0);
						')
					);
				"
				watch1="MicroStoreProcessing" ontrigger1="SetEnabled(!param0);"
			>
				<widgetstate statename="up">
					<frame name="store_page_buttonglow{id}" texture="/ui/frames/squareglow.tga" borderthickness="1.0h" color="#fabf51" width="114%" height="114%" align="center" valign="center" visible="false" />
					<frame texture="/ui/info/button.tga" borderthickness="0.5h" rendermode="grayscale" />
					<frame group="store_page_button{id}" texture="/ui/info/button_down.tga" borderthickness="0.5h" color="1 1 1 1" visible="0" />
					<frame texture="/ui/frames/roundframe.tga" color="#0c2f37" borderthickness="0.5h" noclick="true"/>
					<frame name="store_page_buttonframe{id}" texture="/ui/frames/roundframe.tga" color="#00d2ff" borderthickness="0.5h" noclick="true" visible="0" />
					<label textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" watch="StoreNavigationUpdate" content="-"
						ontrigger="
						If({id} == param0, SetText(Round(param1)));
						If({id} == param0, If(this == _microStore_currentPage,
							Split(
								Call('store_page_buttonframe{id}', 'SetVisible(1);'),
								GroupCall('store_page_button{id}', 'SetVisible(1);'),
								Call('store_page_buttonglow{id}', 'SetVisible(1);'),
								SetColor('white'),
								SetFont('dyn_14')
							),
							Split(
								Call('store_page_buttonframe{id}', 'SetVisible(0);'),
								GroupCall('store_page_button{id}', 'SetVisible(0);'),
								Call('store_page_buttonglow{id}', 'SetVisible(0);'),
								SetColor('.8 .8 .8 1'),
								SetFont('dyn_12')
							)
						));
						"
					/>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/squareglow.tga" borderthickness="1.0h" color="#fabf51" width="114%" height="114%" align="center" valign="center" />
					<frame texture="/ui/info/button_over.tga" borderthickness="0.5h" />
					<frame group="store_page_button{id}" texture="/ui/info/button_down.tga" borderthickness="0.5h" color="1 1 1 1" visible="0" />
					<frame texture="/ui/frames/roundframe.tga" color="#00d2ff" borderthickness="0.5h" noclick="true"/>
					<label textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" watch="StoreNavigationUpdate" content="-"
						ontrigger="
						If({id} == param0, SetText(Round(param1)));
						If({id} == param0, If(this == _microStore_currentPage,
							Split(
								SetColor('white'),
								SetFont('dyn_14')
							),
							Split(
								SetColor('.8 .8 .8 1'),
								SetFont('dyn_12')
							)
						));
						"
					/>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/frames/squareglow.tga" borderthickness="1.0h" color="#fabf51" width="114%" height="114%" align="center" valign="center" />
					<frame texture="/ui/info/button_down.tga" borderthickness="0.5h" color="white"/>
					<frame group="store_page_button{id}" texture="/ui/info/button_down.tga" borderthickness="0.5h" color="1 1 1 1" visible="0" />
					<frame texture="/ui/frames/roundframe.tga" color="#00d2ff" borderthickness="0.5h" noclick="true"/>
					<label textalign="center" textvalign="center" font="dyn_12" color="white" shadow="true" watch="StoreNavigationUpdate" content="-"
						ontrigger="
						If({id} == param0, SetText(Round(param1)));
						If({id} == param0, If(this == _microStore_currentPage,
							Split(
								SetColor('white'),
								SetFont('dyn_14')
							),
							Split(
								SetColor('.8 .8 .8 1'),
								SetFont('dyn_12')
							)
						));
						"
					/>
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="storePagination" >
		<panel noclick="1"
			onload="
				CreateInt('{store}_nav_targetButton', 0);
				CreateInt('{store}_nav_numButtons', 0);
				CreateInt('{store}_nav_adjacents', 1);
				CreateInt('{store}_for_loop', 1);
			"
			watch="MicroStoreUpdatePaging"
			ontriggerlua="
				local _microStore_TotalPages	= GetCvarNumber('_microStore_TotalPages')
				local _microStore_currentPage	= GetCvarNumber('_microStore_currentPage')

				if _microStore_TotalPages &lt; 10 and _microStore_TotalPages &gt; 0 then
					Set('{store}_nav_numButtons', math.min(9, _microStore_TotalPages))
					Trigger('{store}NavigationUpdateEllipsis', 'A', -1)
					Trigger('{store}NavigationUpdateEllipsis', 'B', -1)
					for i=1, _microStore_TotalPages, 1 do
						if i == _microStore_currentPage then
							Trigger('{store}NavigationUpdate', i, i, _microStore_TotalPages, 1, 0)
						else
							Trigger('{store}NavigationUpdate', i, i, _microStore_TotalPages, 0, 0)
						end
					end
					if _microStore_TotalPages &lt; 9 then
						for i=(_microStore_TotalPages + 1), 9, 1 do
							Trigger('{store}NavigationUpdate', i, -1, _microStore_TotalPages, 0, 0)
						end
					end
				else
					if _microStore_TotalPages &gt;= 10 then
						if _microStore_currentPage &lt;= 4 then
							Set('{store}_nav_numButtons', math.min(7, _microStore_TotalPages))
							Trigger('{store}NavigationUpdate', 1, 1, _microStore_TotalPages, 0, 1)
							Trigger('{store}NavigationUpdate', 2, 2, _microStore_TotalPages, 0, 1)
							Trigger('{store}NavigationUpdateEllipsis', 'A', -1)
							Trigger('{store}NavigationUpdate', 3, 3, _microStore_TotalPages, 0, 1)
							Trigger('{store}NavigationUpdate', 4, 4, _microStore_TotalPages, 0, 1)
							Trigger('{store}NavigationUpdate', 5, 5, _microStore_TotalPages, 0, 1)
							Trigger('{store}NavigationUpdateEllipsis', 'B', 5)
							Trigger('{store}NavigationUpdate', 6, _microStore_TotalPages - 1, _microStore_TotalPages, 0, 0)
							Trigger('{store}NavigationUpdate', 7, _microStore_TotalPages, _microStore_TotalPages, 0, 0)
						else
							if _microStore_currentPage &lt;= (_microStore_TotalPages - (2 + (GetCvarNumber('{store}_nav_adjacents') * 2))) then
								Set('{store}_nav_numButtons', math.min(7, _microStore_TotalPages))
								Trigger('{store}NavigationUpdate', 1, 1, _microStore_TotalPages, 0, 2)
								Trigger('{store}NavigationUpdate', 2, 2, _microStore_TotalPages, 0, 2)

								if math.ceil((_microStore_currentPage / 2) - 1) &gt; 2 then
									Trigger('{store}NavigationUpdate', 2, math.ceil( _microStore_currentPage - (_microStore_currentPage / 2)), _microStore_TotalPages, 0, 2)
								else
									Trigger('{store}NavigationUpdate', 2, 2, _microStore_TotalPages, 0, 2)
								end

								Trigger('{store}NavigationUpdateEllipsis', 'A', 1)

								for i=3,5,1 do
									if i == 4 then
										Trigger('{store}NavigationUpdate', i, _microStore_currentPage, _microStore_TotalPages, 1, 1)
									elseif i &lt; 4 then
										Trigger('{store}NavigationUpdate', i, _microStore_currentPage - 1, _microStore_TotalPages, 0, 1)
									else
										Trigger('{store}NavigationUpdate', i, _microStore_currentPage + 1, _microStore_TotalPages, 0, 1)
									end
								end

								Trigger('{store}NavigationUpdateEllipsis', 'B', 5)
								Trigger('{store}NavigationUpdate', 6, _microStore_TotalPages - 1, _microStore_TotalPages, 0, 0)

								if false and math.floor(((_microStore_TotalPages - _microStore_currentPage) / 2 ) + _microStore_currentPage) &lt; (_microStore_TotalPages - 1) then
									Trigger('{store}NavigationUpdate', 6, math.floor(((_microStore_TotalPages - _microStore_currentPage) / 2 ) + _microStore_currentPage), _microStore_TotalPages, 0, 0)
								elseif false then
									Trigger('{store}NavigationUpdate', 6, _microStore_TotalPages - 1, _microStore_TotalPages, 0, 0)
								end

								Trigger('{store}NavigationUpdate', 7, _microStore_TotalPages, _microStore_TotalPages, 0, 0)
							else
								Set('{store}_nav_numButtons', math.min(7, _microStore_TotalPages))
								Trigger('{store}NavigationUpdate', 1, 1, _microStore_TotalPages, 0, 1)
								Trigger('{store}NavigationUpdate', 2, 2, _microStore_TotalPages, 0, 1)
								Trigger('{store}NavigationUpdateEllipsis', 'A', 2)
								Trigger('{store}NavigationUpdate', 3, _microStore_TotalPages - 4, _microStore_TotalPages, 0, 0)
								Trigger('{store}NavigationUpdate', 4, _microStore_TotalPages - 3, _microStore_TotalPages, 0, 0)
								Trigger('{store}NavigationUpdate', 5, _microStore_TotalPages - 2, _microStore_TotalPages, 0, 0)
								Trigger('{store}NavigationUpdateEllipsis', 'B', -1)
								Trigger('{store}NavigationUpdate', 6, _microStore_TotalPages - 1, _microStore_TotalPages, 0, 0)
								Trigger('{store}NavigationUpdate', 7, _microStore_TotalPages, _microStore_TotalPages, 0, 0)
							end
						end
					end
				end
			"
		/>
		<panel valign="center" align="right" height="4.5h" padding="0.5h" color="invisible" noclick="1" >
			<panel noclick="1" x="0" y="0" align="right" >

				<instance name="{store}_pageblock" id="9" x="0" y="0" />
				<instance name="{store}_pageblock" id="8" x="0" y="0" />

				<instance name="{store}_pageblock" id="7" x="0" y="0" />
				<instance name="{store}_pageblock" id="6" x="0" y="0" />

				<instance name="{store}_pageblock" id="5" x="0" y="0" />
				<instance name="{store}_pageblock" id="4" x="0" y="0" />
				<instance name="{store}_pageblock" id="3" x="0" y="0" />

				<instance name="{store}_pageblock" id="2" x="0" y="0" />
				<instance name="{store}_pageblock" id="1" x="0" y="0" />
				<instance name="{store}_pageblock_ellipsis" id="B" x="0" y="0" watch="{store}NavigationUpdateEllipsis" color="green" />
				<instance name="{store}_pageblock_ellipsis" id="A" x="0" y="0" watch="{store}NavigationUpdateEllipsis" color="yellow" />
			</panel>
		</panel>
	</template>

	<template name="storeNavigation">
		<panel width="-30h" height="6.5h" align="right" valign="bottom" color="1 1 1 0.25" noclick="true" name="storeNavigationContainer" visible="false" x="5%"
			onevent0="
				SleepWidget(250, 'DoEvent(2);');
			"
			onevent1="
				DoEvent(3);
			"
			onevent2="
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent3="
				SlideX('5%', 250);
				FadeOut(200);
			"
		>
			<image noclick="true" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/navigation_backer.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" height="12.5@" width="100%"/>
			<panel noclick="true">
				<panel align="left" height="4.5h" valign="bottom" y="-1h" grow="true" float="right" padding="0.5h" x="1h">
					<panel grow="true" visible="true" height="100%" float="right" padding="0.5h" sticky="true" stickytoinvis="false"
						watch="MicroStoreUpdateCategory"
						ontrigger="
							If(
								_microStore_Category == 59 or _microStore_Category == 60 or _microStore_Category == 61 or _microStore_Category == 4,
								FadeIn(250),
								FadeOut(250)
							);
						"
					>
						<instance name="categoryTab" tip_id="mstore_tip_category59" category_id="59" width="8h" height="100%" label="mstore_category59"/>
						<instance name="categoryTab" tip_id="mstore_tip_category60" category_id="60" width="13h" height="100%" label="mstore_category60"/>
						<!--<instance name="categoryTab" tip_id="mstore_tip_category61" category_id="61" width="10h" height="100%" label="mstore_category61"/>-->

					</panel>

					<panel width="15h" height="100%" sticky="true" stickytoinvis="false">

						<panel height="3.5h" valign="center" color="0 0 0 0.5" visible="false"
							watch="MicroStoreUpdateCategory"
							ontrigger="
								If(
									WidgetExists('mstore_tip_ext_' # If(_microStore_Category == 59 or _microStore_Category == 60 or _microStore_Category == 61, 4, _microStore_Category)),
									FadeIn(250),
									FadeOut(250)
								);
							"
							>
							<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="true" />
							<label textalign="center" textvalign="center" color="white" shadow="true" font="dyn_10" content="mstore_sectionhelp" width="-2.5h"/>
							<button
								color="invisible"
								onmouseover="
									If(
										WidgetExists(
											'mstore_tip_ext_' # If(_microStore_Category == 59 or _microStore_Category == 60 or _microStore_Category == 61, 4, _microStore_Category)
										),
										ShowWidget(
											'mstore_tip_ext_' # If(_microStore_Category == 59 or _microStore_Category == 60 or _microStore_Category == 61, 4, _microStore_Category)
										)
									);
									PlaySound('/shared/sounds/ui/button_over_01.wav');
								"
								width="2.3h" height="2.3h" x="-0.5h" valign="center" align="right"
								onmouseout="
									If(
										WidgetExists(
											'mstore_tip_ext_' # If(_microStore_Category == 59 or _microStore_Category == 60 or _microStore_Category == 61, 4, _microStore_Category)
										),
										HideWidget(
											'mstore_tip_ext_' # If(_microStore_Category == 59 or _microStore_Category == 60 or _microStore_Category == 61, 4, _microStore_Category)
										)
									);
								"
							>
								<widgetstate statename="up">
									<image width="100%" height="100%" valign="center" align="center" texture="/ui/elements/tip_mark_up.tga" />
								</widgetstate>
								<widgetstate statename="over">
									<image width="100%" height="100%" valign="center" align="center" texture="/ui/elements/tip_mark_over.tga" />
								</widgetstate>
							</button>
						</panel>
					</panel>
					<panel width="16h" sticky="true" stickytoinvis="false">
						<panel align="center" height="4.5h" valign="bottom" watch="MicroStoreProcessing" ontrigger="
							If(
								param0,
								SetVisible(true),
								FadeOut(350)
							);
							">
							<panel color="0 0 0 0.5">
								<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="true" />
								<label color="white" shadow="true" font="dyn_11" textvalign="center" textalign="center" width="-3h" content="mstore_processing_elipses" />
								<animatedimage texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" align="right" width="3h" height="3h" valign="center" x="-0.25h" />
							</panel>
						</panel>
					</panel>
				</panel>

				<panel align="right" height="4.5h" valign="bottom" y="-1h" grow="true" float="right" padding="0.5h" x="-2.0h" noclick="1">
					<panel width="15h" visible="false" watch="MicroStoreUpdatePaging" ontrigger="If(_microStore_TotalPages gt 1, FadeIn(250), FadeOut(250));" >
						<instance name="storePagination" store="Store" />
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

