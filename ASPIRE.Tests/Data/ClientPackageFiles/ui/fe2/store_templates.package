	<template name="vaultNavigationContainer">
		<panel width="-30h" height="6.5h" align="right" valign="bottom" color="1 1 1 0.25" noclick="true" name="vaultNavigationContainer" x="5%" visible="false"
			onevent0="
				SleepWidget(250, 'DoEvent(2);');
			"
			onevent1="
				DoEvent(3);
			"
			onevent2="
				SlideX(0, 250);
				FadeIn(200);
			"
			onevent3="
				SlideX('5%', 250);
				FadeOut(200);
			"
		>
			<image noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/vault_navigation_backer.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" height="12.5@" width="100%"/>
			<panel noclick="true">
				<panel align="left" height="4.5h" valign="bottom" y="-1h" grow="true" float="right" padding="0.5h" x="1h">
					<panel width="15h" height="100%" sticky="true" stickytoinvis="false">
						<panel height="3.5h" valign="center" color="0 0 0 0.5" visible="false"
							watch="MicroStoreUpdateCategory"
							ontrigger="
								If(
									WidgetExists('mstore_tip_ext_' # _microStore_Category),
									FadeIn(250),
									FadeOut(250)
								);
							"
							>
							<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="true" />
							<label textalign="center" textvalign="center" color="white" shadow="true" font="dyn_10" content="mstore_sectionhelp" width="-2.5h"/>
							<button
								color="invisible"
								onmouseover="
									If(
										WidgetExists('mstore_tip_ext_' # _microStore_Category),
										ShowWidget('mstore_tip_ext_' # _microStore_Category)
									);
									PlaySound('/shared/sounds/ui/button_over_01.wav');
								"
								width="2.3h" height="2.3h" x="-0.5h" valign="center" align="right"
								onmouseout="
									If(
										WidgetExists('mstore_tip_ext_' # _microStore_Category),
										HideWidget('mstore_tip_ext_' # _microStore_Category)
									);
								"
							>
								<widgetstate statename="up">
									<image width="100%" height="100%" valign="center" align="center" texture="/ui/elements/tip_mark_up.tga" />
								</widgetstate>

								<widgetstate statename="over">
									<image width="100%" height="100%" valign="center" align="center" texture="/ui/elements/tip_mark_over.tga" />
								</widgetstate>
							</button>
						</panel>
					</panel>
					<panel width="16h">
						<panel align="center" height="4.5h" valign="bottom" watch="MicroStoreProcessing" ontrigger="
							If(
								param0,
								SetVisible(true),
								FadeOut(350)
							);
							">
							<panel color="0 0 0 0.5">
								<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="true" />
								<label color="white" shadow="true" font="dyn_11" textvalign="center" textalign="center" width="-3h" content="mstore_processing_elipses" />
								<animatedimage texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" align="right" width="3h" height="3h" valign="center" x="-0.25h" />
							</panel>
						</panel>
					</panel>
				</panel>
				<panel align="right" height="4.5h" valign="bottom" y="-1h"  grow="true" float="right" padding="0.5h" x="-1h">
					<panel width="15h" visible="false" watch="MicroStoreUpdatePaging" ontrigger="If(_microStore_TotalPages gt 1, FadeIn(250), FadeOut(250));">
						<instance name="storePagination" store="Vault" />
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storeMainProcessingIndicator">
		<panel width="-30h" noclick="true" align="right" valign="center" color="invisible"><!-- Central processing indicator for when there isn't a store view. -->
			<panel height="4.5h" align="center" valign="center" width="16h" watch="MicroStoreProcessing" ontrigger="
				If(
					param0 and _microStore_RequestCode == 0,
					SetVisible(true),
					FadeOut(350)
				);
				">
				<panel color="0 0 0 0.5">
					<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="true" />
					<label color="white" shadow="true" font="dyn_11" textvalign="center" textalign="center" width="-3h" content="mstore_processing_elipses" />
					<animatedimage texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" align="right" width="3h" height="3h" valign="center" x="-0.25h" />
				</panel>
			</panel>
		</panel>
	</template>

	<!-- Effectively temporary until it's recreated in individual views -->
	<template name="storeMainCloseButton">
		<button
			x="-1.5h"
			y="1.5h"
			width="1.7h" height="1.7h"
			align="right"
			valign="top"
			color="invisible"
			onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav');"
			onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'store_container', nil, false)"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
			"
			watch="MicroStoreProcessing"
			ontrigger="
				If(
					param0,
					SetEnabled(0),
					SetEnabled(1)
				);
			"
		>
			<widgetstate statename="up">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
				<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
			</widgetstate>
			<widgetstate statename="over">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
				<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
				<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
			</widgetstate>
			<widgetstate statename="disabled">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#999999" blockinput="false" rendermode="grayscale" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" rendermode="grayscale" noclick="true"/>
				<image width="1.3h" height="1.3h" align="center" valign="center" color="#AAAAAA" texture="/ui/elements/closex.tga" noclick="true" />
			</widgetstate>
		</button>
	</template>

	<template name="storeMiscOverlays">
		<panel height="50h" y="2.5h" visible="false" name="store_popup_container" noclick="true">


			<panel width="124.8h" align="center" noclick="true">
				<button width="13h" height="24.5h" x="11h" y="-0.5h" valign="bottom" color="invisible"
				name="shopkeeper_model_action"
				onclick="
					Trigger('ShopkeeperAction', 16);

					If(
						_microStore_RequestCode == 0,
						Split(
							Set('_microStore_Category', 7),
							Set('_microStore_currentPage', 1),
							Set('_microStore_RequestCode', 1),
							CallEvent('MicroStoreAction', 0)
						),
						Split(
							Set('_microStore_RequestCode', 0),
							Set('_MicroStore_Category', 1),
							CallEvent('MicroStoreAction', 0)
						)
					);
				"
				onload="
					CreateBool('_microStore_shopkeeper_canIdle', false);
					CreateInt('_microStore_shopkeeperIdleAnim');
				"
				onevent0="
					Set('_microStore_shopkeeper_canIdle', true);
					SleepWidget(300000, 'DoEvent(1);');
				"
				watch1="ShopkeeperIdleRoutine"
				ontrigger1="
					Set('_microStore_shopkeeper_canIdle', true);
					SleepWidget(param1, 'CallEventParamsX(\'shopkeeper_model_action\', 1, '# param0 #');');
				"
				onevent1="
					If(
						_microStore_shopkeeper_canIdle and IsVisible('shopkeeper_model') and !_dancingIsForbidden,
						Split(
							Trigger('ShopkeeperAction', param0),
							If(
								param0 == 5,
								Set('_microStore_shopkeeper_canIdle', false),
								Trigger('ShopkeeperIdleRoutine', 5, 300000)
							)
						)
					);
				"
				onevent2="
					Set('_microStore_shopkeeper_canIdle', false);
				"
				watch="MicroStoreProcessing"
				ontrigger="SetEnabled(!param0);"
				>
					<widgetstate statename="up">
						<panel/>
					</widgetstate>
					<widgetstate statename="over">
						<panel/>
					</widgetstate>
					<widgetstate statename="down">
						<panel/>
					</widgetstate>
					<widgetstate statename="disabled">
						<panel/>
					</widgetstate>
				</button>
			</panel>

			<instance name="storeEAPDisplay"/>
			<instance name="storeFeatured"/>

			<!-- Has to be lowest popup (not even really a popup, but alas!) -->
			<instance name="plankWindow" width="95h" x="15h" id="buy_coins" title="mstore_buycoins_form_title" content="storePopupBuyCoinsForm" show_close="true" debug="false" onshow="Trigger('MicroStoreUpdatePackages'); Trigger('ShopkeeperAction', 21); ##Set('_microStore_buyCoins_package', 3); GroupCall('_microStore_buyCoins_package_radio_group', 'SetButtonState(0);'); Call('microStorePackageButton3', 'SetButtonState(1);');## Call('buy_coins_forfriend', 'SetSelectedItemByValue(1);');"
				onhide="
					If(
						_microStoreFirstVisit, CallEvent('store_container', 2),
						If(
							!IsVisible(_microStoreViewPanel1) and
							!IsVisible(_microStoreViewPanel2) and
							!IsVisible(_microStoreViewPanel3) and
							!IsVisible(_microStoreViewPanel4) and
							!IsVisible(_microStoreViewPanel5) and
							!IsVisible(_microStoreViewPanel6) and
							!IsVisible('store_promo'),
							Split(
								Set('_microStore_RequestCode', 0),
								Set('_microStore_Category', -1),
								CallEvent('MicroStoreAction', 0)
							)
						)
					);
				"
			/>
			<if condition="!cl_GarenaEnable">
				<instance name="plankWindow" width="45h" id="sub_account" title="web_form_subaccount_title" content="storePopupSubAccountForm" show_close="true" debug="false"/>
			</if>
			<instance name="plankWindow" width="45h" id="reset_stats" title="mstore_resetstats_form_title" content="storePopupResetStatsForm" show_close="true" debug="false"/>
			<instance name="plankWindow" width="49.5h" id="name_change" title="mstore_nickchange_form_title" content="storePopupNameChangeForm" show_close="true" debug="false"/>
			<instance name="store_avatars"/>
			<instance name="plankWindow" width="45h" id="bundle_preview" title="mstore_bundlepreview" content="storePopupBundlePreview" show_close="true" regrow="true" titlewatch="MicroStoreBundlePreview" titleontrigger="SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_name'));"/>
			<instance name="plankWindow" width="35h" id="voice_preview" title="mstore_voicepreview" content="storePopupVoicePreview" show_close="true" regrow="true" titlewatch="MicroStoreVoicePreview" titleontrigger="SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_name'));"/>
			<instance name="plankWindow" width="53h" id="confirm_purchase_choose" title="mstore_buyitem_confirm" content="storePopupConfirmPurchaseChoose" show_close="true" debug="false" regrow="true" onhide="Call('mstore_confirmpurchase_altbundlebox', 'SetButtonState(0);');"/>
			<instance name="plankWindow" width="53h" id="confirm_purchase_gift"   title="mstore_buygift_confirm" content="storePopupConfirmGiftChoose" show_close="true" debug="false" regrow="true" onhide=""/>
			<instance name="plankWindow" width="50h" id="firstvisit1" title="mstore_firstvisit1" content="storePopupFirstVisit1" show_close="false" debug="false" onshow="Trigger('ShopkeeperAction', 1);"/>
			<instance name="plankWindow" width="50h" id="firstvisit3" title="mstore_firstvisit3" content="storePopupFirstVisit3" show_close="false" debug="false"/>
			<instance name="plankWindow" width="50h" id="firstvisit2" title="mstore_firstvisit2" content="storePopupFirstVisit2" show_close="false" debug="false" onshow="Trigger('ShopkeeperAction', 2);"/>
			<instance name="plankWindow" width="35h" id="form_error" title="mstore_error_generic" content="storePopupFormError" show_close="true" debug="false" regrow="true"/>
			<instance name="plankWindow" width="35h" id="error" title="mstore_error_generic" content="storePopupError" show_close="true" regrow="true" debug="false"/>
			<instance name="plankWindow" width="50h" id="buy_coin_friend_success" title="mstore_buycoin_friend_success" content="storePopupBuyCoinFriendSuccess" show_close="true" debug="false" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="buy_coin_success_account" title="mstore_buycoin_success" content="storePopupBuyCoinSuccessAccount" show_close="true" debug="false" onshow="PlaySound('/ui/fe2/store/sounds/coin_jingle_4.wav');" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="buy_coin_success_upgrade" title="mstore_buycoin_success" content="storePopupBuyCoinSuccessUpgrade" show_close="true" debug="false" onshow="PlaySound('/ui/fe2/store/sounds/coin_jingle_4.wav');" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="buy_coin_success" title="mstore_buycoin_success" content="storePopupBuyCoinSuccess" show_close="true" debug="false" onshow="PlaySound('/ui/fe2/store/sounds/coin_jingle_4.wav');" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="resetstats_success" title="web_form_resetstats_success_title" content="storePopupResetStatsSuccess" show_close="true" debug="false" onshow="If( _microStore_RequestCode != 2, Set('_microStore_RequestCode', 1) ); CallEvent('MicroStoreAction', 0);"/>
			<instance name="plankWindow" width="50h" id="namechange_success" title="web_form_nickchange_success_title" content="storePopupNameChangeSuccess" show_close="true" debug="false" onshow="If( _microStore_RequestCode != 2, Set('_microStore_RequestCode', 1) ); CallEvent('MicroStoreAction', 0);"/>
			<instance name="plankWindow" width="50h" id="SubAccount_success" title="web_form_subaccount_success_title" content="storePopupSubAccountSuccess" show_close="true" debug="false" onshow="If( _microStore_RequestCode != 2, Set('_microStore_RequestCode', 1) ); CallEvent('MicroStoreAction', 0);"/>
			<instance name="plankWindow" width="50h" id="selectupgrade_success" title="mstore_selectupgrade_success" content="storePopupSelectUpgradeSuccess" show_close="true" debug="false"/>
			<instance name="plankWindow" width="50h" id="buy_item_success" title="mstore_buyitem_success" content="storePopupBuyItemSuccess" show_close="true" debug="false"
				onshow="PlaySound('/ui/fe2/store/sounds/chaching.wav');"
				onhide="CallEvent('microStoreProcessResponse', 0);"
				onhidelua="
							if(NotEmpty(GetCvarString('microStoreDiscountInfo'))) then
								UIManager.GetInterface('main'):HoNStoreF('DisplayAvatarList')
							end
						"
			/>
			<instance name="plankWindow" width="40h" id="buyavatar_needhero" title="mstore_buyavatar_needhero" content="storePopupBuyAvatarNeedHero" show_close="true" debug="false"/>			
			<instance name="plankWindow" width="49.5h" id="redeem_code" title="mstore_redeem_code" content="storePopupRedeemCodeForm" show_close="true" debug="false" onhide=""/>

			<panel width="124.8h" align="center" noclick="true" name="shopkeeperContainer">
				<instance name="shopkeeper"/><!-- Gotta be here so he's not covered up by the darkened background on popups -->
			</panel>

			<panel name="arcade_messages" width="80h" height="30h" y="0h" align="center" color="invisible" noclick="1">
				<modelpanel
					name="store_arcade_messages_model"
					resourcecontext="store"
					visible="0"
					noclick="true"
					anim="idle"
					cameradistance="0"
					lookat="false"
					camerapos="0 1300 0"
					cameraangles="0 0 180"
					camerafov="50"
					cameranear="1"
					carmerafar="5000"
					depthclear="true"
					depthcompress="true"
					sunazimuth="-90"
					sunaltitude="180"
					suncolor="1 1 1"
					scenebuffer="1"
					watch="PreviewAnnouncerText"
					ontrigger="
						SetModel('/ui/common/models/' # param # '.mdf');
						SetVisible(true);
						SetAnim('idle');
						SetEffect('/ui/common/models/' # SubString(param, 0, SearchString(param, '/', 0)) # '/bloodlust.effect');
						SleepWidget(3200, 'SetVisible(false);');
					"			
				/>								
			</panel>

			<panel name="store_grab_bag_container" height="50h" width="178h" align="center" noclick="1"/>
		</panel>
	</template>

</package>
