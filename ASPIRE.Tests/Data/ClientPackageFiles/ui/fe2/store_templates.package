			color="invisible"
			visible="{visible=true}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			onload="{onload}"
		>
			<widgetstate statename="up" x="{x=0}" y="{y=0}">
				<instance name="metalPlateImage" rendermode="{rendermode=normal}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}"/>
				<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center">
					<instance name="metalButtonImage" rendermode="{rendermode=normal}"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{highlight=false}"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="{darken=false}"/>
					<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.60" height="65%" width="-40@" align="center" valign="center" />
					<panel grow="true" height="86%" align="center" valign="center" float="right" padding="0.1h">
						<!-- Vault Image
							- If new, openVaultNew.tga
						-->
						<panel width="100@" height="100%">
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultEmpty.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(!_microStore_vaultHighlight);" />
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultNew.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" visible="false" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(_microStore_vaultHighlight);" />
						</panel>
						<label fitx="true" fitxpadding="0.6h" textvalign="center" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="over" x="{x=0}" y="{y=0}">
				<instance name="metalPlateImage" rendermode="{rendermode=normal}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}"/>
				<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center">
					<instance name="metalButtonImage" rendermode="{rendermode=normal}"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="true"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="{darken=false}"/>
					<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.60" height="65%" width="-40@" align="center" valign="center" />
					<panel grow="true" height="86%" align="center" valign="center" float="right" padding="0.1h">
						<!-- Vault Image
							- If new, openVaultNew.tga
						-->
						<panel width="100@" height="100%">
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultEmpty.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(!_microStore_vaultHighlight);" />
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultNew.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" visible="false" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(_microStore_vaultHighlight);" />
						</panel>
						<label fitx="true" fitxpadding="0.6h" textvalign="center" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="down" x="{x=0}" y="{y=0}">
				<instance name="metalPlateImage" rendermode="{rendermode=normal}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}"/>
				<panel width="{buttonwidth=-28@}" height="{buttonheight=-28%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center">
					<instance name="metalButtonImage" rendermode="{rendermode=normal}"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{highlight=false}"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="true"/>
					<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.60" height="65%" width="-40@" align="center" valign="center" />
					<panel grow="true" height="86%" align="center" valign="center" float="right" padding="0.1h">
						<!-- Vault Image
							- If new, openVaultNew.tga
						-->
						<panel width="100@" height="100%">
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultEmpty.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(!_microStore_vaultHighlight);" />
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultNew.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" visible="false" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(_microStore_vaultHighlight);" />
						</panel>

						<label fitx="true" fitxpadding="0.6h" textvalign="center" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="disabled" x="{x=0}" y="{y=0}">
				<instance name="metalPlateImage" rendermode="grayscale"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}"/>
				<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center">
					<instance name="metalButtonImage" rendermode="grayscale"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{highlight=false}"/>
					<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="true"/>
					<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.60" height="65%" width="-40@" align="center" valign="center" />
					<panel grow="true" height="86%" align="center" valign="center" float="right" padding="0.1h">
						<!-- Vault Image
							- If new, openVaultNew.tga
						-->
						<panel width="100@" height="100%">
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultEmpty.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(!_microStore_vaultHighlight);" />
							<image group="store_vault_images" color="white" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/openVaultNew.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="100@" height="100%" visible="false" watch="MicroStoreUpdateCategory" ontrigger="SetVisible(_microStore_vaultHighlight);" />
						</panel>

						<label fitx="true" fitxpadding="0.6h" textvalign="center" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
