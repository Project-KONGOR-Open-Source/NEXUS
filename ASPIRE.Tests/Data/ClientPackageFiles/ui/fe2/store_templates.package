	<template name="form_radiobutton_stateimage">
		<panel width="{size}" color="invisible">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness=".75h" color="white"/>
			<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness=".8h"/>
			<panel hmargin="0.15h" vmargin="0.15h" visible="{checked}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="-0.55h" color="#3abde7"/>
			</panel>
		</panel>
		<label width="-{size}" height="100%" textvalign="center" font="{font}" color="{color}" shadow="{shadow=true}">{label}</label>
	</template>

	<template name="form_radiobutton_stateimage_nolabel">
		<panel width="{size}" height="{size}" color="invisible">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness=".75h" color="white"/>
			<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness=".8h"/>
			<panel hmargin="0.15h" vmargin="0.15h" visible="{checked}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="-0.55h" color="#3abde7"/>
			</panel>
		</panel>
	</template>

	<template name="form_radiobutton_state">
		<widgetstate statename="{state}" float="right" padding="3%">
			<instance name="{displaytemplate}" size="{size}" checked="{checked}" label="{label}" color="{color=white}" shadow="{shadow=true}" state="{state}"/>
		</widgetstate>
	</template>

	<template name="form_radiobutton">
		<panel width="{width=90%}" height="{height=1.5h}" align="{align}" valign="{valign}" noclick="true" color="invisible" onload="{onpreload=}" visible="{visible=1}" group="{group}" >
			<button
				color="invisible"
				numstates="2"
				onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/shared/sounds/ui/button_click_06.wav'); Set('{cvar=}', '{value=}'); GroupCall('{cvar=}_radio_group', 'SetButtonState(0);'); SetButtonState(1); If(!StringEmpty('{updatetrigger}'), Trigger('{updatetrigger}')); {onclick=}"
				onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onload="SetButtonState({default_state=0}); {onload=}"
				name="{radiobutton_name=}"
				group="{cvar=}_radio_group"
				oninstantiate="{oninstantiate=}"
			>
				<instance name="form_radiobutton_state" state="up" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="white" checked="false" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="over" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="false" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="down" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="false" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="up2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#ffaa00" checked="true" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="over2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="true" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="down2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="true" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="disabled" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#888888" cvar="{cvar=}" checked="false" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="disabled2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#888888" cvar="{cvar=}" checked="true" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
			</button>
		</panel>
	</template>

	<template name="magnifierButtonState">
		<widgetstate statename="{state}" x="{x}" y="{y}">
			<image texture="/ui/common/new_shop_interface/magnify.tga" color="0.6 0.6 0.6 1" rendermode="additive" visible="{over=false}"/>
			<image texture="/ui/common/new_shop_interface/magnify.tga" rendermode="{rendermode=}" color="1 1 1 1"/>
		</widgetstate>
	</template>

	<template name="magnifierButton">
		<button
			color="invisible"
			onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/shared/sounds/ui/button_click_06.wav'); {onclick=}"
			onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
			watch="{watch=}"
			enabled="{enabled=true}"
			ontrigger="{ontrigger=}"
			onevent0="{onevent0}"
			onload="{onload=}"
			name="{button_name=}"
			oninstantiate="{oninstantiate=}"
			align="{align}"	valign="{valign}"
			width="{width}" height="{height}"
			x="{x}" y="{y}"
		>
			<instance name="magnifierButtonState" state="up"/>
			<instance name="magnifierButtonState" state="over" over="true"/>
			<instance name="magnifierButtonState" state="down" color="0.65 0.65 0.65 1" x="1" y="1"/>
			<instance name="magnifierButtonState" state="disabled" rendermode="grayscale"/>
		</button>
	</template>

	<template name="paperform_checkbox_state">
		<widgetstate statename="{state}" float="right" padding="3%">
			<panel width="{size}" color="invisible">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#eedcb4"/>
				<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
				<image hmargin="0.15h" vmargin="0.15h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/closex2.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="#644526" visible="{checked}" />
			</panel>
			<label width="-{size}" height="100%" textvalign="center" font="{font}" color="{color=#774515}">{label}</label>
		</widgetstate>
	</template>

	<!-- v2 accepts cvars that are declared in the UI (by skipping the cvar property of buttons and doing the work manually)  -->
	<template name="form_checkbox2">
		<panel width="{width=100%}" height="{height=1.5h}" align="{align=}" valign="{valign=}" noclick="true" color="invisible" onload="{onpreload=}" visible="{visible=1}" >
			<button
				color="invisible"
				numstates="2"
				onclick="
					If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
					If(
						!StringEmpty('{cvar=}'),
						If(
							VarExists('{cvar=}'),
							If(
								{cvar=true},
								Split(
									Set('{cvar=}', false),
									SetButtonState(0)
								),
								Split(
									Set('{cvar=}', true),
									SetButtonState(1)
								)
							)
						)
					);
					If(
						!StringEmpty('{updatetrigger=}'),
						Trigger('{updatetrigger=}')
					);
					PlaySound('/shared/sounds/ui/button_click_06.wav'); {onclick=}
				"
				onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onload="{onload=}"
				name="{checkbox_name=}"
				group="{checkbox_group=}"
				oninstantiate="{oninstantiate=}"
			>
				<instance name="{state_template=paperform_checkbox_state}" state="up" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" checked="false"/>
				<instance name="{state_template=paperform_checkbox_state}" state="over" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#9d5b1a" checked="false"/>
				<instance name="{state_template=paperform_checkbox_state}" state="down" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" checked="false"/>
				<instance name="{state_template=paperform_checkbox_state}" state="up2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" checked="true"/>
				<instance name="{state_template=paperform_checkbox_state}" state="over2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#9d5b1a" checked="true"/>
				<instance name="{state_template=paperform_checkbox_state}" state="down2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" checked="true"/>

				<instance name="{state_template=paperform_checkbox_state}" state="disabled" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#888888" checked="false"/>
				<instance name="{state_template=paperform_checkbox_state}" state="disabled2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#888888" checked="true"/>
			</button>
		</panel>
	</template>

	<template name="paperform_combobox_state">
		<widgetstate statename="{state}">
			<panel color="invisible" onmouseover="PlaySound('/shared/sounds/ui/button_over_02.wav');">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4"/>
			<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
				<image x="-0.05h" width="100@" height="100%" align="right" valign="center" texture="/ui/info/combobox_button_{image}.tga" />
			</panel>
		</widgetstate>
	</template>

	<template name="paperform_combobox_item">
		<label height="100%" x="50@" font="dyn_9" color="#774515" textvalign="center" content="{label}"/>
	</template>
	
	<template name="paperform_combobox_item_goldsilvercost">
		<panel height="100%" x="50@" font="dyn_9" width="-3.5h" y="0.25h">
			<label font="dyn_9" color="#774515" textvalign="center" content="{label}" width="-6h"/>
			<panel align="right" width="5.5h" x="-5.5h" visible="{showSilver=true}">
				<label font="dyn_9" textalign="center" outline="true" outlinecolor="#2d1d0d" color="#c0d5ed" textvalign="center" content="{silverCost=-}" width="-100@"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/silver_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.5" x="0.1h" y="0.1h"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/silver_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			</panel>
			<panel align="right" width="5.5h">
				<label font="dyn_9" textalign="center" outline="true" color="#FFCC00" outlinecolor="#2d1d0d" textvalign="center" content="{goldCost=-}" width="-100@"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/gold_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.5" x="0.1h" y="0.1h"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/gold_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
			</panel>
		</panel>
	</template>

	<template name="paperform_combobox">
		<combobox
			name="{id}"
			x="{x}"
			width="{width}"
			height="{height=100%}"
			align="{align=right}"
			valign="{valign=center}"
			color="invisible"
			itemwidth="{itemwidth=100%}"
			itemheight="2h"
			maxlistheight="{maxlistheight}"
			cvar="{cvar=}"
			exteriorscrollbars="false"
			scrolltexture="/ui/info/combobox.tga"
			handleheight="100@" handlewidth="100%"
			scrollbarsize="2h"
			scrollbaroffset="0"
			highlight="under"
			highlightcolor="invisible"
			highlightbordercolor="invisible"
			onload="ComboBoxCmd('clear'); {populate=}; {data=}('{displaytemplate=paperform_combobox_item}'); {onload=}"
			onselect="PlaySound('/shared/sounds/ui/button_click_05.wav'); {onselect=}"
			onselectlua="{onselectlua=}"
			onshow="{onshow=}"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_02.wav');"
			watch="{watch=}"
			ontrigger="{ontrigger=}"
			visible="{visible=true}"
			form="{form=}" data="{formdata=}"
			watch0="{watch0=}"
			ontrigger0="{ontrigger0=}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			onevent="{onevent=}"
		>
			<instance name="paperform_combobox_state" state="up" color="1 1 1 1" image="up"/>
			<instance name="paperform_combobox_state" state="over" color="#69ccff" image="over"/>
			<instance name="paperform_combobox_state" state="down" color="#69ccff" image="over"/>
			<widgetstate statename="listbg">
				<panel height="+1.5h" y="-0.75h">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4"/>
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
				</panel>
			</widgetstate>
			<widgetstate statename="itembg">
				<panel width="{itemwidth}" />
			</widgetstate>
			<widgetstate statename="itemhighlight">
				<panel width="{itemwidth=100%}">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.25h" color="#fff2d6"/>
					<frame texture="/ui/frames/roundframe.tga" color="#774515" borderthickness="0.25h"/>
				</panel>
			</widgetstate>
		</combobox>
	</template>

	<template name="paperForm_combobox_container">
		<panel y="{y=0}" align="center" valign="{valign=center}" height="{height=2.5h}" float="right" onload="{onload}">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="dyn_11" color="{labelColor=red}" shadow="{labelShadow=false}" outline="{labelOutline=false}" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}" outlinecolor="{labelOutlineColor}"
				onevent0="SetColor('#8e0000');"
				onevent1="SetColor('{labelColor=#774515}');"
				onload="DoEvent(1);"
			/>
			<panel width="5%" height="100%" valign="center">
				<image align="right" width="1.2h" height="1.0h" valign="center" color="0 0 0 0.75" texture="/ui/info/arrow.tga" visible="{arrowShadow=false}" x="0.1h" y="0.1h" />
				<image align="right" width="1.2h" height="1.0h" valign="center" color="{arrowColor=#774515}" texture="/ui/info/arrow.tga" />
			</panel>
			<panel width="{fieldwidth=55%}" height="100%" valign="center">
				<instance name="paperform_combobox" onshow="{onshow}" onevent="{onevent}" id="{id}" x="0" width="100%" itemwidth="100%" maxlistheight="{maxlistheight=10}" cvar="{cvar}" data="{data}" onselect="If(!StringEmpty('{updatetrigger}'), Trigger('{updatetrigger}')); {onselect}" populate="{populate}" watch="{boxwatch}" ontrigger="{boxontrigger}" watch1="{boxwatch1}" ontrigger1="{boxontrigger1}" watch0="{boxwatch0}" ontrigger0="{boxontrigger0}" onselectlua="{onselectlua}" />
			</panel>
			<panel width="2.4h" height="100%" valign="center" visible="{hastip}">
				<instance name="tip_mark" tip_id="{tip_id}" width="2.3h" height="2.3h" valign="center" align="right" onmouseover="{tipmouseover}" onmouseout="{tipmouseout}"/>
			</panel>
		</panel>
	</template>
	
	<!-- Simplified Combobox - Has no option for tooltip -->
	<template name="paperForm_combobox_simple_container">
		<panel y="{y=0}" align="center" valign="{valign=center}" height="{height=2.5h}" float="right" onload="{onload}">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="dyn_11" color="{labelColor=white}" shadow="{labelShadow=false}" outline="{labelOutline=false}" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}" outlinecolor="{labelOutlineColor}"
				onevent0="SetColor('#8e0000');"
				onevent1="SetColor('{labelColor=#774515}');"
				onload="DoEvent(1);"
			/>
			<panel width="{fieldwidth=55%}" height="100%" valign="center">
				<instance name="paperform_combobox" onshow="{onshow}" onevent="{onevent}" id="{id}" x="0" width="100%" itemwidth="100%" maxlistheight="{maxlistheight=10}" cvar="{cvar}" data="{data}" onselect="If(!StringEmpty('{updatetrigger}'), Trigger('{updatetrigger}')); {onselect}" populate="{populate}" watch="{boxwatch}" ontrigger="{boxontrigger}" watch1="{boxwatch1}" ontrigger1="{boxontrigger1}" watch0="{boxwatch0}" ontrigger0="{boxontrigger0}" onselectlua="{onselectlua}" />
			</panel>
		</panel>
	</template>
	
	<template name="paperForm_expdate_container">
		<panel y="{y}" align="center" valign="{valign}" width="{width}" height="{height=2.5h}" float="right">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="dyn_11" color="#774515" shadow="false" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}"
				onevent0="SetColor('#8e0000');"
				onevent1="SetColor('#774515');"
			/>
			<panel width="5%" height="100%" valign="center">
				<image align="right" width="1.2h" height="1.0h" valign="center" color="#774515" texture="/ui/info/arrow.tga" />
			</panel>
			<panel width="{fieldwidth=55%}" height="100%" valign="center">
				<panel>
					<panel width="45%">
						<label height="100%" textvalign="center" font="dyn_10" color="#774515" shadow="false" content="creditcard_label_prime_month" watch="{updatetrigger}" ontrigger="{ontrigger}"
							onevent0="SetColor('#8e0000');"
							onevent1="SetColor('#774515');"
							onload="DoEvent(1);"
						/>
						<instance
							name="paperform_combobox"
							id="{varprefix}_ccmonth"
							align="right" width="50%" itemwidth="100%" maxlistheight="5"
							onshow="ListBoxCmd('Select 0');"
							onselect="Trigger('UpdatePurchaseCoinsForm');"
							populate="
								AddTemplateListItem('paperform_combobox_item', '01', 'label', '01');
								AddTemplateListItem('paperform_combobox_item', '02', 'label', '02');
								AddTemplateListItem('paperform_combobox_item', '03', 'label', '03');
								AddTemplateListItem('paperform_combobox_item', '04', 'label', '04');
								AddTemplateListItem('paperform_combobox_item', '05', 'label', '05');
								AddTemplateListItem('paperform_combobox_item', '06', 'label', '06');
								AddTemplateListItem('paperform_combobox_item', '07', 'label', '07');
								AddTemplateListItem('paperform_combobox_item', '08', 'label', '08');
								AddTemplateListItem('paperform_combobox_item', '09', 'label', '09');
								AddTemplateListItem('paperform_combobox_item', '10', 'label', '10');
								AddTemplateListItem('paperform_combobox_item', '11', 'label', '11');
								AddTemplateListItem('paperform_combobox_item', '12', 'label', '12');
								"
							form="" formdata="month"
						/>
					</panel>
					<panel align="right" width="50%">
						<label height="100%" textvalign="center" font="dyn_10" color="#774515" shadow="false" content="creditcard_label_prime_year" watch="{updatetrigger}" ontrigger="{ontrigger}"
							onevent0="SetColor('#8e0000');"
							onevent1="SetColor('#774515');"
							onload="DoEvent(1);"
						/>
						<instance
							name="paperform_combobox"
							id="{varprefix}_ccyear"
							align="right" width="60%" itemwidth="100%" maxlistheight="5"
							onshow="ListBoxCmd('Select 0');"
							onselect="Trigger('UpdatePurchaseCoinsForm');"
							populate="
								for(
									GetYear(),GetYear() + 25,1,
									'
										AddTemplateListItem(\'paperform_combobox_item\', iParam, \'label\', iParam);
									'
								);
							"
							form="" formdata="year"
						/>
					</panel>
				</panel>
			</panel>
			<panel width="2.4h" height="100%" valign="center" visible="{hastip}">
				<instance name="tip_mark" tip_id="{tip_id}" width="2.3h" height="2.3h" valign="center" align="right" />
			</panel>
		</panel>
	</template>

	<template name="paperForm_textbox">
		<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#4f2b0033"/>
		<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
		<textbox
			name="{widgetname}"
			taborder="{order}"
			passwordchar="{passchar=}"
			maxlength="{maxlength=-1}"
			y="{y=0.3h}"
			width="{width=-1.0h}"
			align="{align=center}"
			x="{x=0}"
			color="invisible"
			font="{font=dyn_9}"
			textcolor="#774515"
			shadow="true"
			onchange="{onchange}"
			onshow="{onshow}"
			onhide="{onhide}"
			onfocus="{onfocus}"
			onlosefocus="{onlosefocus}"
			form="{form=}"
			data="{data=}"
			wrap="{wrap=}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			onenter="{onenter}"
			onesc="{onesc}"
		/>
	</template>

	<template name="paperForm_textbox_container">
		<panel y="{y}" align="center" valign="{valign}" width="{width}" height="{height=2.5h}" float="right" noclick="true">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="dyn_11" color="white" shadow="false" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}" noclick="true"
				onevent0="SetColor('#8e0000');"
				onevent1="SetColor('#774515');"
				onload="DoEvent(1); {onload=}"
			/>
			<panel width="5%" height="100%" valign="center" noclick="true" visible="{showarrow=true}">
				<image align="right" width="1.2h" height="1.0h" valign="center" color="#774515" texture="/ui/info/arrow.tga" noclick="true" />
			</panel>
			<panel width="{fieldwidth=55%}" height="100%" valign="center" noclick="true">
				<instance name="paperForm_textbox" wrap="{wrap=}" onhide="{onhide}" font="{font=dyn_10}" align="{field_align=center}" x="{field_xoffset=0}" width="{field_width=-1h}" widgetname="{fieldname}" order="{order}" onchange="{onchange} Trigger('{updatetrigger}');" passchar="{passchar=}" maxlength="{maxlength=-1}" form="{form=}" data="{data=}" onfocus="{onfocus}" onlosefocus="{onlosefocus}" watch="{textboxwatch}" ontrigger="{textboxontrigger}" watch2="{textboxwatch2}" ontrigger2="{textboxontrigger2}" onesc="{onesc}"/>
			</panel>
			<panel width="2.4h" height="100%" valign="center" visible="{hastip}" noclick="true">
				<instance name="tip_mark" tip_id="{tip_id}" width="2.3h" height="2.3h" valign="center" align="right" />
			</panel>
		</panel>
	</template>

	<!-- ============================= BUTTONS AND TABS =============================  -->

	<template name="mstore_btn_closex">
		<button
			x="{x}" y="{y}" width="{width}" height="{height}" align="{align}" valign="{valign}"
			color="invisible" visible="{visible=true}"
			name="{button_name}"
			onshowlua="{onshowlua}"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_03.wav'); If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}'));"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
			interactive="false"
			onclicklua="PlaySound('/shared/sounds/ui/button_click_03.wav') {onclicklua}"
			onclick="{onclick}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
		>
			<instance name="mstore_btn_closex_state" statename="up" color="#910000"/>
			<instance name="mstore_btn_closex_state" statename="over" color="#dc0000" xcolor="1 1 1 1" />
			<instance name="mstore_btn_closex_state" statename="down" x="1" y="1" xcolor="1 1 1 1" />
			<instance name="mstore_btn_closex_state" statename="disabled" color="#777777"/>
		</button>
	</template>

	<template name="mstore_btn_closex_state">
		<widgetstate statename="{statename}" x="{x}" y="{y}">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="{color=#910000}" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
			<image width="1.3h" height="1.3h" align="center" valign="center" color="{xcolor=.75 .75 .75 1}" texture="/ui/elements/closex.tga" noclick="true" />
		</widgetstate>
	</template>
	
	<template name="store_metal_panel_bg1">
		<panel valign="bottom" height="85%" y="3%">
			<panel color="{color=1 1 1 1}" valign="bottom" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_tab_center.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" align="center" width="-150@" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale(GetHeight() / 2 # 'p'); SetVScale(GetHeight() # 'p');" height="200%"/>
			<image color="{color=1 1 1 1}" valign="bottom" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_tab_left.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" height="200%" width="100@" align="left"/>
			<image color="{color=1 1 1 1}" valign="bottom" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_tab_right.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"  height="200%" width="100@" align="right"/>
			<image color="{color=1 1 1 1}" valign="top" y="-63%" align="center" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/store_tab_connector.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" width="75@" height="75%"/>
		</panel>
	</template>

	<template name="vaultCategoryTabwidgetstate">
		<widgetstate statename="{statename}" x="{x=0}" y="{y=0}">
			<instance name="metalPlateImage" rendermode="{rendermode=normal}"/>
			<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}"/>
			<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center">
				<instance name="metalButtonImage" rendermode="{rendermode=normal}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{highlight=false}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="{darken=false}"/>
				<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.60" height="65%" width="-40@" align="center" valign="center" />
				<label align="center" textvalign="center" textalign="{textalign=center}" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
			</panel>
		</widgetstate>
	</template>

	<template name="vaultCategoryTab">
		<button width="{width=9.3h}" height="{height=}" color="invisible" group="MicroStore_Tabs"
			numstates="2"
			onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
			onclick="
				If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
				PlaySound('/ui/fe2/store/sounds/metalbutton_click.wav');
				Set('_microStore_currentPage', 1);
				If(
					_microStore_Category != {category_id},
					Set('_microStore_Category', {category_id})
				);
				Set('_microStore_nextAction', 2);
				CallEvent('microStoreProcessResponse', 0);
				Trigger('MicroStoreSetProcTrig', 'MicroStoreVaultThrottle');
				Trigger('MicroStoreVaultThrottle', 1);
				Trigger('MicroStoreVaultThrottle', 0);
				{onclick}
			"
			watch="MicroStoreUpdateCategory" ontrigger="
			If(
				_microStore_nextAction == 2,
				If(
					_microStore_Category == {category_id=1},
					SetButtonState(1),
					SetButtonState(0)
				)
			);
			"
			watch1="MicroStoreProcessing"
			ontrigger1="SetEnabled(!param0);"
			onrightclick="
				If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
				PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav');
				Set('_microStore_currentPage', 1);
				If(
					_microStore_Category != {category_id},
					Set('_microStore_Category', {category_id})
				);
				Set('_microStore_RequestCode', 1);
				CallEvent('MicroStoreAction', 0);
			"
			onload="{onload}"
		>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.8 0.9 0.8 1}" label="{label}" statename="up"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.8 0.9 0.8 1}" label="{label}" statename="over" highlight="true"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.8 0.9 0.8 1}" label="{label}" statename="down" buttonwidth="-28@" buttonheight="-28%" darken="true"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.7 0.7 0.7 1}" label="{label}" statename="disabled" rendermode="grayscale"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.8 0.9 0.8 1}" label="{label}" statename="up2" selected="true"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.8 0.9 0.8 1}" label="{label}" statename="over2" selected="true" highlight="true"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.8 0.9 0.8 1}" label="{label}" statename="down2" selected="true" buttonwidth="-28@" buttonheight="-28%" darken="true"/>
			<instance name="vaultCategoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.7 0.7 0.7 1}" label="{label}" statename="disabled2" selected="true" rendermode="grayscale"/>
		</button>
	</template>

	<template name="categoryTabwidgetstate">
		<widgetstate statename="{statename}" x="{x=0}" y="{y=0}">
			<instance name="metalPlateImage" rendermode="{rendermode=normal}"/>
			<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{selected=false}"/>
			<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center">
				<instance name="woodButtonImage" rendermode="{rendermode=normal}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" visible="{highlight=false}"/>
				<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.15" borderthickness="0.3h" visible="{darken=false}"/>
				<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.6" height="65%" width="-40@" align="center" valign="center" />
				<label align="center" textvalign="center" wrap="true" textalign="{textalign=center}" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
			</panel>
		</widgetstate>
	</template>

	<template name="categoryTab">
		<button width="{width=9.3h}" height="{height=}" color="invisible" group="MicroStore_Tabs" name="{buttonName}"
			enabled="{enabled=true}"
			numstates="2"
			onclick="
				If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
				PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav');
				Set('_microStore_currentPage', 1);
				If(
					_microStore_Category != {category_id},
					Set('_microStore_Category', {category_id})
				);
				Set('_microStore_RequestCode', 1);
				CallEvent('MicroStoreAction', 0);
				{onclick}
			"
			onclicklua="{onclicklua}"
			watch="MicroStoreUpdateCategory" ontrigger="
			If(
				_microStore_nextAction == 1,
				If(
					_microStore_Category == {category_id=1},
					SetButtonState(1),
					SetButtonState(0)
				)
			);
			"
			watch1="MicroStoreProcessing"
			ontrigger1="If({enabled=true}, SetEnabled(!param0));"
			onmouseover="
				If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}'));
				PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
				If(
					!StringEmpty('{idleAnim}'),
					Trigger('ShopkeeperIdleRoutine', {idleAnim=-1}, 5000)
				);
			"
			onmouseout="
				If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
				If(
					!StringEmpty('{idleAnim}'),
					Trigger('ShopkeeperIdleRoutine', 5, 300000)
				);
			"
			onrightclick="
				If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
				PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav');


				If(
					{category_id} != 2 and {category_id} != 58 and {category_id} != 71 and {category_id} != 7,
					DoEvent(3)
				);

			"
			onevent3="
				Set('_microStore_currentPage', 1);
				If(
					_microStore_Category != {category_id},
					Set('_microStore_Category', {category_id})
				);
				If(
					_microStore_Category == 1 or _microStore_Category == 7,
					Set('_microStore_Category', 3)
				);
				Set('_microStore_RequestCode', 2);
				CallEvent('MicroStoreAction', 0);
			"
			onload="{onload}"
		>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=#ffd200}" label="{label}" statename="up"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=#ffd200}" label="{label}" statename="over" highlight="true"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=#ffd200}" label="{label}" statename="down" buttonwidth="-28@" buttonheight="-28%" darken="true"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.7 0.7 0.7 1}" label="{label}" statename="disabled" rendermode="grayscale"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=#ffd200}" label="{label}" statename="up2" selected="true"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=#ffd200}" label="{label}" statename="over2" selected="true" highlight="true"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=#ffd200}" label="{label}" statename="down2" selected="true" buttonwidth="-28@" buttonheight="-28%" darken="true"/>
			<instance name="categoryTabwidgetstate" font="{font=dyn_10}" labelColor="{labelColor=0.7 0.7 0.7 1}" label="{label}" statename="disabled2" selected="true" rendermode="grayscale"/>
		</button>
	</template>

	<template name="plateButtonWidgetState">
		<panel>
			<instance name="metalPlateImage"/>
			<label y="-1%" align="center" textvalign="center" textalign="{textalign=center}" color="{labelColor=white}" shadow="{labelShadow=true}" font="{font=dyn_10}" content="{label}"/>
		</panel>
	</template>

	<!-- Metal Plate Tab/Button -->
	<template name="plateButton">
		<button
			name="{buttonName}"
			width="{width=100%}"
			height="{height=100%}"
			align="{align=left}"
			valign="{valign=top}"
			x="{x}"
			y="{y}"
			onclick="{onclick}"
			color="invisible"
			visible="{visible=true}"
		>
			<widgetstate statename="up">
				<instance name="plateButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}"/>
			</widgetstate>
			<widgetstate statename="over">
				<instance name="plateButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}" bgcolor="1 1 1 .4"/>
			</widgetstate>
			<widgetstate statename="down" x=".1h" y=".1h">
				<instance name="plateButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}"/>
			</widgetstate>
			<widgetstate statename="disabled" rendermode="grayscale">
				<instance name="plateButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}"/>
			</widgetstate>
		</button>
	</template>

	<template name="metalButtonImage">
		<frame texture="/ui/frames/rounded_bg_white.tga" color="0 0 0 0.5" borderthickness="0.3h" x="0.2h" y="0.2h"/>
		<panel color="white" align="center" rendermode="{rendermode=normal}" width="-50@" utile="true" vtile="true" uscale="64p" vscale="64p" onload="SetUScale((GetHeight() * 2) # 'p'); SetVScale(GetHeight() # 'p');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/metal_button_center.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
		<image align="left" height="100%" width="50@" rendermode="{rendermode=normal}" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/metal_button_left.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
		<image align="right" height="100%" width="50@" rendermode="{rendermode=normal}" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/metal_button_right.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
	</template>

