	<!-- ============================= STORE-SPECIFIC FUNCTIONALITY =============================  -->

	<template name="storeItemDataContainer">
		<panel noclick="true" color="invisible" group="storeItemDataContainers" name="storeItemDataContainer{index}"
			onload="
				DoEvent(0);
			"
			watch=""
			ontrigger=""
			onevent0="
				CreateInt('microStoreID{index}', -1);
				CreateString('microStoreName{index}', '-1');
				CreateString('microStoreDescription{index}', '-1');
				CreateString('microStoreWebContent{index}', '-1');
				CreateString('microStoreLocalContent{index}', '-1');
				CreateBool('microStoreBundle{index}', false);
				CreateBool('microStorePurchasable{index}', true);
				CreateString('microStoreCharges{index}', '-1~-1~-1~-1~-1~-1~-1');
				CreateString('microStoreDurations{index}', '-1~-1~-1~-1~-1~-1~-1');
				CreateBool('microStoreAlreadyOwned{index}', false);
				CreateInt('microStorePrice{index}', -1);
				CreateInt('microStoreSilverPrice{index}', -1);
				CreateBool('microStorePremium{index}', false);
				CreateInt('microStoreQuantity{index}', -1);
				CreateString('microStoreCode{index}', -1);
				CreateString('microStoreChargeRemaining{index}', -1);
				CreateString('microStoreSubBundles{index}', '-1~-1~-1~-1~-1');
				CreateInt('microStoreSpecialDisplay{index}', '-1');
			"
		/>
	</template>

	<instance name="storeItemDataContainer" index="1"/>
	<instance name="storeItemDataContainer" index="2"/>
	<instance name="storeItemDataContainer" index="3"/>
	<instance name="storeItemDataContainer" index="4"/>
	<instance name="storeItemDataContainer" index="5"/>
	<instance name="storeItemDataContainer" index="6"/>
	<instance name="storeItemDataContainer" index="7"/>
	<instance name="storeItemDataContainer" index="8"/>
	<instance name="storeItemDataContainer" index="9"/>
	<instance name="storeItemDataContainer" index="10"/>
	<instance name="storeItemDataContainer" index="11"/>
	<instance name="storeItemDataContainer" index="12"/>
	<instance name="storeItemDataContainer" index="13"/>
	<instance name="storeItemDataContainer" index="14"/>
	<instance name="storeItemDataContainer" index="15"/>
	<instance name="storeItemDataContainer" index="16"/>
	<instance name="storeItemDataContainer" index="17"/>
	<instance name="storeItemDataContainer" index="18"/>
	<instance name="storeItemDataContainer" index="999"/><!-- Just a dummy slot for use in popups/etc. -->

	<panel name="vaultRedeemHelper161" noclick="true" color="invisible" watch="vaultConfigureProduct" ontrigger="If(param0 == 161, CallEvent('store_popup_name_change', 0));"/>
	<if condition="!cl_garenaEnable">
		<panel name="vaultRedeemHelper162" noclick="true" color="invisible" watch="vaultConfigureProduct" ontrigger="If(param0 == 162, CallEvent('store_popup_sub_account', 0));"/>
		<panel name="vaultRedeemHelper163" noclick="true" color="invisible" watch="vaultConfigureProduct" ontrigger="If(param0 == 163, CallEvent('store_popup_reset_stats', 0));"/>
		<!--<panel name="vaultRedeemHelper492" noclick="true" color="invisible" watch="vaultConfigureProduct" ontrigger="If(param0 == 492, CallEvent('storeMulligans', 2));"/>-->
	</if>

	<!-- This one will probably change with its product ID. -->
	<if condition="cl_garenaEnable">
		<panel name="vaultRedeemHelper163" noclick="true" color="invisible" watch="vaultConfigureProduct" ontrigger="If(param0 == 163, CallEvent('store_popup_reset_stats', 0));"/>
	</if>

	<!-- ============================= SHOPKEEPER AND ACTIONS =============================  -->

	<template name="shopkeeper">
		<!-- His panel needs to be somewhat large so he has a lot of breathing room -->
		<panel width="30h" valign="bottom" height="30h" noclick="true">
			<modelpanel
				ontrigger9lua="ResourceManager.RegisterModel('/ui/fe2/store/goblin/model.mdf', 'store', self)" resourcecontext="store" watch9="MainRegisterModels"
				visible="1"
				noclick="true"
				anim="idle"
				name="shopkeeper_model"
				camerapos="-13 -125 5"
				cameraangles="0 0 0"
				modelangles="0 0 170"
				camerafov="25"
				cameranear="1"
				carmerafar="100"
				depthclear="true"
				depthcompress="true"
				sunazimuth="180"
				sunaltitude="50"
				suncolor="1 1 1"
				ambientcolor="0.8 0.8 0.8"
				scenebuffer="1"
			/>
		</panel>
	</template>

	<trigger name="ShopkeeperAction"/>
	<trigger name="ShopkeeperIdleRoutine"/><!-- anim number, delay -->


	<panel noclick="true" color="invisible"
		watch="ShopkeeperAction"
		ontrigger="
			If( param0 == 1, Trigger( 'ShopkeeperAnimation', 1 ) );
			If( param0 == 2, Trigger( 'ShopkeeperAnimation', 2 ) );
			If( param0 == 3, Trigger( 'ShopkeeperAnimation', 3 ) );
			If( param0 == 4, Trigger( 'ShopkeeperAnimation', Rand(4, 6) ) );
			If( param0 == 5, Trigger( 'ShopkeeperAnimation', 7 ) );
			If( param0 == 6, Trigger( 'ShopkeeperAnimation', Rand(8, 9) ) );
			If( param0 == 7, Trigger( 'ShopkeeperAnimation', Rand(10, 11) ) );
			If( param0 == 8, Trigger( 'ShopkeeperAnimation', 12 ) );
			If( param0 == 9, Trigger( 'ShopkeeperAnimation', Rand(13, 14) ) );
			If( param0 == 10, Trigger( 'ShopkeeperAnimation', Rand(15, 16) ) );
			If( param0 == 11, Trigger( 'ShopkeeperAnimation', Rand(17, 18) ) );
			If( param0 == 12, Trigger( 'ShopkeeperAnimation', Rand(19, 20) ) );
			If( param0 == 13, Trigger( 'ShopkeeperAnimation', 21 ) );
			If( param0 == 14, Trigger( 'ShopkeeperAnimation', 22 ) );
			If( param0 == 15, Trigger( 'ShopkeeperAnimation', Rand(23, 24) ) );
			If( param0 == 16, Trigger( 'ShopkeeperAnimation', Rand(25, 26) ) );
			If( param0 == 18, Trigger( 'ShopkeeperAnimation', 9 ) );

			If(
				param0 == 19,
				Set('_microStore_tempInt', Rand(1, 2))
			);

			If(
				param0 == 19,
				Split(
					If(_microStore_tempInt == 1, Trigger( 'ShopkeeperAnimation', 22 )),
					If(_microStore_tempInt == 2, Trigger( 'ShopkeeperAnimation', 24 ))
				)
			);

			If(
				param0 == 20,
				Set('_microStore_tempInt', Rand(1, 3))
			);

			If(
				param0 == 20,
				Split(
					If(_microStore_tempInt == 1, Trigger( 'ShopkeeperAnimation', 19 )),
					If(_microStore_tempInt == 2, Trigger( 'ShopkeeperAnimation', 20 )),
					If(_microStore_tempInt == 3, Trigger( 'ShopkeeperAnimation', 23 ))
				)
			);
			If( param0 == 21, Trigger( 'ShopkeeperAnimation', 14 ) );

			## Mulligan Shopkeeper ##
			##
			If( param0 == 31, Trigger( 'ShopkeeperAnimation', Rand(31, 31) ) );
			If( param0 == 32, Trigger( 'ShopkeeperAnimation', Rand(32, 32) ) );
			If( param0 == 33, Trigger( 'ShopkeeperAnimation', Rand(33, 33) ) );
			##
			
			If( param0 == 41, Trigger( 'ShopkeeperAnimation', Rand(17, 18) ) );
			If( param0 == 42, Trigger( 'ShopkeeperAnimation', 16 ) );
			If( param0 == 43, Trigger( 'ShopkeeperAnimation', 15 ) );
			If( param0 == 44, Trigger( 'ShopkeeperAnimation', 13 ) );
			If( param0 == 45, Trigger( 'ShopkeeperAnimation', 14 ) );
	" />

	<trigger name="ShopkeeperAnimation"/>
	<panel noclick="true" color="invisible"
		onload="
			CreateInt('Shopkeeper_LastAnimTime', GetTime());
			CreateInt('Shopkeeper_LastAnimDuration', -1);
			CreateInt('Shopkeeper_LastAction', -1);
			CreateBool('Shopkeeper_LastActionCanSkip', false);
			CreateBool('Shopkeeper_ActionsEnabled', true);
		"
	/>

	<template name="ShopkeeperAnimationHelper">
		<panel noclick="true" color="invisible" watch="ShopkeeperAnimation"
			ontrigger="
				If(
					{ActionID} == param0 and Shopkeeper_ActionsEnabled and
					(
						(Shopkeeper_LastAnimTime + Shopkeeper_LastAnimDuration) lt GetTime()
						or
						Shopkeeper_LastActionCanSkip
					),
					Split(
						StopSound(2),
						Call('{shopkeeper=shopkeeper_model}', 'SetAnim(\'{AnimName}\');'),
						PlaySound('{SoundPath}', 1, 2)
					)
				);
			"
		/>
	</template>

	<!-- Welcome to shop... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="1" AnimName="first_time_1" SoundPath="/ui/fe2/store/goblin/voice//first_time_1.mp3" Duration="" />
	<!-- Before you can buy, exchange money for coins... first time, special offers -->
	<instance name="ShopkeeperAnimationHelper" ActionID="2" AnimName="first_time_2" SoundPath="/ui/fe2/store/goblin/voice//first_time_2.mp3" Duration="" />
	<!-- See you again soon -->
	<instance name="ShopkeeperAnimationHelper" ActionID="3" AnimName="goodbye" SoundPath="/ui/fe2/store/goblin/voice//goodbye.mp3" Duration="" />
	<!-- Welcome back, what can I interest you in? -->
	<instance name="ShopkeeperAnimationHelper" ActionID="4" AnimName="enter_1" SoundPath="/ui/fe2/store/goblin/voice//enter_1.mp3" Duration="" />
	<!-- Come in, come in! -->
	<instance name="ShopkeeperAnimationHelper" ActionID="5" AnimName="enter_2" SoundPath="/ui/fe2/store/goblin/voice//enter_2.mp3" Duration="" />
	<!-- Ah, it's you again.  What can I do for you? -->
	<instance name="ShopkeeperAnimationHelper" ActionID="6" AnimName="enter_3" SoundPath="/ui/fe2/store/goblin/voice//enter_3.mp3" Duration="" />
	<!-- Humming and wandering around... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="7" AnimName="browsing" SoundPath="" Duration="" />
	<!-- Let's go check your storage... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="9" AnimName="check_storage" SoundPath="/ui/fe2/store/goblin/voice//check_storage.mp3" Duration="" />
	<!-- There you are.  I just got a new shipment in ... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="10" AnimName="first_entrance_after_patch_1" SoundPath="/ui/fe2/store/goblin/voice//first_entrance_after_patch_1.mp3" Duration="" />
	<!-- I've been waiting for you, take a look at the new items... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="11" AnimName="first_entrance_after_patch_2" SoundPath="/ui/fe2/store/goblin/voice//first_entrance_after_patch_2.mp3" Duration="" />
	<!-- I've just put some new items up for sale... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="12" AnimName="congratulations" SoundPath="/ui/fe2/store/goblin/voice//congratulations.mp3" Duration="" />
	<!-- Smart shopper -->
	<instance name="ShopkeeperAnimationHelper" ActionID="13" AnimName="point_purchase_1" SoundPath="/ui/fe2/store/goblin/voice//point_purchase_1.mp3" Duration="" />
	<!-- Only the best -->
	<instance name="ShopkeeperAnimationHelper" ActionID="14" AnimName="point_purchase_2" SoundPath="/ui/fe2/store/goblin/voice//point_purchase_2.mp3" Duration="" />
	<!-- Good deal... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="15" AnimName="point_purchase_3" SoundPath="/ui/fe2/store/goblin/voice//point_purchase_3.mp3" Duration="" />
	<!-- Better deals... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="16" AnimName="point_purchase_4" SoundPath="/ui/fe2/store/goblin/voice//point_purchase_4.mp3" Duration="" />
	<!-- Fine and all, consider better deals... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="17" AnimName="point_purchase_5" SoundPath="/ui/fe2/store/goblin/voice//point_purchase_5.mp3" Duration="" />
	<!-- Other packages come with extra coins... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="18" AnimName="point_purchase_6" SoundPath="/ui/fe2/store/goblin/voice//point_purchase_6.mp3" Duration="" />
	<!-- Never pass up a good deal -->
	<instance name="ShopkeeperAnimationHelper" ActionID="19" AnimName="purchasing_1" SoundPath="/ui/fe2/store/goblin/voice//purchasing_1.mp3" Duration="" />
	<!-- Purchase you'll never regret -->
	<instance name="ShopkeeperAnimationHelper" ActionID="20" AnimName="purchasing_2" SoundPath="/ui/fe2/store/goblin/voice//purchasing_2.mp3" Duration="" />
	<!-- Certain? Take a look at these... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="21" AnimName="purchasing_3" SoundPath="/ui/fe2/store/goblin/voice//purchasing_3.mp3" Duration="" />
	<!-- Good buy indeed... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="22" AnimName="purchasing_4" SoundPath="/ui/fe2/store/goblin/voice//purchasing_4.mp3" Duration="" />
	<!-- Lucky while still on sale... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="23" AnimName="purchasing_5" SoundPath="/ui/fe2/store/goblin/voice//purchasing_5.mp3" Duration="" />
	<!-- Pleasure doing business (and receives coins visually) -->
	<instance name="ShopkeeperAnimationHelper" ActionID="24" AnimName="purchasing_6" SoundPath="/ui/fe2/store/goblin/voice//purchasing_6.mp3" Duration="" />
	<!-- Most valued customers, I'll give you recommendations... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="25" AnimName="purchasing_7" SoundPath="/ui/fe2/store/goblin/voice//purchasing_7.mp3" Duration="" />
	<!-- Twisted my arm, show one of the best deals right now... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="26" AnimName="purchasing_8" SoundPath="/ui/fe2/store/goblin/voice//purchasing_8.mp3" Duration="" />

	<!-- Mulligan Animations
	<instance name="ShopkeeperAnimationHelper" ActionID="31" AnimName="purchasing_8" SoundPath="/ui/fe2/store/goblin/voice//purchasing_8.mp3" Duration="" shopkeeper="shopkeeper_model_mulligan" />
	<instance name="ShopkeeperAnimationHelper" ActionID="32" AnimName="purchasing_8" SoundPath="/ui/fe2/store/goblin/voice//purchasing_8.mp3" Duration="" shopkeeper="shopkeeper_model_mulligan" />
	<instance name="ShopkeeperAnimationHelper" ActionID="33" AnimName="purchasing_8" SoundPath="/ui/fe2/store/goblin/voice//purchasing_8.mp3" Duration="" shopkeeper="shopkeeper_model_mulligan" />
	 -->
	<!-- ============================= FORM ELEMENTS (PAPER STYLE) =============================  -->

	<!-- lat versions, they have 4 choices, tweaked dupes of the NA/EU ones -->
	<!-- lat version -->
	<template name="paperform_radiobutton_5_state1_lat">
	
		<!-- $5 -->
		<panel width="12.165h">	

			<!-- Non Button Area -->
			<panel height="-3h">
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#836352" borderthickness="0.5h" />				
				<!-- Selected BG Color -->
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#cd8b0f" borderthickness="0.5h" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );" />
				<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h" />				
				<!-- Package Amount -->
				<panel height="3.0h">
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#4f1b02" borderthickness="0.5h" />
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h" />
					<panel grow="true" height="74%" valign="center" align="center" float="right" padding="0.5h">
						<label fitx="true" height="100%" font="dyn_14" textvalign="center" color="1 1 1 1" outline="true" content="---" watch="MicroStoreUpdatePackages" ontrigger="SetText(microStorePackageCoins1);" /> 
						<image height="100%" width="100@" valign="center" texture="/ui/fe2/store/gold_coins.tga" />
					</panel>
				</panel>
				<!-- Package Contents -->
				<panel height="-6.0h" valign="center" clip="true">
					
					<!-- Selected Glow -->
					<image width="100%" height="100@" align="center" valign="center" noclick="true" texture="/ui/fe2/store/grad_glow3.tga" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/grad_glow3.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="#fff000" rendermode="additive" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );"/>				
					<!-- Package Image(s) -->
					<image height="100@" width="100%" valign="center" align="center" noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coinstack_sml.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" 
						watch="MicroStoreUpdatePackages" ontrigger="If(!StringEmpty(microStorePackageTextures1), SetTexture(microStorePackageTextures1), SetTexture('/ui/fe2/store/coinstack_sml.tga'));"
					/>
					<image height="20%" width="100@" valign="bottom" texture="/ui/fe2/store/package_grad.tga" color="0 0 0 .5" />
					<image height="10%" width="100@" valign="top" vflip="true" texture="/ui/fe2/store/package_grad.tga" color="0 0 0 .3" />

					<!-- Bonus Coins -->
					<!-- <panel height="3.0h" group="coinBundleBonusCoinsVisible1">
						<label height="45%" valign="top" textalign="center" textvalign="center" font="dyn_10" color="1 1 1 1" shadow="true" content="mstore_includes" />
						<panel grow="true" height="55%" valign="bottom" align="center" float="right" padding="0.4h">
							<label fitx="true" height="100%" font="dyn_11" textvalign="center" color="0 1 0 1" shadow="true" content="- Bonus" 
								group="coinBundleBonusCoins1"
							/>
							<image height="100%" width="100@" valign="center" texture="/ui/fe2/store/gold_coins.tga" />
						</panel>
					</panel> -->
					<!-- Bonus % -->
					<label textalign="center" textvalign="center" valign="bottom" height="2.0h" font="dyn_12" color="1 1 1 1" shadow="true" group="coinBundleBonusPercent1" />		
				</panel>				
				<!-- Package Cost -->
				<panel height="3.0h" valign="bottom">
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#4f1b02" borderthickness="0.5h" />
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h" />
					<label height="100%" font="dyn_10" textvalign="center" textalign="center" color="1 1 1 1" outline="true" content="---" watch="MicroStoreUpdatePackages" ontrigger="SetText(ceil(microStorePackagePrice1) # ' ' # Translate(ui_useRegionalCurrencyName));" />
				</panel>
			</panel>
			
			<!-- Select Button -->
			<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up') or StringEquals('{state}', 'over') or StringEquals('{state}', 'down') ); If(StringEquals('{state}', 'down'), Split(SetX(1), SetY(1)));">
				<instance name="storeButton" enabled="true" width="8h" align="center" valign="center" height="2.5h" label="mstore_choose"/>
				<frame width="8h" align="center" height="2.5h" valign="center" texture="/ui/frames/rounded_bg_white.tga" color="#CC9900" borderthickness="0.3h" rendermode="overlay" oninstantiate="SetVisible(StringEquals('{state}', 'over'));"/>
			</panel>
			
			<!-- Selected Text -->
			<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );">
				<label textalign="center" textvalign="center" font="dyn_10" style="microStorePaperTitle" content="mstore_package_selected"  />
			</panel>
		
		</panel>
		<!-- END $5 -->

	</template>

