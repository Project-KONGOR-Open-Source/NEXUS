					<panel color="black" width="+0.5h" height="+0.5h" align="center" valign="center">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="true" />
					</panel>
					<panel grow="true" float="bottom" padding="0.25h" width="100%">
						<instance name="categoryTab" onclick="Trigger('ShowHidePanelToggle', '', 'storeSubCategories');" tip_id="mstore_tip_category3" category_id="3" width="100%" height="5.5h" label="mstore_category3" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',8, true)" /><!-- Icons -->
						<instance name="categoryTab" onclick="Trigger('ShowHidePanelToggle', '', 'storeSubCategories');" tip_id="mstore_tip_category16" category_id="16" width="100%" height="5.5h" label="mstore_category16" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',9, true)" /><!-- Name Colors -->
						<instance name="categoryTab" onclick="Trigger('ShowHidePanelToggle', '', 'storeSubCategories');" tip_id="mstore_tip_category4" category_id="4" width="100%" height="5.5h" label="mstore_category4" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',10, true)" /><!-- Symbols -->
					</panel>
				</panel>
			</panel>

			<panel noclick="true" width="14.5h" y="7.8h" height="8h" x="15h" name="storeGameVanitySubCategoryHolder">
				<panel noclick="true" x="1.35h" grow="true" width="100%" visible="false"
					onload="
						SetY(GetHeight() * -1);
					"
					name="storeGameVanitySubCategory"
					onevent0="
						SetVisible(true);
						SlideY('0', 200);
					"
					onevent1="
						SlideY(GetHeight() * -1, 200);
						FadeOut(200);
					"
				>
					<frame texture="/ui/frames/squareglow.tga" borderthickness="0.75h" color="0 0 0 0.60" width="+3h" height="+3h" align="center" valign="center" />
					<panel color="black" width="+0.5h" height="+0.5h" align="center" valign="center">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="true" />
					</panel>
					<panel grow="true" float="bottom" padding="0.25h" width="100%">
						<instance name="categoryTab" tip_id="mstore_tip_category27" category_id="27" width="100%" height="5.5h" label="mstore_category27" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',11, true)" /><!-- Taunt -->
						<instance name="categoryTab" tip_id="mstore_tip_category5" category_id="5" width="100%" height="5.5h" label="mstore_category5" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',12, true)" /><!-- Announcers -->
						<instance name="categoryTab" tip_id="mstore_tip_category57" category_id="57" width="100%" height="5.5h" label="mstore_category57" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',13, true)" /><!-- Couriers -->
						<instance name="categoryTab" tip_id="mstore_tip_category74" category_id="74" width="100%" height="5.5h" label="mstore_category74" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',27, true)" /><!-- Custom Wards -->
						<instance name="categoryTab" tip_id="mstore_tip_category75" category_id="75" width="100%" height="5.5h" label="mstore_category75" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',28, true)" /><!-- Enhancements -->
					</panel>
				</panel>
			</panel>

			<image noclick="true" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/category_backer.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" height="9.4@" width="100%"/>
			<panel valign="center" height="5.5h" x="1.3h" width="-5h" float="right" padding="0.5h" y="-0.2h">
				<instance name="storeButton" height="100%" tip_id="mstore_tip_view_specials" label="mstore_specials" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" onclick="Set('_microStore_RequestCode', 0); Set('_MicroStore_Category', 1); CallEvent('MicroStoreAction', 0);" visible="true" width="13h"
					 onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',4, true)" 
				/>


				<panel height="100%" width="13.5h" noclick="true" sticky="true" stickytoinvis="false">
					<panel noclick="true" color="invisible" visible="false" watch="AccountInfo" ontriggerlua="self:SetVisible(HasAllHeroes() and ((not HoN_Region) or HoN_Region:GetHasEAP()))" onloadlua="self:SetVisible(HasAllHeroes() and ((not HoN_Region) or HoN_Region:GetHasEAP()))">
						<instance buttonName="store_button_top_eap" name="categoryTab" height="100%" tip_id="mstore_tip_category58" category_id="58" width="13.5h" label="mstore_category58" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',5, true)" /><!-- EAP -->
					</panel>
					
					<panel noclick="true" color="invisible" visible="false" watch="AccountInfo" ontrigger="SetVisible(!HasAllHeroes());" onload="SetVisible(!HasAllHeroes());">
						<instance buttonName="store_button_top_heroes" name="categoryTab" height="100%" tip_id="mstore_tip_category58b" category_id="58" width="13.5h" label="mstore_category58b" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',6, true)" /><!-- EAP (heroes) -->
					</panel>

					<panel noclick="true" color="invisible" visible="false" watch="AccountInfo" ontriggerlua="self:SetVisible(HasAllHeroes() and (HoN_Region and (not HoN_Region:GetHasEAP())))" onloadlua="self:SetVisible(HasAllHeroes() and (HoN_Region and (not HoN_Region:GetHasEAP())))">
						<instance buttonName="store_button_top_debut" name="categoryTab" height="100%" tip_id="mstore_tip_category58c" category_id="68" width="13.5h" label="mstore_category58c" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',5, true)" /><!-- Featured -->
					</panel>
				</panel>

				<instance buttonName="store_button_top_avatars" name="categoryTab" height="100%" tip_id="mstore_tip_category2" category_id="2" width="14h" label="mstore_category2_short" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',7, true)" /><!-- Hero Avatars -->
				<instance name="storeButton" tip_id="mstore_tip_vanity" buttonName="store_btn_mstore_vanity" label="mstore_vanity" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" onclick="Trigger('ShowHidePanelToggle', 'storeVanitySubCategory', 'storeSubCategories');" onload="SleepWidget(1, 'Call(\'storeVanitySubCategoryHolder\', \'SetX(\' # GetX() # \');\');');" visible="true" width="17h"/>

				<instance name="storeButton" tip_id="mstore_tip_gamevanity" label="mstore_gamevanity" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" onclick="Trigger('ShowHidePanelToggle', 'storeGameVanitySubCategory', 'storeSubCategories');" onload="SleepWidget(1, 'Call(\'storeGameVanitySubCategoryHolder\', \'SetX(\' # GetX() # \');\');');" visible="true" width="17h"/>
				<instance name="categoryTab" height="100%" tip_id="mstore_tip_category6" category_id="6" width="12h" label="mstore_category6" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',14, true)" /><!-- Misc -->
				<instance name="categoryTab" height="100%" tip_id="mstore_tip_category7" category_id="7" width="12h" label="mstore_category7" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',15, true)" /><!-- Bundles -->

				<instance name="openVaultButton" tip_id="mstore_tip_open_vault" label="mstore_openvault" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" onclick="Trigger('ShopkeeperAction', 18); Set('_microStore_RequestCode', 2); Set('_MicroStore_Category', 3); CallEvent('MicroStoreAction', 0);" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction',16, true)"  visible="true" width="17h"/>
			</panel>
		</panel>
	</template>

