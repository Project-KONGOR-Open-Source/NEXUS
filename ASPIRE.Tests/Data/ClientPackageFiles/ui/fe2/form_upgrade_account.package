<?xml version="1.0" encoding="UTF-8"?>
<package>

	<!-- Upgrade existing account (deprecated) -->
	<trigger name="UpdateAccountUpgradeForm"/>
	<trigger name="AccountUpgradeStatus"/>
	<trigger name="AccountUpgradeResult"/>
	<form
		name="AccountUpgrade"
		host="!hon"
		target="/client_require_account_upgrade.php"
		statustrigger="AccountUpgradeStatus"
		resulttrigger="AccountUpgradeResult"
		resultparam0="success"
		resultparam1="error"
		resultparam2="connect"
		resultparam3="code"
		resultparam4="sea"
		resultparam5="errors"
		ssl="true"
	/>
	
	<template name="form_upgrade_account_checkbox" >
		<instance
			name="Noptions_checkbox"
			width="87%"
			align="center" valign="center"
			font="dyn_11" label="create_acc_promo_box_5"
			cvar="purchase_u_package"
			enabled="0"
			watch="GetGamePricePackage" 
			ontrigger="SetEnabled(param0 == 1 and GetGamePriceStatus == 2);	
				If(param8, Set(purchase_u_package, 1));
				SleepWidget(10, 'Trigger(\'UpdateAccountUpgradeForm\');');
			"				
			onclick="Trigger('UpdateAccountUpgradeForm');"
			labelwatch="GetGamePricePackage"
			labelontrigger="
				If(param3 gt 1, 
					If(StringEmpty(param7), 
						SetText(Translate('create_acc_promo_box_5')),
						SetText(StringReplace(param7, '~', ','))
					)
				);				
			"			
		/>	
	</template>	
	
	<template name="form_upgrade_account">
	
		<panel y="-110%" align="center" width="100.0h" name="form_upgrade_account" visible="{visible=0}" noclick="true" valign="center">
			
			<panel x="0" y="-100%" height="203.6%" width="90%"  align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel x="18h" y="-100%" height="203.6%" width="50@"  align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-18h" y="-100%" height="203.6%" width="50@"  align="left" texture="mainmenu/upper_frame_left.tga"/>
			
			<panel y="1.0h" width="-6.0h" height="-3.0h" align="center">
			
			
				<panel float="bottom" padding="0.5h">
				
					<panel width="100%" height="2.8h" noclick="1">
						<instance name="header_bar" lbl="web_form_upgrade_account_title" lbl_font="dyn_12" show_close="1" onclick="{close_cmd}" />
					</panel>
					
					<panel width="100%" height="44.0h" grow="true">
						
						<!-- Left -->
						<panel width="50%" float="bottom" padding="0.5h" align="left" reverse="true">
						
							<!-- Promo Code -->
							<panel width="100%" grow="true">								
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<panel width="-10.0h">
										<instance
											name="web_form_field"
											label="creditcard_label_promocode"
											hastip="true"
											order="24"
											fieldwidth="-1.8h"
											fieldname="upgrade_account_upgpromocode"
											ontrigger="
											If(
												AccountUpgradePromoCodeValid and !StringEquals(upgrade_account_upgpromocode, _promocode_code),
												Split(
													Set('AccountUpgradePromoCodeValid', false),
													Trigger('UpdateAccountUpgradeForm')
												)
											);
											If(
												(AccountUpgradePromoCodeValid and StringEquals(upgrade_account_upgpromocode, _promocode_code)) or StringLength(upgrade_account_upgpromocode) == 0,
												SetColor('white'),
												SetColor('red')
											);
											"
											tip_id="web_form_tip_promo code"
											updatetrigger="UpdateAccountUpgradeForm"
										/>
									</panel>
									<instance
										name="button2" button_name="unnamedButton125"
										x="-0.5h"
										width="9.0h" height="2.4h"
										align="right" valign="center"
										borderthickness="0.6h"
										label="general_apply"
										watch="UpdateAccountUpgradeForm"
										ontrigger="SetEnabled(StringLength(upgrade_account_upgpromocode) gt 0);"
										onclick="Set('_promocode_code', upgrade_account_upgpromocode); Set('_promocode_form', 'upgrade_account'); SubmitForm('PromoCodeCheck', 'promocode', _promocode_code);"
										enabled="false"
									/>
								</panel>
								
								<!-- Have a Code? -->
								<panel name="have_promo_code_upgrade" height="4h" color="0 0 0 1">
									<frame texture="/ui/info/backdrop.tga" borderthickness="1.0h" color="1 1 1 .6" noclick="1" />
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<label x="0.5h" height="100%" textvalign="center" color="white" font="dyn_11" shadow="true" content="create_acc_havecode" noclick="true" />
									<instance
										name="button2" button_name="unnamedButton126"
										x="-0.5h"
										width="14.0h" height="2.4h"
										borderthickness="0.6h"
										align="right" valign="center"
										label="create_acc_entercode_btn"
										onclick="Call('have_promo_code_upgrade', 'FadeOut(250);');"
									/>
								</panel>
								
								<!-- Promo Code Error -->
								<panel name="upgrade_account_promo_code_error" color="0 0 0 .9" visible="false" onload="CreateBool('AccountUpgradePromoCodeValid', false);" watch="PromoCodeCheckResult" ontrigger="
									If(
										StringEquals(_promocode_form, 'upgrade_account'),
										If(
											StringEquals(param0, 'YES'),
											Split(
												SetVisible(false),
												Set('AccountUpgradePromoCodeValid', true),
												Set('_promocode_price',param1),
												Trigger('UpdateAccountUpgradeForm')
											),
											Split(
												SetVisible(true),
												Set('AccountUpgradePromoCodeValid', false),
												Set('_promocode_price', 30.00),
												Trigger('UpdateAccountUpgradeForm')
											)
										)
									);
								">
									<frame color="invisible" bordercolor="#720000" borderthickness="1" noclick="true" />				
									<label height="100%" width="-2.2h" textalign="center" textvalign="center" font="dyn_10" color="red" shadow="true" noclick="true" content="web_form_promocode_error1"/>
									<button
										x="-0.5h"			
										width="1.7h" height="1.7h"
										align="right"
										valign="center"
										color="invisible"
										onclick="
											PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav');
											Call('upgrade_account_promo_code_error', 'FadeOut(250);');
										"
										onmouseover="
											PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
										"
									>
										<widgetstate statename="up">
											<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
											<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
											<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
										</widgetstate>
										<widgetstate statename="over">
											<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
											<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
											<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />			
										</widgetstate>
										<widgetstate statename="down" x="1" y="1">
											<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
											<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
											<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
										</widgetstate>
									</button>
								</panel>
								
								<!-- Promo Code Processing -->
								<panel name="upgrade_account_promo_code_processing" color="0 0 0 .9" visible="false" watch="PromoCodeCheckStatus" ontrigger="SetVisible(param == 1 or param == 3);">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />									
									<panel grow="true" height="3.0h" valign="center" align="center" float="right" padding="0.5h">
										<animatedimage width="100@" height="100%" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" />
										<label height="100%" fitx="true" textalign="center" textvalign="center" font="dyn_10" color="#12ff00" shadow="true" noclick="true" content="web_form_promocode_processing"/>
									</panel>									
								</panel>
								
								<!-- Promo Code Success -->
								<panel name="upgrade_account_promo_code_inuse" color="0 0 0 .9" visible="false" watch="PromoCodeCheckResult" ontrigger="SetVisible(StringEquals(param0, 'YES') and StringEquals(_promocode_form, 'upgrade_account'));">
									<frame color="invisible" bordercolor="#00FF00" borderthickness="1" noclick="true" />				
									<label height="100%" width="-2.2h" textalign="center" textvalign="center" font="dyn_10" color="0 1 0 1" shadow="true" noclick="true" watch="PromoCodeCheckResult" ontrigger="SetText(Translate('web_form_promocode_inuse', 'price_reduction', FtoA(30 - param1, 2)));"/>
									<button
										x="-0.5h"			
										width="1.7h" height="1.7h"
										align="right"
										valign="center"
										color="invisible"
										onclick="
											PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav');
											Call('upgrade_account_upgpromocode', 'EraseInputLine();');
											Set('_promocode_code', '');
											Set(AccountUpgradePromoCodeValid, false);
											Trigger('UpdateAccountUpgradeForm');
											Call('upgrade_account_promo_code_inuse', 'FadeOut(250);');
										"
										onmouseover="
											PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
										"
									>
										<widgetstate statename="up">
											<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
											<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
											<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
										</widgetstate>
										<widgetstate statename="over">
											<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
											<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
											<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />			
										</widgetstate>
										<widgetstate statename="down" x="1" y="1">
											<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
											<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
											<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
										</widgetstate>
									</button>
								</panel>
								
							</panel>
						
							<!-- First name -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_first_name"
										hastip="true"
										order="25"
										fieldwidth="-1.8h"
										fieldname="upgrade_account_ccfirstname"
										ontrigger="If(StringEmpty(upgrade_account_ccfirstname) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_first_name"
										form="AccountUpgrade" data="bill_first_name"
										updatetrigger="UpdateAccountUpgradeForm"
									/>
								</panel>
							</panel>

							<!-- Last name -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />	
									<instance
										name="web_form_field"
										label="creditcard_label_last_name"
										hastip="true"
										order="26"
										fieldwidth="-1.8h"
										fieldname="upgrade_account_cclastname"
										ontrigger="If(StringEmpty(upgrade_account_cclastname) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_last_name"
										form="AccountUpgrade" data="bill_last_name"
										updatetrigger="UpdateAccountUpgradeForm"
									/>
								</panel>
							</panel>

							<!-- Zip code -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_billing_zip"
										hastip="true"
										order="27"
										fieldwidth="-1.8h"
										fieldname="upgrade_account_cczip"
										ontrigger="If(StringEmpty(upgrade_account_cczip) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_zip"
										form="AccountUpgrade" data="zip"
										updatetrigger="UpdateAccountUpgradeForm"
									/>
								</panel>
							</panel>
							
							<!-- CC Number -->
							<panel width="100%" grow="true">
								<panel height="6h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<image texture="/ui/elements/cc.tga" width="8.0h" height="2.0h" valign="bottom" x="1h" y="-0.8h" />
									<instance
										name="web_form_field"
										y="0.8h"
										valign="top"
										label="creditcard_label_prime_card_number"
										hastip="false"
										order="28"
										fieldwidth="-1.8h"
										fieldname="upgrade_account_ccnum"
										ontrigger="If(!IsValidCCNumber(upgrade_account_ccnum) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')), SetColor('red'), SetColor('white'));"
										tip_id="ccnum_tip" tip_title="creditcard_label_billing_zip" tip_text="credit_card_billing_zip_tip"
										form="AccountUpgrade" data="card_number"
										updatetrigger="UpdateAccountUpgradeForm"
									/>
								</panel>
							</panel>
							
							<!-- Expiration Date -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									
									<panel align="center" width="-1h" height="2.4h" valign="center" float="right">
										<label name="upgrade_account_exp_label" width="33%" height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" content="creditcard_label_prime_expiration" watch="UpdateAccountUpgradeForm" ontrigger="If(
										(
										upgrade_account_ccmonth lt 1 or
										upgrade_account_ccmonth gt 12 or
										upgrade_account_ccyear lt GetYear() or
										(upgrade_account_ccyear == GetYear() and upgrade_account_ccmonth lt GetMonth())
										) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')),
											SetColor('red'),
											SetColor('white')
										);"/>										
										<panel width="5%">
											<image align="right" width="1.2h" height="1.0h" valign="center" texture="/ui/info/arrow.tga" />
										</panel>
										
										<panel width="57%">
											<label
												width="100%" height="100%"
												align="center" valign="center"
												textalign="left" textvalign="center"
												font="dyn_10" color="white" shadow="true" shadowcolor="black" noclick="1"
												content="creditcard_label_prime_month"
												watch="UpdateAccountUpgradeForm"
												ontrigger="
													If(
														(
														upgrade_account_ccmonth lt 1 or
														upgrade_account_ccmonth gt 12 or
														upgrade_account_ccyear lt GetYear() or
														(upgrade_account_ccyear == GetYear() and upgrade_account_ccmonth lt GetMonth())
														) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')),
															SetColor('red'),
															SetColor('white')
														);
													"
											/>
											
											<panel width="8h" x="5h" height="2.2h" valign="center" reverse="true">
												<instance
													name="Moptions_combobox"
													id="upgrade_account_ccmonth"
													align="right" width="8.0h" itemwidth="100%" maxlistheight="5"
													onload="CreateString('_purchase_month', '01');"
													onshow="ListBoxCmd('Select 0');"
													onselect="Trigger('UpdateAccountUpgradeForm');"
													populate="
														AddTemplateListItem('Ncombobox_item', '01', 'label', '01');
														AddTemplateListItem('Ncombobox_item', '02', 'label', '02');
														AddTemplateListItem('Ncombobox_item', '03', 'label', '03');
														AddTemplateListItem('Ncombobox_item', '04', 'label', '04');								
														AddTemplateListItem('Ncombobox_item', '05', 'label', '05');
														AddTemplateListItem('Ncombobox_item', '06', 'label', '06');
														AddTemplateListItem('Ncombobox_item', '07', 'label', '07');
														AddTemplateListItem('Ncombobox_item', '08', 'label', '08');
														AddTemplateListItem('Ncombobox_item', '09', 'label', '09');
														AddTemplateListItem('Ncombobox_item', '10', 'label', '10');
														AddTemplateListItem('Ncombobox_item', '11', 'label', '11');								
														AddTemplateListItem('Ncombobox_item', '12', 'label', '12');
														"
													form="AccountUpgrade" formdata="month"
												/>
												
											</panel>
											
											<label
												width="100%" height="100%"
												textvalign="center" textalign="left"
												valign="center" x="13.5h"
												font="dyn_10" color="white" shadow="true" shadowcolor="black" noclick="1"
												content="creditcard_label_prime_year"
												watch="UpdateAccountUpgradeForm"
												ontrigger="If(upgrade_account_ccyear lt GetYear() and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')), SetColor('red'), SetColor('white'));"
											/>
											
											<panel width="8h" x="17h" height="2.2h" valign="center" reverse="true">
												<instance
													name="Moptions_combobox"
													id="upgrade_account_ccyear"
													align="right" width="8.0h" itemwidth="100%" maxlistheight="5"
													onload="CreateString('_purchase_month', '01');"
													onshow="ListBoxCmd('Select 0');"
													onselect="Trigger('UpdateAccountUpgradeForm');"
													populate="
														AddTemplateListItem('Ncombobox_item', '2010', 'label', '2010');
														AddTemplateListItem('Ncombobox_item', '2011', 'label', '2011');								
														AddTemplateListItem('Ncombobox_item', '2012', 'label', '2012');
														AddTemplateListItem('Ncombobox_item', '2013', 'label', '2013');
														AddTemplateListItem('Ncombobox_item', '2014', 'label', '2014');
														AddTemplateListItem('Ncombobox_item', '2015', 'label', '2015');
														AddTemplateListItem('Ncombobox_item', '2016', 'label', '2016');
														AddTemplateListItem('Ncombobox_item', '2017', 'label', '2017');
														AddTemplateListItem('Ncombobox_item', '2018', 'label', '2018');								
														AddTemplateListItem('Ncombobox_item', '2019', 'label', '2019');
														AddTemplateListItem('Ncombobox_item', '2020', 'label', '2020');
														"
													form="AccountUpgrade" formdata="year"
												/>
											</panel>										
										</panel>
												
										<panel width="5%">
											<instance name="tip_mark" tip_id="web_form_tip_cc_exp" width="100@" height="100%" valign="center" align="right" />
										</panel>
										
									</panel>
								</panel>
							</panel>
														
							<!-- CVV Number -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_prime_cvv_number"
										hastip="true"
										order="29"
										fieldwidth="-1.8h"
										fieldname="upgrade_account_cccvv"
										ontrigger="If((StringLength(upgrade_account_cccvv) lt 3 or !StringContainsOnly(upgrade_account_cccvv, '', '0')) and !(AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account')),
											SetColor('red'),
											SetColor('white')
											);"
										tip_id="web_form_tip_cc_cvv2"
										form="AccountUpgrade" data="cvv"
										updatetrigger="UpdateAccountUpgradeForm"
										onfocus="ShowWidget('upgrade_account_cccvv_img');" onlosefocus="HideWidget('upgrade_account_cccvv_img');"
									/>
								</panel>
							</panel>

							<!-- $40 Coin / Account Bundle @ Upgrade -->
							<panel width="100%" height="11.5h" visible="0" 
								watch="GetGamePricePackage" 
								ontrigger="SetVisible(param1 == 1 and GetGamePriceStatus == 2);"							
							>
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />							
								<!--<image x="1.0h" width="8.0h" height="8.0h" valign="center" texture="/ui/fe2/store/full_chest.tga" />-->
								<label x="-1.0h" y="0.6h" width="-10.0h" align="right" textalign="center" font="dyn_14" color="#ffaa00" content="create_acc_promo_box_1" noclick="true"
									watch="GetGamePricePackage" ontrigger="									
										If(param3 gt 1, 
											If(StringEmpty(param5), 
												SetText(Translate('create_acc_promo_box_1')),
												SetText(param5)
											)
										);
										"								
								/>
								<label x="-1.0h" y="2.8h" width="-10.0h" align="right" textalign="center" font="dyn_10" color=".8 .8 .8 1" wrap="true" 
									content="create_acc_promo_box_2" noclick="true"
									watch="GetGamePricePackage" ontrigger="
										If(param3 gt 1, 
											If(StringEmpty(param6), 
												SetText(Translate('create_acc_promo_box_2')#' ('#param3#') '#Translate('create_acc_promo_box_4')),
												SetText(param6)
											)
										);
										"
								/>
								<panel x="-1.0h" width="-10.0h" height="3.4h" align="right" valign="bottom" noclick="true"
									onload="
										If(!VarExists('purchase_u_package'), DoEvent());
										Instantiate('form_upgrade_account_checkbox');" 									
									onevent="	
										CreateBool('purchase_u_package');										
									" 								
								>								
								</panel>
							</panel>

		
						</panel>
						
						<panel name="upgrade_account_cccvv_img" width="21.3h" height="10.65h" x="5%" y="-7h" align="left" valign="bottom" visible="0" noclick="true">
							<image texture="/ui/elements/cvv.tga" noclick="true"/>
						</panel>
						
						<!-- Promo code usage notification -->
						<panel height="28.5h" y="4.5h" width="50%" visible="false" watch="UpdateAccountUpgradeForm" ontrigger="SetVisible(StringEquals(_promocode_form, 'upgrade_account') and _promocode_price == 0 and AccountUpgradePromoCodeValid);">
							<panel color="0 0 0 .75">
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<panel width="-8h" grow="true" align="center" valign="center" color="0 0 0 .75">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<label color="white" shadow="true" font="dyn_10" wrap="true" fity="true" fitypadding="1h" align="center" textalign="center" textvalign="center" width="-1h" content="create_acc_nocc_xfer" />
								</panel>
							</panel>
						</panel>
						
						<!-- Right -->
						<panel width="49.0%" align="right">
						
							<!-- ToS -->
							<panel width="100%" height="20.2h">
								<instance height="2.5h" name="header_bar" color=".7 .7 .7 1" lbl="tos_header" lbl_font="dyn_10" show_close="0" />
								<panel valign="bottom" height="-2.7h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 .5" noclick="1" />
									<textbuffer
										scrolltexture="/ui/info/combobox.tga"
										handleheight="2.0h"
										scrollbarsize="2.0h"				
										exteriorscrollbars="false"
										textalign="left"
										font="dyn_10"
										textcolor="white"
										color="invisible"
										shadow="1"
										wrap="true"
										noclick="0"				
										file=":/tos.txt"
										width="-1.0h" height="-2.1h"
										align="center" valign="center"
									/>
								</panel>
							</panel>
							
							<!-- Secure Info -->
							<panel width="100%" height="6.0h" y="21.0h">
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<image width="4.5h" height="4.5h" x="1.0h" valign="center" texture="/ui/elements/thawte.tga" />			
								<label x="-1.0h" width="-7.0h" height="100%" align="right" valign="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" noclick="1">create_acc_secure_transfer</label>
							</panel>
							
							<!-- Price / Button -->
							<panel width="100%" valign="bottom" grow="true">
								<!-- PayPal Info -->
								<panel width="100%" grow="true" y="-7h">
									<panel height="6h">
										<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
										<panel height="5h" valign="center" align="center" width="-1h">
											<image height="6h" width="6h" y=".5h" x="1h" texture="/ui/elements/paypal_icon.tga" />
											<label width="-9.0h" height="100%" align="center" valign="center" textvalign="center" textalign="center" wrap="1" font="dyn_10" color="white" noclick="1">web_form_paypal_notice</label>
											<image height="6h" width="6h" y=".5h" x="-1h" texture="/ui/elements/paypal_icon.tga" align="right" />
										</panel>
									</panel>
								</panel>
								<!-- Price -->
								<panel height="9.2h" width="12.0h" align="left">
									<instance height="2.5h" name="header_bar" color=".7 .7 .7 1" lbl="create_acc_total_price" lbl_font="dyn_10" show_close="0" />
									
									<panel height="-2.7h" valign="bottom">
										<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
										
										<panel width="100%" valign="center" grow="true" float="bottom">
											<label fity="true" width="100%" textalign="center" textvalign="center" font="dyn_14" color="#3abde7" content="$--.--"
											onload="
												CreateFloat('_gamePriceDisplayUpgrade', 30.00);
												CreateFloat('_gamePriceDisplayUpgrade_special', 30.00);
												CreateInt('_gamePriceDisplayUpgrade_purchase_id', -1);
												SetText('$' # FtoA(_gamePriceDisplayUpgrade, 2))
											"      
											watch="UpdateAccountUpgradeForm"
											ontrigger="
												If(!purchase_u_package,
													If(AccountUpgradePromoCodeValid,
														Split(SetColor('0 1 0 1'), SetText('$' # FtoA(_promocode_price, 2))),
														Split(SetColor('#3abde7'),SetText('$' # FtoA(_gamePriceDisplayUpgrade, 2)))
													),
													Split(SetColor('0 1 0 1'), SetText('$' # FtoA(_gamePriceDisplayUpgrade_special, 2)))
												);										
											"
											watch1="GetGamePricePackage"
											ontrigger1="	
												##Echo(param0#' | '#param1#' | '#param2#' | '#param3#' | '#param4#' | '#param5#' | '#param6#' | '#param7);##
												If(param8, Set(purchase_u_package, 1));
												Set('_gamePriceDisplayUpgrade_purchase_id', param2);
												Set('_gamePriceDisplayUpgrade_special', _gamePriceDisplayUpgrade + param4);
											"	
											watch2="GetGamePriceResult"
											ontrigger2="												
												Set('_gamePriceDisplayUpgrade', param0);
												SetText('$' # FtoA(_gamePriceDisplayUpgrade, 2));
											"											
											/>
											<label fity="true" width="-0.8h" align="center" valign="bottom" textalign="center" textvalign="center" font="dyn_8" color=".8 .8 .8 1" wrap="true" content="create_acc_price_usd"/>
										</panel>
										
									</panel>
								
								</panel>
								
								<!-- Button -->
								<panel height="9.2h" width="-13.0h" align="right">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />									
									<panel
										visible="false"
										name="UpdateAccountSubmitGlow"
									>
										<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 1" noclick="1"/>
										<frame color="invisible" bordercolor="#4b628b" borderthickness="1" noclick="1" />
									</panel>
									
									<panel y="1.0h" float="bottom" padding=".5h" grow="true" width="-1h">
									
										<panel height="0" />
										
										<label wrap="true" align="center" textalign="center" font="dyn_10" color="white" shadow="true" fity="true" width="-1h">creditcard_label_upgrade_agreement</label>										
									
										<panel grow="true" width="-8.0h" align="center">
										
											<instance
												name="button2" button_name="unnamedButton127"
												width="18h" height="2.5h"
												enabled="false"
												align="center"
												label="creditcard_label_upgrade_prime"
												font="dyn_10"
												watch="UpdateAccountUpgradeForm" ontrigger="
													if (
														(
															!StringEmpty(upgrade_account_ccfirstname) and
															!StringEmpty(upgrade_account_cclastname) and
															!StringEmpty(upgrade_account_cczip) and
															IsValidCCNumber(upgrade_account_ccnum) and
															StringLength(upgrade_account_cccvv) ge 3 and
															StringLength(upgrade_account_cccvv) le 4 and
															StringContainsOnly(upgrade_account_cccvv, '', '0') and
															upgrade_account_ccmonth ge 1 and
															upgrade_account_ccmonth le 12 and
															upgrade_account_ccyear ge GetYear() and
															(upgrade_account_ccyear gt GetYear() or upgrade_account_ccmonth ge GetMonth()) and
															GetAccountID() != -1
															and ((!StringEmpty(_promocode_form) and AccountUpgradePromoCodeValid and StringEquals(_promocode_form, 'upgrade_account')) or StringEmpty(upgrade_account_upgpromocode))
														) or (AccountUpgradePromoCodeValid and _promocode_price == 0 and StringEquals(_promocode_form, 'upgrade_account') and GetAccountID() != -1)
													, Split(SetEnabled(true), ShowWidget('UpdateAccountSubmitGlow')), Split(SetEnabled(false), HideWidget('UpdateAccountSubmitGlow')));
												"
												onclick="CallEvent('submit_AccountUpgrade');"
											/>											
											
											<panel noclick="true" color="invisible" name="submit_AccountUpgrade" onevent="
											if (
												(
													!StringEmpty(upgrade_account_ccfirstname) and
													!StringEmpty(upgrade_account_cclastname) and
													!StringEmpty(upgrade_account_cczip) and
													IsValidCCNumber(upgrade_account_ccnum) and
													StringLength(upgrade_account_cccvv) ge 3 and
													StringLength(upgrade_account_cccvv) le 4 and
													StringContainsOnly(upgrade_account_cccvv, '', '0') and
													upgrade_account_ccmonth ge 1 and
													upgrade_account_ccmonth le 12 and
													upgrade_account_ccyear ge GetYear() and
													(upgrade_account_ccyear gt GetYear() or upgrade_account_ccmonth ge GetMonth()) and
													GetAccountID() != -1
												),
												Split(
													If(StringEmpty(upgrade_account_upgpromocode),
														If(purchase_u_package,
															SubmitForm('AccountUpgrade', 'account_id', GetAccountID(), 'purchase_id', _gamePriceDisplayUpgrade_purchase_id),
															SubmitForm('AccountUpgrade',  'account_id', GetAccountID())
														)
													),
													If(
														(!StringEmpty(_promocode_form) and AccountUpgradePromoCodeValid and StringEquals(_promocode_form, 'upgrade_account') and _promocode_price != 0),												
														SubmitForm('AccountUpgrade', 'account_id', GetAccountID(), 'promo_code', _promocode_code)
														
													)
												)
											);
											If(
												(!StringEmpty(_promocode_form) and AccountUpgradePromoCodeValid and StringEquals(_promocode_form, 'upgrade_account') and _promocode_price == 0),
												Split(
													Call('upgrade_account_ccfirstname', 'EraseInputLine();'),
													Call('upgrade_account_cclastname', 'EraseInputLine();'),
													Call('upgrade_account_cczip', 'EraseInputLine();'),
													Call('upgrade_account_ccnum', 'EraseInputLine();'),
													Call('upgrade_account_cccvv', 'EraseInputLine();'),
													Call('upgrade_account_ccmonth', 'SetSelectedItemByIndex(-1);'),
													Call('upgrade_account_ccyear', 'SetSelectedItemByIndex(-1);'),
													SubmitForm('AccountUpgrade', 'account_id', GetAccountID(), 'promo_code', _promocode_code)	
												)
											);
											
											
											"/>
			
											<panel align="center" valign="bottom" width="100%" height="2.5h" visible="false" name="AccountUpgradeStatusIndicator" color="0 0 0 1" watch="AccountUpgradeStatus" ontrigger="SetVisible(param == 1);">
												<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 .5" noclick="1" />
												<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
												<label width="-1h" height="-1h" textvalign="center" textalign="center" align="center" valign="center" shadow="true" color="white" font="dyn_11">credit_card_processing</label>
											</panel>
										
										</panel>
									
									</panel>

								</panel>
							
							</panel>
	
						</panel>
						
					</panel>
					
				</panel>
				
				
				<!-- Successful account upgrade -->
				<panel color="0 0 0 .5" name="AccountUpgradeSuccessIndicator" watch="AccountUpgradeResult" visible="false" ontrigger="
				If(param0 and !param1,
					Split(
						Call('upgrade_account_ccfirstname', 'EraseInputLine();'),
						Call('upgrade_account_cclastname', 'EraseInputLine();'),
						Call('upgrade_account_cczip', 'EraseInputLine();'),
						Call('upgrade_account_ccnum', 'EraseInputLine();'),
						Call('upgrade_account_cccvv', 'EraseInputLine();'),
						Call('upgrade_account_ccmonth', 'SetSelectedItemByIndex(-1);'),
						Call('upgrade_account_ccyear', 'SetSelectedItemByIndex(-1);'),
						Call('upgrade_account_upgpromocode', 'EraseInputLine();'),
						SetVisible(true),
						ShowWidget('have_promo_code_upgrade'),
						HideWidget('upgrade_account_promo_code_error'),
						HideWidget('upgrade_account_promo_code_inuse')
					),
					SetVisible(false)
				);
				
				">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="creditcard_label_prime_up_successful" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="credit_card_upgrade_success" />
							</panel>
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton128"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="main_button_login"
									font="dyn_10"
									onclick="
										Logout();
										HideWidget('AccountUpgradeSuccessIndicator');
										HideWidget('upgrade_account_promo_code_inuse');
									"
								/>					
							</panel>							
						</panel>
					</panel>
				</panel>
				
				<!-- Account already created and purchased -->				
				<panel color="0 0 0 .5" name="AccountUpgradePurchasedNotice" watch="AccountInfo" ontrigger="SetVisible(param2 ge 3);">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="create_already_logged_in_title" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="create_already_upgraded" />
							</panel>							
							<panel width="100%" height="4.0h">
								<instance
									name="button2" button_name="unnamedButton129"
									x="1h" y="-1.0h"
									valign="bottom"
									width="9h" height="2.5h"
									label="main_button_logout"
									font="dyn_10"
									onclick="Logout();"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_account', nil, false)"
								/>
								<instance
									name="button2" button_name="unnamedButton130"
									x="-1h" y="-1.0h"
									valign="bottom"
									align="right"
									width="9h" height="2.5h"
									label="general_close"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_account', nil, false)"
								/>							
							</panel>							
						</panel>
					</panel>
				</panel>
				
				<!-- Need to log in first -->				
				<panel color="0 0 0 .5" name="AccountUpgradeLoginNotice" watch="AccountInfo" visible="true" ontrigger="setvisible(GetAccountID() == -1));">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="web_form_must_login" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="web_form_must_login_text" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton131"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_account', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>
				
				<!-- Failed account upgrade -->
				<panel color="0 0 0 .5" name="AccountUpgradeFailureIndicator" watch="AccountUpgradeResult" visible="false" ontrigger="SetVisible(param1);">
					<panel align="center" valign="center" width="38.0h" grow="true" regrow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="credit_card_error_plain" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" regrow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true" regrow="true">
								<label color="white" shadow="true" font="dyn_10" width="100%" wrap="true" fity="true"
									watch="AccountUpgradeResult"
									ontrigger="
										Set('web_resetstats_error_concat', '');
										If(
											param1,
											ExplodeTrigger('ConcatResetStatsError', param5, '|', ':')
										);
										SetText(
											If(
												!StringEmpty(web_resetstats_error_concat),
												FormatStringNewLine(web_resetstats_error_concat),
												''
											)
										);
									"
								/>
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton132"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclick="HideWidget('AccountUpgradeFailureIndicator');"
								/>						
							</panel>
						</panel>
					</panel>
				</panel>
				
				
				<!-- Can't upgrade while in-game -->				
				<panel color="0 0 0 .5" name="AccountUpgradeInGameNotice" watch="GamePhase" visible="false" ontrigger="SetVisible(param != 0));">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="web_form_feature_unavailable_title" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="web_form_feature_unavailable_inmatch" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton133"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_close"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_account', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>
				
				
				<!-- LAN users -->				
				<panel color="0 0 0 .5" name="AccountUpgradeLoginNoticeLan" watch="AccountInfo" visible="false" ontrigger="SetVisible(StringEquals('LAN.', SubString(StripClanTag(GetAccountName()), 0, 4)));">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="web_form_lan_account_feature_unavailable" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="web_form_lan_account_feature_unavailable_text" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton134"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_account', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>
				
				<!-- Feature unavailable (for now) -->				
				<panel color="0 0 0 .5" visible="false" onload="If(ui_disableAccountCreation or ui_disableAccountForms, ShowWidget());">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="web_form_feature_unavailable_title" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="web_form_feature_unavailable" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton135"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_account', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>

				
			</panel>
			
			
		</panel>
		
	</template>

</package>