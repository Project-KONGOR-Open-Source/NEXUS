<!-- item template -->
	<template name="endgame_item_tooltip">
		<frame
			name="{id}"
			texture="/ui/frames/rounded_bg_white.tga"
			onframelua="HoN_Learner:InventoryPopup()"
			borderthickness="0.6h"
			color="0 0 0 .75"
			visible="false"
			align="left"
			valign="top"
			width="27h"
			height="5.0h"
			float="bottom"
			noclick="1"
		>
			<frame texture="/ui/frames/roundframe.tga" noclick="1" borderthickness="0.6h" bordercolor="#434d50"/>
			<anchor x="1.0h" y="0.6h" />

			<panel width="-2.0h" height="3.6h" noclick="1">

				<!-- Icon -->
				<panel width="100@" height="100%" noclick="1">
					<image texture="" noclick="1"
						watch="MSPlayerInventoryTipIcon"
						ontrigger="
							If(
								!StringEmpty(param0),
								Split(
									SetVisible(true),
									SetTexture(param0)
								),
								SetVisible(false)
							);
						"
					/>
					<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1" noclick="1"/>
				</panel>

				<panel width="-120@" align="right" noclick="1">

					<!-- Name -->
					<label noclick="1"
						height="1.8h"
						valign="top"
						textalign="left"
						font="dyn_12" color="#ffab01" shadow="true"
						watch="{watch}"
						ontrigger="SetText(param0);"
					/>

					<!-- Value -->
					<label noclick="1"
						height="1.8h"
						valign="bottom"
						textalign="left" textvalign="bottom"
						font="dyn_10"
						color=".9 .9 .9 1"
						watch="{watch}"
						ontrigger="If(param1 gt 0, SetText(Translate('tooltip_value') # param1), ClearText());"
					/>

					<!-- Level-->
					<label noclick="1"
						height="1.8h"
						valign="bottom"
						textalign="left"
						textvalign="bottom"
						font="dyn_10" color=".9 .9 .9 1" shadow="true"
						watch="{watch}"
						ontrigger="If(param2 != 0 and param3 != 0, SetText(Translate('toolitp_level', 'level', param2))); SetVisible(param2 != 0 and param3 != 0);"
						sticky="true"
						stickytoinvis="false"
						visible="false"
					/>

				</panel>

			</panel>

			<panel 
				width="-2.0h" noclick="1"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param4));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Description text -->
			<label
				width="-2.0h" noclick="1"
				height="0.0h"
				font="dyn_9"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param4); SetVisible(!StringEmpty(param4)); SetHeight(GetStringWrapHeight('dyn_9', param4, GetWidthFromString('-2.0h')) + GetYFromString('0.2h'));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h" noclick="1"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param34));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Description text2 -->
			<label
				width="-2.0h" noclick="1"
				height="0.0h"
				font="dyn_9"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param34); SetVisible(!StringEmpty(param34)); SetHeight(GetStringWrapHeight('dyn_9', param34, GetWidthFromString('-2.0h')) + GetYFromString('0.2h'));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Passive block -->
			<panel
				width="-2.0h" noclick="1"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(param6 gt 0);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h" noclick="1"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(param6 gt 0);"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					height="1.8h" noclick="1"
					font="dyn_10"
					color="white"
					content="tooltip_passive_bonuses"
				/>

				<panel width="10.5h" height="0.2h" color="gray" noclick="1" />
				<panel height="0.4h" sticky="true" noclick="1" />
			</panel>

			<!-- Passive bonuses -->
			<label
				width="-2.0h" noclick="1"
				height="0.0h"
				font="dyn_10"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param5); SetHeight(GetStringWrapHeight('dyn_10', param5, GetWidthFromString('-2.0h')) + GetYFromString('0.4h')); SetVisible(param6 gt 0);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Activation block -->
			<panel
				width="-2.0h" noclick="1"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h" noclick="1"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(param7);"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					width="-2.0h"
					height="1.8h" noclick="1"
					font="dyn_10"
					color="white"
					content="tooltip_activation"
				/>

				<panel width="10.5h" height="0.2h" color="gray" sticky="true" noclick="1" />
				<panel width="-2.0h" height="0.4h" sticky="true" noclick="1" />
			</panel>

			<!-- Action type and Target scheme -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}" noclick="1"
				ontrigger="SetVisible(!StringEmpty(param8) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					textalign="left" noclick="1"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(param8);"
				/>
				<label
					textalign="right" noclick="1"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(param9);"
				/>
			</panel>

			<!-- Cast effect type -->
			<label
				width="-2.0h" noclick="1"
				height="1.8h"
				font="dyn_10"
				color="white"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_type') # param10); SetVisible(!StringEmpty(param10) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Range -->
			<label
				width="-2.0h" noclick="1"
				height="1.8h"
				font="dyn_10"
				color="white"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_range') # param11); SetVisible(!StringEmpty(param11) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Radius -->
			<label
				width="-2.0h" noclick="1"
				height="1.8h"
				font="dyn_10"
				color="white"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_radius') # param12); SetVisible(!StringEmpty(param12) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Channeling time -->
			<label
				width="-2.0h" noclick="1"
				height="1.8h"
				font="dyn_10"
				color="green"
				watch="{watch}"
				ontrigger="If(!StringEmpty(param35), SetText(Translate('tooltip_channeling_time', 'time', param35))); SetVisible(!StringEmpty(param35));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Mana cost -->
			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10" noclick="1"
				color="aqua"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_mana_cost') # param13); SetVisible(!StringEmpty(param13) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Mana Upkeep -->
			<label
				width="-2.0h"
				height="1.8h" noclick="1"
				font="dyn_10"
				color="yellow"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_mana_upkeep', 'value', param36)); SetVisible(!StringEmpty(param36) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Cooldown -->
			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10"
				color="#F0E68C"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_cooldown', 'time', param14)); SetVisible(!StringEmpty(param14));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param15) and param7);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Effect -->
			<label
				width="-2.0h"
				height="0.0h"
				font="dyn_9"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param15); SetVisible(!StringEmpty(param15) and param7); SetHeight(GetStringWrapHeight('dyn_9', param15, GetWidthFromString('-2.0h')) + GetYFromString('0.2h'));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Triggered effect -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(param16);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(param16);"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					width="-2.0h"
					height="1.8h"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(param17);"
				/>

				<panel width="10.5h" height="0.2h" color="gray" sticky="true" />
				<panel width="-2.0h" height="0.4h" sticky="true" />
			</panel>

			<label
				width="-2.0h"
				height="0.0h"
				font="dyn_9"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param18); SetVisible(!StringEmpty(param18) and param16); SetHeight(GetStringWrapHeight('dyn_9', param18, GetWidthFromString('-2.0h')) + GetYFromString('0.2h'));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Status effect -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param19));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param19));"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					height="1.8h"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(param19);"
				/>

				<panel width="10.5h" height="0.2h" color="gray" />
				<panel height="0.4h" sticky="true" />
			</panel>

			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param20); SetHeight(GetStringWrapHeight('dyn_10', param20, GetWidthFromString('-2.0h')) + GetYFromString('0.4h')); SetVisible(param21 gt 0 and !StringEmpty(param19));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Status effect 2 -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param31));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param31));"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					height="1.8h"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(param31);"
				/>

				<panel width="10.5h" height="0.2h" color="gray" />
				<panel height="0.4h" sticky="true" />
			</panel>

			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param32); SetHeight(GetStringWrapHeight('dyn_10', param32, GetWidthFromString('-2.0h')) + GetYFromString('0.4h')); SetVisible(param33 gt 0 and !StringEmpty(param31));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Aura block -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(param22);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(param22);"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					width="-2.0h"
					height="1.8h"
					font="dyn_10"
					color="white"
					content="tooltip_aura"
				/>

				<panel width="10.5h" height="0.2h" color="gray" sticky="true" />
				<panel width="-2.0h" height="0.4h" sticky="true" />
			</panel>

			<!-- Radius and Target scheme -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(param22);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					textalign="left"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(Translate('tooltip_radius') # param28); SetVisible(param22);"
				/>
				<label
					textalign="right"
					font="dyn_10"
					color="white"
					watch="{watch}"
					ontrigger="SetText(param26);"
				/>
			</panel>

			<!-- Aura effect type -->
			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10"
				color="white"
				watch="{watch}"
				ontrigger="SetText(Translate('tooltip_type') # param27); SetVisible(!StringEmpty(param27) and param22);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(param22);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Aura bonuses -->
			<panel
				width="-2.0h"
				height="2.4h"
				watch="{watch}"
				ontrigger="SetVisible(param22);"
				float="bottom"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			>
				<label
					height="1.8h"
					font="dyn_10"
					color="white"
					content="tooltip_aura_effects"
				/>

				<panel width="10.5h" height="0.2h" color="gray" />
				<panel height="0.4h" sticky="true" />
			</panel>

			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10"
				wrap="true"
				color="white"
				watch="{watch}"
				ontrigger="SetText(param23); SetHeight(GetStringWrapHeight('dyn_10', param23, GetWidthFromString('-2.0h')) + GetYFromString('0.4h')); SetVisible(param24 gt 0);"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Flavor text -->
			<panel
				width="-2.0h"
				height="1.8h"
				watch="{watch}"
				ontrigger="SetVisible(!StringEmpty(param29));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_9"
				wrap="true"
				color=".5 .5 .5 1"
				watch="{watch}"
				ontrigger="SetText(param29); SetVisible(!StringEmpty(param29)); SetHeight(GetStringWrapHeight('dyn_9', param29, GetWidthFromString('-2.0h')) + GetYFromString('0.2h'));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel
				width="-2.0h"
				height="1.5h"
				watch="{watch}"
				ontrigger="SetVisible({help} and !StringEmpty(param30));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<!-- Help -->
			<label
				width="-2.0h"
				height="1.8h"
				font="dyn_10"
				wrap="true"
				color="yellow"
				watch="{watch}"
				ontrigger="SetText(param30); SetVisible({help} and !StringEmpty(param30));"
				sticky="true"
				stickytoinvis="false"
				visible="false"
			/>

			<panel width="-2.0h" height="0.0h"
				onframe="If(IsVisible(), Call('{id}', 'SetHeight(' # GetY() # ' + GetYFromString(\'0.55h\'));'));"
				sticky="true"
				stickytoinvis="false"
			/>
		</frame>
	</template>
	<trigger name="MSPlayerInventoryTip" />
	<trigger name="MSPlayerInventoryTipIcon" />
	<trigger name="MSPlayerHeroName" />
	<instance name="endgame_item_tooltip" id="endgameItemTooltip" watch="MSPlayerInventoryTip" help="true" />
	<instance name="generic_tooltip_floater" width="10h" align="right" valign="bottom" tip_id="endgame_hero_tooltip" title="" label="" title_watch="MSPlayerHeroName" title_ontrigger="SetText(GetEntityDisplayName(param0));" label_watch="MSPlayerHeroName" label_ontrigger="DestroyWidget();" />

	<!-- HoN Tour -->
	<instance name="generic_tooltip_float_resizey" tip_id="hontour_multiple_matches" 	title="hontour_multiple_matches" 	label="hontour_multiple_matches_tip" />
	<instance name="generic_tooltip_float_resizey" tip_id="hontour_multiple_events" 	title="hontour_multiple_events" 	label="hontour_multiple_events_tip" />

	<!--
		Generic Floating Tooltip System
		=========================
		Just a generally flexible tooltip with up to a title, 3 text bodies and a top-right corner image.  Can be expanded later on.

		param0		General visibility (you can also just hidewidget on genericMainFloatingTip so you don't need to re-trigger)
		param1		Width
		param2		Icon Path (blank for none) - small square icon at top-right
		param3		Title text
		param4		Body text 1
		param5		Body text 2
		param6		Body text 3
		param7		X
		param8		Y
	-->
	<trigger name="genericMainFloatingTip"/>
	<trigger name="genericMainFloatingTip_subtrigger"/>
	<floater passivechildren="true" visible="false" x="22" y="-22" width="20h" grow="true" regrow="true" name="genericMainFloatingTip"
		watch="genericMainFloatingTip" ontrigger="SetVisible(param0); If(!StringEmpty(param1), SetWidth(param1)); If(!StringEmpty(param7), SetX(param7)); If(!StringEmpty(param8), SetY(param8)); BringToFront(); Trigger('genericMainFloatingTip_subtrigger', param0, param1, param2, param3, param4, param5, param6, param7);"
	>
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .95" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
		<image visible="false" align="right" valign="top" width="2h" height="2h" x="-0.5h" y="0.5h" watch="genericMainFloatingTip_subtrigger" ontrigger="If(!StringEmpty(param2), Split(SetTexture(param2), SetVisible(true)), SetVisible(false));"/>
		<panel grow="true" regrow="true" growinvis="false" float="bottom" width="-1h" align="center">
			<panel height="2" /><!-- Spacer and to get rid of the padding issue -->
			<panel width="100%" grow="true" regrow="true" growinvis="false" float="bottom" padding="0.5h"><!-- Actual usable space -->
				<label align="center" color="#ffab01" font="dyn_12" shadow="true" wrap="true" fity="true" sticky="true" stickytoinvis="false" textvalign="center" watch="genericMainFloatingTip_subtrigger" ontrigger="If(!StringEmpty(param3), Split(SetVisible(true), SetText(Translate(param3))), SetVisible(false));" content="-"/>
				<label align="center" color="white" font="dyn_10" shadow="true" wrap="true" fity="true" sticky="true" stickytoinvis="false" textvalign="center" visible="false" watch="genericMainFloatingTip_subtrigger" ontrigger="If(!StringEmpty(param4), Split(SetVisible(true), SetText(FormatStringNewLine(Translate(param4)))), SetVisible(false));" content="-"/>
				<panel height="0.5h" width="100%" visible="false" sticky="true" stickytoinvis="false" watch="genericMainFloatingTip_subtrigger" ontrigger="SetVisible(!StringEmpty(param5));">
					<panel align="center" valign="center" height="1" width="-1h" color="#555555" />
				</panel>
				<label align="center" color="white" font="dyn_10" shadow="true" wrap="true" fity="true" sticky="true" stickytoinvis="false" textvalign="center" visible="false" watch="genericMainFloatingTip_subtrigger" ontrigger="If(!StringEmpty(param5), Split(SetVisible(true), SetText(FormatStringNewLine(Translate(param5)))), SetVisible(false));" content="-"/>
				<panel height="0.5h" width="100%" visible="false" sticky="true" stickytoinvis="false" watch="genericMainFloatingTip_subtrigger" ontrigger="SetVisible(!StringEmpty(param6));">
					<panel align="center" valign="center" height="1" width="-1h" color="#555555" />
				</panel>
				<label align="center" color="white" font="dyn_10" shadow="true" wrap="true" fity="true" sticky="true" stickytoinvis="false" textvalign="center" visible="false" watch="genericMainFloatingTip_subtrigger" ontrigger="If(!StringEmpty(param6), Split(SetVisible(true), SetText(FormatStringNewLine(Translate(param6)))), SetVisible(false));" content="-"/>
			</panel>
			<panel height="1h"/><!-- Spacer and to get rid of the padding issue -->
		</panel>

	</floater>
</package>
