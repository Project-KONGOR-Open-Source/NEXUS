	<floater width="20h" x="22" y="-22" grow="true" name="stats_tip_matches_played" color="invisible" visible="false">
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
			<panel width="-1.5h" align="center" grow="true" float="bottom">
					<panel height=".5h" />
					<label textvalign="top" textalign="left" font="dyn_10" noclick="1" color="#ffab01" shadow="1" wrap="1" width="100%" fity="true" fitypadding="0.8h">stats_tip_matches_played</label>
					<!--<label textvalign="top"	textalign="left" font="dyn_10" noclick="1" color="white" shadow="1" wrap="1" fity="true" fitxpadding="0" fitypadding="1.0h">player_stats_matches_played_msg</label>-->
					<label textvalign="top"	textalign="left" font="dyn_10" noclick="1" color="white" shadow="1" wrap="1" fity="1" fitxpadding="0"
						   watch1="PlayerStatsResultRanked"
						   watch2="PlayerStatsResult"
						   watch3="PlayerStatsResultCasual"
						   watch4="PlayerStatsResultSeasonNormal"
						   watch5="PlayerStatsResultSeasonCasual"

					ontrigger1lua="
						local public = param89
						local rank_normal = param5
						local rank_casual = param90
						local campaign_normal = param139
						local campaign_casual = param140
						local pre_season_normal = param143
						local pre_season_casual = param144
						local midwars = param123

						if Empty(public) then public = '0' end
						if Empty(rank_normal) then rank_normal = '0' end
						if Empty(rank_casual) then rank_casual = '0' end
						if Empty(campaign_normal) then campaign_normal = '0' end
						if Empty(campaign_casual) then campaign_casual = '0' end
						if Empty(pre_season_normal) then pre_season_normal = '0' end
						if Empty(pre_season_casual) then pre_season_casual = '0' end
						if Empty(midwars) then midwars = '0' end

						local displayText = '^w'..Translate('player_stats_public')..': '..public..'\n'..
											'^w'..Translate('player_stats_campaign_normal')..': '..campaign_normal..'\n'

						if GetCvarBool('cl_GarenaEnable') then
							displayText = displayText..'^w'..Translate('player_stats_campaign_casual')..': '..campaign_casual..'\n'
						end

						displayText = displayText..
											'^w'..Translate('player_stats_pre_campaign_normal')..': '..pre_season_normal..'\n'

						if GetCvarBool('cl_GarenaEnable') then
							displayText = displayText..'^w'..Translate('player_stats_pre_campaign_casual')..': '..pre_season_casual..'\n'
						end

						displayText = displayText..
											'^r'..Translate('player_stats_ranked_normal')..': ' ..rank_normal..'\n'..
											'^w'..Translate('player_stats_ranked_casual')..': '..rank_casual..'\n'..
											'^w'..Translate('player_stats_midwars')..': '..midwars..'\n'

						self:SetText(displayText)
						"
