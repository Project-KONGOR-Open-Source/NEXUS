						if Empty(pre_season_casual) then pre_season_casual = '0' end
						if Empty(midwars) then midwars = '0' end

						local displayText = '^w'..Translate('player_stats_public')..': '..public..'\n'..
											'^w'..Translate('player_stats_campaign_normal')..': '..campaign_normal..'\n'..
											'^r'..Translate('player_stats_campaign_casual')..': '..campaign_casual..'\n'..
											'^w'..Translate('player_stats_pre_campaign_normal')..': '..pre_season_normal..'\n'..
											'^w'..Translate('player_stats_pre_campaign_casual')..': '..pre_season_casual..'\n'..
											'^w'..Translate('player_stats_ranked_normal')..': ' ..rank_normal..'\n'..
											'^w'..Translate('player_stats_ranked_casual')..': '..rank_casual..'\n'..
											'^w'..Translate('player_stats_midwars')..': '..midwars..'\n'

						self:SetText(displayText)
						"
					/>
