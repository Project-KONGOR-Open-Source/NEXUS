	<template name="progstats_key_item">
		<panel width="100%" height="2.0h">
			<panel width="100%" height="-0.2h" valign="center" color="1 1 1 .05" visible="{evenrow=false}" />
			<panel width="-0.4h" align="center" float="right">
				<label width="70%" height="100%" font="dyn_10" textvalign="center" color=".7 .7 .7 1" shadow="true" content="{cat}" />
				<label width="15%" height="100%" font="dyn_10" textalign="center" textvalign="center" color="#8e00ec" shadow="true" content="{exp}" />
				<label width="15%" height="100%" font="dyn_10" textalign="center" textvalign="center" color="#c0d5ed" shadow="true" content="{coins}" />
			</panel>
		</panel>
	</template>

	<floater
		name="progstats_key"
		x="22" y="-22"
		width="72.0h"
		align="right"
		valign="top"
		color="invisible"
		visible="false"
		passivechildren="true"
		grow="true"
		keeponscreen="true"
	>
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 9" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />

		<panel grow="true" y="1.0h" width="-2.0h" align="center" noclick="true" float="bottom">
			<label fity="true" fitypadding="0.5h" font="dyn_14" color="#ffaa00" shadow="true" content="mm_progression_key_title" />
			<label fity="true" fitypadding="0.8h" font="dyn_10" color="1 1 1 1" shadow="true" wrap="true" content="mm_pregression_key_explanation" />

			<panel grow="true" width="100%" float="right">

				<!-- Performance -->
				<panel grow="true" width="39.0%">
					<panel grow="true" width="-1.0h" align="center" noclick="true" float="bottom">
						<label fity="true" fitypadding="0.4h" font="dyn_12" color="#3abce6" shadow="true" content="mm_pregression_gameperformance" />
						<panel width="100%" height="2.0h">
							<panel width="-0.4h" align="center" float="right">
								<label width="70%" height="100%" font="dyn_10" color="1 1 1 1" shadow="true" content="mm_pregression_condition" />
								<panel width="15%" height="100%">
									<image y="-5%" width="90@" height="90%" align="center" valign="center" texture="/ui/fe2/elements/diamond.tga"/>
								</panel>
								<panel width="15%" height="100%">
									<image y="-70%" width="160@" height="320%" align="center" valign="center" texture="/ui/common/gold/gold0000.tga" rendermode="grayscale" noclick="true"/>
								</panel>
							</panel>
						</panel>
						<panel width="100%" height="0.6h">
							<panel width="100%" height="1" valign="center" align="center" color="1 1 1 .1" />
						</panel>
						<instance name="progstats_key_item" cat="mm_pregression_victory" exp="30" coins="6" />
						<instance name="progstats_key_item" cat="mm_pregression_loss" exp="10" coins="4" evenrow="true" />
						<instance name="progstats_key_item" cat="mm_pregression_fotd" exp="20" coins="4" />
						<instance name="progstats_key_item" cat="mm_pregression_socialbonus" exp="0" coins="4-10" evenrow="true" />
						<instance name="progstats_key_item" cat="mm_pregression_consecbonus" exp="0" coins="2-6" />
						<instance name="progstats_key_item" cat="mm_pregression_bloodlust_you" exp="10" coins="2" evenrow="true" />
						<!--<instance name="progstats_key_item" cat="mm_pregression_bloodlust_team" exp="1" coins="1" />-->
						<instance name="progstats_key_item" cat="mm_pregression_immortal_you" exp="50" coins="10" />
						<instance name="progstats_key_item" cat="mm_pregression_immortal_team" exp="15" coins="3" evenrow="true" />
						<instance name="progstats_key_item" cat="mm_pregression_annihilation_you" exp="75" coins="15" />
						<instance name="progstats_key_item" cat="mm_pregression_annihilation_team" exp="25" coins="5" evenrow="true" />
					</panel>
				</panel>

				<!-- Aggregate -->
				<panel grow="true" width="32.0%">
					<panel grow="true" width="-1.0h" align="center" noclick="true" float="bottom">
						<label fity="true" fitypadding="0.4h" font="dyn_12" color="#3abce6" shadow="true" content="mm_pregression_key_aggregate" />
						<panel width="100%" height="2.0h">
							<panel width="-0.4h" align="center" float="right">
								<label width="70%" height="100%" font="dyn_10" color="1 1 1 1" shadow="true" content="mm_pregression_condition" />
								<panel width="15%" height="100%">
									<image y="-5%" width="90@" height="90%" align="center" valign="center" texture="/ui/fe2/elements/diamond.tga"/>
								</panel>
								<panel width="15%" height="100%">
									<image y="-70%" width="160@" height="320%" align="center" valign="center" texture="/ui/common/gold/gold0000.tga" rendermode="grayscale" noclick="true"/>
								</panel>
							</panel>
						</panel>
						<panel width="100%" height="0.6h">
							<panel width="100%" height="1" valign="center" align="center" color="1 1 1 .1" />
						</panel>
						<instance name="progstats_key_item" cat="mm_pregression_50wins" exp="200" coins="10" />
						<instance name="progstats_key_item" cat="mm_pregression_250kills" exp="100" coins="5" evenrow="true" />
						<instance name="progstats_key_item" cat="mm_pregression_250assts" exp="100" coins="5" />
						<instance name="progstats_key_item" cat="mm_pregression_50wards" exp="100" coins="5" evenrow="true" />
						<instance name="progstats_key_item" cat="mm_pregression_10smacks" exp="50" coins="1" />
					</panel>
				</panel>

				<!-- Acct Lvl -->
				<panel grow="true" width="29.0%">
					<panel grow="true" width="-1.0h" align="center" noclick="true" float="bottom">
						<label fity="true" fitypadding="0.4h" font="dyn_12" color="#3abce6" shadow="true" content="mm_pregression_key_acct_level" />
						<panel width="100%" height="2.0h">
							<panel width="-0.4h" align="center" float="right">
								<label width="70%" height="100%" font="dyn_10" color="1 1 1 1" shadow="true" content="mm_pregression_key_acct_levelreached" />
								<panel width="15%" height="100%">

								</panel>
								<panel width="15%" height="100%">
									<image y="-70%" width="160@" height="320%" align="center" valign="center" texture="/ui/common/gold/gold0000.tga" rendermode="grayscale" noclick="true"/>
								</panel>
							</panel>
						</panel>
						<panel width="100%" height="0.6h">
							<panel width="100%" height="1" valign="center" align="center" color="1 1 1 .1" />
						</panel>
						<instance name="progstats_key_item" cat="mm_pregression_key_level1" coins="6" />
						<instance name="progstats_key_item" cat="mm_pregression_key_level2" coins="12" evenrow="true" />
						<instance name="progstats_key_item" cat="mm_pregression_key_level3" coins="18" />
						<panel width="100%" height="2.0h">
							<panel height="-0.2h" color="1 1 1 .05" valign="center">
								<label y="-0.4h" width="100%" height="100%" font="dyn_10" textalign="center" textvalign="center" color=".7 .7 .7 1" shadow="true" content="..." />
							</panel>
						</panel>
						<panel width="100%" height="2.0h">
							<label width="100%" height="100%" font="dyn_10" textalign="center" textvalign="center" color=".7 .7 .7 1" shadow="true" content="mm_pregression_key_level5" />
						</panel>
					</panel>
				</panel>

			</panel>

			<panel width="100%" height="7.0h" />

		</panel>

		<panel grow="true" x="-1.0h" y="-1.0h" width="41.8h" align="right" valign="bottom">
			<frame texture="/ui/frames/roundframe.tga" color="1 1 1 .4" borderthickness="0.4h" blockinput="false" noclick="true"/>
			<panel grow="true" width="-1.0h" y="0.5h" align="center" float="bottom">
				<label fity="true" fitypadding="0.3h" font="dyn_9" color=".7 .7 .7 1" shadow="true" wrap="true" content="mm_pregression_key_consecbonus_exp" />
				<label fity="true" fitypadding="0" font="dyn_9" color="1 1 1 1" shadow="true" wrap="true" content="mm_pregression_key_consecbonus_exp2" />
				<label fity="true" fitypadding="0.5h" font="dyn_9" color=".7 .7 .7 1" shadow="true" wrap="true" content="mm_pregression_key_consecbonus_exp3" />
			</panel>
		</panel>

	</floater>


	<floater
		name="progstats_tip_additional"
		x="22" y="-22"
		width="19.0h"
		align="right"
		valign="top"
		color="invisible"
		visible="visible=0"
