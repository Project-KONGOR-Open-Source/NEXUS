	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="2.5h" iconwidth="2.5h" width="23h" tip_id="mm_option_disabled_needtokenpass_tip" title="mm_option_disabled_needtokenpass" label="mm_option_disabled_needtokenpass_body" icon="/ui/fe2/store/icons/hero_token.tga" />
