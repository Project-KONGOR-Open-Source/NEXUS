	<instance name="generic_tooltip_floater" tip_id="stat_tip_pubgames" title="player_stats_public_games" label="player_stats_public_games_msg" />
	<instance name="generic_tooltip_floater" tip_id="stat_tip_rankedgames" title="player_stats_ranked_games" label="player_stats_ranked_games_msg" />
