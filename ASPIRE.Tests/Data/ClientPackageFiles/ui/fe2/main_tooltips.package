<!-- Store.package and related packages -->

	<panel noclick="true" color="invisible" visible="false"
		width="1h" height="1h"
		watch="StoreImagePreviewInit"
		ontrigger="
			SetWidth(param0);
			SetHeight(param1);
			SetAbsoluteX(param2);
			SetAbsoluteY(param3);
			BringToFront();
		"
		watch1="StoreImagePreviewVis"
		ontrigger1="
			If(
				param0,
				FadeIn(0),
				FadeOut(200)
			);
		"
	>
		<webimage noclick="true" align="center" valign="center"
			watch="StoreImagePreviewInit"
			ontrigger="
				If(
					param4,
					SetTextureURL(param5),
					SetTexture(param5)
				);
			"
			watch1="StoreImagePreviewVis"
			ontrigger1="
				If(
					!IsVisible() or (param0 and IsVisible()),
					Split(
						SetWidth('100%'),
						SetHeight('100%')
					)
				);
				If(
					param0,
					Split(
						ScaleWidth(param1, 200),
						ScaleHeight(param1, 200)
					),
					If(
						IsVisible(),
						Split(
							ScaleWidth('100%', 200),
							ScaleHeight('100%', 200)
						)
					)
				);
			"
		/>
	</panel>

	<floater width="25h" x="22" y="-22" grow="true" name="store_trial_tip" color="invisible" visible="false">
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
			<panel width="-1.5h" align="center" grow="true" float="bottom">
					<panel height=".5h" />
					<label textvalign="top" textalign="left" font="dyn_12" noclick="1" color="#ffab01" shadow="1" wrap="1" width="100%" fity="true" fitypadding="0.8h">learn_trial</label>
					<label textvalign="top" textalign="left" font="dyn_10" noclick="1" color="yellow" shadow="1" wrap="1" width="100%" fity="true" fitypadding="0.8h" watch="trial_store_info" ontrigger="SetText(Translate('compendium_trial_infohead') # param0 # Translate('compendium_trial_infotail'));">learn_trial</label>
			</panel>
	</floater>

