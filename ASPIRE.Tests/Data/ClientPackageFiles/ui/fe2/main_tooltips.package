	<floater width="25h" x="22" y="-22" grow="true" name="simple_hero_list_tip" color="invisible" visible="false">
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
			<panel width="-1.5h" align="center" grow="true" float="bottom">
					<panel height=".5h" />
					<label textvalign="top" textalign="left" font="dyn_11" noclick="1" color="#ffab01" shadow="1" wrap="1" width="100%" fity="true" fitypadding="0.8h" watch="SimpleHeroItemTooltip" ontrigger="SetText(param0);">compendium_hero_name</label>
					<panel grow="true" width="100%" float="right" padding=".25h">
						<label textvalign="top" textalign="left" font="dyn_10" color="yellow" shadow="true" fitx="true" fity="true">compendium_primary_atrib</label>
						<label textvalign="top" textalign="left" font="dyn_10" color="white" shadow="true" fitx="true" fity="true" watch="SimpleHeroItemTooltip" ontrigger="SetText(param1);">compendium_attrib_types</label>
					</panel>
					<panel grow="true" width="100%" float="right" padding=".25h">
						<label textvalign="top" textalign="left" font="dyn_10" color="yellow" shadow="true" fitx="true" fity="true">compendium_attack_type</label>
						<label textvalign="top" textalign="left" font="dyn_10" color="white" shadow="true" fitx="true" fity="true" watch="SimpleHeroItemTooltip" ontrigger="If(param2 == 1, SetText(Translate('tooltip_attack_type_melee')), SetText(Translate('tooltip_attack_type_range')));">compendium_melee_range</label>
					</panel>
					<panel grow="true" width="100%" float="right" padding=".25h" watch="SimpleHeroItemTooltip" ontrigger="SetVisible(!StringEmpty(param3))">
						<label textvalign="top" textalign="left" font="dyn_10" color="yellow" shadow="true" fitx="true" fity="true">compendium_trial_info</label>
						<label textvalign="top" textalign="left" font="dyn_10" color="white" shadow="true" fitx="true" fity="true" watch="SimpleHeroItemTooltip" ontrigger="SetText(Translate('compendium_trial_infohead') # param3 # Translate('compendium_trial_infotail'));">compendium_trial_infohead</label>
					</panel>
					<panel height="1.0h" />
			</panel>
	</floater>

	<floater width="25h" x="22" y="-22" grow="true" name="trial_avatar_tip" color="invisible" visible="false">
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
			<panel width="-1.5h" align="center" grow="true" float="bottom">
					<panel height=".5h" />
					<label textvalign="top" textalign="left" font="dyn_12" noclick="1" color="#ffab01" shadow="1" wrap="1" width="100%" fity="true" fitypadding="0.8h">learn_trial</label>
					<label textvalign="top" textalign="left" font="dyn_10" noclick="1" color="yellow" shadow="1" wrap="1" width="100%" fity="true" fitypadding="0.8h" watch="trial_avatar_info" ontrigger="SetText(Translate('compendium_trial_infohead') # param0 # Translate('compendium_trial_infotail'));">learn_trial</label>
			</panel>
	</floater>

