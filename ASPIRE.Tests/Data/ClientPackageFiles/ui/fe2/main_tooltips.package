				</panel>
				<panel height="1.5h" float="right">
					<label width="9h" textvalign="center" font="dyn_10" noclick="true" color="#42c7ee" name="progstats_spoil_imm_lbl" content="progstats_immortal" />
					<label width="4h" textalign="center" textvalign="center" font="dyn_10" noclick="true" color="#8e00ec" name="progstats_spoil_imm_xp" onevent0="SetText(FtoA(_progstats_imm_xp, 0));" />
					<label width="4h" textalign="center" textvalign="center" font="dyn_10" noclick="true" color="#FFCC00" name="progstats_spoil_imm_gold" onevent0="SetText(FtoA(_progstats_imm_gold, 0));" />
				</panel>
				<panel height="1.0h" color="invisible" noclick="true"/>
			</panel>
	</floater>



