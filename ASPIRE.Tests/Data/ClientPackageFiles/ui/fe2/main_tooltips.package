					<label width="9h" textvalign="center" font="dyn_10" noclick="true" color="#42c7ee" name="progstats_spoil_blood_lbl" content="progstats_bloodlust" />
					<label width="4h" textalign="center" textvalign="center" font="dyn_10" noclick="true" color="#8e00ec" name="progstats_spoil_blood_xp" onevent0="SetText(FtoA(_progstats_blood_xp, 0));" />
					<label width="4h" textalign="center" textvalign="center" font="dyn_10" noclick="true" color="#FFCC00" name="progstats_spoil_blood_gold" onevent0="SetText(FtoA(_progstats_blood_gold, 0));" />
