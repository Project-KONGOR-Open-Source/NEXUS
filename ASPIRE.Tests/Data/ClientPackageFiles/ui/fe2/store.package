	<trigger name="MicroStoreDurationChoice"/>
	<trigger name="MicroStoreUpdatePayStyleChoice"/>
	<trigger name="MicroStoreUpdatePaging"/>
	<trigger name="MicroStoreUpdateCategory"/>
	<trigger name="MicroStoreUpdateCoins"/>
	<trigger name="MicroStoreUpdatePackages"/>
	<trigger name="UpdatePurchaseCoinsForm"/>
	<trigger name="MicroStoreStatus"/>
	<trigger name="MicroStoreResults"/>
	<trigger name="MicroStoreErrorID"/>
	<trigger name="MicroStoreGetCDPrice"/>
	
	<trigger name="MicroStoreSetProcTrig"/>
	<trigger name="MicroStoreProcessing"/>
	<trigger name="MicroStoreBundlePreview"/>
	<trigger name="MicroStoreVoicePreview"/>
	<trigger name="MicroStoreBundleItem"/>
	<trigger name="MicroStorePopulateTokensPasses"/>
	<trigger name="MicroStoreSaveTempChargeData"/>
	
	<!-- Vault-specific -->
	
	<trigger name="vaultPopulate"/>
	<trigger name="vaultPopulatePage"/><!--  -->
	<trigger name="MicroStorePageCount"/><!-- Triggered to calculate total pages for vault (param0 is total items and param1 is per page -->
	
	<!-- Per MicroStoreItemAgainstUpgrade, MicroStoreSelectedUpgrade is triggered for all items in the category to see if one is selected. -->
	<trigger name="MicroStoreSelectedUpgrade"/>
	<trigger name="MicroStoreItemAgainstUpgrade"/>
	<trigger name="MicroStoreSelectedUpgradeListed"/>

	<trigger name="MicroStoreVaultThrottle"/>
	<trigger name="refreshVaultViewShelfCfg"/>
	<trigger name="refreshVaultViewBookCfg"/>
	
	<trigger name="mStoreAppendFormErrors"/>
	<trigger name="PreviewAnnouncerText"/>
	<trigger name="mstoreSaveTempString"/>
	<trigger name="mstoreBuildAvatarsString"/>
	<trigger name="mstoreBuildHeroListString"/>
	<trigger name="mstoreSplitAvatarProductCode"/>
	<trigger name="mstoreSplitAvatarProductCode2"/>
	<trigger name="mstoreSplitAvatarProductCode3"/>
	
	<if condition="!cl_GarenaEnable">
		<form
			name="MicroStore"
			host="!masterserver"
			method="post"
			target="/store_requester.php"
			statustrigger="MicroStoreStatus"
			resulttrigger="MicroStoreResults"
			resultparam0="responseCode"
			resultparam1="popupCode"
			resultparam2="productIDs"
			resultparam3="productNames"
			resultparam4="productPrices"
			resultparam5="productAlreadyOwned"
			resultparam6="productIsBundle"
			resultparam7="productQuantity"
			resultparam8="totalPages"
			resultparam9="totalPoints"
			resultparam10="productWebContent"
			resultparam11="productDescription"
			resultparam12="productLocalContent"
			resultparam13="categoryID"
			resultparam14="currentPage"
			resultparam15="errorCode"
			resultparam16="packagePrices"
			resultparam17="packagePoints"
			resultparam18="packageIDs"
			resultparam19="packageSpecial"
			resultparam20="productCodes"
			resultparam21="vaultCategory2"
			resultparam22="vaultCategory3"
