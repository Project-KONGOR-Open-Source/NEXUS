			CreateInt('_microStore_accIconUnlockSilverCost', -1);
			CreateInt('_microStore_TotalCoins', -1);
			CreateInt('_microStore_TotalSilverCoins', -1);
			CreateInt('_microStore_PremiumCurrency', 0);
