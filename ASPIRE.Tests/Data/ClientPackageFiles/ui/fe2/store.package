<?xml version="1.0" encoding="UTF-8"?>
<package>
	
	<include file="store_promo.package"/>
	<include file="store_templates.package"/>
	<include file="store_earlyaccess.package"/>
	<include file="store_featured.package"/>
	<include file="store_heroavatardisplay.package"/>
	<include file="store_herodisplay.package"/>
	<include file="store_form_buycoins.package"/>
	<include file="store_form_namechange.package"/>
	<include file="store_form_redeemcode.package"/>
	<include file="store_popups.package"/>
	<include file="/content/store_avatars.package"/>
	
	<if condition="cl_GarenaEnable">
		<include file="store_form_resetstats_garena.package"/>
	</if>

	<if condition="!cl_GarenaEnable">
		<include file="store_form_resetstats.package"/>
		<include file="store_form_subaccount.package"/>
	</if>

	<lua file="/ui/scripts/store.lua" />	

	<cvar name="ui_isInWalkthrough" value="0" />

	<trigger name="populateHeroAvatarBundleInfo"/>
	<trigger name="UpdatePurchaseGiftForm" />
	<trigger name="vaultRefreshConfigButtons"/>
	<trigger name="vaultConfigureProduct"/>
	<trigger name="MicroStoreAddAvatarData"/>
	<trigger name="MicroStoreAvatarItem"/>
	<trigger name="MicroStoreUpdateSelection"/>
	<trigger name="MicroStoreUpdateChargeChoices"/>
	<trigger name="MicroStoreUpdateDurationChoices"/>
