	<!-- Generally split between init and action -->

	<panel color="invisible" noclick="true"
		onload="
			CreateInt('mtoreCRemainTempQuantity', -1);
			CreateInt('mtoreCRemainTempStartTime', -1);
			CreateInt('mtoreCRemainTempEndtime', -1);
			CreateInt('mstoreAvatarSortMode', 4);
			CreateInt('mstoreHeroSortMode', 5);
			CreateInt('mstoreAvatarDisplayMode', 0);
			CreateInt('microStoreTargetPurchaseID', -1);
			CreateInt('microStoreGetCDPriceItem', -1);
			CreateInt('microStoreGetCDPriceView', -1);
			CreateInt('microStoreTempCDGold', -1);
			CreateInt('microStoreTempCDSilver', -1);
			CreateInt('microStoreCDPriceGold', -1);
			CreateInt('microStoreCDPriceSilver', -1);
			CreateString('microStoreIDList', '');
			CreateString('microStoreTimes', '');
			CreateInt('_microStore_itemDurationChoice', 0);
			CreateInt('_microStore_itemExpirationChoice', 0);
			CreateInt('_microStore_lastTimestamp', 0);
			CreateBool('_mstore_lastVerified', UIIsVerified);
			CreateBool('_mstore_frontpage_dev', false);
			CreateBool('_microStore_initialResponse', false);
			CreateInt('microStoreView', 1);
