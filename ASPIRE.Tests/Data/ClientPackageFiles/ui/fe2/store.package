			resultparam42="tauntUnlockCost"
			resultparam43="customAccountIcon"
			resultparam44="customAccountIconCost"
			resultparam45="customAccountIconCostMMP"
			resultparam46="timestamp"
			resultparam47="productTimes"
			resultparam48="vaultCategory72"
			resultparam49="is_newly_verified"
			resultparam50="purchasable"
			resultparam51="productCharges"
			resultparam52="productDurations"
			resultparam53="chargesRemaining"
			resultparam54="unlockAccountIconsCostMMP"
