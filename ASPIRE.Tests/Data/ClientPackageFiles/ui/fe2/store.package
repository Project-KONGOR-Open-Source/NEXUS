			CreateInt('_microStore_Category', -1);
			CreateInt('_microStore_RequestCode', 1);
			CreateInt('_microStore_SelectedItem', -1);
			CreateInt('_microStore_SelectedID', -1);
			CreateInt('_microStore_tempInt', -1);
			CreateInt('_microStore_buyCoins_package', -1);
			CreateInt('_microStore_nextAction', -1);
			CreateInt('_microStoreGiftsRemaining', 0);
			CreateString('_microStoreSantaTarget', '');
			CreateBool('_microStore_overrideConfirmName', false);
			CreateBool('_microStore_resetStats_psr', false);
			CreateBool('_microStore_resetStats_pubstats', false);
			CreateBool('_microStore_resetStats_smr', false);
			CreateBool('_microStore_resetStats_normalmm_stats', false);
			CreateBool('_microStore_resetStats_casualmm_stats', false);
			CreateBool('_microStore_resetStats_casual_mmr', false);
			CreateBool('_microStore_resetStats_midwars_mmr', false);
			CreateBool('_microStore_resetStats_midwars_stats', false);
			CreateInt('microStorePackageID1', -1);
			CreateInt('microStorePackageID2', -1);
			CreateInt('microStorePackageID3', -1);
			CreateInt('microStorePackageID4', -1);
			CreateInt('microStorePackageID5', -1);
			CreateFloat('microStorePackagePrice0', -1);
			CreateFloat('microStorePackagePrice1', -1);
			CreateFloat('microStorePackagePrice2', -1);
			CreateFloat('microStorePackagePrice3', -1);
			CreateFloat('microStorePackagePrice4', -1);
			CreateFloat('microStorePackagePrice5', -1);
			CreateFloat('microStoreCurrencyToCoin', -1);
			CreateInt('microStorePackageCoins1', -1);
			CreateInt('microStorePackageCoins2', -1);
			CreateInt('microStorePackageCoins3', -1);
			CreateInt('microStorePackageCoins4', -1);
			CreateInt('microStorePackageCoins5', -1);
			CreateString('microStorePackageTextures1', '');
			CreateString('microStorePackageTextures2', '');
			CreateString('microStorePackageTextures3', '');
			CreateString('microStorePackageTextures4', '');
			CreateString('microStorePackageTextures5', '');
			CreateBool('microStorePackageSpecial1', false);
			CreateBool('microStorePackageSpecial2', false);
			CreateBool('microStorePackageSpecial3', false);
			CreateBool('microStorePackageSpecial4', false);
			CreateBool('microStorePackageSpecial5', false);
			CreateBool('_microStoreFirstVisit', false);
			CreateString('microStore_vaultData3', '');
			CreateString('microStore_vaultData4', '');
			CreateString('microStore_vaultData5', '');
			CreateString('microStore_vaultData6', '');
