	<floater width="25h" grow="true" color="invisible" x="22" y="-22" visible="false" name="mstore_tip_ext_3">
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
		<panel align="center" width="-1h" grow="true" float="bottom" padding="0.5h">
				<panel width="100%" grow="true" float="bottom">
					<label height="3h" textvalign="center" color="#FFCC00" font="dyn_11" content="mstore_category3"/>
					<label fity="true" wrap="true" font="dyn_10" color="white" content="mstore_exttip_accounticons"/>
					<panel height="0.5h"/>
					<label height="2.5h" textvalign="center" color="#FFFF00" font="dyn_10" content="mstore_chatlist"/>
					<panel height="2.5h">
						<image noclick="true" height="100%" width="800@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/examples/accounticon_chat.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
					</panel>
					<label height="2.5h" textvalign="center" color="#FFFF00" font="dyn_10" content="mstore_gamelobby"/>
					<panel height="6h" width="10h">
						<image noclick="true" height="100@" width="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/examples/accounticon_gamelobby.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
					</panel>
					<panel height="0.5h"/>
					<label height="2.5h" textvalign="center" color="#FFFF00" font="dyn_10" content="player_stats_header"/>
					<panel height="5h">
						<image noclick="true" height="100%" width="400@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/examples/preview_stats.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
					</panel>
				</panel>
			<panel height="0"/>
		</panel>
	</floater>

