		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
		<panel align="center" width="-1h" grow="true" float="bottom" padding="0.5h">
				<panel width="100%" grow="true" float="bottom">
					<label height="3h" textvalign="center" color="#FFCC00" font="dyn_11" content="mstore_category75"/>
					<label fity="true" wrap="true" font="dyn_10" color="white" content="mstore_exttip_enhancements"/>
					<panel height="0.5h"/>
					<label height="2.5h" textvalign="center" color="#FFFF00" font="dyn_10" content="mstore_chatlist"/>
					<panel height="75@">
						<image name="mstore_tip_enhancements_image" noclick="true" height="100%" width="800@" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/examples/enhancement_ingame.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" />
					</panel>

					<panel height="2.5h">
					</panel>
				</panel>
			<panel height="0"/>
		</panel>
	</floater>

	<!-- Empty CAI Slot Tooltip -->
	<floater
		name="empty_custom_slot_tip"
		grow="true" x="22" y="-22" width="34.0h"
		visible="false"
	>
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .85" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />

		<panel y="0.8h" width="-1.6h" height="3.6h" align="center" float="right" padding="0.5h">
			<!-- Icon -->
			<panel width="100@" height="100%">
				<image onshow="SetTexture('/ui/fe2/store/icons/custom_icon.tga');" resourcecontext="store" />
				<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1"/>
			</panel>
			<!-- Name / Lvl -->
			<panel width="-120@" height="100%" float="bottom" padding="0">
				<label fity="true" font="dyn_12" color="#ffab01" shadow="true" content="mstore_custom_openslot" />
				<label fity="true" font="dyn_10" color=".8 .8 .8 1" shadow="true" content="mstore_custom_openslot2" />
			</panel>
		</panel>

		<panel grow="true" y="5.2h" width="-1.6h" align="center" float="bottom">
			<label fity="true" fitypadding="0.5h" font="dyn_10" color="1 1 1 1" shadow="true" wrap="true" content="mstore_custom_openslot_inst" />
			<label fity="true" fitypadding="0.8h" font="dyn_10" color="#3abde7" shadow="true" textalign="left" content="mstore_custom_openslot_url" />
		</panel>
	</floater>
	
	<!-- CAI Slot FAQ Tooltip -->
	<floater
		name="custom_slot_faq_tip"
		grow="true" x="22" y="-22" width="40.0h"
		visible="false"
	>
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .85" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />

		<panel y="0.8h" width="-1.6h" height="3.6h" align="center" float="right" padding="0.5h">
			<!-- Icon -->
			<panel width="100@" height="100%">
				<image onshow="SetTexture('/ui/fe2/store/icons/custom_icon.tga');" resourcecontext="store" />
				<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1"/>
			</panel>
			<!-- Name / Lvl -->
			<panel width="-120@" height="100%" float="bottom" padding="0">
				<label fity="true" font="dyn_12" color="#ffab01" shadow="true" content="mstore_custom_faq_title" />
				<label fity="true" font="dyn_10" color=".8 .8 .8 1" shadow="true" content="mstore_custom_faq_title2" />
			</panel>
		</panel>
		<panel grow="true" y="5.2h" width="-1.6h" align="center" float="bottom">
			<label fity="true" fitypadding="0.3h" font="dyn_10" color="#3abde7" shadow="true" textalign="left" content="mstore_custom_faq_Q1" />
			<label fity="true" fitypadding="1.0h" font="dyn_10" color="1 1 1 1" shadow="true" wrap="true" content="mstore_custom_faq_A1" />			
			<label fity="true" fitypadding="0.3h" font="dyn_10" color="#3abde7" shadow="true" textalign="left" content="mstore_custom_faq_Q2" />
			<label fity="true" fitypadding="1.0h" font="dyn_10" color="1 1 1 1" shadow="true" wrap="true" content="mstore_custom_faq_A2" />			
			<label fity="true" fitypadding="0.3h" font="dyn_10" color="#3abde7" shadow="true" textalign="left" content="mstore_custom_faq_Q3" />
			<label fity="true" fitypadding="1.0h" font="dyn_10" color="1 1 1 1" shadow="true" wrap="true" content="mstore_custom_faq_A3" />
		</panel>
	</floater>
		
	
</package>
