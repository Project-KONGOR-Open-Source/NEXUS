			<label name="playerdata_entryhero_{team}{slot}{category}" x="{x}" y="2h" align="{align}" textalign="{textalign}" shadow="1" shadowcolor="0 0 0 1" shadowoffsetx="1.4h" shadowoffsety="1.3h" color="white" font="dyn_9" noclick="1"/>
			<label name="playerdata_entrykda_{team}{slot}{category}" x="{x}" y="4h" align="{align}" textalign="{textalign}" shadow="1" shadowcolor="0 0 0 1" shadowoffsetx="1.4h" shadowoffsety="1.3h" color="white" font="dyn_9" noclick="1"/>
		</panel>
	</template>

	<template name="watch_system_minimap_hero">
		<panel name="watch_system_minimap_hero_{team}{slot}{category}" align="left" valign="top" width="1" height="1" noclick="1" x="{x}" y="{y}" color="red" >
			<image name="watch_system_minimap_hero_{team}{slot}{category}_0" align="center" valign="center" width="1.35h" height="1.35h" texture="/shared/icons/minimap_hero0.tga" color="{color}"/>
			<image name="watch_system_minimap_hero_{team}{slot}{category}_1" align="center" valign="center" width="1.35h" height="1.35h" texture="/shared/icons/minimap_hero1.tga" color="green"/>
		</panel>
	</template>

	<template name="watch_system_minimap_building">
		<panel name="watch_system_minimap_building_{team}{slot}{category}{type}" width="1h" height="1h" x="{x}" y="{y}" noclick="1">
			<image name="watch_system_minimap_building_{team}{slot}{category}{type}_img" align="center" valign="center" width="{size}" height="{size}" texture="{texture}" color="{color}" noclick="1"/>
		</panel>
	</template>

	<template name="watch_system_minimap">
		<!-- the size of the panel need to fit ws_map_bord.tga -->
		<panel name="watch_system_minimap_{category}" x="{x=50h}" y="{y=30h}" width="31.1h" height="31.1h" align="{align}" valign="{valign}" noclick="1">
			<!-- the background image -->
			<image name="watch_system_minimap_icon_{category}" width="100%" height="100%" align="center" valign="center" texture="$invis" noclick="1"/>
			<!-- boarder -->
			<image width="48h" height="48h" y="-0.2h" align="center" valign="center" texture="/ui/elements/watch_system/ws_map_bord.tga" noclick="1"/>

			<!-- Buildings and heroes should be spawned here -->
			<panel name="watch_system_minimap_buildings_{category}" noclick="1"/>
			<panel name="watch_system_minimap_heroes_{category}" noclick="1"/>

			<!-- win team -->
			<panel name="watch_system_minimap_win_team_{category}" visible="0" color="0 0 0 0.7" noclick="1">
				<image name="watch_system_minimap_win_team_icon_{category}" y="2h" width="18h" height="18h" align="center" texture="$black" noclick="1"/>
				<image y="18h" width="24h" height="6h" align="center" texture="/ui/elements/watch_system/win.tga" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="watch_system_team_kills">
		<panel name="watch_system_team_kills_{category}{team}" x="{x}" y="{y}" align="{align}" width="10h" height="3.5h" noclick="1">
			<label name="watch_system_team_kills_label_{category}{team}" align="center" valign="center" textalign="center" textvalign="center" outline="1" outlinecolor="black" color="white" font="dyn_18" content="" noclick="1"/>
		</panel>
	</template>

	<template name="matches_selected">
		<panel name="matches_selected_{category}" noclick="true"
			align="right"
			x="-1.7h"
			width="60%"
			onshowlua=""
			onhidelua=""
		>
			<image texture="/ui/elements/watch_system/line.tga" align="left" x="-2h" y="19h" width="24h" height="6h" noclick="1"/>

			<!-- Players Left -->
			<panel x="0.75h" y="-8h" width="27%" height="40%" align="left" valign="center" noclick="1">
				<instance name="watch_system_playerdata" y="0h" x="6.5h" align="left" textalign="left" category="{category}" team="1" slot="1"/>
				<instance name="watch_system_playerdata" y="7h" x="6.5h" align="left" textalign="left" category="{category}" team="1" slot="2"/>
				<instance name="watch_system_playerdata" y="14h" x="6.5h" align="left" textalign="left" category="{category}" team="1" slot="3"/>
				<instance name="watch_system_playerdata" y="21h" x="6.5h" align="left" textalign="left" category="{category}" team="1" slot="4"/>
				<instance name="watch_system_playerdata" y="28h" x="6.5h" align="left" textalign="left" category="{category}" team="1" slot="5"/>
			</panel>

			<image texture="/ui/elements/watch_system/line.tga" align="right" x="2h" y="19h" width="24h" height="6h"/>

			<!-- Players Right -->
			<panel x="-0.75h" y="-8h" width="27%" height="40%" align="right" valign="center" noclick="1">
				<instance name="watch_system_playerdata" y="0h" x="-6.5h" align="right" textalign="right" category="{category}" team="2" slot="1"/>
				<instance name="watch_system_playerdata" y="7h" x="-6.5h" align="right" textalign="right" category="{category}" team="2" slot="2"/>
				<instance name="watch_system_playerdata" y="14h" x="-6.5h" align="right" textalign="right" category="{category}" team="2" slot="3"/>
				<instance name="watch_system_playerdata" y="21h" x="-6.5h" align="right" textalign="right" category="{category}" team="2" slot="4"/>
				<instance name="watch_system_playerdata" y="28h" x="-6.5h" align="right" textalign="right" category="{category}" team="2" slot="5"/>
			</panel>

			<!-- team kills -->
			<instance name="watch_system_team_kills" x="5h" y="15h" align="left" category="{category}" team="1"/>
			<instance name="watch_system_team_kills" x="-5h" y="15h" align="right" category="{category}" team="2"/>

			<!-- elapsed time -->
			<panel name="watch_system_elapsed_time_{category}" x="1.4h" y="12.2h" width="18h" height="3h" align="center" visible="0" noclick="1">
				<image texture="/ui/elements/watch_system/match_clock.tga" width="3h" height="3h" noclick="1"/>
				<label name="watch_system_elapsed_time_label_{category}" x="3h" width="-3h" valign="center" textvalign="center" font="dyn_10" color="#808080" outline="1" outlinecolor="black" content="" noclick="1"/>
			</panel>

			<!-- Minimap -->
			<instance name="watch_system_minimap" align="center" x="0h" y="16.5h" category="{category}"/>

			<!-- Start Watching -->
			<!-- not start -->
			<instance name="watch_system_button_status" nameid="{category}_notstart" label="watch_system_button_status_notstart" y="4.5h" align="center" valign="center" visible="false"/>
			<!-- preparing -->
			<instance name="watch_system_button_status" nameid="{category}_preparing" label="watch_system_button_status_preparing" y="4.5h" align="center" valign="center" visible="false"/>
			<!-- replay -->
			<instance name="watch_system_button" nameid="{category}_replay" visible="false" label="main_button_view_replay" y="4.5h" align="center" valign="center" onclicklua="Watch_System.StartWatch()"/>
			<!-- live -->
			<instance name="watch_system_button" nameid="{category}" label="watch_system_startwatch" y="4.5h" align="center" valign="center" onclicklua="Watch_System.StartWatch()"/>

		</panel>
	</template>

	<template name="watch_system_bg">
		<panel noclick="1">
			<image x="-35.35h" y="-2.25h" width="96h" height="96h" align="left" valign="top" texture="/ui/elements/watch_system/bg.tga" hflip="true" noclick="1"/>
			<image x="35.35h" y="-2.25h" width="96h" height="96h" align="right" valign="top" texture="/ui/elements/watch_system/bg.tga" noclick="1"/>
		</panel>
	</template>

	<template name="watch_system_match_list_bg">
		<panel noclick="1">
			<frame align="center" height="100.5%" y="-0.4h" texture="/ui/elements/watch_system/frames/border_ml.tga" borderthickness="2.5h" blockinput="0" noclick="1" color="1 1 1 0.5"/>
		</panel>
	</template>

	<template name="live_match_item_empty_bg">
		<panel width="42.5h" height="15.15h" noclick="1">
			<image y="-0.75h" width="48h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/live_match_item_empty_bg.tga" noclick="1"/>
		</panel>
	</template>

	<template name="live_match_item_team_heroes">
		<panel width="13h" align="{align}" float="right" padding="0.30h" >
			<image name="live_match_item_team_heroes_{id}{team}0" width="100@" height="100%" texture="{hero0='/heroes/adeve/icon.tga'}" noclick="1"/>
			<image name="live_match_item_team_heroes_{id}{team}1" width="100@" height="100%" texture="{hero1='/heroes/adeve/icon.tga'}" noclick="1"/>
			<image name="live_match_item_team_heroes_{id}{team}2" width="100@" height="100%" texture="{hero2='/heroes/adeve/icon.tga'}" noclick="1"/>
			<image name="live_match_item_team_heroes_{id}{team}3" width="100@" height="100%" texture="{hero3='/heroes/adeve/icon.tga'}" noclick="1"/>
			<image name="live_match_item_team_heroes_{id}{team}4" width="100@" height="100%" texture="{hero4='/heroes/adeve/icon.tga'}" noclick="1"/>
		</panel>
	</template>

	<template name="live_match_item">
		<panel name="live_match_item_{id}" width="42.5h" height="15.15h" noclick="1">
			<!-- background -->
			<image y="-0.15h" width="48h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/live_match_item_bg.tga" noclick="1"/>

			<panel x="1.25h" y="0.75h" width="15h" height="2h" noclick="1">
				<label name="live_match_item_elapsed_time_{id}" textalign="left" textvalign="center" font="dyn_10" color="#ffffff" outline="1" outlinecolor="black" content="{elapsed_time}" noclick="1"/>
			</panel>

			<panel x="18h" y="0.5h" width="12h" height="2h" noclick="1">
				<label name="live_match_item_view_num_{id}" textalign="left" textvalign="center" font="dyn_10" color="#b3b3b3" outline="1" outlinecolor="black" content="{view_num}" noclick="1"/>
			</panel>

			<panel x="12.5h" y="3.25h" width="29.25h" height="3h" noclick="1">
				<label name="live_match_item_name_{id}" width="-1h" align="center" textalign="center" textvalign="center" font="dyn_16" color="#ffffff" outline="1" outlinecolor="black" content="{match_name}" noclick="1"/>
			</panel>

			<panel x="12.5h" y="7.5h" width="29.25h" height="3h" noclick="1">
				<label name="live_match_item_team_name_{id}" width="-1h" align="center" textalign="center" textvalign="center" font="dyn_12" color="#d4d4d4" outline="1" outlinecolor="black" content="{team_name}" noclick="1"/>
			</panel>

			<panel x="12.5h" y="12h" width="29.25h" height="2.35h" noclick="1">
				<instance name="live_match_item_team_heroes" id="{id}" team="1" align="left" hero0="{hero10}" hero1="{hero11}" hero2="{hero12}" hero3="{hero13}" hero4="{hero14}"/>
				<instance name="live_match_item_team_heroes" id="{id}" team="2" align="right" hero0="{hero20}" hero1="{hero21}" hero2="{hero22}" hero3="{hero23}" hero4="{hero24}"/>
			</panel>

			<panel x="1.25h" y="3.75h" width="10h" height="10h" noclick="1">
				<image name="live_match_item_map_{id}" align="center" valign="center" texture="{map}" noclick="1"/>

				<panel height="1.5h" valign="bottom" noclick="1">
					<label name="live_match_item_map_name_{id}" valign="bottom" textalign="center" textvalign="bottom" font="dyn_8" color="#929290" outline="1" outlinecolor="black" content="{mapname}" noclick="1"/>
				</panel>
			</panel>

			<panel align="right" width="12h" height="12h" noclick="1">
				<image name="live_match_item_flag_{id}1" texture="{tournament}" visible="{is_tournament=false}" noclick="1"/>
				<image name="live_match_item_flag_{id}2" texture="{starplayer}" visible="{is_starplayer=false}" noclick="1"/>
				<image name="live_match_item_flag_{id}3" texture="{newmap}" visible="{is_newmap=false}" noclick="1"/>
			</panel>

			<panel name="live_match_item_{id}_glow" visible="false" noclick="1">
				<modelpanel
					align="left"
					valign="top"
					noclick="1"
					model="/ui/common/models/main/button3.mdf"
					anim="idle"
					camerapos="0 -150 0"
					cameraangles="0 0 0"
					camerafov="80.5"
					carmerafar="7000"
					depthclear="false"
					depthcompress="true"
					sunazimuth="140"
					sunaltitude="10"
					suncolor="1.4 1.3 1"
					onshow="SetEffect('/ui/common/models/main/button.effect'));"
				/>
			</panel>
		</panel>
	</template>

	<template name="match_item_empty_bg">
		<panel width="40.25h" height="18h" noclick="1">
			<image width="48h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/match_item_empty_bg.tga" noclick="1"/>
		</panel>
	</template>

	<!-- /ui/elements/watch_system/hontour.tga -->
	<template name="watch_system_tour_button">
		<panel name="watch_system_tour_button_{nameid}" x="{x}" y="{y}" width="{width=4h}" height="{height=6h}" align="{align=center}" valign="{valign=center}" visible="{visible=1}" noclick="0">
			<button width="4h" height="6h" align="center" valign="center" color="invisible"
				enabled="{enabled=1}"
				onclick="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onclick}"
				onclicklua="Watch_System.TourClicked('{tour_link}')">
				<widgetstate statename="up">
					<image width="6h" height="6h" align="center" valign="center" url="{tour_icon}" texture="$invis" noclick="1"/>
				</widgetstate>

				<widgetstate statename="over">
					<image width="6h" height="6h" align="center" valign="center" url="{tour_icon}" texture="$invis" rendermode="additive" noclick="1"/>
				</widgetstate>

				<widgetstate statename="down" x="1" y="1">
					<image width="6h" height="6h" align="center" valign="center" url="{tour_icon}" texture="$invis" rendermode="additive" noclick="1"/>
				</widgetstate>

				<widgetstate statename="disabled">
					<image width="6h" height="6h" align="center" valign="center" url="{tour_icon}" texture="$invis" rendermode="normal" noclick="1"/>
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="match_item_team">
		<panel x="{x}" y="{y=3h}" width="12h" height="11h" noclick="1">
			<panel y="0.75h" width="6.5h" height="6.5h" align="center" noclick="1">
				<image width="6h" height="6h" align="center" valign="center" url="{team_icon}" noclick="1"/>
			</panel>

			<panel height="3h" valign="bottom" noclick="1">
				<label name="match_item_team_name_{category}{id}{team_id}" align="center" textalign="center" textvalign="center" font="dyn_12" color="#cccccc" wrap="true" outline="1" outlinecolor="black" content="{team_name}" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="match_item">
		<panel name="match_item_{category}{id}" width="40.25h" height="18h" noclick="1">
				<!-- background -->
				<image y="-0.15h" width="48h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/match_item_bg.tga" noclick="1"/>

				<panel noclick="1">
					<panel x="1.5h" y="0.75h" width="38h" height="2h" noclick="1">
						<label name="match_item_name_{category}{id}" textalign="left" textvalign="center" font="dyn_10" color="#ffffff" shadow="1" shadowcolor="black" content="{itemName=HoN Codex Show Match 1}" noclick="1"/>
					</panel>

					<instance name="match_item_team" x="2h" category="{category}" id="{id}" team_id="1" team_icon="{team1Icon}" team_name="{team1Name}"/>
					<instance name="match_item_team" x="26.25h" category="{category}" id="{id}" team_id="2" team_icon="{team2Icon}" team_name="{team2Name}"/>

					<panel y="-0.65h" width="29.25h" height="3h" align="center" valign="bottom" noclick="1">
						<label name="match_item_time_{category}{id}" width="-1h" align="center" textalign="center" textvalign="center" font="dyn_10" color="#808080" outline="1" outlinecolor="black" content="{matchTime=11:00 pm}" noclick="1"/>
					</panel>

					<!-- debug -->
					<if condition="!releaseStage_stable">
						<panel width="15h" height="3h" align="right" x="-15.5h" y="0h" valign="top" noclick="1">
							<label name="match_item_id_{category}{id}" textalign="right" textvalign="center" font="dyn_10" color="#808080" outline="1" outlinecolor="black" content="id: {status_id}" noclick="1"/>
						</panel>
						<panel width="15h" height="3h" align="right" x="-15.5h" y="1.5h" valign="top" noclick="1">
							<label name="match_item_match_id_{category}{id}" textalign="right" textvalign="center" font="dyn_10" color="#808080" outline="1" outlinecolor="black" content="match_id: {matchID}" noclick="1"/>
						</panel>
					</if>

					<panel y="3.5h" width="6h" height="6h" align="center" noclick="0">
						<instance name="watch_system_tour_button" nameid="match_item_tour_btn_{category}{id}" tour_icon="{tour_icon}" tour_link="{tour_link}" enabled="{enabled}" noclick="1"/>
					</panel>

					<panel width="128i" height="128i" align="right" noclick="1">
						<image name="match_item_status_flag_img_{category}{id}" align="center" valign="center" texture="/ui/elements/watch_system/match_status/{status_img}.tga" noclick="1"/>
					</panel>

					<panel name="match_item_{category}{id}_glow" visible="false" noclick="1">
						<modelpanel
							align="left"
							valign="top"
							noclick="1"
							model="/ui/common/models/main/button4.mdf"
							anim="idle"
							camerapos="0 -70 0"
							cameraangles="0 0 0"
							camerafov="80.5"
							carmerafar="7000"
							depthclear="false"
							depthcompress="true"
							sunazimuth="140"
							sunaltitude="10"
							suncolor="1.4 1.3 1"
							onshow="SetEffect('/ui/common/models/main/button.effect'));"
						/>
					</panel>
				</panel>
			</panel>
	</template>

	<template name="watch_system_battlelog">
		<panel name="watch_system_{category}_battlelog" x="{x=-2.3h}" y="{y=56.5h}" width="71h" height="{height=20.75h}" align="{align=right}" noclick="1">

			<!-- background -->
			<panel y="-0.6h" noclick="1">
				<frame align="center" width="100.8%" height="102.5%" texture="/ui/elements/watch_system/frames/border_cl.tga" borderthickness="2.5h" blockinput="false" noclick="true" color="1 1 1 0.7"/>
			</panel>

			<!-- title -->
			<panel y="0.1h" height="2.65h" noclick="1">
				<image width="96h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/bar.tga" noclick="1"/>
				<label x="1.0h" valign="center" textalign="left" textvalign="center" font="dyn_12" color="#686a6d" outline="1" outlinecolor="black" content="watch_system_battle_log"/>
			</panel>

			<!-- self:AddBufferText('00:08:49 ^352caipan1^* says are you share 11111 ???')
			self:AddBufferText('00:10:19 ^621snq006^* was killed')
			self:AddBufferText('00:11:48 ^352caipan1^* killed by neural creature')
			self:AddBufferText('00:12:50 ^352caipan1^* says - - - - - 11111111111111111111111222223') -->

			<panel x="0h" y="3h" height="{content_height=18h}" noclick="1">
				<textbuffer
					name="watch_system_battlelog_chatbuffer_{category}"
					scrolltexture="/ui/elements/watch_system/info/ws.tga"
					nocompress="true"
					handleheight="5.6h"
					handlewidth="2.8h"
					x="1.0h"
					y="0.2h"
					width="-1.6h" height="{text_height=16.8h}"
					scrollbarsize="1.75h"
					textalign="left"
					font="dyn_12"
					wrap="true"
					anchorbottom="false"
					shadow="true"
					color="invisible"
					textcolor="#999a9a"
					onshowlua="self:ClearBufferText()"
					onhidelua="self:ClearBufferText()"
				/>
			</panel>
		</panel>
	</template>

	<template name="watch_system_bigbutton">
		<panel name="bigbutton_panel_{button_name}_{category}" width="17.65h" height="12.65h" y="{y}" x="{x}" align="{align}" valign="{valign}" noclick="true" visible="{visible=1}">
			<button
				name="{button_name}_{category}"
				y="0"
				numstates="2"
				width="90%"
				height="90%"
				align="center"
				valign="center"
				color="invisible"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				enabled="{enabled=true}"
				onclick="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onclick}"
				onclicklua="{onclicklua}"
				onevent="{onevent}"
				watch="{watch}"
				ontriggerlua="{ontriggerlua}"
				watch1="{watch1}"
				ontrigger1lua="{ontrigger1lua}"
				onshowlua="self:SetButtonState(1)"
			>
				<widgetstate statename="up">
					<image nocompress="true" texture="/ui/elements/watch_system/frames/bb_gradient.tga" borderthickness="2.0h" align="center" valign="center"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" color="white" outline="true" outlinecolor="black" content="{label}"/>
				</widgetstate>
				<widgetstate statename="over">
					<image nocompress="true" texture="/ui/elements/watch_system/frames/bb_gradient_over.tga" borderthickness="2.0h" align="center" valign="center"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}_glow.tga" noclick="1"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" color="white" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>
				<widgetstate statename="down">
					<image nocompress="true" texture="/ui/elements/watch_system/frames/bb_gradient_down.tga" borderthickness="2.0h" align="center" valign="center"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}_glow.tga" noclick="1"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" color="white" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>
				<widgetstate statename="disabled">
					<image nocompress="true" texture="/ui/elements/watch_system/frames/bb_gradient_disabled.tga" borderthickness="2.0h" align="center" valign="center"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" rendermode="grayscale" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" color="gray" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>

				<widgetstate statename="up2">
					<image width="24h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/bigbutton_grey_bg.tga" noclick="1"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>
				<widgetstate statename="over2">
					<image width="24h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/bigbutton_grey_bg.tga" noclick="1"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>
				<widgetstate statename="down2">
					<image width="24h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/bigbutton_grey_bg.tga" noclick="1"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>
				<widgetstate statename="disabled2">
					<image width="24h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/bigbutton_grey_bg.tga" noclick="1"/>
					<image y="-1.1h" width="12h" height="12h" align="center" valign="center" texture="/ui/elements/watch_system/icons/{icon}.tga" rendermode="grayscale" noclick="1"/>
					<label y="7.25h" textalign="center" textvalign="top" font="{font=dyn_12}" shadow="1" color="gray" outline="1" outlinecolor="black" content="{label}"/>
				</widgetstate>
			</button>
			<image nocompress="true" width="24h" height="24h" align="center" valign="center" texture="/ui/elements/watch_system/wr_bigbutton.tga" noclick="1"/>
		</panel>
	</template>

	<template name="watch_system_live">
		<panel name="watch_system_live" visible="0" noclick="1">
			<!-- battle log -->
			<instance name="watch_system_battlelog" category="live" height="34.15h" bg_y="-2.65h" bg_height="39.25h" content_height="31h" text_height="29.6h"/>

			<!-- Selected Match Data -->
			<instance name="watch_system_region_header" category="live"/>
			<instance name="watch_system_live_header"/>
			<instance name="matches_selected" category="live"/>

			<!-- live match list -->
			<panel x="2.25h" y="3.5h" width="44h" height="91%" noclick="1">
				<instance name="watch_system_match_list_bg"/>

				<panel align="center" valign="center" width="-1.5h" height="-1.5h" noclick="1">
					<panel float="bottom" padding="0.75h" noclick="1">
						<instance name="live_match_item_empty_bg"/>
						<instance name="live_match_item_empty_bg"/>
						<instance name="live_match_item_empty_bg"/>
						<instance name="live_match_item_empty_bg"/>
						<instance name="live_match_item_empty_bg"/>
					</panel>

					<listbox
						name="watch_system_live_matches_listbox"
						y="-0.5h"
						align="left"
						valign="top"
						width="100%"
						height="100%"
						itemheight="15h"
						usescrollbars="false"
						vpadding="0.75h"
						hoverselect="false"
						hoverhighlight="true"
						highlight="over"
						highlightcolor=".3 .3 .3 .2"
						highlightbordercolor="invisible"
						color="invisible"
						watch=""
						ontriggerlua=""
						onload=""
						onselect="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onselect}"
						onselectlua="Watch_System.SelectMatch(self)"
						onshowlua="Watch_System.SubscribeLiveMatches(self, 'live')"
						onhidelua="
							Watch_System.UnsubscribeLiveMatches(self)
							Watch_System.UnsubscribeMatchInfo()
						"
					/>
					<instance name="watch_system_pagebar" align="center" valign="bottom" type="live" updatefunc="Watch_System.UpdateLiveList()" />
				</panel>
			</panel>
		</panel>
	</template>

	<template name="watch_system_matches">
		<panel name="watch_system_{category}_matches" visible="0" noclick="1"
		>
			<!-- Selected Match Data -->
			<instance name="watch_system_region_header" category="{category}"/>
			<instance name="matches_selected" category="{category}"/>

			<!-- Battlelog -->
			<instance name="watch_system_battlelog" category="{category}"/>

			<!-- Betting buttons -->
			<panel name="watch_system_{category}_bigbuttons" x="-3h" y="-5.5h" align="right" valign="bottom" height="13h" width="71h" float="right" padding="0.5h" noclick="1">
				<instance name="watch_system_bigbutton" button_name="pick_winner" category="{category}" icon="wr_winner" label="watch_system_pickwinner"/>
				<instance name="watch_system_bigbutton" button_name="tower_crush" category="{category}" icon="wr_firsttower" label="watch_system_picktowercrushed"/>
				<instance name="watch_system_bigbutton" button_name="first_blood" category="{category}" icon="wr_firstblood" label="watch_system_pickfirstblood"/>
				<instance name="watch_system_bigbutton" button_name="ten_kills" category="{category}" icon="wr_firsttenkills" label="watch_system_picktenkills"/>
			</panel>

			<!-- loading panel -->
			<frame
				name="watch_system_loading_{category}"
				texture="/ui/frames/rounded_bg_white.tga"
				color="0 0 0 1"
				x="-1.5h"
				y="-5h"
				align="right"
				valign="bottom"
				width="72.5h"
				height="13.5h"
				borderthickness="0.6h"
				noclick="0"
			>
				<frame texture="/ui/frames/thick.tga" color="#303030" borderthickness="0.6h"/>
				<label width="-1h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_18" color="#c0c0c0" outline="1" outlinecolor="#202020" content="watch_system_match_loading" noclick="1"/>
			</frame>

			<!-- match list -->
			<panel x="2.25h" y="3.5h" width="44h" height="91%" noclick="1">
				<instance name="watch_system_match_list_bg"/>

				<!-- dates -->
				<panel name="watch_system_{category}_matches_dates" x="0.75h" y="0.25h" width="-1.5h" height="3h" float="right" padding="0.5h" noclick="1">
					<instance name="watch_system_date_tab" category="{category}" date="10/2"/>
					<instance name="watch_system_date_tab" category="{category}" date="11/2"/>
					<instance name="watch_system_date_tab" category="{category}" date="12/2"/>
					<instance name="watch_system_date_tab" category="{category}" date="13/2"/>
					<instance name="watch_system_date_tab" category="{category}" date="14/2"/>
					<instance name="watch_system_date_tab" category="{category}" date="15/2"/>
					<instance name="watch_system_date_tab" category="{category}" date="16/2"/>
				</panel>

				<panel y="3.5h" align="center" valign="top" width="-1.5h" height="-4h" clip="1" noclick="1">
					<panel float="bottom" padding="0.5h" noclick="1">
						<instance name="match_item_empty_bg"/>
						<instance name="match_item_empty_bg"/>
						<instance name="match_item_empty_bg"/>
						<instance name="match_item_empty_bg"/>
						<instance name="match_item_empty_bg"/>
					</panel>

					<listbox
						name="watch_system_{category}_listbox"
						height="100%"
						itemwidth="40.25h"
						itemheight="18h"
						itemheightfudge="10h"
						handleheight="5.6h"
						scrollbarsize="1.68h"
						shadow="true"
						handlewidth="2.8h"
						usescrollbars="true"
						scrolltexture="/ui/elements/watch_system/info/ws.tga"
						scrollinterval="0"
						vpadding="0.5h"
						hoverselect="false"
						hoverhighlight="true"
						highlight="over"
						highlightcolor=".3 .3 .3 .2"
						highlightbordercolor="invisible"
						color="invisible"
						watch=""
						ontriggerlua=""
						onload=""
						onselect="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onselect}"
						onselectlua="Watch_System.SelectMatch(self)"
						onshowlua="Watch_System.SubscribeRegionMatches(self, '{category}')"
						onhidelua="
							Watch_System.UnsubscribeRegionMatches(self)
							Watch_System.UnsubscribeMatchInfo()
						"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="watch_system_bethistory_betret">
		<panel width="10h" height="11h" valign="center">
			<panel width="7h" height="2h" align="center" y="0.8h">
				<label color="white" font="dyn_8" textvalign="center" textalign="left" shadow="true" content="{title}"/>
			</panel>
			<panel name="watch_system_bethistory_betret_{id}_{index}_success" visible="0">

				<panel width="8h" height="3h" align="center" y="3h">
					<label color="#ffbf01" font="dyn_12" textvalign="center" textalign="center" shadow="true" content="watch_system_betsuccess"/>
				</panel>
				<panel width="8h" height="3h" align="center" y="5.3h">
					<label name="watch_system_bethistory_betret_{id}_{index}_success_wincoin" color="white" font="dyn_12" textvalign="center" textalign="center" shadow="true" content=""/>
				</panel>
				<panel x="3h" width="2h" height="2h" align="center" y="6h">
					<image align="center" valign="center" texture="/ui/fe2/store/silver_coins.tga" noclick="1"/>
				</panel>
				<panel width="8h" height="2h" align="center" y="7.5h">
					<label color="white" font="dyn_8" textvalign="center" textalign="center" shadow="true" content="watch_system_betearned"/>
				</panel>
				<image texture="/ui/elements/watch_system/succes.tga" width="12h" height="12h" align="center" valign="center" noclick="1"/>
			</panel>

			<panel name="watch_system_bethistory_betret_{id}_{index}_fail" visible="0">
				<panel width="8h" height="3h" align="center" valign="center">
