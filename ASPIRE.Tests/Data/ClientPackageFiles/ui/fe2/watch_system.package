		ssl="false"
		php="false"
	/>

	<form
		name="WatchSystemMatchBetForm"
		method="get"
		host="!ascension"
		target=""
		statustrigger=""
		resulttrigger=""
		resultparam0=""
		ssl="false"
		php="false"
	/>

	<form
		name="WatchSystemSpectateMatchForm"
		method="get"
		host="!ascension"
		target=""
		statustrigger=""
		resulttrigger=""
		resultparam0=""
