				<panel width="1" height="30%" valign="center" color="#555555" noclick="1"/>
				<panel width="5.7h" valign="center" noclick="1">
					<label name="watch_system_live_header_casual_label" font="dyn_12" color="0 .7 1" shadow="1" shadowcolor="0 0 0 1" shadowoffsetx="1.7h" shadowoffsety="1.7h" valign="center" textvalign="center" noclick="1"/>
