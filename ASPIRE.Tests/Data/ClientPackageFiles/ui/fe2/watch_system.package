				</panel>
			</panel>

			<panel name="watch_system_bethistory_betret_{id}_{index}_nobet">
				<panel width="6h" height="6h" align="center" valign="center" y="0.6h">
					<image texture="/ui/elements/watch_system/honlogo.tga"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="watch_system_bethistory_item">
		<panel name="watch_system_bethistory_item_{id}" width="120h" height="12h" align="center" noclick="1" visible="0">
			<image texture="/ui/elements/watch_system/bethistory_item_bg.tga" width="192h" height="12h" align="center" valign="center"/>
			<panel valign="center" x="2.5h" width="11h" height="3h">
				<label name="watch_system_bethistory_item_{id}_date" color=".7 .7 .7" font="dyn_12" textvalign="center" textalign="center" shadow="true" content=""/>
			</panel>
			<panel valign="center" x="14h" width="20h" height="6h">
				<label name="watch_system_bethistory_item_{id}_name" color="white" font="dyn_12" textvalign="center" textalign="center" wrap="1" shadow="true" content=""/>
			</panel>
			<panel valign="center" x="34h" width="2h" height="3h">
				<label color=".23 .74 .87" font="dyn_12" textvalign="center" textalign="center" shadow="true" content=""/>
			</panel>
			<panel x="-18.5h" width="12h" height="12h" align="center" valign="center">
				<image name="watch_system_bethistory_item_{id}_tournament_icon" width="-4h" height="-4h" texture="$invis" align="center" valign="center"/>
			</panel>

			<panel x="-7h" width="11h" height="-2h" align="center" valign="center">
				<panel y="-2h" width="6.5h" height="6.5h" align="center" valign="center">
					<image name="watch_system_bethistory_item_{id}_clan1_icon" texture="$invis"/>
				</panel>
				<panel valign="bottom" height="4h">
					<label name="watch_system_bethistory_item_{id}_clan1_name" color=".7 .7 .7" font="dyn_12" textvalign="center" textalign="center" shadow="true" wrap="1" content=""/>
				</panel>
			</panel>

			<panel x="10h" width="11h" height="-2h" align="center" valign="center">
				<panel y="-2h" width="6.5h" height="6.5h" align="center" valign="center">
					<image name="watch_system_bethistory_item_{id}_clan2_icon" texture="$invis"/>
				</panel>
				<panel valign="bottom" height="4h">
					<label name="watch_system_bethistory_item_{id}_clan2_name" color=".7 .7 .7" font="dyn_12" textvalign="center" textalign="center" shadow="true" wrap="1" content="PaiN Gaming"/>
				</panel>
			</panel>

			<panel x="-2.1h" align="right" valign="center" width="40.5h" float="right">
				<instance name="watch_system_bethistory_betret" id="{id}" index="1" title="watch_system_bettitle_winner"/>
				<instance name="watch_system_bethistory_betret" id="{id}" index="2" title="watch_system_bettitle_tower"/>
				<instance name="watch_system_bethistory_betret" id="{id}" index="3" title="watch_system_bettitle_1stblood"/>
				<instance name="watch_system_bethistory_betret" id="{id}" index="4" title="watch_system_bettitle_10kills"/>
			</panel>
		</panel>
	</template>

	<template name="watch_system_bet_history">
		<panel name="watch_system_bet_history" visible="0" noclick="1" onshowlua="Watch_System.UpdateBetHistory() Watch_System.GetBetHistory()">
			<frame texture="/ui/elements/watch_system/frames/border_ml.tga" align="center" y="2h" width="117.5h" height="89h" borderthickness="2.5h" blockinput="0" noclick="1" color="1 1 1 0.8"/>
			<panel width="-3h" height="-5h" align="center" valign="center" float="bottom" noclick="1">
				<instance name="watch_system_bethistory_item" id="0"/>
				<instance name="watch_system_bethistory_item" id="1"/>
				<instance name="watch_system_bethistory_item" id="2"/>
				<instance name="watch_system_bethistory_item" id="3"/>
				<instance name="watch_system_bethistory_item" id="4"/>
				<instance name="watch_system_bethistory_item" id="5"/>
				<instance name="watch_system_bethistory_item" id="6"/>
			</panel>
			<instance name="watch_system_pagebar" y="-5.5h" align="center" valign="bottom" type="bethistory" updatefunc="Watch_System.UpdateBetHistory()" />
		</panel>
	</template>

	<template name="watch_system_radiobutton_state">
		<widgetstate statename="{state}">
			<panel width="{size}">
				<image hmargin="0.15h" vmargin="0.15h" texture="/ui/elements/watch_system/cb_unchecked.tga"/>
				<image hmargin="0.15h" vmargin="0.15h" texture="/ui/elements/watch_system/cb_checked.tga" visible="{checked}"/>
			</panel>
			<panel width="-{size}" align="right" >
				<label x="1h" width="-3h" textalign="left" textvalign="center" font="{font}" color="{color}" shadow="1" oninstantiate="{labeloninstantiate}">{label}</label>
				<image x="4.25h" width="2h" height="2h" valign="center" texture="/ui/fe2/store/silver_coins.tga" noclick="1"/>
			</panel>
		</widgetstate>
	</template>

	<template name="watch_system_radiobutton">
		<panel width="{width=90%}" height="{height=1.75h}" align="{align=center}" valign="{valign=top}" onload="{onpreload=}" y="{y=}" noclick="1">
			<button
				name="{radiobutton_name=}"
				color="invisible"
				numstates="2"
				onclick="PlaySound('/shared/sounds/ui/button_click_06.wav'); Set('{cvar=}', '{value=}'); Set('{cvar2=}', '{value2=}'); Set('{cvar3=}', '{value3=}'); GroupCall('{cvar=}_radio_group', 'SetButtonState(0);'); SetButtonState(1); {onclick=}"
				onclicklua="Watch_System.RefreshBetDialog('{value}', '{ratio}')"
				onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
				watch="{watch=}"
				ontrigger="{ontrigger=}"
				enabled="{enabled=true}"
				onload="{onload=}"
				group="{cvar=}_radio_group"
				oninstantiate="{oninstantiate=}"
			>
				<instance name="watch_system_radiobutton_state" state="up" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="white" checked="0" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
				<instance name="watch_system_radiobutton_state" state="over" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#3abde7" checked="0" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
				<instance name="watch_system_radiobutton_state" state="down" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#3abde7" checked="0" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
				<instance name="watch_system_radiobutton_state" state="disabled" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#888888" checked="0" watch="{labelwatch}" ontrigger="{labelontrigger}"/>

				<instance name="watch_system_radiobutton_state" state="up2" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#3abde7" checked="1" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
				<instance name="watch_system_radiobutton_state" state="over2" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#3abde7" checked="1" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
				<instance name="watch_system_radiobutton_state" state="down2" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#3abde7" checked="1" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
				<instance name="watch_system_radiobutton_state" state="disabled2" size="{height=1.75h}" label="{label}" font="{font=dyn_12}" color="#888888" checked="1" watch="{labelwatch}" ontrigger="{labelontrigger}"/>
			</button>
		</panel>
	</template>

	<template name="watch_system_bet_team">
		<panel x="{x}" width="21.85h" height="25.5h" align="{align}" float="bottom" noclick="1">
			<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1"/>
			<anchor y="0"/>
			<panel height="1.5h" noclick="1"/>
			<panel width="9.26h" height="9.26h" align="center" noclick="1">
				<image name="watch_system_bet_team_icon_{team}" align="center" valign="center" texture="/ui/elements/watch_system/team/ddog.tga"/>
			</panel>
			<panel width="-2h" height="3h" align="center" noclick="1">
				<label name="watch_system_bet_team_odds_{team}" font="dyn_10" textalign="center" textvalign="center" color="#8a8a8a" content="win: 1:2.5" noclick="1"/>
			</panel>
			<panel height="1.5h" noclick="1"/>
			<panel name="watch_system_bet_team_container_{team}" width="-10h" height="10h" align="center" float="bottom" padding="1h" noclick="1"/>
		</panel>
	</template>

	<template name="watch_system_bet_dialog">
		<panel name="watch_system_bet_dialog" visible="0"
			onhidelua="GetWidget('watch_system_bet_desc2'):SetText('')"
		>
			<panel width="50.9h" align="center" valign="center" float="bottom" color="black" grow="1" noclick="1">
				<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1"/>
				<anchor y="0"/>
				<instance name="header_bar" label_name="watch_system_bet_dialog_title" height="3h" lbl_font="dyn_12" show_close="1" onclicklua="GetWidget('watch_system_bet_dialog'):SetVisible(false)"/>
				<panel height="3.5h" noclick="1">
					<panel width="-4h" align="center" valign="center" noclick="1">
						<label font="dyn_12" textalign="center" textvalign="center" color="white" content="watch_system_bet_dialog_desc_1" noclick="1"/>
					</panel>
				</panel>

				<panel width="-1h" height="25.5h" align="center" noclick="1">
					<instance name="watch_system_bet_team" x="0.25h" align="left" team="1"/>
					<panel width="6h" height="100%" align="center" noclick="1">
						<image texture="/ui/elements/watch_system/vs.tga" align="center" valign="center" width="16h" height="16h" noclick="1"/>
					</panel>
					<instance name="watch_system_bet_team" x="-0.25h" align="right" team="2"/>
				</panel>

				<panel height="3h" noclick="1">
					<panel width="-2h" align="center" valign="center" noclick="1">
						<label name="watch_system_bet_desc2" font="dyn_12" textalign="left" textvalign="center" color="white" content="" noclick="1"/>
					</panel>
				</panel>

				<panel height="5h" noclick="1">
					<instance name="button2" button_name="watch_system_bet_btn" x="-6h" width="9h" height="3h" label="general_yes" font="dyn_12" align="center" valign="center" onclicklua="GetWidget('watch_system_bet_dialog'):SetVisible(false) Watch_System.DoBet()"/>

					<instance name="button2" x="6h" width="9h" height="3h" label="general_no" font="dyn_12" align="center" valign="center" onclicklua="GetWidget('watch_system_bet_dialog'):SetVisible(false)"/>
				</panel>
				<panel height="0.5h" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="watch_system_bet_floater">
		<floater
			name="{tip_id}"
			x="{x=-24.5h}" y="{y=3h}"
			width="{width=22.0h}"
			align="{align=left}"
			valign="{valign=top}"
			visible="{visible=0}"
			passivechildren="true"
			grow="true"
			noclick="1"
		>
			<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
			<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
				<label
					name="{tip_id}_title"
					x="0.8h" y="0.6h"
					textvalign="top"
					textalign="left"
					align="center"
					font="dyn_10"
					noclick="1"
					color="#ffab01"
					shadow="1"
					wrap="1"
					fity="true"
					fitypadding="0.8h"
					watch="{title_watch}"
					ontrigger="{title_ontrigger}"
				>{title}</label>
				<image x="-0.6h" y="{icony=0.6h}" noclick="1" height="{iconheight=2.5h}" width="{iconwidth=2.5h}" align="right" visible="0" color="{color=1 1 1 1}"
					onload="If(!StringEmpty('{icon}'), Split(SetVisible(1), SetTexture('{icon}')), SetVisible(0));"
				/>
				<panel y="2.5h" width="-1.6h" align="center" noclick="true" grow="true" float="bottom">
					<label
						name="{tip_id}_label"
						textvalign="top"
						textalign="left"
						align="center"
						font="dyn_10"
						noclick="1"
						color="white"
						shadow="1"
						wrap="1"
						fity="true"
						fitxpadding="0"
						watch="{label_watch}" ontrigger="{label_ontrigger}"
					>{label}</label>
					<panel height="1.0h" color="invisible" noclick="true"/>
				</panel>
		</floater>
	</template>

	<template name="watch_system_warning">
		<panel name="watch_system_warning" color="0 0 0 0.8" visible="0" noclick="0"
		>
			<panel y="-10h" width="45h" height="16h" align="center" valign="center">
				<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1"/>
				<instance name="header_bar" close_name="watch_system_warning_btn_close" lbl="watch_system_warning_title" height="3h" lbl_font="dyn_12" show_close="1" onclicklua="GetWidget('watch_system_warning'):SetVisible(false)"/>

				<panel y="3.25h" width="-0.5h" height="-3.5h" align="center" valign="top" noclick="1">
					<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
					<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1"/>

					<panel width="-3h" height="9h" y="0h" align="center">
						<label name="watch_system_warning_label" font="dyn_12" textvalign="center" textalign="center" noclick="true" wrap="true" color="white" content=""/>
					</panel>

					<instance
						name="button2"
						button_name="watch_system_warning_btn_confirm"
						x="0h"
						y="-1.5h"
						width="10h"
						height="2.5h"
						label="general_ok"
						font="dyn_11"
						align="center"
						valign="bottom"
						onclicklua="GetWidget('watch_system_warning'):SetVisible(false)"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- Template of the whole watch system page -->
	<template name="watch_system">
		<panel name="watch_system" y="-210%" align="center" width="-2.7h" visible="{visible=0}" valign="center" noclick="1"
			onload="CreateInt('watch_system_bet_coin', 0);CreateInt('watch_system_bet_item_id', 0);CreateInt('watch_system_bet_id', 0);"
			watch1="ReplayPanel"
			ontrigger1lua="
				self:SetVisible(false)
				local hider = GetWidget('com_hider2')
				if hider ~= nil then hider:SetVisible(false) end
			"
			onshowlua="self:RegisterWatch('ChatStatus', Watch_System.ChatStatus) Watch_System.SubscribeTodayMatch()"
			onhidelua="self:UnregisterWatch('ChatStatus') Watch_System.Reset()"
		>
			<panel x="0" y="-100%" height="203.6%" width="-15@" align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel y="100%" passivechildren="true" noclick="1">
				<panel valign="bottom" y="-2.5h" width="+2h" x="-0.75h">
					<panel width="3.125@" texture="/ui/fe2/frames/slideout_frame_l.tga"/>
					<panel width="3.125@" texture="/ui/fe2/frames/slideout_frame_r.tga" align="right"/>
					<panel width="3.125@" height="3.125%" x="3.125@" valign="bottom" texture="/ui/fe2/frames/slideout_frame_bl.tga"/>
					<panel width="3.125@" height="3.125%" x="-3.125@" valign="bottom" texture="/ui/fe2/frames/slideout_frame_br.tga" align="right"/>
					<panel hmargin="6.25@" height="3.125%" valign="bottom" texture="/ui/fe2/frames/slideout_frame_b.tga"/>
				</panel>
			</panel>

			<panel x="20h" y="-100%" height="203.6%" width="50@" align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-20h" y="-100%" height="203.6%" width="50@" align="left" texture="mainmenu/upper_frame_left.tga"/>

			<panel color="black" y="95%" height="90%" align="center" width="-0.2h" x="0.15h"/>

			<!-- content -->
			<panel y="1h" height="192%" noclick="1">
				<!-- tabs -->
				<panel name="watch_system_tab_container" y="0.25h" height="3.5h" noclick="1">
					<panel name="watch_system_tabs" x="6.5h" y="0h" float="right" padding="0.75h">
						<if condition="cl_GarenaEnable">
							<instance name="watch_system_tab" tabName="live"/>
							<instance name="watch_system_tab" tabName="sea_matches" btnonshowlua="self:SetEnabled(GetRegion() == 'sea')"/>
							<instance name="watch_system_tab" tabName="bet_history" btnonshowlua="self:SetEnabled(false)" />
						</if>						
					</panel>
				</panel>

				<!-- panels -->
				<panel name="watch_system_containers" y="3.75h" width="-1h" align="center" noclick="1">
					<!-- background -->
					<instance name="watch_system_bg"/>

					<instance name="watch_system_live"/>
					<instance name="watch_system_matches" category="sea"/>
					<instance name="watch_system_matches" category="naeu"/>
					<instance name="watch_system_bet_history"/>
				</panel>

				<!-- Compatibilty warning -->
				<panel name="watch_system_replay_compatWarning" color="0 0 0 0.8" visible="0"
					onload="CreateString('watch_system_replay_version', '');"
					watch="WebReplayCompatWarning"
					ontriggerlua="
						self:SetVisible(true)
						Set('watch_system_replay_version', param)
					"
				>
					<panel width="60h" height="21.9h" align="center" valign="center" >
						<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1"/>
						<panel width="-1h" height="-1h" align="center" valign="center">
							<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
							<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1"/>

							<panel width="-3h" height="9h" y="1.5h" align="center">
								<label font="dyn_16" textvalign="center" textalign="left" noclick="true" wrap="true" color="white" content="game_end_stats_download_compat_tooltip"/>
							</panel>

							<instance
								name="button2"
								x="-7.5h"
								y="-1.5h"
								width="12h"
								height="3h"
								label="game_end_stats_compat_btn"
								font="dyn_12"
								align="center"
								valign="bottom"
								onclick="DownloadCompat(watch_system_replay_version);"
								onclicklua="GetWidget('watch_system_replay_compatWarning'):SetVisible(false)"
							/>

							<instance name="button2"
								x="7.5h"
								y="-1.5h"
								width="12h"
								height="3h"
								label="general_cancel"
								font="dyn_12"
								align="center"
								valign="bottom"
								onclicklua="
									GetWidget('watch_system_replay_compatWarning'):SetVisible(false)
									ResetStreamParameters()
								"
							/>
						</panel>
					</panel>
				</panel>

				<!-- Compatibilty archive calculating -->
				<panel width="100%" height="100%" visible="false" color="0 0 0 0.66" align="center" noclick="1" watch="CompatCalculating" ontriggerlua="self:SetVisible(AtoB(param))">
					<panel width="24h" height="9.5h" align="center" valign="center" color="invisible" noclick="1">
						<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
						<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

						<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
							<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_calculating"/>
							<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" content="replay_compat_version"/>

							<instance
								name="button2"
								id="replay_compat_button2"
								y="-0.5h"
								width="13h"
								height="2.2h"
								align="center"
								valign="bottom"
								font="dyn_9"
								label="general_cancel"
								onclick="CancelCompat();"
								enabled="false"
							/>
						</panel>
					</panel>
				</panel>

				<!-- Compatibilty archive downloading -->
				<panel width="100%" height="100%" visible="false" color="0 0 0 0.66" align="center" noclick="1" watch="CompatDownloading" ontriggerlua="self:SetVisible(AtoB(param))">
					<panel width="24h" height="22h" align="center" valign="center" color="invisible" noclick="1">
						<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
						<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

						<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
							<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_downloading"/>
							<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));"/>

							<panel x="1.0h" y="5.0h" width="100%" height="0" align="right" color="invisible" noclick="true" passivechildren="true">
								<label y="0.1h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatFilesLeft" ontrigger="SetText(Translate('replay_compat_files', 'count', param0, 'total', param1));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
								<label y="1.9h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatProgress" ontrigger="SetText(Translate('replay_compat_progress', 'count', param0, 'total', param1));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);"/>
								<label y="3.8h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatSpeed" ontrigger="SetText(Translate('replay_compat_speed', 'speed', param));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);"/>
								<label y="5.7h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatTime" ontrigger="SetText(Translate('replay_compat_time', 'time', param));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);"/>
							</panel>

							<frame
								y="-4.5h"
								width="90%" height="3h"
								align="center" valign="bottom"
								borderthickness="0.3h"
								color="invisible" bordercolor="white"
								watch="CompatPercent" ontrigger="SetVisible(param != 2);"
							>
								<panel x="0.7h" y="0.7h" width="-1.4h" height="-1.4h">
									<panel
										width="50%"
										color="white"
										watch="CompatPercent"
										ontrigger="SetWidth(FtoP(param));"
									/>
								</panel>
							</frame>

							<instance
								name="button2"
								id="replay_compat_button"
								y="-0.5h"
								width="13h"
								height="2.2h"
								align="center"
								valign="bottom"
								font="dyn_9"
								label="general_cancel"
								onclick="CancelCompat();"
								onclicklua="ResetStreamParameters()"
							/>
						</panel>
					</panel>
				</panel>

				<!-- Compatibilty archive writing -->
				<panel width="100%" height="100%" visible="false" color="0 0 0 0.66" align="center" noclick="1" watch="CompatWriting" ontrigger="SetVisible(param);">
					<panel width="24h" height="13.5h" align="center" valign="center" color="invisible" noclick="1">
						<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
						<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

						<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
							<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_writing"/>
							<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" content="replay_compat_version"/>

							<frame
								y="-4.5h"
								width="90%" height="3h"
								align="center" valign="bottom"
								borderthickness="0.3h"
								color="invisible" bordercolor="white"
								watch="CompatWritePercent" ontrigger="SetVisible(param != 2);"
							>
								<panel x="0.7h" y="0.7h" width="-1.4h" height="-1.4h">
									<panel
										width="50%"
										color="white"
										watch="CompatWritePercent"
										ontrigger="SetWidth(FtoP(param));"
									/>
								</panel>
							</frame>

							<instance
								name="button2"
								id="replay_compat_button2"
								y="-0.5h"
								width="13h"
								height="2.2h"
								align="center"
								valign="bottom"
								font="dyn_9"
								label="general_cancel"
								onclick="CancelCompat();"
							/>
						</panel>
					</panel>
				</panel>

				<!-- bet dialog -->
				<instance name="watch_system_bet_dialog"/>

				<instance name="watch_system_warning" />

				<panel name="watch_system_match_info_helper" width="1" height="1" noclick="1"/>
				<panel name="watch_system_refresh_today_match_helper" width="1" height="1" noclick="1"/>
				<panel name="watch_system_refresh_match_bet_info_helper" width="1" height="1" noclick="1"/>
			</panel>

			<instance name="watch_system_bet_floater" tip_id="watch_system_bet_floater" visible="0"/>

			<panel name="watch_system_request_status" y="1h" height="192%" noclick="1"/>

			<!-- close button -->
			<panel x="-1h" y="1.2h" width="2.0h" height="2.0h" align="right" noclick="1">
				<button
					color="invisible"
					onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); Set('_mainmenu_currentpanel', 'watch_system'); CallEvent('MainMenuPanelSwitcher');"
					onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				>
					<widgetstate statename="up">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#520000" blockinput="false" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="1"/>
					</widgetstate>
					<widgetstate statename="over">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#c50000" blockinput="false" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="1"/>
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#9c0000" blockinput="false" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="1"/>
					</widgetstate>
				</button>
			</panel>
		</panel>
	</template>
</package>