		php="false"
	/>

	<template name="watch_system_pagebtn">
		<panel name="watch_system_{type}_pagebtn_{id}" width="2.2h" height="2.2h" valign="center" stickytoinvis="false">
			<button name="watch_system_{type}_pagebtn_{id}_btn" color="invisible"
			        onclicklua="Set('_pagebar_{type}_selected', {id}, 'int')
			   			        Watch_System.UpdatePageBar('{type}')
			   			        {updatefunc}"
			   		onclick="PlaySound('/shared/sounds/ui/button_click_03.wav');"
		    >
		    	<widgetstate statename="up">
					<panel/>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#10a6d9" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="#10a6d9" borderthickness=".6h" noclick="true"/>
				</widgetstate>
				<widgetstate statename="down">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#10a6d9" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="#10a6d9" borderthickness=".6h" noclick="true"/>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#10a6d9" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="#10a6d9" borderthickness=".6h" noclick="true"/>
				</widgetstate>
			</button>

			<label name="watch_system_{type}_pagebtn_{id}_text" color="white" font="dyn_12" textvalign="center" textalign="center" shadow="true" noclick="1"/>
		</panel>
	</template>

	<template name="watch_system_pagechangebtn">
		<button width="{width=2.5h}" height="2.2h" align="{align}" valign="{valign}" onclicklua="{onclicklua}" color="invisible" onclick="PlaySound('/shared/sounds/ui/button_click_05.wav');">
			<widgetstate statename="up">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#313538" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="#313538" borderthickness=".6h" noclick="true"/>
				<label align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="#bac0c2" shadow="1" content="{content}" noclick="1"/>
				<!-- <image width="1.5h" height="1.5h" align="center" valign="center" noclick="1" texture="{texture}" hflip="{hflip=0}"/> -->
			</widgetstate>
			<widgetstate statename="over">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#5d6063" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="#5d6063" borderthickness=".6h" noclick="true"/>
				<label align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="#bac0c2" shadow="1" content="{content}" noclick="1"/>
				<!-- <image width="1.5h" height="1.5h" align="center" valign="center" noclick="1" texture="{texture}" hflip="{hflip=0}"/> -->
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#5d6063" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="#5d6063" borderthickness=".6h" noclick="true"/>
				<label align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="#bac0c2" shadow="1" content="{content}" noclick="1"/>
				<!-- <image width="1.5h" height="1.5h" align="center" valign="center" noclick="1" texture="{texture}" hflip="{hflip=0}"/> -->
			</widgetstate>
		</button>
	</template>

	<template name="watch_system_pagebar">
		<panel height="4h" align="{align}" valign="{valign}"  x="{x}" y="{y}" float="right" padding="0.6h" grow="true" regrow="true"
			   onloadlua="Cvar.CreateCvar('_pagebar_{type}_start', 'int', 0)
			  			  Cvar.CreateCvar('_pagebar_{type}_total', 'int', 1)
			   			  Cvar.CreateCvar('_pagebar_{type}_selected', 'int', 0)
			   			  Cvar.CreateCvar('_pagebar_{type}_permax', 'int', {maxperpage=5})
			   			  Watch_System.UpdatePageBar('{type}')">
			<instance name="watch_system_pagechangebtn" texture="/ui/elements/watch_system/arrow_2.tga" valign="center"
					  content="First" width="4h"
					  onclicklua="local start = GetCvarInt('_pagebar_{type}_start')
					  			  local selected = GetCvarInt('_pagebar_{type}_selected')

							   if start > 0 or selected > 0 then
							   		Set('_pagebar_{type}_start', 0, 'int')
							   		Set('_pagebar_{type}_selected', 0, 'int')
							   		Watch_System.UpdatePageBar('{type}')
			   			  			{updatefunc}
							   end
							   "/>

			<instance name="watch_system_pagechangebtn" texture="/ui/elements/watch_system/arrow_1.tga" valign="center"
				      content="Previous" width="6.5h"
				      onclicklua="local start = GetCvarInt('_pagebar_{type}_start')
				     			  local selected = GetCvarInt('_pagebar_{type}_selected')
				     			  local permax = GetCvarInt('_pagebar_{type}_permax')

							   if start + selected > 0 then
							   		if selected > 0 then
							   			Set('_pagebar_{type}_selected', selected - 1, 'int')
							   		elseif start >= permax then
							   			Set('_pagebar_{type}_selected', permax - 1, 'int')
							   			Set('_pagebar_{type}_start', start - permax, 'int')
							   		else
							   			Set('_pagebar_{type}_selected', start - 1, 'int')
							   			Set('_pagebar_{type}_start', 0, 'int')
							   		end

							   		Watch_System.UpdatePageBar('{type}')
			   			  			{updatefunc}
							   end
							   "/>

			<instance name="watch_system_pagebtn" id="0" updatefunc="{updatefunc}" type="{type}"/>
			<instance name="watch_system_pagebtn" id="1" updatefunc="{updatefunc}" type="{type}"/>
			<instance name="watch_system_pagebtn" id="2" updatefunc="{updatefunc}" type="{type}"/>
			<instance name="watch_system_pagebtn" id="3" updatefunc="{updatefunc}" type="{type}"/>
			<instance name="watch_system_pagebtn" id="4" updatefunc="{updatefunc}" type="{type}"/>

			<instance name="watch_system_pagechangebtn" texture="/ui/elements/watch_system/arrow_1.tga" valign="center" hflip="1"
					  content="Next" width="4h"
				      onclicklua="local start = GetCvarInt('_pagebar_{type}_start')
				      			  local selected = GetCvarInt('_pagebar_{type}_selected')
							      local total = GetCvarInt('_pagebar_{type}_total')
							      local permax = GetCvarInt('_pagebar_{type}_permax')

							   if total - 1 > start + selected then
							   		if permax - 1 > selected then
							   			Set('_pagebar_{type}_selected', selected + 1, 'int')
							   		else
							   			Set('_pagebar_{type}_selected', 0, 'int')
							   			Set('_pagebar_{type}_start', start + permax, 'int')
							   		end

							   		Watch_System.UpdatePageBar('{type}')
			   			  			{updatefunc}
							   end
							   "/>

			<instance name="watch_system_pagechangebtn" texture="/ui/elements/watch_system/arrow_2.tga" valign="center" hflip="1"
					  content="Last" width="4h"
				      onclicklua="local start = GetCvarInt('_pagebar_{type}_start')
							   local total = GetCvarInt('_pagebar_{type}_total')
							   local permax = GetCvarInt('_pagebar_{type}_permax')
							   local start = GetCvarInt('_pagebar_{type}_start')
							   local selected = GetCvarInt('_pagebar_{type}_selected')

							   local newselected = 0
							   local newstart = 0
							   if total >= permax then
							   		newselected = permax - 1
							   		newstart = total - permax
							   else
							   		newselected = total - 1
							   end

							   if newstart ~= start or newselected ~= selected then
							   		Set('_pagebar_{type}_start', newstart, 'int')
							   		Set('_pagebar_{type}_selected', newselected, 'int')
							   		Watch_System.UpdatePageBar('{type}')
			   			  			{updatefunc}
							   end
							   "/>
		</panel>
	</template>

	<template name="watch_system_tab">
		<panel name="watch_system_tab_{tabName}" x="{x}" y="{y}" width="{width=18.25h}" height="{height=3h}" align="{align=}" valign="{valign=}"
			onloadlua="{onloadlua}"
			onclicklua="{onclicklua}"
		>
			<button name="watch_system_tab_{tabName}_btn" align="center" color="invisible" onclicklua="Watch_System.SelectTab('{tabName}')" onshowlua="{btnonshowlua}">
				<widgetstate statename="up">
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/ws_tab_up.tga" noclick="1"/>
					<label y="0.25h" width="-3h" height="3h" align="center" valign="bottom" textalign="center" textvalign="bottom" font="dyn_14" color="#1a1b1b" shadow="1" shadowcolor="#77a2b1" content="watch_system_tab_label_{tabName}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="over">
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/ws_tab_over.tga" noclick="1"/>
					<label y="0.25h" width="-3h" height="3h" align="center" valign="bottom" textalign="center" textvalign="bottom" font="dyn_14" color="#1a1b1b" shadow="1" shadowcolor="#77a2b1" content="watch_system_tab_label_{tabName}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="down">
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/ws_tab_down.tga" noclick="1"/>
					<label y="0.25h" width="-3h" height="3h" align="center" valign="bottom" textalign="center" textvalign="bottom" font="dyn_14" color="#102736" shadow="1" shadowcolor="#12e5f6" content="watch_system_tab_label_{tabName}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="disabled">
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/ws_tab_up.tga" noclick="1" color="1 1 1 .7"/>
					<label y="0.25h" width="-3h" height="3h" align="center" valign="bottom" textalign="center" textvalign="bottom" font="dyn_14" color="#283a3f" shadow="1" shadowcolor="#5d7276" content="watch_system_tab_label_{tabName}" noclick="1"/>
				</widgetstate>
			</button>

			<panel name="watch_system_tab_{tabName}_selected" align="center" visible="0" noclick="1">
				<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/ws_tab_down.tga" noclick="1"/>
				<label width="-3h" height="3h" align="center" valign="bottom" textalign="center" textvalign="bottom" font="dyn_14" color="#102736" shadow="1" shadowcolor="#12e5f6" content="watch_system_tab_label_{tabName}" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="watch_system_date_tab">
		<panel name="watch_system_date_tab_{category}{date}" x="{x}" y="{y}" width="{width=5.5h}" height="{height=3h}" align="{align=}" valign="{valign=}"
			onloadlua="{onloadlua}"
			onclicklua="{onclicklua}"
		>
			<button name="watch_system_date_tab_{category}{date}_btn" align="center" color="invisible"
				onclick="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onclick}"
				onclicklua="Watch_System.SelectRegionMatchDate('{date}')">
				<widgetstate statename="up">
					<image width="6h" height="3h" align="center" valign="center" texture="/ui/elements/watch_system/date_btn_up.tga" noclick="1"/>
					<label width="-0.5h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="white" shadow="1" shadowcolor="black" content="{date}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="over">
					<image width="6h" height="3h" align="center" valign="center" texture="/ui/elements/watch_system/date_btn_over.tga" noclick="1"/>
					<label width="-0.5h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="white" shadow="1" shadowcolor="black" content="{date}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="down">
					<image width="6h" height="3h" align="center" valign="center" texture="/ui/elements/watch_system/date_btn_down.tga" noclick="1"/>
					<label width="-0.5h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="white" shadow="1" shadowcolor="black" content="{date}" noclick="1"/>
				</widgetstate>
			</button>

			<panel name="watch_system_date_tab_{category}{date}_selected" align="center" visible="0" noclick="1">
				<image width="6h" height="3h" align="center" valign="center" texture="/ui/elements/watch_system/date_btn_down.tga" noclick="1"/>
				<label width="-0.5h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_10" color="white" shadow="1" shadowcolor="black" content="{date}" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="watch_system_button">
		<panel name="watch_system_button_{nameid}" x="{x}" y="{y}" width="{width=21.5h}" height="{height=5h}" align="{align}" valign="{valign}" visible="{visible}" noclick="1">
			<button align="center" color="invisible"
				onclick="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onclick}"
				onclicklua="{onclicklua}">
				<widgetstate statename="up">
					<image width="19.5h" height="5.5h" y="0.1h" align="center" valign="center" texture="/ui/elements/watch_system/frames/sb_gradient_up.tga" noclick="1" nocompress="true"/>
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/watch_system_btn_up.tga" noclick="1"/>
					<label width="-1h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_14" color="#ffffff" outline="1" outlinecolor="#333333" content="{label}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="over">
					<image width="19.5h" height="5.5h" y="0.1h" align="center" valign="center" texture="/ui/elements/watch_system/frames/sb_gradient_over.tga" noclick="1" nocompress="true"/>
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/watch_system_btn_up.tga" noclick="1"/>
					<label width="-1h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_14" color="#ffffff" outline="1" outlinecolor="#294a66" content="{label}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="down">
					<image width="19.5h" height="5.5h" y="0.2h" align="center" valign="center" texture="/ui/elements/watch_system/frames/sb_gradient_down.tga" noclick="1" nocompress="true"/>
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/watch_system_btn_up.tga" noclick="1"/>
					<label width="-1h" height="3h" y="0.1h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_14" color="#ffffff" outline="1" outlinecolor="#294a66" content="{label}" noclick="1"/>
				</widgetstate>

				<widgetstate statename="disabled">
					<image width="19.5h" height="5.5h" y="0.1h" align="center" valign="center" texture="/ui/elements/watch_system/frames/sb_gradient_up.tga" rendermode="grayscale" noclick="1" nocompress="true"/>
					<image width="24h" height="6h" align="center" valign="center" texture="/ui/elements/watch_system/watch_system_btn_up.tga" rendermode="grayscale" noclick="1"/>
					<label width="-1h" height="3h" align="center" valign="center" textalign="center" textvalign="center" font="dyn_14" color="#2f3739" shadow="1" shadowcolor="#7e9598" content="{label}" noclick="1"/>
				</widgetstate>
			</button>
		</panel>
	</template>

