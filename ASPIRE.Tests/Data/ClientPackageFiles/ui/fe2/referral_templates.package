<?xml version="1.0" encoding="UTF-8"?>
<package>

	<template name="tourn_countdown_unit">
		<panel x="{x=0}" y="0" width="3.8h" height="3.8h" valign="bottom" noclick="1" passivechildren="1" name="tourn_countdown_unit_{pos}_0_{index=0}" >
			<image texture="/ui/fe2/store/promo/countdown_base.tga" />
			<label x="0.7h" y="-0.7h" textvalign="bottom" textalign="left" font="dyn_12" color="1 1 1 1" shadow="true" noclick="true" content="0" name="tourn_countdown_unit_label_{pos}_0_{index=0}"  />
		</panel>  
		<panel x="{x=0}" y="-2.8h" width="3.8h" height="3.8h" valign="bottom" noclick="1" passivechildren="1" name="tourn_countdown_unit_{pos}_1_{index=0}" visible="0" >
			<image texture="/ui/fe2/store/promo/countdown_base.tga" />
			<label x="0.7h" y="-0.7h" textvalign="bottom" textalign="left" font="dyn_12" color="1 1 1 1" shadow="true" noclick="true" content="0" name="tourn_countdown_unit_label_{pos}_1_{index=0}"  />
		</panel>		
	</template>	 
	
	<template name="ref_reward">
		<panel width="13.4h" height="100%" noclick="true">
			<frame texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".5 .5 .5 1" blockinput="false" />
			<frame texture="/ui/frames/roundframe.tga" color="#074880" borderthickness="0.6h" blockinput="false" />			
			<panel width="-1.0h" height="-1.0h" align="center" valign="center" float="bottom">
				<label fity="true" fitypadding="0.7h" textalign="center" font="dyn_14" color="#3abde7" shadow="true" content="{label}" noclick="true"/>
				<panel grow="true" height="2.4h" align="center" float="right" padding="0.2h">
					<image width="100@" height="100%" texture="{texture}" />
					<label fitx="true" height="100%" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="{reward_amt}" />
				</panel>
			</panel>			
		</panel>
	</template>
	
	<template name="referral_user">
		<panel name="referral_user_parent_{index}" width="100%" height="2.4h" float="right" visible="false" noclick="1" passivechildren="1" >
			<label name="referral_user_name_{index}" height="100%" width="28%" textvalign="center" textalign="center" font="dyn_11" color=".8 .8 .8 1" content="" />			
			<panel height="100%" width="18%">
				<image name="referral_user_milestone_1_{index}" width="100@" height="100%" align="center" texture="/ui/elements/check_mark.tga" color="1 1 1 1" />
			</panel>
			<panel height="100%" width="18%">
				<image name="referral_user_milestone_2_{index}" width="100@" height="100%" align="center" texture="/ui/elements/check_mark.tga" color="1 1 1 1" />
			</panel>
			<panel height="100%" width="18%">
				<image name="referral_user_milestone_3_{index}" width="100@" height="100%" align="center" texture="/ui/elements/check_mark.tga" color="1 1 1 1" />
			</panel>
			<panel height="100%" width="18%">
				<image name="referral_user_milestone_4_{index}" width="100@" height="100%" align="center" texture="/ui/elements/check_mark.tga" color="1 1 1 1" />
			</panel>
		</panel>
	</template>
	
</package>