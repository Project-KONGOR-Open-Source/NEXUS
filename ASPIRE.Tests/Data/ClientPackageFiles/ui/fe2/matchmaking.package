			<label name="matchmaking_option_map_{mapid}_{index=1}_name" fity="true" wrap="1" x="0.8h" y="0.7h" width="100%" textalign="left" font="dyn_14" color=".5 .5 .5 1" shadow="true" content="{mapname}" noclick="true" />
			<panel x="0.8h" y="-0.8h" width="13.0h" height="13.0h" valign="bottom">
				<image name="matchmaking_option_map_{mapid}_{index=1}_minimap"
					resourcecontext="matchmaking" watch9="MainRegisterTextures"
