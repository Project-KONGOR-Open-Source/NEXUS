												height="28.8h"
												align="right"
												width="1.6h"
												scrollbarsize="1.5h"
												handlewidth="1.5h"
												handleheight="1.5h"
												texture="/ui/info/combobox.tga"
												scrollbarplaceholder="true"
												minvalue="0"
												maxvalue="1"
												step="1"
												value="0"
												vertical="true"
												slotwidth="0.6h" slotheight="1"
												onevent1="SetValue(GetValue+1);"
												onevent0="SetValue(GetValue-1);"
												onslidelua="UIManager.GetInterface('main'):HoNMatchmakingF('MultiBotListSlide', self, self:GetValue(), 'right')"
												/>
											<panel processonlyscroll="1" hover="false"
												onmousewheelup="Call('mm_right_multibot_scrollbar', 'DoEvent(0);');"
												onmousewheeldown="Call('mm_right_multibot_scrollbar', 'DoEvent(1);');"
											/>
										</panel>
									</panel>
								</panel>
							</panel>
						</panel>

