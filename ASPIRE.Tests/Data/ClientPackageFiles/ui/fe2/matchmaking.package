<?xml version="1.0" encoding="UTF-8"?>
<package>
	<panel name="TMM_TriggerHelper" color="invisible" noclick="true"
		onloadlua="MatchmakingInitialize(self)"
	/>
	<lua file="/ui/scripts/matchmaking.lua" />

	<!-- ======================================= -->

	<template name="mapLoadGuideLoadProgress">
		<panel
			name="mapLoadGuideLoadProgress{id}"
			sticky="true"
			stickytoinvis="false"
			height="{height=1.8h}"
			width="100%"
			noclick="true"
			visible="{visible=false}"
		>
		<!--
			watch="TMMPlayerStatus{id}"
			ontrigger="SetVisible(!StringEmpty(param0));"
		-->
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="#171a28"/>
			<panel x="0.2h" y="0.2h" width="-0.4h" height="-0.35h">
				<panel
					name="mapLoadGuideLoadProgress{id}Bar"
					width="{testwidth=0%}"
					color="green"
				/>
				<!--
					watch="TMMPlayerStatus{id}"
					ontrigger="SetWidth(param4 # '%');"
				-->
			</panel>
			<frame texture="/ui/frames/roundframe.tga" color="#bbdefa" borderthickness="0.3h"/>
			<label
				name="mapLoadGuideLoadProgress{id}Name"
				y="-0.1h"
				width="100%"
				height="100%"
				textalign="center"
				textvalign="center"
				font="dyn_10"
				color="white"
				shadow="true"
			/>
			<!--
				watch="TMMPlayerStatus{id}"
				ontrigger="SetText(param1);"
			-->

			<!-- Darken -->
			<panel visible="{darken=false}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="0 0 0 .8"/>
				<frame texture="/ui/frames/roundframe.tga" color="#678095" borderthickness="0.3h"/>
			</panel>
		</panel>
	</template>

	<template name="mapLoadGuideLegendMarker">
		<panel height="2.75h" noclick="true" passivechildren="true">
			<label align="right" x="-140@" textalign="right" textvalign="center" shadow="true" font="dyn_12" color="#619483" content="{label}"/>
			<panel width="100@" height="100%" align="right">
				<image texture="{icon}" align="center" valign="center"/>
			</panel>
		</panel>
	</template>

	<template name="mapLoadGuideInfo">
		<panel width="100%" grow="true">
			<panel width="{width=100%}" grow="true">
				<label wrap="true" fity="true" fitypadding="{fitypadding=1h}" font="dyn_10" color="#91e0c3" content="{label}"/>
			</panel>
		</panel>
	</template>

	<template name="mapLoadGuideMarker">
		<panel noclick="true" width="1" height="1" x="{x}" y="{y}" align="{align}" valign="{valign}">
			<panel width="3h" height="3h" align="center" valign="center" passivechildren="true">
				<image texture="{icon}"/>
			</panel>
		</panel>
	</template>

	<template name="mapLoadGuideInfos_capturetheflag_flagdrop">
		<panel height="3h" width="24h">
			<panel align="center" grow="true" height="100%" float="right" padding="0.75h">
				<panel width="100@" height="100%">
					<image texture="/triggers/custom_maps/capturetheflag/flag/flagdrop.tga"/>
					<frame color="invisible" bordercolor="#666666" borderthickness="1"/>
				</panel>
				<label fitx="true" font="dyn_9" color="#91e0c3" textvalign="center" content="map_loading_capturetheflag_dropicon"/>
			</panel>
		</panel>
	</template>

	<template name="mapLoadGuideInfos_devowars_abilities">
		<panel height="4h" float="right" padding="1.75h">
			<panel width="100@" height="100%">
				<image texture="/triggers/custom_maps/herowars/heroes/devx/ability_01_chain/icon.tga" y="0.1h"/>
				<image y="0.1h" width="6.2h" height="6.2h" align="center" valign="center" texture="/ui/common/ability_frame.tga" noclick="1" />
			</panel>

			<panel width="75@" height="100%">
				<image texture="/ui/elements/devowars/loading/arrow.tga" height="2h" width="2h" align="center" valign="center" />
			</panel>

			<panel width="100@" height="100%"><!-- 1 -->
				<image texture="/triggers/custom_maps/herowars/heroes/devx/hook_levelups/damage.tga"/>
				<modelpanel
					visible="1"
					noclick="true"
					model="/ui/common/models/toggle/toggle.mdf"
					anim="idle"
					effect="/ui/common/models/toggle/toggle.effect"
					camerapos="0 1 0"
					cameraangles="0 0 180"
					camerafov="45"
					cameranear="1"
					carmerafar="100"
					depthclear="false"
					depthcompress="true"
					onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
				/>
			</panel>

			<panel width="100@" height="100%"><!-- 2 -->
				<image texture="/triggers/custom_maps/herowars/heroes/devx/hook_levelups/range.tga" />
				<modelpanel
					visible="1"
					noclick="true"
					model="/ui/common/models/toggle/toggle.mdf"
					anim="idle"
					effect="/ui/common/models/toggle/toggle.effect"
					camerapos="0 1 0"
					cameraangles="0 0 180"
					camerafov="45"
					cameranear="1"
					carmerafar="100"
					depthclear="false"
					depthcompress="true"
					onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
				/>
			</panel>

			<panel width="100@" height="100%"><!-- 3 -->
				<image texture="/triggers/custom_maps/herowars/heroes/devx/hook_levelups/speed.tga"/>
				<modelpanel
					visible="1"
					noclick="true"
					model="/ui/common/models/toggle/toggle.mdf"
					anim="idle"
					effect="/ui/common/models/toggle/toggle.effect"
					camerapos="0 1 0"
					cameraangles="0 0 180"
					camerafov="45"
					cameranear="1"
					carmerafar="100"
					depthclear="false"
					depthcompress="true"
					onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
				/>
			</panel>

			<panel width="100@" height="100%"><!-- 4 -->
				<image texture="/triggers/custom_maps/herowars/heroes/devx/hook_levelups/width.tga" />
				<modelpanel
					visible="1"
					noclick="true"
					model="/ui/common/models/toggle/toggle.mdf"
					anim="idle"
					effect="/ui/common/models/toggle/toggle.effect"
					camerapos="0 1 0"
					cameraangles="0 0 180"
					camerafov="45"
					cameranear="1"
					carmerafar="100"
					depthclear="false"
					depthcompress="true"
					onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
				/>
			</panel>
		</panel>
	</template>

	<template name="mapLoadGuideInfos_soccer_ability">
		<panel width="12h">
			<panel x="0.5h" width="5h" height="5h" valign="center">
				<frame color="invisible" bordercolor="#666666" borderthickness="1"/>
				<image width="-2" height="-2" align="center" valign="center" texture="/ui/elements/soccer/loading/icon_{type}.tga" />
			</panel>
			<panel x="6h" width="6h">
				<label textvalign="center" font="dyn_10" color="#91e0c3" content="map_loading_soccer_tip01_{type}"/>
			</panel>
		</panel>
	</template>
	<template name="mapLoadGuideInfos_soccer_abilities">
		<panel height="4h" width="40h">
			<panel y="-1h" float="right" padding="1" width="40h" height="5h" >
				<instance name="mapLoadGuideInfos_soccer_ability" type="kick"/>
				<instance name="mapLoadGuideInfos_soccer_ability" type="slide"/>
				<instance name="mapLoadGuideInfos_soccer_ability" type="sprint"/>
			</panel>
		</panel>
	</template>

	<!-- ======================================= -->

	<template name="mapLoadGuide">

		<panel name="mapLoadGuide" color="0 0 0" height="45h" y="4.5h" align="center" width="112h" visible="false">
			<frame borderthickness="1" color="invisible" bordercolor="1 1 1 0.1"/>

			<panel height="2.5h" color="1 1 1 0.1" align="center" width="-1h">
				<image width="-64" align="center" texture="/ui/info/header_bar_c.tga" color="white" noclick="1" blockinput="0"/>
				<image height="50.1%" width="32" align="left" valign="top" texture="/ui/info/header_bar_tl.tga" color="white" noclick="1" blockinput="0"/>
				<image height="49.9%" width="32" align="left" valign="bottom" texture="/ui/info/header_bar_bl.tga" color="white" noclick="1" blockinput="0"/>
				<image height="50.1%" width="32" align="right" valign="top" texture="/ui/info/header_bar_tr.tga" color="white" noclick="1" blockinput="0"/>
				<image height="49.9%" width="32" align="right" valign="bottom" texture="/ui/info/header_bar_br.tga" color="white" noclick="1" blockinput="0"/>

				<label name="mapLoadGuideHeaderGlow" textalign="center" textvalign="center" content="map_capturetheflag" font="dyn_12" color="#5cdae5" glow="true" rendermode="additive" />
				<label name="mapLoadGuideHeaderText" textalign="center" textvalign="center" content="map_capturetheflag" font="dyn_12" color="white" />
			</panel>

			<panel height="36.75h" y="3.1h" align="center" width="-1h">
				<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
				<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
			</panel>


			<!-- Loading Space -->
			<panel noclick="true" height="3.8h" valign="bottom" align="center" width="-1h" y="-0.5h">
				<frame texture="/ui/info/button.tga" borderthickness="borderthickness=0.6h" color="1 1 1 1" noclick="true"/>
				<panel
					watch="TMMGamePhase"
					ontrigger="SetVisible(param == 1);"
					visible="true"
					noclick="true" passivechildren="true"
				>
					<instance name="mm_loading_progressbar" index="0"
						barwatch0="LoadingProgress" barontrigger0="SetWidth(FtoP(param0));"
						label="mm_you"
						font="dyn_12"
						height="100%"
						visible="true"
						labelwatch="AccountInfo" labelontrigger="SetText(param1)"
					/>
				</panel>
				<panel
					watch="TMMReadyStatus"
					ontrigger="SetVisible(param2 and !param4);"
					noclick="true" passivechildren="true"
				>
					<instance name="mapLoadGuideLoadProgress" id="0"
						label="mm_you"
						font="dyn_12"
						height="100%"
						visible="true"
					/>
				</panel>
				<instance
					name="button2" button_name="unnamedButton167b"
					label="mm_queue_leave_btn"
					watch="TMMReset TMMTime TMMLeftQueue" ontrigger="SetVisible(IsInQueue());"
					onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_button_leave_queue_OnClick')"
				/>
			</panel>

			<panel name="mapLoadGuideMap" width="48h" height="48h" align="center" y="-2h" noclick="true" visible="false" passivechildren="true">
				<panel name="mapLoadGuideMarkers"/>
			</panel>

			<panel name="mapLoadGuideInfos" float="bottom" padding="1.85h" x="3.25h" y="6.5h" noclick="true" passivechildren="true"/>
			<panel name="mapLoadGuideLegend" valign="bottom" align="right" width="27h" y="-6.25h" grow="true" regrow="true" float="bottom" x="-2h" noclick="true" visible="false"/>

			<panel align="right" valign="bottom" width="25h" height="18.75h" x="-0.5h" y="-5.25h">
				<frame texture="/ui/frames/thick.tga" color="#43695c" borderthickness="0.5h"/>
				<label font="dyn_12" color="#619483" content="map_loading_legend" x="1h" y="1h"/>
			</panel>

			<panel align="right" width="26h" height="18h" y="3h" x="-0.5h">
				<!-- ==================================== -->
				<!-- ==================================== -->

				<!-- Loading Assets...  -->
				<panel name="mapLoadGuide_mm_loading_1"
					visible="false"
				>

					<label fity="true" fitypadding="0.4h" textalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="mm_loading_assets" />

					<label fity="true" y="-1.4h" textalign="left" valign="bottom" wrap="true" font="dyn_9" color="1 1 1 1" shadow="true" content="mm_preloadworld_groupwait" />
					<panel y="4h" width="100%" height="10.0h" valign="top" noclick="true">
						<panel grow="true" growinvis="false" width="-1h" align="center" valign="top" float="bottom" padding="0.2h" noclick="true">
							<!--<instance name="mapLoadGuideLoadProgress" id="0" />-->
							<instance name="mapLoadGuideLoadProgress" id="1" height="1.5h" />
							<instance name="mapLoadGuideLoadProgress" id="2" height="1.5h" />
							<instance name="mapLoadGuideLoadProgress" id="3" height="1.5h" />
							<instance name="mapLoadGuideLoadProgress" id="4" height="1.5h" />
						</panel>
					</panel>

				</panel>

				<!-- ==================================== -->
				<!-- ==================================== -->

				<!-- MM Game Loading - Team Loading-->
				<panel
					name="mapLoadGuide_mm_loading_3"

					watch="TMMGamePhase"
					ontrigger="SetVisible(param == 1);"
					visible="false"
					watch0="GamePhase" ontrigger0="If(param0 ge 3, SetVisible(0));"
				>

					<panel y="0.8h" width="-2.0h" align="center" noclick="true">
						<label fity="true" textalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="mm_loading_game" />

						<!-- Player Loading (replaced by bar in center) -->
						<panel y="3.8h" width="100%" height="2.0h" valign="top" noclick="true" visible="fasle">
							<instance name="mm_loading_progressbar" index="0"
								barwatch0="LoadingProgress" barontrigger0="SetWidth(FtoP(param0));"
								label="mm_you"
								font="dyn_10"
								height="2.0h"
								visible="true"
							/>
						</panel>

						<!-- Team Loading Lights -->
						<label y="3h" fity="true" width="100%" textalign="center" font="dyn_12" color="1 1 1 1" shadow="true" noclick="true" content="mm_otherplayers" />
						<panel grow="true" growinvis="false" y="5h" height="3.7h" float="right" noclick="true" regrow="true">
							<instance name="mm_loading_status_light" index="0" />
							<instance name="mm_loading_status_light" index="1" />
							<instance name="mm_loading_status_light" index="2" />
							<instance name="mm_loading_status_light" index="3" />
							<instance name="mm_loading_status_light" index="4" />
							<instance name="mm_loading_status_light" index="5" />
							<instance name="mm_loading_status_light" index="6" />
							<instance name="mm_loading_status_light" index="7" />
							<instance name="mm_loading_status_light" index="8" />
							<instance name="mm_loading_status_light" index="9" />
						</panel>

						<label fity="true" y="-1.5h" textalign="left" valign="bottom" wrap="true" font="dyn_10" color="1 1 1 1" shadow="true" content="mm_gameloading_msg" />
					</panel>

				</panel>

				<!-- ==================================== -->
				<!-- ==================================== -->

				<panel visible="false"><!-- I believe this is probably never used, but we're making it look alright regardless. -->
					<label fity="true" fitypadding="0.4h" textalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="mm_loading_game" />

					<!-- Player Loading -->
					<panel y="3.8h" width="100%" height="1.7h" valign="top" noclick="true">
						<instance name="mm_loading_progressbar" index="0"
							barwatch0="LoadingProgress" barontrigger0="SetWidth(FtoP(param0));"
							label="mm_you"
							font="dyn_10"
							height="2.0h"
							visible="true"
						/>
					</panel>

					<!-- Team Loading Lights
					<label y="7.3h" fity="true" width="100%" textalign="center" font="dyn_11" color=".7 .7 .7 1" shadow="true" noclick="true" content="mm_otherplayers" />
					<panel grow="true" growinvis="false" y="9.1h" height="4.0h" float="right" noclick="true" regrow="true">
						<instance name="mm_loading_status_light" index="0" />
						<instance name="mm_loading_status_light" index="1" />
						<instance name="mm_loading_status_light" index="2" />
						<instance name="mm_loading_status_light" index="3" />
						<instance name="mm_loading_status_light" index="4" />
						<instance name="mm_loading_status_light" index="5" />
						<instance name="mm_loading_status_light" index="6" />
						<instance name="mm_loading_status_light" index="7" />
						<instance name="mm_loading_status_light" index="8" />
						<instance name="mm_loading_status_light" index="9" />
					</panel>
					 -->

					 <!-- Team Loading Msg -->
					 <label y="2.75h" fity="true" width="100%" textalign="center" font="dyn_11" color=".7 .7 .7 1" shadow="true" noclick="true" content="mm_otherplayers" />
					 <panel y="7.75h" width="100%" height="3.5h" align="center" noclick="true">
							<panel width="36%" height="100%" noclick="true">
								<animatedimage width="100@" height="100%" align="right" valign="center" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" />
							</panel>
							<label width="60%" height="100%" textalign="left" textvalign="center" align="right" font="dyn_10" color=".7 .7 .7 1" shadow="true" noclick="true" content="general_wait" />
					 </panel>

					<label fity="true" textalign="left" valign="bottom" wrap="true" font="dyn_10" color="1 1 1 1" shadow="true" content="mm_gameloading_msg" />

				</panel>

				<!-- ==================================== -->
				<!-- ==================================== -->

				<!-- Solo Queue Display -->
				<panel
					name="mapLoadGuideQueueDisplay"
					visible="false"
					watch1="GamePhase" ontrigger1="If(param ge 3, SetVisible(0));"
					watch="TMMReset TMMTime TMMLeftQueue" ontrigger="SetVisible(IsInQueue());"
					onshow="##PlayMusic('/music/lobby.mp3', true);##"
					width="100%" height="100%"
				>

					<panel width="100%" height="100%" float="bottom" noclick="true">
						<label height="4h" textalign="center" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="mm_queue_finding" />
						<panel height="0.5h" noclick="true"/>
						<panel grow="1" regrow="1" growinvis="0" width="100%" float="right" padding="1.2h">
							<panel x="1.2h" height="6.6h" width="6.6h">
								<animatedimage y="0.9h" width="100@" height="100%" align="center" valign="center" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" />
							</panel>
							<panel grow="1" regrow="1" growinvis="0" width="-6.6h" float="bottom">
								<label fity="true" fitypadding="0.1h" textalign="left" font="dyn_10" color="#3abde7" shadow="true" content="mm_queue_past" />
								<label name="matchmaking_queue_past" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true" watch="TMMTime" ontrigger="SetText(param0);" />
								<label fity="true" fitypadding="0.1h" textalign="left" font="dyn_10" color="#3abde7" shadow="true" content="mm_queue_eta" />
								<label name="matchmaking_queue_eta" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true" watch="TMMTime" ontrigger="SetText(param1);" />
								<label name="matchmaking_queue_popularity_1b" fity="true" fitypadding="0.1h" textalign="left" font="dyn_11" color="#3abde7" shadow="true" content="mm_queue_popularity" />
								<label name="matchmaking_queue_popularity_2b" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true" />
								<label name="matchmaking_queue_popularity_3b" fity="true" fitypadding="0.1h" textalign="left" font="dyn_11" color="#3abde7" shadow="true" content="mm_queue_extra" visible="0"/>
								<label name="matchmaking_queue_popularity_4b" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true"  visible="0" />
							</panel>
							<button name="matchmaking_hover_question_btn_1b"
								x="7.2h" y="8.2h" height="1.4h" width="1.4h" align="left" color="invisible"
								onmouseover=""
								onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');"
							>
								<widgetstate statename="up">
									<image texture="/ui/elements/tip_mark_up.tga"/>
								</widgetstate>
								<widgetstate statename="over">
									<image texture="/ui/elements/tip_mark_over.tga"/>
								</widgetstate>
								<widgetstate statename="down" x="1" y="1">
									<image texture="/ui/elements/tip_mark_up.tga"/>
								</widgetstate>
							</button>
						</panel>
					</panel>

				</panel>

				<!-- ==================================== -->
				<!-- ==================================== -->

			</panel>

		</panel>
	</template>

	<!-- ======================================= -->

	<template name="mm_category_tab">
		<button
			name="mm_category_tab_{mode}"
			width="100%" height="103.3@"
			y="{y}"
			color="invisible"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
			onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('SelectTab', '{mode}')
						HoN_Matchmaking.TabClickTime = GetTime()"
			mouseoverdisabled=""
			disabledmouseover=""
			mouseoutdisabled=""
			disabledmouseout=""
			onmouseoverdisabled=""
			onmouseoutdisabled=""
			numstates="2"
			enabled="{enabled=true}"

			onframelua="local curTime = GetTime()
						if (curTime - HoN_Matchmaking.TabClickTime) > HoN_Matchmaking.TabClickInteval then
							GetWidget('mm_category_tab_mask'):SetVisible(false)
						else
							GetWidget('mm_category_tab_mask'):SetVisible(true)
						end"
		>
			<widgetstate statename="up">
				<frame texture="/ui/frames/{frameimg}.tga" borderthickness="33%" noclick="true">
					<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
						<panel y="3%" width="100%" height="{iconsize=60}%">
							<image width="100@" height="100%" align="center" texture="{icon}" />
						</panel>
						<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
							<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
							<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" onshowlua="{onsetsublabellua}" noclick="true" />
						</panel>
					</panel>
					<panel x="1.0h" width="1.9h" height="100%" align="right" color="{arrowcolor}">
						<image x="90%" y="10%" align="right" width="106%" height="212@" texture="/ui/frames/{tabboxarrow}.tga" noclick="true" />
					</panel>
				</frame>
			</widgetstate>
			<widgetstate statename="over">
				<frame texture="/ui/frames/{frameimg}.tga" borderthickness="33%" noclick="true">
					<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
						<panel y="3%" width="100%" height="{iconsize=60}%">
							<image width="100@" height="100%" align="center" texture="{icon}" />
						</panel>
						<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
							<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
							<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" onshowlua="{onsetsublabellua}" noclick="true" />
						</panel>
					</panel>
					<panel x="1.0h" width="1.9h" height="100%" align="right" color="{arrowcolor}">
						<image x="90%" y="10%" align="right" width="106%" height="212@" texture="/ui/frames/{tabboxarrow}.tga" noclick="true" />
					</panel>
				</frame>
			</widgetstate>
			<widgetstate statename="down">
