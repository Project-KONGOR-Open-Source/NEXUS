				<image name="matchmaking_option_map_{mapid}_{index=1}_minimap_thumb" width="4.0h" height="4.0h" align="center" valign="center" texture="/ui/fe2/elements/vote_up.tga" />
			</panel>
			<panel x="-0.8h" y="1.0h" width="4h" height="7.0h" align="right" valign="center">
				<label name="matchmaking_option_map_{mapid}_{index=1}_teamsize_text" fity="true" width="100%" textalign="center" font="dyn_10" color=".5 .5 .5 1" shadow="true" content="{teamsize}" />
				<image name="matchmaking_option_map_{mapid}_{index=1}_icon" y="-0.2h" width="4.8h" height="4.8h" align="center" valign="bottom" color="1 1 1 .5"
					resourcecontext="matchmaking" watch9="MainRegisterTextures"
					ontrigger9lua="ResourceManager.RegisterTexture('/maps/{mapid}/icon.tga', 'matchmaking', self)"
				/>
			</panel>
			<panel name="matchmaking_option_map_{mapid}_{index=1}_disabled" color="0 0 0 .5">
				<image width="80@" height="80%" align="center" valign="center" color=".3 .3 .3 1" texture="/ui/elements/kick_disabled.tga" />
				<label name="matchmaking_option_map_{mapid}_{index=1}_disabled_text" height="100%" width="14.0h" align="center" textalign="center" textvalign="center" font="dyn_11" color=".6 .6 .6 1" shadow="true" wrap="true" content="mm_map_locked" />
			</panel>
			<panel
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_map_OnMouseOver', '{mapid}')"
				onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_map_OnMouseOut', '{mapid}')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_map_OnClick', '{mapid}')"
			/>
		</panel>
	</template>

	<template name="matchmaking_option_gametype">
		<panel name="matchmaking_option_gametype_{typeid}_{index=1}" color="#183042">
			<frame width="-2" height="-2" align="center" valign="center" name="matchmaking_option_gametype_{typeid}_{index=1}_frame" color=".1 .1 .1 1" bordercolor="#183042" borderthickness="0" noclick="1" />
			<frame width="-2" height="-2" align="center" valign="center" name="matchmaking_option_gametype_{typeid}_{index=1}_frame_color" texture="/ui/info/backdrop.tga" color=".1 .1 .1 1" borderthickness="0" noclick="1" />
			<panel height="2.4h" align="center" valign="center" >
				<panel width="2.4h" height="2.4h" x="1.0h" valign="center" color="invisible">
					<frame name="matchmaking_option_gametype_{typeid}_{index=1}_thumb_background" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color=".6 .6 .6 1"/>
					<frame name="matchmaking_option_gametype_{typeid}_{index=1}_thumb_border" texture="/ui/frames/roundframe.tga" color=".3 .3 .3 1" borderthickness="0.4h"/>
					<image name="matchmaking_option_gametype_{typeid}_{index=1}_thumb_icon" texture="/ui/fe2/elements/vote_down.tga" color=".8 .8 .8 1" rendermode="grayscale" />
				</panel>
				<panel x="3.4h" width="-3.4h" height="100%">
					<label name="matchmaking_option_gametype_{typeid}_{index=1}_label" height="100%" textalign="center" textvalign="center" font="dyn_11" color=".6 .6 .6 1" shadow="true">{label}</label>
				</panel>
			</panel>
			<image name="matchmaking_option_gametype_{typeid}_{index=1}_disabled" width="80@" height="80%" align="center" valign="center" color="1 1 1 .8" texture="/ui/elements/kick_disabled.tga" />
			<panel
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_gametype_OnMouseOver', '{typeid}')"
				onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_gametype_OnMouseOut', '{typeid}')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_gametype_OnClick', '{typeid}')"
			/>
		</panel>
	</template>

	<template name="matchmaking_option_gamemode">
		<panel name="matchmaking_option_gamemode_{modeid}" height="{height=3.6h}" visible="{visible=true}" sticky="1" stickytoinvis="0" >
			<panel float="right" padding="0.8h">
				<panel width="100@" height="100%" valign="center" color="invisible">
					<frame name="matchmaking_option_gamemode_{modeid}_thumb_background" texture="/ui/frames/rounded_bg_white.tga" color=".7 .7 .7 1" borderthickness="0.4h" />
					<frame name="matchmaking_option_gamemode_{modeid}_thumb_border" texture="/ui/frames/roundframe.tga" color="#0c3405" borderthickness="0.4h" />
					<image name="matchmaking_option_gamemode_{modeid}_thumb_icon" texture="/ui/fe2/elements/vote_up.tga" color=".8 .8 .8 1" visible="false"/>
				</panel>
				<panel width="-110@">
					<panel height="2.4h" float="right" padding="0.5h">
						<image name="matchmaking_option_gamemode_{modeid}_icon" width="100@" height="100%" valign="center" texture="/ui/icons/{icon}" rendermode="grayscale" />
						<label name="matchmaking_option_gamemode_{modeid}_text" width="-100@" height="100%" textvalign="center" font="dyn_11" color="#888888" shadow="true">{label}</label>
					</panel>
					<panel y="-0.2h" height="-3.0h" valign="bottom" float="right" padding="0.5%">
						<instance name="matchmaking_option_popularity_marker" basename="matchmaking_option_gamemode_{modeid}_popularity" />
					</panel>
				</panel>
			</panel>
			<panel name="matchmaking_option_gamemode_{modeid}_disabled_panel" visible="false">
				<frame width="104%" height="115%" align="center" valign="center" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .7" noclick="true"/>
				<frame width="104%" height="115%" align="center" valign="center" texture="/ui/frames/roundframe.tga" color=".5 .5 .5 1" borderthickness="0.4h" noclick="true" />
				<panel width="100@" height="100%" valign="center" color="invisible">
					<image width="80@" height="80%" align="center" valign="center" color="1 1 1 .8" texture="/ui/elements/kick_disabled.tga" />
				</panel>
				<label name="matchmaking_option_gamemode_{modeid}_disabled_text" height="100%" width="-100@" align="right" textalign="center" textvalign="center" font="dyn_11" color=".7 .7 .7 1" shadow="true" wrap="true" content="mm_option_disabled" />
			</panel>
			<panel name="matchmaking_option_gamemode_{modeid}_buytokens" visible="false">
				<frame width="104%" height="115%" align="center" valign="center" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .7" noclick="true"/>
				<frame width="104%" height="115%" align="center" valign="center" texture="/ui/frames/roundframe.tga" color=".5 .5 .5 1" borderthickness="0.4h" noclick="true" />
				<panel width="100@" height="100%" valign="center" color="invisible">
					<image width="80@" height="80%" align="center" valign="center" color="1 1 1 .8" texture="/ui/fe2/store/icons/hero_token.tga" />
				</panel>
				<label height="100%" width="-100@" align="right" textalign="center" textvalign="center" font="dyn_11" color="#ffab01" shadow="true" wrap="true" content="mm_option_disabled_buytoken" />
			</panel>
			<panel
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_gamemode_OnMouseOver', '{modeid}')"
				onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_gamemode_OnMouseOut', '{modeid}')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_gamemode_OnClick', '{modeid}')"
			/>
		</panel>
	</template>

	<template name="mm_botpickplate">
		<panel name="mm_botpickplate_{side}_{id}" width="100@" height="100%" visible="1"
			onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('SelectBot', self, {id}, '{side}')"
			onmouseover="Call('mm_botpickplate_border_{side}_{id}_hover', 'FadeIn(150);'); ShowWidget('hero_info');"
			onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('HoverBot', self, {id}, '{side}')"
			onmouseout="Call('mm_botpickplate_border_{side}_{id}_hover', 'FadeOut(150);'); HideWidget('hero_info');"
			onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('LeaveBotHover', '{side}')"
		>
			<image name="mm_botpickplate_icon_{side}_{id}" texture="/ui/fe2/store/icons/account_icons/derp.tga" noclick="1"/>
			<frame name="mm_botpickplate_border_{side}_{id}" color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="1"/>
			<frame name="mm_botpickplate_border_{side}_{id}_hover" color="invisible" visible="0" borderthickness="1" bordercolor=".8 .2 .2 1" noclick="1"/>
			<label name="mm_botpickplate_index_{side}_{id}" visible="0" noclick="1" />
		</panel>
	</template>

	<!-- Enemy Bot Version -->
	<template name="mm_multibotplate">
		<panel name="mm_multibotplate_{side}_{id}" height="{height=7.2h}"
			onmouseover="Call('mm_mb_frame_{side}_{id}', 'FadeIn(150)'); ShowWidget('hero_info');"
			onmouseoverlua=""
			onmouseout="Call('mm_mb_frame_{side}_{id}', 'FadeOut(150)'); HideWidget('hero_info');"
			onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('SelectMultiBot', self, {id}, '{side}')"
		>
			<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color="0 0 0 1" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" noclick="true" />
			<frame name="mm_mb_frame_{side}_{id}" visible="0" texture="/ui/frames/roundframe.tga" color=".8 .2 .2 1" borderthickness="0.6h" noclick="true" />
			<label name="mm_multibotpickplate_index_{side}_{id}" visible="0" noclick="1" />

			<panel width="-1.0h" height="-1.0h" valign="center" align="center" noclick="true">
				<panel width="100@" height="100%" noclick="true">
					<image name="mm_multibotplate_{side}_{id}_icon" texture="/heroes/empath/icon.tga" noclick="true"/>
					<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
				</panel>
				<panel width="-110@" align="right" noclick="true">
					<panel height="2.0h" noclick="true">
						<label name="mm_multibotplate_{side}_{id}_name" textalign="left" font="dyn_12" color="#37b2d9" noclick="true"/>
						<label name="mm_multibotplate_{side}_{id}_version" textalign="right" font="dyn_10" color=".6 .6 .6 1" noclick="true"/>
					</panel>
					<panel height="-2.4h" valign="bottom" noclick="true">
						<label name="mm_multibotplate_{side}_{id}_desc" font="{font=dyn_10}" wrap="true" color="1 1 1 1" noclick="true"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- autocomplete entry for 'invite a person' -->
	<template name="mm_autocomplete_plate">
		<panel
			name="mm_autocomplete_plate_{id}" height="3.0h"
			width="100%"  visible="0"
			align="center"
			sticky="1"
			onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('ClickAutocomplete', self, {id})"
			ondoubleclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('DoubleClickAutoComplete', self, {id})"
			onmouseover="ShowWidget('mm_autocomplete_plate_{id}_bg_blue'); Call('mm_autocomplete_plate_{id}_hover', 'FadeIn(75)');"
			onmouseout="HideWidget('mm_autocomplete_plate_{id}_bg_blue'); Call('mm_autocomplete_plate_{id}_hover', 'FadeOut(75)');"
			onmousewheeldown="CallEvent('mm_invite_scrollbar', 1);"
			onmousewheelup="CallEvent('mm_invite_scrollbar', 0);"
		>
			<panel noclick="1" valign="top" height="-1" >
				<frame name="mm_autocomplete_plate_{id}_bg_blue" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".6 .6 .6 .9" blockinput="0" noclick="1" visible="0" />

				<frame name="mm_autocomplete_plate_{id}_border" texture="/ui/frames/roundframe.tga" color=".2 .2 .2 1" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<!-- Hover  -->
				<panel name="mm_autocomplete_plate_{id}_hover" noclick="true" visible="0">
					<frame name="mm_autocomplete_plate_{id}_hover_bg_blue" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color="1 1 1 1" blockinput="0" noclick="1" />
					<frame name="mm_autocomplete_plate_{id}_hover_border" texture="/ui/frames/roundframe.tga" color="#0081ed" borderthickness="0.6h" blockinput="false" noclick="true"/>
				</panel>
				<panel height="-0.8h" width="-0.8h" valign="center" align="center" noclick="true" float="right">
					<!-- Icon -->
					<panel x="0.3h" name="mm_autocomplete_plate_{id}_iconframe" height="100%" width="100@" noclick="true">
						<!-- this guy would have an on double click, but they don't appear to exist on images :x -->
						<image name="mm_autocomplete_plate_{id}_icon" texture="$invis" noclick="0"
							onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('ClickAutocomplete', self, {id})"
							onmouseover="
								If(!StringEquals(GetTexture(), '/ui/fe2/store/icons/account_icons/default.tga'), Split(
										Trigger(
											'StoreImagePreviewInit',
											GetWidth(),
											GetHeight(),
											GetAbsoluteX(),
											GetAbsoluteY(),
											false,
											GetTexture()
										),
										Trigger('StoreImagePreviewVis', true, '250%')
									)
								);
							"
							onmouseout="
								DoEvent(1);
							"
							onevent1="
								Trigger('StoreImagePreviewVis', false, '100%');
							"
						/>
					</panel>

					<!-- User Info -->
					<panel name="mm_autocomplete_plate_{id}_userinfo" width="-0.5h" align="right" noclick="true">
						<!-- Name -->
						<label x="1%" name="mm_autocomplete_plate_{id}_name" width="-52@" valign="top" textvalign="top" font="dyn_11" color="white" shadow="true" content="" noclick="true" />
						<!-- Focus Icon -->
						<panel name="mm_autocomplete_plate_{id}_invited" x="-8%" width="90@" height="90%" align="right" valign="center" noclick="true" visible="0" color="invisible">
							<image texture="/ui/fe2/lobby/matchmaking_server_dot_green.tga" noclick="true" color="#FFD52E" />
						</panel>
					</panel>\
				</panel>
			</panel>
		</panel>
	</template>

	<template name="matchmaking_group_error_floater">
		<floater
			name="matchmaking_group_error_tooltip"
			x="{x=2.2h}" y="{y=-0.5h}"
			width="{width=25.0h}"
			align="{align=left}"
			valign="{valign=top}"
			visible="{visible=0}"
			passivechildren="true"
			grow="true" regrow="1"
			watch="MatchmakingGroupErrorUpdate"
			ontrigger="SetVisible(!StringEmpty(param0));"
		>
			<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 .8" borderthickness=".6h" />
			<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
				<label
					x="0.8h" y="0.6h"
					textvalign="top"
					textalign="left"
					align="center"
					font="dyn_10"
					noclick="1"
					color="#ffab01"
					shadow="1"
					wrap="1"
					fity="true"
					fitypadding="0.8h"
					watch="MatchmakingGroupErrorUpdate" ontrigger="SetText(param0);"
				></label>
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/icons/basic.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 1);" />
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/fe2/elements/vote_down.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 2);" />
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/icons/goldcoin.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 3);" />
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/fe2/elements/vote_up.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 4);" />
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/icons/botmatch.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 5);" />
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/elements/lobby/icon_host.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 6);" />
				<image x="-0.6h" y="0.6h" noclick="1" height="2.5h" width="2.5h" align="right" visible="0" texture="/ui/fe2/elements/vote_down.tga" watch="MatchmakingGroupErrorUpdate" ontrigger="SetVisible(param2 == 7);" />
				<panel y="2.5h" width="-1.6h" align="center" noclick="true" grow="true" float="bottom">
					<label
						textvalign="top"
						textalign="left"
						align="center"
						font="dyn_10"
						noclick="1"
						color="white"
						shadow="1"
						wrap="1"
						fity="true"
						fitxpadding="0"
						content="Get"
						watch="MatchmakingGroupErrorUpdate" ontrigger="SetText(param1);"
					></label>
					<panel height="1.0h" color="invisible" noclick="true"/>
				</panel>
		</floater>
	</template>
	<trigger name="MatchmakingGroupErrorUpdate" />
	<instance name="matchmaking_group_error_floater" />

	<template name="mm_start_match_btn">
		<panel name="{btnname}" y="-0.8h" width="310i" height="30i" x="-80i" align="center" valign="bottom" noclick="true" visible="{visible}">
			<button
				width="100%" height="3.8h"
				valign="bottom"
				color="invisible"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				onclick="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav}');"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('EnterQueue')"
			>
				<widgetstate statename="up">
					<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1"/>
					<label name="{labelname}_1" width="100%" height="100%" textvalign="center" textalign="center" font="dyn_14" color="#ffc600" outline="true" content="{buttonlabel}" autofont="1" autofontmax="14"/>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/info/button_over.tga" borderthickness="0.6h" />
					<label name="{labelname}_2" width="100%" height="100%" textvalign="center" textalign="center" font="dyn_14" color="#ffc600" outline="true" content="{buttonlabel}" autofont="1" autofontmax="14"/>
				</widgetstate>
				<widgetstate statename="down">
					<frame texture="/ui/info/button_down.tga" borderthickness="0.6h" color="white"/>
					<label name="{labelname}_3" width="100%" height="100%" textvalign="center" textalign="center" font="dyn_14" color="#ffc600" outline="true" content="{buttonlabel}" autofont="1" autofontmax="14"/>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/info/button.tga" borderthickness="0.6h" color=".3 .3 .3 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label name="{labelname}_4" width="100%" height="100%" textvalign="center" textalign="center" font="dyn_14" color=".4 .4 .4 1" outline="true" content="{buttonlabel}" autofont="1" autofontmax="14"/>
				</widgetstate>
			</button>
			<panel name="{btnname}_seasonend" width="100%" height="3.8h" valign="bottom" color="0 0 0 .6"
					onmouseoverlua="Trigger('genericMainFloatingTip', 'true', '20h', '', '', 'season_is_end', '', '', '3h', '-2h')" onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')" visible="0"/>
			<modelpanel
				name="{btnname}_effect"
				width="100%" height="3.8h"
				valign="bottom"
				noclick="true"
				model="/ui/common/models/main/button.mdf"
				anim="idle"
				camerapos="0 -1500 2"
				cameraangles="0 0 0"
				camerafov="4.42"
				carmerafar="7000"
				depthclear="false"
				depthcompress="true"
				sunazimuth="140"
				sunaltitude="10"
				suncolor="1.4 1.3 1"
				onshow="SetEffect('/ui/common/models/main/button.effect'));"
			/>
			<frame width="100%" height="3.8h" valign="bottom" texture="/ui/frames/black_corners.tga" color="invisible" borderthickness="0.6h" bordercolor="red" noclick="true" />
		</panel>
	</template>

	<template name="placement_match">
		<panel width="64i" height="16i" noclick="1">
			<image name="placement_match_{id}_line" texture="/ui/fe2/season/finishmatch.tga" noclick="1"/>
			<panel x="27i" y="-60i" align="right" valign="top" width="64i" height="64i" noclick="1">
				<image name="placement_match_{id}_icon" x="5i" y="8i" width="-8i" height="-8i" texture="/ui/fe2/season/dag.tga" noclick="1"/>
				<panel name="placement_match_{id}_text">
					<panel width="50%" height="75%" align="left" valign="top">
						<label textalign="right" textvalign="bottom" color="#6a777e" font="dyn_24" noclick="true" content="{id}"/>
					</panel>
					<panel width="45%" height="65%" align="right" valign="top">
						<label textalign="left" textvalign="bottom" color="#6a777e" font="dyn_9" noclick="true" content="{suffix}"/>
					</panel>
					<panel width="100%" height="35%" align="center" valign="bottom">
						<label textalign="center" textvalign="top" color="#6a777e" font="dyn_9" noclick="true" content="Match"/>
					</panel>
				</panel>
		 	</panel>
		</panel>
	</template>

	<template name="matchmaking">

		<panel y="-110%" width="117.5h" align="center" name="matchmaking" visible="false" noclick="true"
			onshow="DoEvent(2)"
			onshowlua="RequestRankedPlayInfo() GetWidget('season_not_eligible_mask'):SetVisible(false)
						if HoN_Matchmaking.selectedTab == 'season' then
							Cmd('GetCampaignSeasonRewards')
						end"
			watch="EntityDefinitionsLoaded" ontrigger="Call('matchmaking_panels', 'SetVisible(1);'); DoEvent(2);"
			onevent2lua="if (self:IsVisible()) then UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_OnShow') end"
			onhidelua="UIManager.GetInterface('main'):HoNMatchmakingF('OnHide')"
		>
			<panel x="0" y="-100%" height="203.6%" width="90%" align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel x="18h" y="-100%" height="203.6%" width="50@" align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-18h" y="-100%" height="203.6%" width="50@" align="left" texture="mainmenu/upper_frame_left.tga"/>

			<!-- Header -->
			<panel name="matchmaking_header" y="1.0h" height="2.8h" width="-6.0h" align="center" noclick="true">
				<instance name="header_bar" show_close="true" onclick="Set('_mainmenu_currentpanel', 'matchmaking'); CallEvent('MainMenuPanelSwitcher');" />
				<panel width="-1.0h" align="center" noclick="true" passivechildren="true">
					<label height="100%" valign="center" textalign="left" textvalign="center" color="white" shadow="true" font="dyn_12" noclick="true" content="mm_title"/>
				</panel>

			</panel>

			<panel name="matchmaking_panels" y="4.0h" height="-4.5h" width="-6.0h" align="center" noclick="true" visible="1">


				<panel x="14.6h" width="-14.5h" noclick="true" clip="1">

					<panel color="#183042" noclick="true"/>
					<panel width="-0.8h" height="-0.8h" align="center" valign="center" color="0 0 0 1" noclick="true">
						<!--<image y="1" width="-2" height="36%" align="center" texture="/ui/info/grad_vert.tga" color="#1f3f57" noclick="true" />-->
					</panel>

					<panel y="0.8h" width="-1.6h" height="-6.0h" align="center" valign="top" float="right" padding="0.5h" noclick="true">

						<!-- Team Builder -->
						<panel width="31.0h" noclick="true" onshow="BringToFront();">
							<panel width="102%" color="black" />
							<instance name="header_bar" color=".7 .7 .7 1" height="2.5h" lbl="mm3_coop_team" show_close="false"/>

							<panel height="-2.8h" valign="bottom" float="bottom" padding="0.2h" noclick="true">
								<!-- Team Slot 1 (Host) -->
								<panel height="8.5h"
									onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('HoverTeamSlot', self, 1)"
									onmouseout="HideWidget('matchmaking_group_error_tooltip');"
								>
									<frame name="mm_topslot_frame1" texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" noclick="1"/>
									<panel name="mm_topslot_background" align="center" valign="center" width="-0.25h" height="-0.25h" noclick="1" color="invisible"/>

									<!-- Slot Number / Account Status -->
									<panel height="100%" width="3.0h" noclick="true">
										<frame name="mm_topslot_frame2" texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color="#183042" noclick="1"/>
										<panel name="mm_topslot_cpanel" width="50%" align="right" color="#183042" noclick="true"/>
										<label y="0.2h" textalign="center" font="dyn_16" color="1 1 1 1" shadow="true" content="1" noclick="true" />
										<image name="mm_player_verified" y="-0.6h" valign="bottom" align="center" width="76%" height="76@" texture="/ui/elements/verified.tga" noclick="1" visible="0"/>
									</panel>

									<panel x="-0.5h" width="-4.0h" height="-1.0h" align="right" valign="center" noclick="1">
										<!-- Account Icon -->
										<image name="mm_player_icon" height="100%" width="100@" texture="/ui/fe2/store/icons/account_icons/default.tga" noclick="true" />

										<panel width="-108@" align="right" noclick="true">
											<label name="mm_player_name" fity="true" font="dyn_14" color="#ffaa00" content="[S2]Pillowpants2" noclick="true" />
											<label name="mm_player_title" y="1.8h" fity="true" textalign="right" font="dyn_10" color=".6 .6 .6 1" noclick="true" />
											<button
												name="mm_selfleave"
												align="right"
												color="invisible"
												width="30@" height="30%"
												onmouseover="
														PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');
														PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
														Trigger('genericMainFloatingTip', 'true', '28.0h', '', 'tmm_leavegroup', 'tmm_leavegroup_tip', '', '', '3.0h', '-2.0h');
														"
												onmouseout="HideWidget('genericMainFloatingTip');"
												onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('LeaveGroup')"
											>
												<widgetstate statename="up">
													<image texture="/ui/elements/kick_up.tga"/>
												</widgetstate>

												<widgetstate statename="over">
													<image texture="/ui/elements/kick_over.tga"/>
												</widgetstate>

												<widgetstate statename="down" x="1" y="1">
													<image texture="/ui/elements/kick_down.tga"/>
												</widgetstate>
												<widgetstate statename="disabled">
													<image texture="/ui/elements/kick_disabled.tga"/>
												</widgetstate>
											</button>
											<label name="mm_player_mmr" y="32%" fity="true" font="dyn_12" color="#37b2d9" content="MMR: 1500" noclick="true" />
											<panel name="mm_player_ranklevel_root" y="32%" height="30%" width="80%" noclick="1">
												<image name="mm_player_ranklevel_icon" x="-45@" width="230@" height="230%" align="left" valign="center" texture="$invis" noclick="1" />
												<label name="mm_player_ranklevel_text" x="145@" textalign="left" textvalign="center" font="dyn_10" color="white" content="-" noclick="1"/>
											</panel>
											<panel height="48%" valign="bottom" noclick="true">

												<!-- Account Progress Lvl Bar -->
												<panel width="-130@" noclick="true">
													<!-- Lvl Bar -->
													<panel valign="bottom" height="-1.0h" color="invisible" noclick="true">
														<image texture="/ui/legion/behind_bar.tga" color="#170045" noclick="true" />
														<panel name="tmm_infopanel_stats_progress_1" width="50%" noclick="true">
															<image texture="/ui/legion/behind_bar.tga" color="#ac00f5" noclick="true" />
															<image align="right" texture="/ui/legion/behind_bar.tga" color="1 1 1 .5" noclick="true" />
														</panel>
														<image width="-0.6h" align="center" texture="/ui/elements/bar_highlight.tga" noclick="true" />
														<frame color="invisible" bordercolor=".2 .2 .2 1" borderthickness="1" noclick="true" />
													</panel>
												</panel>

												<!-- Account Level-->
												<panel height="100%" width="120@" align="right" noclick="true">
													<frame texture="/ui/info/backdrop.tga" color="1 1 1 .2" noclick="true" />
													<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true" />
													<label name="mm_player_level" textalign="center" textvalign="center" font="dyn_14" color="1 1 1 1" shadow="true" content="15" noclick="true" />
												</panel>

											</panel>
										</panel>
									</panel>
								</panel>

								<!-- Player Slots / Invite Windows -->
								<panel height="27.5h" float="bottom" padding="0.2h" noclick="true">
									<!-- Team Slots 2-5 -->
									<instance name="mm_team_slot_occupied_2" slot="2" />
									<instance name="mm_team_slot_empty_2" slot="2" />
									<instance name="mm_team_slot_bot_2" slot="2" />

									<instance name="mm_team_slot_occupied_2" slot="3" />
									<instance name="mm_team_slot_empty_2" slot="3" />
									<instance name="mm_team_slot_bot_2" slot="3" />

									<instance name="mm_team_slot_occupied_2" slot="4" />
									<instance name="mm_team_slot_empty_2" slot="4" />
									<instance name="mm_team_slot_bot_2" slot="4" />

									<instance name="mm_team_slot_occupied_2" slot="5" />
									<instance name="mm_team_slot_empty_2" slot="5" />
									<instance name="mm_team_slot_bot_2" slot="5" />

									<!-- Invite Person -->
									<panel name="mm_invite_person" y="0" width="100%" height="+.5h" noclick="true" visible="false"
										watch="LoginStatus"
										ontrigger="If(!param2, SetVisible(0));"
										onshowlua="HoN_Matchmaking:StartSavingInvites()"
										onhidelua="HoN_Matchmaking:DumpInvitedList()"
									>
										<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color="0 0 0 1" />
										<frame texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" />

										<panel y="0.7h" width="-1.2h" height="2.2h" align="center" noclick="true">
											<label x="0.4h" width="-0.4h" height="100%" font="dyn_14" color="#ffaa00" content="mm3_coop_inviteperson" />
											<instance name="closex_btn" align="right" valign="center" onclick="Call('mm_invite_person', 'FadeOut(100);');" />
										</panel>

										<!-- search bar -->
										<panel name="mm_invite_person_search" y="3.3h" x="0h" height="2.8h" width="-1.2h" align="center" noclick="true">
											<panel width="75%" align="left" onclick="Call('mm_autocomplete_textbox', 'SetFocus(true);');">
												<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.4h" color="0 0 0 0.6" blockinput="false" noclick="true"/>
												<frame texture="/ui/frames/roundframe.tga" color="#30405d" borderthickness="0.6h" blockinput="false" noclick="true"/>
												<image valign="center" x="2%" y="1%" height="80%" width="80@" align="left" texture="/ui/common/new_shop_interface/magnify.tga" noclick="1"/>
												<textbox
													name="mm_autocomplete_textbox"
													x="2.0h"
													y="-0.125h"
													hmargin="1.0h" vmargin="0.4h"
													maxlength="15"
													textalign="center" textvalign="center"
													font="dyn_14"
													textcolor="white"
													shadow="true"
													color="invisible"
													onshow="SetFocus(true);"
													onesc="
														EraseInputLine();
														Call('mm_invite_person', 'FadeOut(100);');
													"
													onevent1lua="UIManager.GetInterface('main'):HoNMatchmakingF('InvitePlayer', self)"
													onenter="DoEvent(1);"
													onchange="If(StringLength(this) ge 5,
																ChatAutoCompleteNick(StripClanTag(this)),
																Trigger('ChatAutoCompleteClear')
															  );
															  If(StringLength(this) gt 0,
															  	Split(
																	If(!StringEquals(this, StripClanTag(GetAccountName())),
																		EnableWidget('mm_invite_person_button'),
																		DisableWidget('mm_invite_person_button')
																	),
																	Call('mm_enter_name', 'SetVisible(0);')
																),
																DisableWidget('mm_invite_person_button')
															  );"
													onhide="EraseInputLine(); Call('mm_enter_name', 'SetVisible(1);');"
													onhidelua="self:Sleep(1, function() end)"
													onmousewheeldown="CallEvent('mm_invite_scrollbar', 1);"
													onmousewheelup="CallEvent('mm_invite_scrollbar', 0);"
												/>
												<label name="mm_enter_name" x="3.8h" width="-0.5h" height="-0.4h" valign="center" align="left" textvalign="center" font="dyn_10" color="white" shadow="true" content="social_panel_enter_name" noclick="1" />
												<panel noclick="0" blockinput="0" processonlyscroll="1" hover="false"
													onmousewheeldown="CallEvent('mm_invite_scrollbar', 1);"
													onmousewheelup="CallEvent('mm_invite_scrollbar', 0);"
												/>
											</panel>

											<instance
												name="button2"
												enabled="false"
												height="2.8h" width="24%"
												align="right" valign="center"
												font="dyn_10"
												label="cc_com_button_findoptions_invite"
												onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('InvitePlayer', GetWidget('mm_autocomplete_textbox'))"
												button_name="mm_invite_person_button"
											/>
										</panel>

