	<template name="team_type">
		<frame name="{id}" group="{group=customgames_optionstab}" onshow="{onshow}" color=".1 .1 .1 1" bordercolor=".2 .2 .2 1" borderthickness="1" noclick="1" visible="{visible}" />
		<label name="{id}_label" height="100%" textvalign="center" textalign="center" font="dyn_12" color="{fontcolor}" shadow="true" content="{label}" />
		<!-- Click Controls -->
		<panel
			onclick="{onclick}"
			onevent="{onevent}"
			onload="{onload}"
			oneventlua="{oneventlua}"
		/>
	</template>

	<template name="mm_team_slot_bot_2">
		<panel name="mm_team_slot{slot}_bot" height="6.75h" noclick="0" sticky="1" stickytoinvis="0"
			onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('HoverTeamSlot', self, {slot})"
			onmouseout="HideWidget('matchmaking_group_error_tooltip');"
		>
			<frame texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" noclick="1"/>
			<panel align="center" valign="center" width="-0.25h" height="-0.25h" noclick="1" color="invisible"/>

			<!-- Slot Number / Account Status -->
			<panel height="100%" width="3.0h" noclick="true">
				<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color="#183042" noclick="1"/>
				<panel width="50%" align="right" color="#183042" noclick="true" />
				<label y="0.2h" textalign="center" font="dyn_16" color="1 1 1 1" shadow="true" content="{slot}" noclick="true" />
				<image name="mm_botslot{slot}_subicon" y="-0.6h" valign="bottom" align="center" width="76%" height="76@" texture="/ui/elements/verified.tga" noclick="1"/>
			</panel>

			<panel x="-0.5h" width="-4.0h" height="-1.0h" align="right" valign="center" noclick="1">
				<!-- Account Icon -->
				<image name="mm_botslot{slot}_icon" height="100%" width="100@" texture="/ui/fe2/store/icons/account_icons/stupid.tga" noclick="true" />

				<panel width="-108@" align="right" noclick="1">
					<label name="mm_botslot{slot}_name" fity="true" font="dyn_14" color="#ffaa00" content="Player Name" noclick="true" />
					<label name="mm_botslot{slot}_botver" y="0.4h" fity="true" textalign="right" font="dyn_10" color=".6 .6 .6 1" content="v1.0" noclick="true" />

					<panel height="50%" valign="bottom" noclick="true">
						<!-- Invite Person -->
						<button
							name="mm_botslot{slot}_invite"
							width="50%"	height="100%"
							color="invisible"
							visible="1"
							onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
							onclick="showwidget('mm_invite_person'); EnableWidget('mm_invite_person_button'); DisableWidget('mm_invite_person_button');"
							onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('ClickInvitePerson', {slot})"
						>
							<widgetstate statename="up">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_invitetoteam" />
								</panel>
							</widgetstate>
							<widgetstate statename="over">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitetoteam" />
								</panel>
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitetoteam" />
								</panel>
							</widgetstate>
							<widgetstate statename="disabled">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" rendermode="grayscalse" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_invitetoteam" />
								</panel>
							</widgetstate>
						</button>


						<!-- Invite Bot -->
						<button
							name="mm_botslot{slot}_invitebot"
							width="50%"	height="100%"
							align="right"
							color="invisible"
							visible="1"
							onclick="Call('mm_invite_bot', 'FadeIn(100);');"
							onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('RepickBot', self, {slot}, 'left')"
						>
							<widgetstate statename="up">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_up.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
							<widgetstate statename="over">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_over.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_over.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
							<widgetstate statename="disabled">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="50@" height="50%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_up.tga" rendermode="grayscale" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
						</button>
					</panel>

					<button
						name="mm_botslot{slot}_kick"
						x="-4@" y="-4%"
						color="invisible"
						width="44@" height="44%" align="right" valign="bottom"
						onmouseover="
								PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');
								PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
								Trigger('genericMainFloatingTip', 'true', '28.0h', '', 'mm3_kickbots', 'mm3_kickbots_desc', '', '', '3.0h', '-2.0h')
								"
						onmouseout="HideWidget('genericMainFloatingTip');"
						onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('KickBots')"
					>
						<widgetstate statename="up">
							<image texture="/ui/elements/kick_up.tga"/>
						</widgetstate>

						<widgetstate statename="over">
							<image texture="/ui/elements/kick_over.tga"/>
						</widgetstate>

						<widgetstate statename="down" x="1" y="1">
							<image texture="/ui/elements/kick_down.tga"/>
						</widgetstate>
						<widgetstate statename="disabled">
							<image texture="/ui/elements/kick_disabled.tga"/>
						</widgetstate>
					</button>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="mm_team_slot_occupied_2">
		<panel name="mm_team_slot{slot}_occupied" height="6.75h" noclick="0" sticky="1" stickytoinvis="0"
			onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('HoverTeamSlot', self, {slot})"
			onmouseout="HideWidget('matchmaking_group_error_tooltip');"
			onrightclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('RightClickPlayer', {slot})"
		>
			<frame name="mm_slot{slot}_frame1" texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" noclick="1"/>
			<panel name="mm_slot{slot}_background" align="center" valign="center" width="-0.25h" height="-0.25h" noclick="1" color="invisible"/>

				<!-- Slot Number / Account Status -->
				<panel height="100%" width="3.0h" noclick="true">
					<frame name="mm_slot{slot}_frame2" texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color="#183042" noclick="1"/>
					<panel name="mm_slot{slot}_cpanel" width="50%" align="right" color="#183042" noclick="true" />
					<label y="0.2h" textalign="center" font="dyn_16" color="1 1 1 1" shadow="true" content="{slot}" noclick="true" />
					<image name="mm_teamslot{slot}_subicon" y="-0.6h" valign="bottom" align="center" width="76%" height="76@" texture="/ui/elements/verified.tga" noclick="1"/>
				</panel>

				<panel x="-0.5h" width="-4.0h" height="-1.0h" align="right" valign="center" noclick="1">
					<!-- Account Icon -->
					<image name="mm_teamslot{slot}_icon" height="100%" width="100@" texture="/ui/fe2/store/icons/account_icons/stupid.tga" noclick="true" />

					<panel width="-108@" align="right" noclick="1">
						<label name="mm_teamslot{slot}_name" fity="true" font="dyn_14" color="#ffaa00" content="Player Name" noclick="true" />
						<label name="mm_teamslot{slot}_botver" y="0.4h" fity="true" textalign="right" font="dyn_10" color=".6 .6 .6 1" content="v1.0" noclick="true" />
						<label name="mm_teamslot{slot}_namesub" y="54%" fity="true" font="dyn_12" color="#37b2d9" content="MMR: 1500" noclick="true" />
						<panel name="mm_teamslot{slot}_ranklevel_root" y="54%" height="50%">
							<image name="mm_teamslot{slot}_ranklevel_icon" x="-40@" width="200@" height="200%" align="left" valign="center" texture="$invis" noclick="1" />
							<label name="mm_teamslot{slot}_ranklevel_text" x="140@" textalign="left" textvalign="center" font="dyn_12" color="white" content="-" noclick="1"/>
						</panel>
						<button
							name="mm_teamslot{slot}_kick"
							x="-4@" y="-4%"
							color="invisible"
							width="44@" height="44%" align="right" valign="bottom"
							onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');
										Trigger('genericMainFloatingTip', true, '25h', '', 'game_menu_kick', 'game_lobby_kick_tip', '', '', '3h', '-2h');"
							onmouseout="HideWidget('genericMainFloatingTip');"
							onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('KickTeamMember', self, {slot})"

						>
							<widgetstate statename="up">
								<image texture="/ui/elements/kick_up.tga"/>
							</widgetstate>

							<widgetstate statename="over">
								<image texture="/ui/elements/kick_over.tga"/>
							</widgetstate>

							<widgetstate statename="down" x="1" y="1">
								<image texture="/ui/elements/kick_down.tga"/>
							</widgetstate>
							<widgetstate statename="disabled">
								<image texture="/ui/elements/kick_disabled.tga"/>
							</widgetstate>
						</button>
					</panel>
				</panel>

		</panel>
	</template>

	<template name="mm_team_slot_empty_2">
		<panel name="mm_team_slot{slot}_empty" height="6.75h" noclick="true" sticky="1" stickytoinvis="0">
			<frame texture="/ui/frames/roundframe.tga" color=".3 .3 .3 1" borderthickness="0.6h" />

				<!-- Slot Number -->
				<panel height="100%" width="3.0h" noclick="true">
					<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color=".3 .3 .3 1" />
					<panel width="50%" align="right" color=".3 .3 .3 1" noclick="true" />
					<label y="0.2h" textalign="center" font="dyn_16" color="1 1 1 1" shadow="true" content="{slot}" noclick="true" />
				</panel>

				<panel x="-0.5h" width="-4.0h" height="-1.0h" align="right" valign="center">
					<!-- Account Icon -->
					<image name="mm_teamslot{slot}_icon_dis" height="100%" width="100@" texture="/ui/fe2/store/icons/account_icons/default.tga" noclick="true" />

					<panel width="-108@" align="right" noclick="true">
						<label name="mm_teamslot{slot}_text" font="dyn_12" color=".5 .5 .5 1" textalign="center" content="mm3_coop_emptyslot" noclick="true" />
						<panel height="60%" valign="bottom" noclick="true">

							<!-- Invite Person -->
							<button
								name="mm_teamslot{slot}_invite"
								width="55%"	height="100%"
								color="invisible"
								visible="1"
								onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
								onclick="showwidget('mm_invite_person'); EnableWidget('mm_invite_person_button'); DisableWidget('mm_invite_person_button');"
								onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('ClickInvitePerson', {slot})"
							>
								<widgetstate statename="up">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="over">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="down" x="1" y="1">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="disabled">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" rendermode="grayscalse" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
							</button>


							<!-- Invite Bot -->
							<button
								name="mm_teamslot{slot}_invitebot"
								width="45%"	height="100%"
								align="right"
								color="invisible"
								visible="1"
								onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
								onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('FillTeamWithBots')"
							>
								<!-- onclick="Call('mm_invite_bot', 'FadeIn(100);');" -->
								<!-- onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('RepickBot', self, {slot}, 'left')" -->
								<widgetstate statename="up">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="over">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="down" x="1" y="1">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="disabled">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="50@" height="50%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" rendermode="grayscale" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
							</button>

						</panel>
					</panel>
				</panel>
		</panel>
	</template>

	<template name="mm_team_slot_occupied">
		<panel name="mm_team_slot{slot}_occupied" height="5.2h" noclick="0" sticky="1" stickytoinvis="0"
			onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('HoverTeamSlot', self, {slot})"
			onmouseout="HideWidget('matchmaking_group_error_tooltip');"
		>
			<frame name="mm_slot{slot}_frame1" texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" noclick="1"/>
			<panel name="mm_slot{slot}_background" align="center" valign="center" width="-0.25h" height="-0.25h" noclick="1" color="invisible"/>

			<!-- Slot Number / Account Status -->
			<panel height="100%" width="3.0h" noclick="true">
				<frame name="mm_slot{slot}_frame2" texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color="#183042" noclick="1"/>
				<panel name="mm_slot{slot}_cpanel" width="50%" align="right" color="#183042" noclick="true" />
				<label y="0.2h" textalign="center" font="dyn_16" color="1 1 1 1" shadow="true" content="{slot}" noclick="true" />
				<image name="mm_teamslot{slot}_subicon" y="-0.6h" valign="bottom" align="center" width="62%" height="62@" texture="/ui/elements/verified.tga" noclick="1"/>
			</panel>

			<panel x="-0.5h" width="-4.0h" height="-1.0h" align="right" valign="center" noclick="1">
				<!-- Account Icon -->
				<image name="mm_teamslot{slot}_icon" height="100%" width="100@" texture="/ui/fe2/store/icons/account_icons/stupid.tga" noclick="true" />

				<panel width="-108@" align="right" noclick="1">
					<label name="mm_teamslot{slot}_name" fity="true" font="dyn_14" color="#ffaa00" content="Player Name" noclick="true" />
					<label name="mm_teamslot{slot}_botver" y="0.4h" fity="true" textalign="right" font="dyn_10" color=".6 .6 .6 1" content="v1.0" noclick="true" />
					<label name="mm_teamslot{slot}_namesub" y="54%" fity="true" font="dyn_12" color="#37b2d9" content="MMR: 1500" noclick="true" />
					<button
						name="mm_teamslot{slot}_kick"
						x="-4@" y="-4%"
						color="invisible"
						width="44@" height="44%" align="right" valign="bottom"
						onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
						onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('KickTeamMember', self, {slot})"

					>
						<widgetstate statename="up">
							<image texture="/ui/elements/kick_up.tga"/>
						</widgetstate>

						<widgetstate statename="over">
							<image texture="/ui/elements/kick_over.tga"/>
						</widgetstate>

						<widgetstate statename="down" x="1" y="1">
							<image texture="/ui/elements/kick_down.tga"/>
						</widgetstate>
						<widgetstate statename="disabled">
							<image texture="/ui/elements/kick_disabled.tga"/>
						</widgetstate>
					</button>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="mm_team_slot_empty">
		<panel name="mm_team_slot{slot}_empty" height="5.2h" noclick="true" sticky="1" stickytoinvis="0">
			<frame texture="/ui/frames/roundframe.tga" color=".3 .3 .3 1" borderthickness="0.6h" />

				<!-- Slot Number -->
				<panel height="100%" width="3.0h" noclick="true">
					<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.6h" color=".3 .3 .3 1" />
					<panel width="50%" align="right" color=".3 .3 .3 1" noclick="true" />
					<label y="0.2h" textalign="center" font="dyn_16" color="1 1 1 1" shadow="true" content="{slot}" noclick="true" />
				</panel>

				<panel x="-0.5h" width="-4.0h" height="-1.0h" align="right" valign="center">
					<!-- Account Icon -->
					<image name="mm_teamslot{slot}_icon_dis" height="100%" width="100@" texture="/ui/fe2/store/icons/account_icons/default.tga" noclick="true" />

					<panel width="-108@" align="right" noclick="true">
						<label name="mm_teamslot{slot}_text" font="dyn_12" color=".5 .5 .5 1" textalign="center" content="mm3_coop_emptyslot" noclick="true" />
						<panel height="50%" valign="bottom" noclick="true">

							<!-- Invite Person -->
							<button
								name="mm_teamslot{slot}_invite"
								width="55%"	height="100%"
								color="invisible"
								visible="0"
								onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
								onclick="showwidget('mm_invite_person'); EnableWidget('mm_invite_person_button'); DisableWidget('mm_invite_person_button');"
								onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('ClickInvitePerson', {slot})"
							>
								<widgetstate statename="up">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="over">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="down" x="1" y="1">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="disabled">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" rendermode="grayscalse" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_invitetoteam" />
									</panel>
								</widgetstate>
							</button>


							<!-- Invite Bot -->
							<button
								name="mm_teamslot{slot}_invitebot"
								width="45%"	height="100%"
								align="right"
								color="invisible"
								visible="0"
								onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
								onclick="Call('mm_invite_bot', 'FadeIn(100);');"
								onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('RepickBot', self, {slot}, 'left')"
							>
								<widgetstate statename="up">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="over">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="down" x="1" y="1">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_over.tga" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
								<widgetstate statename="disabled">
									<panel float="right">
										<panel height="100%" width="100@">
											<image width="74@" height="74%" valign="center" align="center" texture="/ui/elements/addfriend_up.tga" rendermode="grayscale" />
										</panel>
										<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_invitebottoteam" />
									</panel>
								</widgetstate>
							</button>

						</panel>
					</panel>
				</panel>
		</panel>
	</template>

	<template name="mm_loading_progressbar">
		<panel watch="{watch}" ontrigger="{ontrigger}" sticky="true" stickytoinvis="false" height="{height=1.5h}" width="100%" noclick="true" visible="{visible=false}">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="#171a28"/>
			<panel x="0.2h" y="0.2h" width="-0.4h" height="-0.35h">
				<panel width="1%" color="green"
					watch="{barwatch}" ontrigger="{barontrigger}"
					watch0="{barwatch0}" ontrigger0="{barontrigger0}"
					watch1="{barwatch1}" ontrigger1="{barontrigger1}"
					watch2="{barwatch2}" ontrigger2="{barontrigger2}"
					watch3="{barwatch3}" ontrigger3="{barontrigger3}"
					watch4="{barwatch4}" ontrigger4="{barontrigger4}"
					watch5="{barwatch5}" ontrigger5="{barontrigger5}"
					watch6="{barwatch6}" ontrigger6="{barontrigger6}"
					watch7="{barwatch7}" ontrigger7="{barontrigger7}"
					watch8="{barwatch8}" ontrigger8="{barontrigger8}"
					watch9="{barwatch9}" ontrigger9="{barontrigger9}"
				/>
			</panel>
			<frame texture="/ui/frames/roundframe.tga" color="#bbdefa" borderthickness="0.3h"/>
			<label y="-0.1h" width="100%" height="100%" textalign="center" textvalign="center" font="{font=dyn_9}" color="white" shadow="true" content="{label}" watch="{labelwatch}" ontrigger="{labelontrigger}" />

			<!-- Darken -->
			<panel visible="{darken=false}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="0 0 0 .8"/>
				<frame texture="/ui/frames/roundframe.tga" color="#678095" borderthickness="0.3h"/>
			</panel>
		</panel>
	</template>

	<template name="mm_loading_status_light">
		<panel
			sticky="true"
			stickytoinvis="false"
			width="2.3h"
			height="4.0h"
			noclick="true"
			passivechildren="true"
			visible="false"
			watch="LobbyPlayerList{index}"
			ontrigger="SetVisible(!param17 and param18);"
		>
			<!-- Not yet connected -->
			<image
				visible="false"
				texture="/ui/fe2/lobby/matchmaking_server_dot_gray.tga"
				width="136%"
				height="136@"
				align="center"
				valign="top"
				watch="LobbyPlayerList{index}"
				ontrigger="SetVisible(param19 == 0);"
			/>

			<!-- Loading -->
			<image
				visible="false"
				texture="/ui/fe2/lobby/matchmaking_server_dot_yellow.tga"
				width="136%"
				height="136@"
				align="center"
				valign="top"
				watch="LobbyPlayerList{index}"
				ontrigger="SetVisible(param19 == 1);"
			/>

			<!-- Loaded -->
			<image
				visible="false"
				texture="/ui/fe2/lobby/matchmaking_server_dot_green.tga"
				width="136%"
				height="136@"
				align="center"
				valign="top"
				watch="LobbyPlayerList{index}"
				ontrigger="SetVisible(param19 == 2);"
			/>
		</panel>
	</template>

	<template name="matchmaking_option_botteam">
		<panel name="matchmaking_option_botteam" group="mm3_botteam" width="-1.0h" height="-1.0h" align="center" valign="center">
			<panel float="right" padding="0.8h">
				<panel width="100@" height="100%" valign="center" color="invisible">
					<frame name="matchmaking_option_bots_thumb_background" texture="/ui/frames/rounded_bg_white.tga" color=".7 .7 .7 1" borderthickness="0.4h" />
					<frame name="matchmaking_option_bots_thumb_border" texture="/ui/frames/roundframe.tga" color="#0c3405" borderthickness="0.4h" />
					<image name="matchmaking_option_bots_thumb_icon" texture="/ui/fe2/elements/vote_up.tga" color=".8 .8 .8 1" visible="false"/>
				</panel>
				<panel width="-110@">
					<panel float="right" padding="0.5h">
						<image name="matchmaking_option_bots_icon" width="100@" height="100%" valign="center" texture="/ui/icons/botmatch.tga" rendermode="" />
						<label name="matchmaking_option_bots_text" width="-100@" height="100%" textvalign="center" font="dyn_11" color="#888888" shadow="true">Fill Empty Slots with Bots</label>
					</panel>
				</panel>
			</panel>
			<panel name="matchmaking_option_botteam_disabled_panel" group="mm3_botteam" visible="false">
				<frame width="102%" height="115%" align="center" valign="center" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .7" noclick="true"/>
				<frame width="102%" height="115%" align="center" valign="center" texture="/ui/frames/roundframe.tga" color=".5 .5 .5 1" borderthickness="0.4h" noclick="true" />
				<panel width="100@" height="100%" valign="center" color="invisible">
					<image width="80@" height="80%" align="center" valign="center" color="1 1 1 .8" texture="/ui/elements/kick_disabled.tga" />
				</panel>
				<label name="matchmaking_option_botteam_disabled_text" height="100%" width="-100@" align="right" textalign="center" textvalign="center" font="dyn_11" color=".7 .7 .7 1" shadow="true" wrap="true" content="mm_option_disabled" />
			</panel>
			<panel
				onmouseoverlua=""
				onmouseoutlua=""
				onclicklua=""
			/>
		</panel>
	</template>

	<template name="matchmaking_option_popularity_dot">
		<panel name="{basename}_{id}" width="9.0%" visible="{visible=false}">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.2h" color="{color}"/>
			<frame texture="/ui/frames/roundframe.tga" color="1 1 1 1" borderthickness="0.2h"/>
		</panel>
	</template>

	<template name="matchmaking_option_popularity_marker">
		<instance name="matchmaking_option_popularity_dot" id="1" color="1 .4 0 .1" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="2" color="1 .4 0 .2" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="3" color="1 .4 0 .3" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="4" color="1 .4 0 .4" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="5" color="1 .4 0 .5" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="6" color="1 .4 0 .6" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="7" color="1 .4 0 .7" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="8" color="1 .4 0 .8" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="9" color="1 .4 0 .9" basename="{basename}" visible="false" />
		<instance name="matchmaking_option_popularity_dot" id="10" color="1 .4 0 1" basename="{basename}" visible="false" />
	</template>

	<template name="matchmaking_option_region">
		<panel name="matchmaking_option_region_{regionid}" height="3.6h" group="matchmaking_option_regions" sticky="1" stickytoinvis="0">
			<panel float="right" padding="0.8h" x="0.9h">
				<panel width="100@" height="100%" valign="center" color="invisible">
					<frame name="matchmaking_option_region_{regionid}_thumb_background" texture="/ui/frames/rounded_bg_white.tga" color=".7 .7 .7 1" borderthickness="0.4h" />
					<frame name="matchmaking_option_region_{regionid}_thumb_border" texture="/ui/frames/roundframe.tga" color="#0c3405" borderthickness="0.4h" />
					<image name="matchmaking_option_region_{regionid}_thumb_icon" texture="/ui/fe2/elements/vote_up.tga" color=".8 .8 .8 1" visible="false"/>
				</panel>
				<panel width="-110@">
					<panel height="2.4h" float="right" padding="0.5h">
						<image name="matchmaking_option_region_{regionid}_icon" width="100@" height="100%" valign="center" texture="{icon}" rendermode="grayscale" />
						<label name="matchmaking_option_region_{regionid}_text" width="-100@" height="100%" textvalign="center" font="dyn_11" color="#888888" shadow="true">{label}</label>
					</panel>
					<panel y="-0.2h" height="-3.0h" valign="bottom" float="right" padding="0.5%">
						<instance name="matchmaking_option_popularity_marker" basename="matchmaking_option_region_{regionid}_popularity" />
					</panel>
				</panel>
			</panel>
			<panel name="matchmaking_option_region_{regionid}_disabled_panel" visible="false" x="0.9h">
				<frame width="104%" height="115%" align="center" valign="center" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .7" noclick="true"/>
				<frame width="104%" height="115%" align="center" valign="center" texture="/ui/frames/roundframe.tga" color=".5 .5 .5 1" borderthickness="0.4h"  noclick="true" />
				<panel width="100@" height="100%" valign="center" color="invisible">
					<image width="80@" height="80%" align="center" valign="center" color="1 1 1 .8" texture="/ui/elements/kick_disabled.tga" />
				</panel>
				<label name="matchmaking_option_region_{regionid}_disabled_text" height="100%" width="-100@" align="right" textalign="center" textvalign="center" font="dyn_11" color=".7 .7 .7 1" shadow="true" wrap="true" content="mm_option_disabled" />
			</panel>
			<panel
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_region_OnMouseOver', '{regionid}')"
				onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_region_OnMouseOut', '{regionid}')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_region_OnClick', '{regionid}')"
			/>
		</panel>
	</template>

	<template name="matchmaking_enemy_team_slot">
		<panel name="mm_enemy_team_slot_{id}" height="5.6h"
			onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('HoverEnemyTeamSlot', self, {id})"
			onmouseout="HideWidget('hero_info');"
		>
			<frame texture="/ui/frames/roundframe.tga" color="#183042" borderthickness="0.6h" noclick="true" />
			<panel width="-0.8h" height="-0.8h" valign="center" align="center" noclick="true">

				<!-- Icon -->
				<panel width="100@" height="100%" noclick="true">
					<image name="mm_enemyteam_{id}_icon" texture="/heroes/armadon/icon.tga" noclick="true" />
					<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
				</panel>

				<!-- Hero Details -->
				<panel x="110@" width="45%" height="100%" noclick="true">
					<label name="mm_enemyteam_{id}_name" font="dyn_14" color="#ffaa00" content="Keeper of the Forest" noclick="true" />
					<panel height="50%" valign="bottom" float="right" padding="0.5h" noclick="true">
						<image name="mm_enemyteam_{id}_attacktype" width="100@" height="100%" texture="/ui/fe2/lobby/ranged.tga" noclick="true" />
						<panel width="100@" height="100%" noclick="true">
							<image name="mm_enemyteam_{id}_type" y="-2@" width="118@" height="118%" texture="/ui/fe2/lobby/intelligence.tga" noclick="true" />
						</panel>

						<!-- Repick -->
						<button
							x="0"
							width="42%"	height="100%"
							align="right"
							color="invisible"
							onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); ShowWidget('hero_info');"
							onmouseout="HideWidget('hero_info');"
							onclick="Call('mm_repick_enemy_bot', 'FadeIn(100)');"
							onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('RepickBot', self, {id}, 'right')"
						>
							<widgetstate statename="up">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="82@" height="82%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_up.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="#37b2d9" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
							<widgetstate statename="over">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="82@" height="82%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_over.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="82@" height="82%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_down.tga" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color="1 1 1 1" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
							<widgetstate statename="disabled">
								<panel float="right">
									<panel height="100%" width="100@">
										<image width="82@" height="82%" valign="center" align="center" texture="/ui/fe2/lobby/swap_hero_up.tga" rendermode="grayscalse" />
									</panel>
									<label fitx="true" height="100%" textvalign="center" font="dyn_10" color=".5 .5 .5 1" content="mm3_coop_repickbot" />
								</panel>
							</widgetstate>
						</button>

					</panel>
				</panel>

				<!-- Abils -->
				<panel grow="true" height="88%" align="right" valign="center" float="right" padding="0.3h" noclick="true">
					<panel width="100@" height="100%" noclick="true">
						<image name="mm_enemyteam_{id}_ability1" texture="/heroes/armadon/ability_01/icon.tga" noclick="true" />
						<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
					</panel>
					<panel width="100@" height="100%" noclick="true">
						<image name="mm_enemyteam_{id}_ability2" texture="/heroes/armadon/ability_02/icon.tga" noclick="true" />
						<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
					</panel>
					<panel width="100@" height="100%" noclick="true">
						<image name="mm_enemyteam_{id}_ability3" texture="/heroes/armadon/ability_03/icon.tga" noclick="true" />
						<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true" />
					</panel>
					<panel width="100@" height="100%" noclick="true">
						<image name="mm_enemyteam_{id}_ability4" texture="/heroes/armadon/ability_04/icon.tga" noclick="true" />
						<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
					</panel>
				</panel>

			</panel>
		</panel>
	</template>

	<template name="season_gm_allpick_button">
		<panel name="season_gm_allpick_button_{id}" x="{x}" y="{y}"  width="255i" height="37i" color="invisible" >
			<image name="season_gm_allpick_button_{id}_default" texture="/ui/fe2/season/bb3.tga" width="512i" height="64i" align="center" valign="center" />
			<image name="season_gm_allpick_button_{id}_normal" texture="/ui/fe2/season/{image}.tga" width="512i" height="64i" align="center" valign="center" visible="0" />
			<image name="season_gm_allpick_button_{id}_casual" texture="/ui/fe2/season/{image}.tga" width="512i" height="64i" align="center" valign="center" visible="0" />
			<label name="season_gm_allpick_button_{id}_label" fity="true" x="45i" y="0.7h" width="100%" textalign="left" textvalign="center" font="dyn_14" color=".5 .5 .5 1" shadow="true" content="{label}" noclick="true" />

			<image name="season_gm_allpick_button_{id}_up_thumb" x="10i" width="32i" height="32i" align="left" valign="center" rendermode="grayscale" texture="/ui/fe2/elements/vote_up.tga" />
			<image name="season_gm_allpick_button_{id}_down_thumb" x="10i" width="32i" height="32i" align="left" valign="center" rendermode="grayscale" texture="/ui/fe2/elements/vote_down.tga" />

			<panel align="right" width="110i" float="right">
				<panel width="16i">
					<image name="season_gm_allpick_button_{id}_pickmode_icon" height="16i" align="center" valign="center" texture="/ui/icons/normal.tga" />
				</panel>
				<panel width="94i">
					<label name="season_gm_allpick_button_{id}_pickmode_text" textalign="center" textvalign="center" font="dyn_10" color="#81817f" noclick="1" autofont="1" autofontmax="10"/>
					<label name="season_gm_allpick_button_{id}_pickmode_text_1" x="0.5h" textalign="left" textvalign="top" font="dyn_10" color="#81817f" noclick="1" autofont="1" autofontmax="10"/>
					<label name="season_gm_allpick_button_{id}_pickmode_text_2" x="0.5h" textalign="left" textvalign="bottom" font="dyn_10" color="#81817f" noclick="1" autofont="1" autofontmax="10"/>
				</panel>
			</panel>
			<panel align="right" width="110i"
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('season_gm_allpick_button_OnMouseOver', '{id}')
								local rankInfo = GetRankedPlayInfo('{id}'=='normal' and 0 or 1)
								Trigger('genericMainFloatingTip', 'true', '20h', '', '', 'rank_pickmode_tips_{id}2', '', '', '3.0h', '-2.0h')"
				onmouseoutlua=" UIManager.GetInterface('main'):HoNMatchmakingF('season_gm_allpick_button_OnMouseOut', '{id}')
								Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('season_gm_allpick_button_OnClick', '{id}')"
			/>

			<panel width="-110i" align="left"
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('season_gm_allpick_button_OnMouseOver', '{id}')"
				onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('season_gm_allpick_button_OnMouseOut', '{id}')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('season_gm_allpick_button_OnClick', '{id}')"
			/>
		</panel>
	</template>
	
	<!-- old/orig map size -->
	<template name="matchmaking_option_map">
		<panel name="matchmaking_option_map_{mapid}_{index=1}" height="34.5%" valign="{valign}" visible="0" sticky="1" stickytoinvis="0">
			<frame name="matchmaking_option_map_{mapid}_{index=1}_backdrop" texture="/ui/info/backdrop.tga" borderthickness="3.0h" color="1 1 1 .3" noclick="1" />
			<frame name="matchmaking_option_map_{mapid}_{index=1}_border" color=".05 .07 .1 .5" bordercolor=".2 .2 .2 1" borderthickness="1" noclick="1" />
			<image name="matchmaking_option_map_{mapid}_{index=1}_cornerarrow" x="-0.2h" y="0.2h" width="1.8h" height="1.8h" align="right" valign="top" color="1 1 1 .5" texture="/ui/fe2/elements/corner_arrow.tga" />
			<label name="matchmaking_option_map_{mapid}_{index=1}_name" fity="true" x="0.8h" y="0.7h" width="100%" textalign="left" font="dyn_14" color=".5 .5 .5 1" shadow="true" content="{mapname}" noclick="true" />
			<panel x="0.8h" y="-0.8h" width="7.0h" height="7.0h" valign="bottom">
				<image name="matchmaking_option_map_{mapid}_{index=1}_minimap"
					resourcecontext="matchmaking" watch9="MainRegisterTextures"
					ontrigger9lua="
						if string.len('{minimapOverride2}') &gt; 0 then
							ResourceManager.RegisterTexture('{minimapOverride}', 'matchmaking', self)
						else
							ResourceManager.RegisterTexture('/maps/{mapid}/{minimapOverride=minimap.tga}', 'matchmaking', self)
						end
					"
				/>
				<frame name="matchmaking_option_map_{mapid}_{index=1}_minimap_border" color="invisible" bordercolor=".2 .2 .2 1" borderthickness="1" noclick="1" />
				<image name="matchmaking_option_map_{mapid}_{index=1}_minimap_thumb" width="4.0h" height="4.0h" align="center" valign="center" texture="/ui/fe2/elements/vote_up.tga" />
			</panel>
			<panel x="-0.8h" y="-0.8h" width="10h" height="7.0h" align="right" valign="bottom">
				<label name="matchmaking_option_map_{mapid}_{index=1}_teamsize_text" fity="true" width="100%" textalign="center" font="dyn_10" color=".5 .5 .5 1" shadow="true" content="{teamsize}" />
				<image name="matchmaking_option_map_{mapid}_{index=1}_icon" y="-0.2h" width="4.8h" height="4.8h" align="center" valign="bottom" color="1 1 1 .5"
					resourcecontext="matchmaking" watch9="MainRegisterTextures"
					ontrigger9lua="
						if string.len('{iconOverride2}') &gt; 0 then
							ResourceManager.RegisterTexture('{iconOverride}', 'matchmaking', self)
						else
							ResourceManager.RegisterTexture('/maps/{mapid}/{iconOverride=icon.tga}', 'matchmaking', self)
						end
					"
				/>
			</panel>
			<image name="matchmaking_option_map_{mapid}_{index=1}_beta" visible="{isBeta=0}" align="right" x="-1" y="1" width="135@" height="135%" noclick="1"
				resourcecontext="matchmaking" watch9="MainRegisterTextures"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/beta_banner.tga', 'matchmaking', self)"
			/>
			<image name="matchmaking_option_map_{mapid}_{index=1}_other_banner" visible="{hasBanner=0}" align="right" x="-1" y="1" width="135@" height="135%" noclick="1"
				resourcecontext="matchmaking" watch9="MainRegisterTextures"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/other_banner.tga', 'matchmaking', self)"
			/>
			<panel name="matchmaking_option_map_{mapid}_{index=1}_disabled" color="0 0 0 .5">
				<image width="80@" height="80%" align="center" valign="center" color=".3 .3 .3 1" texture="/ui/elements/kick_disabled.tga" />
				<label name="matchmaking_option_map_{mapid}_{index=1}_disabled_text" height="100%" width="14.0h" align="center" textalign="center" textvalign="center" font="dyn_11" color=".6 .6 .6 1" shadow="true" wrap="true" content="mm_map_locked" />
			</panel>
			<panel
				onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_map_OnMouseOver', '{mapid}')"
				onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_map_OnMouseOut', '{mapid}')"
				onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_option_map_OnClick', '{mapid}')"
			/>
		</panel>
	</template>

	<!-- new maps size for 2 maps -->
