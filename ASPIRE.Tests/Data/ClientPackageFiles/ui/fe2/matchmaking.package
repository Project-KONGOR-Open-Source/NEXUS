						<!-- Season Map and Options -->
						<panel name="mm_season_options" x="0" align="right" width="43.1h" visible="false" noclick="1"
							watch="RankInfoUpdated" ontriggerlua="HoN_Matchmaking:RefreshButtons()">
							<image y="1i" width="512i" height="512i" align="center" valign="center" texture="/ui/fe2/season/bgbg.tga" noclick="0" />
							<panel name="mm_season_options_hasrank">
								<!-- rank -->
								<panel y="5i" align="center" valign="top" height="64i" noclick="1">
									<label name="mm_season_options_rankname" align="center" valign="top" y="5i" height="30i" textvalign="center" textalign="center" font="dyn_18" noclick="1" color="#ffbc3cbb" />
									<image y="-10i" width="64i" height="64i" align="left" valign="top" x='98i' texture="/ui/fe2/season/ms2.tga" noclick="0"/>
									<image y="-10i" width="64i" height="64i" align="right" valign="top" x='-98i' hflip="1" texture="/ui/fe2/season/ms2.tga" noclick="0"/>
									<image name="mm_season_options_rankicon" width="168i" height="168i" y="90i" align="center" valign="center" texture="$invis" noclick="1" />
								</panel>

								<!-- next rank -->
								<panel name="mm_season_options_nextrank_root" width="64i" height="64i" align="right" valign="top" x='-21.33i' y='152.8i'>
									<label height="15i" width="80i" align="center" valign="top" y="-10i" textvalign="center" textalign="center" content="mm3_season_next_rank" noclick="1" font="dyn_9" color="#ffbc3cbb" />
									<image width="64i" height="64i" align="center" valign="center" texture="/ui/fe2/season/nn2.tga" noclick="0"/>
									<image name="mm_season_options_nextrank_icon" width="52i" height="52i" align="center" valign="center" texture="$invis" noclick="1" />
									<panel name="mm_season_options_nextrank_tips" onmouseoverlua="" onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"/>
								</panel>

								<!-- progress bar -->
								<panel name="mm_season_options_progressbar_root" width="406i" height="14i" align="center" valign="top" y="220i">
									<panel name="mm_season_options_progressbar" align="left" color="#7e35c2" width="100%"/>
									<image width="512i" height="64i" align="center" valign="center" texture="/ui/fe2/season/jindu002.tga" noclick="0" />
								</panel>

								<!-- win lose streak -->
								<panel width="70%" height="20i" align="center" y="245i" noclick="0" float="right">
									<panel width="36%">
										<label name="mm_season_options_wins" align="left" valign="center" textvalign="center" textalign="left" font="dyn_10" content="" noclick="1" color="#f8b63a"/>
									</panel>
									<panel width="36%">
										<label name="mm_season_options_losses" align="left" valign="center" textvalign="center" textalign="left" font="dyn_10" content="" noclick="1" color="#f8b63a"/>
									</panel>
									<if condition="cl_GarenaEnable">
										<panel width="36%">
											<label name="mm_season_options_winstreaks" align="left" valign="center" textvalign="center" textalign="left" font="dyn_10" content="" noclick="1" color="#f8b63a"/>
										</panel>
									</if>
								</panel>

								<label name="mm_season_options_debug" align="left" valign="center" x="2h" y="-1h" width="40h" height="4h" textvalign="center" textalign="left" font="dyn_12" noclick="1" color="white" content=""/>
							</panel>

							<panel name="mm_season_options_hasnorank">
								<panel height="4h" valign="top">
									<label textvalign="center" textalign="center" content="rank_placement_match" noclick="1" font="dyn_24" color="#ffb143" />
								</panel>
								<image y="-8h" align="center" valign="center" width="168i" height="168i" noclick="1" texture="/ui/fe2/season/nolevel.tga" rendermode="grayscale"/>
								<panel y="6.7h" height="6h" width="36h" float="right" padding="0.1h" align="center" valign="center">
									<instance name="placement_match" id="1" suffix="st"/>
									<instance name="placement_match" id="2" suffix="nd"/>
									<instance name="placement_match" id="3" suffix="rd"/>
									<instance name="placement_match" id="4" suffix="th"/>
									<instance name="placement_match" id="5" suffix="th"/>
									<instance name="placement_match" id="6" suffix="th"/>
								</panel>
							</panel>
							<!-- season info -->
							<instance width="118i" height="22i" align="center" y="280i" name="button2" label="mm3_season_info_button"
										onclicklua="local url = ''
													if GetCvarBool('cl_GarenaEnable') then
														url = 'http://www.hon.in.th/events/20161215_seasoninfo/?hongameclientcookie='..Client.GetCookie()..'|sea|'..GetCvarString('host_language')
													else
														url = 'http://fun.naeu.heroesofnewerth.com/events/20161215_seasoninfo/?hongameclientcookie='..Client.GetCookie()..'|naeu|'..GetCvarString('host_language')
													end

													UIManager.GetInterface('webpanel'):HoNWebPanelF('ShowPlayerTourStats', GetWidget('web_browser_player_tour_stats_insert'), url)
													UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'player_tour_stats', nil, false)" />

							<!-- match -->
							<panel width="90%" height="100i" align="center" valign="top" y="320i" noclick="0" >
								<image width="64i" height="64i" x='0i' y='2.67' align="left" valign="top" texture="/ui/fe2/season/mapi.tga" noclick="0"/>
								<label height="15i" width="80i" x='75i' y='-7.35i' align="left" valign="center" textvalign="center" textalign="left" font="dyn_12" content="mm_5v5" noclick="1" color="#989a9b"/>
								<label height="15i" width="170i" x='5i' y='32.5i' align="left" valign="center" textvalign="center" textalign="left" font="dyn_11" content="mm3_season_map_name" noclick="1" color="#e8eff2"/>

								<panel align="right" width="65%" >
									<instance name="season_gm_allpick_button" x="20i" y="8i" id="normal" label="mm_gen_normal" image="b1" />
									<instance name="season_gm_allpick_button" x="20i" y="56i" id="casual" label="mm_gen_casual" image="b22" />
									<if condition="!cl_GarenaEnable">
										<panel  x="20i" y="55i" width="255i" height="38i" color="0 0 0 .7"
											onmouseover="Trigger('genericMainFloatingTip', 'true', '20.0h', '', '', 'rank_pickmode_tips_disabled', '', '', '3.0h', '-2.0h')"
											onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');"/>
									</if>
								</panel>
							</panel>
						</panel>
					</panel>

					<!-- Start Button - Not Practice Match-->
					<instance name="mm_start_match_btn" btnname="mm_start_btn" visible="false" labelname="mm_queuebutton" buttonlabel="mm3_enterqueuebutton" />

					<!-- Start Button - Practice Match - Created a second button so there could be some cool transition between buttons when human is added? -->

					<instance name="mm_start_match_btn" btnname="mm_start_practice_btn" visible="true" labelname="mm_localgamebutton"  buttonlabel="mm3_localgamebutton" />
					<panel name="season_invalid_teammembers_number_mask" color="0 0 0 .8" y="-0.8h" width="310i" height="3.8h" x="-80i" align="center" valign="bottom" visible="0"
						   onmouseover="Trigger('genericMainFloatingTip', 'true', '20.0h', '', '', 'season_invalid_temamember_number', '', '', '3.0h', '-2.0h')"
						   onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');"/>
					<panel name="season_not_eligible_mask" color="0 0 0 .8" visible="0">
						<label align="center" textvalign="center" textalign="center" wrap="1" width="80%" font="dyn_24" content="season_not_eligible_mask" noclick="1" color="white"/>

					</panel>
				</panel>


				<!-- Tabs -->
				<panel width="14.0h" float="bottom" padding="1.0h" noclick="true">
					<!-- Co-Op -->
					<instance name="mm_category_tab" y="0" icon="/ui/fe2/elements/coop_icon.tga" iconsize="66" cat_label="mm3_coop" cat_sub_label="mm3_coop_desc" enabled="true" mode="coop" frameimg="tabbox" arrowcolor="#183042" tabboxarrow="tabbox_arrow" />
					<!-- Pvp -->
					<instance name="mm_category_tab" icon="/ui/fe2/elements/pvp_icon.tga" iconsize="66" cat_label="mm3_pvp" cat_sub_label="mm3_pvp_desc" enabled="true" mode="pvp" frameimg="tabbox" arrowcolor="#183042" tabboxarrow="tabbox_arrow" />
					<!-- Season -->
					<instance name="mm_category_tab" icon="/ui/fe2/season/icon.tga" iconsize="88" cat_label="" cat_sub_label="mm3_season_desc" enabled="true" mode="season" frameimg="tabbox_d" arrowcolor="#553218"  tabboxarrow="tabbox_arrow_d"
					onsetsublabellua="
						if IsPreseason() then
							self:SetText(Translate('mm3_preseason_desc'))
						else
							self:SetText(Translate('player_stats_season_highest', 'season', GetCurrentSeason()))
						end
					"/>
				</panel>
				<panel name="mm_category_tab_mask" width="14.0h"/>

			</panel>

			<!-- Load Progress -->
			<panel width="-2.0h" align="center" name="mm_loading_progress" visible="0" blockinput="true" watch="EntityDefinitionsLoaded" ontrigger="SetVisible(false);" color="0 0 0 .7">
				<panel align="center" valign="center" width="25.0h" height="5h" y=".5h">
					<image height="100%" texture="../mainmenu/update_bar_bg.tga" />

					<panel watch="EntityDefinitionsProgress" width="1" ontrigger="If(param1 gt 0, SetWidth(((param0 / param1) * 100) # '%')); SetWidth(Max(GetWidth(), 32));">
						<image watch="EntityDefinitionsProgress" ontrigger="If(param1 gt 0 and param0 gt 0, SetUScale(1 / (param0 / param1)));" texture="../mainmenu/update_bar_fg.tga"/>
						<image width="32" texture="../loadingscreens/loading_bar_fg_l.tga"/>
						<image width="32" align="right" texture="../loadingscreens/loading_bar_fg_r.tga"/>
					</panel>
				</panel>
				<image align="center" valign="center" width="31.5h" height="9h" x="-.8h" color="1 1 1 1" texture="elements/loading_bar_frame.tga" />
				<panel color="invisible" y=".5h">
					<label width="-10.0h" height="100%" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="general_wait" />
				</panel>
			</panel>

			<!-- Not Host Cover -->	<!-- hide the simple covers if they are verified so they can see if the host changes those options -->
			<!-- <panel name="mm_tmm_cover" color="invisible" noclick="1" visible="0"
				onevent1="FadeIn(100);
						  Call('mm_map_advanced_options', 'SlideY(\'13.3h\', 100)');
						  Call('mm_modes_advanced_options', 'SlideY(\'23.3h\', 150)')"
				onevent1lua="UIManager.GetInterface('main'):HoNMatchmakingF('ClickMapAdvanced', 0)
							UIManager.GetInterface('main'):HoNMatchmakingF('ClickGameModeAdvanced', 0)"
				onevent0="FadeOut(100);"
				onevent0lua="if (Client.IsNewAccount()) then
								UIManager.GetInterface('main'):HoNMatchmakingF('ClickMapAdvanced', 1)
								UIManager.GetInterface('main'):HoNMatchmakingF('ClickGameModeAdvanced', 1)
								GetWidget('mm_map_advanced_options'):SlideY('-0.3h', 100)
								GetWidget('mm_modes_advanced_options'):SlideY('-0.3h', 150)
							end"
			> -->
			<panel name="mm_tmm_cover" color="invisible" noclick="1" visible="0"
				onevent1="FadeIn(100);"
				onevent0="FadeOut(100);"
			>
				<panel name="mm3_tmml" x="3.0h" y="3.8h" align="left" width="14.7h" height="-1h" color="0 0 0 .5" blockinput="1"
					onclick="Call('matchmaking_options_blocker_highlight', 'DoEvent(0);');">
				</panel>

				<!-- <panel name="mm3_tmmm" y="-5.5h" x="18.2h" align="left" valign="bottom" width="31.1h" height="3.8h" color="0 0 0 .5" blockinput="1"
					onclick="Call('matchmaking_options_blocker_highlight', 'DoEvent(0);');">
				</panel> -->

				<panel name="mm3_tmmr" align="right" x="-3.0h" y="3.8h" width="65.0h" height="-9.5h" color="0 0 0 .5" blockinput="1"
					onclick="Call('matchmaking_options_blocker_highlight', 'DoEvent(0);');">
					<panel valign="top" align="left" height="3h" width="-1.0h" y="0"
					onclick="Call('matchmaking_options_blocker_highlight', 'DoEvent(0);');"
					>
						<frame texture="/ui/info/backdrop.tga" borderthickness="3.0h" color="1 1 1 .3" noclick="1" />
						<frame color=".05 .07 .1 .5" bordercolor=".2 .2 .2 1" borderthickness="1" noclick="1" />
						<label color="white" shadow="true" font="dyn_10" textalign="center" textvalign="center" wrap="true" content="mm_settings_locked"/>
						<frame name="matchmaking_options_blocker_highlight" color="invisible" bordercolor="#FFCC00" borderthickness="1" noclick="true" visible="false"
							onevent0="
								FadeIn(80);
								SleepWidget(80, 'DoEvent(1);');
							"
							onevent1="
								FadeOut(80);
								SleepWidget(80, 'DoEvent(2);');
							"
							onevent2="
								FadeIn(80);
								SleepWidget(80, 'DoEvent(3);');
							"
							onevent3="
								FadeOut(80);
							"
						/>
					</panel>
				</panel>
			</panel>

			<panel name="matchmaking_blocker_leaver" width="100%" color="0 0 0 0.5" visible="true"
				onclick="
					PlaySound('/shared/sounds/ui/error.wav');
					CallEvent('matchmaking_blocker_leaver_highlight', 0);
				"
				onshow="
					Trigger('TMMUpdateTooltipTrigger', '', '', '', '', '');
					HideWidget('mm_option_disabled_unverified_tip');
				"
			>
				<panel valign="center" align="center" width="40h" grow="true" regrow="true">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color=".05 .07 .1 .8"/>
					<frame texture="/ui/frames/roundframe.tga" color="#678095" borderthickness="0.6h"/>
					<panel width="-1.0h" align="center" color="invisible" noclick="1" grow="true" regrow="true" float="bottom">
						<panel height="0.5h"/>
						<label name="matchmaking_leaver_label" font="dyn_10" wrap="true" fity="true" color="white" shadow="true" textalign="center" content="-" />
						<panel height="0.5h"/>
						<label font="dyn_10" wrap="true" fity="true" color="#FFCC00" shadow="true" textalign="center" content="mm_leaver_resetstats" />
						<panel height="0.5h"/>

						<panel width="100%" height="2.5h">
							<panel height="100%" grow="true" align="center" float="right" padding="0.5h">
								<instance
									width="6h" height="2.5h"
									name="button2" button_name="unnamedButton166"
									label="general_close"
									onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav'); Set('_mainmenu_currentpanel', ''); CallEvent('MainMenuPanelSwitcher');"
								/>
							</panel>
						</panel>
						<panel height="0.5h"/>
					</panel>
					<frame name="matchmaking_blocker_leaver_highlight" texture="/ui/frames/roundframe.tga" color="#FFCC00" borderthickness="0.6h" visible="false"
						onevent0="
							FadeIn(80);
							SleepWidget(80, 'DoEvent(1);');
						"
						onevent1="
							FadeOut(80);
							SleepWidget(80, 'DoEvent(2);');
						"
						onevent2="
							FadeIn(80);
							SleepWidget(80, 'DoEvent(3);');
						"
						onevent3="
							FadeOut(80);
						"
					/>
				</panel>
			</panel>

			<panel name="matchmaking_queue_blocker" width="100%" color="0 0 0 0.5" visible="false" watch="TMMReset TMMTime TMMLeftQueue" ontrigger="SetVisible(IsInQueue());" />

			<instance name="mapLoadGuide"/>
			<!-- Solo Queue Display -->
			<panel
				name="matchmaking_queue_display"
				y="2.0h"
				width="28.5h"
				height="28.2h"
				align="center"
				valign="center"
				color="0 0 0 .9"
				visible="false"
				watch1="GamePhase" ontrigger1="If(param ge 3, SetVisible(0));"
				onshow="##PlayMusic('/music/lobby.mp3', true);##"
				grow="1" regrow="1" growinvis="0"
			>
				<frame texture="/ui/info/backdrop.tga" borderthickness="3.0h" color="1 1 1 .5" noclick="1" />
				<frame color="invisible" bordercolor=".2 .2 .2 1" borderthickness="1" noclick="1" />

				<panel grow="1" regrow="1" growinvis="0" y="0.8h" width="-2.0h" align="center" float="bottom" noclick="true">
					<label fity="true" fitypadding="3.0h" textalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="mm_queue_finding" />
					<panel grow="1" regrow="1" growinvis="0" width="100%" float="right" padding="1.2h">
						<panel x="1.2h" height="6.6h" width="6.6h">
							<animatedimage y="0.9h" width="100@" height="100%" align="center" valign="center" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" />
						</panel>
						<panel grow="1" regrow="1" growinvis="0" width="-6.6h" float="bottom">
							<label fity="true" fitypadding="0.1h" textalign="left" font="dyn_11" color="#3abde7" shadow="true" content="mm_queue_past" />
							<label name="matchmaking_queue_past" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true" watch="TMMTime" ontrigger="SetText(param0);" />
							<label fity="true" fitypadding="0.1h" textalign="left" font="dyn_11" color="#3abde7" shadow="true" content="mm_queue_eta" />
							<label name="matchmaking_queue_eta" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true" watch="TMMTime" ontrigger="SetText(param1);" />
							<label name="matchmaking_queue_popularity_1" fity="true" fitypadding="0.1h" textalign="left" font="dyn_11" color="#3abde7" shadow="true" content="mm_queue_popularity" />
							<label name="matchmaking_queue_popularity_2" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true" />
							<label name="matchmaking_queue_popularity_3" fity="true" fitypadding="0.1h" textalign="left" font="dyn_11" color="#3abde7" shadow="true" content="mm_queue_extra" visible="0"/>
							<label name="matchmaking_queue_popularity_4" fity="true" fitypadding="0.5h" textalign="left" font="dyn_10" color="1 1 1 1" shadow="true"  visible="0" />
						</panel>
						<button name="matchmaking_hover_question_btn_1"
							x="7.2h" y="8.2h" height="1.4h" width="1.4h" align="left" color="invisible"
							onmouseover=""
							onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');"
						>
							<widgetstate statename="up">
								<image texture="/ui/elements/tip_mark_up.tga"/>
							</widgetstate>
							<widgetstate statename="over">
								<image texture="/ui/elements/tip_mark_over.tga"/>
							</widgetstate>
							<widgetstate statename="down" x="1" y="1">
								<image texture="/ui/elements/tip_mark_up.tga"/>
							</widgetstate>
						</button>
					</panel>
				</panel>

				<!-- <panel name="matchmaking_queue_fidelity" y="-7h" width="-2.0h" height="5h" align="center" valign="bottom" noclick="1" color="1 1 0 0" float="bottom" visible="1"
					watch="TMMTime" ontrigger="SetVisible(!ShouldHideTMMStats());"
				>
					<panel height="2h" noclick="1" align="center">
						<label color="white" font="dyn_10" textalign="center" textvalign="center" shadow="true" content="mm_queue_fidelity1" noclick="1" />
					</panel>
					<panel align="center" height="2.5h" noclick="1">
						<panel width="14h" align="center" noclick="1">
							<instance name="Moptions_slider_bg" />
							<slider width="-3h" align="center" enabled="1"
								name="matchmaking_queue_fidelity_slider"
								slotwidth="-1%" slotheight="0.6h"
								slotcolor="1 1 1 1"
								handlewidth="100@" handleheight="-10%"
								handlecolor="1 1 1 1"
								cvar="cc_TMMMatchFidelity"
								minvalue="0" maxvalue="1"
								step="1"
								texture="/ui/info/slider.tga"
								onshowlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_queue_fidelity_slider_OnShow')"
								onselect="PlaySound('/shared/sounds/ui/button_over_02.wav');"
								onchangelua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_queue_fidelity_slider_OnChange')"
								watch="TMMTime"
								ontrigger="
									SetValue(Round(param2));
								"
								onmouseoverlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_queue_fidelity_slider_OnMouseOver')"
								onmouseoutlua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_queue_fidelity_slider_OnMouseOut')"
							/>
						</panel>
						<panel width="-0.8h" height="100%" align="center" noclick="1">
							<label width="5.5h" wrap="1" color="white" height="100%" textvalign="center" shadow="true" font="dyn_9" valign="center" align="left"  textalign="left"  content="mm_queue_fidelity2" noclick="1" />
							<label width="5.5h" wrap="1" color="white" height="100%" textvalign="center" shadow="true" font="dyn_9" valign="center" align="right" textalign="right" content="mm_queue_fidelity3" noclick="1" />
						</panel>
					</panel>
				</panel> -->

				<instance
					name="button2" button_name="unnamedButton167"
					y="-1.6h"
					width="16.0h"
					height="2.4h"
					align="center"
					valign="bottom"
					label="mm_queue_leave_btn"
					onclicklua="UIManager.GetInterface('main'):HoNMatchmakingF('matchmaking_button_leave_queue_OnClick')"
				/>
			</panel>

		</panel>
	</template>

	<trigger name="MMBuySingleTokenStatus"/>
	<trigger name="MMBuySingleTokenResults"/>

	<form
		name="MMBuySingleToken"
		host="!masterserver"
		method="post"
		target="/store_requester.php"
		statustrigger="MMBuySingleTokenStatus"
		resulttrigger="MMBuySingleTokenResults"
		resultparam0="responseCode"
		resultparam1="popupCode"
		resultparam2="errorCode"
		resultparam3="requestHostTime"
		ssl="false"
	/>

	<template name="tmm_purchase_tokens_template" >
		<!-- Popup space -->
		<panel y="0" height="100%" width="100%" align="center" noclick="true">

			<!-- Buy token prompt -->
			<panel width="100%" height="100%" color="0 0 0 0.5" name="mm_popup_buytoken" onevent0="FadeIn(150);" onevent1="FadeOut(150);" visible="false">
				<panel y="-10h" width="46h" grow="true" regrow="true" align="center" valign="center" noclick="1">
				<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
					<panel float="bottom" width="100%" grow="true" regrow="true">
						<instance
							name="header_bar"
							buttonsize="1.8h"
							height="2.4h"
							lbl="mm_buytoken_title"
							show_close="true"
							onclick="PlaySound('/shared/sounds/ui/button_click.mp3'); CallEvent('mm_popup_buytoken', 1);"
						/>
						<panel height="0.5h"/>
						<panel width="100%" grow="true" regrow="true">
							<panel width="-1.0h" align="center" grow="true" regrow="true" noclick="1">
								<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<panel width="-1.0h" align="center" color="invisible" noclick="1" grow="true" regrow="true" float="bottom">
									<panel height="0.5h"/>
									<label font="dyn_10" wrap="true" fity="true" color="white" shadow="true" textalign="center" content="mm_buytoken_body"/>
									<panel height="0.5h"/>
									<panel height="0.5h">
										<panel height="1" width="-1h" align="center" valign="center" color="0 0 0 0.5"/>
										<panel height="1" width="-1h" align="center" valign="center" color="1 1 1 0.25" x="1" y="1"/>
									</panel>
									<panel height="0.5h"/>

									<panel width="100%" height="5h">
										<panel align="left" width="-10h">
											<panel height="100%" align="center" grow="true" float="right" padding="1h">
												<panel width="10h" height="100%">
													<image x="1.0h" width="3.0h" valign="bottom" height="3.0h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="true"/>
													<label font="dyn_10" wrap="true" fity="true" color="white" shadow="true" textalign="center" content="Buy 1 Token"/>
												</panel>
												<panel width="10h" height="100%">
													<panel height="2h" width="-1h" color="black" align="center">
														<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
														<panel hmargin="0.25h" vmargin="0.25h">
															<label font="dyn_10" color="#FFCC00" width="-110@" height="100%" textalign="center" textvalign="center" content="25"/>
															<image align="right" width="100@" height="100%" texture="/ui/fe2/store/gold_coins.tga"/>
														</panel>
													</panel>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton168"
														label="mstore_purchase_gold"
														onclick="
															PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav');
															Set('_lastRequestHostTime', GetTime());
															SubmitForm(
																'MMBuySingleToken',
																'account_id', GetAccountID(),
																'request_code', 4, 'cookie', GetCookie(),
																'category_id', 6, 'page', 1,
																'hostTime', _lastRequestHostTime,
																'currency', 0,
																'displayAll', false,
																'notPurchasable', false,
																'charge_id', 10
															);
														"
														valign="bottom"
														watch="GoldCoins"
														ontrigger="SetVisible(param ge 25);"
													/>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton169"
														label="mstore_needcoins"
														onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav'); CallEvent('store_open_purchase_helper', 2); CallEvent('mm_popup_buytoken', 1);"
														valign="bottom"
														enabled="true"
														watch="GoldCoins"
														ontrigger="SetVisible(param lt 25);"
													/>
												</panel>

												<panel width="10h" height="100%">
													<panel height="2h" width="-1h" color="black" align="center">
														<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
														<panel hmargin="0.25h" vmargin="0.25h">
															<label font="dyn_10" color="#c0d5ed" width="-110@" height="100%" textalign="center" textvalign="center" content="35"/>
															<image align="right" width="100@" height="100%" texture="/ui/fe2/store/silver_coins.tga"/>
														</panel>
													</panel>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton170"
														label="mstore_purchase_silver"
														onclick="
															PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav');
															SubmitForm(
																'MMBuySingleToken',
																'account_id', GetAccountID(),
																'request_code', 4, 'cookie', GetCookie(),
																'category_id', 6, 'page', 1,
																'hostTime', _lastRequestHostTime,
																'currency', 1,
																'displayAll', false,
																'notPurchasable', false,
																'charge_id', 10
															);
														"
														valign="bottom"
														watch="SilverCoins"
														ontrigger="SetVisible(param ge 35);"
													/>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton171"
														label="mstore_needcoins"
														onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav');"
														valign="bottom"
														enabled="false"
														watch="SilverCoins"
														ontrigger="SetVisible(param lt 35);"
													/>
												</panel>

											</panel>
										</panel>
										<panel align="right" width="10h">
											<instance
												width="9h" height="2.5h"
												name="button2" button_name="unnamedButton172"
												label="general_cancel"
												onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav'); CallEvent('mm_popup_buytoken', 1);"
												align="center" valign="center"
											/>

										</panel>
									</panel>
									<panel height="0.5h"/>
								</panel>
							</panel>
						</panel>
						<panel height="0.5h"/>
						<panel width="100%" grow="true" regrow="true">
							<panel width="-1.0h" align="center" grow="true" regrow="true" noclick="1">
								<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<panel width="-1.0h" align="center" color="invisible" noclick="1" grow="true" regrow="true" float="bottom">
									<panel height="0.5h"/>
									<label font="dyn_10" wrap="true" fity="true" color="white" shadow="true" textalign="center" content="Purchase a token 10 pack?"/>
									<panel height="0.5h"/>
									<panel height="0.5h">
										<panel height="1" width="-1h" align="center" valign="center" color="0 0 0 0.5"/>
										<panel height="1" width="-1h" align="center" valign="center" color="1 1 1 0.25" x="1" y="1"/>
									</panel>
									<panel height="0.5h"/>

									<panel width="100%" height="5h">
										<panel align="left" width="-10h">
											<panel height="100%" align="center" grow="true" float="right" padding="1h">
												<panel width="10h" height="100%">
													<image x="1.0h" width="3.0h" valign="bottom" height="3.0h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="true"/>
													<image x="2.0h" width="3.0h" valign="bottom" height="3.0h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="true"/>
													<image x="3.0h" width="3.0h" valign="bottom" height="3.0h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="true"/>
													<image x="4.0h" width="3.0h" valign="bottom" height="3.0h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="true"/>
													<label font="dyn_10" wrap="true" fity="true" color="white" shadow="true" textalign="center" content="Buy 10 Tokens"/>
												</panel>
												<panel width="10h" height="100%">
													<panel height="2h" width="-1h" color="black" align="center">
														<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
														<panel hmargin="0.25h" vmargin="0.25h">
															<label font="dyn_10" color="#FFCC00" width="-110@" height="100%" textalign="center" textvalign="center" content="250"/>
															<image align="right" width="100@" height="100%" texture="/ui/fe2/store/gold_coins.tga"/>
														</panel>
													</panel>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton173"
														label="mstore_purchase_gold"
														onclick="
															PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav');
															Set('_lastRequestHostTime', GetTime());
															SubmitForm(
																'MMBuySingleToken',
																'account_id', GetAccountID(),
																'request_code', 4, 'cookie', GetCookie(),
																'category_id', 6, 'page', 1,
																'hostTime', _lastRequestHostTime,
																'currency', 0,
																'displayAll', false,
																'notPurchasable', false,
																'charge_id', 1
															);
														"
														valign="bottom"
														watch="GoldCoins"
														ontrigger="SetVisible(param ge 25);"
													/>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton174"
														label="mstore_needcoins"
														onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav'); CallEvent('store_open_purchase_helper', 2); CallEvent('mm_popup_buytoken', 1);"
														valign="bottom"
														enabled="true"
														watch="GoldCoins"
														ontrigger="SetVisible(param lt 25);"
													/>
												</panel>

												<panel width="10h" height="100%">
													<panel height="2h" width="-1h" color="black" align="center">
														<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
														<panel hmargin="0.25h" vmargin="0.25h">
															<label font="dyn_10" color="#c0d5ed" width="-110@" height="100%" textalign="center" textvalign="center" content="350"/>
															<image align="right" width="100@" height="100%" texture="/ui/fe2/store/silver_coins.tga"/>
														</panel>
													</panel>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton175"
														label="mstore_purchase_silver"
														onclick="
															PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav');
															SubmitForm(
																'MMBuySingleToken',
																'account_id', GetAccountID(),
																'request_code', 4, 'cookie', GetCookie(),
																'category_id', 6, 'page', 1,
																'hostTime', _lastRequestHostTime,
																'currency', 1,
																'displayAll', false,
																'notPurchasable', false,
																'charge_id', 1
															);
														"
														valign="bottom"
														watch="SilverCoins"
														ontrigger="SetVisible(param ge 35);"
													/>
													<instance
														width="10h" height="2.5h"
														name="button2" button_name="unnamedButton176"
														label="mstore_needcoins"
														onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav');"
														valign="bottom"
														enabled="false"
														watch="SilverCoins"
														ontrigger="SetVisible(param lt 35);"
													/>
												</panel>

											</panel>
										</panel>
										<panel align="right" width="10h">
											<instance
												width="9h" height="2.5h"
												name="button2" button_name="unnamedButton177"
												label="general_cancel"
												onclick="PlaySound('/shared/sounds/ui/lobby/button_jointeam.wav'); CallEvent('mm_popup_buytoken', 1);"
												align="center" valign="center"
											/>

										</panel>
									</panel>
									<panel height="0.5h"/>
								</panel>
							</panel>
						</panel>
						<panel height="0.5h"/>
					</panel>
					<panel visible="false" watch="MMBuySingleTokenStatus" ontrigger="SetVisible(param == 1);" color="0 0 0 0.5">
						<panel align="center" valign="center" width="15h" height="4h" color="black">
							<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="true" />
							<animatedimage valign="center" x="0.5h" width="3h" height="3h" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" />
							<label align="right" x="-0.5h" width="-5h" shadow="true" color="white" font="dyn_12" textvalign="center" content="mstore_processing_elipses"/>
						</panel>
					</panel>

				</panel>
			</panel>

			<!-- Error -->
			<panel name="MMBuyTokenError" watch="MMBuyTokenStatus" ontrigger="If(param1 == 3, DoEvent(0));" watch1="MMBuySingleTokenResults" ontrigger1="If(param2 gt 0, DoEvent(0));" color="0 0 0 0.75" visible="false"
				onevent0="FadeIn(200);"
				onevent1="FadeOut(200);"
			>
				<panel width="35h" grow="true" regrow="true" align="center" valign="center" noclick="true" color="black">
					<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="true" />
					<panel float="bottom" width="35h" grow="true" regrow="true">
						<instance
							name="header_bar"
							buttonsize="1.8h"
							height="2.4h"
							lbl="mstore_error_generic"
							show_close="true"
							onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
							onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav'); CallEvent('MMBuyTokenError', 1);"
						/>
						<panel height="0.5h"/>
						<panel grow="true" regrow="true" width="100%">
							<panel width="-1h" align="center" grow="true" regrow="true" float="bottom" padding="0.5h">
								<label font="dyn_10" wrap="true" fity="true" color="white" shadow="true" watch0="MMBuySingleTokenResults" ontrigger0="If(param2 gt 0, SetText(Translate('mstore_error' # param2)));" watch1="MMBuyTokenStatus" ontrigger1="If(param0 == 3, SetText(Translate('mstore_error_connect')));" content="-"/>
								<panel height="2.4h" width="100%">
									<instance
										width="6h" height="100%"
										align="center"
										name="button2" button_name="unnamedButton178"
										label="general_ok"
										onclick="CallEvent('MMBuyTokenError', 1);"
									/>
								</panel>
							</panel>
						</panel>
						<panel height="0.5h"/>
					</panel>
				</panel>
			</panel>

			<!-- Success -->
			<panel name="MMBuyTokenSuccess" watch="MMBuySingleTokenResults"
				ontrigger="
					If(
						param1 == 3,
						Split(
							DoEvent(0),
							ChatRefreshUpgrades(),
							ClientRefreshUpgrades(),
							CallEvent('mm_popup_buytoken', 1)
						)
					);
				"
				color="0 0 0 0.75" visible="false"
				onevent0="FadeIn(200);"
				onevent1="FadeOut(200);"
			>
				<panel width="35h" grow="true" regrow="true" align="center" valign="center" noclick="true" color="black">
					<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="true" />
					<panel float="bottom" width="35h" grow="true" regrow="true">
						<instance
							name="header_bar"
							buttonsize="1.8h"
							height="2.4h"
							lbl="mstore_buyitem_success"
							show_close="true"
							onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
							onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav'); CallEvent('MMBuyTokenSuccess', 1);"
						/>
						<panel height="0.5h"/>
						<panel grow="true" regrow="true" width="100%">
							<panel width="-1h" align="center" grow="true" regrow="true" float="bottom" padding="0.5h">
								<label font="dyn_10" wrap="true" fity="true" color="white" shadow="true" content="mstore_buyitem_success_body"/>
								<panel height="2.4h" width="100%">
									<instance
										width="6h" height="100%"
										align="center"
										name="button2" button_name="unnamedButton179"
										label="general_ok"
										onclick="CallEvent('MMBuyTokenSuccess', 1);"
									/>
								</panel>
							</panel>
						</panel>
						<panel height="0.5h"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="campaign_reward_popup_item">
		<panel name="campaign_reward_popup_item{id}" x="{x}" y="{y}" width="50%" height="50%">
			<image name="campaign_reward_popup_item{id}_icon" width="80@" height="80%" valign="center" texture="$invis" />
			<panel x="100@" width="80%" align="left" valign="center" >
				<label name="campaign_reward_popup_item{id}_text" font="dyn_12" textvalign="center" textalign="left" noclick="true" color="#dfdfdf" content="-"/>
			</panel>
		</panel>
	</template>

	<template name="campaign_reward_popup">
		<panel name="campaign_reward_popup" color="0 0 0 0.8" visible="0" onframelua="HoN_Matchmaking.OnCampaignRewardPopupFrame()">
			<effectpanel  name="campaign_reward_popup_effect"
						  camerawidth="100a"
			              cameraheight="100"
			              noclick="true"
			              onloadlua="self:StartEffect('/ui/fe2/season/effects/popup_back_1.effect', 0.5, 0.5, '1 1 1', 1)"
			              visible="1"
			/>
			<panel name="campaign_reward_popup_levelup_anim" align="center" valign="center" width="96h" height="96h">
				<image x="1%" y="14%" align="center" width="100%" height="12.5%" texture="/ui/fe2/season/season_reward.tga" noclick="1"/>

				<panel y="-5%" width="45%" height="45@" align="center" valign="center">
					<image name="campaign_reward_popup_icon" texture="$invis" />
				</panel>
				<panel y="20%" width="50%" height="6%" align="center" valign="center">
					<label name="campaign_reward_popup_tips" font="dyn_12" wrap="1" textvalign="center" textalign="left" noclick="true" color="#dfdfdf" content="-"/>
				</panel>
				<panel y="24%" width="50%" height="1" align="center" valign="center" color="1 1 1 .5" />
				<panel y="26%" width="50%" height="2%" align="center" valign="center" >
					<label font="dyn_12" textvalign="center" textalign="left" noclick="true" color="white" content="season_rewards_youwillget"/>
				</panel>
				<panel y="33%" width="50%" height="10%" align="center" valign="center">
					<instance name="campaign_reward_popup_item" id="1"/>
					<instance name="campaign_reward_popup_item" id="2" x="50%"/>
					<instance name="campaign_reward_popup_item" id="3" y="50%"/>
					<instance name="campaign_reward_popup_item" id="4" x="50%" y="50%"/>
					<instance name="campaign_reward_popup_item" id="5" y="100%"/>
					<instance name="campaign_reward_popup_item" id="6" x="50%" y="100%"/>
				</panel>
				<button align="right"
						x="-19%"
						y="16%"
						width="3h"
						height="3h"
						color="invisible"
						onclicklua="HoN_Matchmaking.popupTimer = GetTime()
							    HoN_Matchmaking.popupShow = false
							    GetWidget('campaign_reward_popup'):FadeOut(200)" >
					<widgetstate statename="up">
						<image align="center" valign="center" color=".75 .75 .75 1" texture="/ui/fe2/season/close.tga" noclick="true" />
					</widgetstate>
					<widgetstate statename="over">
						<image align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/season/close_over.tga" noclick="true" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/season/close_over.tga" noclick="true" />
					</widgetstate>
				</button>

				<button align="center" valign="bottom"
						y="-1.5%"
						width="15.6%"
						height="4%"
						color="invisible"
						onclicklua="HoN_Matchmaking.popupTimer = GetTime()
							    HoN_Matchmaking.popupShow = false
							    GetWidget('campaign_reward_popup'):FadeOut(200)" >
					<widgetstate statename="up">
						<image align="center" valign="center" width="160%" height="160%" texture="/ui/fe2/season/btn.tga" noclick="true" />
						<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" shadow="true" shadowcolor="#d89019" content="general_close"/>
					</widgetstate>
					<widgetstate statename="over">
						<image align="center" valign="center" width="160%" height="160%" texture="/ui/fe2/season/btn_over.tga" noclick="true" />
						<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" shadow="true" shadowcolor="#d89019" content="general_close"/>
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image align="center" valign="center" width="160%" height="160%" texture="/ui/fe2/season/btn_over.tga" noclick="true" />
						<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" shadow="true" shadowcolor="#d89019" content="general_close"/>
					</widgetstate>
				</button>
			</panel>
		</panel>
	</template>
</package>