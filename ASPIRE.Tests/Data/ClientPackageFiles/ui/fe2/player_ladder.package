<?xml version="1.0" encoding="UTF-8"?>
<package>

	<style name="playerLadderTabBacker" width="148.83%" height="113.77%" align="center" valign="center" hflip="true"/>
	<style name="playerLadderTabLabel" x="-0.65h" y="6h" font="dyn_12" textalign="center" noclick="true" color="1 1 1 1" content=""/>
	<style name="playerLadderTabIcon" width="50%" height="50@" align="center" x="-17%" y="9.5%"/>

	<template name="player_ladder">
		<panel name="player_ladder" y="-210%" align="center" width="-2.7h" visible="{visible=0}" noclick="true" valign="center" 
			hotkey="ESC"
			onhotkey="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); Set('_mainmenu_currentpanel', 'player_ladder'); CallEvent('MainMenuPanelSwitcher');"
			onhidelua="if isNewUI() then Homepage_V2:InitMotd() end"
		>
			<panel width="200%" height="200%" align="center" valign="center"/>
			<panel x="0" y="-100%" height="203.6%" width="-15@"  align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel y="100%" noclick="true" passivechildren="true" onloadlua="self:SetHeight(isNewUI() and '96%' or '100%')">
				<panel valign="bottom" y="-2.5h" width="+2h" x="-0.75h">
					<panel width="3.125@" texture="/ui/fe2/frames/slideout_frame_l.tga"/>
					<panel width="3.125@" texture="/ui/fe2/frames/slideout_frame_r.tga" align="right"/>
					<panel width="-2h" align="center" height="3.125%" valign="bottom" texture="/ui/fe2/frames/slideout_frame_b.tga"/>
					<panel width="3.125@" height="3.125%" x="3.125@" valign="bottom" texture="/ui/fe2/frames/slideout_frame_bl.tga"/>
					<panel width="3.125@" height="3.125%" x="-3.125@" valign="bottom" texture="/ui/fe2/frames/slideout_frame_br.tga" align="right"/>
				</panel>
			</panel>

			<panel x="20h" y="-100%" height="203.6%" width="50@"  align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-20h" y="-100%" height="203.6%" width="50@"  align="left" texture="mainmenu/upper_frame_left.tga"/>

			<panel color="black" y="95%" height="90%" align="center" width="-0.2h" x="0.15h"/>

			<panel name="player_stats_tabs" y="2h" x="0.57h" align="left" height="89.8h" width="6.2h" noclick="true" float="bottom" padding="1.5h"
				watch="openstatstrigger"
				ontrigger="Echo('openstatstrigger ' # param0);"
			>
				<panel height="22h" color="invisible" noclick="1">
					<button
						name="player_stats_ladder_tab" noclick="0" enabled="1"
						color="invisible"
						onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
						onclicklua="
							if isNewUI() then
								Homepage_V2:ClickedLadder()
							else
								Player_Stats.ClickedLadder()
							end
						"
						numstates="2"
					>
						<widgetstate statename="up">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_unselected.tga" style="playerLadderTabBacker"/>
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="over">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_hover.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="down" x="1" y="1">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="up2">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="over2">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="down2" x="1" y="1">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<label style="playerLadderTabLabel" onload="SetText(FormatStringNewLine(Translate('player_stats_tabs_ladder')));" ></label>
					</button>
				</panel>

				<if condition="cl_GarenaEnable">
				<panel height="22h" color="invisible" noclick="1">
					<button
						name="player_stats_ladder_tab2" noclick="0" enabled="1"
						color="invisible"
						onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
						onclicklua="
