						</widgetstate>
						<widgetstate statename="over">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_hover.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="down" x="1" y="1">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="up2">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="over2">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<widgetstate statename="down2" x="1" y="1">
							<image texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" style="playerLadderTabBacker" />
							<image texture="/ui/fe2/season/icon_s.tga" style="playerLadderTabIcon" />
						</widgetstate>
						<label style="playerLadderTabLabel" onload="SetText(FormatStringNewLine(Translate('player_stats_tabs_ladder2')));" ></label>
					</button>
				</panel>
				</if>

