	<panel name="codex_editor" noclick="0" width="80h" height="20h" align="center" valign="center" color="0.1 0.1 0.1 0.5" visible="0" cangrab="true" >
		<instance name="button2" button_name="codex_editor_close" width="2h" height="1.5h" x="-2h" y="0.9h" align="right" label="X" onclicklua="GetWidget('codex_editor'):SetVisible(false)" />
		<label name="codex_editor_avatarName" x=".5h" y="2h" height="2h" textvalign="center" color="white" noclick="1" />
		<label name="codex_editor_model" x=".5h" y="5h" height="2h" textvalign="center" color="white" noclick="1" />
		<label name="codex_editor_effect" x=".5h" y="12h" height="2h" textvalign="center" color="white" noclick="1" />
		<instance name="test_suite_checkbox" x=".5h" y="9h" width="2h" height="2h" checkbox="codex_editor_effectEnabled" content="EffectEnabled" startenabled="0" onclicklua="HoN_Codex:Editor_ChangeEffectEnabled()"/>
		<instance name="button2" button_name="codex_editor_save" width="12h" height="2h" x=".5h" y="15h" label="Save To File" onclicklua="HoN_Codex:Editor_Save()" />
		<label name="codex_editor_savepath" x="13h" y="15h" height="2h" textvalign="center" color="white" noclick="1" content="d:\\specialavatar.txt" />
	</panel>

	<template name="codex_roulette_item_template">
		<panel name="codex_roulette_item_{id}" x="{x}" y="{y}" width="{width=128i}" height="{height=128i}" align="center" valign="center">
			<image name="codex_roulette_item_{id}_icon" texture="$invis" usealphamask="true" alphamaskfile="/ui/fe2/codex/roulette_item_mask.tga" noclick="1"/>
			<dynamicimage name="codex_roulette_item_{id}_highlight" color="1 1 1 1" visible="0" usealphamask="true" alphamaskfile="/ui/fe2/codex/roulette_item_mask.tga"/>
			<image name="codex_roulette_item_{id}_owned" x="20i" y="20i" width="128i" height="128i" texture="/ui/fe2/codex/owned1.png" noclick="1" align="center" valign="center" visible="0"/>
			<panel onmouseoverlua="HoN_Codex:OnMouseOverRoulette({id})" onmouseoutlua="GetWidget('codex_roulette_tip'):SetVisible(false)"/>
		</panel>
	</template>

	<template name="codex_roulette_history_item_template">
		<panel name="codex_roulette_history_item_{id}" height="47i" float="right" visible="0">
			<anchor x="30i"/>
			<panel width="100i">
				<label name="codex_roulette_history_item_{id}_date" font="square_18" textvalign="center" color="#7f7f7f"/>
			</panel>
			<panel width="100i">
				<label name="codex_roulette_history_item_{id}_time" font="square_18" textalign="center" textvalign="center" color="#7f7f7f"/>
			</panel>
			<panel width="42i">
				<image name="codex_roulette_history_item_{id}_icon" width="40i" height="40i" align="center" valign="center" texture="$invis" noclick="1" />
			</panel>
			<panel width="260i">
				<label name="codex_roulette_history_item_{id}_name" x="10i" font="square_18" textvalign="center" color="#7f7f7f"/>
			</panel>
		</panel>
	</template>

	<panel name="codex_roulette" visible="0" color="0 0 0 .7" onshowlua="HoN_Codex:InitRoulette()">
		<button width="64i" height="64i" x="-20i" y="25i" align="right" valign="top" color="invisible" onclicklua="HoN_Codex:CloseRoulette()" onclick="PlaySound('/ui/fe2/codex/sounds/cancel.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
			<widgetstate statename="up">
				<image width="128i" height="128i" align="center" valign="center" texture="/ui/fe2/codex/close_up.png" noclick="1" y="8i"/>
			</widgetstate>
			<widgetstate statename="over">
				<image width="128i" height="128i" align="center" valign="center" texture="/ui/fe2/codex/close_over.png" noclick="1" y="8i"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image width="128i" height="128i" align="center" valign="center" texture="/ui/fe2/codex/close_over.png" noclick="1" y="8i"/>
			</widgetstate>
		</button>
		<panel name="codex_roulette_item_root" noclick="1" onframelua="HoN_Codex:UpdateRoulette()">
			<panel name="codex_roulette_item_capture" width="120h" height="80h" align="center" valign="center" color="invisible" noclick="1"/>
		</panel>
		<button name="codex_roulette_start"
			align="center" valign="center"
			width="256i"
			height="256i"
			color="invisible"
			onclicklua="HoN_Codex:OnClickFreeRoulette()"
			usebitmask="1"
			bitmaskfile="/ui/fe2/codex/start_btn.png"
			onclick="PlaySound('/ui/fe2/codex/sounds/startrolling.ogg')"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')"
			visible="0"
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/codex/start_btn.png" noclick="1"/>
				<image texture="/ui/fe2/codex/arrow.png" x="50i" y="22i" width="64i" height="64i" align="center" valign="center" noclick="1"/>
				<label font="keny_52" x="-18i" y="24i" textvalign="center" textalign="center" color="white" content="graffiti_roulette_start" outline="1" outlinecolor="#0c547e" noclick="1"/>
				<label name="codex_roulette_freetimes1" font="square_22" y="65i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#0c547e" noclick="1"/>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/codex/start_btn_over.png" noclick="1"/>
				<image texture="/ui/fe2/codex/arrow.png" x="50i" y="22i" width="64i" height="64i" align="center" valign="center" noclick="1"/>
				<label font="keny_52" x="-18i" y="24i" textvalign="center" textalign="center" color="white" content="graffiti_roulette_start" outline="1" outlinecolor="#0c547e" noclick="1"/>
				<label name="codex_roulette_freetimes2" font="square_22" y="65i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#0c547e" noclick="1"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image texture="/ui/fe2/codex/start_btn_over.png" noclick="1"/>
				<image texture="/ui/fe2/codex/arrow.png" x="50i" y="22i" width="64i" height="64i" align="center" valign="center" noclick="1"/>
				<label font="keny_52" x="-18i" y="24i" textvalign="center" textalign="center" color="white" content="graffiti_roulette_start" outline="1" outlinecolor="#0c547e" noclick="1"/>
				<label name="codex_roulette_freetimes3" font="square_22" y="65i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#0c547e" noclick="1"/>
