					suncolor="1 1 1"
					onshow="
						SetEffect('/ui/fe2/codex/effects/hexagon.effect');
					"
			/> -->
		</button>


		<image name="codex_roulette_noroulette" align="center" valign="center" width="256i" height="256i" texture="/ui/fe2/codex/noroulette.png" />

		<image texture="/ui/fe2/codex/item_mask.png" align="right" valign="center" width="1024i" height="1024i" x="-50%" noclick="1"/>
		<image texture="/ui/fe2/codex/item_mask.png" align="left" valign="center" x="50%" width="1024i" height="1024i" noclick="1" hflip="1"/>

		<button width="256i" height="70i" y="-40i" align="center" valign="bottom" color="invisible" 
				onclicklua="GetWidget('codex_roulette_history'):FadeIn(250)
							SubmitForm('FormGetLotteryHistory',  'account_id', Client.GetAccountID(), 'cookie', Client.GetCookie())"
				onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')"
		>
			<widgetstate statename="up">
				<image y="8i" width="256i" height="128i" align="center" valign="center" texture="/ui/fe2/codex/history_btn.png" noclick="1"/>
				<label font="keny_36" x="95i" y="5i" textvalign="center" color="white" content="graffiti_roulette_history" shadow="1" shadowcolor="#0081b2"/>
			</widgetstate>
			<widgetstate statename="over">
				<image y="8i" width="256i" height="128i" align="center" valign="center" texture="/ui/fe2/codex/history_btn_over.png" noclick="1"/>
				<label font="keny_36" x="95i" y="5i" textvalign="center" color="white" content="graffiti_roulette_history" shadow="1" shadowcolor="#0081b2"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image y="8i" width="256i" height="128i" align="center" valign="center" texture="/ui/fe2/codex/history_btn_over.png" noclick="1"/>
				<label font="keny_36" x="95i" y="5i" textvalign="center" color="white" content="graffiti_roulette_history" shadow="1" shadowcolor="#0081b2"/>
			</widgetstate>
		</button>

		<panel name="codex_roulette_mask" visible="0"/>

		<panel name="codex_roulette_result" noclick="1" width="512i" height="512i" onframelua="" align="center" valign="center" visible="0">
			<image texture="/ui/fe2/codex/win_back.png" y="2%" align="center" valign="center" noclick="1" />
			<modelpanel
					width="-100i" 
					height="-100i"
					align="center" 
					valign="center"
					noclick="1"
					model="/shared/models/invis.mdf"
					cameradistance="0"
					lookat="false"
					camerapos="0 200 0"
					cameraangles="0 0 180"
					camerafov="50"
					cameranear="0"
					camerafar="190"
					ambientcolor="1 1 1"
					suncolor="1 1 1"
					onshow="
						SetEffect('/ui/fe2/codex/effects/win.effect');
					"
			/>
			<instance name="codex_roulette_item_template" id="100" width="29%" height="29%"/>
			<image texture="/ui/fe2/codex/win_center.png" width="50%" height="50%" align="center" valign="center" noclick="1" />
			<instance name="codex_ok_button_template" width="25%" height="10%" align="center" valign="bottom" y="-15%" onclicklua="HoN_Codex:OnClickRouletteResultOK()"/>
		
			<panel align="center" valign="center" height="8%" y="18%">
				<label name="codex_roulette_result_rewardname" font="square_18" textvalign="center" textalign="center" color="#7f7f7f" outline="1" outlinecolor="black" noclick="1" content=""/>
			</panel>

			<panel align="center" valign="center" width="60%" height="8%" y="18.5%">
				<label name="codex_roulette_result_rewardname2" font="square_18" textvalign="center" textalign="center" color="white" outline="1" wrap="1" outlinecolor="black" noclick="1" content=""/>
			</panel>
			<image name="codex_roulette_result_duplicated" y="51i" align="center" valign="center" width="256i" height="64i" texture="/ui/fe2/codex/duplicated.png" noclick="1" visible="0"/>

		</panel>

		<panel name="codex_roulette_history" color="0 0 0 .8" visible="0">
			<image texture="/ui/fe2/codex/list_back.png" width="1024i" height="1024i" align="center" valign="center" noclick="1" />
			<button width="40i" height="40i" x="230i" y="-320i" align="center" valign="center" color="invisible" onclicklua="GetWidget('codex_roulette_history'):FadeOut(250)" onclick="PlaySound('/ui/fe2/codex/sounds/cancel.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
				<widgetstate statename="up">
					<image width="80i" height="80i" align="center" valign="center" texture="/ui/fe2/codex/close_up.png" noclick="1" y="8i"/>
				</widgetstate>
				<widgetstate statename="over">
					<image width="80i" height="80i" align="center" valign="center" texture="/ui/fe2/codex/close_over.png" noclick="1" y="8i"/>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<image width="80i" height="80i" align="center" valign="center" texture="/ui/fe2/codex/close_over.png" noclick="1" y="8i"/>
				</widgetstate>
			</button>

			<image x="-200i" y="205i" texture="/ui/fe2/codex/icon_history.png" width="64i" height="64i" noclick="1" align="center"/>
			<panel y="210i" height="64i" noclick="1">
				<label font="keny_58" textalign="center" textvalign="center" color="#2fbff5" content="graffiti_roulette_history_title" noclick="1"/>
			</panel>

			<panel x="-30i" y="292i" width="528i" height="580i" float="bottom" padding="1" align="center">
				<instance name="codex_roulette_history_item_template" id="1"/>
				<instance name="codex_roulette_history_item_template" id="2"/>
				<instance name="codex_roulette_history_item_template" id="3"/>
				<instance name="codex_roulette_history_item_template" id="4"/>
				<instance name="codex_roulette_history_item_template" id="5"/>
				<instance name="codex_roulette_history_item_template" id="6"/>
				<instance name="codex_roulette_history_item_template" id="7"/>
				<instance name="codex_roulette_history_item_template" id="8"/>
				<instance name="codex_roulette_history_item_template" id="9"/>
				<instance name="codex_roulette_history_item_template" id="10"/>
				<instance name="codex_roulette_history_item_template" id="11"/>
				<instance name="codex_roulette_history_item_template" id="12"/>
			</panel>
			<panel x="-30i" y="292i" width="528i" height="580i" float="bottom" processonlyscroll="1"  hover="false" align="center"
					onmousewheeldown="CallEvent('codex_roulette_history_scrollbar', 1);"
					onmousewheelup="CallEvent('codex_roulette_history_scrollbar', 0);" />
				
			<scrollbar  name="codex_roulette_history_scrollbar"
						align="center"
						x="262i" y="278i"
						width="1.2h" height="590i"
						scrollbarsize="1.2h"
						handlewidth="1.2h"
						handleheight="10h"							
						texture="/ui/fe2/codex/scroll/scroll.png"
						scrollbarplaceholder="true"
						minvalue="1"
						maxvalue="10"							
						step="1"
						value="1"
						vertical="true"
						slotwidth="0.6h" slotheight="1"
						onevent1="SetValue(GetValue+1);"
						onevent0="SetValue(GetValue-1);"
						onslidelua="HoN_Codex:RefreshRouletteHistory()"
			/>
		</panel>
	</panel>

	<panel name="codex_roulette_tip" width="200i" height="60i" color="0 0 0 .8" visible="0" noclick="1" onframelua="HoN_Codex:OnTipMouseMove()">
		<label name="codex_roulette_tip_text" font="square_18" width="-10i" align="center" textalign="center" textvalign="center" color="#7f7f7f" wrap="1" content="" noclick="1"/>
	</panel>

	<panel name="codex_popup" color="0 0 0 .8" visible="0">
		<image y="-60i" width="1024i" height="512i" align="center" valign="center" texture="/ui/fe2/codex/popup_back.png" noclick="1" />
		<image x="-80i" y="-170i" width="64i" height="64i" align="center" valign="center" texture="/ui/fe2/codex/icon_confirm.png" noclick="1"/>
		<panel y="-170i" valign="center" height="64i" noclick="1">
			<label x="20i" y="2i" font="keny_58" textalign="center" textvalign="center" color="#2fbff5" content="graffiti_confirm"/>
		</panel>
		<button width="40i" height="40i" x="255i" y="-185i" align="center" valign="center" color="invisible" onclicklua="GetWidget('codex_popup'):FadeOut(250)" onclick="PlaySound('/ui/fe2/codex/sounds/cancel.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
			<widgetstate statename="up">
				<image width="80i" height="80i" align="center" valign="center" texture="/ui/fe2/codex/close_up.png" noclick="1" y="8i"/>
			</widgetstate>
			<widgetstate statename="over">
				<image width="80i" height="80i" align="center" valign="center" texture="/ui/fe2/codex/close_over.png" noclick="1" y="8i"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image width="80i" height="80i" align="center" valign="center" texture="/ui/fe2/codex/close_over.png" noclick="1" y="8i"/>
			</widgetstate>
		</button>

		<panel y="-85i" align="center" valign="center" width="430i" height="100i" >
			<label name="codex_popup_text" font="square_22" textalign="center" textvalign="center" color="#7f7f7f" wrap="1" content="" noclick="1"/>
		</panel>
		<instance name="codex_ok_button_template" button_name="codex_popup_confirm_btn" y="30i" width="128i" height="50i" align="center" valign="center"/>
		
		<panel name="codex_popup_price_root" x="-120i" y="25i" width="100i" height="50i" align="center" valign="center" noclick="1">
			<image width="32i" height="32i" valign="center" noclick="1" texture="/ui/fe2/codex/gold2.png"/>
			<label name="codex_popup_price" x="35i" y="3i" font="square_20" textalign="left" textvalign="center" color="white" content="" noclick="1"/>
		</panel>
	</panel>

	<panel name="codex_mask" color="0 0 0 .8" visible="0" onshowlua="HoN_Codex:OnMaskShow()" onframelua="HoN_Codex:OnMaskFrame()"
		watch="GraffitiWallsStatus" ontriggerlua="if tonumber(param) == 3 then HoN_Codex:OnTimeOut() end"
		watch1="GetLotteryListStatus" ontrigger1lua="if tonumber(param) == 3 then HoN_Codex:OnTimeOut() end"
		watch2="LotteryStatus" ontrigger2lua="if tonumber(param) == 3 then HoN_Codex:OnTimeOut() end"
		watch4="BuyWallStatus" ontrigger4lua="if tonumber(param) == 3 then HoN_Codex:OnTimeOut() end"
	>
		<animatedimage texture="/ui/fe2/elements/store2/loading/loading_.png" width="512i" height="128i" align="center" valign="center"
				fps="25" loop="true" loopbackframe="0" startframe="0" onshow="StartAnim();" />
	</panel>
</package>
