					width="-100i" 
					height="-100i"
					align="center" 
					valign="center"
					noclick="1"
					model="/ui/fe2/codex/effects/hexagon.mdf"
					cameradistance="0"
					lookat="false"
					camerapos="0 100 0"
					cameraangles="0 0 180"
					camerafov="50"
					cameranear="0"
					camerafar="190"
