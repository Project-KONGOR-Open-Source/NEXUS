			/> -->
		</button>

		<button name="codex_roulette_boost"
			align="center" valign="center"
			width="256i" 
			height="256i"
			color="invisible"
			onclicklua="HoN_Codex:OnClickBoost()"
			usebitmask="1"
			bitmaskfile="/ui/fe2/codex/start_btn.png"
			onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')"
			visible="0"
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/codex/boost_btn.png" noclick="1"/>
				<image texture="/ui/fe2/codex/arrow2.png" x="50i" y="22i" width="64i" height="64i" align="center" valign="center" noclick="1"/>
				<image texture="/ui/fe2/codex/gold1.png" x="-25i" y="60i" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				<label font="keny_52" x="-18i" y="24i" textvalign="center" textalign="center" color="white" content="graffiti_roulette_boost" outline="1" outlinecolor="#8b031e" noclick="1"/>
				<label name="codex_roulette_price1" x="14i" font="square_22" y="63i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#8b031e" noclick="1"/>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/codex/boost_btn_over.png" noclick="1"/>
				<image texture="/ui/fe2/codex/arrow2.png" x="50i" y="22i" width="64i" height="64i" align="center" valign="center" noclick="1"/>
				<image texture="/ui/fe2/codex/gold1.png" x="-25i" y="60i" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				<label font="keny_52" x="-18i" y="24i" textvalign="center" textalign="center" color="white" content="graffiti_roulette_boost" outline="1" outlinecolor="#8b031e" noclick="1"/>
				<label name="codex_roulette_price2" x="14i" font="square_22" y="63i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#8b031e" noclick="1"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image texture="/ui/fe2/codex/boost_btn_over.png" noclick="1"/>
				<image texture="/ui/fe2/codex/arrow2.png" x="50i" y="22i" width="64i" height="64i" align="center" valign="center" noclick="1"/>
				<image texture="/ui/fe2/codex/gold1.png" x="-25i" y="60i" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				<label font="keny_52" x="-18i" y="24i" textvalign="center" textalign="center" color="white" content="graffiti_roulette_boost" outline="1" outlinecolor="#8b031e" noclick="1"/>
				<label name="codex_roulette_price3" x="14i" font="square_22" y="63i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#8b031e" noclick="1"/>
			</widgetstate>
