<?xml version="1.0" encoding="UTF-8"?>
<package>
	<panel onloadlua="RegisterScript2('Codex_Interface', '1')" color="invisible" noclick="1"/>

	<!-- Lua -->
	<lua file="/ui/scripts/codex.lua" />

	<!-- forms -->
	<trigger name="GraffitiWallMsg" />

	<trigger name="GraffitiWallsStatus" />
	<trigger name="GraffitiWallsResult" />
	<form
		name="FormGraffitiWalls"
		host="!masterserver"
		target="/master/eventgraffiti/getgraffitiwalllist"
		statustrigger="GraffitiWallsStatus"
		resulttrigger="GraffitiWallsResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="GraffitiEditStatus" />
	<trigger name="GraffitiEditResult" />
	<form
		name="FormGraffitiEdit"
		host="!masterserver"
		target="/master/eventgraffiti/updategraffitiinfo "
		statustrigger="GraffitiEditStatus"
		resulttrigger="GraffitiEditResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="GetLotteryListStatus" />
	<trigger name="GetLotteryListResult" />
	<form
		name="FormLotteryList"
		host="!masterserver"
		target="/master/eventgraffiti/getlotterylist"
		statustrigger="GetLotteryListStatus"
		resulttrigger="GetLotteryListResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="LotteryStatus" />
	<trigger name="LotteryResult" />
	<form
		name="FormLottery"
		host="!masterserver"
		target="/master/eventgraffiti/lottery"
		statustrigger="LotteryStatus"
		resulttrigger="LotteryResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="GetLotteryHistoryStatus" />
	<trigger name="GetLotteryHistoryResult" />
	<form
		name="FormGetLotteryHistory"
		host="!masterserver"
		target="/master/eventgraffiti/getlotteryhistory"
		statustrigger="GetLotteryHistoryStatus"
		resulttrigger="GetLotteryHistoryResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="GetLadderStatus" />
	<trigger name="GetLadderResult" />
	<form
		name="FormGetLadder"
		host="!masterserver"
		target="/master/eventgraffiti/getladder"
		statustrigger="GetLadderStatus"
		resulttrigger="GetLadderResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="BuyWallStatus" />
	<trigger name="BuyWallResult" />
	<form
		name="FormBuyWall"
		host="!masterserver"
		target="/master/eventgraffiti/buy"
		statustrigger="BuyWallStatus"
		resulttrigger="BuyWallResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 


	<trigger name="ShareGraffitiStatus" />
	<trigger name="ShareGraffitiResult" />
	<form
		name="FormShareGraffiti"
		host="!masterserver"
		target="/master/eventgraffiti/share"
		statustrigger="ShareGraffitiStatus"
		resulttrigger="ShareGraffitiResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 

	<trigger name="GetCommunityGoalStatus" />
	<trigger name="GetCommunityGoalResult" />
	<form
		name="FormGetCommunityGoal"
		host="!masterserver"
		target="/master/eventgraffiti/getgraffitistats"
		statustrigger="GetCommunityGoalStatus"
		resulttrigger="GetCommunityGoalResult"
		resultparam0=""
		ssl="false"
		php="false"
	/> 
	<!-- end forms -->

	<panel name="codex_entrance_help" noclick="1" onframelua="HoN_Codex:UpdateEntrance()" visible="0"/>

	<template name="codex_ok_button_template">
		<button name="{button_name}" width="{width=128i}" height="{height=50i}" color="invisible" align="{align=center}" valign="{valign=center}" x="{x}" y="{y}" onclicklua="{onclicklua}"
				onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
			<widgetstate statename="up">
				<image texture="/ui/fe2/codex/r_btn.png" width="100%" height="100@" align="center" valign="center" noclick="1"/>
				<label font="keny_26" x="-4i" y="-4i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#8b031e" content="graffiti_ok" noclick="1"/>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/codex/r_btn_over.png" width="100%" height="100@" align="center" valign="center" noclick="1"/>
				<label font="keny_26" x="-4i" y="-4i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#8b031e" content="graffiti_ok" noclick="1"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image texture="/ui/fe2/codex/r_btn_over.png" width="100%" height="100@" align="center" valign="center" noclick="1"/>
				<label font="keny_26" x="-4i" y="-4i" textvalign="center" textalign="center" color="white" outline="1" outlinecolor="#8b031e" content="graffiti_ok" noclick="1"/>
			</widgetstate>
		</button>
	</template>

	<template name="codex_graffiti_editor_btn_template">
		<button name="codex_graffiti_editor{id}_btn{index}" width="32i" height="32i" color="invisible" 
			onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)" 
			onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)"
			onclicklua="HoN_Codex:RecordAnimChange({id}, {index}) HoN_Codex:UpdateOneItem({id})"
			onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
			<widgetstate statename="up">
				<image texture="/ui/fe2/codex/anim_btn.png" noclick="1"/>
				<image texture="/ui/fe2/codex/anim_btn{index}.png" width="16i" height="16i" align="center" valign="center" noclick="1"/>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/codex/anim_btn_over.png" noclick="1"/>
				<image texture="/ui/fe2/codex/anim_btn{index}.png" width="16i" height="16i" align="center" valign="center" noclick="1"/>
				<panel y="-30i" width="180i" height="30i" align="center" color="0 0 0 .9">
					<label align="center" textalign="center" textvalign="center" width="-20i" content="graffiti_pose_{index}" font="dyn_12" color="white" noclick="1"/>
				</panel>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image texture="/ui/fe2/codex/anim_btn_over.png" noclick="1"/>
				<image texture="/ui/fe2/codex/anim_btn{index}.png" width="16i" height="16i" align="center" valign="center" noclick="1"/>
			</widgetstate>
			<widgetstate statename="disabled">
				<image texture="/ui/fe2/codex/anim_btn_selected.png" noclick="1"/>
				<image texture="/ui/fe2/codex/anim_btn{index}.png" width="16i" height="16i" align="center" valign="center" noclick="1"/>
			</widgetstate>
		</button>
	</template>

	<template name="codex_graffiti_item_back_template">
		<panel name="codex_graffiti_item_back_{id}" width="192i" height="100%">
			<dynamicimage name="codex_graffiti_item_back_{id}_graffiti" y="-40i" width="256i" height="256i" align="center" valign="center" noclick="1" texture="$invis"/>
			<image texture="/ui/fe2/codex/shadow.png" width="256i" height="128i" align="center" valign="center" y="280i"/>
		</panel>
	</template>

	<template name="codex_graffiti_item_middle_template">
		<panel name="codex_graffiti_item_middle_{id}" width="192i" height="100%" >
			<panel y="170i" height="280i" valign="center">
				<modelpanel name="codex_graffiti_item_middle_{id}_avatar" y="-620i" width="600%" height="600%" align="center" valign="center"
							sunazimuth="120"
							sunaltitude="50"
							suncolor="0.9 0.9 0.9"
							ambientcolor="0.6 0.7 0.7"
							cameranear="0.0"
							lookat="false"
							camerafar="5000.0"
							camerapos="0 450 50"
							cameraangles="0 0 180"
							camerafov="10"
							depthclear="true"
							depthcompress="false"
							cull="false"
							resourcecontext="model"
							scenebuffer="true"
							outline="1"
							outlinecolor="0 0 0"
							posteffects="true"
							postoutline="/core/post/outline.posteffect"
				/>
			</panel>
		</panel>
	</template>

	<template name="codex_graffiti_item_front_template">
		<panel name="codex_graffiti_item_front_{id}" width="192i" height="100%">		
			<panel name="codex_graffiti_item_front_{id}_avatar" y="155i" height="320i" valign="center" 
				   onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)"
				   onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)"
				   onmouseldownlua="self:DoEventN(1)"
				   onmouseluplua="self:DoEventN(2)"
				   onmouserdownlua="HoN_Codex:OpenEditor({id})"
				   onhidelua="self:DoEventN(2)"
				   onevent1lua="HoN_Codex:StartRotation({id})"
				   onevent2lua="HoN_Codex:EndRotation({id})"
				   ontriggerlua="HoN_Codex:UpdateRotation({id})">
				
				<slider name="codex_graffiti_item_front_{id}_avatar_editor" y="-40i" width="-40i" height="15i" align="center" valign="bottom" sticky="1" slotwidth="-1%" slotheight="15i" slotcolor="white" 
						handlewidth="25i" handleheight="25i" handlecolor="white" 
						value="0" minvalue="0" maxvalue="1" step="0.01" 
						texture="/ui/fe2/codex/slider_white.tga" visible="0"
						onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)
										self:GetChildWidget('codex_graffiti_item_front_{id}_avatar_editor_handle'):SetVisible(true)"
						onchangelua="HoN_Codex:SetModelPos({id}, nil, tonumber(self:GetValue()), false)"
				/>
				<panel name="codex_graffiti_item_front_{id}_avatar_editor2" width="-40i" height="32i" noclick="1" align="center" valign="bottom" visible="0" float="right">
					<instance name="codex_graffiti_editor_btn_template" id="{id}" index="1"/>
					<instance name="codex_graffiti_editor_btn_template" id="{id}" index="2"/>
					<instance name="codex_graffiti_editor_btn_template" id="{id}" index="3"/>
					<instance name="codex_graffiti_editor_btn_template" id="{id}" index="4"/>
					<instance name="codex_graffiti_editor_btn_template" id="{id}" index="5"/>
					<anchor x="0"/>
					<panel name="codex_graffiti_editor{id}_disablebtn1" width="32i" height="32i" onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)" onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)" visible="0"/>
					<panel name="codex_graffiti_editor{id}_disablebtn2" width="32i" height="32i" onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)" onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)" visible="0"/>
					<panel name="codex_graffiti_editor{id}_disablebtn3" width="32i" height="32i" onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)" onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)" visible="0"/>
					<panel name="codex_graffiti_editor{id}_disablebtn4" width="32i" height="32i" onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)" onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)" visible="0"/>
					<panel name="codex_graffiti_editor{id}_disablebtn5" width="32i" height="32i" onmouseoverlua="HoN_Codex:SetSliderVisible({id}, true)" onmouseoutlua="HoN_Codex:SetSliderVisible({id}, false)" visible="0"/>
				</panel>
			</panel>
			<panel name="codex_graffiti_item_front_{id}_friend" height="32i" valign="bottom" y="-190i">
				<image texture="/ui/fe2/codex/player_name.png" width="256i" noclick="1" />
				<panel x="40i" width="80i">
					<label name="codex_graffiti_item_front_{id}_friend_name" textalign="center" textvalign="center" font="keny_26" color="#2fbff5"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="codex_page_index_template">
		<button name="codex_page_index_{id}" width="24i" color="invisible" visible="0" stickytoinvis="false" onclicklua="HoN_Codex:SelectPage({id})" onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
			<widgetstate statename="up">
				<label name="codex_page_index_{id}_label1" textalign="center" textvalign="center" font="square_22" color="#827474" outline="1" outlinecolor="#1c1111" content="{id}"/>
			</widgetstate>
			<widgetstate statename="over">
				<label name="codex_page_index_{id}_label2" textalign="center" textvalign="center" font="square_22" color="#C2B4B4" outline="1" outlinecolor="#1c1111" content="{id}"/>
			</widgetstate>
			<widgetstate statename="down">
				<label name="codex_page_index_{id}_label3" textalign="center" textvalign="center" font="square_22" color="#C2B4B4" outline="1" outlinecolor="#1c1111" content="{id}"/>
			</widgetstate>
		</button>
	</template>

	<template name="codex_rank_item_template">
		<panel name="codex_rank_item_{id}" height="47i" float="right" visible="0">
			<anchor x="30i"/>
			<panel width="80i">
				<label name="codex_rank_item_{id}_rank_text" font="{font=square_18}" textalign="center" textvalign="center" color="#7f7f7f" noclick="1"/>
				<image name="codex_rank_item_{id}_rank_image" width="64i" height="64i" align="center" valign="center" noclick="1"/>
			</panel>
			<panel width="170i">
				<label name="codex_rank_item_{id}_name" font="{font=square_18}" textalign="center" textvalign="center" color="#7f7f7f" noclick="1"/>
			</panel>
			<panel width="165i">
				<label name="codex_rank_item_{id}_completed" font="{font=square_18}" textalign="center" textvalign="center" color="#7f7f7f" noclick="1"/>
			</panel>
			<panel width="65">
				<label name="codex_rank_item_{id}_reward_text" font="{font=square_18}" textalign="center" textvalign="center" color="#7f7f7f" noclick="1"/>
				<image name="codex_rank_item_{id}_reward_image" width="42i" height="42i" align="center" valign="center" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="codex_share_item_template">
		<button name="codex_share_item_{id}" x="{x}" y="{y}" width="{width=160i}" height="{height=50i}" align="{align=left}" valign="{valign=top}" color="invisible" numstates="2"
				onloadlua="self:SetButtonState({startstate=0})" onclicklua="HoN_Codex:OnClickChooseSignature({id})" onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')">
			<widgetstate statename="up">
				<image width="16i" height="16i" align="left" valign="center" texture="/ui/fe2/codex/c1.png" noclick="1"/>
				<label x="25i" y="5i" font="square_20" width="+40i" textalign="left" textvalign="center" color="#7f7f7f" content="graffiti_share_signature{id}" noclick="1"/>
			</widgetstate>
			<widgetstate statename="over">
				<image width="16i" height="16i" align="left" valign="center" texture="/ui/fe2/codex/c2.png" noclick="1"/>
				<label x="25i" y="5i" font="square_20" width="+40i" textalign="left" textvalign="center" color="#7f7f7f" content="graffiti_share_signature{id}" noclick="1"/>
			</widgetstate>
			<widgetstate statename="down">
				<image width="16i" height="16i" align="left" valign="center" texture="/ui/fe2/codex/c2.png" noclick="1"/>
				<label x="25i" y="5i" font="square_20" width="+40i" textalign="left" textvalign="center" color="#7f7f7f" content="graffiti_share_signature{id}" noclick="1"/>
			</widgetstate>
			<widgetstate statename="up2">
				<image width="16i" height="16i" align="left" valign="center" texture="/ui/fe2/codex/c2.png" noclick="1"/>
				<label x="25i" y="5i" font="square_20" width="+40i" textalign="left" textvalign="center" color="#dfdfdf" content="graffiti_share_signature{id}" noclick="1"/>
			</widgetstate>
			<widgetstate statename="over2">
				<image width="16i" height="16i" align="left" valign="center" texture="/ui/fe2/codex/c2.png" noclick="1"/>
				<label x="25i" y="5i" font="square_20" width="+40i" textalign="left" textvalign="center" color="#dfdfdf" content="graffiti_share_signature{id}" noclick="1"/>
			</widgetstate>
			<widgetstate statename="down2">
				<image width="16i" height="16i" align="left" valign="center" texture="/ui/fe2/codex/c2.png" noclick="1"/>
				<label x="25i" y="5i" font="square_20" width="+40i" textalign="left" textvalign="center" color="#dfdfdf" content="graffiti_share_signature{id}" noclick="1"/>
			</widgetstate>
		</button>
	</template>

	<panel name="codex" visible="0" onloadlua="HoN_Codex:Init()" onframelua="HoN_Codex:OnFrame()"
			onshowlua="self:Sleep(500, function()
							PlayMusic('/ui/fe2/codex/sounds/bg.ogg', true)
						end)"
			onhidelua=" playBgMusic()"
	>
		<!-- background image -->
		<image name="codex_bg" noclick="1" width="1920i" height="1080i" align="center" valign="center" texture="/ui/fe2/codex/bg/1.png"/>
		<panel x="450i" y="-200i" width="128i" height="128i" align="center" valign="center" noclick="1">
			<dynamicimage name="codex_wall_index1" x="-38i" align="center" texture="$invis" height="128i" noclick="1" />
			<dynamicimage name="codex_wall_index2" x="38i" align="center" texture="$invis" height="128i" noclick="1" />
			<dynamicimage name="codex_wall_index3" x="-114i" align="center" texture="$invis" height="128i" noclick="1" />
			<dynamicimage name="codex_wall_index4" x="-190i" align="center" texture="$invis" height="128i" noclick="1" />
			<panel name="codex_rank_number" x="128i" width="128i" height="32i">
				<dynamicimage name="codex_rank_number_rank" texture="/ui/fe2/codex/rank.png" width="128i" height="32i" noclick="1"/>
				<dynamicimage name="codex_rank_number_1" x="108i" texture="$invis" width="32i" noclick="1"/>
				<dynamicimage name="codex_rank_number_2" x="122i" texture="$invis" width="32i" noclick="1"/>
				<dynamicimage name="codex_rank_number_3" x="136i" texture="$invis" width="32i" noclick="1"/>
			</panel>

			<dynamicimage name="codex_signature" x="90i" y="64i" width="256i" height="64i" texture="$invis" visible="1"/>
		</panel>

		<panel noclick="1" width="512i" height="512i" x="0" y="-30i" align="center" >
			<image y="16i" align="center" valign="center" texture="/ui/fe2/codex/logo_bg.png" noclick="1" />
			<modelpanel
		 			align="center"
		 			valign="center"
		 			width="200%"
		 			height="200%"
					noclick="true"
					model="/ui/fe2/elements/graffiti_logo/model.mdf"
					cameradistance="0"
					lookat="false"
					camerapos="-10 200 5"
					cameraangles="0 0 180"
					camerafov="50"
					cameranear="1"
					carmerafar="5000"
					ambientcolor="1 1 1"
					suncolor="0 0 0"
					onshow="
						SetAnim('idle');
						SetEffect('/ui/fe2/elements/graffiti_logo/body.effect');
					"
			/>
		</panel>

		<panel width="1350i" align="center" float="right" padding="1">	
			<instance name="codex_graffiti_item_back_template" id="1"/>
			<instance name="codex_graffiti_item_back_template" id="2"/>
			<instance name="codex_graffiti_item_back_template" id="3"/>
			<instance name="codex_graffiti_item_back_template" id="4"/>
			<instance name="codex_graffiti_item_back_template" id="5"/>
			<instance name="codex_graffiti_item_back_template" id="6"/>
			<instance name="codex_graffiti_item_back_template" id="7"/>
			<anchor x="0"/>
			<instance name="codex_graffiti_item_middle_template" id="1"/>
			<instance name="codex_graffiti_item_middle_template" id="2"/>
			<instance name="codex_graffiti_item_middle_template" id="3"/>
			<instance name="codex_graffiti_item_middle_template" id="4"/>
			<instance name="codex_graffiti_item_middle_template" id="5"/>
			<instance name="codex_graffiti_item_middle_template" id="6"/>
			<instance name="codex_graffiti_item_middle_template" id="7"/>
			<anchor x="0"/>
			<instance name="codex_graffiti_item_front_template" id="1"/>
			<instance name="codex_graffiti_item_front_template" id="2"/>
			<instance name="codex_graffiti_item_front_template" id="3"/>
			<instance name="codex_graffiti_item_front_template" id="4"/>
			<instance name="codex_graffiti_item_front_template" id="5"/>
			<instance name="codex_graffiti_item_front_template" id="6"/>
			<instance name="codex_graffiti_item_front_template" id="7"/>
		</panel>

		<panel height="32i" float="right" grow="1" regrow="1" align="center" valign="bottom" y="-120i" padding="1" >
			<button name="codex_lastpage" width="32i" color="invisible" onclicklua="HoN_Codex:TurningPage(false)" onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')" visible="0">
				<widgetstate statename="up">
						<image y="-3i" texture="/ui/fe2/codex/turning_btn.png" noclick="1" hflip="1"/>
					</widgetstate>
					<widgetstate statename="over">
						<image y="-3i" texture="/ui/fe2/codex/turning_btn_over.png" noclick="1" hflip="1"/>
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image y="-3i" texture="/ui/fe2/codex/turning_btn_over.png" noclick="1" hflip="1"/>
					</widgetstate>
					<widgetstate statename="disabled">
						<image y="-3i" texture="/ui/fe2/codex/turning_btn_disabled.png" noclick="1" hflip="1"/>
					</widgetstate>
			</button>
			<instance name="codex_page_index_template" id="1"/>
			<instance name="codex_page_index_template" id="2"/>
			<instance name="codex_page_index_template" id="3"/>
			<instance name="codex_page_index_template" id="4"/>
			<instance name="codex_page_index_template" id="5"/>
			<instance name="codex_page_index_template" id="6"/>
			<instance name="codex_page_index_template" id="7"/>
			<instance name="codex_page_index_template" id="8"/>
			<instance name="codex_page_index_template" id="9"/>
			<button name="codex_nextpage" width="32i" color="invisible" onclicklua="HoN_Codex:TurningPage(true)" onclick="PlaySound('/ui/fe2/codex/sounds/ok.ogg')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav')" visible="0">
				<widgetstate statename="up">
