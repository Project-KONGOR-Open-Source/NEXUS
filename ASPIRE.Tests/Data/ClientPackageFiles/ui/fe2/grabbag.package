<?xml version="1.0" encoding="UTF-8"?>
<package>
	<lua file="/ui/scripts/grabbag.lua" />
	
	<template name="grabBagPrizeModel">
		<panel name="grab_bag_prize_model_{id}" noclick="1" color="invisible" visible="0" >
			<!-- the actual model panel -->
			<modelpanel
				align="center"
				valign="center"
				width="100h"
				height="100h"
				name="grab_bag_prize_model_{id}_model"
				noclick="true"
				model="/shared/models/invis.mdf"
				onhidelua="self:SetEffect('')"
				anim="idle"
				cameranear="100.0"
				camerafar="20000.0"
				depthclear="true"
				depthcompress="false"
				lookat="false"
				cameradistance="30"
				camerapos="30 2500 65"
				cameraangles="0 0 180"
				camerafov="7"
				modelpos="0 0 0"
				modelangles="-15.0 0 0.0"
				modelscale="1.0"
				sunazimuth="120"
				sunaltitude="20"
				suncolor="0.9 0.9 0.9"
				ambientcolor="0.6 0.7 0.7"
				scenebuffer="true"
				resourcecontext="grabbag"
			/>

			<panel y="2%" noclick="1">
				<image name="grab_bag_prize_model_{id}_icon" height="17%" width="17@" y="3%" x="3@" noclick="1" />
				<label name="grab_bag_prize_model_{id}_name" font="dyn_14" textalign="center" outline="1" noclick="1" />
				<label name="grab_bag_prize_model_{id}_type" font="dyn_10" textalign="center" outline="1" y="18%" width="23@" noclick="1" />
			</panel>
		</panel>
	</template>

	<template name="grabBagPrizeIcon">
		<panel name="grab_bag_prize_icon_{id}" noclick="1" color="invisible" visible="0" >
			<image name="grab_bag_prize_icon_{id}_icon" height="25%" width="25@" align="center" valign="center" noclick="1" />
			<label name="grab_bag_prize_icon_{id}_name" height="25%" font="dyn_14" textalign="center" textvalign="center" valign="center" y="-15.5%" outline="1" noclick="1" />
			<label name="grab_bag_prize_icon_{id}_type" height="25%" font="dyn_12" textalign="center" textvalign="center" valign="center" y="15.5%" outline="1" noclick="1" />
		</panel>
	</template>

	<template name="grabBagChest">
		<panel name="grab_bag_prize_chest_{id}" color="invisible"
			onclicklua="UIManager.GetInterface('main'):HoNGrabbagF('ClickGrabBagChest', '{id}')"
			onmouseoverlua="UIManager.GetInterface('main'):HoNGrabbagF('HoverGrabBagChest', '{id}')"
			onmouseoutlua="UIManager.GetInterface('main'):HoNGrabbagF('UnhoverGrabBagChest', '{id}')"
		>
			<modelpanel
				name="grab_bag_prize_chest_{id}_model"
				align="center"
				valign="center"
				width="50h"
				height="50h"
				resourcecontext="grabbag"
				onhidelua="self:SetEffect('')"
				noclick="true"
				anim="idle"
				modelangles="0 0 180"
				camerafov="25"
				cameranear="1"
				carmerafar="100"
				depthclear="true"
				depthcompress="true"
				sunazimuth="165"
				sunaltitude="180"
				suncolor="1 1 1"
				ambientcolor="0.8 0.8 0.8"
				posteffects="true"
				outline="false"
				postoutline="/core/post/outline.posteffect"

			/>
			<panel name="grab_bag_prize_chest_{id}_sleeper" noclick="1" />
			<panel name="grab_bag_prize_chest_{id}_shaker" noclick="1" />
		</panel>
	</template>

	<template name="grabBagPrize">
		<panel name="grab_bag_prize_{id}_master" noclick="1" visible="0" width="25h" >
			<panel name="grab_bag_prize_{id}" noclick="1" visible="0">
				<panel valign="bottom" height="30%" noclick="1" >
					<instance name="grabBagChest" id="{id}" />
				</panel>

				
				<!-- the things I do for this clipping panel ... -->
				<panel name="grab_bag_prize_{id}_clipper" noclick="1" clip="1" align="center" width="100w" > 	<!-- full width on the clipper so effects look nicer -->
					<panel name="grab_bag_prize_{id}_slider" height="70%" width="17.5h" noclick="1" align="center" > 	<!-- 17.5 is 70% of 25h, this lets me not have an extra panel resetting the width to 25h after that clipper -->
						<instance name="grabBagPrizeModel" id="{id}" />
						<instance name="grabBagPrizeIcon" id="{id}" />
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="grabBag">
		<panel name="grabBag" height="50h" width="178h" align="center" visible="false" color="0 0 0 0.85"
			onhidelua="	GetWidget('grab_bag_theme_modelpanel_fore'):DoEventN(9)
						GetWidget('grab_bag_theme_modelpanel_back'):DoEventN(9)"
		>
			<panel name="grab_bag_sleeper_1" noclick="1" />
			<panel name="grab_bag_sleeper_2" noclick="1" />
			<panel name="grab_bag_theme_sleeper" noclick="1" />

			<!-- overlay for themes -->
			<image name="grab_bag_theme_back" noclick="1" resourcecontext="grabbag" visible="0" />
			<modelpanel name="grab_bag_theme_modelpanel_back" noclick="1" resourcecontext="grabbag" visible="0"
				anim="idle"
				model=""
				effect=""
				onevent9lua="self:SetModel('') self:SetEffect('')"
				camerapos="0 100 -60"
				cameraangles="0 0 180"
				camerafov="125"
				modelangles="0 0 180"
				modelpos="-20 0 0"
				sunaltitude="10"
				sunazimuth="120"
				fog="true"
				fogcolor="0 0 0" fognear="0" fogfar="100" fogscale="1"
				lookat="false"
			/>

			<panel grow="1" regrow="1" growinvis="0" height="100%" align="center" noclick="1" float="right">
				<instance name="grabBagPrize" id="1" />
				<instance name="grabBagPrize" id="2" />
				<instance name="grabBagPrize" id="3" />
				<instance name="grabBagPrize" id="4" />
				<instance name="grabBagPrize" id="5" />
			</panel>

			<!-- overlay for themes -->
			<modelpanel name="grab_bag_theme_modelpanel_fore" noclick="1" resourcecontext="grabbag" visible="0"
				anim="idle"
				model=""
				effect=""
				onevent9lua="self:SetModel('') self:SetEffect('')"
				camerapos="0 100 -60"
				cameraangles="0 0 180"
				camerafov="125"
				modelangles="0 0 180"
				modelpos="-20 0 0"
				sunaltitude="10"
				sunazimuth="120"
				fog="true"
				fogcolor="0 0 0" fognear="0" fogfar="100" fogscale="1"
				lookat="false"
			/>
			<image name="grab_bag_theme_fore" noclick="1" resourcecontext="grabbag" visible="0"/>

			<!-- exit button -->
			<panel width="125h" noclick="1" align="center">
				<instance name="mstore_btn_closex" width="1.75h" height="1.75h" align="right" x="-1h" y="1h"
					onclicklua="GetWidget('grabBag'):FadeOut(150)
					self:UICmd('ChatRefreshUpgrades(); ClientRefreshUpgrades();')
					if (UIGamePhase() >= 1) then
						self:UICmd('ServerRefreshUpgrades()')
					end
					"
				/>
			</panel>
		</panel>
	</template>
</package>