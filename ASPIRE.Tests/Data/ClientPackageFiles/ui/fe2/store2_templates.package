<?xml version="1.0" encoding="UTF-8"?>
<package>

	<!-- ============================= STYLES, PRELOADED TEXTURES =============================  -->
	<style name="microStorePaperText" color="#8e6b5b" outline="1" outlinecolor="#241410"/>
	<style name="microStoreDetailDesc" font="dyn_12" color="#d7b6a2" outline="1" outlinecolor="#241410"/>
	<style name="microStorePaperTitle" color="#d7b6a2" outline="1" outlinecolor="#180c0a"/>
	<style name="microStorePaperCost" color="#0471d6"/>
	<style name="microStoreMetalText" color="0.8 0.9 0.8 1" outlinecolor="0 0 0 0.6" outline="true"/>
	
	<trigger name="StoreImagePreviewInit"/>
	<trigger name="StoreImagePreviewVis"/>
	
	<template name="store2_close">
		<panel x="{x=60h}" y="{y=2.5h}" width="2.5h" height="2.5h" align="{align=center}" valign="top" color="invisible" noclick="1">
			<button
				visible="{visible=true}"
				color="invisible"
				watch="{watch}"
				ontriggerlua="{ontriggerlua}"
				onclicklua="PlaySound('/shared/sounds/ui/button_click_03.wav') {onclicklua}"
				onmouseoverlua="PlaySound('/shared/sounds/ui/button_over_03.wav')"
			>
				<widgetstate statename="up"><image width="3h" height="3h" align="center" valign="center" texture="/ui/fe2/elements/store2/close.png" noclick="1"/></widgetstate>
				<widgetstate statename="over"><image width="3h" height="3h" align="center" valign="center" texture="/ui/fe2/elements/store2/close_over.png" noclick="1"/></widgetstate>
				<widgetstate statename="down" x="1" y="1"><image width="3h" height="3h" align="center" valign="center" texture="/ui/fe2/elements/store2/close_over.png" noclick="1"/></widgetstate>
				<widgetstate statename="disabled"><image width="3h" height="3h" align="center" valign="center" texture="/ui/fe2/elements/store2/close.png" rendermode="grayscale" noclick="1"/></widgetstate>
			</button>
		</panel>
	</template>

	<template name="store2_tip_mark" >
		<panel name="{tip_name}" color="invisible" x="{x}" y="{y}" width="{width=3h}" height="{height=3h}" align="{align=right}" valign="{valign=center}" onevent0="{onevent0}" onevent1="{onevent1}" watch="{watch}" ontrigger="{ontrigger}" visible="{tip_visible=true}" noclick="1">
			<button
				name="{button_name}"
				color="invisible"
				visible="{visible=true}"
				onmouseover="If(!StringEmpty('{tip_id}'), Cmd('UICall {tip_id} SetVisible(1)')); PlaySound('/shared/sounds/ui/button_over_01.wav'); {onmouseover=}"
				onmouseout=" If(!StringEmpty('{tip_id}'), Cmd('UICall {tip_id} SetVisible(0)')); {onmouseout=}"
				oninstantiatelua="{oninstantiatelua}"
				onmousewheeluplua="{onmousewheeluplua}"
				onmousewheeldownlua="{onmousewheeldownlua}"
				onmouseoverlua="{onmouseoverlua}"
				onmouseoutlua="{onmouseoutlua}"
			>
				<widgetstate statename="up">
					<image width="100%" height="100%" valign="center" align="center" texture="/ui/fe2/elements/store2/tip_mark_up.png"/>
				</widgetstate>

				<widgetstate statename="over">
					<image width="100%" height="100%" valign="center" align="center" texture="/ui/fe2/elements/store2/tip_mark_over.png"/>
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="woodButtonImage">
		<panel color="white" align="center" width="-50@" utile="true" vtile="true" uscale="64p" vscale="64p" rendermode="{rendermode}" onload="SetUScale((GetHeight() * 2) # 'p'); SetVScale(GetHeight() # 'p');" texture="/ui/fe2/store/wood_button_center.tga" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/wood_button_center.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" noclick="1"/>
		<image align="left" height="100%" width="50@" rendermode="{rendermode}" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/wood_button_left.tga', 'store', self)" texture="/ui/fe2/store/wood_button_left.tga" resourcecontext="store" watch9="MainRegisterTextures" noclick="1"/>
		<image align="right" height="100%" width="50@" rendermode="{rendermode}" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/wood_button_right.tga', 'store', self)" texture="/ui/fe2/store/wood_button_right.tga" resourcecontext="store" watch9="MainRegisterTextures" noclick="1"/>
	</template>

	<template name="storeButtonWidgetState">
		<panel width="{buttonwidth=-25@}" height="{buttonheight=-25%}" x="{buttony=0}" y="{buttonx=0}" align="center" valign="center" noclick="1">
			<instance name="woodButtonImage" rendermode="{rendermode=normal}"/>
			<label align="center" textvalign="center" textalign="{textalign=center}" color="{labelColor=white}" shadow="{labelShadow=1}" font="{font=dyn_10}" content="{label}" noclick="1"/>
		</panel>
	</template>

	<!-- Standard Store Button -->
	<template name="storeButton">
		<button
			name="{buttonName}"
			width="{width=100%}"
			height="{height=100%}"
			align="{align=left}"
			valign="{valign=top}"
			x="{x}"
			y="{y}"
			onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav'); {onclick}"
			onclicklua="{onclicklua}"
			color="invisible"
			visible="{visible=true}"
			enabled="{enabled=true}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			watch2="{watch2}"
			ontrigger2="{ontrigger2}"
			watch3="{watch3}"
			ontrigger3="{ontrigger3}"
			watch4="{watch4}"
			ontrigger4="{ontrigger4}"
			onevent="{onevent}"
			onevent0="{onevent0}"
			onevent1="{onevent1}"
			onevent2="{onevent2}"
			onevent3="{onevent3}"
			onevent4="{onevent4}"
			onevent5="{onevent5}"
			onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); {onmouseout}"
			onmouseoverlua="{onmouseoverlua}"
			onmouseoutlua="{onmouseoutlua}"
			onrightclick="{onrightclick}"
			mouseoverdisabled="{mouseoverdisabled=false}"
			mouseoutdisabled="{mouseoutdisabled=false}"
			onload="{onload}"
		>
			<widgetstate statename="up">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}"/>
			</widgetstate>
			<widgetstate statename="over">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}" highlight="1"/>
			</widgetstate>
			<widgetstate statename="down">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=#ffd200}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" label="{label}" buttonwidth="-28@" buttonheight="-28%" darken="1"/>
			</widgetstate>
			<widgetstate statename="disabled" rendermode="grayscale">
				<instance name="storeButtonWidgetState" textalign="{textalign=center}" labelColor="{labelColor=0.7 0.7 0.7 1}" labelshadow="{labelShadow=true}" font="{font=dyn_10}" rendermode="grayscale" label="{label}"/>
			</widgetstate>
		</button>
	</template>

	<template name="store2Button">
		<button
			name="{buttonName}"
			width="{width=100%}"
			height="{height=100%}"
			align="{align=left}"
			valign="{valign=top}"
			x="{x}"
			y="{y}"
			onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav'); {onclick}"
			onclicklua="{onclicklua}"
			color="invisible"
			visible="{visible=true}"
			enabled="{enabled=true}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			watch2="{watch2}"
			ontrigger2="{ontrigger2}"
			watch3="{watch3}"
			ontrigger3="{ontrigger3}"
			watch4="{watch4}"
			ontrigger4="{ontrigger4}"
			onevent="{onevent}"
			oneventlua="{oneventlua}"
			onevent0="{onevent0}"
			onevent1="{onevent1}"
			onevent2="{onevent2}"
			onevent3="{onevent3}"
			onevent4="{onevent4}"
			onevent5="{onevent5}"
			onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); {onmouseout}"
			onmouseoverlua="{onmouseoverlua}"
			onmouseoutlua="{onmouseoutlua}"
			onrightclick="{onrightclick}"
			onrightclicklua="{onrightclicklua}"
			mouseoverdisabled="{mouseoverdisabled=false}"
			mouseoutdisabled="{mouseoutdisabled=false}"
			onload="{onload}"
			onloadlua="HoN_Store:SetWidgetScale(self, {scale=1})"
			oninstantiate="{oninstantiate}"
			onshow="{onshow}"
			onshowlua="{onshowlua}"
			onhide="{onhide}"
			onhidelua="{onhidelua}"
		>
			<widgetstate statename="up">
				<image onloadlua="HoN_Store:SetWidgetScale(self, {scale=1})" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label content="{label}" font="{font=dyn_12}" color="{color=#d7b6a2}" outline="1" outlinecolor="{outlinecolor=#230000}" align="center" valign="center" textalign="center" textvalign="center"/>
			</widgetstate>
			<widgetstate statename="over">
				<image onloadlua="HoN_Store:SetWidgetScale(self, {scale=1})" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}_over.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label x="1i" y="1i" content="{label}" font="{font=dyn_12}" color="{color=#d7b6a2}" outline="1" outlinecolor="{outlinecolor=#230000}" align="center" valign="center" textalign="center" textvalign="center"/>
			</widgetstate>
			<widgetstate statename="down">
				<image onloadlua="HoN_Store:SetWidgetScale(self, {scale=1})" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}_over.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label x="2i" y="2i" content="{label}" font="{font=dyn_12}" color="{color=#d7b6a2}" outline="1" outlinecolor="{outlinecolor=#230000}" align="center" valign="center" textalign="center" textvalign="center"/>
			</widgetstate>
			<widgetstate statename="disabled">
				<image onloadlua="HoN_Store:SetWidgetScale(self, {scale=1})" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}.png" color="{bgcolor=}" rendermode="{disabledrendermode=grayscale}"/>
				<label content="{label}" font="{font=dyn_12}" color="{disabledcolor=#c2c2c2}" outline="1" outlinecolor="{disabledoutlinecolor=#353535}" align="center" valign="center" textalign="center" textvalign="center"/>
			</widgetstate>
		</button>
	</template>

	<template name="store2AnimatedButton">
		<panel x="{x}" y="{y}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="1"
		>
			<animatedimage texture="/ui/fe2/elements/store2/{animatedimage}.png" align="center" valign="center" hflip="{hflip=false}" vflip="{vflip=false}" fps="25" loop="1" loopbackframe="0" startframe="0" noclick="1"/>
			<button
				name="{buttonName}"
				width="{buttonWidth=100%}"
				height="{buttonHeight=100%}"
				align="center"
				valign="center"
				onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav'); {onclick}"
				onclicklua="{onclicklua}"
				color="invisible"
				visible="{visible=true}"
				enabled="{enabled=true}"
				watch="{watch}"
				ontrigger="{ontrigger}"
				watch1="{watch1}"
				ontrigger1="{ontrigger1}"
				watch2="{watch2}"
				ontrigger2="{ontrigger2}"
				watch3="{watch3}"
				ontrigger3="{ontrigger3}"
				watch4="{watch4}"
				ontrigger4="{ontrigger4}"
				onevent="{onevent}"
				oneventlua="{oneventlua}"
				onevent0="{onevent0}"
				onevent1="{onevent1}"
				onevent2="{onevent2}"
				onevent3="{onevent3}"
				onevent4="{onevent4}"
				onevent5="{onevent5}"
				onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
				onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); {onmouseout}"
				onmouseoverlua="{onmouseoverlua}"
				onmouseoutlua="{onmouseoutlua}"
				onrightclick="{onrightclick}"
				mouseoverdisabled="{mouseoverdisabled=false}"
				mouseoutdisabled="{mouseoutdisabled=false}"
				onload="{onload}"
				oninstantiate="{oninstantiate}"
				onshow="{onshow}"
				onshowlua="{onshowlua}"
				onhide="{onhide}"
				onhidelua="{onhidelua}"
			>
				<widgetstate statename="up"><panel/></widgetstate>
				<widgetstate statename="over"><panel/></widgetstate>
				<widgetstate statename="down"><panel/></widgetstate>
				<widgetstate statename="disabled"><panel/></widgetstate>
			</button>
		</panel>
	</template>

	<template name="store2ButtonNoLabel">
		<button
			name="{buttonName}"
			width="{width=100%}"
			height="{height=100%}"
			align="{align=left}"
			valign="{valign=top}"
			x="{x}"
			y="{y}"
			onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav'); {onclick}"
			onclicklua="{onclicklua}"
			color="invisible"
			visible="{visible=true}"
			enabled="{enabled=true}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			watch2="{watch2}"
			ontrigger2="{ontrigger2}"
			watch3="{watch3}"
			ontrigger3="{ontrigger3}"
			watch4="{watch4}"
			ontrigger4="{ontrigger4}"
			onevent="{onevent}"
			oneventlua="{oneventlua}"
			onevent0="{onevent0}"
			onevent1="{onevent1}"
			onevent2="{onevent2}"
			onevent3="{onevent3}"
			onevent4="{onevent4}"
			onevent5="{onevent5}"
			onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); {onmouseout}"
			onmouseoverlua="{onmouseoverlua}"
			onmouseoutlua="{onmouseoutlua}"
			onrightclick="{onrightclick}"
			mouseoverdisabled="{mouseoverdisabled=false}"
			mouseoutdisabled="{mouseoutdisabled=false}"
			onload="{onload}"
			oninstantiate="{oninstantiate}"
			onshow="{onshow}"
			onshowlua="{onshowlua}"
			onhide="{onhide}"
			onhidelua="{onhidelua}"
		>
			<widgetstate statename="up">
				<image width="{imgwidth=32i}" height="{imgheight=32i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}.png" color="{bgcolor=}" rendermode="{rendermode=}" hflip="{hflip=false}" vflip="{vflip=false}"/>
			</widgetstate>
			<widgetstate statename="over">
				<image width="{imgwidth=32i}" height="{imgheight=32i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}_over.png" color="{bgcolor=}" rendermode="{rendermode=}" hflip="{hflip=false}" vflip="{vflip=false}"/>
			</widgetstate>
			<widgetstate statename="down">
				<image width="{imgwidth=32i}" height="{imgheight=32i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}_over.png" color="{bgcolor=}" rendermode="{rendermode=}" hflip="{hflip=false}" vflip="{vflip=false}"/>
			</widgetstate>
			<widgetstate statename="disabled">
				<image width="{imgwidth=32i}" height="{imgheight=32i}" align="center" valign="center" texture="/ui/fe2/elements/store2/button/{texture}.png" color="{bgcolor=}" rendermode="{disabledrendermode=grayscale}" hflip="{hflip=false}" vflip="{vflip=false}"/>
			</widgetstate>
		</button>
	</template>

	<template name="store2ToggleDetailButton">
		<panel name="{panelname}" x="{x=-2h}" y="{y=2h}" align="{align=right}" valign="{valign=top}" visible="{visible=true}" width="3h" height="3h" noclick="1">
			<instance name="store2AnimatedButton" align="center" valign="center" vflip="{vflip=false}" animatedimage="button/animatedarrow/sf_" onclicklua="{onclicklua}"/>
		</panel>
	</template>

	<template name="mstore_btn_closex_state">
		<widgetstate statename="{statename}" x="{x}" y="{y}">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="{color=#910000}" blockinput="false" noclick="1"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
			<image width="1.3h" height="1.3h" align="center" valign="center" color="{xcolor=.75 .75 .75 1}" texture="/ui/elements/closex.tga" noclick="1"/>
		</widgetstate>
	</template>

	<template name="mstore_btn_closex">
		<button
			x="{x}" y="{y}" width="{width}" height="{height}" align="{align}" valign="{valign}"
			color="invisible" visible="{visible=true}"
			name="{button_name}"
			onshowlua="{onshowlua}"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_03.wav'); If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}'));"
			onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
			interactive="false"
			onclicklua="PlaySound('/shared/sounds/ui/button_click_03.wav') {onclicklua}"
			onclick="{onclick}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
		>
			<instance name="mstore_btn_closex_state" statename="up" color="#910000"/>
			<instance name="mstore_btn_closex_state" statename="over" color="#dc0000" xcolor="1 1 1 1"/>
			<instance name="mstore_btn_closex_state" statename="down" x="1" y="1" xcolor="1 1 1 1"/>
			<instance name="mstore_btn_closex_state" statename="disabled" color="#777777"/>
		</button>
	</template>

	<template name="store2OthersButtons">
		<panel name="store2OthersButtons" width="25h" height="8h" align="center" valign="bottom" color="invisible" noclick="1"
			onevent2="
				If(
					microStoreID{id} ge 1,
					Split(
						If(
							microStorePremium{id},
							If(
								microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
								ShowOnly('storeViewShelfBackerPremGO{id}'),
								ShowOnly('storeViewShelfBackerPrem{id}')
							),
							If(
								microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
								ShowOnly('storeViewShelfBackerRegGO{id}'),
								ShowOnly('storeViewShelfBackerReg{id}')
							)
						),
						If(
							microStoreTempCDGold gt 0 and microStoreTempCDSilver le 0,
							HideWidget('storeViewShelfSCostBox{id}'),
							ShowWidget('storeViewShelfSCostBox{id}')
						),
						If(
							microStoreQuantity{id} ge 1,
							Call('storeViewShelfQuantity{id}', 'SetText(microStoreQuantity{id} # \' Left!\');'),
							Call('storeViewShelfQuantity{id}', '')
						),
						Call('storeViewShelfImage{id}', 'DoEvent();'),
						CallEvent('storeViewShelfUnlockIconBtn{id}'),
						CallEvent('storeViewShelfUnlockTauntBtn{id}')
					)
				);
			"
			onevent8="
				Set('microStoreGetCDPriceView', 1);
				Set('microStoreGetCDPriceItem', {id=0});

				ExplodeTrigger('MicroStoreGetCDPrice', microStoreCharges{id}, ',', '~');
				ExplodeTrigger('MicroStoreGetCDPrice', microStoreDurations{id}, ',', '~');

				If(
					!microStoreAlreadyOwned{id} or (!microStorePurchasable{id} and (microStoreTempCDGold ge 1 or microStoreTempCDSilver ge 1)),
					If(
						_microStore_TotalCoins ge microStoreTempCDGold or (_microStore_TotalSilverCoins ge microStoreTempCDSilver and microStoreTempCDSilver ge 1),
						Split(
							ShowWidget('storeViewShelfBtnBuy{id}'),
							If(
								microStoreTargetPurchaseID == microStoreID{id},
								Split(
									Set('_microStore_SelectedID', microStoreID{id}),
									Set('_microStore_SelectedItem', {id}),
									Trigger('MicroStoreUpdateSelection'),
									CallEvent('store_popup_confirm_purchase_choose', 0),
									Set('microStoreTargetPurchaseID', -1)
								)
							),
							HideWidget('storeViewShelfBtnNeedCoins{id}')
						),
						Split(
							HideWidget('storeViewShelfBtnBuy{id}'),
							ShowWidget('storeViewShelfBtnNeedCoins{id}')
						)
					),
					Split(
						HideWidget('storeViewShelfBtnBuy{id}'),
						HideWidget('storeViewShelfBtnNeedCoins{id}')
					)
				);
			"
		>
			<!-- TODO::quantity -->
			<panel name="storeViewShelfDescBox{id}" align="right" x="-1.25h" y="4.75h" width="18h" height="6.25h">
				<panel valign="bottom" height="1.5h" noclick="1">
					<label wrap="1" font="dyn_9" color="0 1 0 1" shadow="1" textalign="center" textvalign="center" name="storeViewShelfQuantity{id}" noclick="1"/>
				</panel>
			</panel>

			<!-- reset stats -->
			<if condition="!cl_GarenaEnable">
				<instance name="store2_buy_button" enabled="0"
					btname="store2OthersBtnResetStats"
					label="web_form_resetstats_button"
					align="center" valign="top"
					watch="UpdateStoreResetStatsForm MicroStoreProcessing"
					ontrigger="If(ui_disableAccountCreation, DoEvent(3), DoEvent(2));"
					onclick="
						HideWidget('mstore_tip_redeem_statreset');
						Trigger('MicroStoreSetProcTrig', 'StoreNameChangeStatus');
						DoEvent(If(ui_disableAccountCreation, 1, 0));
					"
					onclicklua="HoN_Store:Store2Loading(1, 'Reset stats')"
					onmouseover="
						ShowWidget('mstore_tip_redeem_statreset');
					"
					onmouseout="
						HideWidget('mstore_tip_redeem_statreset');
					"
					onevent0="
						Trigger('MicroStoreSetProcTrig', 'StoreResetStatsStatus');
						SubmitForm(
							'StoreResetStats',
							'password', _store_resetstats_confirm_pass,
							'account_id', GetAccountID(),
							'psr', If(_microStore_resetStats_psr, 1, 0),
							'public', If(_microStore_resetStats_pubstats, 1, 0),
							'mmmidwars', If(_microStore_resetStats_midwars_mmr, 1, 0),
							'midwars', If(_microStore_resetStats_midwars_stats, 1, 0),
							'connormalstats', If(_microStore_resetStats_con_normal_stats, 1, 0),
							'cookie', GetCookie()
						);
					"
					onevent1="
						Trigger('MicroStoreSetProcTrig', 'StoreResetStatsStatus');
						SubmitForm(
							'StoreResetStats',
							'account_id', GetAccountID(),
							'psr', If(_microStore_resetStats_psr, 1, 0),
							'public', If(_microStore_resetStats_pubstats, 1, 0),
							'mmmidwars', If(_microStore_resetStats_midwars_mmr, 1, 0),
							'midwars', If(_microStore_resetStats_midwars_stats, 1, 0),
							'connormalstats', If(_microStore_resetStats_con_normal_stats, 1, 0),
							'cookie', GetCookie()
						);
					"
					onevent2="
						SetEnabled((_microStore_resetStats_psr or
									_microStore_resetStats_pubstats or
									_microStore_resetStats_midwars_mmr or
									_microStore_resetStats_midwars_stats or
									_microStore_resetStats_con_normal_stats) and !StringEmpty(_store_resetstats_confirm_pass)
						);
					"
					onevent3="
						SetEnabled((_microStore_resetStats_psr or
									_microStore_resetStats_pubstats or
									_microStore_resetStats_midwars_mmr or
									_microStore_resetStats_midwars_stats or
									_microStore_resetStats_con_normal_stats)
						);
					"
				/>
			</if>
			<if condition="cl_GarenaEnable">
				<instance name="store2_buy_button" enabled="0"
					btname="store2OthersBtnResetStats"
					label="web_form_resetstats_button"
					align="center" valign="top"
					watch="UpdateStoreResetStatsForm MicroStoreProcessing"
					ontrigger="
						SetEnabled((
								_microStore_resetStats_psr or
								_microStore_resetStats_pubstats or
								_microStore_resetStats_smr or
								_microStore_resetStats_normalmm_stats or
								_microStore_resetStats_casualmm_stats or
								_microStore_resetStats_casual_mmr or
								_microStore_resetStats_midwars_mmr or
								_microStore_resetStats_midwars_stats or
								_microStore_resetStats_con_normal_stats or
								_microStore_resetStats_con_casual_stats
								)
						);
					"
					onclick="
						Trigger('MicroStoreSetProcTrig', 'StoreResetStatsStatus');
						SubmitForm(
							'StoreResetStats',
							'account_id', GetAccountID(),
							'psr', If(_microStore_resetStats_psr, 1, 0),
							'smr', If(_microStore_resetStats_smr, 1, 0),
							'public', If(_microStore_resetStats_pubstats, 1, 0),
							'mmnormal', If(_microStore_resetStats_normalmm_stats, 1, 0),
							'mmcasual', If(_microStore_resetStats_casualmm_stats, 1, 0),
							'casual', If(_microStore_resetStats_casual_mmr, 1, 0),
							'mmmidwars', If(_microStore_resetStats_midwars_mmr, 1, 0),
							'midwars', If(_microStore_resetStats_midwars_stats, 1, 0),
							'connormalstats', If(_microStore_resetStats_con_normal_stats, 1, 0),
							'concasualstats', If(_microStore_resetStats_con_casual_stats, 1, 0),
							'cookie', GetCookie()
						);
					"
					onclicklua="HoN_Store:Store2Loading(1, 'Reset stats')"
				/>
			</if>

			<!-- sub account -->
			<if condition="!cl_GarenaEnable">
				<instance name="store2_buy_button" enabled="0"
					btname="store2OthersBtnCreateSubaccount"
					label="web_form_subaccount_title"
					font="dyn_12"
					align="center" valign="top"
					watch="UpdateStoreSubAccountForm"
					ontrigger="If(ui_disableAccountCreation, DoEvent(3), DoEvent(2));"
					onclick="Trigger('MicroStoreSetProcTrig', 'StoreSubAccountStatus');	DoEvent(If(ui_disableAccountCreation, 1, 0));"
					onclicklua="HoN_Store:Store2Loading(1, 'Sub account')"
					onevent0="SubmitForm('StoreSubAccount', 'account_id', GetAccountID(), 'password', store_SubAccount_confirmpass, 'cookie', GetCookie());"
					onevent1="SubmitForm('StoreSubAccount', 'account_id', GetAccountID(), 'cookie', GetCookie());"
					onevent2="SetEnabled(!StringEmpty(store_SubAccount_nick) and StringEquals(store_SubAccount_nick, store_SubAccount_nick2) and !StringEmpty(store_SubAccount_confirmpass));"
					onevent3="SetEnabled(!StringEmpty(store_SubAccount_nick) and StringEquals(store_SubAccount_nick, store_SubAccount_nick2));"
				/>
			</if>

			<!-- change nickname -->
			<instance name="store2_buy_button" enabled="0"
				btname="store2OthersBtnChangeNickname"
				label="mstore_nickchange_submit"
				font="dyn_12"
				align="center" valign="top"
				watch="UpdateStoreNameChangeForm"
				ontrigger="
					DoEvent(If(ui_disableAccountCreation, 3, 2));
				"
				onclick="
					Trigger('MicroStoreSetProcTrig', 'StoreNameChangeStatus');
					DoEvent(If(ui_disableAccountCreation, 1, 0));
				"
				onclicklua="HoN_Store:Store2Loading(1, 'Change nickname')"
				onevent0="
					SubmitForm('StoreNameChange', 'account_id', GetAccountID(), 'password', _store_namechange_confirmpass, 'cookie', GetCookie());
				"
				onevent1="
					SubmitForm('StoreNameChange', 'account_id', GetAccountID(), 'cookie', GetCookie());
				"
				onevent2lua="
					local enabled = HoN_Store.store_namechange_nick ~= nil 
									and HoN_Store.store_namechange_nick == HoN_Store.store_namechange_nick2
									and HoN_Store.store_namechange_confirmpass ~= nil and HoN_Store.store_namechange_confirmpass ~= ''
					self:SetEnabled(enabled)
				"
				onevent3lua="
					local enabled = (HoN_Store.store_namechange_nick ~= nil and HoN_Store.store_namechange_nick == HoN_Store.store_namechange_nick2)
					self:SetEnabled(enabled)
				"
			/>

			<!-- buy & price -->
			<panel name="store2OthersBuyContainer" align="center" width="-3h" grow="1" float="bottom" padding="0.1h" noclick="1" >
				<instance name="store2_specials_booth_buy_button" id="others" align="center" showdiscount="0" scale="1" onclicklua="HoN_Store:OnPurchaseVanity()"/>
				<instance name="store2_specials_booth_owned_button" id="others" align="center" valign="center" text="general_unavailable" onmouseoverlua="HoN_Store:VanityItemShowToolTip()" onmouseoutlua="HoN_Store:HideToolTip()" />
				<panel name="store2_specials_booth_price_parent_others" grow="1" height="32i" align="center" float="right"/>
			</panel>

			<button color="invisible" visible="0"
				name="storeViewShelfBtnIneligible{id}"
				onmouseoverlua="UIManager.GetInterface('main'):HoNStoreF('HoverShelvedInelidgible', GetCvarString('microStoreID{id}'))"
				onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
			>
				<widgetstate statename="up"><instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/></widgetstate>
				<widgetstate statename="over"><instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/></widgetstate>
				<widgetstate statename="down"><instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/></widgetstate>
				<widgetstate statename="disabled"><instance name="storeButtonWidgetState" label="mstore_elig_only" rendermode="grayscale" labelColor="0.7 0.7 0.7 1"/></widgetstate>
			</button>

			<instance name="store2_buy_button" tip_id="mstore_tip_need_coins" align="center" valign="top" label="mstore_needcoins" visible="0"
				btname="store2OthersNeedCoinsBtn"
				onclick="Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"
			/>
		</panel>
	</template>

	<template name="store2OthersDetailPanel">
		<panel name="store2OthersDetailPanel" x="-6h" y="-3h" align="right" valign="center" width="590i" grow="1" float="bottom" color="invisible" visible="0" noclick="0"
		>
			<panel width="100%" grow="1" float="bottom" padding="1h" color="invisible" noclick="1">
				<instance name="store2_frame2"/>
				<anchor x="3h" y="1.5h"/>
				<panel width="-6h" grow="1" float="bottom" padding="1h" color="invisible" noclick="1">
					<panel width="100%" grow="1" noclick="1">
						<label name="store2OthersDetailName" fity="1" width="100%" textalign="center" font="dyn_16" color="#f1dbcb" content="" noclick="1" />
					</panel>

					<instance name="store2_line2" align="center" width="100%"/>

					<panel width="100%" grow="1" noclick="1">
						<label name="store2OthersDetailDescription" fity="1" wrap="1" style="microStoreDetailDesc" content="" noclick="1"/>
					</panel>

					<instance name="store2_line2" align="center" width="100%"/>

					<panel name="store2OthersFormContainer" width="100%" grow="1" noclick="1">
					</panel>
				</panel>
			</panel>

			<panel width="-6h" align="center" height="14i" noclick="1" color="invisible"/>
			<panel width="-6h" align="center" grow="1" float="bottom" noclick="1" color="invisible">
				<instance name="store2OthersButtons"/>
			</panel>

			<panel width="-6h" align="center" name="store2OthersForms" height="1" visible="0" noclick="1" color="invisible">
				<instance name="storePopupResetStatsForm" id="others" visible="0"/>
				<if condition="!cl_GarenaEnable">
					<instance name="storePopupSubAccountForm" id="others" visible="0"/>
				</if>
				<instance name="storePopupNameChangeForm" id="others" visible="0"/>
			</panel>
		</panel>
	</template>

	<template name="woodenPlankFrame">
		<panel>
			<!-- <frame texture="/ui/frames/squareglow.tga" borderthickness="1h" color="0 0 0 0.5" height="+4h" width="+3h" y="-0.5h" align="center" valign="center"/> -->
			<panel color="white" align="center" valign="center" width="-4h" height="-4h" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_center.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="1" vtile="1" uscale="64p" vscale="64p" onload="SetUScale((GetScreenHeight() / 6.25) # 'p'); SetVScale((GetScreenHeight() / 6.25) # 'p');"/>
			<panel color="white" height="16h" width="-24h" y="-8h" align="center" valign="top" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_top.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="1" vtile="1" uscale="64p" vscale="64p" onload="SetUScale((GetHeight() * 0.5) # 'p'); SetVScale(GetHeight() # 'p');"/>
			<panel color="white" height="8h" width="-10h" align="center" valign="bottom" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_bottom.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="1" vtile="1" uscale="64p" vscale="64p" onload="SetUScale(GetHeight() # 'p'); SetVScale(GetHeight() # 'p');"/>
			<panel color="white" height="-10h" width="16h" align="left" valign="center" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_left.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="1" vtile="1" uscale="64p" vscale="64p" onload="SetUScale(GetWidth() # 'p'); SetVScale(GetWidth() # 'p');"/>
			<panel color="white" height="-10h" width="16h" align="right" valign="center" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_right.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" utile="1" vtile="1" uscale="64p" vscale="64p" onload="SetUScale(GetWidth() # 'p'); SetVScale(GetWidth() # 'p');"/>
			<image width="16h" height="16h" y="-8h" align="left" valign="top" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_tl.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			<image width="16h" height="16h" y="-8h" align="right" valign="top" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_tr.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			<image width="16h" height="8h" align="left" valign="bottom" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_bl.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			<image width="16h" height="8h" align="right" valign="bottom" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_br.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			<image width="6h" height="30h" x="2h" y="-28.5h" valign="top" align="left" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_chain.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			<image width="6h" height="30h" x="-2h" y="-28.5h" valign="top" align="right" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/popup/frame_chain.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
		</panel>
	</template>

	<template name="plankWindow">
		<panel color="{color=0 0 0 .5}" visible="false" name="store_popup_{id}" noclick="{noclick=0}"
			onclicklua="{onclicklua=}"
			group="{group=storePopupWindows}"
			onevent0="
				Echo('store_popup_' # '{id}' # ' is showing');
				FadeIn(100);
				SleepWidget(101, 'CallEvent(name # \'_plank\', 0);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slidein.wav');
				{onshow=}
			"
			onevent0lua="{onshowlua=}"
			onevent1="
				Echo('store_popup_' # '{id}' # ' is hiding');
				{onhide=}
				CallEvent(name # '_plank', 1);
				SleepWidget(101, 'FadeOut(100);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slideout.wav');
			"
			onevent1lua="
				{onhidelua=}
			"
			onevent2="
				## So these can be groupcalled to hide anything visible when the store closes. ##
				If(
					IsVisibleSelf(),
					DoEvent(1)
				);
			"
			onload="If({debug=false}, DoEvent(0));"
		>
			<panel width="{width=40h}" grow="1" x="{x}" y="-110%" valign="center" align="center" name="store_popup_{id}_plank" regrow="{regrow=false}" noclick="{noclick=0}"
				onevent0lua="
					self:Sleep(1, function() self:SlideY('{y='.. (tonumber(self:GetHeight()) &lt; 200 and '-15h' or '-10h') .. '}', 250) end)
					self:SetVisible(true)"
				onevent1lua="self:SlideY('-110%', 250) self:Sleep(251, function() self:SetVisible(false) end)"
			>
				<instance name="woodenPlankFrame"/>
				<panel height="11h" noclick="1"/><!-- This is about the minimum height that this thing can have -->
				<label y="-0.5h" width="100%" height="2.5h" uppercase="true" content="{title}" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperTitle" watch="{titlewatch}" ontrigger="{titleontrigger}"/>
				<panel width="-6h" align="center" grow="1" y="3.5h" float="bottom" regrow="{regrow=false}">
					<panel width="100%" grow="1" regrow="{regrow=false}">
						<instance name="{content}"/>
					</panel>
					<panel height="3h" noclick="1"/>
				</panel>
				<instance name="store2_close" x="-1.25h" y="0.25h" width="2h" height="2h" align="right" visible="{show_close=false}" onclicklua="GetWidget('store_popup_{id}'):DoEventN(1)" watch="MicroStoreProcessing" ontriggerlua="self:SetEnabled(not AtoB(param0))"/>
			</panel>
		</panel>
	</template>

	<template name="form_radiobutton_stateimage">
		<panel width="{size}" color="invisible">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness=".75h" color="white"/>
			<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness=".8h"/>
			<panel hmargin="0.15h" vmargin="0.15h" visible="{checked}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="-0.55h" color="#3abde7"/>
			</panel>
		</panel>
		<label width="-{size}" height="100%" textvalign="center" font="{font}" color="{color}" shadow="{shadow=true}">{label}</label>
	</template>

	<template name="form_radiobutton_stateimage_nolabel">
		<panel width="{size}" height="{size}" color="invisible">
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness=".75h" color="white"/>
			<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness=".8h"/>
			<panel hmargin="0.15h" vmargin="0.15h" visible="{checked}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="-0.55h" color="#3abde7"/>
			</panel>
		</panel>
	</template>

	<template name="form_radiobutton_state">
		<widgetstate statename="{state}" float="right" padding="3%">
			<instance name="{displaytemplate}" size="{size}" checked="{checked}" label="{label}" color="{color=white}" shadow="{shadow=true}" state="{state}"/>
		</widgetstate>
	</template>

	<template name="form_radiobutton">
		<panel width="{width=90%}" height="{height=1.5h}" align="{align}" valign="{valign}" noclick="1" color="invisible" onload="{onpreload=}" visible="{visible=1}" group="{group}" >
			<button
				color="invisible"
				numstates="2"
				onclick="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}')); PlaySound('/shared/sounds/ui/button_click_06.wav'); Set('{cvar=}', '{value=}'); GroupCall('{cvar=}_radio_group', 'SetButtonState(0);'); SetButtonState(1); If(!StringEmpty('{updatetrigger}'), Trigger('{updatetrigger}')); {onclick=}"
				onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onload="SetButtonState({default_state=0}); {onload=}"
				name="{radiobutton_name=}"
				group="{cvar=}_radio_group"
				oninstantiate="{oninstantiate=}"
			>
				<instance name="form_radiobutton_state" state="up" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="white" checked="false" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="over" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="false" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="down" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="false" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="disabled" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#888888" cvar="{cvar=}" checked="false" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>

				<instance name="form_radiobutton_state" state="up2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#ffaa00" checked="true" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="over2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="true" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="down2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#3abde7" checked="true" cvar="{cvar=}" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
				<instance name="form_radiobutton_state" state="disabled2" size="{height=1.5h}" label="{label}" font="{font=dyn_9}" color="#888888" cvar="{cvar=}" checked="true" displaytemplate="{displaytemplate=form_radiobutton_stateimage}"/>
			</button>
		</panel>
	</template>

	<template name="paperform_combobox_item">
		<label x="50@" style="microStorePaperText" height="100%" font="dyn_10" textvalign="center" content="{label}"/>
	</template>

	<template name="paperform_combobox_item_goldsilvercost">
		<panel height="100%" x="50@" font="dyn_9" width="-3.5h" y="0.25h">
			<label font="dyn_9" color="#774515" textvalign="center" content="{label}" width="-6h"/>
			<panel align="right" width="5.5h" x="-5.5h" visible="{showSilver=true}">
				<label font="dyn_9" textalign="center" outline="true" outlinecolor="#2d1d0d" color="#c0d5ed" textvalign="center" content="{silverCost=-}" width="-100@"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/silver_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.5" x="0.1h" y="0.1h"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/silver_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/silver_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			</panel>
			<panel align="right" width="5.5h">
				<label font="dyn_9" textalign="center" outline="true" color="#FFCC00" outlinecolor="#2d1d0d" textvalign="center" content="{goldCost=-}" width="-100@"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/gold_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0 0 0 0.5" x="0.1h" y="0.1h"/>
				<image align="right" height="100%" width="85@" valign="center" oninstantiate="SetTexture('/ui/fe2/store/gold_coins.tga');" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
			</panel>
		</panel>
	</template>

	<template name="paperform_combobox">
		<combobox
			name="{id}"
			x="{x}"
			width="{width}"
			height="{height=100%}"
			align="{align=right}"
			valign="{valign=center}"
			color="invisible"
			itemwidth="{itemwidth=100%}"
			itemheight="2h"
			maxlistheight="{maxlistheight}"
			cvar="{cvar=}"
			exteriorscrollbars="false"
			scrolltexture="/ui/fe2/elements/store2/combobox/combobox.png"
			handleheight="100@" handlewidth="100%"
			vertical="true"
			scrollbarsize="2h"
			scrollbaroffset="0"
			highlight="under"
			highlightcolor="invisible"
			highlightbordercolor="invisible"
			onload="DoEvent(1);"
			onselect="PlaySound('/shared/sounds/ui/button_click_05.wav'); {onselect=}"
			onselectlua="{onselectlua=}"
			onshow="{onshow=}"
			onhide="{onhide=}"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_02.wav');"
			watch="{watch=}"
			ontrigger="{ontrigger=}"
			ontriggerlua="{ontriggerlua=}"
			visible="{visible=true}"
			form="{form=}" data="{formdata=}"
			watch0="{watch0=}"
			ontrigger0="{ontrigger0=}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			ontrigger1lua="{ontrigger1lua=}"
			onevent="{onevent=}"
			onevent1="ComboBoxCmd('clear'); {populate=}; {data=}('{displaytemplate=paperform_combobox_item}'); {onload=}"
		>
			<instance name="store2_combobox_state" state="up"/>
			<instance name="store2_combobox_state" state="over" texSuffix="_over"/>
			<instance name="store2_combobox_state" state="down" texSuffix="_over"/>

			<widgetstate statename="listbg">
				<instance name="store2_frame" y="-2i" height="+4i"/>
			</widgetstate>
			<widgetstate statename="itembg">
				<image texture="/ui/fe2/elements/store2/line.png" align="center" valign="top" y="-37i" width="148%" height="64i"/>
			</widgetstate>
			<widgetstate statename="itemhighlight">
				<frame color="#cda5963b" align="center" valign="center" width="-6i" height="-1i" y="-1i"/>
			</widgetstate>
		</combobox>
	</template>

	<template name="paperForm_combobox_container">
		<panel y="{y=0}" align="center" valign="{valign=center}" height="{height=2.5h}" float="right" onload="{onload}" noclick="1">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="dyn_10" color="{labelColor=#d7b6a2}" shadow="{labelShadow=false}" outline="{labelOutline=true}" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}" outlinecolor="{labelOutlineColor}"
				onevent0="SetColor('#ae181c');"
				onevent1="SetColor('{labelColor=#d7b6a2}');"
				onload="DoEvent(1);"
			/>
			<panel width="5%" height="100%" valign="center" noclick="1">
				<image width="1.5h" height="1.5h" align="left" valign="center" texture="/ui/fe2/elements/store2/popup/arrow.png" noclick="1"/>
			</panel>
			<panel width="{fieldwidth=55%}" height="100%" valign="center" noclick="1">
				<instance name="paperform_combobox" onshow="{onshow}" onevent="{onevent}" id="{id}" x="0" width="100%" itemwidth="100%" maxlistheight="{maxlistheight=10}" cvar="{cvar}" data="{data}" onselect="If(!StringEmpty('{updatetrigger}'), Trigger('{updatetrigger}')); {onselect}" populate="{populate}" watch="{boxwatch}" ontrigger="{boxontrigger}" ontriggerlua="{boxontriggerlua}" watch1="{boxwatch1}" ontrigger1="{boxontrigger1}" ontrigger1lua="{boxontrigger1lua}" watch0="{boxwatch0}" ontrigger0="{boxontrigger0}" onselectlua="{onselectlua}"/>
			</panel>
			<panel width="2.4h" height="100%" valign="center" visible="{hastip}" noclick="1">
				<instance name="store2_tip_mark" tip_id="{tip_id}" onmouseover="{tipmouseover}" onmouseout="{tipmouseout}"/>
			</panel>
		</panel>
	</template>

	<template name="paperForm_expdate_container">
		<panel y="{y}" align="center" valign="{valign}" width="{width}" height="{height=2.5h}" float="right">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="dyn_10" color="#d7b6a2" outline="1" outlinecolor="black" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}"
				onevent0="SetColor('#ae181c');"
				onevent1="SetColor('#d7b6a2');"
			/>
			<panel width="5%" height="100%" valign="center" noclick="1">
				<image width="1.5h" height="1.5h" align="left" valign="center" texture="/ui/fe2/elements/store2/popup/arrow.png" noclick="1"/>
			</panel>
			<panel width="{fieldwidth=55%}" valign="center" noclick="1">
				<panel>
					<panel width="45%" noclick="1">
						<label textvalign="center" font="dyn_10" color="#d7b6a2" outline="1" outlinecolor="black" content="creditcard_label_prime_month" watch="{updatetrigger}" ontrigger="{ontrigger}"
							onevent0="SetColor('#ae181c');"
							onevent1="SetColor('#d7b6a2');"
							onload="DoEvent(1);"
						/>
						<instance
							name="paperform_combobox"
							id="{varprefix}_ccmonth"
							align="right" width="50%" itemwidth="100%" maxlistheight="5"
							onshow="ListBoxCmd('Select 0');"
							onhide="DoEvent(1);"
							onselect="Trigger('UpdatePurchaseCoinsForm');"
							populate="
								AddTemplateListItem('paperform_combobox_item', '01', 'label', '01');
								AddTemplateListItem('paperform_combobox_item', '02', 'label', '02');
								AddTemplateListItem('paperform_combobox_item', '03', 'label', '03');
								AddTemplateListItem('paperform_combobox_item', '04', 'label', '04');
								AddTemplateListItem('paperform_combobox_item', '05', 'label', '05');
								AddTemplateListItem('paperform_combobox_item', '06', 'label', '06');
								AddTemplateListItem('paperform_combobox_item', '07', 'label', '07');
								AddTemplateListItem('paperform_combobox_item', '08', 'label', '08');
								AddTemplateListItem('paperform_combobox_item', '09', 'label', '09');
								AddTemplateListItem('paperform_combobox_item', '10', 'label', '10');
								AddTemplateListItem('paperform_combobox_item', '11', 'label', '11');
								AddTemplateListItem('paperform_combobox_item', '12', 'label', '12');
								"
							form="" formdata="month"
						/>
					</panel>
					<panel align="right" width="50%" noclick="1">
						<label textvalign="center" font="dyn_10" color="#d7b6a2" outline="1" outlinecolor="black" content="creditcard_label_prime_year" watch="{updatetrigger}" ontrigger="{ontrigger}"
							onevent0="SetColor('#ae181c');"
							onevent1="SetColor('#d7b6a2');"
							onload="DoEvent(1);"
						/>
						<instance
							name="paperform_combobox"
							id="{varprefix}_ccyear"
							align="right" width="60%" itemwidth="100%" maxlistheight="5"
							onshow="ListBoxCmd('Select 0');"
							onhide="DoEvent(1);"
							onselect="Trigger('UpdatePurchaseCoinsForm');"
							populate="
								for(
									GetYear(),GetYear() + 25,1,
									'
										AddTemplateListItem(\'paperform_combobox_item\', iParam, \'label\', iParam);
									'
								);
							"
							form="" formdata="year"
						/>
					</panel>
				</panel>
			</panel>
			<panel width="2.4h" height="100%" valign="center" visible="{hastip}" noclick="1">
				<instance name="store2_tip_mark" tip_id="{tip_id}"/>
			</panel>
		</panel>
	</template>

	<template name="paperForm_textbox">
		<instance name="store2_frame"/>
		<textbox
			name="{widgetname}"
			taborder="{order}"
			passwordchar="{passchar=}"
			maxlength="{maxlength=-1}"
			y="{y=0.3h}"
			width="{width=-1.0h}"
			align="{align=center}"
			x="{x=0}"
			color="invisible"
			font="{font=dyn_10}"
			textcolor="#774515"
			enabled="{enabled=true}"
			shadow="true"
			onchange="{onchange}"
			onchangelua="HoN_Store.{widgetname} = self:GetInputLine() {onchangelua}"
			onkeydown="{onkeydown}"
			onkeydownlua="{onkeydownlua}"
			onshow="{onshow}"
			onhide="{onhide}"
			onfocus="{onfocus}"
			onlosefocus="{onlosefocus}"
			onfocuslua="{onfocuslua}"
			onlosefocuslua="{onlosefocuslua}"
			form="{form=}"
			data="{data=}"
			wrap="{wrap=}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			onenter="{onenter}"
			onesc="{onesc}"
		/>
	</template>

	<template name="paperForm_textbox_container">
		<panel name="paperForm_textbox_{fieldname}" y="{y}" align="center" valign="{valign}" width="{width}" height="{height=2.5h}" float="right" noclick="1">
			<label name="{fieldname}_label" width="{labelwidth=35%}" height="100%" textvalign="center" font="{font=dyn_10}" color="{color=#d7b6a2}" outline="1" outlinecolor="black" content="{label}" watch="{updatetrigger}" ontrigger="{ontrigger}" noclick="1"
				onevent0lua="self:SetColor('#ae181c') {onevent0lua}"
				onevent1lua="self:SetColor('#d7b6a2') {onevent1lua}"
				onload="DoEvent(1); {onload=}"
				onshowlua="{onshowlua}"
			/>
			<panel width="5%" height="100%" valign="center" visible="{showarrow=true}" noclick="1">
				<image width="1.5h" height="1.5h" align="left" valign="center" texture="/ui/fe2/elements/store2/popup/arrow.png" noclick="1"/>
			</panel>
			<panel width="{fieldwidth=55%}" height="100%" valign="center" noclick="1">
				<instance name="paperForm_textbox" wrap="{wrap=}" onhide="{onhide}" font="{font=dyn_10}" enabled="{enabled=true}" align="{field_align=center}" x="{field_xoffset=0}" width="{field_width=-1h}" widgetname="{fieldname}" order="{order}" onchangelua="{onchangelua} Trigger('{updatetrigger}')" onchange="{onchange} Trigger('{updatetrigger}');" onkeydown="{onkeydown}" onkeydownlua="{onkeydownlua}" passchar="{passchar=}" maxlength="{maxlength=-1}" form="{form=}" data="{data=}" onfocus="{onfocus}" onlosefocus="{onlosefocus}" onfocuslua="{onfocuslua}" onlosefocuslua="{onlosefocuslua}" watch="{textboxwatch}" ontrigger="{textboxontrigger}" watch2="{textboxwatch2}" ontrigger2="{textboxontrigger2}" onesc="{onesc}"/>
			</panel>
			<panel width="2.4h" height="100%" valign="center" visible="{hastip}" noclick="1">
				<instance name="store2_tip_mark" tip_id="{tip_id}"/>
			</panel>
		</panel>
	</template>

	<template name="paperform_checkbox_state">
		<widgetstate statename="{state}" float="right" padding="0.25h">
			<panel width="{size}" color="invisible">
				<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/checkbox/{texture=cb}.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" rendermode="{rendermode=normal}" noclick="1"/>
				<image ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/store2/checkbox/{texture=cb}x.png', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" visible="{checked}" rendermode="{rendermode=normal}" noclick="1"/>
			</panel>
			<label width="-{size}" height="100%" textvalign="center" font="{font=dyn_12}" color="{color=#a4806f}" outline="{outline=0}" outlinecolor="{outlinecolor=#241410}" onshowlua="{onlabelshowlua}">{label}</label>
		</widgetstate>
	</template>

	<!-- v2 accepts cvars that are declared in the UI (by skipping the cvar property of buttons and doing the work manually)  -->
	<template name="form_checkbox2">
		<panel x="{x=}" width="{width=100%}" height="{height=3h}" align="{align=}" valign="{valign=}" color="invisible" onload="{onpreload=}" visible="{visible=1}" noclick="1">
			<button
				x="-0.5h"
				color="invisible"
				numstates="2"
				onclick="
					If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));
					If(
						!StringEmpty('{cvar=}'),
						If(
							VarExists('{cvar=}'),
							If(
								{cvar=true},
								Split(
									Set('{cvar=}', false),
									SetButtonState(0)
								),
								Split(
									Set('{cvar=}', true),
									SetButtonState(1)
								)
							)
						)
					);
					If(
						!StringEmpty('{updatetrigger=}'),
						Trigger('{updatetrigger=}')
					);
					PlaySound('/shared/sounds/ui/button_click_06.wav'); {onclick=}
				"
				onmouseover="If(!StringEmpty('{tip_id}'), ShowWidget('{tip_id}')); PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				onmouseout="If(!StringEmpty('{tip_id}'), HideWidget('{tip_id}'));"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onload="{onload=}"
				name="{checkbox_name=}"
				group="{checkbox_group=}"
				oninstantiate="{oninstantiate=}"
				onhidelua="{onhidelua=}"
			>
				<instance name="{state_template=paperform_checkbox_state}" state="up" size="{height=3h}" label="{label}" font="{font=dyn_12}" color="{color}" outline="{outline}" outlinecolor="{outlinecolor}" texture="cb" checked="0" onlabelshowlua="{onlabelshowlua}"/>
				<instance name="{state_template=paperform_checkbox_state}" state="over" size="{height=3h}" label="{label}" font="{font=dyn_12}" outline="{outline}" outlinecolor="{outlinecolor}" texture="cbover" color="#9d5b1a" checked="0"/>
				<instance name="{state_template=paperform_checkbox_state}" state="down" size="{height=3h}" label="{label}" font="{font=dyn_12}" color="{color}" outline="{outline}" outlinecolor="{outlinecolor}" texture="cbover" checked="0" onlabelshowlua="{onlabelshowlua}"/>
				<instance name="{state_template=paperform_checkbox_state}" state="disabled" size="{height=3h}" label="{label}" font="{font=dyn_12}" outline="{outline}" outlinecolor="black" texture="cb" rendermode="grayscale" color="#4c3226" checked="0"/>

				<instance name="{state_template=paperform_checkbox_state}" state="up2" size="{height=3h}" label="{label}" font="{font=dyn_12}" color="{color}" outline="{outline}" outlinecolor="{outlinecolor}" texture="cb" checked="1" onlabelshowlua="{onlabelshowlua}"/>
				<instance name="{state_template=paperform_checkbox_state}" state="over2" size="{height=3h}" label="{label}" font="{font=dyn_12}" outline="{outline}" outlinecolor="{outlinecolor}" texture="cbover" color="#9d5b1a" checked="1"/>
				<instance name="{state_template=paperform_checkbox_state}" state="down2" size="{height=3h}" label="{label}" font="{font=dyn_12}" color="{color}" outline="{outline}" outlinecolor="{outlinecolor}" texture="cbover" checked="1" onlabelshowlua="{onlabelshowlua}"/>
				<instance name="{state_template=paperform_checkbox_state}" state="disabled2" size="{height=3h}" label="{label}" font="{font=dyn_12}" outline="{outline}" outlinecolor="black" texture="cb" rendermode="grayscale" color="#4c3226" checked="1"/>
			</button>
		</panel>
	</template>

	<!-- ============================= SHOPKEEPER AND ACTIONS =============================  -->
	<template name="shopkeeper">
		<panel name="shopkeeper" x="{x=0}" y="{y=89h}" width="122.4h" height="6h" align="center" noclick="1">
			<!-- replaced with Miku copyright -->
			<panel align="center" valign="top" height="20i" y="25i" float="right" padding="0i" noclick="1" onloadlua="self:SetVisible(not isNewUI())">
				<panel name="shopkeepr_shop" noclick="1" visible="1">
					<label textalign="center" content="shopkeeper_label" font="dyn_12" color="#714e43" outline="0" outlinecolor="#000000"/>
				</panel>
				<panel name="shopkeepr_vault" noclick="1" visible="0">
					<label textalign="center" content="shopkeeper_label" font="dyn_12" color="#b8d7ca" outline="0" outlinecolor="#000000"/>
				</panel>
			</panel>
			
			<!-- <panel align="center" valign="top" height="20i" y="25i" noclick="1">
				<panel name="shopkeepr_shop" noclick="1" visible="1" align="center" float="right" grow="1" padding="10i" >
					<label textvalign="center" content="shopkeeper_miku_copyright" font="dyn_12" color="#714e43" outline="0" outlinecolor="#000000" fitx="1" />
					<image texture="/ui/fe2/elements/store2/miku_cp1.png" width="64i" height="16i" valign="center"/>
				</panel>
				<panel name="shopkeepr_vault" noclick="1" visible="0" align="center" float="right" grow="1" padding="10i" >
					<label textvalign="center" content="shopkeeper_miku_copyright" font="dyn_12" color="#717f7a" outline="0" outlinecolor="#000000" fitx="1"/>
					<image texture="/ui/fe2/elements/store2/miku_cp2.png" width="64i" height="16i" valign="center"/>
				</panel>
				<image texture="/ui/fe2/elements/store2/miku_cp0.png" width="128i" height="64i" valign="center" align="right" />
			</panel> -->

			<!-- Goblin: His panel needs to be somewhat large so he has a lot of breathing room -->
			<panel x="-10h" y="0h" valign="bottom" width="40h" height="25h" noclick="1" onloadlua="if isNewUI() then self:SetY('40i') end">
				<modelpanel
					watch9="MainRegisterModels"
					ontrigger9lua="ResourceManager.RegisterModel('/ui/fe2/store/goblin/model.mdf', 'store', self)"
					modelscale=".87"
					resourcecontext="store"
					anim="idle"
					name="shopkeeper_model"
					camerapos="0 -128 25"
					cameraangles="0 0 0"
					modelangles="0 0 180"
					camerafov="25"
					cameranear="1"
					carmerafar="100"
					depthclear="true"
					depthcompress="true"
					sunazimuth="157.06"
					sunaltitude="22.05"
					suncolor=".49 .49 .49"
					ambientcolor="1.34 1.34 1.34"
					scenebuffer="1"
					noclick="1"
				/>
				
				<panel x="10h" y="12h" width="12h" height="14h" noclick="1">
					<button color="invisible"
						name="shopkeeper_model_action"
						onclick="
							Trigger('ShopkeeperAction', 16);
						"
						onclicklua="
							HoN_Store:OnClickShopkeeper()
						"
						onload="
							CreateBool('_microStore_shopkeeper_canIdle', false);
							CreateInt('_microStore_shopkeeperIdleAnim');
						"
						watch="MicroStoreProcessing"
						ontrigger="SetEnabled(!param0);"
						watch1="ShopkeeperIdleRoutine"
						ontrigger1="
							Set('_microStore_shopkeeper_canIdle', true);
							SleepWidget(param1, 'CallEventParamsX(\'shopkeeper_model_action\', 1, '# param0 #');');
						"
						onevent0="
							Set('_microStore_shopkeeper_canIdle', true);
							SleepWidget(180000, 'DoEvent(1);');
						"
						onevent1="
							If(
								_microStore_shopkeeper_canIdle and IsVisible('shopkeeper_model') and !_dancingIsForbidden,
								Split(
									Trigger('ShopkeeperAction', param0),
									If(
										param0 == 5,
										Set('_microStore_shopkeeper_canIdle', false),
										Trigger('ShopkeeperIdleRoutine', 5, 180000)
									)
								)
							);
						"
						onevent2="Set('_microStore_shopkeeper_canIdle', false);"
					>
						<widgetstate statename="up"><panel/></widgetstate>
						<widgetstate statename="over"><panel/></widgetstate>
						<widgetstate statename="down"><panel/></widgetstate>
						<widgetstate statename="disabled"><panel/></widgetstate>
					</button>
					<image texture="/ui/fe2/elements/store2/gulinmask.png" x="12h" align="center" valign="bottom" width="128i" height="64i" noclick="1"/>
				</panel>
			</panel>
		</panel>
	</template>

	<trigger name="ShopkeeperAction"/>
	<trigger name="ShopkeeperIdleRoutine"/><!-- anim number, delay -->

	<panel noclick="1" color="invisible"
		watch="ShopkeeperAction"
		ontrigger="
			If( param0 == 1, Trigger( 'ShopkeeperAnimation', 1 ) );
			If( param0 == 2, Trigger( 'ShopkeeperAnimation', 2 ) );
			If( param0 == 3, Trigger( 'ShopkeeperAnimation', 3 ) );
			If( param0 == 4, Trigger( 'ShopkeeperAnimation', Rand(4, 6) ) );
			If( param0 == 5, Trigger( 'ShopkeeperAnimation', 7 ) );
			If( param0 == 6, Trigger( 'ShopkeeperAnimation', Rand(8, 9) ) );
			If( param0 == 7, Trigger( 'ShopkeeperAnimation', Rand(10, 11) ) );
			If( param0 == 8, Trigger( 'ShopkeeperAnimation', 12 ) );
			If( param0 == 9, Trigger( 'ShopkeeperAnimation', Rand(13, 14) ) );
			If( param0 == 10, Trigger( 'ShopkeeperAnimation', Rand(15, 16) ) );
			If( param0 == 11, Trigger( 'ShopkeeperAnimation', Rand(17, 18) ) );
			If( param0 == 12, Trigger( 'ShopkeeperAnimation', Rand(19, 20) ) );
			If( param0 == 13, Trigger( 'ShopkeeperAnimation', 21 ) );
			If( param0 == 14, Trigger( 'ShopkeeperAnimation', 22 ) );
			If( param0 == 15, Trigger( 'ShopkeeperAnimation', Rand(23, 24) ) );
			If( param0 == 16, Trigger( 'ShopkeeperAnimation', Rand(25, 26) ) );
			If( param0 == 18, Trigger( 'ShopkeeperAnimation', 9 ) );

			If(
				param0 == 19,
				Set('_microStore_tempInt', Rand(1, 2))
			);

			If(
				param0 == 19,
				Split(
					If(_microStore_tempInt == 1, Trigger( 'ShopkeeperAnimation', 22 )),
					If(_microStore_tempInt == 2, Trigger( 'ShopkeeperAnimation', 24 ))
				)
			);

			If(
				param0 == 20,
				Set('_microStore_tempInt', Rand(1, 3))
			);

			If(
				param0 == 20,
				Split(
					If(_microStore_tempInt == 1, Trigger( 'ShopkeeperAnimation', 19 )),
					If(_microStore_tempInt == 2, Trigger( 'ShopkeeperAnimation', 20 )),
					If(_microStore_tempInt == 3, Trigger( 'ShopkeeperAnimation', 23 ))
				)
			);
			If( param0 == 21, Trigger( 'ShopkeeperAnimation', 14 ) );

			## Mulligan Shopkeeper ##
			##
			If( param0 == 31, Trigger( 'ShopkeeperAnimation', Rand(31, 31) ) );
			If( param0 == 32, Trigger( 'ShopkeeperAnimation', Rand(32, 32) ) );
			If( param0 == 33, Trigger( 'ShopkeeperAnimation', Rand(33, 33) ) );
			##

			If( param0 == 41, Trigger( 'ShopkeeperAnimation', Rand(17, 18) ) );
			If( param0 == 42, Trigger( 'ShopkeeperAnimation', 16 ) );
			If( param0 == 43, Trigger( 'ShopkeeperAnimation', 15 ) );
			If( param0 == 44, Trigger( 'ShopkeeperAnimation', 13 ) );
			If( param0 == 45, Trigger( 'ShopkeeperAnimation', 14 ) );
	"/>

	<trigger name="ShopkeeperAnimation"/>
	<panel noclick="1" color="invisible"
		onload="
			CreateInt('Shopkeeper_LastAnimTime', GetTime());
			CreateInt('Shopkeeper_LastAnimDuration', -1);
			CreateInt('Shopkeeper_LastAction', -1);
			CreateBool('Shopkeeper_LastActionCanSkip', false);
			CreateBool('Shopkeeper_ActionsEnabled', true);
		"
	/>

	<template name="ShopkeeperAnimationHelper">
		<panel noclick="1" color="invisible" watch="ShopkeeperAnimation"
			ontrigger="
				If(
					{ActionID} == param0 and Shopkeeper_ActionsEnabled and
					(
						(Shopkeeper_LastAnimTime + Shopkeeper_LastAnimDuration) lt GetTime()
						or
						Shopkeeper_LastActionCanSkip
					),
					Split(
						StopSound(2),
						Call('{shopkeeper=shopkeeper_model}', 'SetAnim(\'{AnimName}\');'),
						PlaySound('{SoundPath}', 1, 2)
					)
				);
			"
		/>
	</template>

	<!-- Welcome to shop... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="1" AnimName="first_time_1" SoundPath="/ui/fe2/store/goblin/voice/first_time_1.mp3" Duration=""/>
	<!-- Before you can buy, exchange money for coins... first time, special offers -->
	<instance name="ShopkeeperAnimationHelper" ActionID="2" AnimName="first_time_2" SoundPath="/ui/fe2/store/goblin/voice/first_time_2.mp3" Duration=""/>
	<!-- See you again soon -->
	<instance name="ShopkeeperAnimationHelper" ActionID="3" AnimName="goodbye" SoundPath="/ui/fe2/store/goblin/voice/goodbye.mp3" Duration=""/>
	<!-- Welcome back, what can I interest you in? -->
	<instance name="ShopkeeperAnimationHelper" ActionID="4" AnimName="enter_1" SoundPath="/ui/fe2/store/goblin/voice/enter_1.mp3" Duration=""/>
	<!-- Come in, come in! --> 
	<instance name="ShopkeeperAnimationHelper" ActionID="5" AnimName="enter_2" SoundPath="/ui/fe2/store/goblin/voice/enter_2.mp3" Duration=""/>
	<!-- Ah, it's you again.  What can I do for you? -->
	<instance name="ShopkeeperAnimationHelper" ActionID="6" AnimName="enter_3" SoundPath="/ui/fe2/store/goblin/voice/enter_3.mp3" Duration=""/>
	<!-- Humming and wandering around... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="7" AnimName="browsing" SoundPath="" Duration=""/>
	<!-- Let's go check your storage... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="9" AnimName="check_storage" SoundPath="/ui/fe2/store/goblin/voice/check_storage.mp3" Duration=""/>
	<!-- There you are.  I just got a new shipment in ... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="10" AnimName="first_entrance_after_patch_1" SoundPath="/ui/fe2/store/goblin/voice/first_entrance_after_patch_1.mp3" Duration=""/>
	<!-- I've been waiting for you, take a look at the new items... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="11" AnimName="first_entrance_after_patch_2" SoundPath="/ui/fe2/store/goblin/voice/first_entrance_after_patch_2.mp3" Duration=""/>
	<!-- I've just put some new items up for sale... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="12" AnimName="congratulations" SoundPath="/ui/fe2/store/goblin/voice/congratulations.mp3" Duration=""/>
	<!-- Smart shopper -->
	<instance name="ShopkeeperAnimationHelper" ActionID="13" AnimName="point_purchase_1" SoundPath="/ui/fe2/store/goblin/voice/point_purchase_1.mp3" Duration=""/>
	<!-- Only the best -->
	<instance name="ShopkeeperAnimationHelper" ActionID="14" AnimName="point_purchase_2" SoundPath="/ui/fe2/store/goblin/voice/point_purchase_2.mp3" Duration=""/>
	<!-- Good deal... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="15" AnimName="point_purchase_3" SoundPath="/ui/fe2/store/goblin/voice/point_purchase_3.mp3" Duration=""/>
	<!-- Better deals... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="16" AnimName="point_purchase_4" SoundPath="/ui/fe2/store/goblin/voice/point_purchase_4.mp3" Duration=""/>
	<!-- Fine and all, consider better deals... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="17" AnimName="point_purchase_5" SoundPath="/ui/fe2/store/goblin/voice/point_purchase_5.mp3" Duration=""/>
	<!-- Other packages come with extra coins... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="18" AnimName="point_purchase_6" SoundPath="/ui/fe2/store/goblin/voice/point_purchase_6.mp3" Duration=""/>
	<!-- Never pass up a good deal -->
	<instance name="ShopkeeperAnimationHelper" ActionID="19" AnimName="purchasing_1" SoundPath="/ui/fe2/store/goblin/voice/purchasing_1.mp3" Duration=""/>
	<!-- Purchase you'll never regret -->
	<instance name="ShopkeeperAnimationHelper" ActionID="20" AnimName="purchasing_2" SoundPath="/ui/fe2/store/goblin/voice/purchasing_2.mp3" Duration=""/>
	<!-- Certain? Take a look at these... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="21" AnimName="purchasing_3" SoundPath="/ui/fe2/store/goblin/voice/purchasing_3.mp3" Duration=""/>
	<!-- Good buy indeed... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="22" AnimName="purchasing_4" SoundPath="/ui/fe2/store/goblin/voice/purchasing_4.mp3" Duration=""/>
	<!-- Lucky while still on sale... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="23" AnimName="purchasing_5" SoundPath="/ui/fe2/store/goblin/voice/purchasing_5.mp3" Duration=""/>
	<!-- Pleasure doing business (and receives coins visually) -->
	<instance name="ShopkeeperAnimationHelper" ActionID="24" AnimName="purchasing_6" SoundPath="/ui/fe2/store/goblin/voice/purchasing_6.mp3" Duration=""/>
	<!-- Most valued customers, I'll give you recommendations... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="25" AnimName="purchasing_7" SoundPath="/ui/fe2/store/goblin/voice/purchasing_7.mp3" Duration=""/>
	<!-- Twisted my arm, show one of the best deals right now... -->
	<instance name="ShopkeeperAnimationHelper" ActionID="26" AnimName="purchasing_8" SoundPath="/ui/fe2/store/goblin/voice/purchasing_8.mp3" Duration=""/>

	<template name="storeMiscOverlays">
		<panel name="store_popup_container" visible="0" noclick="1" onshowlua="self:SetY(isNewUI() and '-3.5h' or '0')">
			<!-- Has to be lowest popup (not even really a popup, but alas!) -->
			<instance name="plankWindow" width="95h" id="buy_coins" title="mstore_buycoins_form_title" content="storePopupBuyCoinsForm" show_close="1" debug="false"
				onshow="
					Trigger('MicroStoreUpdatePackages');
					Trigger('ShopkeeperAction', 21);
					Call('buy_coins_forfriend', 'SetSelectedItemByValue(1);');
				"
				onhide="
					If(
						_microStoreFirstVisit, CallEvent('store_container2', 2),
						If(
							!IsVisible(_microStoreViewPanel1) and
							!IsVisible(_microStoreViewPanel2) and
							!IsVisible(_microStoreViewPanel3) and
							!IsVisible(_microStoreViewPanel4) and
							!IsVisible(_microStoreViewPanel5) and
							!IsVisible(_microStoreViewPanel6) and
							!IsVisible('store_promo'),
							Split(
								Set('_microStore_RequestCode', 0),
								Set('_microStore_Category', -1),
								CallEvent('MicroStoreAction', 0)
							)
						)
					);
				"
			/>
			<instance name="plankWindow" width="35h" id="voice_preview" title="mstore_voicepreview" content="storePopupVoicePreview" show_close="1" debug="0" regrow="1" titlewatch="MicroStoreVoicePreview" titleontrigger="SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_name'));"/>
			<instance name="plankWindow" width="53h" id="confirm_purchase_choose" title="mstore_buyitem_confirm" content="storePopupConfirmPurchaseChoose" show_close="1" debug="0" regrow="1" onhide="Call('mstore_confirmpurchase_altbundlebox', 'SetButtonState(0);');"/>
			<instance name="plankWindow" width="53h" id="confirm_purchase_gift"   title="mstore_buygift_confirm" content="storePopupConfirmGiftChoose" show_close="1" debug="0" regrow="1" onhide="" noclick="0" onclicklua="Trigger('ChatAutoCompleteClear')"/>
			<instance name="plankWindow" width="50h" id="firstvisit1" title="mstore_firstvisit1" content="storePopupFirstVisit1" show_close="false" debug="0" onshow="Trigger('ShopkeeperAction', 1);"/>
			<instance name="plankWindow" width="35h" id="form_error" title="mstore_error_generic" content="storePopupFormError" show_close="1" debug="0" regrow="1"/>
			<instance name="plankWindow" width="35h" id="error" title="mstore_error_generic" content="storePopupError" show_close="1" debug="0" regrow="1"/>
			<instance name="plankWindow" width="50h" id="buy_coin_friend_success" title="mstore_buycoin_friend_success" content="storePopupBuyCoinFriendSuccess" show_close="1" debug="0" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="buy_coin_success_account" title="mstore_buycoin_success" content="storePopupBuyCoinSuccessAccount" show_close="1" debug="0" onshow="PlaySound('/ui/fe2/store/sounds/coin_jingle_4.wav');" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="buy_coin_success_upgrade" title="mstore_buycoin_success" content="storePopupBuyCoinSuccessUpgrade" show_close="1" debug="0" onshow="PlaySound('/ui/fe2/store/sounds/coin_jingle_4.wav');" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="buy_coin_success" title="mstore_buycoin_success" content="storePopupBuyCoinSuccess" show_close="1" debug="0" onshow="PlaySound('/ui/fe2/store/sounds/coin_jingle_4.wav');" onhide="CallEvent('microStoreProcessResponse', 0);"/>
			<instance name="plankWindow" width="50h" id="resetstats_success" title="web_form_resetstats_success_title" content="storePopupResetStatsSuccess" show_close="1" debug="0" 
				onshow="If( _microStore_RequestCode != 2, Set('_microStore_RequestCode', 1) ); CallEvent('MicroStoreAction', 0);"/>
			<instance name="plankWindow" width="50h" id="namechange_success" title="web_form_nickchange_success_title" content="storePopupNameChangeSuccess" show_close="1" debug="0" 
				onshow="If( _microStore_RequestCode != 2, Set('_microStore_RequestCode', 1) ); CallEvent('MicroStoreAction', 0);" 
				onshowlua="HoN_Store:Store2OnItemUsed('namechange')"/>
			<instance name="plankWindow" width="50h" id="SubAccount_success" title="web_form_subaccount_success_title" content="storePopupSubAccountSuccess" show_close="1" debug="0" 
				onshow="If( _microStore_RequestCode != 2, Set('_microStore_RequestCode', 1) ); CallEvent('MicroStoreAction', 0);" 
				onshowlua="HoN_Store:Store2OnItemUsed('subaccount')"/>
			<instance name="plankWindow" width="50h" id="selectupgrade_success" title="mstore_selectupgrade_success" content="storePopupSelectUpgradeSuccess" show_close="1" debug="0"/>
			<instance name="plankWindow" width="50h" id="buy_item_success" title="mstore_buyitem_success" content="storePopupBuyItemSuccess" show_close="1" debug="0"
				onshow="PlaySound('/ui/fe2/store/sounds/chaching.wav');"
				onhide="CallEvent('microStoreProcessResponse', 0);"
				onhidelua="
					if(NotEmpty(GetCvarString('microStoreDiscountInfo'))) then
						UIManager.GetInterface('main'):HoNStoreF('DisplayAvatarList')
					end
				"
			/>
			<instance name="plankWindow" width="40h" id="buyavatar_needhero" title="mstore_buyavatar_needhero" content="storePopupBuyAvatarNeedHero" show_close="1" debug="0"/>
			<instance name="plankWindow" width="49.5h" id="redeem_code" title="mstore_redeem_code" content="storePopupRedeemCodeForm" show_close="1" debug="0" onhide="Cmd('script trackedUserFocus:closeRedeemCode()');"/>
			<instance name="plankWindow" width="40h" id="buyfeatured_ownedproduct" title="mstore_featured_owned_header" content="storePopupBuyFeaturedOwnedProduct" show_close="1" debug="0"/>

			<!-- Gotta be here so he's not covered up by the darkened background on popups -->
			<panel name="shopkeeperContainer" width="124.8h" align="center" noclick="1">
				<instance name="shopkeeper"/>
			</panel>

			<panel name="store_grab_bag_container" height="50h" width="178h" align="center" noclick="1"/>
		</panel>
	</template>

	<!-- lat versions, they have 4 choices, tweaked dupes of the NA/EU ones -->
	<!-- $5 -->
	<template name="paperform_radiobutton_5_state1_lat">
		<panel width="12.165h">
			<!-- Non Button Area -->
			<panel height="-3h">
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#836352" borderthickness="0.5h"/>
				<!-- Selected BG Color -->
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#cd8b0f" borderthickness="0.5h" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );"/>
				<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
				<!-- Package Amount -->
				<panel height="3.0h">
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#4f1b02" borderthickness="0.5h"/>
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
					<panel grow="true" height="74%" valign="center" align="center" float="right" padding="0.5h">
						<label fitx="true" height="100%" font="dyn_14" textvalign="center" color="1 1 1 1" outline="true" content="---" watch="MicroStoreUpdatePackages" ontrigger="SetText(microStorePackageCoins1);"/>
						<image height="100%" width="100@" valign="center" texture="/ui/fe2/store/gold_coins.tga"/>
					</panel>
				</panel>
				<!-- Package Contents -->
				<panel height="-6.0h" valign="center" clip="true">

					<!-- Selected Glow -->
					<image width="100%" height="100@" align="center" valign="center" noclick="1" texture="/ui/fe2/store/grad_glow3.tga" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/grad_glow3.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="#fff000" rendermode="additive" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );"/>
					<!-- Package Image(s) -->
					<image height="100@" width="100%" valign="center" align="center" noclick="1" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coinstack_sml.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"
						watch="MicroStoreUpdatePackages" ontrigger="If(!StringEmpty(microStorePackageTextures1), SetTexture(microStorePackageTextures1), SetTexture('/ui/fe2/store/coinstack_sml.tga'));"
					/>
					<image height="20%" width="100@" valign="bottom" texture="/ui/fe2/store/package_grad.tga" color="0 0 0 .5"/>
					<image height="10%" width="100@" valign="top" vflip="true" texture="/ui/fe2/store/package_grad.tga" color="0 0 0 .3"/>

					<!-- Bonus % -->
					<label textalign="center" textvalign="center" valign="bottom" height="2.0h" font="dyn_12" color="1 1 1 1" shadow="true" group="coinBundleBonusPercent1"/>
				</panel>
				<!-- Package Cost -->
				<panel height="3.0h" valign="bottom">
					<frame texture="/ui/frames/rounded_bg_white.tga" color="#4f1b02" borderthickness="0.5h"/>
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
					<label height="100%" font="dyn_10" textvalign="center" textalign="center" color="1 1 1 1" outline="true" content="---" watch="MicroStoreUpdatePackages" ontrigger="SetText(ceil(microStorePackagePrice1) # ' ' # Translate(ui_useRegionalCurrencyName));"/>
				</panel>
			</panel>

			<!-- Select Button -->
			<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up') or StringEquals('{state}', 'over') or StringEquals('{state}', 'down') ); If(StringEquals('{state}', 'down'), Split(SetX(1), SetY(1)));">
				<instance name="store2Button" y="0.5h" width="8.5h" height="3.25h" imgwidth="128i" texture="button1" font="dyn_10" align="center" valign="center" label="mstore_choose"/>
			</panel>

			<!-- Selected Text -->
			<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );">
				<label textalign="center" textvalign="center" font="dyn_10" style="microStorePaperTitle" content="mstore_package_selected"/>
			</panel>

		</panel>
	</template>

