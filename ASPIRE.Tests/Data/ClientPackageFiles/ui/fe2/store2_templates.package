						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="0 1 0 1" font="dyn_10" watch="MicroStoreUpdatePackages" content="mstore_bonuscoins"/>
					</panel>
					<panel y="5.15h" color="0 0 0 0.75" height="2.25h" visible="false" group="coinBundleBonusCoinsVisible3">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="#FFCC00" font="dyn_9" group="coinBundleBonusString3"/>
					</panel>

					<panel valign="bottom" color="#392407" height="3h">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="white" font="dyn_16" watch="MicroStoreUpdatePackages" ontrigger="SetText(ceil(microStorePackagePrice3) # ' ' # Translate(ui_useRegionalCurrencyName));"/>
					</panel>
				</panel>
				<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up') or StringEquals('{state}', 'over') or StringEquals('{state}', 'down') ); If(StringEquals('{state}', 'down'), Split(SetX(1), SetY(1)));">
					<instance name="store2Button" y="0.5h" width="8.5h" height="3.25h" imgwidth="128i" texture="button1" font="dyn_10" align="center" valign="center" label="mstore_choose"/>
				</panel>
				<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );">
					<label textalign="center" textvalign="center" font="dyn_10" style="microStorePaperTitle" content="mstore_package_selected"/>
				</panel>

			</panel>
		</panel>
	</template>

	<template name="paperform_radiobutton_state3_promo">
		<panel width="23.25h">
			<panel width="21.25h" align="center">
				<panel height="-3h">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#5b480d88"
						oninstantiate="
							If(
								StringEquals('{state}', 'up2') or
								StringEquals('{state}', 'over2') or
								StringEquals('{state}', 'down2'),
								SetColor('#5b480d33')
							);
						"/>
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
					<image width="100%" height="100@" align="center" valign="center" noclick="1" texture="/ui/fe2/store/grad_glow3.tga" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/grad_glow3.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="#fff000" rendermode="additive" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );"/>
					<image width="85@" height="85%" align="center" valign="center" noclick="1" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/promo_free_gunblade.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"
						watch="MicroStoreUpdatePackages" ontrigger="If(!StringEmpty(microStorePackageTextures3), SetTexture(microStorePackageTextures3), SetTexture('/ui/fe2/store/promo_free_gunblade.tga'));"
					/>
					<frame texture="/ui/frames/squareglow.tga" borderthickness="1h" color="#f4d60d66" width="7h" height="3.5h" y="-1.6h" align="center" valign="center"/>
					<label y="-1.6h" x="-0.15h" textalign="center" textvalign="center" noclick="1" color="0 0 0 1" outline="true" outlinecolor="#ffc600" font="dyn_16" watch="MicroStoreUpdatePackages" ontrigger="SetText(microStorePackageCoins3);"/>
					<panel height="3h">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#4d310a" noclick="1"/>
						<panel height="1h" valign="bottom" color="#392407" noclick="1"/>
						<panel valign="bottom" height="0.1h" color="#7d4711" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="white" font="dyn_16" watch="MicroStoreUpdatePackages" ontrigger="SetText(Translate('mstore_coinamount', 'coins', microStorePackageCoins3));"/>
					</panel>

					<panel y="-3h" valign="bottom" color="0 0 0 0.75" height="2.25h" watch="MicroStoreUpdatePackages" visible="false" ontrigger="SetVisible(microStorePackageSpecial3);">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="0 1 0 1" font="dyn_10" content="mstore_specialoffer"/>
					</panel>

					<panel y="3h" color="0 0 0 0.75" height="2.25h" visible="false" group="coinBundleBonusCoinsVisible3">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="0 1 0 1" font="dyn_10" watch="MicroStoreUpdatePackages" content="mstore_bonuscoins"/>
					</panel>
					<panel y="5.15h" color="0 0 0 0.75" height="2.25h" visible="false" group="coinBundleBonusCoinsVisible3">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="#FFCC00" font="dyn_9" group="coinBundleBonusString3"/>
					</panel>

					<panel valign="bottom" color="#392407" height="3h">
						<frame color="invisible" bordercolor="#9d5b1a" borderthickness="0.1h" noclick="1"/>
						<label textalign="center" textvalign="center" noclick="1" shadow="true" color="white" font="dyn_16" watch="MicroStoreUpdatePackages" ontrigger="SetText(ceil(microStorePackagePrice3) # ' ' # Translate(ui_useRegionalCurrencyName));"/>
					</panel>
				</panel>
				<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up') or StringEquals('{state}', 'over') or StringEquals('{state}', 'down') ); If(StringEquals('{state}', 'down'), Split(SetX(1), SetY(1)));">
					<instance name="store2Button" y="0.5h" width="8.5h" height="3.25h" imgwidth="128i" texture="button1" font="dyn_10" align="center" valign="center" label="mstore_choose"/>
				</panel>
				<panel height="3h" valign="bottom" oninstantiate="SetVisible( StringEquals('{state}', 'up2') or StringEquals('{state}', 'over2') or StringEquals('{state}', 'down2') );">
					<label textalign="center" textvalign="center" font="dyn_10" style="microStorePaperTitle" content="mstore_package_selected"/>
				</panel>

			</panel>
		</panel>
	</template>

	<!-- ============================= STORE-SPECIFIC FUNCTIONALITY =============================  -->

	<template name="storeItemDataContainer">
		<panel noclick="true" color="invisible" group="storeItemDataContainers" name="storeItemDataContainer{index}"
			   onload="
				DoEvent(0);
			"
			   watch=""
			   ontrigger=""
			   onevent0="
				CreateInt('microStoreID{index}', -1);
				CreateString('microStoreName{index}', '-1');
				CreateString('microStoreDescription{index}', '-1');
				CreateString('microStoreWebContent{index}', '-1');
				CreateString('microStoreLocalContent{index}', '-1');
				CreateBool('microStoreBundle{index}', false);
				CreateBool('microStorePurchasable{index}', true);
				CreateString('microStoreCharges{index}', '-1~-1~-1~-1~-1~-1~-1');
				CreateString('microStoreDurations{index}', '-1~-1~-1~-1~-1~-1~-1');
				CreateBool('microStoreAlreadyOwned{index}', false);
				CreateInt('microStorePrice{index}', -1);
				CreateInt('microStoreSilverPrice{index}', -1);
				CreateBool('microStorePremium{index}', false);
				CreateInt('microStoreQuantity{index}', -1);
				CreateString('microStoreCode{index}', -1);
				CreateString('microStoreChargeRemaining{index}', -1);
				CreateString('microStoreSubBundles{index}', '-1~-1~-1~-1~-1');
				CreateInt('microStoreSpecialDisplay{index}', '-1');
			"
		/>
	</template>

	<instance name="storeItemDataContainer" index="1"/>
	<instance name="storeItemDataContainer" index="2"/>
	<instance name="storeItemDataContainer" index="3"/>
	<instance name="storeItemDataContainer" index="4"/>
	<instance name="storeItemDataContainer" index="5"/>
	<instance name="storeItemDataContainer" index="6"/>
	<instance name="storeItemDataContainer" index="7"/>
	<instance name="storeItemDataContainer" index="8"/>
	<instance name="storeItemDataContainer" index="9"/>
	<instance name="storeItemDataContainer" index="10"/>
	<instance name="storeItemDataContainer" index="11"/>
	<instance name="storeItemDataContainer" index="12"/>
	<instance name="storeItemDataContainer" index="13"/>
	<instance name="storeItemDataContainer" index="14"/>
	<instance name="storeItemDataContainer" index="15"/>
	<instance name="storeItemDataContainer" index="16"/>
	<instance name="storeItemDataContainer" index="17"/>
	<instance name="storeItemDataContainer" index="18"/>
	<instance name="storeItemDataContainer" index="19"/>
	<instance name="storeItemDataContainer" index="20"/>
	<instance name="storeItemDataContainer" index="21"/>
	<instance name="storeItemDataContainer" index="22"/>
	<instance name="storeItemDataContainer" index="23"/>
	<instance name="storeItemDataContainer" index="24"/>
	<instance name="storeItemDataContainer" index="999"/><!-- Just a dummy slot for use in popups/etc. -->

	<!-- ============================= STORE-GIFT FRIENDS FUNCTIONALITY =============================  -->

	<template name="store2_autocomplete_list">
		<panel name="store2_{listbox_name}_panel" y="{y=0}" x="{x=0}" width="{width=-1.0h}" height="{height=-1.0h}" align="{align=center}" valign="{valign=center}">
			<instance name="store2_frame"/>
			<listbox
					name="store2_{listbox_name}_listbox"
					width="-2.25h"
					color="invisible"
					font="dyn_10"
					itemwidth="100%"
					itemheight="3h"
					select="true"
					clearselection="true"
					hoverselect="true"
					hoverhighlight="true"
					highlight="under"
					highlightcolor="#cda5963b"
					highlightbordercolor="invisible"
					selectedcolor="#cda5963b"
					selectedbordercolor="invisible"
					colortransition="true"
					colortransitiontime="250"
					usescrollbars="{usescrollbars=true}"
					exteriorscrollbars="true"
					scrollbarplaceholder="true"
					scrollbarsize="2.0h"
					scrolltexture="/ui/fe2/elements/store2/combobox/combobox.png"
					handleheight="2.0h"
					itemoffsetx="5i"
					onclick="{onclick}"
					ondoubleclick="{ondoubleclick}"
					onselect="Set('ui_lastSelectedUser', this); Call(ui_autocompleteTextBox, 'SetInputLine(ui_lastSelectedUser);'); ChatAutoCompleteClear();"
					onloadlua="
						self:UnregisterWatch('ChatAutoCompleteAdd')
						self:UnregisterWatch('ChatAutoCompleteClear')
					"
			/>
		</panel>
	</template>

	<template name="store2_autocomplete_player">
		<label width="-1.6h" textvalign="center" textalign="left" align="center" valign="center" font="dyn_9" color="#774515" content="{username}" shadow="1" wrap="0" />
	</template>

	<!-- ============================= STORE-COUPON FUNCTIONALITY =============================  -->
	<template name="Store2_CardListControl">
		<panel name="Store2_CardListControl_{surffix}" y="{y}" width="{width}" height="{height}"  sticky="{sticky}" stickytoinvis="{stickytoinvis}">

			<panel name="Store2_CardListBack_{surffix}" align="center" valign="center" y="-6.8%" width="97%" height="92%" visible="{useframe=false}">
				<instance name="store2_frame"/>
			</panel>

			<listbox
					name="Store2_easy_CardListbox_{surffix}"
					x="2.5%"
					width="95%"
					visible="true"
					color="invisible"
					font="dyn_11"
					itemheight="{itemheight}"
					hoverselect="false"
					itemmultipleselection="true"
					hoverhighlight="true"
					highlight="under"
					highlightbordercolor="{highlightbordercolor}"
					highlightcolor="{highlightcolor}"
					selectedcolor="{selectedcolor}"
					selectedbordercolor="{selectedbordercolor}"
					backgroundimage="{backgroundimage}"
					backgroundimagecolor="{backgroundimagecolor}"
					scrolltexture="/ui/info/combobox.tga"
					colortransition="false"
					colortransitiontime="250"
					scrollbarsize="2h"
					handleheight="2h"
					onclick=""
					onevent=""
					onselectlua="{onselectlua}"
					onshow="{onshow}"
					onshowlua="{onshowlua}"
					watch="{watch}"
					ontrigger="{ontrigger}"
					ontriggerlua="{ontriggerlua}"
			/>
			<label y="{label_y}" name="Store2_easy_CardDesc_{surffix}" sticky="true" stickytoinvis="false" align="center" width="80%" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_10" color="{textcolor}" style="microStorePaperText"/>
		</panel>
	</template>

	<template name="Store2_Card_ListItem">
		<panel height="0.25h" color="{framecolor0}" />
		<panel y="100%" height="0.25h" color="{framecolor0}" />
		<panel x="-0.25%" width="0.5%" height="105%" color="{framecolor0}" />
		<panel x="100%" height="105%" width="0.5%" color="{framecolor0}" />
		<panel x="70.6%" y="17.5%" width="0.2%" height="75%" color="{framecolor1}" />
		<panel x="70.8%" y="17.5%" width="0.2%" height="75%" color="{framecolor2}" />
		<label width="70%" font="dyn_10" color="{textcolor}" align="left" valign="center" textalign="center" textvalign="center" content="{name}" />
		<label x="71%" width="29%" font="dyn_10" color="{textcolor}" valign="center" textalign="center" textvalign="center" content="{discount}" />
	</template>
</package>
