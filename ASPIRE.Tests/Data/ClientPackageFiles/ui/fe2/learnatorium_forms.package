	<panel noclick="1" visible="1"
		onload="CreateBool('compendium_guide_auto_selection', 0); CreateBool('compendium_guide_usingLocal', 0);"
		watch0="compendium_guideListFormResult"
		ontrigger0="
			If(((compendium_guideListFormStatus == 2) and (compendium_guide_masterQueryTime == param2)) or compendium_usage_usingCache,
				Split(
					Call('compendium_guide_list', 'ClearItems();'),
					ExplodeTrigger('compendium_guideListFormResultExplode', param1, '`', '|')
				)
			);
		"		
		watch1="compendium_guideListFormResultExplode"
		ontrigger1="
			If((compendium_guideListFormStatus == 2 or compendium_usage_usingCache),				
				Call('compendium_guide_list', '
					AddTemplateListItem(\'compendium_guidelist_item\', '#param1#',
						\'index\', '#param0#',
						\'compendium_guideindex\', '#param1#',
						\'timestamp\',  \''#param2#'\',
						\'author\', \''#param3#'\',
						\'compendium_guidename\', \''#param4#'\',
						\'isdef\', '#StringEquals(param5, 'is_def')#',
						\'isfav\', '#StringEquals(param6, 'is_fav')#',				
						\'pop\', '#Round(param7*100)#',
						\'is_yours\', '#StringEquals(param8, 'is_yours')#',
						\'is_premium\', '#param9#'	
					);	
					If(StringEmpty(\'\'#this#\'\') and !compendium_guide_auto_selection and !compendium_guide_usingLocal,
						If(compendium_guide_selectedcompendium_guide != 99999 and 0 ## always 0 guide ##, 
							Trigger(\'compendium_guideLoadcompendium_guide\'),
							Split(
								SetSelectedItemByIndex(0),
								SleepWidget(10, \'									
									Set(compendium_guide_selectedcompendium_guide, this);
									Trigger(\\\'compendium_guideLoadcompendium_guide\\\');
									\'
								)
							)
						)
					);
				')			
			);
		"	
		
		watch2="compendium_guideListFormStatus"
		ontrigger2="If(param != 1, SleepWidget(250, 'Set(compendium_guide_auto_selection, 0)'));"
	/>	
	
