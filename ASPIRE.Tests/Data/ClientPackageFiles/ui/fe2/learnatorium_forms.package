	<!-- compendium_guide list -->
	<form		
		name="compendium_guideListForm"
		host="!masterserver"
		method="POST"
		target="/client_requester.php"
		statustrigger="compendium_guideListFormStatus"
		resulttrigger="compendium_guideListFormResult"
		resultparam0="errors"
		resultparam1="guide_list"
