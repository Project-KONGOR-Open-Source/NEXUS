	<trigger name="HeroStatsStatus" />
	<trigger name="HeroStatsResult" />
	<trigger name="CoNNormalHeroStatsStatus" />
	<trigger name="CoNNormalHeroStatsResult" />
	<trigger name="CoNCasualHeroStatsStatus" />
	<trigger name="CoNCasualHeroStatsResult" />
	<trigger name="HeroStatsLoadCache" />
	
	<panel name="hero_stats_submit_compendium" noclick="1" color="invisible"
		onload="CreateString('hero_stats_cache_string', ''); CreateString('compendium_hero_stats_playerLookupName', StripClanTag(GetAccountName()));"
		onevent="
			If(!VarExists('hero_stats_cache_0_'#compendium_heroLastViewed) or !compendium_usage_useCache,
				Split(Set(compendium_usage_useCache, 1), Set(compendium_usage_usingCache, 0), Trigger('compendium_guideMasterQuery', 'HeroStats', HostTime), SubmitForm('HeroStats', 'f', 'get_hero_stats', 'hosttime', HostTime, 'nickname', compendium_hero_stats_playerLookupName, 'account_id', GetAccountID(), 'cookie', GetCookie(), 'hero', compendium_heroLastViewed)),
				Split(Set(compendium_usage_usingCache, 1), Trigger('HeroStatsLoadCache'))
			);	

			SubmitForm('CoN_HeroStats_Normal', 'f', 'get_campaign_hero_stats', 'cookie', GetCookie(), 'nickname', compendium_hero_stats_playerLookupName, 'hero_name', compendium_heroLastViewed, 'is_casual', '0');
			SubmitForm('CoN_HeroStats_Casual', 'f', 'get_campaign_hero_stats', 'cookie', GetCookie(), 'nickname', compendium_hero_stats_playerLookupName, 'hero_name', compendium_heroLastViewed, 'is_casual', '1');
		"
		watch5="HeroStatsLoadCache"
		ontrigger5="	
			Set(hero_stats_cache_string, 'Trigger(\'HeroStatsResult\', ');
			For(0, 190, 1, '
					Set(hero_stats_cache_string, hero_stats_cache_string # *(\'hero_stats_cache_\'#iParam#\'_\'#compendium_heroLastViewed) # \', \' ),
				');
			Set(hero_stats_cache_string, SubString(hero_stats_cache_string, 0, (StringLength(hero_stats_cache_string) - 5) ) # ');');
			Evaluate(hero_stats_cache_string);
		"		
		watch7="HeroStatsResult"
		ontrigger7="
			If(StringEmpty(param0) and !StringEmpty(param1),
			If(!VarExists('hero_stats_cache_0_'#compendium_heroLastViewed),								
				For(0, 190, 1, '
					If(!StringEmpty(*(\'param\'#iParam)),
						CreateString(\'hero_stats_cache_\'#iParam#\'_\'#compendium_heroLastViewed, *(\'param\'#iParam) ),
						CreateString(\'hero_stats_cache_\'#iParam#\'_\'#compendium_heroLastViewed, 0 )
					)
				'),
				For(0, 190, 1, '
					If(!StringEmpty(*(\'param\'#iParam)),
						Set(\'hero_stats_cache_\'#iParam#\'_\'#compendium_heroLastViewed, *(\'param\'#iParam) ),
						Set(\'hero_stats_cache_\'#iParam#\'_\'#compendium_heroLastViewed, 0 )
					)
				')				
			));
		"
		watch8="LoginStatus"
		ontrigger8="
			If(param2 and StringEquals(param0, 'success') and !StringEquals(StripClanTag(GetAccountName()), compendium_hero_stats_playerLookupName),
				Split(
					Set(compendium_usage_useCache, 0),
					Set(compendium_hero_stats_playerLookupName, StripClanTag(GetAccountName()))
				)
			);"
	/>	
	
