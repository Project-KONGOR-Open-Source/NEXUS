<?xml version="1.0" encoding="UTF-8"?>
<package>
	<!-- usage list -->
	<trigger name="HeroUsageListFormStatus"/>
	<trigger name="HeroUsageListFormResult"/>
	<trigger name="HeroUsageListFormResultExplode"/>		
	<trigger name="HeroUsageListFormLoadCache"/>
	
	<form		
		name="HeroUsageListForm"
		host="!masterserver"
		method="POST"
		target="/client_requester.php"
		statustrigger="HeroUsageListFormStatus"
		resulttrigger="HeroUsageListFormResult"
		resultparam0="errors"
		resultparam1="success"
		resultparam2="data"
		resultparam3="total_use"
		ssl="false"
	/>	
	<panel  name="submit_herousagelistform" noclick="1" group="compendium_hero_usage_list_boxes"
		    onevent="
				If(!VarExists('compendium_usage_list_cache_'#compendium_hero_usage_list_sort#'_0_') or !compendium_usage_useCache,
					Split(Set(compendium_usage_useCache, 1), Set(compendium_usage_usingCache, 0), SubmitForm('HeroUsageListForm', 'f', 'get_hero_usage_list', 'cookie', GetCookie(), 'sort', compendium_hero_usage_list_sort)),
					Split(Set(compendium_usage_usingCache, 1), Trigger('HeroUsageListFormLoadCache'))
				);			
				"  
		    onload="CreateString('compendium_hero_usage_list_sort', 'use');"
		    watch="HeroUsageListFormStatus" ontrigger="If(param0 == 2, GroupCall('compendium_hero_usage_list_boxes', 'DoEvent(1);'), GroupCall('compendium_hero_usage_list_boxes', 'DoEvent(2);'));"		
		   
	/>
	
	<!-- usage graph -->
	<trigger name="HeroUsageGraphAxisUpdate"/>	
	<trigger name="HeroUsageGraphTooltipUpdate"/>		
	<trigger name="HeroUsageGraphFormStatus"/>
	<trigger name="HeroUsageGraphFormResult"/>
	<trigger name="HeroUsageGraphFormResultExplode"/>		
	<trigger name="HeroUsageGraphFormLoadCache"/>
	
	<form		
		name="HeroUsageGraphForm"
		host="!masterserver"
		method="POST"
		target="/client_requester.php"
		statustrigger="HeroUsageGraphFormStatus"
		resulttrigger="HeroUsageGraphFormResult"
		resultparam0="errors"
		resultparam1="success"
		resultparam2="data"
		resultparam3="count"
		resultparam4="high_total"
		resultparam5="high"
		ssl="false"
	/>	
	<panel  name="submit_herousagegraphform" noclick="1"  
		    onevent="
				If(!VarExists('compendium_usage_cache_0_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays) or !compendium_usage_useCache,
					Split(Set(compendium_usage_useCache, 1), Set(compendium_usage_usingCache, 0), SubmitForm('HeroUsageGraphForm', 'f', 'get_hero_usage_graph', 'cookie', GetCookie(), 'hero', compendium_heroLastViewed, 'limit', 45, 'days', compendium_usage_retrieveDays)),
					Split(Set(compendium_usage_usingCache, 1), Trigger('HeroUsageGraphFormLoadCache'))
				);			
				"  
		    onload="CreateInt('compendium_usage_retrieveDays', 90); CreateBool('compendium_usage_useCache', 0); CreateBool('compendium_usage_usingCache', 0);"
		    watch="HeroUsageGraphFormStatus" ontrigger="If(param0 == 2, GroupCall('compendium_hero_usage_graph_bars', 'DoEvent(1);'), GroupCall('compendium_hero_usage_graph_bars', 'DoEvent(2);'));"
		   
			watch1="HeroUsageGraphFormLoadCache"
			ontrigger1="
				GroupCall('compendium_hero_usage_graph_bars', 'DoEvent(3);');
				
				SleepWidget(250, ' 
					GroupCall(\'compendium_hero_usage_graph_bars\', \'DoEvent(1);\' );
					Trigger(\'HeroUsageGraphFormResult\', 
						*(\'compendium_usage_cache_0_\'#compendium_heroLastViewed#\'_\'#compendium_usage_retrieveDays),
						*(\'compendium_usage_cache_1_\'#compendium_heroLastViewed#\'_\'#compendium_usage_retrieveDays),
						*(\'compendium_usage_cache_2_\'#compendium_heroLastViewed#\'_\'#compendium_usage_retrieveDays),
						*(\'compendium_usage_cache_3_\'#compendium_heroLastViewed#\'_\'#compendium_usage_retrieveDays),
						*(\'compendium_usage_cache_4_\'#compendium_heroLastViewed#\'_\'#compendium_usage_retrieveDays),
						*(\'compendium_usage_cache_5_\'#compendium_heroLastViewed#\'_\'#compendium_usage_retrieveDays)
					);	
					'
				);

			"		

			watch7="HeroUsageGraphFormResult"
			ontrigger7="
				If(StringEmpty(param0) and !StringEmpty(param1),
				If(!VarExists('compendium_usage_cache_0_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays),
					Split(
						CreateString('compendium_usage_cache_0_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param0#''),
						CreateString('compendium_usage_cache_1_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param1#''),
						CreateString('compendium_usage_cache_2_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param2#''),
						CreateString('compendium_usage_cache_3_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param3#''),
						CreateString('compendium_usage_cache_4_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param4#''),
						CreateString('compendium_usage_cache_5_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param5#'')
					),
					Split(
						Set('compendium_usage_cache_0_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param0#''),
						Set('compendium_usage_cache_1_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param1#''),
						Set('compendium_usage_cache_2_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param2#''),
						Set('compendium_usage_cache_3_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param3#''),
						Set('compendium_usage_cache_4_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param4#''),
						Set('compendium_usage_cache_5_'#compendium_heroLastViewed#'_'#compendium_usage_retrieveDays, ''#param5#'')
					)				
				));
			"		
		   
	/>	
	
	<!-- Styles -->
	<style name="modeNormal_bg" color="#FFFFFF" />
	<style name="modeCasual_bg" color="#00ff36" />
	<style name="modePublic_bg" color="#ff0000" />
	
	<style name="modeNormal_txt" color="#3abde7" />
	<style name="modeCasual_txt" color="#3ae77b" />
	<style name="modePublic_txt" color="#c02e2e" />

	<!-- Guides -->	
	<trigger name="compendium_guideLoadFeatured" />
	<trigger name="compendium_guideHeroName" />	
	<trigger name="compendium_guideLoadCache" />
	<trigger name="compendium_guideInfoFormResultCache" />
	<trigger name="compendium_guideInfoFormResultCache2" />	
	<trigger name="compendium_guideLabelEvent" />
	<trigger name="compendium_guideButtonUpdate" />	
	<trigger name="compendium_guideAbilityEvent" />
	<trigger name="compendium_guideAbilityClear" />	
	<trigger name="compendium_guideTextClear" />
	<trigger name="compendium_guideRecommendedEvent" />
	<trigger name="compendium_guideRecommendedClear" />	
	<trigger name="compendium_guideRecommendedBorder" />
	<trigger name="compendium_guideListFormStatus"/>
	<trigger name="compendium_guideListFormResult"/>
	<trigger name="compendium_guideListFormResultExplode"/>	
	<trigger name="compendium_guideListFormLoadCache" />
	<trigger name="compendium_guideInfoFormStatus"/>
	<trigger name="compendium_guideInfoFormResult"/>
	<trigger name="compendium_guideInfoFormResultSave"/>
	<trigger name="compendium_guideInfoFormResultExplodeAbilities"/>
	<trigger name="compendium_guideInfoFormResultExplodeItemsStart"/>
	<trigger name="compendium_guideInfoFormResultExplodeItemsLaning"/>
	<trigger name="compendium_guideInfoFormResultExplodeItemsCore"/>
	<trigger name="compendium_guideInfoFormResultExplodeItemsLux"/>
	<trigger name="compendium_guideVoteFormStatus" />
	<trigger name="compendium_guideVoteFormResult" />
	<trigger name="compendium_guideDefaultFormStatus" />
	<trigger name="compendium_guideDefaultFormResult" />
	<trigger name="compendium_guideSetAsDefault"   />	
	<trigger name="compendium_guideFavoriteFormStatus" />
	<trigger name="compendium_guideFavoriteFormResult" />
	<trigger name="compendium_guideAddToFavorites" />		
	<trigger name="compendium_guideLoadcompendium_guide" />
	<trigger name="compendium_guideChangedcompendium_guide" />
	<trigger name="compendium_guideUpdateButtons" />
	<trigger name="compendium_guideMasterQuery" />
	<trigger name="compendium_guideMasterStatus" />
	<trigger name="buildcompendium_guideErrorString" />
	
	<!-- event handler  -->
	<panel noclick="1"
		onload="
			CreateString('compendium_guide_currentcompendium_guideString', '');
			CreateString('compendium_guide_selectedcompendium_guideString', '');
			CreateString('compendium_guide_currentIntroString', '');
			CreateString('compendium_guide_currentHero', '');
			CreateString('compendium_guide_reportReason', ''); 
			CreateString('compendium_guide_recommendedString', '');
			
			CreateInt('compendium_guide_masterQueryTime', -1);
			CreateInt('compendium_guide_masterQueryTimeSent', -1);
			CreateInt('compendium_guide_selectedcompendium_guide', 99999);
			CreateInt('compendium_guide_lastcompendium_guide', -1);
			CreateInt('compendium_guide_defaultcompendium_guide', 0);
			CreateInt('compendium_guide_favoritecompendium_guide', 0);
			CreateInt('compendium_animSpeedMult', 1);
			CreateInt('compendium_guide_fadein', 125);
			CreateInt('compendium_guide_lerptime', 1000);
			
			##CreateBool('compendium_guide_useReport', 1);##
			CreateBool('compendium_guide_useCache', 1);			
			CreateBool('compendium_guide_newRound', 0);
			CreateInt('compendium_guide_goToTab', 2);
		"	

		watch0="Disconnected"
		ontrigger0="Set(compendium_guide_useCache, 0);"		
	
		watch=""
		ontrigger="
			If(param != 1, SleepWidget(500, 'Trigger(\'compendium_guideMasterStatus\', param)'));
		"
		
		watch1="compendium_guideSetAsDefault"
		ontrigger1="
			Set(compendium_guide_lastcompendium_guide, compendium_guide_selectedcompendium_guide);
			Set(compendium_guide_auto_selection, 1);
			If(param == 1,
				Split(Set(compendium_guide_defaultcompendium_guide, compendium_guide_selectedcompendium_guide), Trigger('compendium_guideMasterQuery', 'compendium_guideDefaultForm', HostTime), SubmitForm('compendium_guideDefaultForm', 'f', 'guide_default_set', 'account', GetAccountID(), 'cookie', GetCookie(), 'hosttime', HostTime, 'gid', compendium_guide_selectedcompendium_guide)),
				Split(Set(compendium_guide_defaultcompendium_guide, -1), 										Trigger('compendium_guideMasterQuery', 'compendium_guideDefaultForm', HostTime), SubmitForm('compendium_guideDefaultForm', 'f', 'guide_default_remove', 'account', GetAccountID(), 'cookie', GetCookie(), 'hosttime', HostTime, 'gid', compendium_guide_selectedcompendium_guide))
			);
		"
		
		watch2="compendium_guideAddToFavorites"
		ontrigger2="
			Set(compendium_guide_lastcompendium_guide, compendium_guide_selectedcompendium_guide);
			Set(compendium_guide_auto_selection, 1);
			If(param == 1,
				Split(Set(compendium_guide_favoritecompendium_guide, compendium_guide_selectedcompendium_guide), Trigger('compendium_guideMasterQuery', 'compendium_guideFavoriteForm', HostTime), SubmitForm('compendium_guideFavoriteForm', 'f', 'guide_favorite_set', 'account', GetAccountID(), 'cookie', GetCookie(), 'hosttime', HostTime, 'gid', compendium_guide_selectedcompendium_guide)),
				Split(Set(compendium_guide_favoritecompendium_guide, -1), 										 Trigger('compendium_guideMasterQuery', 'compendium_guideFavoriteForm', HostTime), SubmitForm('compendium_guideFavoriteForm', 'f', 'guide_favorite_remove', 'account', GetAccountID(), 'cookie', GetCookie(), 'hosttime', HostTime, 'gid', compendium_guide_selectedcompendium_guide))
			);
		"

		watch3="compendium_guideMasterQuery"
		ontrigger3="
			SetWatch(''#param0#'Status');
			Set(compendium_guide_masterQueryTime, param1);
			Set(compendium_guide_masterQueryTimeSent, param1);
			Trigger('compendium_guideMasterStatus', 1);
		"		
					
		watch4="compendium_guideReportFormResult compendium_guideVoteFormResult compendium_guideListFormResult compendium_guideInfoFormResult compendium_guideFavoriteFormResult compendium_guideDefaultFormResult"
		ontrigger4="
			## Error param0 ##
		"
					
		watch5="compendium_guideLoadCache"
		ontrigger5="
			Trigger('compendium_guideInfoFormResult', 
				*('guide_info_cache_0_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_1_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_2_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_3_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_4_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_5_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_6_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_7_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_8_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_9_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_10_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_11_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_12_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_13_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_14_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_15_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_16_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_17_'#compendium_guide_selectedcompendium_guide),
				*('guide_info_cache_18_'#compendium_guide_selectedcompendium_guide),
				1,
				1,
				*('guide_info_cache_21_'#compendium_guide_selectedcompendium_guide)
			);	
		"		
		
		watch7="compendium_guideInfoFormResult"
		ontrigger7="
			If(StringEmpty(param0) and !StringEmpty(param1),
			If(!VarExists('guide_info_cache_0_'#compendium_guide_selectedcompendium_guide),
				Split(
					CreateString('guide_info_cache_0_'#compendium_guide_selectedcompendium_guide, ''#param0#''),
					CreateString('guide_info_cache_1_'#compendium_guide_selectedcompendium_guide, ''#param1#''),
					CreateString('guide_info_cache_2_'#compendium_guide_selectedcompendium_guide, ''#param2#''),
					CreateString('guide_info_cache_3_'#compendium_guide_selectedcompendium_guide, ''#param3#''),
					CreateString('guide_info_cache_4_'#compendium_guide_selectedcompendium_guide, ''#param4#''),
					CreateString('guide_info_cache_5_'#compendium_guide_selectedcompendium_guide, ''#param5#''),
					CreateString('guide_info_cache_6_'#compendium_guide_selectedcompendium_guide, ''#param6#''),
					CreateString('guide_info_cache_7_'#compendium_guide_selectedcompendium_guide, ''#param7#''),
					CreateString('guide_info_cache_8_'#compendium_guide_selectedcompendium_guide, ''#param8#''),
					CreateString('guide_info_cache_9_'#compendium_guide_selectedcompendium_guide, ''#param9#''),				
					CreateString('guide_info_cache_10_'#compendium_guide_selectedcompendium_guide, ''#param10#''),
					CreateString('guide_info_cache_11_'#compendium_guide_selectedcompendium_guide, ''#param11#''),
					CreateString('guide_info_cache_12_'#compendium_guide_selectedcompendium_guide, ''#param12#''),
					CreateString('guide_info_cache_13_'#compendium_guide_selectedcompendium_guide, ''#param13#''),
					CreateString('guide_info_cache_14_'#compendium_guide_selectedcompendium_guide, ''#param14#''),
					CreateString('guide_info_cache_15_'#compendium_guide_selectedcompendium_guide, ''#param15#''),
					CreateString('guide_info_cache_16_'#compendium_guide_selectedcompendium_guide, ''#param16#''),
					CreateString('guide_info_cache_17_'#compendium_guide_selectedcompendium_guide, ''#param17#''),
					CreateString('guide_info_cache_18_'#compendium_guide_selectedcompendium_guide, ''#param18#''),
					CreateString('guide_info_cache_21_'#compendium_guide_selectedcompendium_guide, ''#param21#'')
				),
				Split(
					Set('guide_info_cache_0_'#compendium_guide_selectedcompendium_guide, ''#param0#''),
					Set('guide_info_cache_1_'#compendium_guide_selectedcompendium_guide, ''#param1#''),
					Set('guide_info_cache_2_'#compendium_guide_selectedcompendium_guide, ''#param2#''),
					Set('guide_info_cache_3_'#compendium_guide_selectedcompendium_guide, ''#param3#''),
					Set('guide_info_cache_4_'#compendium_guide_selectedcompendium_guide, ''#param4#''),
					Set('guide_info_cache_5_'#compendium_guide_selectedcompendium_guide, ''#param5#''),
					Set('guide_info_cache_6_'#compendium_guide_selectedcompendium_guide, ''#param6#''),
					Set('guide_info_cache_7_'#compendium_guide_selectedcompendium_guide, ''#param7#''),
					Set('guide_info_cache_8_'#compendium_guide_selectedcompendium_guide, ''#param8#''),
					Set('guide_info_cache_9_'#compendium_guide_selectedcompendium_guide, ''#param9#''),		
					Set('guide_info_cache_10_'#compendium_guide_selectedcompendium_guide, ''#param10#''),
					Set('guide_info_cache_11_'#compendium_guide_selectedcompendium_guide, ''#param11#''),
					Set('guide_info_cache_12_'#compendium_guide_selectedcompendium_guide, ''#param12#''),
					Set('guide_info_cache_13_'#compendium_guide_selectedcompendium_guide, ''#param13#''),
					Set('guide_info_cache_14_'#compendium_guide_selectedcompendium_guide, ''#param14#''),
					Set('guide_info_cache_15_'#compendium_guide_selectedcompendium_guide, ''#param15#''),
					Set('guide_info_cache_16_'#compendium_guide_selectedcompendium_guide, ''#param16#''),
					Set('guide_info_cache_17_'#compendium_guide_selectedcompendium_guide, ''#param17#''),
					Set('guide_info_cache_18_'#compendium_guide_selectedcompendium_guide, ''#param18#''),
					Set('guide_info_cache_21_'#compendium_guide_selectedcompendium_guide, ''#param21#'')
				)				
			));
		"		
	/>

	<panel noclick="1"
		watch7="compendium_guideChangedcompendium_guide"
		ontrigger7="	
			##SetAutoLevelup(' ');##
			##
			Trigger('compendium_guideRecommendedEvent');
			Trigger('compendium_guideAbilityEvent');
			Trigger('compendium_guideLabelEvent');
			##
			Set(compendium_guide_usingLocal, 0);
		"
		
		watch8="compendium_guideLoadcompendium_guide"
		ontrigger8="
			Trigger('compendium_guideRecommendedClear');
			Trigger('compendium_guideAbilityClear');	
			Trigger('compendium_guideTextClear');
			##SetAutoLevelup(' ');##
			##Echo('compendium_guideLoadcompendium_guide');##
			Call('compendium_guide_usingLocalPanel', 'SetVisible(0);');
			If(!VarExists('guide_info_cache_0_'#compendium_guide_selectedcompendium_guide) or !compendium_guide_useCache,
				Split(Set(compendium_guide_useCache, 1), Trigger('compendium_guideMasterQuery', 'compendium_guideInfoForm', HostTime), SubmitForm('compendium_guideInfoForm', 'f', 'get_guide', 'account', GetAccountID(), 'cookie', GetCookie(), 'hero', compendium_guide_currentHero, 'hosttime', HostTime, 'gid', compendium_guide_selectedcompendium_guide)),
				##Split(Echo('Load from ^gcache'),## Trigger('compendium_guideLoadCache')##)##
			);
			
			If(WidgetExists('compendium_guidelist_item_'#compendium_guide_selectedcompendium_guide),
				Call('compendium_guidelist_item_'#compendium_guide_selectedcompendium_guide, 
					'Call(\'compendium_guide_pop_display_label\', \'SetText(\\\'\'#this#\'\\\'); SetColor(Saturate(1 - ((this/100) - 0.50) / 0.50), ((this/100) + ((((this/100) - 0.05) / 1.0)*0.2)) / 0.45, 	0, 1); \')'
				)
			);
			##Trigger('compendium_guideChangedcompendium_guide');##
		"

		watch9="compendium_guideHeroName"
		ontrigger9="
			If(!StringEmpty(param0),
				If(!StringEquals(param0, compendium_guide_currentHero) or compendium_guide_newRound,
					Split(
						Set(compendium_guide_newRound, 0),
						Set(compendium_guide_currentHero, param0),
						Call('compendium_guide_list', 'ClearItems();'),
						If(!VarExists('guide_list_cache__0_'#compendium_heroLastViewed) or !compendium_usage_useCache,
							Split(Set(compendium_usage_useCache, 1), Set(compendium_usage_usingCache, 0), Trigger('compendium_guideMasterQuery', 'compendium_guideListForm', HostTime), SubmitForm('compendium_guideListForm', 'f', 'get_guide_list_filtered', 'account', GetAccountID(), 'cookie', GetCookie(), 'hero', param0, 'hosttime', HostTime)),
							Split(Set(compendium_usage_usingCache, 1), Trigger('compendium_guideListFormLoadCache'))
						),						
						Trigger('compendium_guideLoadcompendium_guide')	
					)
				)
			);
		"
		
		watch1="compendium_guideListFormLoadCache"
		ontrigger1="
			Trigger('compendium_guideListFormResult', 
				*('guide_list_cache__0_'#compendium_heroLastViewed),
				*('guide_list_cache__1_'#compendium_heroLastViewed),
				*('guide_list_cache__2_'#compendium_heroLastViewed)
			);	
		"		

		watch2="compendium_guideListFormResult"
		ontrigger2="
			If(StringEmpty(param0) and !StringEmpty(param1),
			If(!VarExists('guide_list_cache__0_'#compendium_heroLastViewed),
				Split(
					CreateString('guide_list_cache__0_'#compendium_heroLastViewed, ''#param0#''),
					CreateString('guide_list_cache__1_'#compendium_heroLastViewed, ''#param1#''),
					CreateString('guide_list_cache__2_'#compendium_heroLastViewed, ''#param2#'')
				),
				Split(
					Set('guide_list_cache__0_'#compendium_heroLastViewed, ''#param0#''),
					Set('guide_list_cache__1_'#compendium_heroLastViewed, ''#param1#''),
					Set('guide_list_cache__2_'#compendium_heroLastViewed, ''#param2#'')
				)				
			));
		"			
		
	/>	
	
	<trigger name="compendium_guideLoadFeaturedExplode" />
	<trigger name="compendium_guideLoadFeaturedInstantiate" />		
	<trigger name="compendium_guideInfoFormResultLocal" />
	<panel noclick="1"
		watch2="compendium_guideLoadFeatured"
		ontrigger2="
			Set(compendium_guide_useCache, 0);
			Trigger('compendium_guideInfoFormStatus', 1);
			SleepWidget(50, '
				If(!WidgetExists(\'compendium_guide_reader_textbuffer_\'#compendium_guide_currentHero),
					Split(
						##Echo(\'^y 1 - compendium_guideLoadFeatured Triggered - Instantiating\'),##
						Instantiate(\'compendium_guide_reader_textbuffer\', \'hero\', compendium_guide_currentHero),
						SleepWidget(1, \'Trigger(\\\'compendium_guideLoadFeaturedInstantiate\\\');\')
					),
					SleepWidget(1, \'Trigger(\\\'compendium_guideLoadFeaturedInstantiate\\\');\')
				);'
			);
		"
		
		watch1="compendium_guideLoadFeaturedExplode"
		ontrigger1="		
			Trigger('compendium_guideRecommendedClear');
			Trigger('compendium_guideAbilityClear');	
			Trigger('compendium_guideTextClear');
			##SetAutoLevelup(' ');	##	
			Call('compendium_guide_usingLocalPanel', 'SetVisible(1);');			
			Trigger('compendium_guideInfoFormResultLocal', 
				'', ## ##
				'',
				'',
				'',
				'',
				param7, ## Items ##
				param8, ## Items ##
				param9, ## Items ##
				param10, ## Items ##
				param11, ## Abilities ##
				param12, ## Intro ##
				param13, ## Desc ##
				'', ## Date Modified ##
				0, ## Fav ##
				0, ## Def ##
				1, ##  ##
				1, ## Vote result ##
				1, ##  ##
				1, ##  ##
				1, ##  ##
				1, ##  ##
				1, ## Featured ##
				1
			);	
			##
			Call('compendium_guide_list', '
				ClearItems();
				Set(compendium_guide_usingLocal, 1);
				AddTemplateListItem(\'compendium_guidelist_item\', 0,
					\'index\', 0,
					\'compendium_guideindex\', 0,
					\'timestamp\',  \''#param1#'\',
					\'author\', \''#param2#'\',
					\'compendium_guidename\', \''#param4#'\',
					\'isdef\', 0,
					\'isfav\', 0,				
					\'pop\', 1,
					\'is_yours\', 0,
					\'is_premium\', 1	
				);	
			');			
			##
			Trigger('compendium_guideChangedcompendium_guide');
			"	
	/>	
	<template name="compendium_guide_reader_textbuffer" >
		<textbuffer name="compendium_guide_reader_textbuffer_{hero}" visible="0" group="compendium_guide_reader_textbuffers" scrolltexture="/ui/info/combobox.tga" handleheight="2.0h" scrollbarsize="2.2h" wrap="0" exteriorscrollbars="false" textalign="left" font="dyn_10" textcolor="white" color="invisible" shadow="1" noclick="1"
			file="/guides/{hero}_guide.txt"
			watch1="compendium_guideLoadFeaturedInstantiate" ontrigger1="
			Trigger('compendium_guideRecommendedClear');
			Trigger('compendium_guideAbilityClear');	
			Trigger('compendium_guideTextClear');
			##SetAutoLevelup(' ');##		
			SleepWidget(50, 'ExplodeTrigger(\'compendium_guideLoadFeaturedExplode\', NormalizeLineBreaks(this), \'$#$#\', \'`\', 0, 0);');
			"
			watch="compendium_guideLoadFeatured" ontrigger="DestroyWidget();"
		/>
	</template>
	 
