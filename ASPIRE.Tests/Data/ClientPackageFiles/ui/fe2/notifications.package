<?xml version="1.0" encoding="UTF-8"?>
<package>

	<!-- Styles -->
	<style name="friends_border" bordercolor=".4 .4 .4 1" />
	<style name="clans_border" bordercolor=".4 .4 .4 1" />
	<style name="tourney_border" bordercolor=".4 .4 .4 1" />
	<style name="invite_border" bordercolor=".4 .4 .4 1" />
	<style name="patch_border" bordercolor=".4 .4 .4 1" />

	<style name="friends_dependent" color=".8 .8 .8 1" />
	<style name="clans_dependent" color=".8 .8 .8 1" />
	<style name="tourney_dependent" color=".8 .8 .8 1" />
	<style name="invite_dependent" color=".8 .8 .8 1" />
	<style name="patch_dependent" color=".8 .8 .8 1" />

	<style name="friends_situation_bgcolor" color=".4 .4 .4 1" />
	<style name="clans_situation_bgcolor" color=".4 .4 .4 1" />
	<style name="tourney_situation_bgcolor" color=".4 .4 .4 1" />
	<style name="invite_situation_bgcolor" color=".4 .4 .4 1" />
	<style name="patch_situation_bgcolor" color=".4 .4 .4 1" />

	<template name="sp_notification_history_expand_btn_template">
		<!-- Notification History Maximize -->
		<panel name="sp_notification_history_expand_btn_{index}" group="sp_notification_history_expand_btns" x="{x=0}" y="{y=0.1h}" width="1.5h" height="1.5h" valign="{valign=top}" align="{align=left}" color="invisible" visible="{visible=1}" passivechildren="1" noclick="1" >
			<button noclick="1" color="invisible" >
				<widgetstate statename="up">
					<!--
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{up_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					-->
					<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" rotation="0" texture="/ui/fe2/elements/notification_expand.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="over">
					<!--
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{over_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					-->
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" rotation="0" texture="/ui/fe2/elements/notification_expand.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<!--
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{dn_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					-->
					<image width="1.3h" height="1.3h" align="center" valign="center" color=".1 1 1 1" rotation="0" texture="/ui/fe2/elements/notification_expand.tga" noclick="true" />
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="sp_notification_history_close_btn_template">
		<!-- Remove From History List  -->
		<panel x="{x=0}" y="{y=0.1h}" width="1.5h" height="1.5h" valign="{valign=top}" align="{align=right}" color="invisible" visible="{visible=1}">
			<button
				name="sp_notification_history_template_{index}_button_3"
				color="invisible" onclick="PlaySound('/shared/sounds/ui/ccpanel/notification_close.wav');"
				onclicklua="HoN_Notifications.NotificationButtonClicked(3, {index}, 'history')"
				onmouseover="Set({var=sp_notification_history_template_?_mouseover}, true);"
				onmouseout="Set({var=sp_notification_history_template_?_mouseover}, false); Call('{call}', 'DoEvent(1)');"
			>
				<widgetstate statename="up">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{up_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/fe2/elements/closex.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{over_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/elements/closex.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{dn_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/elements/closex.tga" noclick="true" />
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="sp_notification_toast_template">
		<panel name="sp_notification_sleeper_{index}" noclick="1" color="invisible"/>
		<panel name="sp_notification_toast_template_{index}" group="sp_notification_toast_templates" width="25h" height="6.5h" sticky="1" stickytoinvis="0" visible="0" noclick="0" align="right" valign="top"
			oninstantiate="CreateBool('sp_notification_toast_template_{index}_mouseover', false);"
			onrightclicklua="HoN_Notifications.NotificationButtonClicked(3, {index}, 'toast')"
			onmouseoverlua=""
			onmouseover=""
			onmouseout="
				Set(sp_notification_toast_template_{index}_mouseover, false);
				DoEvent(1);
			"
			onevent1lua="GetWidget('sp_notification_sleeper_{index}', 'main'):Sleep(1, function() GetWidget('sp_notification_toast_template_{index}'):DoEvent() end)"
			onevent="
				If(!sp_notification_toast_template_{index}_mouseover,
					Split(
						Call('sp_notification_toast_template_{index}_buttons', 'FadeOut(100)'),
						Call('sp_notification_toast_template_{index}_game_info', 'FadeOut(100)')
					)
				);
			"
			oneventlua="
				if (not GetCvarBool('sp_notification_toast_template_{index}_mouseover')) then
					HoN_Notifications.MouseoverToastNotification(false, {index})
					if (not (HoN_Notifications.toastWidgetTable[{index}].isClosing or
						HoN_Notifications.toastWidgetTable[{index}].isOpening)) then

						self:ScaleHeight('6.5h', 100)
						GetWidget('sp_notification_sleeper_{index}', 'main'):Sleep(101, function() HoN_Notifications.toastWidgetTable[{index}].isOpen = false end)
					end
				end
			"
		>
			<frame texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".6 .6 .6 .9" blockinput="0" noclick="1" visible="1" />
			<frame texture="/ui/frames/roundframe.tga" color=".2 .2 .2 1" borderthickness="0.6h" blockinput="false" noclick="1" />

			<panel y="0.3h" x="0.3h" height="5.9h" width="5.9h" noclick="1">
				<image name="sp_notification_toast_template_{index}_icon" texture="{icon=/ui/fe2/store/icons/account_icons/default.tga}" noclick="1"  />
			</panel>

			<panel x="6.0h" height="5.9h" width="-6.0h" noclick="1" >
				<panel height="2.5h" x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_toast_template_{index}_label_1" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_11" color="{namecolor=white}" shadow="true" content="" noclick="1" visible="1" />
				</panel>
				<panel height="-3.5h" y="2.0h" x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_toast_template_{index}_label_2" align="left" height="100%" width="100%" textalign="left" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="1" visible="1" wrap="1" />
				</panel>
				<panel height="1.1h" valign="bottom"  x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_toast_template_{index}_label_3" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_8" color="0.7 0.7 0.7 1" shadow="true" content="" noclick="1" visible="1" />
				</panel>
			</panel>

			<panel name="sp_notification_toast_template_{index}_game_info" visible="0" y="0.3h" height="-0.6h" width="-2" align="center" noclick="1" color="0 0 0 0.93" float="bottom" padding="0.2h"
			>
				<panel x="0" y="0" height="1.7h" noclick="1" sticky="1" stickytoinvis="0" >
					<label name="sp_notification_toast_template_{index}_label_4" align="left" height="100%" width="100%" textalign="center" textvalign="center" font="dyn_11" color="#ffb300" shadow="true" content="" noclick="1" visible="1" />
				</panel>

				<panel height="1.8h" align="center" noclick="1" float="right" padding="0.5h" sticky="1" stickytoinvis="0" >
					<label name="sp_notification_toast_template_{index}_label_5" align="left" height="100%" width="100%" textalign="center" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="1" visible="1" wrap="1" />
				</panel>

				<panel grow="1" regrow="1" growinvis="0" align="center" noclick="1" float="right" padding="0.2h" sticky="0" stickytoinvis="0" >
					<image name="sp_notification_toast_template_{index}_icon_1" visible="1" texture="$invis" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_2" visible="1" texture="$invis" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_3" visible="{isVerifiedOnly=1}" texture="/ui/icons/verified.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />

					<image name="sp_notification_toast_template_{index}_icon_4" visible="{isCasualMode=1}" texture="/ui/icons/casual.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_5" visible="{isHardcore=1}" texture="/ui/icons/hardcore.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_6" visible="{isGated=1}" texture="/ui/icons/gated.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_7" visible="{isAdvOptions=1}" texture="/ui/icons/more.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
				</panel>
				<panel grow="1" regrow="1" growinvis="0" align="center" noclick="1" float="right" padding="0.2h" sticky="1" stickytoinvis="0" >
					<image name="sp_notification_toast_template_{index}_icon_8"  visible="{isAutoBalanced=1}" texture="/ui/icons/autobalance.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_9"  visible="0" oninstantiate="SetVisible({statsLevel=0} == 1);" texture="/ui/icons/official.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_10" visible="0" oninstantiate="SetVisible({statsLevel=0} == 2);" texture="/ui/icons/official_2.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_11" visible="{isNoLeaver=1}" texture="/ui/icons/noleaver.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_12" visible="{isPrivate=1}" texture="/ui/icons/private.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_13" visible="{isDevHeroes=1}" texture="/ui/icons/devheroes.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_toast_template_{index}_icon_14" visible="{isBots=1}" texture="/ui/icons/botmatch.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
				</panel>
			</panel>

			<panel name="sp_notification_toast_template_{index}_buttons" visible="0" y="-0.3h" height="2.3h" width="100%" valign="bottom" align="center" noclick="1" sticky="true" stickytoinvis="false"
				onshow="Call('sp_notification_history_expand_btn_toast_{index}', 'SetVisible(0);');"
				onhide="Call('sp_notification_history_expand_btn_toast_{index}', 'SetVisible(1);');"
			>
				<instance name="button2"
					button_name="sp_notification_toast_template_{index}_button_1"
					x="-0.3h" visible="0"
					width="47%" height="2.2h"
					align="right" valign="bottom"
					borderthickness="0.5h"
					label="general_ignore"
					onclicklua=""
					onmouseoverlua="HoN_Notifications.MouseoverToastNotification(true, {index})"
					onmouseover="Set(sp_notification_toast_template_{index}_mouseover, true);"
					onmouseout="Set(sp_notification_toast_template_{index}_mouseover, false); Call('sp_notification_toast_template_{index}', 'DoEvent(1)');"
					labelgroup="sp_notification_toast_template_{index}_buttons_1"
				/>
				<instance name="button2"
					button_name="sp_notification_toast_template_{index}_button_2"
					x="0.3h" visible="0"
					width="47%" height="2.2h"
					align="left" valign="bottom"
					borderthickness="0.5h"
					label="general_approve"
					onclicklua=""
					onmouseoverlua="HoN_Notifications.MouseoverToastNotification(true, {index})"
					onmouseover="Set(sp_notification_toast_template_{index}_mouseover, true);"
					onmouseout="Set(sp_notification_toast_template_{index}_mouseover, false); Call('sp_notification_toast_template_{index}', 'DoEvent(1)');"
					labelgroup="sp_notification_toast_template_{index}_buttons_2"
				/>

			</panel>

			<instance name="sp_notification_history_close_btn_template" call="sp_notification_toast_template_{index}" var="sp_notification_toast_template_{index}_mouseover" visible="1" x="-0.3h" y="0.3h" align="right" valign="top" index="toast_{index}" framecolor=".7 .7 .7 1" up_color=".3 .3 .3 1" over_color=".5 .5 .5 1" dn_color=".4 .4 .4 1" />
			<instance name="sp_notification_history_expand_btn_template" call="sp_notification_toast_template_{index}" var="sp_notification_toast_template_{index}_mouseover" visible="0" x="0.2h" y="0.2h" align="left" valign="top" index="toast_{index}" framecolor=".7 .7 .7 1" up_color=".3 .3 .3 1" over_color=".5 .5 .5 1" dn_color=".4 .4 .4 1" />

		</panel>
	</template>

	<template name="sp_notification_history_template">
		<panel name="sp_notification_history_template_{index}" group="sp_notification_history_templates" height="6.5h" sticky="1" stickytoinvis="0" visible="0" noclick="0"
			oninstantiate="CreateBool('sp_notification_history_template_{index}_mouseover', false);"
			onrightclicklua="HoN_Notifications.NotificationButtonClicked(3, {index}, 'history')"
			onmouseoverlua=""
			onmouseout="
				Set(sp_notification_history_template_{index}_mouseover, false);
				SleepWidget(1, 'DoEvent();');
			"
			onevent2="Set(sp_notification_history_template_{index}_mouseover, false); SleepWidget(1, 'DoEvent();');"
			onevent1="SleepWidget(1, 'DoEvent();');"
			onevent="
				If(!sp_notification_history_template_{index}_mouseover,
					Split(
						ScaleHeight('6.5h', 100),
						Call('sp_notification_history_template_{index}_border', 'FadeOut(100)'),
						Call('sp_notification_history_template_{index}_buttons', 'FadeOut(100)'),
						Call('sp_notification_history_template_{index}_game_info', 'FadeOut(100)')
					)
				);
			"
		>
			<frame name="sp_notification_history_template_{index}_border" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".7 .7 .7 1" blockinput="0" noclick="1" visible="1" />
			<frame texture="/ui/frames/roundframe.tga" color=".2 .2 .2 1" borderthickness="0.6h" blockinput="false" noclick="1" />

			<panel y="0.3h" x="0.3h" height="5.9h" width="5.9h" noclick="1">
				<image name="sp_notification_history_template_{index}_icon" texture="{icon=/ui/fe2/store/icons/account_icons/default.tga}" noclick="1"  />
			</panel>

			<panel x="6.0h" height="5.9h" width="-6.0h" noclick="1" >
				<panel height="2.5h" x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_history_template_{index}_label_1" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_11" color="{namecolor=white}" shadow="true" content="" noclick="1" visible="1" />
				</panel>
				<panel height="-3.5h" y="2.0h" x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_history_template_{index}_label_2" align="left" height="100%" width="100%" textalign="left" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="1" visible="1" wrap="1" />
				</panel>
				<panel height="1.1h" valign="bottom"  x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_history_template_{index}_label_3" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_8" color="0.7 0.7 0.7 1" shadow="true" content="" noclick="1" visible="1" />
				</panel>
			</panel>

			<panel name="sp_notification_history_template_{index}_game_info" visible="0" y="0.3h" height="-0.6h" width="-2" align="center" noclick="1" color="0 0 0 0.93" float="bottom" padding="0.2h"
			>
				<panel x="0" y="0" height="1.7h" noclick="1" sticky="1" stickytoinvis="0" >
					<label name="sp_notification_history_template_{index}_label_4" align="left" height="100%" width="100%" textalign="center" textvalign="center" font="dyn_11" color="#ffb300" shadow="true" content="" noclick="1" visible="1" />
				</panel>

				<panel height="1.8h" align="center" noclick="1" float="right" padding="0.5h" sticky="1" stickytoinvis="0" >
					<label name="sp_notification_history_template_{index}_label_5" align="left" height="100%" width="100%" textalign="center" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="1" visible="1" wrap="1" />
				</panel>

				<panel grow="1" regrow="1" growinvis="0" align="center" noclick="1" float="right" padding="0.2h" sticky="0" stickytoinvis="0" >
					<image name="sp_notification_history_template_{index}_icon_1" visible="1" texture="$invis" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_2" visible="1" texture="$invis" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_3" visible="{isVerifiedOnly=1}" texture="/ui/icons/verified.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />

					<image name="sp_notification_history_template_{index}_icon_4" visible="{isCasualMode=1}" texture="/ui/icons/casual.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_5" visible="{isHardcore=1}" texture="/ui/icons/hardcore.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_6" visible="{isGated=1}" texture="/ui/icons/gated.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_7" visible="{isAdvOptions=1}" texture="/ui/icons/more.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
				</panel>
				<panel grow="1" regrow="1" growinvis="0" align="center" noclick="1" float="right" padding="0.2h" sticky="1" stickytoinvis="0" >
					<image name="sp_notification_history_template_{index}_icon_8"  visible="{isAutoBalanced=1}" texture="/ui/icons/autobalance.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_9"  visible="0" oninstantiate="SetVisible({statsLevel=0} == 1);" texture="/ui/icons/official.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_10" visible="0" oninstantiate="SetVisible({statsLevel=0} == 2);" texture="/ui/icons/official_2.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_11" visible="{isNoLeaver=1}" texture="/ui/icons/noleaver.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_12" visible="{isPrivate=1}" texture="/ui/icons/private.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_13" visible="{isDevHeroes=1}" texture="/ui/icons/devheroes.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_history_template_{index}_icon_14" visible="{isBots=1}" texture="/ui/icons/botmatch.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
				</panel>
			</panel>

			<panel name="sp_notification_history_template_{index}_buttons" visible="0" y="-0.3h" height="2.3h" width="100%" valign="bottom" align="center" noclick="1" sticky="true" stickytoinvis="false"
				onshow="Call('sp_notification_history_expand_btn_{index}', 'SetVisible(0);'); Call('notifications_remove_all_btn', 'FadeOut(150);');"
				onhide="Call('sp_notification_history_expand_btn_{index}', 'SetVisible(1);'); Call('notifications_remove_all_btn', 'FadeIn(150);');"
			>
				<instance name="button2"
					button_name="sp_notification_history_template_{index}_button_1"
					x="-0.3h"
					width="47%" height="2.2h"
					align="right" valign="bottom"
					borderthickness="0.5h"
					label="general_ignore"
					onclicklua=""
					onmouseover="Set(sp_notification_history_template_{index}_mouseover, true);"
					onmouseout="Set(sp_notification_history_template_{index}_mouseover, false); Call('sp_notification_history_template_{index}', 'DoEvent(1)');"
					labelgroup="sp_notification_history_template_{index}_buttons_1"
				/>
				<instance name="button2"
					button_name="sp_notification_history_template_{index}_button_2"
					x="0.3h"
					width="47%" height="2.2h"
					align="left" valign="bottom"
					borderthickness="0.5h"
					label="general_approve"
					onclicklua=""
					onmouseover="Set(sp_notification_history_template_{index}_mouseover, true);"
					onmouseout="Set(sp_notification_history_template_{index}_mouseover, false); Call('sp_notification_history_template_{index}', 'DoEvent(1)');"
					labelgroup="sp_notification_history_template_{index}_buttons_2"
				/>

			</panel>

			<instance name="sp_notification_history_close_btn_template" call="sp_notification_history_template_{index}" var="sp_notification_history_template_{index}_mouseover" visible="1" x="-0.3h" y="0.3h" align="right" valign="top" index="{index}" framecolor=".7 .7 .7 1" up_color=".3 .3 .3 1" over_color=".5 .5 .5 1" dn_color=".4 .4 .4 1" />
			<instance name="sp_notification_history_expand_btn_template" call="sp_notification_history_template_{index}" var="sp_notification_history_template_{index}_mouseover" visible="0" x="0.2h" y="0.2h" align="left" valign="top" index="{index}" framecolor=".7 .7 .7 1" up_color=".3 .3 .3 1" over_color=".5 .5 .5 1" dn_color=".4 .4 .4 1" />

		</panel>
	</template>

	<template name="sp_notification_minimize_btn">
		<!-- Notification Minimize -->
		<panel y="0.1h" width="1.5h" height="1.5h" valign="top" align="right" color="invisible" visible="{visible}">
			<button color="invisible" onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_01.wav');"
				onclicklua="Notification.SmallNotificationMinimisedClicked({index})"
			>
				<widgetstate statename="up">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{up_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/fe2/elements/minimize_bar.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{over_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/elements/minimize_bar.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.3h" color="{dn_color}" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="{framecolor=0 0 0 1}" borderthickness="0.3h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/elements/minimize_bar.tga" noclick="true" />
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="sp_notification_invite_popup_template">
		<panel name="sp_notification_invite_popup_template_{index}" height="10.0h" sticky="1" stickytoinvis="0" visible="0" noclick="0"
			oninstantiate="CreateBool('sp_notification_invite_popup_template_{index}_mouseover', false);"
			onmouseover="
				Set(sp_notification_invite_popup_template_{index}_mouseover, true);
				ScaleHeight('10.0h', 100);
				SleepWidget(250,
					'
					If(sp_notification_invite_popup_template_{index}_mouseover,
						Call(\'sp_notification_invite_popup_template_{index}_game_info\', \'FadeIn(100)\')
					);'
				);
			"
			onmouseout="
				Set(sp_notification_invite_popup_template_{index}_mouseover, false);
				SleepWidget(1, 'DoEvent();');
			"
			onevent1="SleepWidget(1, 'DoEvent();');"
			onevent="
				If(!sp_notification_invite_popup_template_{index}_mouseover,
					Split(
						ScaleHeight('10.0h', 100),
						Call('sp_notification_invite_popup_template_{index}_game_info', 'FadeOut(100)')
					)
				);
			"
		>
			<frame texture="/ui/frames/roundframe.tga" color=".2 .2 .2 1" borderthickness="0.6h" blockinput="false" noclick="true"/>
			<panel y="0.3h" x="0.3h" height="6.5h" width="6.5h" noclick="true">
				<image name="sp_notification_invite_popup_template_{index}_icon" texture="/ui/fe2/store/icons/account_icons/default.tga" noclick="1"  />
			</panel>
			<panel x="7.0h" height="6.9h" width="-7.0h" noclick="1" >
				<panel height="2.5h" x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_invite_popup_template_{index}_label_1" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_11" color="red" shadow="true" content="" noclick="true" visible="1" />
				</panel>
				<panel height="-3.5h" y="2.2h" x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_invite_popup_template_{index}_label_2" align="left" height="100%" width="100%" textalign="left" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="true" visible="1" wrap="1" oninstantiate="SetText(Translate('notify_buddy_requested_added_info'));" />
				</panel>
				<panel height="1.5h" valign="bottom"  x="5%" width="-5%" noclick="1" >
					<label name="sp_notification_invite_popup_template_{index}_label_3" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_8" color="0.7 0.7 0.7 1" shadow="true" content="" noclick="true" visible="1" />
				</panel>
			</panel>

			<panel name="sp_notification_invite_popup_template_{index}_game_info" clip="1" visible="0" y="0.3h" height="-0.6h" width="-2" align="center" noclick="1" color="0 0 0 0.93" float="bottom" padding="0.2h" >
				<panel x="0" y="0" height="1.7h" noclick="1" sticky="1" stickytoinvis="0" >
					<label name="sp_notification_invite_popup_template_{index}_label_4" align="left" height="100%" width="100%" textalign="center" textvalign="center" font="dyn_11" color="#ffb300" shadow="true" content="" noclick="1" visible="1" />
				</panel>

				<panel height="1.8h" align="center" noclick="1" float="right" padding="0.5h" sticky="1" stickytoinvis="0" >
					<label name="sp_notification_invite_popup_template_{index}_label_5" align="left" height="100%" width="100%" textalign="center" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="1" visible="1" wrap="1" />
				</panel>

				<panel grow="1" regrow="1" growinvis="0" align="center" noclick="1" float="right" padding="0.2h" sticky="0" stickytoinvis="0" >
					<image name="sp_notification_invite_popup_template_{index}_icon_1" visible="1" texture="/maps/{mapName}/icon.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_3" visible="1" texture="/ui/icons/{gameMode}.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_2" visible="{isVerifiedOnly=1}" texture="/ui/icons/verified.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />

					<image name="sp_notification_invite_popup_template_{index}_icon_4" visible="{isCasualMode=1}" texture="/ui/icons/casual.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_5" visible="{isHardcore=1}" texture="/ui/icons/hardcore.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_6" visible="{isGated=1}" texture="/ui/icons/gated.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_7" visible="{isAdvOptions=1}" texture="/ui/icons/more.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_8"  visible="{isAutoBalanced=1}" texture="/ui/icons/autobalance.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_9"  visible="0" oninstantiate="SetVisible({statsLevel=0} == 1);" texture="/ui/icons/official.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_10" visible="0" oninstantiate="SetVisible({statsLevel=0} == 2);" texture="/ui/icons/official_2.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_11" visible="{isNoLeaver=1}" texture="/ui/icons/noleaver.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_12" visible="{isPrivate=1}" texture="/ui/icons/private.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_13" visible="{isDevHeroes=1}" texture="/ui/icons/devheroes.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
					<image name="sp_notification_invite_popup_template_{index}_icon_14" visible="{isBots=1}" texture="/ui/icons/botmatch.tga" align="left" sticky="1" stickytoinvis="0" height="2.4h" width="2.4h" noclick="0" />
				</panel>
			</panel>

			<panel name="sp_notification_invite_popup_template_{index}_buttons" y="-0.3h" height="2.3h" width="100%" valign="bottom" align="center" noclick="1" sticky="true" stickytoinvis="false">
				<instance name="button2"
					button_name="sp_notification_invite_popup_template_{index}_button_1"
					x="-0.3h"
					width="47%" height="2.2h"
					align="right" valign="bottom"
					borderthickness="0.5h"
					label="general_ignore"
					onclicklua="HoN_Notifications.PopupNotificationButtonClicked(1, {index}, 'invite')"
					onmouseover="Set(sp_notification_invite_popup_template_{index}_mouseover, true);"
					onmouseout="Set(sp_notification_invite_popup_template_{index}_mouseover, false); Call('sp_notification_invite_popup_template_{index}', 'DoEvent(1)');"
				/>
				<instance name="button2"
					button_name="sp_notification_invite_popup_template_{index}_button_2"
					x="0.3h"
					width="47%" height="2.2h"
					align="left" valign="bottom"
					borderthickness="0.5h"
					label="general_join"
					onclicklua="HoN_Notifications.PopupNotificationButtonClicked(2, {index}, 'invite')"
					onmouseover="Set(sp_notification_invite_popup_template_{index}_mouseover, true);"
					onmouseout="Set(sp_notification_invite_popup_template_{index}_mouseover, false); Call('sp_notification_invite_popup_template_{index}', 'DoEvent(1)');"
				/>
			</panel>
		</panel>
	</template>

	<template name="sp_notification_friend_popup_template">
		<panel name="sp_notification_friend_popup_template_{index}" height="10.0h" sticky="1" stickytoinvis="0" visible="0" >
			<frame texture="/ui/frames/roundframe.tga" color=".2 .2 .2 1" borderthickness="0.6h" blockinput="false" noclick="true"/>
			<panel y="0.3h" x="0.3h" height="6.5h" width="6.5h" noclick="true">
				<image name="sp_notification_friend_popup_template_{index}_icon" texture="/ui/fe2/store/icons/account_icons/default.tga" noclick="0"  />
			</panel>
			<panel x="7.0h" height="6.9h" width="-7.0h" noclick="true" >
				<panel height="2.5h" x="5%" width="-5%">
					<label name="sp_notification_friend_popup_template_{index}_label_1" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_11" color="red" shadow="true" content="Bangerz" noclick="true" visible="1" />
				</panel>
				<panel height="-3.5h" y="2.2h" x="5%" width="-5%">
					<label name="sp_notification_friend_popup_template_{index}_label_2" align="left" height="100%" width="100%" textalign="left" textvalign="top" font="dyn_9" color="1 1 1 1" shadow="true" content="" noclick="true" visible="1" wrap="1" oninstantiate="SetText(Translate('notify_buddy_requested_added_info'));" />
				</panel>
				<panel height="1.5h" valign="bottom"  x="5%" width="-5%">
					<label name="sp_notification_friend_popup_template_{index}_label_3" align="left" height="100%" width="100%" textalign="left" textvalign="center" font="dyn_8" color="0.7 0.7 0.7 1" shadow="true" content="7:39PM Today" noclick="true" visible="1" />
				</panel>
			</panel>
			<panel name="sp_notification_friend_popup_template_{index}_buttons" y="7.0h" height="2.3h" width="100%" align="center" noclick="true" sticky="true" stickytoinvis="false">
				<instance name="button2"
					button_name="sp_notification_friend_popup_template_{index}_button_1"
					x="-0.3h"
					width="47%" height="2.2h"
					align="right" valign="bottom"
					borderthickness="0.5h"
					label="general_ignore"
					onclicklua="HoN_Notifications.PopupNotificationButtonClicked(1, {index}, 'friend')"
				/>
				<instance name="button2"
					button_name="sp_notification_friend_popup_template_{index}_button_2"
					x="0.3h"
					width="47%" height="2.2h"
					align="left" valign="bottom"
					borderthickness="0.5h"
					label="general_approve"
					onclicklua="HoN_Notifications.PopupNotificationButtonClicked(2, {index}, 'friend')"
				/>
			</panel>
		</panel>
	</template>

	<template name="sp_notification_small_template">
		<panel name="sp_notification_small_{index}" grow="true" width="100%" sticky="true" stickytoinvis="false" visible="1" >
			<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6ccb" noclick="true"/>

			<!--Borders -->
			<frame name="sp_notification_small_{index}_border" color="invisible" style="friends_border" borderthickness="1" noclick="true" visible="1" />

			<panel grow="true" width="100%" align="center" valign="center" noclick="true">
				<panel y="0.4h" width="-0.8h" height="2.0h" align="center" noclick="true">
					<!-- Images -->
					<image x="0.1h" height="2.4h" width="2.4h" texture="/ui/elements/gamefeature_heroes.tga" noclick="true" visible="1" />

					<panel x="-2.0h" width="-5.0h" height="100%" valign="top" align="right" noclick="true">
						<!-- Situation BGs -->
						<frame name="sp_notification_small_{index}_bg" style="friends_situation_bgcolor" texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" blockinput="false" noclick="true" visible="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.4h" blockinput="false" noclick="true"/>
						<label name="sp_notification_small_{index}_label_1" height="100%" textalign="center" textvalign="center" font="dyn_10" color="white" shadow="true" content="{label_1}" noclick="true"/>
					</panel>
					<!-- Minimize -->
					<instance name="sp_notification_minimize_btn" id="{index}" framecolor=".7 .7 .7 1" up_color=".3 .3 .3 1" over_color=".5 .5 .5 1" dn_color=".4 .4 .4 1" visible="1"/>
				</panel>
				<panel grow="true" y="2.7h" width="-1.0h" align="center" float="bottom" padding="0.1h" noclick="true">
					<panel grow="true" width="100%" sticky="true" stickytoinvis="false" noclick="true">
						<!-- Dependate Labels -->
						<label name="sp_notification_small_{index}_label_2" fity="true" width="100%" textalign="center" font="dyn_10" style="friends_dependent" shadow="true" content="{label_2}" noclick="true" visible="1"/>
					</panel>

					<panel grow="true" width="100%" align="right" sticky="true" stickytoinvis="false" noclick="true">
						<label name="sp_notification_small_{index}_label_3" fity="true" textalign="center" font="dyn_9" color="white" shadow="true" wrap="true" content="{label_3}" noclick="true"/>
					</panel>

					<panel name="sp_notification_small_{index}_buttons" height="2.3h" width="100%" align="right" noclick="true" sticky="true" stickytoinvis="false">
						<instance name="button2"
							button_name="sp_notification_small_{index}_button_1"
							x="-0.3h"
							width="47%" height="2.2h"
							align="right" valign="bottom"
							borderthickness="0.5h"
							label="general_ignore"
							onclicklua="HoN_Notifications.SmallNotificationButtonClicked(1, {index})"
						/>
						<instance name="button2"
							button_name="sp_notification_small_{index}_button_2"
							x="0.3h"
							width="47%" height="2.2h"
							align="left" valign="bottom"
							borderthickness="0.5h"
							label="general_approve"
							onclicklua="HoN_Notifications.SmallNotificationButtonClicked(2, {index})"
						/>
					</panel>

					<panel height="2.4h" width="100%" sticky="true" stickytoinvis="false" noclick="true">
						<label name="sp_notification_small_{index}_label_4" height="100%" textalign="center" textvalign="center" font="dyn_8" color=".7 .7 .7 1" shadow="true" wrap="true" content="{label_4}" noclick="true"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<panel name="notification_toast_main" y="2.5h" x="-0.5h" width="25.0h" noclick="1" visible="true" align="right" padding="0.4h" color="invisible"
	>
		<instance name="sp_notification_toast_template" index="1" label_1="1" label_2="2" label_3="3" label_4="4" label_5="5" hasExpandBtns="1" hasHoverInfo="1" icon="/ui/fe2/store/icons/account_icons/default.tga" namecolor="red" scaleheight="11.9h" />

		<instance name="sp_notification_toast_template" index="2" label_1="1" label_2="2" label_3="3" label_4="4" label_5="5" hasExpandBtns="1" hasHoverInfo="1" icon="/ui/fe2/store/icons/account_icons/default.tga" namecolor="red" scaleheight="11.9h" />

		<instance name="sp_notification_toast_template" index="3" label_1="1" label_2="2" label_3="3" label_4="4" label_5="5" hasExpandBtns="1" hasHoverInfo="1" icon="/ui/fe2/store/icons/account_icons/default.tga" namecolor="red" scaleheight="11.9h" />
	</panel>
</package>
