									depthclear="false"
									depthcompress="true"
									onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
								/>
							</panel>

							<panel width="100@" height="100%"><!-- 3 -->
								<image texture="/triggers/custom_maps/herowars/heroes/devx/hook_levelups/speed.tga"/>
								<modelpanel
									visible="1"
									noclick="true"
									model="/ui/common/models/toggle/toggle.mdf"
									anim="idle"
									effect="/ui/common/models/toggle/toggle.effect"
									camerapos="0 1 0"
									cameraangles="0 0 180"
									camerafov="45"
									cameranear="1"
									carmerafar="100"
									depthclear="false"
									depthcompress="true"
									onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
								/>
							</panel>

							<panel width="100@" height="100%"><!-- 4 -->
								<image texture="/triggers/custom_maps/herowars/heroes/devx/hook_levelups/width.tga" />
								<modelpanel
									visible="1"
									noclick="true"
									model="/ui/common/models/toggle/toggle.mdf"
									anim="idle"
									effect="/ui/common/models/toggle/toggle.effect"
									camerapos="0 1 0"
									cameraangles="0 0 180"
									camerafov="45"
									cameranear="1"
									carmerafar="100"
									depthclear="false"
									depthcompress="true"
									onshow="SetAnim('idle'); SetEffect('/ui/elements/devowars/loading/toggle.effect'); SetAnimSpeed(0.7)"
								/>
							</panel>
						</panel>
   					</panel>
   					<panel name="map_selection_popup_map_info2_soccer" noclick="1">
   						<label y="10i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_soccer_tip01"/>
   						<label y="115i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_soccer_tip02"/>
   						<label y="145i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_soccer_tip03"/>
   						<label y="190i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_soccer_tip04"/>
   						<label y="235i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_soccer_tip05"/>
						<panel y="65i" height="4h" width="40h">
							<panel y="-1h" float="right" padding="1" width="40h" height="5h" >
								<panel width="12h">
									<panel x="0.5h" width="5h" height="5h" valign="center">
										<frame color="invisible" bordercolor="#666666" borderthickness="1"/>
										<image width="-2" height="-2" align="center" valign="center" texture="/ui/elements/soccer/loading/icon_kick.tga" />
									</panel>
									<panel x="6h" width="6h">
										<label textvalign="center" font="dyn_10" color="#91e0c3" content="map_loading_soccer_tip01_kick"/>
									</panel>
								</panel>
								<panel width="12h">
									<panel x="0.5h" width="5h" height="5h" valign="center">
										<frame color="invisible" bordercolor="#666666" borderthickness="1"/>
										<image width="-2" height="-2" align="center" valign="center" texture="/ui/elements/soccer/loading/icon_slide.tga" />
									</panel>
									<panel x="6h" width="6h">
										<label textvalign="center" font="dyn_10" color="#91e0c3" content="map_loading_soccer_tip01_slide"/>
									</panel>
								</panel>
								<panel width="12h">
									<panel x="0.5h" width="5h" height="5h" valign="center">
										<frame color="invisible" bordercolor="#666666" borderthickness="1"/>
										<image width="-2" height="-2" align="center" valign="center" texture="/ui/elements/soccer/loading/icon_sprint.tga" />
									</panel>
									<panel x="6h" width="6h">
										<label textvalign="center" font="dyn_10" color="#91e0c3" content="map_loading_soccer_tip01_sprint"/>
									</panel>
								</panel>
							</panel>
						</panel>
   					</panel>
   					<panel name="map_selection_popup_map_info2_midwarsbeta" noclick="1">
   						<label y="10i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_midwars_beta_tip01"/>
   						<label y="65i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_midwars_beta_tip02"/>
   						<label y="120i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_midwars_beta_tip03"/>
   						<label y="175i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_midwars_beta_tip04"/>
   					</panel>
   					<panel name="map_selection_popup_map_info2_caldavar_reborn" noclick="1">
   						<label y="10i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_caldavar_reborn_tip01"/>
   						<label y="70i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_caldavar_reborn_tip02"/>
   						<label y="120i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_caldavar_reborn_tip03"/>
   						<label y="175i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_caldavar_reborn_tip04"/>
   						<label y="230i" noclick="1" color="#efd4c1" outline="1" wrap="1" outlinecolor="#230000" font="dyn_11" content="map_loading_caldavar_reborn_tip05"/>
   					</panel>					
   				</panel>
   			</panel>

   			<instance name="newui_common_button_2_template" y="-10i" width="105i" height="32i" align="center" valign="bottom" label="general_ok"
				  onclicklua="GetWidget('map_selection_popup_map_info'):FadeOut(150)"
			/>
   		</panel>
   	</template>

	<panel name="map_selection" visible="0" hotkey="ESC" onhotkeylua="MapSelection_V2:Hide()">
		<image texture="/ui/fe2/newui/res/common/bg.png" width="2048i" height="2048i" align="center" valign="center" noclick="1"/>
		<image texture="/ui/fe2/newui/res/mapselection/line.png" y="123i" width="1700i" height="4i" align="center" noclick="1"/>

		<panel name="map_selection_large" y="185i" width="1752i" height="767i" align="center" noclick="1" visible="0">
			<instance name="map_selection_large_item_template" index="1" x="0"/>
			<instance name="map_selection_large_item_template" index="2" x="305i"/>
			<instance name="map_selection_large_item_template" index="3" x="610i"/>
			<instance name="map_selection_large_item_template" index="4" x="915i"/>
			<instance name="map_selection_large_item_template" index="5" x="1220i"/>
			<instance name="map_selection_large_item_template" index="6" x="1525i"/>
		</panel>

		<panel name="map_selection_small" y="185i" width="1333i" height="767i" align="center" noclick="1" visible="0">
			<instance name="map_selection_small_item_template" index="1" x="0"/>
			<instance name="map_selection_small_item_template" index="2" x="264i"/>
			<instance name="map_selection_small_item_template" index="3" x="528i"/>
			<instance name="map_selection_small_item_template" index="4" x="792i"/>
			<instance name="map_selection_small_item_template" index="5" x="1056i"/>
			<instance name="map_selection_small_item_template" index="6" x="1320i"/>
		</panel>

		<panel name="map_selection_title" align="center" width="1507i" noclick="1">
			<image texture="/ui/fe2/newui/res/mapselection/title_icon.png" y="81i" width="32i" height="32i" noclick="1"/>
			<label x="48i" y="81i" height="32i" textalign="left" textvalign="center" font="dyn_24" color="#a1867d" outline="1" outlinecolor="#230000" noclick="1" content="newui_mapselection_title"/>
			<if condition="cl_GarenaEnable">
				<button width="156i" height="32i" x="-305i" y="81i" align="right" color="invisible" onclicklua="MapSelection_V2:OnClickHostedGame()">
					<widgetstate statename="up">
						<image texture="/ui/fe2/newui/res/mapselection/hg_up.png" width="256i" height="32i" align="center" valign="center" noclick="1"/>
						<image texture="/ui/fe2/newui/res/mapselection/hg_icon.png" x="3i" width="32i" height="32i" valign="center" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_hostedgame" noclick="1"/>
					</widgetstate>
					<widgetstate statename="over">
						<image texture="/ui/fe2/newui/res/mapselection/hg_over.png" width="256i" height="32i" align="center" valign="center" noclick="1"/>
						<image texture="/ui/fe2/newui/res/mapselection/hg_icon.png" x="3i" width="32i" height="32i" valign="center" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_hostedgame" noclick="1"/>
					</widgetstate>
					<widgetstate statename="down">
						<image texture="/ui/fe2/newui/res/mapselection/hg_over.png" width="256i" height="32i" align="center" valign="center" noclick="1"/>
						<image texture="/ui/fe2/newui/res/mapselection/hg_icon.png" x="3i" width="32i" height="32i" valign="center" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_hostedgame" noclick="1"/>
					</widgetstate>
					<widgetstate statename="disabled">
						<image texture="/ui/fe2/newui/res/mapselection/hg_up.png" width="256i" height="32i" align="center" valign="center" rendermode="grayscale" noclick="1"/>
						<image texture="/ui/fe2/newui/res/mapselection/hg_icon.png" x="3i" width="32i" height="32i" valign="center" rendermode="grayscale" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_hostedgame" noclick="1"/>
					</widgetstate>
				</button>
			</if>
			
			<panel name="map_selection_openregion" x="40h" y="81i" width="30h" height="32i" align="left" float="right" padding="1h" color="invisible">
				<panel width="8h" noclick="1">
					<label x="0" y="0.3h" height="32i" textalign="center" textvalign="center" font="dyn_14" color="#a1867d" outline="1" outlinecolor="#230000" noclick="1" content="newui_mapselection_region2"/>
				</panel>
				<instance name="map_selection_region_item_template" id="1"/>
				<instance name="map_selection_region_item_template" id="2"/>
				<instance name="map_selection_region_item_template" id="3"/>
				<instance name="map_selection_region_item_template" id="4"/>
				<instance name="map_selection_region_item_template" id="5"/>
				<instance name="map_selection_region_item_template" id="6"/>
				<instance name="map_selection_region_item_template" id="7"/>
				<instance name="map_selection_region_item_template" id="8"/>
				<instance name="map_selection_region_item_template" id="9"/>
				<instance name="map_selection_region_item_template" id="10"/>
			</panel>

			<instance name="newui_button_close_template" y="81i" align="right" type="2" onclicklua="MapSelection_V2:Hide()"/>

			<panel name="map_selection_disable_desc" y="-70i" grow="1" regrow="1" width="210i" valign="bottom" align="right" noclick="1" visible="0">
				<instance name="newui_custom_frame_template" />
				<panel width="-16i" align="center" grow="1" regrow="1" noclick="1">
					<label name="map_selection_disable_desc_text" font="dyn_10" textalign="center" textvalign="center" noclick="1" vpadding="20i" color="#ad9181" shadow="1" wrap="1" fity="1" fitypadding="0.8h"/>
				</panel>
			</panel>

			<instance name="newui_common_button_1_template" button_name="map_selection_startgame" y="-20i" width="210i" height="47i" align="right" valign="bottom" font="dyn_16" content="newui_mapselection_startgame" onclicklua="MapSelection_V2:OnStartGame()"
			/>
		</panel>

		<panel name="map_selection_mask" visible="0"/>
	</panel>

	<panel name="map_selection_trigger_help" width="1" height="1" noclick="1" onloadlua="MapSelection_V2:Init()" onframelua="MapSelection_V2:OnFrame()"/>
</package>