	<!-- Quit  -->
	<!-- Quit Body - Can Leave -->
	<template name="quit_confirm_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">

			<panel grow="1" height="3.5h" width="100%">
				<label fity="1" width="-1.0h" align="center" valign="center" textalign="center" style="newui_font_style_12" wrap="1" content="main_quit_confirm2"/>
			</panel>

			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('quit_confirm', 'FadeOut(250);');]])"
				/>
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="main_button_quit"
					onclicklua="
						if(GetCvarBool('cg_banjo_sound')) then
							StopMusic()
							PlaySound('/shared/sounds/ui/quit.wav')
							self:Sleep(1400, function() self:UICmd('Quit()') end)
						else
							self:UICmd('Quit()')
						end
					"
				/>
			</panel>
		</panel>
	</template>
	<template name="quit_confirm">
		<panel name="quit_confirm" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()">
			<instance name="newui_common_popup" y="20h" width="30h" valign="top" id="quit_confirm_content" visible="1" show_close="1"
				title="main_quit_confirm"
				content="quit_confirm_body"
				oncloselua="self:UICmd([[Call('quit_confirm', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

