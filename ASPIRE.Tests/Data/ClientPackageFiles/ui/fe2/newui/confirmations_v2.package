		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel y="1.0h" grow="1" width="100%" noclick="1">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_12" wrap="1" content="main_graphicsdriverold_confirm2"/>
			</panel>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" width="12h" height="2.5h" align="center" valign="top" label="general_confirm"
					onclicklua="self:UICmd([[Call('graphicsdriverold_confirm', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
