		<panel name="graphicsdriverold_confirm" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()" onloadlua="--self:SetVisible(GetCvarBool('host_graphicsdriverold')) Set('host_graphicsdriverold', false)">
			<instance name="newui_common_popup" y="20h" width="35h" valign="top" id="graphicsdriverold_confirm_content" visible="1" show_close="1"
				title="main_graphicsdriverold_confirm"
				content="graphicsdriverold_confirm_body"
				oncloselua="self:UICmd([[Call('graphicsdriverold_confirm', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Quit Body - Leaver -->
	<template name="quit_confirm_leaver_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">

			<panel y="1.0h" grow="1" width="100%" noclick="1">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" content="main_quit_confirm2" noclick="1"/>
			</panel>

			<panel grow="1" width="100%" noclick="1" visible="1">
				<panel grow="1" width="-2.0h" align="center">
					<instance name="newui_custom_frame_template"/>
					<panel y="0.5h" float="bottom" noclick="1" color="invisible" grow="1" width="-2.0h" align="center">
						<panel width="100%" height="2.0h" noclick="1">
							<label textalign="left" textvalign="center" style="newui_font_style_11" noclick="1" content="game_menu_currentleavepercent"/>
							<label textalign="right" textvalign="center" style="newui_font_style_11" noclick="1" watch="AccountInfo" ontrigger="SetText(FtoA(param8 * 100, 2) # '%');"/>
						</panel>
						<panel width="100%" height="2.0h" noclick="1">
							<label textalign="left" textvalign="center" style="newui_font_style_11" noclick="1" content="game_menu_newleavepercent"/>
							<label textalign="right" textvalign="center" style="newui_font_style_11" noclick="1" watch="AccountInfo" ontrigger="SetText(FtoA(param9 * 100, 2) # '%');"/>
						</panel>
						<panel width="100%" height="2.0h" noclick="1">
							<label textalign="left" textvalign="center" style="newui_font_style_11" noclick="1" content="game_menu_newleavethreshold"/>
							<label textalign="right" textvalign="center" style="newui_font_style_11" noclick="1" watch="AccountInfo" ontrigger="SetText(FtoA(param10 * 100, 2) # '%');"/>
						</panel>

						<panel width="100%" color="invisible" grow="1" noclick="1">
							<label fity="1" fitypadding="0.5h" width="100%" font="dyn_10" color="#3abde7" shadow="1" wrap="1" noclick="1" watch="AccountInfo" ontrigger="SetText(Translate(If(param7, 'confirm_leaver_result_nowleaver', 'confirm_leaver_result_notleaver')));"/>
						</panel>
					</panel>
				</panel>
			</panel>

			<panel height="0" noclick="1"/>

			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('quit_confirm_leaver', 'FadeOut(250);');]])"
				/>
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="main_button_quit"
					onclicklua="
						if(GetCvarBool('cg_banjo_sound')) then
							StopMusic()
							PlaySound('/shared/sounds/ui/quit.wav')
							self:Sleep(1400, function() self:UICmd('Quit()') end)
						else
							self:UICmd('Quit()')
						end
					"
				/>
			</panel>
		</panel>
	</template>
	<template name="quit_confirm_leaver">
		<panel name="quit_confirm_leaver" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()">
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="quit_confirm_leaver_content" visible="1" show_close="1"
				title="confirm_disconnect_title"
				content="quit_confirm_leaver_body"
				oncloselua="self:UICmd([[Call('quit_confirm_leaver', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Disband Confirm - Note this used to be a disband game confirmation, but now it's labeled as a disconnect and doesn't necessarily disband the game,
		the server tries to assign a new host when the player disconnects, so it won't disband the game unless there are no other players in the game -->
	<template name="disband_confirm_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel y="0.5h" grow="1" width="100%">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_12" wrap="1" content="game_menu_disconnect_confirm"/>
			</panel>

			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('disband_confirm', 'FadeOut(250);');]])"
				/>
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="gamelobby_disconnect_button"
					onclicklua="self:UICmd([[Disconnect(); Call('disband_confirm', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
	<template name="disband_confirm">
		<panel name="disband_confirm" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()">
			<instance name="newui_common_popup" y="20h" width="33h" valign="top" id="disband_confirm_content" visible="1" show_close="1"
				title="gamelobby_disconnect_button"
				content="disband_confirm_body"
				oncloselua="self:UICmd([[Call('disband_confirm', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Generic Dialog Box
		TriggerDialogBox
		0 - Header
		1 - Left Button Label
		2 - Right Button Label
		3 - Left Button Onclick
		4 - Right Button Onclick
		5 - Text Header
		6 - Text
		7 - Left Button lua onclick
		8 - Right Button lua onclick
	-->
	<trigger name="TriggerDialogBox"/>
	<template name="generic_dialog_box_template">
		<panel name="generic_dialog_box" visible="0" color="0 0 0 .7" onshowlua="self:BringToFront()" 
				watch="TriggerDialogBox" ontriggerlua="if NotEmpty(param0) then self:FadeIn(150) else self:FadeOut(150) end"
				hotkey="ESC"
				onhotkeylua="GetWidget('generic_dialog_box'):FadeOut(150)"
		>
			<panel y="-10h" width="36h" align="center" valign="center" grow="1" regrow="1" growinvis="0" noclick="1">
				<instance name="newui_popup_caption_frame"
					watch="TriggerDialogBox"
					ontriggerlua="if NotEmpty(param0) then self:SetText(Translate(param0)) end"
					onclicklua="GetWidget('generic_dialog_box'):FadeOut(150)"
				/>
				<panel y="3.5h" width="36h" float="bottom" padding="1h" grow="1" regrow="1" growinvis="0" noclick="1">
					<panel width="100%" grow="1" regrow="1" growinvis="0" stickytoinvis="0" watch="TriggerDialogBox" ontriggerlua="self:SetVisible(NotEmpty(param5))">
						<label y=".5h" fity="1" width="-1.0h" align="center" textalign="center" textvalign="top" style="newui_font_style_11" wrap="1"
							watch="TriggerDialogBox" ontriggerlua="if NotEmpty(param5) then self:SetText(FormatStringNewline(Translate(param5))) end"
						/>
					</panel>

					<panel width="-1h" align="center" grow="1" regrow="1" growinvis="0" stickytoinvis="0" noclick="1" watch="TriggerDialogBox" ontriggerlua="self:SetVisible(NotEmpty(param6))">
						<instance name="newui_custom_frame_template" rgb="0 0 0" alpha="0.5"/>
						<label fity="1" fitypadding="1.5h" wrap="1" width="-.5h" align="center" textalign="center" textvalign="center" style="newui_font_style_10" noclick="1" watch="TriggerDialogBox" ontriggerlua="if NotEmpty(param6) then self:SetText(FormatStringNewline(Translate(param6))) end"/>
					</panel>

					<panel align="center" height="3.5h" grow="1" growinvis="0" stickytoinvis="0" float="right" padding="1h" noclick="1">
						<instance name="newui_common_button_2_template" width="15h" height="2.5h"
							button_name="generic_dialog_box_left_btn"
							onclicklua="GetWidget('generic_dialog_box'):FadeOut(150)"
							watch="TriggerDialogBox"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_box\', \'FadeOut(250);\');
									'#param3#'
								');
							"
							ontriggerlua="
								local callback = param7
								if NotEmpty(callback) then
									self:SetCallback('onclick', function() GetWidget('generic_dialog_box'):FadeOut(150) loadstring(callback)() end)
								end
							"
							labelwatch="TriggerDialogBox"
							labelontriggerlua="GetWidget('generic_dialog_box_left_btn'):SetVisible(NotEmpty(param1)) if NotEmpty(param1) then self:SetText(Translate(param1)) end"
						/>
						<instance name="newui_common_button_2_template" width="15h" height="2.5h"
							button_name="generic_dialog_box_right_btn"
							onclicklua="self:UICmd([[Call('generic_dialog_box', 'FadeOut(250);');]])"
							watch="TriggerDialogBox"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_box\', \'FadeOut(250);\');
									'#param4#'
								');
							"
							ontriggerlua="
								local callback = param8
								if NotEmpty(callback) then
									self:SetCallback('onclick', function() GetWidget('generic_dialog_box'):FadeOut(150) loadstring(callback)() end)
								end
							"
							labelwatch="TriggerDialogBox"
							labelontriggerlua="GetWidget('generic_dialog_box_left_btn'):SetVisible(NotEmpty(param2)) if NotEmpty(param2) then self:SetText(Translate(param2)) end"
						/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="newui_combobox_container">
		<panel width="{width=100%}" height="{height=2.5h}" align="center" noclick="1" onshow="{onshow}" sticky="true" stickytoinvis="false">
			<panel width="96%" align="center">
				<panel width="-2.6h" height="100%" valign="center" align="left" noclick="true">
					<panel width="{labelwidth=40%}">
						<label textvalign="center" fitx="1" fitxpadding=".5h" style="newui_font_style_10">{label}</label>
					</panel>
					<panel width="-{labelwidth=40%}" height="2.2h" valign="center" align="right">
						<image x="-12%" width="32i" height="32i" valign="center" hflip="1" texture="/ui/fe2/newui/res/communicator/arrow.png" noclick="1"/>
						<instance name="newui_combobox_template" id="{id}" font="{font=dyn_12}" x="0" maxlistheight="{maxlistheight=10}" cvar="{cvar}" data="{data}" onselect="{onselect}" populate="{populate}" />
					</panel>
				</panel>
				<instance name="newui_tip_button_template" title="{tip_label}" desc="{tip_desc}" tip_width="30h" valign="center" align="right"/>
			</panel>
		</panel>
	</template>

	<!-- Generic Dialog Box
		HTTriggerDialogBox
		0 - Header
		1 - Left Button Label
		2 - Right Button Label
		3 - Left Button Onclick
		4 - Right Button Onclick
		5 - Text Header
		6 - Text
		7 - Show dropdown (HoN Tour Only atm).
		8 - Show dropdown (HoN Tour Only atm).
		HoN Tour dropdowns need to be reworked, don't use them for anything else atm.
	-->
	<trigger name="HTTriggerDialogBox"/>
	<template name="generic_ht_dialog_box_template">
		<panel name="generic_ht_dialog_box" visible="0" color="0 0 0 .7" onshowlua="self:BringToFront()" watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param0), FadeIn(250), FadeOut(250));">
			<panel y="-10h" width="36h" align="center" valign="center" grow="1" regrow="1" growinvis="0" noclick="1">
				<instance name="newui_popup_caption_frame" title=""
					watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param0), SetText(Translate(param0)));"
					btn_watch="HTTriggerDialogBox" btn_ontrigger="SetVisible(!StringEmpty(''#param2));"
					onclick="Call('generic_ht_dialog_box', 'FadeOut(250);');"
				/>
				<panel y="3.5h" width="36h" float="bottom" padding="1h" grow="1" regrow="1" growinvis="0" reverse="1" noclick="1">
					<panel y="1.0h" width="100%" grow="1" regrow="1" growinvis="0" stickytoinvis="0" watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param5), SetVisible(1), SetVisible(0));" noclick="1">
						<label fity="1" width="-1.0h" align="center" textalign="center" textvalign="top" style="newui_font_style_11" wrap="1"
							watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param5), SetText(Translate(param5)));"
						/>
					</panel>

					<panel width="100%" grow="1" regrow="1" growinvis="1" stickytoinvis="0" visible="0" watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param8), SetVisible(param8));" noclick="1"
					>
						<instance name="newui_combobox_container" id="confirmations_generic_ht_dialog_dropdown_1" label="hontour_select_event" cvar="" data="" onshow="BringToFront();" tip_label="hontour_multiple_events" tip_desc="hontour_multiple_events_tip"/>
					</panel>

					<panel width="100%" grow="1" regrow="1" growinvis="1" stickytoinvis="0" visible="0" watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param7), SetVisible(param7));" noclick="1"
					>
						<instance name="newui_combobox_container" id="confirmations_generic_ht_dialog_dropdown_2" label="hontour_select_match" cvar="" data="" onshow="BringToFront();" tip_label="hontour_multiple_matches" tip_desc="hontour_multiple_matches_tip"/>
					</panel>

					<panel width="-1h" align="center" grow="1" regrow="1" growinvis="0" stickytoinvis="0" watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param6), SetVisible(1), SetVisible(0));" noclick="1">
						<instance name="newui_custom_frame_template" rgb="0 0 0" alpha="0.5"/>
						<label fity="1" fitypadding="1.5h" wrap="1" width="-.5h" align="center" textalign="center" textvalign="center" style="newui_font_style_10" noclick="1" watch="HTTriggerDialogBox" ontrigger="If(!StringEmpty(param6), SetText(Translate(param6)));"/>
					</panel>

					<panel width="-1h" align="center" height="3.5h" sticky="1" stickytoinvis="0" noclick="1">
						<instance name="newui_common_button_2_template" x="-8h" y="-0.25h" width="15h" height="2.5h" align="center"
							button_name="generic_ht_dialog_box_left_btn"
							onclicklua="self:UICmd([[Call('generic_ht_dialog_box', 'FadeOut(250);');]])"
							watch="HTTriggerDialogBox"
							ontrigger="
								SetOnClick('
									Call(\'generic_ht_dialog_box\', \'FadeOut(250);\');
									'#param3#'
								');
								SetVisible(!StringEmpty(''#param1));
							"
							labelwatch="HTTriggerDialogBox"
							labelontrigger="If(!StringEmpty(param1), SetText(Translate(param1)));"
						/>
						<instance name="newui_common_button_2_template" x="8h" y="-0.25h" width="15h" height="2.5h" align="center"
							button_name="generic_ht_dialog_box_right_btn"
							onclicklua="self:UICmd([[Call('generic_ht_dialog_box', 'FadeOut(250);');]])"
							watch="HTTriggerDialogBox"
							ontrigger="
								SetOnClick('
									Call(\'generic_ht_dialog_box\', \'FadeOut(250);\');
									'#param4#'
								');
								SetVisible(!StringEmpty(''#param2));
							"
							labelwatch="HTTriggerDialogBox"
							labelontrigger="If(!StringEmpty(param2), SetText(Translate(param2)));"
						/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- Generic Dialog Box (for web requests)
		TriggerDialogBoxWebRequest
		0 - Header
		1 - Left Button Label
		2 - Right Button Label
		3 - Left Button Onclick
		4 - Right Button Onclick
		5 - Text Header
		6 - Text
		7 - WebForm Status Trigger 	<< added 12/10/12 >>
		8 - WebForm Results Trigger
		9 - On WebForm Results
		10 - Success Text Header
		11 - Success Text
	-->
	<trigger name="TriggerDialogBoxWebRequest"/>
	<template name="generic_dialog_box_wr_template">
		<panel name="generic_dialog_box_wr" visible="0" color="0 0 0 .7" onshowlua="self:BringToFront()" watch="TriggerDialogBoxWebRequest" ontrigger="If(!StringEmpty(param0), FadeIn(250), FadeOut(250));" onhide="ClientRefreshUpgrades(); ClientRefreshInfos();" >
			<!-- web form helper -->
			<panel name="generic_dialog_box_wr_webhelper" noclick="1"
				watch1="TriggerDialogBoxWebRequest"
				ontrigger1="
					If(!StringEmpty(param7),
						Split(
							SetWatch(2, param7),
							SetWatch(3, param8)
						),
						Split(
							SetWatch(2, ''),
							SetWatch(3, '')
						)
					);
					SetOnTrigger(3,
						'If(StringEmpty(param0),
							Split(
								Trigger(\'TriggerDialogBox\', Translate(\'general_success\'), \'\', Translate(\'general_ok\'), \'\', \'\', FormatStringNewline(Translate(\''#param10#'\')), FormatStringNewline(Translate(\''#param11#'\'))),
								Call(\'generic_dialog_box_wr\', \'FadeOut(100);\')
							),
							Split(
								EnableWidget(\'generic_dialog_box_wr_left_btn\'),
								Call(\'generic_dialog_box_wr_throb\', \'SetVisible(0);\'),
								GroupCall(\'generic_dialog_box_wr_left_group\', \'SetText(Translate(\\\'general_retry\\\'))\'),
								GroupCall(\'generic_dialog_box_wr_right_group\', \'SetText(Translate(\\\'general_cancel\\\'))\'),
								Call(\'generic_dialog_bodymain\', \'SetText(Translate(\\\'\'#param0#\'\\\'))\')
							)
						);
						'#param9
					);
				"
				ontrigger2="
					If(param == 3,
						Split(
							EnableWidget('generic_dialog_box_wr_left_btn'),
							Call('generic_dialog_box_wr_throb', 'SetVisible(0);'),
							GroupCall('generic_dialog_box_wr_left_group', 'SetText(Translate(\'general_retry\'))'),
							GroupCall('generic_dialog_box_wr_right_group', 'SetText(Translate(\'general_cancel\'))'),
							Call('generic_dialog_bodymain', 'SetText(Translate(\'mstore_error_connect\'))')
						)
					);
				"
				onhide="SetWatch(2, ''); SetWatch(3, '');"
			/>

			<panel y="-10h" width="36h" align="center" valign="center" grow="1" regrow="1" growinvis="0" noclick="1">
				<instance name="newui_popup_caption_frame" title=""
					watch="TriggerDialogBoxWebRequest" ontrigger="If(!StringEmpty(param0), SetText(Translate(param0)));"
					onclick="Call('generic_dialog_box_wr', 'FadeOut(250);');"
				/>
				<panel y="3.5h" width="36h" float="bottom" padding="1h" grow="1" regrow="1" growinvis="0" noclick="1">
					<panel y="1.0h" grow="1" regrow="1" growinvis="0" stickytoinvis="0" width="100%" watch="TriggerDialogBoxWebRequest" ontriggerlua="self:SetVisible(NotEmpty(param5))" >
						<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" watch="TriggerDialogBoxWebRequest" ontriggerlua="if NotEmpty(param5) then self:SetText(FormatStringNewline(Translate(param5))) end"
						/>
					</panel>

					<panel width="-1h" align="center" grow="1" regrow="1" growinvis="0" stickytoinvis="0" watch="TriggerDialogBoxWebRequest" ontrigger="If(!StringEmpty(param6), SetVisible(1), SetVisible(0));" noclick="1">
						<instance name="newui_custom_frame_template" rgb="0 0 0" alpha="0.5"/>
						<label name="generic_dialog_bodymain" fity="1" fitypadding="1.5h" wrap="1" width="-.5h" align="center" textalign="center" textvalign="center" style="newui_font_style_10" noclick="1" watch="TriggerDialogBoxWebRequest" ontriggerlua="if NotEmpty(param6) then self:SetText(FormatStringNewline(Translate(param6))) end"/>
					</panel>

					<panel height="3.5h" sticky="1" stickytoinvis="0" noclick="1">
						<instance name="newui_common_button_2_template" x="-8h" y="-0.25h" width="15h" height="2.5h" align="center"
							button_name="generic_dialog_box_wr_left_btn"
							onclicklua="self:UICmd([[Call('generic_dialog_box_wr', 'FadeOut(250);');]])"
							watch="TriggerDialogBoxWebRequest"
							ontrigger="
								EnableWidget('generic_dialog_box_wr_left_btn');
								SetOnClick('
									If(StringEmpty(\''#param7#'\'),
										Call(\'generic_dialog_box_wr\', \'FadeOut(250);\'),
										Split(
											DisableWidget(\'generic_dialog_box_wr_left_btn\'),
											Call(\'generic_dialog_box_wr_throb\', \'SetVisible(1)\')
										)
									);
									'#param3#'
								');
							"
							labelgroup="generic_dialog_box_wr_left_group"
							labelwatch="TriggerDialogBoxWebRequest"
							labelontrigger="If(!StringEmpty(param1), Split(SetText(Translate(param1)), Call('generic_dialog_box_wr_left_btn', 'SetVisible(1)')), Call('generic_dialog_box_wr_left_btn', 'SetVisible(0)'));"
						/>

						<!-- throb over left button -->
						<animatedimage name="generic_dialog_box_wr_throb" x="-8h" y="-0.5h" align="center" valign="center" texture="/ui/elements/throb/throb.tga" noclick="1" loop="1" fps="30" onshow="StartAnim(1);" visible="0" height="3h" width="3h" watch="TriggerDialogBoxWebRequest" ontriggerlua="self:SetVisible(false)"/>

						<instance name="newui_common_button_2_template" x="8h" y="-0.25h" width="15h" height="2.5h" align="center"
							button_name="generic_dialog_box_wr_right_btn"
							onclicklua="self:UICmd([[Call('generic_dialog_box_wr', 'FadeOut(250);');]])"
							watch="TriggerDialogBoxWebRequest"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_box_wr\', \'FadeOut(250);\');
									'#param4#'
								');
							"
							labelgroup="generic_dialog_box_wr_right_group"
							labelwatch="TriggerDialogBoxWebRequest"
							labelontrigger="If(!StringEmpty(param2), Split(SetText(Translate(param2)), Call('generic_dialog_box_wr_right_btn', 'SetVisible(1)')), Call('generic_dialog_box_wr_right_btn', 'SetVisible(0)'));"
						/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- Generic Dialog Box with Combobox
		TriggerDialogBoxWithCombobox
		0 - Header
		1 - Left Button Label
		2 - Right Button Label
		3 - Left Button Onclick
		4 - Right Button Onclick
		5 - Text Header
		6 - Text
		7 - Combobox Text
		8 - Combobox Variable
	-->
	<trigger name="TriggerDialogBoxWithCombobox"/>
	<template name="generic_dialog_box_combo_template">
		<panel name="generic_dialog_box_combo" visible="0" color="0 0 0 .7" onshowlua="self:BringToFront()" watch="TriggerDialogBoxWithCombobox" ontrigger="If(!StringEmpty(param0), FadeIn(250), FadeOut(250));">
			<panel y="-10h" width="36h" align="center" valign="center" grow="1" regrow="1" growinvis="0" noclick="1">
				<instance name="newui_popup_caption_frame" title=""
					watch="TriggerDialogBoxWithCombobox" ontrigger="If(!StringEmpty(param0), SetText(Translate(param0)));"
					onclick="Call('generic_dialog_box_combo', 'FadeOut(250);');"
				/>
				<panel y="3.5h" width="35h" align="center" float="bottom" padding="1h" grow="1" regrow="1" growinvis="0" reverse="1" noclick="1">
					<panel y="1.0h" grow="1" regrow="1" growinvis="0" stickytoinvis="0" width="100%" watch="TriggerDialogBoxWithCombobox" ontriggerlua="self:SetVisible(NotEmpty(param5))" >
						<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" watch="TriggerDialogBoxWithCombobox" ontriggerlua="if NotEmpty(param5) then self:SetText(FormatStringNewline(Translate(param5))) end"
						/>
					</panel>

					<panel width="100%" grow="1" regrow="1" growinvis="0" stickytoinvis="0" noclick="1" watch="TriggerDialogBoxWithCombobox" ontriggerlua="self:SetVisible(NotEmpty(param6))" >
						<label width="-1.0h" align="center" fity="1" fitypadding="2h" wrap="1" textalign="center" textvalign="center" style="newui_font_style_10" noclick="1" watch="TriggerDialogBoxWithCombobox" ontriggerlua="if NotEmpty(param6) then self:SetText(FormatStringNewline(Translate(param6))) end"/>
					</panel>

					<panel width="-1h" align="center" height="3.5h" sticky="1" stickytoinvis="0" noclick="1">
						<instance name="newui_common_button_2_template" x="-8h" y="-0.25h" width="15h" height="2.5h" align="center"
							button_name="generic_dialog_box_combo_left_btn"
							onclicklua="self:UICmd([[Call('generic_dialog_box_combo', 'FadeOut(250);');]])"
							watch="TriggerDialogBoxWithCombobox"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_box_combo\', \'FadeOut(250);\');
									'#param3#'
								');
							"
							labelwatch="TriggerDialogBoxWithCombobox"
							labelontrigger="If(!StringEmpty(param1), Split(SetText(Translate(param1)), Call('generic_dialog_box_combo_left_btn', 'SetVisible(1)')), Call('generic_dialog_box_combo_left_btn', 'SetVisible(0)'));"
						/>
						<instance name="newui_common_button_2_template" x="8h" y="-0.25h" width="15h" height="2.5h" align="center"
							button_name="generic_dialog_box_combo_right_btn"
							onclicklua="self:UICmd([[Call('generic_dialog_box_combo', 'FadeOut(250);');]])"
							watch="TriggerDialogBoxWithCombobox"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_box_combo\', \'FadeOut(250);\');
									'#param4#'
								');
							"
							labelwatch="TriggerDialogBoxWithCombobox"
							labelontrigger="If(!StringEmpty(param2), Split(SetText(Translate(param2)), Call('generic_dialog_box_combo_right_btn', 'SetVisible(1)')), Call('generic_dialog_box_combo_right_btn', 'SetVisible(0)'));"
						/>
					</panel>

					<panel align="center" height="2.4h" grow="1" regrow="1" float="right" padding="0.5h"
						watch="TriggerDialogBoxWithCombobox"
						ontriggerlua="
							self:SetVisible(NotEmpty(param7) and NotEmpty(param8))

							local cvarStr = param8
							local populateCheckbox = function(checked, mouseOver)
								GetWidget('generic_dialog_combobox_checkmark'):SetVisible(checked)
								local labelWidget = GetWidget('generic_dialog_combobox_label')
								if (mouseOver) then
									labelWidget:SetColor('#3abde7')
								elseif (checked) then
									labelWidget:SetColor('#ffaa00')
								else
									labelWidget:SetColor('white')
								end
							end
							local onClickFunc = function()
								local cvarValue = not GetCvarBool(cvarStr)
								SetSave(cvarStr, cvarValue, 'bool')
								populateCheckbox(cvarValue, true)
							end
							local onMouseOverFunc = function()
								PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
								populateCheckbox(GetCvarBool(cvarStr), true)
							end
							local onMouseOutFunc = function()
								populateCheckbox(GetCvarBool(cvarStr), false)
							end
							self:SetCallback('onclick', onClickFunc)
							self:SetCallback('onmouseover', onMouseOverFunc)
							self:SetCallback('onmouseout', onMouseOutFunc)
							self:RefreshCallbacks()

							populateCheckbox(GetCvarBool(cvarStr), false)
						"
					>
						<panel width="1.5h" height="1.5h" noclick="1">
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1"/>
							<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
							<image name="generic_dialog_combobox_checkmark" texture="/ui/elements/check.tga" noclick="1"/>
						</panel>
						<label name="generic_dialog_combobox_label" fitx="1" fity="1" textvalign="center" font="dyn_10" color="white" shadow="1" watch="TriggerDialogBoxWithCombobox" ontriggerlua="self:SetText(Translate(param7))" noclick="1"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

