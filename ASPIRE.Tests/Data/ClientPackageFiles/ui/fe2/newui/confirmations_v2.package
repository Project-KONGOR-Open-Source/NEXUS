	<!-- Generic Dialog Box
		TriggerDialogBoxGame
		0 - Header
		1 - Left Button Label
		2 - Right Button Label
		3 - Left Button Onclick
		4 - Right Button Onclick
		5 - Text Header
		6 - Text
	-->
	<trigger name="TriggerDialogBoxGame"/>
	<template name="generic_dialog_box_game_template">
		<panel name="generic_dialog_game_box" visible="0" color="0 0 0 .1" onshowlua="self:BringToFront()" noclick="
			1" watch="TriggerDialogBoxGame" ontrigger="If(!StringEmpty(param0), FadeIn(250), FadeOut(250));">
