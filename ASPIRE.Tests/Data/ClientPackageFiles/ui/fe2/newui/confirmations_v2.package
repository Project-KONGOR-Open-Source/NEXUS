<?xml version="1.0" encoding="UTF-8"?>
<package>

	<!-- Warn Unverified  -->
	<trigger name="WarnUnverifiedTrigger"/>
	<template name="warn_unverified_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%">
				<label fity="1" width="-2h" align="center" textalign="center" style="newui_font_style_11" wrap="1" content="confirm_warn_unverified_msg" watch="WarnUnverifiedTrigger" ontriggerlua="self:SetText(Translate('confirm_warn_unverified_msg', 'player', param0))"/>
			</panel>
			<panel height="0" noclick="1"/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-9h" width="16h" height="2.5h" align="center" label="confirm_warn_unverified_no"
					onclicklua="self:UICmd([[Call('warn_unverified', 'FadeOut(250);');]])"
					watch="WarnUnverifiedTrigger"
					ontrigger="
						SetOnClick('
							Call(\'warn_unverified\', \'FadeOut(250);\');
							'#param2#'
						');
					"
				/>
				<instance name="newui_common_button_2_template" x="9h" width="16h" height="2.5h" align="center" label="confirm_warn_unverified_yes"
					onclicklua="self:UICmd([[Call('warn_unverified', 'FadeOut(250);');]])"
					watch="WarnUnverifiedTrigger"
					ontrigger="
						SetOnClick('
							Call(\'warn_unverified\', \'FadeOut(250);\');
							'#param1#'
						');
					"
				/>
			</panel>
		</panel>
	</template>
	<template name="warn_unverified">
		<panel name="warn_unverified" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()"
			watch="WarnUnverifiedTrigger"
			ontriggerlua="if NotEmpty(param0) then self:FadeIn(250) else self:FadeOut(250) end"
		>
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="warn_unverified_content" visible="1" show_close="1"
				title="confirm_warn_unverified_title"
				content="warn_unverified_body"
				oncloselua="self:UICmd([[Call('warn_unverified', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Warn NotEligibleForCampaign  -->
	<trigger name="WarnNotEligibleForCampaignTrigger"/>
	<template name="warn_noteligibleforcampaign_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%">
				<label fity="1" width="-2h" align="center" textalign="center" style="newui_font_style_11" wrap="1" content="confirm_warn_noteligibleforcampaign_msg" watch="WarnNotEligibleForCampaignTrigger" ontriggerlua="self:SetText(Translate('confirm_warn_noteligibleforcampaign_msg', 'player', param0))"/>
			</panel>
			<panel height="0" noclick="1"/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" width="15h" height="2.5h" align="center" label="confirm_warn_unverified_no"
					onclicklua="self:UICmd([[Call('warn_noteligibleforcampaign', 'FadeOut(250);');]])"
					watch="WarnNotEligibleForCampaignTrigger"
					ontrigger="
						SetOnClick('
							Call(\'warn_noteligibleforcampaign\', \'FadeOut(250);\');
							'#param1#'
						');
					"
				/>
			</panel>
		</panel>
	</template>
	<template name="warn_noteligibleforcampaign">
		<panel name="warn_noteligibleforcampaign" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()"
			watch="WarnNotEligibleForCampaignTrigger" ontriggerlua="if NotEmpty(param0) then self:FadeIn(250) else FadeOut(250) end"
		>
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="warn_noteligibleforcampaign_content" visible="1" show_close="1"
				title="confirm_warn_noteligibleforcampaign_title"
				content="warn_noteligibleforcampaign_body"
				oncloselua="self:UICmd([[Call('warn_noteligibleforcampaign', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Warn Tokens  -->
	<trigger name="WarnTokensTrigger"/>
	<template name="warn_tokens_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%">
				<image x="1.5h" width="5.4h" height="5.4h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="1"/>
				<label x="-1.5h" fity="1" width="-9.5h" align="right" textalign="center" style="newui_font_style_11" wrap="1" content="confirm_warn_tokens_msg"/>
			</panel>
			<panel height="2.4h" noclick="1" align="center"
				onload="If(!VarExists('warn_tokens_dontask'), DoEvent()); Instantiate('newui_checkbox_template', 'width', '24.0h', 'align', 'right', 'valign', 'center', 'font', 'dyn_10', 'content', 'confirm_token_warn_da', 'cvar', 'warn_tokens_dontask'); "
				onevent="CreateBool('warn_tokens_dontask', 0); SetSave('warn_tokens_dontask');"
			>
			</panel>
			<panel height="0" noclick="1"/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('warn_tokens', 'FadeOut(250);');]])"
					watch="WarnTokensTrigger"
					ontrigger="
						SetOnClick('
							Call(\'warn_tokens\', \'FadeOut(250);\');
							'#param0#'
						');
					"
				/>
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="general_ok"
					onclicklua="self:UICmd([[Call('warn_tokens', 'FadeOut(250);');]])"
					watch="WarnTokensTrigger"
					ontrigger="
						SetOnClick('
							Call(\'warn_tokens\', \'FadeOut(250);\');
							'#param1#'
						');
					"
				/>
			</panel>
		</panel>
	</template>
	<template name="warn_tokens">
		<panel name="warn_tokens" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()"
			watch="WarnTokensTrigger" ontrigger="If(!warn_tokens_dontask, FadeIn(250), Evaluate(param1));"
		>
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="warn_tokens_content" visible="1" show_close="1"
				title="confirm_warn_tokens_title"
				content="warn_tokens_body"
				oncloselua="self:UICmd([[Call('warn_tokens', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Need Tokens -->
	<trigger name="NeedTokensTrigger"/>
	<template name="need_tokens_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%">
				<image x="1.5h" width="5.4h" height="5.4h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="1"/>
				<label x="-1.5h" y="0.8h" fity="1" width="-9.5h" align="right" textalign="center" style="newui_font_style_11" wrap="1" content="confirm_need_tokens_msg"/>
			</panel>
			<panel height="0" noclick="1"/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-9h" width="16h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('need_tokens', 'FadeOut(250);');]])"
					watch="NeedTokensTrigger"
					ontrigger="
						SetOnClick('
							Call(\'need_tokens\', \'FadeOut(250);\');
							'#param0#'
						');
					"
				/>
				<instance name="newui_common_button_2_template" x="9h" width="16h" height="2.5h" align="center" label="general_purchase_token"
					onclicklua="self:UICmd([[Call('need_tokens', 'FadeOut(250);');]])"
					watch="NeedTokensTrigger"
					ontrigger="
						SetOnClick('
							Call(\'need_tokens\', \'FadeOut(250);\');
							'#param1#'
						');
					"
				/>
			</panel>
		</panel>
	</template>
	<template name="need_tokens">
		<panel name="need_tokens" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()"
			watch="NeedTokensTrigger" ontrigger="FadeIn(250);"
		>
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="need_tokens_content" visible="1" show_close="1"
				title="confirm_need_tokens_title"
				content="need_tokens_body"
				oncloselua="self:UICmd([[Call('need_tokens', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<template name="restricted_regions_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" watch="RestrictedRegions" ontrigger="SetText(Translate('mm_region_unavailable_body', 'regions', param0));"/>
			</panel>
			<panel height="0" noclick="1"/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" width="12h" height="2.5h" align="center" label="general_ok"
					onclicklua="self:UICmd([[Call('restricted_regions', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
	<template name="restricted_regions">
		<panel name="restricted_regions" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()"
			watch="RestrictedRegions" ontrigger="FadeIn(250);"
		>
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="restricted_regions_content" visible="1" show_close="1"
				title="mm_region_unavailable"
				content="restricted_regions_body"
				oncloselua="self:UICmd([[Call('restricted_regions', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Too many friends :( F2P RMM -->
	<trigger name="TooManyFriendsTrigger"/>
	<template name="too_many_friends_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" content="confirm_too_many_friends_msg"/>
			</panel>
			<panel height="0" noclick="1"/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" width="12h" height="2.5h" align="center" label="general_ok"
					onclicklua="self:UICmd([[Call('too_many_friends', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
	<template name="too_many_friends">
		<panel name="too_many_friends" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()"
			watch="TooManyFriendsTrigger" ontrigger="FadeIn(250);"
		>
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="too_many_friends_content" visible="1" show_close="1"
				title="confirm_too_many_friends_title"
				content="too_many_friends_body"
				oncloselua="self:UICmd([[Call('too_many_friends', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Benefits of Verified Account(Content) -->
	<template name="verified_benefits_content">
		<panel name="verified_benefits_content_{id}" grow="1" width="54.0h" align="{align}" valign="{valign}" noclick="1">
			<instance name="newui_custom_frame_template" alpha="0.95"/>

			<panel grow="1" growinvis="0" width="-2.0h" align="center" float="bottom" padding="1.0h" noclick="1">

				<panel y="1.0h" height="10.0h" noclick="1">
					<panel x="1.0h" width="9.6h" height="9.6h">
						<image width="60%" height="60@" align="left" valign="bottom" texture="/ui/elements/basic.tga" color="1 1 1 .8"/>
						<image width="86%" height="86@" align="right" valign="top" texture="/ui/elements/verified.tga"/>
					</panel>
					<label x="-3h" y="0.8h" fity="1" width="-14h" align="right" textalign="center" style="newui_font_style_14" wrap="1" content="confirm_verify_bene_not" noclick="1"/>
					<label x="-3h" y="3.4h" fity="1" width="-14h" align="right" textalign="center" font="dyn_18" wrap="1" outline="1" color="#3abde7" content="confirm_verify_bene_what" noclick="1"/>
				</panel>

				<label fity="1" style="newui_font_style_12" align="center" wrap="1" content="confirm_verify_bene_txt1" noclick="1"/>
				<label fity="1" fitypadding="1.5h" style="newui_font_style_12" align="center" wrap="1" content="confirm_verify_bene_txt2" noclick="1"/>
				<label fity="1" fitypadding="0.5h" style="newui_font_style_12" align="center" wrap="1" content="confirm_verify_bene_txt3" noclick="1"/>

				<panel grow="1" width="100%" noclick="1">
					<panel height="100%" width="48%" align="left" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
					</panel>
					<panel height="100%" width="48%" align="right" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
					</panel>
					<panel grow="1" width="48%" align="left" noclick="1">
						<panel grow="1" y="0.8h" width="-1.6h" align="center" float="bottom" padding="0.5h" noclick="1">
							<label fity="1" font="dyn_16" color="#ffcc00" shadow="1" align="center" textalign="center" content="confirm_verify_bene_opt1" noclick="1"/>
							<label fity="1" fitypadding="0.5h" style="newui_font_style_10" align="center" wrap="1" content="confirm_verify_bene_opt1_txt1" noclick="1"/>
							<panel grow="1" width="100%" noclick="1">
								<label fity="1" style="newui_font_style_10" align="center" wrap="1" content="confirm_verify_bene_opt1_current" noclick="1"/>
								<label fity="1" style="newui_font_style_10" align="center" textalign="right" wrap="1" content="" noclick="1" onshow="SetText(GetAccountLevel(GetExperience()));"/>
							</panel>
							<panel grow="1" width="100%" noclick="1">
								<label fity="1" fitypadding="0.8h" style="newui_font_style_10" align="center" wrap="1" content="confirm_verify_bene_opt1_target" noclick="1"/>
								<label fity="1" style="newui_font_style_10" align="center" textalign="right" wrap="1" content="" noclick="1" onshow="SetText(VerifiedThreshold);"/>
							</panel>
						</panel>
					</panel>
					<panel grow="1" width="48%" align="right" noclick="1">
						<panel grow="1" y="0.8h" width="-1.6h" align="center" float="bottom" padding="0.5h" noclick="1">
							<label fity="1" font="dyn_16" color="#ffcc00" shadow="1" align="center" textalign="center" content="confirm_verify_bene_opt2" noclick="1"/>
							<label fity="1" fitypadding="2.0h" style="newui_font_style_10" align="center" wrap="1" content="confirm_verify_bene_opt2_txt1" noclick="1"/>

							<!-- Purchase Button(Modal Dialog Only) -->
							<panel width="100%" height="2.4h" noclick="1" visible="{showClickables=false}">
								<instance name="newui_common_button_2_template" width="16h" height="2.5h" align="center" label="confirm_verify_bene_buycoinsnow"
									onclicklua="
										GetWidget('store_open_purchase_helper'):DoEventN(2)
										{closeClicklua}
									"
								/>
							</panel>
						</panel>
					</panel>
				</panel>

				<!-- Close Button (Model Dialog Only) -->
				<panel sticky="1" stickytoinvis="false" width="100%" height="4h" visible="{showClickables=false}" noclick="1">
					<instance name="newui_common_button_2_template" width="16h" height="2.5h" align="center" label="confirm_verify_bene_closeWindow" onclicklua="{closeClicklua}"/>
				</panel>

				<panel height="0" visible="{morespace=false}" noclick="1"/>
			</panel>

			<!-- Close X -->
			<instance name="newui_button_close_template" x="-1h" y="1h" align="right" visible="{showClickables=false}" onclicklua="{closeClicklua}"/>
		</panel>
	</template>

	<!-- Benefits of Verified Account(Modal) -->
	<template name="verified_benefits_modal">
		<panel name="verified_benefits_modal" visible="{visible=0}" color="0 0 0 .6" onshowlua="self:BringToFront()">
			<instance name="verified_benefits_content" id="1" align="center" valign="center" showClickables="1" closeClicklua="self:UICmd([[Call('verified_benefits_modal', 'FadeOut(250);');]])"/>
		</panel>
	</template>

	<!-- Benefits of Verified Account(Tooltip) -->
	<template name="verified_benefits_FloatTip">
		<floater name="verified_benefits_FloatTip" visible="{visible=0}">
			<instance name="verified_benefits_content" id="2" morespace="true"/>
		</floater>
	</template>

	<!-- Account Verified -->
	<template name="account_verified">
		<panel name="account_verified" visible="{visible=0}" color="0 0 0 .6"
			onload="CreateBool('waiting_on_verified', 0);"
			onshow="BringToFront(); Call('confirmations_verified_popup_model', 'SetVisible(1);'); Set(waiting_on_verified, 0);"
			onhide="BringToFront(); Call('confirmations_verified_popup_model', 'SetVisible(0);');"
			watch="EventAccountLevelup" ontrigger="If(param1, FadeIn(150));"
			watch1="MicroStoreResults" ontrigger1="If(param49, FadeIn(150));"
			watch2="UIIsVerified" ontrigger2="If(param0 and waiting_on_verified, FadeIn(150));"
			watch3="LoginStatus" ontrigger3="If(!param2, Set(waiting_on_verified, 0));"
		>
			<panel grow="1" regrow="1" growinvis="0" width="42.0h" align="center" valign="center">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 .9" noclick="1"/>
				<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" color=".2 .2 .2 1" noclick="1"/>

				<panel grow="1" regrow="1" growinvis="0" width="100%" float="bottom" padding="1.2h">

					<panel y="1.0h" width="-3.0h" align="center" height="10.0h">
						<panel x="1.0h" width="9.6h" height="9.6h">
							<image width="60%" height="60@" align="left" valign="bottom" texture="/ui/elements/basic.tga" color="1 1 1 .8"/>
							<image width="86%" height="86@" align="right" valign="top" texture="/ui/elements/verified.tga"/>
						</panel>
						<label x="-3.0h" y="0.6h" fity="1" width="-14.0h" align="right" textalign="center" font="dyn_14" wrap="1" outline="1" color=".8 .8 .8 1" content="confirm_verify_congrats"/>
						<label x="-3.0h" y="3.4h" fity="1" width="-14.0h" align="right" textalign="center" font="dyn_18" wrap="1" outline="1" color="#3abde7" content="confirm_verify_complete"/>
					</panel>

					<label fity="1" font="dyn_12" color=".8 .8 .8 1" shadow="1" width="-3.0h" align="center" wrap="1" content="confirm_verify_text1"/>
					<label fity="1" fitypadding="1.0h" font="dyn_12" color=".8 .8 .8 1" shadow="1" width="-3.0h" align="center" wrap="1" content="confirm_verify_text2"/>

					<panel stickytoinvis="0" sticky="1" grow="1" regrow="1" growinvis="0" width="-3.0h" align="center" onshow="SetVisible(!HasAllHeroes());" visible="0" >
						<image x="0.5h" width="6.0h" height="6.0h" texture="/ui/fe2/store/icons/hero_token.tga" noclick="1"/>
						<label x="-1.5h" fity="1" fitypadding="2.4" width="-9.5h" align="right" textalign="left" textvalign="top" font="dyn_12" color=".8 .8 .8 1" shadow="1" wrap="1" content="confirm_verify_text3"/>
					</panel>

					<panel stickytoinvis="0" sticky="1" height="4.4h" width="-3.0h" align="center">
						<instance name="button2" button_name="conf_account_verified_ok"
							width="12.0h" height="2.4h"
							align="center"
							valign="top"
							label="general_ok" font="dyn_10"
							onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
							onclick="Call('account_verified', 'FadeOut(250);'); ClientRefreshInfos();"
						/>
					</panel>

				</panel>

				<!-- Close X -->
				<instance name="newui_button_close_template" x="-1h" y="1h" align="right" onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); Call('account_verified', 'FadeOut(250);'); ClientRefreshInfos();"/>
			</panel>
			<panel width="130h" height="100h" y="0h" align="center" color="invisible" noclick="1" name="confirmations_verified_popup_model" visible="0" onshow="SleepWidget(0, ''); SleepWidget(8000, 'SetVisible(false);');" >
				<modelpanel
					noclick="1"
					model="/ui/common/models/levelup/verified2.mdf"
					anim="idle"
					cameradistance="0"
					lookat="false"
					camerapos="0 1300 0"
					cameraangles="0 0 180"
					camerafov="50"
					cameranear="1"
					carmerafar="5000"
					depthclear="1"
					depthcompress="1"
					sunazimuth="-90"
					sunaltitude="180"
					suncolor="1 1 1"
					onshow="
						SetAnim('idle');
						SetEffect('/ui/common/models/levelup/verified2.effect');
					"
				/>
			</panel>
		</panel>
	</template>

	<!-- Switch to sub -->
	<template name="switch_sub_confirm_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" y="1.0h" width="100%" noclick="1">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" content="confirm_switchsub_msg"/>
			</panel>
			<panel height="2.4h" align="center" noclick="1"
				onload="If(!VarExists('subswitch_dontask'), DoEvent()); Instantiate('newui_checkbox_template', 'width', '24.0h', 'align', 'right', 'valign', 'center', 'font', 'dyn_10', 'content', 'confirm_switchsub_da', 'cvar', 'subswitch_dontask');"
				onevent="CreateBool('subswitch_dontask', 0); SetSave('subswitch_dontask');"
			/>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('switch_sub_confirm', 'FadeOut(250);');]])"
				/>
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="general_ok"
					onclicklua="self:UICmd([[SwitchSubAccount(sysbar_switch_sub_name); Call('switch_sub_confirm', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
	<template name="switch_sub_confirm">
		<panel name="switch_sub_confirm" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()">
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="switch_sub_confirm_content" visible="1" show_close="1"
				title="confirm_switchsub_title"
				content="switch_sub_confirm_body"
				oncloselua="self:UICmd([[Call('switch_sub_confirm', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Disconnect -->

	<!-- Disconnect Body - Can Leave -->
	<template name="disconnect_confirm_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">
			<panel grow="1" height="5.5h" width="100%">
				<label fity="1" width="-1.0h" align="center" valign="center" textalign="center" style="newui_font_style_12" wrap="1" content="confirm_disconnect_msg"/>
			</panel>
			<panel height="3.5h" noclick="1">
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="general_disconnect"
					onclicklua="self:UICmd([[Disconnect(); Call('disconnect_confirm', 'FadeOut(250);');]])
						self:Sleep(1, function() Trigger('AfterMatchStatsTrigger') end)
						"
				/>
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('disconnect_confirm', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
	<template name="disconnect_confirm">
		<panel name="disconnect_confirm" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()">
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="disconnect_confirm_content" visible="1" show_close="1"
				title="confirm_disconnect_title"
				content="disconnect_confirm_body"
				oncloselua="self:UICmd([[Call('disconnect_confirm', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Disconnect Body - Leaver -->
	<template name="disconnect_confirm_leaver_body">
		<panel width="100%" grow="1" align="center" float="bottom" padding="1.0h" noclick="1">

			<panel y="1.0h" grow="1" width="100%">
				<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_12" wrap="1" content="confirm_disconnect_msg"/>
			</panel>

			<panel grow="1" width="100%" noclick="1">
				<panel grow="1" width="-2.0h" align="center">
					<instance name="newui_custom_frame_template"/>
					<panel y="0.5h" float="bottom" grow="1" width="-2.0h" align="center" noclick="1">
						<panel width="100%" height="2.0h" noclick="1">
							<label textalign="left" textvalign="center" style="newui_font_style_11" noclick="1" content="game_menu_currentleavepercent"/>
							<label textalign="right" textvalign="center" style="newui_font_style_11" noclick="1" watch="AccountInfo" ontrigger="SetText(FtoA(param8 * 100, 2) # '%');"/>
						</panel>
						<panel width="100%" height="2.0h" noclick="1">
							<label textalign="left" textvalign="center" style="newui_font_style_11" noclick="1" content="game_menu_newleavepercent"/>
							<label textalign="right" textvalign="center" style="newui_font_style_11" noclick="1" watch="AccountInfo" ontrigger="SetText(FtoA(param9 * 100, 2) # '%');"/>
						</panel>
						<panel width="100%" height="2.0h" noclick="1">
							<label textalign="left" textvalign="center" style="newui_font_style_11" noclick="1" content="game_menu_newleavethreshold"/>
							<label textalign="right" textvalign="center" style="newui_font_style_11" noclick="1" watch="AccountInfo" ontrigger="SetText(FtoA(param10 * 100, 2) # '%');"/>
						</panel>

						<panel width="100%" color="invisible" grow="1" noclick="1">
							<label fity="1" fitypadding="0.5h" width="100%" textalign="left" font="dyn_10" color="#3abde7" shadow="1" wrap="1" noclick="1" watch="AccountInfo" ontrigger="SetText(Translate(If(param7, 'confirm_leaver_result_nowleaver', 'confirm_leaver_result_notleaver')));"/>
						</panel>
					</panel>
				</panel>
			</panel>
			
			<panel height="0" noclick="1"/>

			<panel height="3.5h" sticky="1" stickytoinvis="0" noclick="1">
				<instance name="newui_common_button_2_template" x="-7h" width="12h" height="2.5h" align="center" label="general_disconnect"
					onclicklua="self:UICmd([[Disconnect(); Call('disconnect_confirm_leaver', 'FadeOut(250);');]])"
				/>
				<instance name="newui_common_button_2_template" x="7h" width="12h" height="2.5h" align="center" label="general_cancel"
					onclicklua="self:UICmd([[Call('disconnect_confirm_leaver', 'FadeOut(250);');]])"
				/>
			</panel>
		</panel>
	</template>
	<template name="disconnect_confirm_leaver">
		<panel name="disconnect_confirm_leaver" visible="{visible=0}" color="0 0 0 .7" onshowlua="self:BringToFront()">
			<instance name="newui_common_popup" y="20h" width="40h" valign="top" id="disconnect_confirm_leaver_content" visible="1" show_close="1"
				title="confirm_disconnect_title"
				content="disconnect_confirm_leaver_body"
				oncloselua="self:UICmd([[Call('disconnect_confirm_leaver', 'FadeOut(250);');]])"
			/>
		</panel>
	</template>

	<!-- Prompt to lower settings -->
