				<instance name="newui_popup_caption_frame" title=""
					watch="TriggerDialogBoxGame" ontrigger="If(!StringEmpty(param0), SetText(Translate(param0)));"
					onclick="Call('generic_dialog_game_box', 'FadeOut(250);');"
				/>
				<panel y="3.5h" width="35h" align="center" float="bottom" padding="1h" grow="1" regrow="1" growinvis="0" reverse="1" noclick="1">
					<panel y="1.0h" grow="1" regrow="1" growinvis="0" stickytoinvis="0" width="100%" watch="TriggerDialogBoxGame" ontriggerlua="self:SetVisible(NotEmpty(param5))" >
						<label fity="1" width="-1.0h" align="center" textalign="center" style="newui_font_style_11" wrap="1" watch="TriggerDialogBoxGame" ontriggerlua="if NotEmpty(param5) then self:SetText(FormatStringNewline(Translate(param5))) end"/>
					</panel>
					<panel width="100%" grow="1" regrow="1" growinvis="0" stickytoinvis="0" watch="TriggerDialogBoxGame" ontriggerlua="self:SetVisible(NotEmpty(param6))" >
						<label width="-1.0h" align="center" fity="1" fitypadding="1.5h" wrap="1" textalign="center" textvalign="center" style="newui_font_style_10" noclick="1" watch="TriggerDialogBoxGame" ontriggerlua="if NotEmpty(param6) then self:SetText(FormatStringNewline(Translate(param6))) end"/>
					</panel>
					<panel width="-1h" align="center" height="3.5h" sticky="1" stickytoinvis="0" noclick="1">
						<instance name="newui_common_button_2_template" x="-8h" width="15h" height="2.5h" align="center"
							button_name="generic_dialog_game_box_left_btn"
							onclick="Call('generic_dialog_game_box', 'FadeOut(250);');"
							watch="TriggerDialogBoxGame"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_game_box\', \'FadeOut(250);\');
									'#param3#'
								');
							"
							labelwatch="TriggerDialogBoxGame"
							labelontrigger="If(!StringEmpty(param1), Split(SetText(Translate(param1)), Call('generic_dialog_game_box_left_btn', 'SetVisible(1)')), Call('generic_dialog_game_box_left_btn', 'SetVisible(0)'));"
						/>
						<instance name="newui_common_button_2_template" x="8h" width="15h" height="2.5h" align="center"
							button_name="generic_dialog_game_box_right_btn"
							onclick="Call('generic_dialog_game_box', 'FadeOut(250);');"
							watch="TriggerDialogBoxGame"
							ontrigger="
								SetOnClick('
									Call(\'generic_dialog_game_box\', \'FadeOut(250);\');
									'#param4#'
								');
							"
							labelwatch="TriggerDialogBoxGame"
							labelontrigger="If(!StringEmpty(param2), Split(SetText(Translate(param2)), Call('generic_dialog_game_box_right_btn', 'SetVisible(1)')), Call('generic_dialog_game_box_right_btn', 'SetVisible(0)'));"
						/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<trigger name="GLIncorrectDisplay"/>

	<!-- Purchase confirmation -->
	<!-- form for purchasing (alts, couriers) -->
	<trigger name="purchase_confirmation_status"/>
	<trigger name="purchase_confirmation_results"/>
	<form
		name="purchase_confirmation_submit"
		host="!masterserver"
		method="post"
		target="/store_requester.php"
		statustrigger="purchase_confirmation_status"
		resulttrigger="purchase_confirmation_results"
		resultparam0="responseCode"
		resultparam1="popupCode"
		resultparam2="errorCode"
		resultparam3="error"
		ssl="false"
	/>

	<trigger name="Confirm_Purchase_AltCourier"/>
	<!-- Confirm_Purchase_AltCourier
		0 - Product Name (Ex: Pig Courier, mstore_product16_name)
		1 - Product Type Text (Ex: globby_purchase_avatar, game_purchase_courier)
		2 - Gold Cost (Ex: 300)
		3 - Silver Cost (Ex: 400)
		4 - Hero Name (Ex: Hero_Pearl)
		5 - Alt Code (Ex: Alt2)
		6 - Product Type (Ex: Alt Avatar, Couriers) -->
	<!-- params, 0- ProductName 1- ProductType Text 2-GoldCost 3-SilverCost 4-HeroName 5-AltCode 6-ProductType -->
	<template name="purchase_confirmation_altcoutier_body">
		<panel width="35h" grow="1" regrow="1" align="center" valign="center" float="bottom" padding="0.75h" noclick="1">
			<label name="altavatar_purchase_confirm_productname" content="" fity="1" textalign="center" style="newui_font_style_11" wrap="1" watch="Confirm_Purchase_AltCourier" ontriggerlua="self:SetText(Translate(param0))"/>

			<label content="globby_purchase_avatar" fity="1" textalign="center" style="newui_font_style_12" wrap="1" watch="Confirm_Purchase_AltCourier" ontriggerlua="self:SetText(Translate(param1))"/>

			<panel vmargin="0.75h" grow="1" align="center" width="-1h" color="0 0 0 1" noclick="1">
				<instance name="newui_custom_frame_template" height="+1h" alpha="0.95"/>
				<label name="altavatar_body_text" width="-.5h" align="center" wrap="1" fity="1" y="0.5h" textalign="center" textvalign="center" style="newui_font_style_10" content="mstore_purchase_choosecurrency_desc"
					onevent0lua="
						local slvCst, gldCst = GetCvarInt('_confirm_silvercost'), GetCvarInt('_confirm_goldcost')
						local slvVld, gldVld = (slvCst > 0 and slvCst ~= 9002), (gldCst > 0 and gldCst ~= 9001)
						local slvAfrd, gldAfrd = (tonumber(UISilverCoins()) >= slvCst), (tonumber(UIGoldCoins()) >= gldCst)
						local content = ''
						if (not (slvVld or gldVld)) then
							content = Translate('mstore_purchase_itemisfree')
						elseif (not slvVld) then
							content = Translate('mstore_purchase_goldonly')..(not gldAfrd and ('\n\n'..Translate('mstore_viewcost_desc')) or '')
						elseif (not gldVld) then
							content = Translate('mstore_purchase_silveronly')..(not slvAfrd and ('\n\n'..Translate('mstore_viewcost_desc')) or '')
						else
							content = Translate(not (gldAfrd or slvAfrd) and 'mstore_purchase_choosecurrency_viewcost' or 'mstore_purchase_choosecurrency_desc')
						end
						self:SetText(content)
					"
				/>
			</panel>

			<panel vmargin="0.75h" height="6h" noclick="1">
				<panel vmargin="0.75h" x="-6h" width="10h" align="center" float="bottom" padding="0.25h" noclick="1">
					<panel name="altavatar_purchase_confirm_goldbox" height="2h" color="0 0 0 1" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
						<panel hmargin="0.25h" vmargin="0.25h" noclick="1">
							<label name="altavatar_purchase_confirm_goldcost" width="-120@" height="100%" textalign="center" textvalign="center" font="dyn_10" outline="1" color="#FFCC00" noclick="1" onevent0="SetText(_confirm_goldcost); SetVisible(_confirm_goldcost != 9001 and _confirm_goldcost gt 0); Call('altavatar_purchase_confirm_goldbox', 'SetVisible(_confirm_goldcost != 9001 and _confirm_goldcost gt 0)');"
							/>
							<image height="100%" width="100@" align="right" noclick="1" texture="/ui/fe2/store/gold_coins.tga"/>
						</panel>
					</panel>
					<instance name="newui_common_button_2_template" width="10.25h" height="2h" visible="0" align="center" label="mstore_purchase_gold"
						button_name="altavatar_purchase_confirm_goldbutton"
						onclick="
							PlaySound('/ui/fe2/store/sounds/purchase_avatar.wav');
							SubmitForm('purchase_confirmation_submit', 'account_id', GetAccountID(), 'request_code', 8, 'cookie', GetCookie(), 'hero_name', _confirm_heroname, 'avatar_code', _confirm_altcode, 'currency', 0, 'type', _confirm_producttype);
							CallEvent('altavatar_purchase_confirm_main', 1);
						"
					/>
				</panel>
				<panel vmargin="0.75h" x="6h" width="10h" align="center" float="bottom" padding="0.25h" noclick="1">
					<panel name="altavatar_purchase_confirm_silverbox" height="2h" color="0 0 0 1" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
						<panel hmargin="0.25h" vmargin="0.25h" noclick="1">
							<label name="altavatar_purchase_confirm_silvercost" font="dyn_10" width="-120@" height="100%" textalign="center" textvalign="center" outline="1" color="#c0d5ed" noclick="1" onevent0="SetText(_confirm_silvercost); SetVisible(_confirm_silvercost != 9002 and _confirm_silvercost gt 0); Call('altavatar_purchase_confirm_silverbox', 'SetVisible(_confirm_silvercost != 9002 and _confirm_silvercost gt 0)');"/>
							<image height="100%" width="100@" align="right" noclick="1" texture="/ui/fe2/store/silver_coins.tga"/>
						</panel>
					</panel>
					<instance name="newui_common_button_2_template" width="10.25h" height="2h" visible="0" align="center" label="mstore_purchase_silver"
						button_name="altavatar_purchase_confirm_silverbutton"
						onclick="
							PlaySound('/ui/fe2/store/sounds/purchase_avatar.wav');
							SubmitForm('purchase_confirmation_submit', 'account_id', GetAccountID(), 'request_code', 8, 'cookie', GetCookie(), 'hero_name', _confirm_heroname, 'avatar_code', _confirm_altcode, 'currency', 1, 'type', _confirm_producttype);
							CallEvent('altavatar_purchase_confirm_main', 1);
						"
					/>
				</panel>
				<panel width="50%" height="100%" align="center" noclick="1">
					<instance name="newui_common_button_2_template" width="15h" height="5h" visible="0" align="center" valign="center" label="mstore_purchase_claimfree"
						button_name="altavatar_purchase_confirm_free"
						onclick="
							PlaySound('/ui/fe2/store/sounds/purchase_avatar.wav');
							SubmitForm('purchase_confirmation_submit', 'account_id', GetAccountID(), 'request_code', 8, 'cookie', GetCookie(), 'hero_name', _confirm_heroname, 'avatar_code', _confirm_altcode, 'currency', 0, 'type', _confirm_producttype);
							CallEvent('altavatar_purchase_confirm_main', 1);
						"
					/>
				</panel>
			</panel>
			<panel align="center" width="-1h" height="3h" noclick="1">
				<instance name="newui_common_button_2_template" y="-0.75h" width="12h" height="2.5h" align="center" label="general_cancel" onclick="CallEvent('altavatar_purchase_confirm_main', 1);"/>
			</panel>
		</panel>
	</template>
	<template name="purchase_confirmation_altcoutier">
		<panel name="altavatar_purchase_confirm_main" width="100%" height="100%" color="0 0 0 0.5" onevent0="FadeIn(150);" onevent1="FadeOut(150);" visible="0"
			onload="CreateInt('_confirm_goldcost', 0); CreateInt('_confirm_silvercost', 0); CreateString('_confirm_heroname', ''); CreateString('_confirm_altcode', ''); CreateString('_confirm_producttype', '');"
			watch="Confirm_Purchase_AltCourier"
			ontrigger="Set('_confirm_goldcost', param2); Set('_confirm_silvercost', param3); Set('_confirm_heroname', param4); Set('_confirm_altcode', param5); Set('_confirm_producttype', param6);
			CallEvent('altavatar_purchase_confirm_goldcost', 0);
			CallEvent('altavatar_purchase_confirm_silvercost', 0);
			CallEvent('altavatar_body_text', 0);
			DoEvent(0);"
			ontriggerlua="if ((tonumber(UIGoldCoins()) >= tonumber(param2)) and (tonumber(param2) ~= 9001) and (tonumber(param2) > 0)) then GetWidget('altavatar_purchase_confirm_goldbutton'):SetVisible(1) else GetWidget('altavatar_purchase_confirm_goldbutton'):SetVisible(0) end if ((tonumber(UISilverCoins()) >= tonumber(param3)) and (tonumber(param3) ~= 9002) and (tonumber(param3) > 0)) then GetWidget('altavatar_purchase_confirm_silverbutton'):SetVisible(1) else GetWidget('altavatar_purchase_confirm_silverbutton'):SetVisible(0) end if (((tonumber(param2) == 0) or (tonumber(param2) == 9001)) and ((tonumber(param3) == 0) or (tonumber(param3) == 9002))) then GetWidget('altavatar_purchase_confirm_free'):SetVisible(1) else GetWidget('altavatar_purchase_confirm_free'):SetVisible(0) end"
		>
			<instance name="newui_common_popup" y="20h" width="33h" valign="top" id="altavatar_purchase_confirm_main_content" visible="1" show_close="1"
				title="globby_purchase"
				content="purchase_confirmation_altcoutier_body"
				oncloselua="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav') self:UICmd([[CallEvent('altavatar_purchase_confirm_main', 1);]])"
			/>
		</panel>

		<!-- handle form results -->
		<panel visible="0" onload="CreateString('_purchase_confirm_err_string', '')"
			watch="purchase_confirmation_results"
			ontrigger=" If(param1 == 3,
							Split(	DoEvent(0),
									ChatRefreshUpgrades(),
									ClientRefreshUpgrades(),
									ServerRefreshUpgrades()
								)
						);

						If((param1 == 0 or param1 == 1) and param2 ge 0, Set('_purchase_confirm_err_string', Translate('mstore_error' # param2)));
						If(param2 gt 0, DoEvent(1));"
			watch2="purchase_confirmation_status"
			ontrigger2="If(param0 == 3, Set('_purchase_confirm_err_string', Translate('mstore_error_connect')));"
			onevent0="Trigger('TriggerDialogBox', 'mstore_buyitem_success', '', 'general_ok', '', '', 'mstore_buyitem_success', 'mstore_buyitem_success_body');"
			onevent1="Trigger('TriggerDialogBox', 'mstore_error_generic', '', 'general_ok', '', '', 'mstore_error_generic', _purchase_confirm_err_string);"
		/>
	</template>

	<!-- Other Purchase confirmation -->
	<trigger name="Confirm_Purchase_Other"/>
	<trigger name="Confirm_Purchase_Other_Start"/>
	<!-- Confirm_Purchase_Other
		0 - Product Name (Ex: Fist of Sol, mstore_product481_name)
		1 - Product Type Text (Ex: mstore_buyitem_confirm, globby_purchase_eap_is)
		2 - Gold Cost (Ex: 300)
		3 - Silver Cost (Ex: 400)
		4 - Category ID (Ex: 23)
		5 - Product ID (Ex: 3)
		6 - Tips (Ex: Note: Purchase Mastery Boost here will use it directly.) -->
	<!-- params, 0- ProductName 1-ProductType (label) 2-GoldCost 3-SilverCost 4-ProductID 5-CategoryID -->
	<template name="purchase_confirmation_other_body">
		<panel width="35h" grow="1" regrow="1" align="center" valign="center" float="bottom" padding="1.5h" noclick="1">
			<label name="other_purchase_confirm_productname" content="" fity="1" textalign="center" style="newui_font_style_11" wrap="1" watch="Confirm_Purchase_Other" ontriggerlua="self:SetText(Translate(param0))"/>

			<label content="mstore_buyitem_confirm" fity="1" textalign="center" style="newui_font_style_12" wrap="1" watch="Confirm_Purchase_Other" ontrigger="If(!StringEmpty(param1), SetText(Translate(param1)), SetText(Translate('mstore_buyitem_confirm')));"/>

			<panel vmargin="0.75h" grow="1" align="center" width="-1h" color="0 0 0 1" noclick="1">
				<instance name="newui_custom_frame_template" height="+1h" alpha="0.95"/>
				<label name="other_body_text" y="0.5h" width="-.5h" align="center" wrap="1" fity="1" textalign="center" style="newui_font_style_10" content="mstore_purchase_choosecurrency_desc"
					onevent0lua="
						local slvCst, gldCst = GetCvarInt('_confirm_silvercost_other'), GetCvarInt('_confirm_goldcost_other')
						local slvVld, gldVld = (slvCst > 0 and slvCst ~= 9002), (gldCst > 0 and gldCst ~= 9001)
						local slvAfrd, gldAfrd = (tonumber(UISilverCoins()) >= slvCst), (tonumber(UIGoldCoins()) >= gldCst)
						local content = ''
						if (not (slvVld or gldVld)) then
							content = Translate('mstore_purchase_itemisfree')
						elseif (not slvVld) then
							content = Translate('mstore_purchase_goldonly')..(not gldAfrd and '\n\n'..Translate('mstore_viewcost_desc') or '')
						elseif (not gldVld) then
							content = Translate('mstore_purchase_silveronly')..(not slvAfrd and '\n\n'..Translate('mstore_viewcost_desc') or '')
						else
							content = Translate(not (gldAfrd or slvAfrd) and 'mstore_purchase_choosecurrency_viewcost' or 'mstore_purchase_choosecurrency_desc')
						end
						self:SetText(content)
					"
				/>
			</panel>

			<panel height="1.5h" sticky="1" stickytoinvis="0" visible="0" watch="Confirm_Purchase_Other" ontriggerlua="self:SetVisible(NotEmpty(param6))">
				<label content="mstore_buyitem_confirm" align="center" fity="1" textalign="center" style="newui_font_style_10" watch="Confirm_Purchase_Other" ontriggerlua="if NotEmpty(param6) then self:SetText(param6) end"/>
			</panel>

			<panel height="6h" noclick="1">
				<panel x="0h" width="10h" align="left" float="bottom" padding="0.25h" noclick="1">
					<panel name="other_purchase_confirm_goldbox" height="2h" color="0 0 0 1" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
						<panel hmargin="0.25h" vmargin="0.25h" noclick="1">
							<label name="other_purchase_confirm_goldcost" width="-120@" height="100%" textalign="center" textvalign="center" font="dyn_10" outline="1" color="#FFCC00" noclick="1" onevent0="SetText(_confirm_goldcost_other); SetVisible(_confirm_goldcost_other != 9001 and _confirm_goldcost_other gt 0); Call('other_purchase_confirm_goldbox', 'SetVisible(_confirm_goldcost_other != 9001 and _confirm_goldcost_other gt 0)');"
							/>
							<image height="100%" width="100@" align="right" noclick="1" texture="/ui/fe2/store/gold_coins.tga"/>
						</panel>
					</panel>
					<instance name="newui_common_button_2_template" width="10.25h" height="2h" visible="0" align="center" label="mstore_purchase_gold"
						button_name="other_purchase_confirm_goldbutton"
						onclick="
							PlaySound('/ui/fe2/store/sounds/purchase_avatar.wav');
							Set('_confirm_submitted', true);
							SubmitForm('MicroStore', 'account_id', GetAccountID(), 'request_code', '4', 'cookie', GetCookie(), 'product_id', _confirm_product, 'category_id', _confirm_category, 'hostTime', HostTime, 'currency', 0, 'type');
							CallEvent('other_purchase_confirm_main', 1);
							Trigger('Confirm_Purchase_Other_Start', _confirm_product);
						"
					/>
				</panel>
				<panel width="10h" align="center" float="bottom" padding="0.25h" noclick="1">
					<panel name="other_purchase_confirm_silverbox" height="2h" color="0 0 0 1" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
						<panel hmargin="0.25h" vmargin="0.25h" noclick="1">
							<label name="other_purchase_confirm_silvercost" font="dyn_10" width="-120@" height="100%" textalign="center" textvalign="center" outline="1" color="#c0d5ed" noclick="1" onevent0="SetText(_confirm_silvercost_other); SetVisible(_confirm_silvercost_other != 9002 and _confirm_silvercost_other gt 0); Call('other_purchase_confirm_silverbox', 'SetVisible(_confirm_silvercost_other != 9002 and _confirm_silvercost_other gt 0)');"/>
							<image height="100%" width="100@" align="right" noclick="1" texture="/ui/fe2/store/silver_coins.tga"/>
						</panel>
					</panel>
					<instance name="newui_common_button_2_template" width="10.25h" height="2h" visible="0" align="center" label="mstore_purchase_silver"
						button_name="other_purchase_confirm_silverbutton"
						onclick="
							PlaySound('/ui/fe2/store/sounds/purchase_avatar.wav');
							Set('_confirm_submitted', true);
							SubmitForm('MicroStore', 'account_id', GetAccountID(), 'request_code', '4', 'cookie', GetCookie(), 'product_id', _confirm_product, 'category_id', _confirm_category, 'hostTime', HostTime, 'currency', 1, 'type');
							CallEvent('other_purchase_confirm_main', 1);
							Trigger('Confirm_Purchase_Other_Start', _confirm_product);
						"
					/>
				</panel>
				<panel x="-1h" width="10h" align="right" float="bottom" padding="0.25h" noclick="1">
					<panel height="2h" color="0 0 0 1" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
						<panel hmargin="0.25h" vmargin="0.25h" noclick="1">
							<label width="-120@" height="100%" textalign="center" textvalign="center" font="dyn_10" outline="1" color="#FFCC00" noclick="1"
								watch="GoldCoins"
								ontrigger="SetText(FtoA(GoldCoins, 0, 0, ',')); SetWidth( GetStringWidth('dyn_10', (FtoA(GoldCoins, 0, 0, ',')) ) );"
							/>
							<image height="100%" width="100@" align="right" noclick="1" texture="/ui/fe2/store/gold_coins.tga"/>
						</panel>
					</panel>
					<panel height="2h" color="0 0 0 1" noclick="1">
						<instance name="newui_custom_frame_template" alpha="0.95"/>
						<panel hmargin="0.25h" vmargin="0.25h" noclick="1">
							<label font="dyn_10" width="-120@" height="100%" textalign="center" textvalign="center" outline="1" color="#c0d5ed" noclick="1"
								watch="SilverCoins"
								ontrigger="SetText(FtoA(SilverCoins, 0, 0, ',')); SetWidth( GetStringWidth('dyn_10', (FtoA(SilverCoins, 0, 0, ',')) ) );"
							/>
							<image height="100%" width="100@" align="right" noclick="1" texture="/ui/fe2/store/silver_coins.tga"/>
						</panel>
					</panel>
				</panel>
				<panel width="50%" height="100%" align="center" noclick="1">
					<instance name="newui_common_button_2_template" width="15h" height="5h" visible="0" align="center" valign="center" label="mstore_purchase_claimfree"
						button_name="other_purchase_confirm_free"
						onclick="
							PlaySound('/ui/fe2/store/sounds/purchase_avatar.wav');
							Set('_confirm_submitted', true);
							SubmitForm('MicroStore', 'account_id', GetAccountID(), 'request_code', '4', 'cookie', GetCookie(), 'product_id', _confirm_product, 'category_id', _confirm_category, 'hostTime', HostTime, 'currency', 0, 'type');
							CallEvent('other_purchase_confirm_main', 1);
							Trigger('Confirm_Purchase_Other_Start', _confirm_product);
						"
					/>
				</panel>
			</panel>
			<panel align="center" width="-1h" height="3h" noclick="1">
				<instance name="newui_common_button_2_template" button_name="confirm_purchase_other_cancel" y="-0.5h" width="12h" height="2.5h" align="center" label="general_cancel" onclick="CallEvent('other_purchase_confirm_main', 1);"/>
			</panel>
		</panel>
	</template>
	<template name="purchase_confirmation_other">
		<panel name="other_purchase_confirm_main" width="100%" height="100%" color="0 0 0 0.5" onevent0="FadeIn(150);" onevent1="FadeOut(150);" visible="0"
			onload="CreateInt('_confirm_goldcost_other', 0); CreateInt('_confirm_silvercost_other', 0); CreateString('_confirm_product', ''); CreateString('_confirm_category', ''); CreateBool('_confirm_submitted', false);"
			watch="Confirm_Purchase_Other"
			ontrigger="Set('_confirm_goldcost_other', param2); Set('_confirm_silvercost_other', param3); Set('_confirm_product', param5); Set('_confirm_category', param4);
			CallEvent('other_purchase_confirm_goldcost', 0);
			CallEvent('other_purchase_confirm_silvercost', 0);
			CallEvent('other_body_text', 0);
			DoEvent(0);"
			ontriggerlua="if ((tonumber(UIGoldCoins()) >= tonumber(param2)) and (tonumber(param2) ~= 9001) and (tonumber(param2) > 0)) then GetWidget('other_purchase_confirm_goldbutton'):SetVisible(1) else GetWidget('other_purchase_confirm_goldbutton'):SetVisible(0) end if ((tonumber(UISilverCoins()) >= tonumber(param3)) and (tonumber(param3) ~= 9002) and (tonumber(param3) > 0)) then GetWidget('other_purchase_confirm_silverbutton'):SetVisible(1) else GetWidget('other_purchase_confirm_silverbutton'):SetVisible(0) end if (((tonumber(param2) == 0) or (tonumber(param2) == 9001)) and ((tonumber(param3) == 0) or (tonumber(param3) == 9002))) then GetWidget('other_purchase_confirm_free'):SetVisible(1) else GetWidget('other_purchase_confirm_free'):SetVisible(0) end"
			onshowlua="self:UICmd('SetActiveWidget(\'NULL\');')"
		>
			<instance name="newui_common_popup" y="20h" width="33h" valign="top" id="other_purchase_confirm_main_content" visible="1" show_close="1"
				title="globby_purchase"
				content="purchase_confirmation_other_body"
				oncloselua="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav') self:UICmd([[CallEvent('other_purchase_confirm_main', 1);]])"
			/>
		</panel>

		<!-- handle form results -->
		<panel visible="0" noclick="1" watch="MicroStoreResults" onload="CreateString('_other_confirm_err_string', '');"
			ontrigger="	If(param15 gt 0 and _confirm_submitted,
							Split(	Set('_other_confirm_err_string', Translate('mstore_error' # param15)),
									DoEvent(1)
								)
						);
						If(param1 == 3 and _confirm_submitted,
							Split(	DoEvent(0),
									ChatRefreshUpgrades(),
									ClientRefreshUpgrades(),
									ServerRefreshUpgrades()
								)
						);
						Set('_confirm_submitted', false);"
			onevent0="Trigger('TriggerDialogBox', 'mstore_buyitem_success', '', 'general_ok', '', '', 'mstore_buyitem_success', 'mstore_buyitem_success_body');"
			onevent1="Trigger('TriggerDialogBox', 'mstore_error_generic', '', 'general_ok', '', '', 'mstore_error_generic', _other_confirm_err_string);"
		/>
	</template>
</package>
