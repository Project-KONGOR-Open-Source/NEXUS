								<instance name="communicator_chat_template" width="140i" id="24"/>
							</panel>
							<panel width="60i" noclick="1" align="right">
								<button name="communicator_main_large_chat_lastpage" x="-42i" align="right"  width="12i" color="invisible" visible="1" onclicklua="Communicator_V2:ChatOnClickChangePage(false)">
									<widgetstate statename="up">
										<image texture="/ui/fe2/newui/res/communicator/arrow.png" width="32i" height="32i" align="center" valign="center" noclick="1" />
									</widgetstate> 
									<widgetstate statename="over">
										<image texture="/ui/fe2/newui/res/communicator/arrow_over.png" width="32i" height="32i" align="center" valign="center" noclick="1" />
									</widgetstate>
									<widgetstate statename="down" x="1" y="1">
										<image texture="/ui/fe2/newui/res/communicator/arrow_over.png" width="32i" height="32i" align="center" valign="center" noclick="1" />
									</widgetstate>
									<widgetstate statename="disabled">
										<image texture="/ui/fe2/newui/res/communicator/arrow.png" width="32i" height="32i" align="center" valign="center" rendermode="grayscale" noclick="1" />
									</widgetstate> 
								</button>
								<button name="communicator_main_large_chat_nextpage" x="-30i" align="right" width="12i" color="invisible" visible="1" onclicklua="Communicator_V2:ChatOnClickChangePage(true)">
									<widgetstate statename="up">
										<image texture="/ui/fe2/newui/res/communicator/arrow.png" width="32i" height="32i" align="center" valign="center" noclick="1" hflip="1"/>
									</widgetstate> 
									<widgetstate statename="over">
										<image texture="/ui/fe2/newui/res/communicator/arrow_over.png" width="32i" height="32i" align="center" valign="center" noclick="1" hflip="1"/>
									</widgetstate>
									<widgetstate statename="down" x="1" y="1">
										<image texture="/ui/fe2/newui/res/communicator/arrow_over.png" width="32i" height="32i" align="center" valign="center" noclick="1" hflip="1"/>
									</widgetstate>
									<widgetstate statename="disabled">
										<image texture="/ui/fe2/newui/res/communicator/arrow_over.png" width="32i" height="32i" align="center" valign="center" rendermode="grayscale" hflip="1" noclick="1" />
									</widgetstate> 
								</button>
								<image texture="/ui/fe2/newui/res/communicator/line3.png" x="-25i" align="right" valign="center" width="1" height="16i" noclick="1" visible="1"/>
								
								<button x="-5i" width="16i" height="16i" align="right" valign="center" color="invisible"
										onclicklua="PlaySound('/shared/sounds/ui/revamp/region_click.wav') Communicator_V2:ChatOnClickShowJoinChannelPanel()"
										onmouseoverlua="Common_V2:ShowGenericTip(true, 'irc_join_create_tip_title', 'irc_join_create_tip')"
										onmouseoutlua="Common_V2:ShowGenericTip(false)"
								>
									<widgetstate statename="up">
										<image texture="/ui/fe2/newui/res/communicator/add.png" align="center" valign="center" noclick="1"/>
									</widgetstate>
									<widgetstate statename="over">
										<image texture="/ui/fe2/newui/res/communicator/add_over.png" align="center" valign="center" noclick="1"/>
									</widgetstate>
									<widgetstate statename="down" x="1" y="1">
										<image texture="/ui/fe2/newui/res/communicator/add_over.png" align="center" valign="center" noclick="1"/>
									</widgetstate>
								</button>
							</panel>
							<image name="communicator_chat_tab_line1" texture="/ui/fe2/newui/res/communicator/tab_line.png" height="64i" valign="bottom" noclick="1" visible="0"/>
							<image name="communicator_chat_tab_line2" texture="/ui/fe2/newui/res/communicator/tab_line.png" height="64i" align="right" valign="bottom" noclick="1"/>
						</panel>

						<panel height="-38i" noclick="1">
							<frame texture="/ui/fe2/newui/res/common/frames/communicator/frame.png" borderthickness="16" noclick="1"/>
							<panel width="-267i" noclick="1">
								<panel width="-30i" height="-16i" align="center" valign="center" noclick="1">
									<textbuffer name="communicator_chatbuffer"
												onclick="SetFocusName('communicator_send_box')"
												scrolltexture="/ui/fe2/newui/res/common/scroll/scroll.png"
												handleheight="25i"
												scrollbarsize="12i"
												textalign="left"
												font="dyn_10"
												wrap="true"
												anchorbottom="true"
												usesmileys="true"
												maxlines="1000"
												shadow="true"
												color="invisible"
												textcolor="#d7b6a2"
												outline="1"
												outlinecolor="#230000"
									/>
								</panel>
							</panel>
							<panel name="communicator_main_large_users" width="275i" noclick="1" align="right">
								<image texture="/ui/fe2/newui/res/common/vline.png" y="-1%" width="1" height="100%" valign="center" noclick="1"/>
								<panel width="-20i" height="32i" align="center" noclick="1">
									<image texture="/ui/fe2/newui/res/common/hline.png" x="-2%" width="115%" height="1" align="center" valign="bottom" noclick="1"/>
									<image texture="/ui/fe2/newui/res/communicator/icon02.png" x="-5i" width="32i" height="32i" valign="center" noclick="1"/>
									<instance name="newui_longtext_label_template" label_name="communicator_main_large_channelname" x="30i" width="120i" textvalign="center" font="dyn_10" color="#c1afa3" outline="1" outlinecolor="#230000"/>
								</panel>
								<panel width="-20i" height="-32i" align="center" valign="bottom" noclick="1">
									<scrollbar  name="communicator_user_scrollbar"
										align="right"
										width="12i"
										height="-10i"
										valign="center"
										scrollbarsize="12i"
										handlewidth="12i"
										handleheight="25i"							
										texture="/ui/fe2/newui/res/common/scroll/scroll.png"
										scrollbarplaceholder="true"
										minvalue="1"
										maxvalue="1"							
										step="1"
										value="1"
										vertical="true"
										slotwidth="0.6h" slotheight="1"
										onevent1="SetValue(GetValue+1);"
										onevent0="SetValue(GetValue-1);"
										onslidelua="Communicator_V2:UserPopulate()"
									/>
									<panel width="-3i" x="-10i" noclick="1">
										<instance name="communicator_user_template" y="0" id="1" />
										<instance name="communicator_user_template" y="36i" id="2" />
										<instance name="communicator_user_template" y="72i" id="3" />
										<instance name="communicator_user_template" y="108i" id="4" />
										<instance name="communicator_user_template" y="144i" id="5" />
										<instance name="communicator_user_template" y="180i" id="6" />
									</panel>		
								</panel>
							</panel>
						</panel>
					</panel>
				</panel>
			</panel>

			<instance name="newui_common_popup" id="communicator_main_popup_joinchannel" width="425i" y="-460i" align="right" show_close="1" title="newui_communicator_channelname" content="communicator_joinchannel_body_template" oncloselua="GetWidget('communicator_main_popup_joinchannel'):FadeOut(150)"/>
		</panel>

		<panel name="communicator_main_helper" width="1" height="1" noclick="1" onframelua="Communicator_V2:ChatOnFrame()" onloadlua="Communicator_V2:Init()"/>
	</template>
</package>