	<!-- entry -->
	<template name="playerstats_template">
		<panel name="playerstats" color="0 0 0 .7" visible="0" hotkey="ESC" onhotkeylua="Player_Stats_V2:Hide()"
			onload="CreateString('_playerstats_match_owner', '')"
		>
			<panel width="1325i" height="915i" align="center" valign="center">
				<frame texture="/ui/fe2/newui/res/playerstats/bg.png" borderthickness="16i" width="+18i" height="+18i" align="center" valign="center" noclick="1"/>
				<image texture="/ui/fe2/newui/res/playerstats/bar.png" y="-35i" width="2048i" height="128i" align="center" noclick="1"/>
				<image texture="/ui/fe2/newui/res/playerstats/bar2.png" y="170i" width="2048i" height="64i" align="center" noclick="1"/>

				<panel height="47i" noclick="1">
					<image texture="/ui/fe2/newui/res/playerstats/title.png" x="-60i" width="32i" height="64i" align="center" valign="center" noclick="1"/>
					<label textalign="center" textvalign="center" font="dyn_14" color="#d0b09b" outline="1" outlinecolor="#260e0a" content="newui_playerstats_title" noclick="1"/>
					<panel x="15i" y="-1i" align="left" valign="center" float="right" grow="1" growinvis="0" regrow="1" noclick="1">
						<panel name="playerstats_fetch_player_container" width="150i" height="28i" align="left" valign="center" stickytoinvis="0" visible="0">
							<instance name="newui_custom_frame_template"/>
							<textbox name="playerstats_fetch_player"
									color="0 0 0 .5" font="dyn_11" textcolor="#f0d3c1"
									width="146i" height="24i" hpadding="2i"
									textalign="left" textvalign="center" align="center" valign="center"
									onesc="EraseInputLine();"
									onenter="
										Set('_playerstats_playername_fetch', this);
										DoEvent(0);
										Call('playerstats_fetch_player_container', 'FadeOut(150);');
										"
									onevent0lua="
										if NotEmpty(GetCvarString('_playerstats_playername_fetch')) then
											Player_Stats_V2:Hide()
											Player_Stats_V2:Show(GetCvarString('_playerstats_playername_fetch'))
										end
										"
									onchange=""
									onload="CreateString('_playerstats_playername_fetch');"
							/>
						</panel>
						<instance name="playerstats_button_template" button_name="playerstats_fetch_player_button" width="32i" height="32i" align="left" valign="center"
								  img_width="32i" img_height="32i" stickytoinvis="0"
								  image_up="/ui/fe2/newui/res/playerstats/fetchplayer.png"
								  image_over="/ui/fe2/newui/res/playerstats/fetchplayer_up.png"
								  image_down="/ui/fe2/newui/res/playerstats/fetchplayer.png"
								  image_disabled="/ui/fe2/newui/res/playerstats/fetchplayer.png"
								  onclicklua="Player_Stats_V2:SearchPlayer()"
						/>
					</panel>
				</panel>

				<instance name="newui_button_close_template" x="-10i" y="6i" align="right" valign="top" onclicklua="Player_Stats_V2:Hide()"/>

				<panel x="50i" y="47i" width="1164i" height="136i" noclick="1" float="right">
					<panel width="395i" noclick="1">
						<panel width="110i" height="110i" x="-40i" valign="center" noclick="1">
							<avatar name="playerstats_playericon" texture="$invis" width="-14i" height="-14i" y="-1.5i" align="center" valign="center" noclick="1"/>
						</panel>
						<label name="playerstats_playername" x="82i" y="-30i" textalign="left" textvalign="center" font="dyn_12" color="#efd2c0" outline="1" outlinecolor="#230000" fitx="1" noclick="1"/>
						<image name="playerstats_playerstanding" x="250i" y="-30i" width="24i" height="24i" align="left" valign="center" texture="/ui/icons/basic.tga" visible="0" noclick="0"/>
						<label name="playerstats_playerlevel" x="82i" y="-6i" textalign="left" textvalign="center" font="dyn_10" color="#ae9380" outline="0" outlinecolor="#6d554b" noclick="1"/>
						<label name="playerstats_clanname" x="82i" y="11i" textalign="left" textvalign="center" font="dyn_10" color="#ad9281" outline="0" outlinecolor="#6d554b" fitx="1" noclick="1"/>
						<image name="playerstats_clanrole" x="250i" y="11i" width="16i" height="16i" align="left" valign="center" texture="$invis" visible="1" noclick="1" />
						<panel x="82i" y="29i" valign="center" width="300i" height="15i">
							<frame borderthickness="1i" color="invisible" bordercolor="#36261e" noclick="1" />
							<panel width="298i" height="13i" align="center" valign="center">
								<panel name="playerstats_levelprogress" width="100%" noclick="1" clip="1">
									<image texture="/ui/fe2/newui/res/homepage/exp.png" width="296i" noclick="0"/>
								</panel>
							</panel>
							<label name="playerstats_levelexp" textalign="center" textvalign="center" font="dyn_9" color="#e4ffff" outline="1" outlinecolor="#0d5a68" noclick="1"/>
						</panel>
						<instance name="playerstats_button_template" button_name="playerstats_codex" x="350i" y="5i" width="32i" height="32i" align="left" valign="center"
							      img_width="100%" img_height="100%"
								  image_up="/ui/elements/player_tour_stats_up.tga"
								  image_over="/ui/elements/player_tour_stats_over.tga"
								  image_down="/ui/elements/player_tour_stats_up.tga"
								  image_disabled="/ui/elements/player_tour_stats_up.tga"
								  onclicklua="Player_Stats_V2:OpenTourStats()"
								 
						/>
