					<image texture="/ui/fe2/newui/res/common/line2.png" width="2i" height="100%" valign="center" />
					<panel width="388i" noclick="1">
						<panel x="40i" y="20i" float="bottom" noclick="1" padding="12i">
							<panel height="20i" noclick="0" float="right" padding="12i">
