	<trigger name="PlayerStatsMasteryStatus"/>
    <trigger name="PlayerStatsMasteryResult"/>
    <form
		name="PlayerStatsMastery"
		host="!masterserver"
		method="post"
		target="/client_requester.php"
		statustrigger="PlayerStatsMasteryStatus"
		resulttrigger="PlayerStatsMasteryResult"
		resultparam0="nickname"
		resultparam1="name"
		resultparam2="rank"
		resultparam3="account_id"
		resultparam4="last_activity"
		resultparam5="create_date"
		resultparam6="selected_upgrades"
		resultparam7="level"
		resultparam8="level_exp"
		resultparam9="standing"
		resultparam10="mastery_info"
		resultparam11="mastery_rewards"
	/>

	<trigger name="PlayerStatsMVPAwardsStatus"/>
    <trigger name="PlayerStatsMVPAwardsResult"/>
    <form
		name="PlayerStatsMVPAwards"
		host="!masterserver"
		method="post"
		target="/client_requester.php"
		statustrigger="PlayerStatsMVPAwardsStatus"
		resulttrigger="PlayerStatsMVPAwardsResult"
		resultparam0="awd_mann"
		resultparam1="awd_mqk"
		resultparam2="awd_lgks"
		resultparam3="awd_msd"
		resultparam4="awd_mkill"
		resultparam5="awd_masst"
		resultparam6="awd_ledth"
		resultparam7="awd_mbdmg"
		resultparam8="awd_mwk"
		resultparam9="awd_mhdd"
		resultparam10="awd_hcs"
		resultparam11="account_id"
		resultparam12="mvp"
	/>
    <!--End of Forms-->

	<template name="playerstats_tab_template">
		<button name="playerstats_tab_{type}" width="{width=160i}" height="100%" color="invisible" onclicklua="PlaySound('/shared/sounds/ui/revamp/region_click.wav') Player_Stats_V2:OnClickTab('{type}')"
				onmouseoverlua="PlaySound('/shared/sounds/ui/revamp/region_hover.wav')"
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/newui/res/playerstats/tab_unselected.png" width="164.1%" height="64i" align="center" valign="center" noclick="1"/>
				<panel x="{offset=15i}" noclick="1" float="right">
					<panel width="36i" noclick="1">
						<image texture="/ui/fe2/newui/res/playerstats/{type}_unselected.png" width="64i" height="64i" align="center" valign="center" noclick="1"/>
					</panel>
					<label textalign="left" textvalign="center" font="dyn_12" color="#bea693" outline="1" outlinecolor="#3a211d" content="{content}" noclick="1"/>
				</panel>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/newui/res/playerstats/tab_hover.png" width="164.1%" height="64i" align="center" valign="center" noclick="1"/>
				<panel x="{offset=15i}" noclick="1" float="right">
					<panel width="36i" noclick="1">
						<image texture="/ui/fe2/newui/res/playerstats/{type}_hover.png" width="64i" height="64i" align="center" valign="center" noclick="1"/>
					</panel>
					<label textalign="left" textvalign="center" font="dyn_12" color="#c1a695" outline="1" outlinecolor="#3a211d" content="{content}" noclick="1"/>
				</panel>
			</widgetstate>
			<widgetstate statename="down">
				<image texture="/ui/fe2/newui/res/playerstats/tab_unselected.png" width="164.1%" height="64i" align="center" valign="center" noclick="1"/>
				<panel x="{offset=15i}" noclick="1" float="right">
					<panel width="36i" noclick="1">
						<image texture="/ui/fe2/newui/res/playerstats/{type}_unselected.png" width="64i" height="64i" align="center" valign="center" noclick="1"/>
					</panel>
					<label textalign="left" textvalign="center" font="dyn_12" color="#bea693" outline="1" outlinecolor="#3a211d" content="{content}" noclick="1"/>
				</panel>
			</widgetstate>
			<widgetstate statename="disabled">
				<image texture="/ui/fe2/newui/res/playerstats/tab_selected.png" width="164.1%" height="64i" align="center" valign="center" noclick="1"/>
				<panel x="{offset=15i}" noclick="1" float="right">
					<panel width="36i" noclick="1">
						<image texture="/ui/fe2/newui/res/playerstats/{type}_selected.png" width="64i" height="64i" align="center" valign="center" noclick="1"/>
					</panel>
					<label textalign="left" textvalign="center" font="dyn_12" color="#daf5f0" outline="1" outlinecolor="#0d3d3f" content="{content}" noclick="1"/>
				</panel>
			</widgetstate>
		</button> 
	</template>

	<template name="playerstats_hero_fav_template">
		<panel x="{x=0i}" y="{y=0i}" width="{width=180i}" height="{height=100%}">
			<panel width="51i" height="51i" y="10i" align="center" valign="top" >
				<image name="playerstats_hero_fav_{index}_icon" texture="$invis" width="-6i" height="-6i" align="center" valign="center" usealphamask="true" alphamaskfile="/ui/fe2/elements/store2/mask.png" noclick="1"/>
				<image name="playerstats_hero_fav_{index}_border" texture="/ui/fe2/newui/res/homepage/border_iron.png"/>
			</panel>
			<label name="playerstats_hero_fav_{index}_name" y="60i" height="25i" valign="top" textalign="center" textvalign="center" font="dyn_10" color="#ab927e" noclick="0"/>
			<label name="playerstats_hero_fav_{index}_percent" y="85i" height="25i" valign="top" textalign="center" textvalign="center" font="dyn_10" color="#e29c08" noclick="0"/>
		</panel>
	</template>

	<template name="playerstats_mastery_level_template">
		<panel name="playerstats_mastery_level_{index}" width="100%" height="60i" noclick="1" visible="0">
			<image texture="/ui/fe2/newui/res/common/line.png" width="100%" height="2i" align="center" noclick="1" visible="{showline=1}"/>
			<panel width="51i" height="51i" valign="center">
				<image name="playerstats_mastery_level_{index}_icon" texture="$invis" width="-6i" height="-6i" align="center" valign="center" usealphamask="true" alphamaskfile="/ui/fe2/elements/store2/mask.png" noclick="1"/>
				<image name="playerstats_mastery_level_{index}_border" texture="/ui/fe2/newui/res/homepage/border_iron.png"/>
			</panel>
			<label name="playerstats_mastery_level_{index}_name" x="70i" y="-10i" textalign="left" textvalign="center" font="dyn_11" color="#efd2c0" noclick="1"/>
			<label name="playerstats_mastery_level_{index}_level" x="70i" y="10i" textalign="left" textvalign="center" font="dyn_10" color="#ae9380" noclick="1"/>
		</panel>
	</template>

	<template name="playerstats_mastery_all_item_template">
		<panel name="playerstats_mastery_all_item_{row}_{id}" width="153i" height="214i"
			onmousewheeldown="CallEvent('playerstats_mastery_scroll', 1);"
			onmousewheelup="CallEvent('playerstats_mastery_scroll', 0);"
		>
			<image name="playerstats_mastery_all_item_{row}_{id}_icon" y="8i" width="130i" height="130i" align="center" noclick="1"/>
			<image name="playerstats_mastery_all_item_{row}_{id}_border" texture="/ui/fe2/newui/res/playerstats/border_iron.png" width="256i" height="256i" align="center" valign="center" noclick="1"/>
			<label name="playerstats_mastery_all_item_{row}_{id}_name" textalign="center" textvalign="center" y="-45i" valign="bottom" height="30i" font="dyn_10" color="#fffdf6" outline="1" outlinecolor="#803705" noclick="1"/>
			<label name="playerstats_mastery_all_item_{row}_{id}_level" textalign="center" textvalign="center" y="-25i" valign="bottom" height="30i" font="dyn_10" color="#fffdf6" outline="1" outlinecolor="#803705" noclick="1"/>
		</panel>
	</template>

	<template name="playerstats_mastery_all_row_template">
		<panel name="playerstats_mastery_all_row_{row}" grow="1" height="214i" noclick="1" float="right" padding="25i" align="center" stickytoinvis="false" visible="0"
			onmousewheeldown="CallEvent('playerstats_mastery_scroll', 1);"
			onmousewheelup="CallEvent('playerstats_mastery_scroll', 0);"
		>
			<instance name="playerstats_mastery_all_item_template" row="{row}" id="0"/>
			<instance name="playerstats_mastery_all_item_template" row="{row}" id="1"/>
			<instance name="playerstats_mastery_all_item_template" row="{row}" id="2"/>
			<instance name="playerstats_mastery_all_item_template" row="{row}" id="3"/>
			<instance name="playerstats_mastery_all_item_template" row="{row}" id="4"/>
		</panel>
	</template>

	<template name="playerstats_mastery_overall_reward_template">
		<panel name="playerstats_mastery_overall_reward_{index}" height="64i" stickytoinvis="false"
			onmousewheeldown="CallEvent('playerstats_mastery_overallrewards_scroll', 1);"
			onmousewheelup="CallEvent('playerstats_mastery_overallrewards_scroll', 0);"
		>
			<panel name="playerstats_mastery_overall_reward_{index}_body" width="100%" height="100%" noclick="0"
				onclicklua="Player_Stats_V2:OnClickClaimMasteryReward({index})"
				onmouseoverlua="self:GetWidget('playerstats_mastery_overall_reward_{index}_bg'):SetTexture('/ui/fe2/newui/res/common/list_item_bg_selected16.png')"
				onmouseldownlua="self:GetWidget('playerstats_mastery_overall_reward_{index}_bg'):SetTexture('/ui/fe2/newui/res/common/list_item_bg.png')"
				onmouseoutlua="self:GetWidget('playerstats_mastery_overall_reward_{index}_bg'):SetTexture('/ui/fe2/newui/res/common/list_item_bg.png')"
				onmousewheeldown="CallEvent('playerstats_mastery_overallrewards_scroll', 1);"
				onmousewheelup="CallEvent('playerstats_mastery_overallrewards_scroll', 0);"
			>
				<image name="playerstats_mastery_overall_reward_{index}_bg" texture="/ui/fe2/newui/res/common/list_item_bg.png" width="100%" height="64i" align="center" valign="center" noclick="1"/>
				<panel x="16i" width="54i" height="54i" valign="center" noclick="0"
					onmouseoverlua="
						self:GetWidget('playerstats_mastery_overall_reward_{index}_bg'):SetTexture('/ui/fe2/newui/res/common/list_item_bg_selected16.png')
						self:GetWidget('playerstats_mastery_overall_reward_{index}_icon_mask'):SetVisible(0)
						"
					onmouseldownlua="self:GetWidget('playerstats_mastery_overall_reward_{index}_bg'):SetTexture('/ui/fe2/newui/res/common/list_item_bg.png')"
					onmouseoutlua="
						self:GetWidget('playerstats_mastery_overall_reward_{index}_bg'):SetTexture('/ui/fe2/newui/res/common/list_item_bg.png')
						self:GetWidget('playerstats_mastery_overall_reward_{index}_icon_mask'):SetVisible(1)
						"
					onmousewheeldown="CallEvent('playerstats_mastery_overallrewards_scroll', 1);"
					onmousewheelup="CallEvent('playerstats_mastery_overallrewards_scroll', 0);"
				>
					<instance name="newui_custom_frame_template"/>
					<image name="playerstats_mastery_overall_reward_{index}_icon" texture="$invis" width="-4i" height="-4i" align="center" valign="center" noclick="1"/>
					<panel name="playerstats_mastery_overall_reward_{index}_icon_mask" width="-4i" height="-4i" align="center" valign="center" noclick="1" color="0 0 0 .1"/>
				</panel>
				<label name="playerstats_mastery_overall_reward_{index}_value" x="100i" y="10i" textvalign="center" font="dyn_12" color="white" outline="1" outlinecolor="black" noclick="1" visible="0"/>
				<label name="playerstats_mastery_overall_reward_{index}_text" x="100i" y="-10i" textvalign="center" font="dyn_12" color="white" outline="1" outlinecolor="black" noclick="1"/> 
				<label name="playerstats_mastery_overall_reward_{index}_level" x="100i" y="10i" textvalign="center" font="dyn_12" color="white" outline="1" outlinecolor="black" noclick="1"/>
				<panel x="-17i" width="32i" height="32i" align="right" valign="center" noclick="0">
					<image name="playerstats_mastery_overall_reward_{index}_claim_icon" texture="$invis" align="center" valign="center" noclick="1"/>
				</panel>
				<image name="playerstats_mastery_overall_reward_{index}_line" texture="/ui/fe2/newui/res/common/line.png" y="2i" width="100%" height="2i" align="center" valign="bottom" noclick="1" visible="{showline=1}"/>
			</panel>
			<panel name="playerstats_mastery_overall_reward_{index}_mask" color="0 0 0 .5" noclick="1"/>
		</panel> 
	</template>

	<template name="playerstats_mastery_level_reward_template">
		<panel height="40i">                                   
			<panel x="20i" width="100@" align="left"
				onmouseoverlua="Common_V2:ShowGenericTip(true, 'mastery_levelreward_{index}', 'mastery_levelreward_desc_{index}')"
				onmouseoutlua="Common_V2:ShowGenericTip(false)"
			>
				<instance name="newui_custom_frame_template"/>     
				<image texture="/ui/fe2/mastery/reward_level_{index}.tga" width="30i" height="30i" align="center" valign="center" noclick="1"/>
			</panel>
			<panel x="85i" width="190i" align="left">
				<instance name="newui_custom_frame_template"/>     
				<label textalign="center" textvalign="center" align="left" x="0i" width="50i" font="dyn_12" color="#ac9180" content="{index}" noclick="1"/>
				<image texture="/ui/fe2/newui/res/common/line2.png" x="52i" width="2i" height="100%" valign="center" />
				<label name="playerstats_mastery_level_reward_{index}_number" x="70i" width="120i" align="left" textalign="center" textvalign="center" font="dyn_12" color="#ac9180" noclick="1"/>
			</panel>
		</panel>
	</template>
	
	<template name="playerstats_button_template">
		<button name="{button_name}" x="{x}" y="{y}" width="{width=100%}" height="{height=100%}" align="{align=center}" valign="{valign=center}" color="invisible" onclicklua="{onclicklua}"
				watch="{watch}" ontriggerlua="{ontriggerlua}"
		>
			<widgetstate statename="up">
				<image name="{button_name}_up" texture="{image_up=$invis}" width="{img_width=64i}" height="{img_height=64i}" align="center" valign="center" noclick="1"/>
				<label width="-10i" align="center" textalign="center" textvalign="center" font="dyn_12" color="#fffdf6" noclick="1" content="{label}"/>
			</widgetstate>
			<widgetstate statename="over">
				<image name="{button_name}_over" texture="{image_over=$invis}" width="{img_width=64i}" height="{img_height=64i}" align="center" valign="center" noclick="1"/>
				<label width="-10i" align="center" textalign="center" textvalign="center" font="dyn_12" color="#fffdf6" noclick="1" content="{label}"/>
			</widgetstate>
			<widgetstate statename="down" y="1">
				<image name="{button_name}_down" texture="{image_down=$invis}" width="{img_width=64i}" height="{img_height=64i}" align="center" valign="center" noclick="1"/>
				<label width="-10i" align="center" textalign="center" textvalign="center" font="dyn_12" color="#fffdf6" noclick="1" content="{label}"/>
			</widgetstate>
			<widgetstate statename="disabled">
				<image name="{button_name}_disabled" texture="{image_disabled=$invis}" width="{img_width=64i}" height="{img_height=64i}" align="center" valign="center" rendermode="grayscale" noclick="1"/>
				<label width="-10i" align="center" textalign="center" textvalign="center" font="dyn_12" color="#fffdf6" noclick="1" content="{label}"/>
			</widgetstate>
		</button>
	</template>

	<template name="playerstats_stats_horizontal_item_template">
		<panel name="horizontal_stats_item_{prefix}{item_name}" x="{x=0}" y="{y=0}" width="{width=100%}" height="{height=30i}" float="right" noclick="1">
			<panel x="6%" width="{name_width=54%}" noclick="1">
				<label textalign="left" textvalign="center" font="{font=dyn_12}" color="#bd9f8d" content="{item_name}" noclick="1" />
			</panel>
			<panel width="{data_width=34%}" noclick="1">
				<label textalign="left" textvalign="center" font="{font=dyn_12}" color="#bd9f8d" content=":" noclick="1"/>
				<label name="stats_data_{prefix}{item_name}" textalign="right" textvalign="center" font="{font=dyn_12}" color="#8e6b5b" content="-" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="playerstats_stats_vertical_item_template">
		<panel name="vertical_stats_item_{prefix}{item_name}" x="{x=0}" y="{y=0}" width="{width=64i}" height="{height=100%}" noclick="1">
			<image texture="/ui/fe2/newui/res/playerstats/v_stats_item_bg.png"  align="center" valign="center" width="128i" height="128i" noclick="1" />
			<image name="stats_icon_{prefix}{item_name}" texture="{item_icon}" align="center" valign="top" width="32i" height="32i" noclick="1" />
			<label name="stats_data_{prefix}{item_name}" textalign="center" textvalign="center" align="center" valign="center" font="dyn_12" color="#f1dbcb" content="-" noclick="0"
				   onmouseoverlua="if {has_tip=false} then ShowWidget('{tip_name}') end"
				   onmouseoutlua="if {has_tip=false} then HideWidget('{tip_name}') end"
			/>
			<label name="stats_name_{prefix}{item_name}" textalign="center" textvalign="center" y="75%" height="20i" font="dyn_10" color="#ac9a81" content="{item_name}" noclick="0"/>
		</panel>
	</template>

	<template name="playerstats_mvpawards_template">
		<panel name="mvpaward_{awd_code}" x="{x=0}" y="{y=0}" width="{width=100%}" height="{height=100%}" noclick="false" align="{align=center}" valign="{valign=center}">
			<image texture="{awd_bg=/ui/fe2/newui/res/playerstats/mvpawards/item_bg.png}" align="center" valign="center" width="256i" height="512i" noclick="true" />
			<image name="awd_icon_{awd_code}" y="-14%" texture="{awd_icon}" width="80@" height="80%" align="center" valign="center" rendermode="{rendermode}" noclick="true" />
			<label textalign="center" textvalign="center" align="center" valign="center" y="26%" width="100%" height="13%" color="#ffde5c" outline="true" outlinecolor="#581b08" font="{font=dyn_12}" content="{awd_name}" autofont="false" noclick="true"/>
			<panel y="42%" width="80%" height="15%" align="center" valign="center" noclick="true">
				<image name="awd_score_icon_{awd_code}" texture="{awd_score_icon}" align="left" valign="center" x="{score_icon_offset=20%}" width="{score_icon_width=100@}" height="{score_icon_height=100%}" rendermode="{rendermode}" noclick="true" />
				<label name="awd_score_sum_{awd_code}" textalign="center" textvalign="center" align="right" valign="center" width="80%" height="100%" color="#CFC2A6" outline="true" outlinecolor="0 0 0 0.35" font="dyn_12" content="x {awd_score_sum=-}" noclick="true"/>
			</panel>
		</panel>
	</template>

	<template name="playerstats_match_row_template">
		<panel name="playerstats_match_row_{row}" height="50i" align="center"
			onmousewheeldown="CallEvent('playerstats_match_list_scroll', 1);"
			onmousewheelup="CallEvent('playerstats_match_list_scroll', 0);"
		>
			<instance name="newui_custom_frame_template" />
			<panel x="1i" height="100%" float="right" padding="5i" align="left" stickytoinvis="false" noclick="0"
				onclicklua="Player_Stats_V2:OnClickMatchDetail({match_id})"
				onmouseoverlua="
					GetWidget('playerstats_match_row_bg_{row}'):SetTexture('/ui/fe2/newui/res/playerstats/match_list_selected.png')
					GetWidget('playerstats_match_row_hero_name_{row}'):SetColor('#FFDCC5')
					GetWidget('playerstats_match_row_kda_{row}'):SetColor('#FFDCC5')
					GetWidget('playerstats_match_row_duration_{row}'):SetColor('#FFDCC5')
					GetWidget('playerstats_match_row_map_{row}'):SetColor('#FFDCC5')
					GetWidget('playerstats_match_row_time_{row}'):SetColor('#FFDCC5')
					GetWidget('playerstats_match_row_id_{row}'):SetColor('#FFDCC5')
					GetWidget('playerstats_match_row_hero_name_{row}'):SetOutlineColor('#A56E4D')
					GetWidget('playerstats_match_row_kda_{row}'):SetOutlineColor('#A56E4D')
					GetWidget('playerstats_match_row_duration_{row}'):SetOutlineColor('#A56E4D')
					GetWidget('playerstats_match_row_map_{row}'):SetOutlineColor('#A56E4D')
					GetWidget('playerstats_match_row_time_{row}'):SetOutlineColor('#A56E4D')
					GetWidget('playerstats_match_row_id_{row}'):SetOutlineColor('#A56E4D')
					"
				onmouseldownlua=""
				onmouseluplua=""
				onmouseoutlua="
					GetWidget('playerstats_match_row_bg_{row}'):SetTexture('$invis')
					GetWidget('playerstats_match_row_hero_name_{row}'):SetColor('#AC9180')
					GetWidget('playerstats_match_row_kda_{row}'):SetColor('#AC9180')
					GetWidget('playerstats_match_row_duration_{row}'):SetColor('#AC9180')
					GetWidget('playerstats_match_row_map_{row}'):SetColor('#AC9180')
					GetWidget('playerstats_match_row_time_{row}'):SetColor('#AC9180')
					GetWidget('playerstats_match_row_id_{row}'):SetColor('#AC9180')
					GetWidget('playerstats_match_row_hero_name_{row}'):SetOutlineColor('#230000')
					GetWidget('playerstats_match_row_kda_{row}'):SetOutlineColor('#230000')
					GetWidget('playerstats_match_row_duration_{row}'):SetOutlineColor('#230000')
					GetWidget('playerstats_match_row_map_{row}'):SetOutlineColor('#230000')
					GetWidget('playerstats_match_row_time_{row}'):SetOutlineColor('#230000')
					GetWidget('playerstats_match_row_id_{row}'):SetOutlineColor('#230000')
					"
				onmousewheeldown="CallEvent('playerstats_match_list_scroll', 1);"
				onmousewheelup="CallEvent('playerstats_match_list_scroll', 0);"
			>
				<image name="playerstats_match_row_bg_{row}" texture="$invis" width="100%" height="100%" align="center" valign="center" noclick="1"/>
				<image name="playerstats_match_row_hero_icon_{row}" x="2i" y="2i" width="46i" height="46i" align="left" valign="top" texture="$invis" noclick="1" />
				<label name="playerstats_match_row_hero_name_{row}" textalign="center" textvalign="center" width="160i" align="left" font="dyn_12" color="#AC9180" outline="1" outlinecolor="#230000" content="---" noclick="1" />
				<image name="playerstats_match_row_result_{row}" width="128i" height="32i" align="left" valign="center" texture="/ui/fe2/newui/res/playerstats/match_result_victory.png" noclick="1" />
				<label name="playerstats_match_row_kda_{row}" textalign="center" textvalign="center"  width="100i" align="left" valign="center" font="dyn_12" color="#AC9180" outline="1" outlinecolor="#230000" content="^g00/^r00/^y00" noclick="1" />
				<label name="playerstats_match_row_duration_{row}" textalign="center" textvalign="center" width="100i" align="left" valign="center" font="dyn_12" color="#AC9180" outline="1" outlinecolor="#230000" content="00:00" noclick="1" />
				<label name="playerstats_match_row_map_{row}" textalign="center" textvalign="center" width="230i" align="left" valign="center" font="dyn_12" color="#AC9180" outline="1" outlinecolor="#230000" content="Forests of Caldavars" noclick="1" />
				<label name="playerstats_match_row_time_{row}" textalign="center" textvalign="center" width="260i" align="left" valign="center" font="dyn_12" color="#AC9180" outline="1" outlinecolor="#230000" content="00/00/0000 00:00:00 PM" noclick="1" />
				<label name="playerstats_match_row_id_{row}" textalign="center" textvalign="center" width="150i" align="left" valign="center" font="dyn_12" color="#AC9180" outline="1" outlinecolor="#230000" content="123456789" noclick="1" />
			</panel>
		</panel>
	</template>
	
	<template name="playerstats_switch_accounts_list_item_template">
		<panel name="playerstats_switch_accounts_list_item_{row}" height="45i" align="center"
			onmousewheeldown="CallEvent('playerstats_switch_accounts_list_scroll', 1);"
			onmousewheelup="CallEvent('playerstats_switch_accounts_list_scroll', 0);"
		>
			<panel width="100%" height="100%" noclick="0"
				onclicklua="Player_Stats_V2:OnClickSwitchAccount({row})"
				onmouseoverlua="GetWidget('playerstats_switch_accounts_list_item_bg_{row}'):SetTexture('/ui/fe2/newui/res/common/list_item_bg_selected16.png')"
				onmouseldownlua=""
				onmouseluplua=""
				onmouseoutlua="GetWidget('playerstats_switch_accounts_list_item_bg_{row}'):SetTexture('/ui/fe2/newui/res/common/list_item_bg.png')"
				onmousewheeldown="CallEvent('playerstats_switch_accounts_list_scroll', 1);"
				onmousewheelup="CallEvent('playerstats_switch_accounts_list_scroll', 0);"
			>
				<image name="playerstats_switch_accounts_list_item_bg_{row}" texture="/ui/fe2/newui/res/common/list_item_bg.png" width="100%" height="100%" align="center" valign="center" noclick="1"/>
				<label name="playerstats_switch_accounts_list_item_name_{row}" textalign="center" textvalign="center" font="dyn_12" color="{name_color=#CFC2A6}" content="{account_name}" noclick="1" />
				<image name="playerstats_switch_accounts_list_item_line_{row}" texture="/ui/fe2/newui/res/common/line.png" width="100%" height="2i" align="center" valign="bottom" noclick="1" visible="{showline=1}"/>
			</panel>
		</panel>
	</template>
	
	<template name="playerstats_switch_sub_confirm_body">
		<panel width="100%" grow="true" align="center" float="bottom" padding="1.0h" noclick="true">
			<panel grow="true" y="1.0h" width="100%">
				<label fity="true" width="-1.0h" align="center" textalign="center" textvalign="top" font="dyn_11" color="white" shadow="true" wrap="true" content="confirm_switchsub_msg"/>
			</panel>
			<panel height="2.4h" noclick="true" align="center"
				onload="If(!VarExists('subswitch_dontask'), DoEvent()); Instantiate('Noptions_checkbox', 'width', '22.0h', 'align', 'right', 'valign', 'center', 'font', 'dyn_10', 'label', 'confirm_switchsub_da', 'cvar', 'subswitch_dontask', 'interactive', 'false'); "
				onevent="CreateBool('subswitch_dontask', 0); SetSave('subswitch_dontask');"
			>
			</panel>
			<panel height="5h" noclick="true">
				<instance name="newui_common_button_2_template" button_name="playerstats_conf_switch_sub_cancel"
					x="7.0h"
					width="12.0h"
					align="center"
					valign="center"
					label="general_cancel"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclicklua="Player_Stats_V2:OnClickedConfirmSwitchAccountCancel()"
					interactive="{interactive}"
				/>
				<instance name="newui_common_button_2_template" button_name="playerstats_conf_switch_sub_ok"
					x="-7.0h"
					width="12.0h"
					align="center"
					valign="center"
					label="general_ok"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclicklua="Player_Stats_V2:OnClickedConfirmSwitchAccountOk()"
					interactive="{interactive}"
				/>
			</panel>
		</panel>
	</template>

	<template name="playerstats_claim_mastery_reward_fail_body">
