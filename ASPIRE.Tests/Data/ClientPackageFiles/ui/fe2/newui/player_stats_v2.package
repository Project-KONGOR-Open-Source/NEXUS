						<panel name="playerstats_match_no_history" visible="0">
							<instance name="newui_custom_frame_template"/>
							<label height="100%" width="-8.0h" align="center" textalign="center" textvalign="center" wrap="true" font="dyn_16" color="#f1dbcb" content="player_stats_nohistory"/>
						</panel>
					</panel>

					<scrollbar  name="playerstats_match_list_scroll"
								x="1266i"
								y="90i"
								align="left"
								width="12i"
								height="560i"
								valign="top"
								scrollbarsize="12i"
								handlewidth="12i"
								handleheight="25i"							
								texture="/ui/fe2/newui/res/common/scroll/scroll.png"
								scrollbarplaceholder="true"
								minvalue="1"
								maxvalue="1"							
								step="20"
								value="1"
								vertical="true"
								slotwidth="0.6h" slotheight="1"
								onevent1="SetValue(GetValue+20);"
								onevent0="SetValue(GetValue-20);"
								onslidelua="Player_Stats_V2:UpdateMatchList()"
					/>

					<instance name="newui_combobox_template" widgetname="playerstats_match_ranktype" x="1087i" y="9i" width="191i" height="32i" align="left" valign="top"
							onselectlua="Player_Stats_V2:OnSelectMatchRankType()"
					/>
				</panel>

				<panel name="playerstats_waiting_mask" visible="0" color="0 0 0 .7">
					<animatedimage texture="/ui/fe2/elements/store2/loading/loading_.png" width="512i" height="128i" align="center" valign="center" fps="25" loop="true" loopbackframe="0" startframe="0" onshow="StartAnim();" />
				</panel>

				<panel name="playerstats_loadingentity_mask" width="100w" height="100h" align="center" valign="center" visible="0" color="0 0 0 .7">
					<label textalign="center" textvalign="center" font="dyn_18" color="#f0d3c1" outline="1" outlinecolor="#230000" content="newui_playerstats_loading" noclick="0"/>
					<panel width="682i" height="64i" y="40i" align="center" valign="center">
						<image texture="/ui/fe2/newui/res/playerstats/loading_progress_bg.png" width="1024i" noclick="0"/>
						<panel>
							<panel width="0%" clip="1" watch="EntityDefinitionsProgress" ontriggerlua="local percent = tonumber(param0) / tonumber(param1) * 100
																									self:SetWidth(tostring(percent)..'%')">
								<image texture="/ui/fe2/newui/res/playerstats/loading_progress.png" width="1024i" height="64i" valign="center" noclick="0"/>
							</panel>
						</panel>
					</panel>
				</panel>

				<panel name="playerstats_switch_account_confirm_mask" visible="0" color="0 0 0 .7">
					<instance name="newui_common_popup" width="600i" id="switch_sub_confirm" visible="1" show_close="1"
						title="newui_playerstats_switch_accounts_caption" 
						content="playerstats_switch_sub_confirm_body"
						oncloselua="GetWidget('playerstats_switch_account_confirm_mask'):FadeOut(250)"
					/>
				</panel>

				<panel name="playerstats_claim_mastery_reward_fail_mask" visible="0" color="0 0 0 .7">
					<instance name="newui_common_popup" width="300i" id="claim_mastery_reward_fail" visible="1" show_close="0"
						title="newui_lobby_popup_error" 
						content="playerstats_claim_mastery_reward_fail_body"
					/>
				</panel>
			</panel>

		</panel>

		<panel name="playerstats_helper" width="1" height="1" noclick="1" onloadlua="Player_Stats_V2:Init()"/>
	</template>
</package>