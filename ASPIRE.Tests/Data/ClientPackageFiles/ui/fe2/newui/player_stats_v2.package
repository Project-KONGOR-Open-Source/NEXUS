						<panel name="playerstats_social_buttons" x="246i" y="8i" width="116i" height="64i" align="left" valign="bottom" noclick="1" visible="1">
							<!--instance name="playerstats_button_template" button_name="playerstats_chat" x="-16i" width="25i" height="25i" align="left"
									  image_up="/ui/fe2/newui/res/playerstats/chat_up.png"
