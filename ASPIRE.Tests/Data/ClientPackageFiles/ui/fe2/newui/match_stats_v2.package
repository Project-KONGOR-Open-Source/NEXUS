				<label name="rewardstat_soccer_mategoals_{team}_{index}" noclick="1" content="5" color="white" font="dyn_24" shadow="1" 
					align="center" valign="center" textalign="center" textvalign="center" y="1.5h"
				/>
			</panel>
			
			<!-- Player Award -->
			<panel noclick="1" align="right" width="35%" height="38%" valign="bottom" x="-1.1h" y="0h" float="bottom" padding=".3h">
				<frame color="0 0 0 0" borderthickness="1" bordercolor=".6 .6 .6" width="3.7h" height="3.7h" align="center"
					watch="MatchInfoPlayer{index}"
					ontrigger="If({team} == 1,
									SetBorderColor('#33525f'),
									SetBorderColor('#7b5313')
								);"				
				>						
					<image name="rewardstat_soccer_mateaward1_{team}_{index}" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
				</frame>
				<frame color="0 0 0 0" borderthickness="1" bordercolor=".6 .6 .6" width="3.7h" height="3.7h" align="center"
					watch="MatchInfoPlayer{index}"
					ontrigger="If({team} == 1,
									SetBorderColor('#33525f'),
									SetBorderColor('#7b5313')
								);"				
				>						
					<image name="rewardstat_soccer_mateaward2_{team}_{index}" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
				</frame>
			</panel>
			
		</panel>
	</template>
	
	<template name="ctfEndSplashSidePlayerAward">
		<panel name="{id}" width="{width=100%}" height="{height=100@}" passivechildren="true">
			<image name="{id}Icon" texture="{icon=/ui/elements/hero_picker_icon.tga}"/>
			<frame color="invisible" bordercolor="#6f6f7b" borderthickness="1"/>
		</panel>
	</template>
	
	<!-- CTF Detailed Stats -->
	<template name="rewardstat_detailed_ctf_instance">
		<panel noclick="1" align="center" valign="center" width="96%" height="84%">
			
			<!-- Outside Frame -->
			<!--<frame color="0 0 0 0" borderthickness="1" bordercolor="white" />-->
			
			<!-- Blue Team -->
			<panel name="rewardstats_ctf_blueteam_panel" noclick="1" width="49.5%" align="left">
				<frame texture="/ui/fe2/newui/res/lobby/frame_legion.png" borderthickness="8i" noclick="1"/>
				
				<!-- Title -->
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/ctf/blue_team.png" width="512i" height="32i" x=".8h" y=".8h" />
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/soccer/title_blue.tga" width="256i" height="32i" x="-4h" y=".8h" />
				
				<!-- Top Middle Flag -->
				<panel noclick="1" width="256i" height="256i" x=".3h" y="3.2h" align="center" valign="top">
					<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/ctf/blue_flag.png" />
					<label name="rewardstats_ctf_bluetotalflags" noclick="1" content="5" color="white" font="dyn_72_numeric" shadow="1" 
						align="center" valign="center" textalign="center" textvalign="center" y="-1h"
					/>
				</panel>
				
				<!-- Owner Player Stats -->
				<panel noclick="1" width="95%" height="23%" align="center" valign="center" y=".5h">
					<frame color="0 0 0 0" borderthickness="1" bordercolor="#33525f" />
					
					<!-- Player Icon/MVP -->
					<frame color="0 0 0 0" borderthickness="1" bordercolor="#33525f" width="11.5h" height="11.5h" align="left" valign="center" x="2.3h">						
						<image noclick="1" name="rewardstat_ctf_playerMVP_heroicon_blue" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
						<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/mvp_stats.png" width="64i" height="64i" align="left" valign="top" y="-1.5h" x="-1.5h" />
					</frame>
					
					<!-- Player MVP/Hero Name/Awards -->
					<panel noclick="1" align="left" valign="center" width="30%" height="90%" x="14h">					
						<!--<frame color="0 0 0 0" borderthickness="1" bordercolor="blue" />-->
					
						<panel noclick="1" float="bottom" x="1h" y="1h" padding=".4h">
							<label name="rewardstat_ctf_playerMVP_blue" noclick="1" width="22h" height="2h" color="#ffdcc5" textalign="left" shadow="1" shadowoffset="2" font="dyn_14" content="Player Name"/>
							<label name="rewardstat_ctf_playerMVP_heroname_blue" noclick="1" width="22h" height="2h" color="#a78d7d" textalign="left" shadow="1" shadowoffset="2" font="dyn_12" content="Hero Name"/>
						</panel>
						<panel noclick="1" valign="bottom" float="right" padding=".5h" height="50%" y="1h" x=".7h">
							<instance name="ctfEndSplashSidePlayerAward" id="ctfEndSplashSide1Player1Award1" icon="{icon1Texture=/ui/elements/hero_picker_icon.tga}" width="4.5h" height="4.5h"/>
							<instance name="ctfEndSplashSidePlayerAward" id="ctfEndSplashSide1Player1Award2" icon="{icon2Texture=/ui/elements/hero_picker_icon.tga}" width="4.5h" height="4.5h"/>
						</panel>
					
					</panel>
					
					<!-- Flags Captured -->
					<panel noclick="1" width="17h" height="17h" x="1.6h" y="0.2h" align="right" valign="center">
