			</panel>
			
			<!-- Rank Progression Bar -->
			<panel name="rewardstat_panel_sleepcontrol" noclick="1">
				<panel name="rewardstat_panel_rankprogression" noclick="1" y="9h" x="0h" width="24h" align="center" valign="center" visible="1">
					<piegraph name="rewardstat_bar_rankprogression" texture="/ui/fe2/newui/res/match_stats/rings/ring.tga" value="0" align="center" valign="center"
						start="110" end="430" color="#23bccf" noclick="true" detail="11" width="256i" height="256i" y="-9.9h" x=".5h"
					/>
				</panel>
				<image name="rewardstat_placements_bg" texture="/ui/fe2/season/icon_l/level_16.tga" align="center" valign="center" width="175i" height="175i" noclick="1" x=".5h" y="-.5h" />
				<panel noclick="1" width="18h" height="18h" align="center" valign="center" y="-.4h" x=".8h">
					<modelpanel name="rewardstat_rankup_visualpanel"
						align="center"
						valign="center"
						height="250%"
						width="250%"
						y="-.1h"
						noclick="true"
						anim="idle"
						camerapos="0 0 0"
						cameraangles="0 0 0"
						camerafov="45"
						modelangles="0 0 180"
						modelpos="0 0 0"
						lookat="1"
						watch1="RankUpVisual"
						watch2="RankUpStop"
						ontrigger1="SetModel('/ui/fe2/mainmenu/bg_effects/debug.mdf'); SetEffect(param); SetAnim('idle');"
						ontrigger2="SetModel('/ui/fe2/mainmenu/bg_effects/debug.mdf'); SetEffect(''); SetAnim('idle');"
					/>
				</panel>
				<!-- Rank Progression Label -->
				<label name="rewardstat_label_ranklabel" noclick="1" content="-" color="#f1dbcb" font="dyn_14" visible="0" shadow="1"
					textalign="center" textvalign="center" y="9.2h" x=".4h"
				/>
			</panel>
			
			<!-- Test -->
			<panel noclick="1" color="0 1 0 .03" align="center" valign="bottom" width="80%" height="30%" visible="0">
				
			</panel>
			
		</panel>
	</template>
	
	<!-- Hero Mastery Info -->
	<template name="rewardstat_heromastery_info_instance">
		<panel name="rewardstat_heromastery_info_panel" noclick="1"
			width="25%" height="32%" align="left" valign="bottom"
			x="38.2h" y="-1.2h"
		>
			
			<!-- Frame -->
			<instance name="rewardstat_main_border" />	
			
			<!-- Hero Mastery -->
			<panel noclick="1" height="20%" width="90%" align="center">
				
				<label name="rewardstat_label_heromastery_desc" noclick="1" color="#f1dbcb" font="dyn_12"
					align="center" textalign="left" textvalign="center" content="x" shadow="1" shadowoffset="2"
					onloadlua="local str = Translate('mastery_replay_rewardtab_mastery') self:SetText(string.upper(str))"
				/>
				<image noclick="1" texture="/ui/fe2/NewUI/Res/system_message/item_line.png" width="512i" height="1i" align="center" valign="bottom" />
			</panel>
			
			<panel noclick="1" height="60%" valign="center" float="bottom">
				<!-- Total Experience -->
				<panel noclick="1" height="23%" width="90%" align="center" float="right" padding=".5h">
					<panel width="32i">
						<instance name="rewardstat_icon_mouseover" id="totalexp" icon="/ui/fe2/NewUI/Res/match_stats/total_experience.png"
								onmouseoverlua="
									PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav')
									local desc = Translate('mastery_replay_totalexp')
									local title = Translate('mastery_replay_main_totalexp')
									
									Common_V2:ShowGenericTip(true, title, desc, '{width=300i}')
									"
								onmouseoutlua="Common_V2:ShowGenericTip(false)"
						/>
					</panel>
					<label noclick="1" name="rewardstat_label_heromastery_totalexp_desc" content="mastery_replay_main_totalexp" color="#f1dbcb" font="dyn_11"
						width="15h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
					<label noclick="1" color="#f1dbcb" font="dyn_11" width="2.5h" textalign="left" textvalign="center" content=":" shadow="1" shadowoffset="2" />
					<label noclick="1" name="rewardstat_label_heromastery_totalexp" content="-" color="#f1dbcb" font="dyn_11"
						width="8h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
				</panel>
				<!-- Match Experience -->
				<panel noclick="1" height="23%" width="90%" align="center" float="right" padding=".5h">
					<panel width="32i">
						<instance name="rewardstat_icon_mouseover" id="matchexp" icon="/ui/fe2/NewUI/Res/match_stats/match_experience.png"
								onmouseoverlua="
									PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav')
									local title = Translate('mastery_replay_main_matchexp')
									local desc = Translate('mastery_replay_matchexperience')
									Common_V2:ShowGenericTip(true, title, desc, '{width=300i}')
									"
						/>
					</panel>
					<label noclick="1" name="rewardstat_label_heromastery_matchesexp_desc" content="mastery_replay_main_matchexp" color="#a78d7d" font="dyn_11"
						width="15h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
					<label noclick="1" color="#a78d7d" font="dyn_11" width="2.5h" textalign="left" textvalign="center" content=":" shadow="1" shadowoffset="2" />
					<label noclick="1" name="rewardstat_label_heromastery_matchesexp" content="-" color="#a78d7d" font="dyn_11"
						width="8h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
				</panel>
				<!-- Bonus Exp -->
				<panel noclick="1" height="23%" width="90%" align="center" float="right" padding=".5h">
					<panel width="32i">
						<instance name="rewardstat_icon_mouseover" id="bonusexp" icon="/ui/fe2/NewUI/Res/match_stats/bonus_experience.png"
							onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav')
											local desc = ''
											local desc2 = Translate('mastery_replay_bonustip_nobonus')
											local title = Translate('mastery_replay_main_bonusexp')
											local alreadyhas = false

											if matchStats_maxleveladdon > 0 then
												local value =  matchStats_maxleveladdonPercent
												if value > 50 then value = 50 end
												desc = Translate('mastery_replay_bonustip_maxleveladdon', 'heronum', tostring(matchStats_maxlevelcount), 'value', tostring(value))
												alreadyhas = true
											end

											if matchStats_bonusExp > 0 or matchStats_eventBonus > 0 then
												if alreadyhas then desc = desc..'\n\n' end

												desc = desc..'^852'..Translate('mastery_replay_bonustip_other', 'value', tostring(math.floor((matchStats_bonusExp + matchStats_eventBonus)/ matchStats_matchExp * 100)))..'^*'
											end
											
											if matchStats_maxleveladdon ~= 0 then
												Common_V2:ShowGenericTip(true, title, desc, '{width=300i}')
											else
												Common_V2:ShowGenericTip(true, title, desc2, '{width=300i}')
											end
										"
						/>
					</panel>
					<label noclick="1" name="rewardstat_label_heromastery_bonusexp_desc" content="mastery_replay_main_bonusexp" color="#a78d7d" font="dyn_11"
						width="15h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
					<label noclick="1" color="#a78d7d" font="dyn_11" width="2.5h" textalign="left" textvalign="center" content=":" shadow="1" shadowoffset="2" />
					<label noclick="1" name="rewardstat_label_heromastery_bonusexp" content="-" color="#a78d7d" font="dyn_11"
						width="8h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
				</panel>
				<!-- Boost Experience -->
				<panel noclick="1" height="23%" width="90%" align="center" float="right" padding=".5h">
					<panel width="32i">
						<instance name="rewardstat_icon_mouseover" id="boostexp" icon="/ui/fe2/NewUI/Res/match_stats/boost_experience.png"
							onmouseoverlua="
								PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav')
								local desc = Translate('mastery_replay_boostexp')
								local title = Translate('mastery_replay_main_boostexp')
								Common_V2:ShowGenericTip(true, title, desc, '{width=300i}')
								"
						/>
					</panel>
					<label noclick="1" name="rewardstat_label_heromastery_boostexp_desc" content="mastery_replay_main_boostexp" color="#a78d7d" font="dyn_11"
						width="15h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
					<label noclick="1" color="#a78d7d" font="dyn_11" width="2.5h" textalign="left" textvalign="center" content=":" shadow="1" shadowoffset="2" />
					<label noclick="1" name="rewardstat_label_heromastery_boostexp" content="-" color="#f1dbcb" font="dyn_11"
						width="8h" valign="center" textalign="left" textvalign="center" shadow="1" shadowoffset="2"
					/>
				</panel>
			</panel>
			
			<!-- Next Level Award -->
			<panel name="rewardstat_nextlevelaward_panel" noclick="1" width="90%" height="24%" align="center" valign="bottom">
				<image noclick="1" texture="/ui/fe2/NewUI/Res/system_message/item_line.png" width="512i" height="1i" align="center" valign="top" />
				<label noclick="1" name="rewardstat_label_heromastery_nextrank_desc" content="Next LVL Award:" color="#a78d7d" font="dyn_11"
					textalign="left" textvalign="center" shadow="1" shadowoffset="2"
				/>
				<image name="rewardstat_label_heromastery_nextrank" texture="$invis"
					width="48i" height="48i" align="right" valign="center"
					onmouseoverlua="
						PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav')
						local leveldat = matchStats_UILevel
						if leveldat ~= 0 then
							local desc = (Translate('mastery_levelreward_desc_') .. leveldat)
							local title = (Translate('mastery_levelreward_') .. leveldat)
							
							Common_V2:ShowGenericTip(true, title, desc, '{width=300i}')
						end
						"
					onmouseoutlua="Common_V2:ShowGenericTip(false)"
				/>
				<frame width="48i" height="48i" align="right" valign="center" borderthickness="1" bordercolor="#30221C" color="invisible" noclick="1"/>
				<panel noclick="1" align="right" width="15h" height="15h" valign="center" x="5.3h">
					<modelpanel name="rewardstat_heromastery_info_levelup_effect" align="center" valign="center" noclick="true"
						model="/shared/models/invis.mdf"
						modelpos="0 0 0"
						modelscale="1.0"
						modelangles="0 0 0"
						cameradistance="30"
						camerapos="0 850 0"
						cameraangles="0 0 180"
						camerafov="7"
						cameranear="100.0"
						camerafar="20000.0"
						depthclear="1"
						depthcompress="0"
						sunazimuth="120"
						sunaltitude="20"
						suncolor="0.9 0.9 0.9"
						ambientcolor="0.6 0.7 0.7"
						scenebuffer="1"
						lookat="0"
						visible="1"
					/>
				</panel>
			</panel>
			
		</panel>
	</template>
	
	<!-- Hero Mastery Visual -->
	<template name="rewardstat_heromastery_visual_instance">
		<panel name="rewardstat_heromastery_visual_panel" noclick="0"
			width="25%" height="27%" align="left" valign="center"
			x="38.2h" y=".8h"
		>

			<panel noclick="1" align="left" width="75%" y="-.7h">
				<!-- Mastery Circle -->
				<panel noclick="1" width="18h" height="18h" align="center" valign="center">
					<!-- <piegraph texture="/ui/fe2/NewUI/Res/match_stats/level_ring.tga" value="1" align="center" valign="center"
						start="110" end="430" color=".1 0 .3 1" noclick="true" detail="14" width="256i" height="256i"
					/> -->
					<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_bg.png"
						width="256i" height="256i" align="center" valign="center"
					/>
					<piegraph name="rewardstat_masterypiegraph_masteryboost" texture="/ui/fe2/newui/res/match_stats/rings/ring.tga" value="0" align="center" valign="center"
						start="110" end="430" color="#201800" noclick="true" detail="14" width="254i" height="256i"
					/>
					<piegraph name="rewardstat_masterypiegraph" texture="/ui/fe2/newui/res/match_stats/rings/ring.tga" value="0" align="center" valign="center"
						start="110" end="430" color="#ffc008" noclick="true" detail="14" width="254i" height="256i"
					/>
					<!-- Hero Icon -->
					<panel noclick="1" align="center" valign="bottom" width="128i" height="128i">
						<image name="rewardstat_masteryheroicon" noclick="1" texture="/ui/elements/hero_picker_icon.tga"
							y="5h" width="5.4h" height="5.4h" align="center" valign="center"
							usealphamask="true" alphamaskfile="/ui/masks/hero_circle.tga"
						/>						
						<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rings/mastery_border.png"
							y="5h"
						/>
					</panel>
				</panel>
				<!-- Mastery LVL Label -->
				<label noclick="1" content="LVL" color="#f1dbcb" font="dyn_11" shadow="1" shadowoffset="2"
					align="center" valign="top" textalign="center" textvalign="top" y="5.2h"
				/>
				<!-- Mastery Level -->
				<label name="rewardstat_label_mastery_level" noclick="1" content="0" color="white" font="dyn_60_numeric" shadow="1"
					align="center" valign="center" textalign="center" textvalign="center" y=".2h" x=".2h"
				/>
				<!-- Mastery XP -->
				<label name="rewardstat_label_mastery_exp" noclick="1" content="XP: 0/0" color="#f1dbcb" font="dyn_9" shadow="1" shadowoffset="2"
					align="center" valign="bottom" textalign="center" textvalign="bottom" y="-5.3h"
				/>
				
				<panel noclick="1" color="0 0 1 0" x="1.4h" y=".8h" width="40h" height="40h" align="center" valign="center">
					<modelpanel name="rewardstat_heromastery_visual_levelup_effect" align="center" valign="center" noclick="true"
						model="/shared/models/invis.mdf"
						modelpos="0 0 0"
						modelscale="1.0"
						modelangles="0 0 0"
						cameradistance="30"
						camerapos="7 1100 23"
						cameraangles="0 0 180"
						camerafov="7"
						cameranear="100.0"
						camerafar="20000.0"
						depthclear="1"
						depthcompress="0"
						sunazimuth="120"
						sunaltitude="20"
						suncolor="0.9 0.9 0.9"
						ambientcolor="0.6 0.7 0.7"
						scenebuffer="1"
						lookat="0"
						visible="1"
					/>
				</panel>
				
			</panel>
			
			<panel noclick="1" width="35%" align="right" float="bottom" x=".6h">
				<panel name="rewardstat_superboostpanel" noclick="1" height="50%" visible="1">
					<!-- Super Boost Button -->
					<instance name="rewardstat_boostbutton" type="super" width="4.5h" height="4.5h" align="center" valign="top" x=".3h" y="2h"
						texture="/ui/fe2/mastery/super_boost"
						onclicklua="GetWidget('use_mastery_super_boost_confirm'):SetVisible(1)"
						onmouseoverlua="RewardStat_SuperBoostMouseOverUI(1)"
						onmouseoutlua="RewardStat_SuperBoostMouseOverUI(0)"
					/>
					<panel name="rewardstat_label_mastery_superboosts_labels" noclick="1" y="5h">
						<label noclick="1" color="#f1dbcb" font="dyn_8" align="center" valign="top" textalign="center" textvalign="center" x=".3h" y="-2.5h" content="mastery_replay_main_masterysuperboost"
							onloadlua="local text = Translate('mastery_replay_main_masterysuperboost') self:SetText(string.upper(text))"
						/>
						<label name="rewardstat_label_mastery_superboosts" noclick="1" color="#f1dbcb" font="dyn_8"
							align="center" valign="top" textalign="center" textvalign="center" x=".3h" y="-1.0h" content="X ^o0^*"	
						/>
					</panel>
				</panel>
				<panel name="rewardstat_regularboostpanel" noclick="1" height="50%" valign="bottom">
					<!-- Regular Boost Button -->
					<instance name="rewardstat_boostbutton" type="regular" width="4.5h" height="4.5h" align="center" valign="bottom" x=".3h" y="-3.8h"
						texture="/ui/fe2/mastery/boost_iron" 
						onclicklua="
							if matchStats_boostNum > 0 then
								GetWidget('use_mastery_boost_confirm'):SetVisible(1)
							else
								Trigger('Confirm_Purchase_Other', 'mstore_product'..'3609'..'_name', 'mstore_buyitem_confirm', matchStats_boostCostGold, matchStats_boostCostSilver, 'MASTERY', tostring('3609'), Translate('mastery_replay_main_buy_tip'))
							end
							"
						onmouseoverlua="RewardStat_RegularBoostMouseOverUI(1)"
						onmouseoutlua="RewardStat_RegularBoostMouseOverUI(0)"
						watch="MasteryBoost"
						ontriggerlua="
							GetWidget('rewardstat_operation_mask'):SetVisible(false)
							if tonumber(param0) == 0 then
								Echo('DEBUG: MASTERY BOOST WORKED! Reloading Match ID..')
								Player_Stats_V2:OnClickMatchDetail(matchStats_match_id)
							else
								Echo('DEBUG: FAILED! MASTERY BOOST DID NOT WORK DUE TO AN ERROR RETURNED BY SERVER.')
							end
						"
						watch1="MicroStoreResults"
						ontrigger1lua="
							if tonumber(param78) == 3609 and self:IsVisible() then
								Cmd('UseMasteryBoost ' .. matchStats_match_id)
								GetWidget('rewardstat_operation_mask'):SetVisible(true)
								Match_Stats_MasteryInfo_masktimer = GetTime()
							end
						"
					/>
					<label name="rewardstat_label_mastery_boosts_desc" noclick="1" color="#f1dbcb" height="3h" font="dyn_8" align="center" valign="bottom" textalign="center" textvalign="top" x=".2h" y="-.6h" content="mastery_replay_main_masteryboost" wrap="1"
						onloadlua="local text = Translate('mastery_replay_main_masteryboost') self:SetText(string.upper(text))"
					/>
					<label name="rewardstat_label_mastery_boosts" noclick="1" color="#f1dbcb" font="dyn_8"
						align="center" valign="bottom" textalign="center" textvalign="bottom" y="-.7h" content="X ^o0^*"				
					/>
				</panel>
			</panel>
			
		</panel>
	</template>
	
	<!-- Total Earned -->
	<template name="rewardstat_totalearned_instance">
		<panel name="rewardstat_totalearned_panel" noclick="1"
			width="51.55%" height="19%" align="left" valign="top"
			x="5.2h" y="12.7h"
		>
			
			<panel noclick="1">
