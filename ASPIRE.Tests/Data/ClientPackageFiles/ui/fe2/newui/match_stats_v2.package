						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph name="rewardstat_placementspie_3" texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="197" end="225" color="#00e2ff" value="0" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="255" end="283" color=".2 .2 .2" value="1" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph name="rewardstat_placementspie_4" texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="255" end="283" color="#00e2ff" value="0" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="313" end="342" color=".2 .2 .2" value="1" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph name="rewardstat_placementspie_5" texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="313" end="342" color="#00e2ff" value="0" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="370" end="404" color=".2 .2 .2" value="1" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<piegraph name="rewardstat_placementspie_6" texture="/ui/fe2/NewUI/Res/match_stats/rings/rank_ring.tga" 
						start="370" end="404" color="#00e2ff" value="0" noclick="true" detail="14"
						align="center" valign="center" width="18.5h" height="18.8h" x="-.2h"
					/>
					<!-- Icons -->
					<image name="rewardstat_placementsico_1" noclick="1" visible="1" texture="/ui/fe2/NewUI/Res/match_stats/placements/1th.png"
						width="64i" height="64i" align="center" valign="center" x="-5h" y="7.5h"
					/>
					<image name="rewardstat_placementsico_2" noclick="1" visible="1" texture="/ui/fe2/NewUI/Res/match_stats/placements/2th.png"
						width="64i" height="64i" align="center" valign="center" x="-9.3h" y="-.6h"
					/>
					<image name="rewardstat_placementsico_3" noclick="1" visible="1" texture="/ui/fe2/NewUI/Res/match_stats/placements/3th.png"
						width="64i" height="64i" align="center" valign="center" x="-4.7h" y="-8.3h"
					/>
					<image name="rewardstat_placementsico_4" noclick="1" visible="1" texture="/ui/fe2/NewUI/Res/match_stats/placements/4th.png"
						width="64i" height="64i" align="center" valign="center" x="4.0h" y="-8.3h"
					/>
					<image name="rewardstat_placementsico_5" noclick="1" visible="1" texture="/ui/fe2/NewUI/Res/match_stats/placements/5th.png"
						width="64i" height="64i" align="center" valign="center" x="8.5h" y="-.6h"
					/>
					<image name="rewardstat_placementsico_6" noclick="1" visible="1" texture="/ui/fe2/NewUI/Res/match_stats/placements/6th.png"
						width="64i" height="64i" align="center" valign="center" x="4.2h" y="7.5h"
					/>
