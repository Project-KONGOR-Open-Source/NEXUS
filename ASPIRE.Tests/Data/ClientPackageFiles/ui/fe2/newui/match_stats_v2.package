					ontrigger="If({team} == 1,
									SetBorderColor('#33525f'),
									SetBorderColor('#774830')
								);"/>
			
			<frame color="0 0 0 0" borderthickness="1" bordercolor=".6 .6 .6" width="8h" height="8h" align="center" valign="top" x=".3h" y="1h">						
				<image name="rewardstat_soccer_mateheroicon_{team}_{index}" noclick="1" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
			</frame>
			
