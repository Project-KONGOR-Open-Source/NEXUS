			<panel noclick="1" align="center" valign="center" float="bottom" width="80%" height="18%" y=".3h">
				<label name="rewardstat_soccer_matename_{team}_{index}" noclick="1" width="11h" height="1.8h" color="#ffdcc5" font="dyn_12" textalign="center" shadow="1" shadowoffset="2"
					content="Player Name" 
				/>
				<label name="rewardstat_soccer_matehero_{team}_{index}" noclick="1" width="11h" height="1.8h" color="#a78d7d" font="dyn_10" textalign="center" shadow="1" shadowoffset="2"
					content="Hero Name" 
				/>
			</panel>
			
			<!-- Goals Scored -->
			<panel noclick="1" width="9.8h" height="9.8h" x="-.7h" y="0.2h" align="left" valign="bottom">
				<image noclick="1" width="32i" height="32i" align="center" valign="center" y="-2h" texture="/ui/fe2/NewUI/Res/match_stats/soccer/soccer_legion.tga" watch="MatchInfoPlayer{index}"
					ontrigger="If({team} == 1,
									SetTexture('/ui/fe2/NewUI/Res/match_stats/soccer/soccer_legion.tga'),
									SetTexture('/ui/fe2/NewUI/Res/match_stats/soccer/soccer_hellbourne.tga')
