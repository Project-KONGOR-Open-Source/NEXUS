	<!-- Rewards Stats Row -->
	<template name="matchStatsTotalsPlayerStatRow">
		<panel height="3h">
			<panel width="11h">
				<frame y="0" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".3 .3 .3 .9" noclick="1" />
				<frame y="0" texture="/ui/frames/roundframe.tga" color="0 0 0 .4" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label textalign="center" textvalign="center" color="#adc0cf" font="dyn_12" content="{label=---}"/>
			</panel>
			<panel align="right" width="-12h">
				<frame y="0" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".3 .3 .3 .9" noclick="1" />
				<frame y="0" texture="/ui/frames/roundframe.tga" color="0 0 0 .4" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label name="{id}" textalign="center" textvalign="center" color="{#a6bcc7}" font="dyn_12" watch="{watch}" ontrigger="{ontrigger}" ontriggerlua="{ontriggerlua}" content="-"/>
			</panel>
		</panel>
	</template>
	
	<!-- CTF Other Player Instance -->
	<template name="rewardstat_ctf_otherplayerinstance">
		<panel name="rewardstat_ctf_otherplayerinstance_{team}_{index}" noclick="1" width="13.6h">			
			<!-- Border -->
			<frame color="0 0 0 0" borderthickness="1" bordercolor="#33525f" watch="MatchInfoPlayer{index}"
					ontrigger="If({team} == 1,
									SetBorderColor('#33525f'),
									SetBorderColor('#7b5313')
								);"/>
			
			<frame color="0 0 0 0" borderthickness="1" bordercolor="#33525f" width="8h" height="8h" align="center" valign="top" x=".3h" y="1h">						
				<image name="rewardstat_ctf_otherplayerinstance_heroico_{team}_{index}" noclick="1" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
			</frame>
		
			<!-- Player/Hero Name -->
			<panel noclick="1" align="center" valign="center" float="bottom" width="80%" height="18%" y=".3h">
				<label name="rewardstat_ctf_otherplayerinstance_name_{team}_{index}" noclick="1" width="11h" height="1.8h" color="#ffdcc5" font="dyn_12" textalign="center" shadow="1" shadowoffset="2"
					content="Player Name" 
				/>
				<label name="rewardstat_ctf_otherplayerinstance_hero_{team}_{index}" noclick="1" width="11h" height="1.8h" color="#a78d7d" font="dyn_10" textalign="center" shadow="1" shadowoffset="2"
					content="Hero Name" 
				/>
			</panel>
			
			<!-- Flags Captured -->
			<panel noclick="1" width="9.8h" height="9.8h" x="-.7h" y="0.2h" align="left" valign="bottom">
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/ctf/blue_flag.png" />
				<label name="rewardstat_ctf_otherplayerinstance_flags_{team}_{index}" noclick="1" content="5" color="white" font="dyn_24" shadow="1" 
					align="center" valign="center" textalign="center" textvalign="center" y="-1h"
				/>
			</panel>
			
			<!-- Player Award -->
			<panel name="rewardstat_ctf_funawards_panel_{index}_{team}" noclick="1" align="right" width="35%" height="38%" valign="bottom" x="-1.1h" y="0h" float="bottom" padding=".3h">
				<frame color="0 0 0 0" borderthickness="1" bordercolor="#33525f" width="3.7h" height="3.7h" align="center"
					watch="MatchInfoPlayer{index}"
					ontrigger="If({team} == 1,
									SetBorderColor('#33525f'),
									SetBorderColor('#7b5313')
								);"
				>						
					<image name="rewardstat_ctf_playeraward_1_{index}_{team}" noclick="1" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
				</frame>
				<frame color="0 0 0 0" borderthickness="1" bordercolor="#33525f" width="3.7h" height="3.7h" align="center"
					watch="MatchInfoPlayer{index}"
					ontrigger="If({team} == 1,
									SetBorderColor('#33525f'),
									SetBorderColor('#7b5313')
								);"				
				>						
					<image name="rewardstat_ctf_playeraward_2_{index}_{team}" noclick="1" texture="/ui/elements/hero_picker_icon.tga" width="94%" height="94%" align="center" valign="center" />
				</frame>
			</panel>
			
		</panel>
	</template>
	
	<!-- Soccer Other Player Instance -->
	<template name="rewardstat_soccer_otherplayerinstance">
		<panel name="rewardstat_soccer_otherplayerinstance_{team}_{index}" noclick="1" width="13.6h">			
			<!-- Border -->
