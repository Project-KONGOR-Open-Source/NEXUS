						/>
					</panel>
					<!-- Wins -->
					<panel noclick="1" float="right" padding="1h" x="2h" y="6h" height="3h">
						<instance name="newui_tip_button_template" align="left" valign="center" title="ms_toolip_reward_wins" desc="ms_toolip_desc_reward_wins"/>
						<label noclick="1" color="#a78d7d" font="dyn_11" content="Wins" shadow="1" shadowoffset="2"
							textalign="left" textvalign="center" valign="center" width="10.5h" height="16i"
						/>
						<panel width="50%" height="22i" valign="center" noclick="1">
							<label name="rewardstat_extra_wins_total" noclick="1" content="888" color="#8e6b5b" font="dyn_10" shadow="1" shadowoffset="2"
								textalign="left" textvalign="center" align="left" valign="top" y="-2i" width="10.5h" height="16i"
							/>
							<instance name="rewardstat_total_extra_progressbar" id="rewardstat_wins_framepercent" y="2i" valign="bottom"/>
						</panel>
						<label name="rewardstat_extra_wins" noclick="1" color="#a78d7d" font="dyn_11" content="0/0"
							textalign="left" textvalign="center" valign="center" width="6.5h" height="16i" shadow="1" shadowoffset="2"
						/>
						<image name="rewardstat_extra_wins_gold_icon" texture="/ui/fe2/NewUI/Res/match_stats/coin.png" width="16i" height="16i" valign="center" noclick="1" />
						<label name="rewardstat_extra_wins_gold" noclick="1" color="orange" font="dyn_11" textalign="left" valign="center" textvalign="center"
							width="5h" height="16i" content="+999" shadow="1" shadowoffset="2"
						/>
					</panel>
					<!-- Kills -->
					<panel noclick="1" float="right" padding="1h" x="2h" y="9h" height="3h">
						<instance name="newui_tip_button_template" align="left" valign="center" title="ms_toolip_reward_kills" desc="ms_toolip_desc_reward_kills"/>
						<label noclick="1" color="#a78d7d" font="dyn_11" content="Kills" shadow="1" shadowoffset="2"
							textalign="left" textvalign="center" valign="center" width="10.5h" height="16i"
						/>
						<panel width="50%" height="22i" valign="center" noclick="1">
							<label name="rewardstat_extra_kills_total" noclick="1" content="888" color="#8e6b5b" font="dyn_10" shadow="1" shadowoffset="2"
								textalign="left" textvalign="center" align="left" valign="top" y="-2i" width="10.5h" height="16i"
							/>
							<instance name="rewardstat_total_extra_progressbar" id="rewardstat_kills_framepercent" y="2i" valign="bottom"/>
						</panel>
						<label name="rewardstat_extra_kills" noclick="1" color="#a78d7d" font="dyn_11" content="0/0"
							textalign="left" textvalign="center" valign="center" width="6.5h" height="16i" shadow="1" shadowoffset="2"
						/>
						<image name="rewardstat_extra_kills_gold_icon" texture="/ui/fe2/NewUI/Res/match_stats/coin.png" width="16i" height="16i" valign="center" noclick="1" />
						<label name="rewardstat_extra_kills_gold" noclick="1" color="orange" font="dyn_11" textalign="left" valign="center" textvalign="center"
							width="5h" height="16i" content="+999" shadow="1" shadowoffset="2"
						/>
					</panel>
					<!-- Assists -->
					<panel noclick="1" float="right" padding="1h" x="2h" y="12h" height="3h">
						<instance name="newui_tip_button_template" align="left" valign="center" title="ms_toolip_reward_assists" desc="ms_toolip_desc_reward_assists"/>
						<label noclick="1" color="#a78d7d" font="dyn_11" content="Assists" shadow="1" shadowoffset="2"
							textalign="left" textvalign="center" valign="center" width="10.5h" height="16i"
						/>
						<panel width="50%" height="22i" valign="center" noclick="1">
							<label name="rewardstat_extra_assists_total" noclick="1" content="888" color="#8e6b5b" font="dyn_10" shadow="1" shadowoffset="2"
								textalign="left" textvalign="center" align="left" valign="top" y="-2i" width="10.5h" height="16i"
							/>
							<instance name="rewardstat_total_extra_progressbar" id="rewardstat_assists_framepercent" y="2i" valign="bottom"/>
						</panel>
						<label name="rewardstat_extra_assists" noclick="1" color="#a78d7d" font="dyn_11" content="0/0"
							textalign="left" textvalign="center" valign="center" width="6.5h" height="16i" shadow="1" shadowoffset="2"
						/>
						<image name="rewardstat_extra_assists_gold_icon" texture="/ui/fe2/NewUI/Res/match_stats/coin.png" width="16i" height="16i" valign="center" noclick="1" />
						<label name="rewardstat_extra_assists_gold" noclick="1" color="orange" font="dyn_11" textalign="left" valign="center" textvalign="center"
							width="5h" height="16i" content="+999" shadow="1" shadowoffset="2"
						/>
					</panel>
					<!-- Wards -->
					<panel noclick="1" float="right" padding="1h" x="2h" y="15h" height="3h">
						<instance name="newui_tip_button_template" align="left" valign="center" title="ms_toolip_reward_wards" desc="ms_toolip_desc_reward_wards"/>
						<label noclick="1" color="#a78d7d" font="dyn_11" content="Wards" shadow="1" shadowoffset="2"
							textalign="left" textvalign="center" valign="center" width="10.5h" height="16i"
						/>
						<panel width="50%" height="22i" valign="center" noclick="1">
							<label name="rewardstat_extra_wards_total" noclick="1" content="888" color="#8e6b5b" font="dyn_10" shadow="1" shadowoffset="2"
								textalign="left" textvalign="center" align="left" valign="top" y="-2i" width="10.5h" height="16i"
							/>
							<instance name="rewardstat_total_extra_progressbar" id="rewardstat_wards_framepercent" y="2i" valign="bottom"/>
						</panel>
						<label name="rewardstat_extra_wards" noclick="1" color="#a78d7d" font="dyn_11" content="0/0"
							textalign="left" textvalign="center" valign="center" width="6.5h" height="16i" shadow="1" shadowoffset="2"
						/>					
						<image name="rewardstat_extra_wards_gold_icon" texture="/ui/fe2/NewUI/Res/match_stats/coin.png" width="16i" height="16i" valign="center" noclick="1" />
						<label name="rewardstat_extra_wards_gold" noclick="1" color="orange" font="dyn_11" textalign="left" valign="center" textvalign="center"
							width="5h" height="16i" content="+999" shadow="1" shadowoffset="2"
						/>
					</panel>
					<!-- Smackdowns -->
					<panel noclick="1" float="right" padding="1h" x="2h" y="18h" height="3h">
						<instance name="newui_tip_button_template" align="left" valign="center" title="ms_toolip_reward_smackdowns" desc="ms_toolip_desc_reward_smackdowns"/>
						<label noclick="1" color="#a78d7d" font="dyn_11" content="Smackdowns" shadow="1" shadowoffset="2"
							textalign="left" textvalign="center" valign="center" width="10.5h" height="16i"
						/>
						<panel width="50%" height="22i" valign="center" noclick="1">
							<label name="rewardstat_extra_smackdowns_total" noclick="1" content="888" color="#8e6b5b" font="dyn_10" shadow="1" shadowoffset="2"
								textalign="left" textvalign="center" align="left" valign="top" y="-2i" width="10.5h" height="16i"
							/>
							<instance name="rewardstat_total_extra_progressbar" id="rewardstat_smackdowns_framepercent" y="2i" valign="bottom"/>
						</panel>
						<label name="rewardstat_extra_smackdowns" noclick="1" color="#a78d7d" font="dyn_11" content="0/0"
							textalign="left" textvalign="center" valign="center" width="6.5h" height="16i" shadow="1" shadowoffset="2"
						/>					
						<image name="rewardstat_extra_smackdowns_gold_icon" texture="/ui/fe2/NewUI/Res/match_stats/coin.png" width="16i" height="16i" valign="center" noclick="1" />
						<label name="rewardstat_extra_smackdowns_gold" noclick="1" color="orange" font="dyn_11" textalign="left" valign="center" textvalign="center"
							width="5h" height="16i" content="+999" shadow="1" shadowoffset="2"
						/>
					</panel>
				</panel>
				
			</panel>
			
		</panel>
	</template>
	
	<!-- Player Name -->
	<template name="rewardstat_playername_instance">
		<panel name="rewardstat_playername_panel" noclick="1"
			width="30%" height="14%" align="left" valign="top"
			x="3h" y="1.3h"
			watch="MatchInfoSummary" ontrigger="SetVisible(!param32);"
		>
			
			<!-- Player Account Name -->
			<label name="rewardstat_player_name" noclick="1" color="#e7c8b5" font="dyn_14"
				align="center" textalign="left" y="3.15h" x="10h" shadow="1" shadowoffset="2"
				content="[player_name]"
			/>
			
			<!-- Player Level -->
			<label name="rewardstat_player_level" noclick="1" color="#a78d7d" font="dyn_9"
				align="center" textalign="left" y="5.7h" x="10h" shadow="1" shadowoffset="2"
				content="LV. " 
			/>
			
			<!-- Player Account Icon -->
			<panel noclick="1" width="7h" height="7h" x="-13.5h" y="1.2h" align="center" valign="center">
				<image name="rewardstat_player_icon_1" texture="/ui/elements/hero_picker_icon.tga" width="87%" height="87%" align="center" valign="center" />
				<image texture="/ui/fe2/newui/res/playerstats/border.png" />
			</panel>
			
			<!-- Player Account Symbol -->
			<panel noclick="1" width="3.5h" height="3.5h" x="-4h" y="-.2h" align="right" valign="center">
				<image name="rewardstat_player_icon_2" width="87%" height="87%" align="center" valign="center" texture="/heroes/frosty/icon.tga" />
			</panel>
			
			<!-- Player Account Experience -->
			<panel name="rewardstat_player_panel_accountexp" noclick="1"
				width="24h" height="1.7h"
				align="center" valign="bottom"
				x="3h" y="-1h"
			>
				
				<frame color="0 0 0 .55" borderthickness="1" bordercolor="#5d4c43" noclick="1" />
				<panel noclick="1">
					<panel name="rewardstat_player_frame_accountexp_extra" width="100%" noclick="1" clip="1">
						<image texture="/ui/fe2/newui/res/homepage/exp.png" width="100%" noclick="0" color="#075661" />
					</panel>
					<panel name="rewardstat_player_frame_accountexp" width="100%" noclick="1" clip="1">
						<image texture="/ui/fe2/newui/res/homepage/exp.png" width="100%" noclick="0" />
					</panel>
				</panel>
				<label name="rewardstat_player_label_accountexp" noclick="1" color="white" font="dyn_8"
					align="center" textalign="center" y=".1h" x="0h" shadow="1"
					content="[exp]" 
				/>
				
				<panel noclick="1" color="0 0 1 0" x="-2.4h" y="1h" width="40h" height="25h" align="center" valign="center">
					<modelpanel name="rewardstat_experience_levelup_effect" align="center" valign="center" noclick="true"
						model="/shared/models/invis.mdf"
						modelpos="0 0 0"
						modelscale="1.0"
						modelangles="0 0 0"
						cameradistance="30"
						camerapos="47 1100 -3"
						cameraangles="0 0 180"
						camerafov="7"
						cameranear="100.0"
						camerafar="20000.0"
						depthclear="1"
						depthcompress="0"
						sunazimuth="120"
						sunaltitude="20"
						suncolor="0.9 0.9 0.9"
						ambientcolor="0.6 0.7 0.7"
						scenebuffer="1"
						lookat="0"
						visible="1"
					/>
				</panel>
				
			</panel>

		</panel>
	</template>
	
	<!-- Items/GPM/KDA/ETC -->
	<template name="rewardstat_items_gpm_kda_etc_instance">
		<panel name="rewardstat_items_gpm_kda_etc_panel" noclick="1"
			width="22.5%" height="14%" align="left" valign="top" x="42h" y="1.3h"
			watch="MatchInfoSummary" ontrigger="SetVisible(!param32);"
		>
			
			<panel noclick="1" float="right" align="left" valign="bottom" width="90%" x=".5h" height="4h" y="-3.2h" padding=".8h">
				<!-- Hero Match Level -->
				<label name="rewardstat_player_herolevel" noclick="1" color="#f1dbcb" font="dyn_10" shadow="1" shadowoffset="2"
					textalign="left" textvalign="center" width="6h" height="2h"
					content="LV: "
				/>
				<!-- Hero Match KDA -->
				<label name="rewardstat_player_herokda" noclick="1" color="#f1dbcb" font="dyn_10" shadow="1" shadowoffset="2"
					textalign="left" textvalign="center" width="11h" height="2h"
					content="KDA: "
				/>
				<!-- Hero Match GPM -->
				<label name="rewardstat_player_herogpm" noclick="1" color="#f1dbcb" font="dyn_10" shadow="1" shadowoffset="2"
					textalign="left" textvalign="center" width="10.5h" height="2h"
					content="GPM: "
				/>
			</panel>
			
			<!-- Hero Match Items -->
			<panel noclick="1" float="right" align="left" valign="bottom" width="90%" height="4h" y="-.6h" padding=".8h">
				<!-- Item 1 -->
				<panel noclick="1" height="43i" width="43i" valign="center">
					<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
						color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
					/>
					<image texture="/ui/common/empty_pack_garena.tga" height="90%" width="90%" align="center" valign="center"
						name="rewardstat_player_inventory1"
					/>
				</panel>
				<!-- Item 2 -->
				<panel noclick="1" height="43i" width="43i" valign="center">
					<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
						color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
					/>
					<image texture="/ui/common/empty_pack_garena.tga" height="90%" width="90%" align="center" valign="center"
						name="rewardstat_player_inventory2"
					/>
				</panel>
				<!-- Item 3 -->
				<panel noclick="1" height="43i" width="43i" valign="center">
					<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
						color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
					/>
					<image texture="/ui/common/empty_pack_garena.tga" height="90%" width="90%" align="center" valign="center"
						name="rewardstat_player_inventory3"
					/>
				</panel>
				<!-- Item 4 -->
				<panel noclick="1" height="43i" width="43i" valign="center">
					<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
						color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
					/>
					<image texture="/ui/common/empty_pack_garena.tga" height="90%" width="90%" align="center" valign="center"
						name="rewardstat_player_inventory4"
					/>
				</panel>
				<!-- Item 5 -->
				<panel noclick="1" height="43i" width="43i" valign="center">
					<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
						color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
					/>
					<image texture="/ui/common/empty_pack_garena.tga" height="90%" width="90%" align="center" valign="center"
						name="rewardstat_player_inventory5"
					/>
				</panel>
				<!-- Item 6 -->
				<panel noclick="1" height="43i" width="43i" valign="center">
					<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
						color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
					/>
					<image texture="/ui/common/empty_pack_garena.tga" height="90%" width="90%" align="center" valign="center"
						name="rewardstat_player_inventory6"
					/>
				</panel>
			</panel>

		</panel>
	</template>
	
	<!-- Model Panel -->
	<template name="rewardstat_modelpanel_instance">
		<panel name="rewardstat_modelpanel_panel" noclick="1"
			width="40.5%" height="97%" align="right" valign="center"
			x="-2.2h" y="0.0h"		
		>
			
			<!-- Hero Model Panel -->
			<panel noclick="1" height="150%" width="180%" y="-3h" align="center" valign="center">
				<modelpanel
					name="rewardstat_modelpanel_widget"
					scenebuffer="true"
					noclick="0"
					anim="idle"
					cameranear="0.0"
					camerafar="5000.0"
					depthclear="true"
					depthcompress="false"
					lookat="false"
					cameradistance="30"
					camerapos="0 2300 328"
					cameraangles="-6 0 180"
					camerafov="8"
					modelpos="0 0 0"
					modelangles="0 0 0"
					modelscale="1.0"
					sunazimuth="157.9"
					sunaltitude="71.05"
					suncolor="1.08 1.08 1.08"
					ambientcolor="0.56 0.56 0.56"
					luatable="1"
					cull="false"
					processcursor="true"
					model0="/ui/fe2/elements/store2/pedestal/model.mdf"
					effect0="/ui/fe2/elements/store2/pedestal/seat_light.effect"
					rotate0="true"
					model1="/shared/models/invis.mdf"
					model2="/shared/models/invis.mdf"
					anim1="idle"
					anim2="idle"
				/>
			</panel>
			
			<!-- MVP -->
			<image name="rewardstat_image_modelpanel_mvp" noclick="1" texture="$invis" width="195i" height="195i" align="right" valign="top" x="3.5h" y="0.5h" />
			
			<frame name="rewardstat_frame_mvprewards" noclick="1" width="14h" height="16%" y=".2h" borderthickness="32i" visible="0"
				align="center" valign="bottom" float="right" padding=".6h" grow="1" growinvis="0" regrow="1"
				texture="/ui/fe2/NewUI/Res/match_stats/mvp_frame/mvpframe.tga"
			/>
			
			<frame visible="0" noclick="1" color="0 0 0 0"
				 x="0h" y="0h" height="13%" float="right" padding=".8h" grow="1" growinvis="0" regrow="1" width="10h"
			/>
			
		</panel>
	</template>

	<!-- Detailed Stats Player -->
	<template name="rewardstat_detailedstats_playerlist_instance">
		<panel name="rewardstat_detailedstats_player{index}_{team}" float="right" padding="1.45h" noclick="1"
				watch="MatchInfoPlayer{index}"
				ontriggerlua="if not NotEmpty(param0) then self:SetVisible(0) else self:SetVisible(1) end"
		>
			<panel noclick="1" valign="center" width="6i" height="100%" color="invisible">
				<image texture="/ui/fe2/newui/res/match_stats/stats_bgs/list_bg.png" width="2048i" height="64i" align="left" valign="center" noclick="1" x="-34.6h" />
				<image name="rewardstat_detailedstats_gradient_{team}_{index}" noclick="1" texture="/ui/fe2/newui/res/match_stats/stats_bgs/brown_gradient.tga" width="2042i" height="64i" align="left" valign="center" x="-371i" visible="0"
					watch="MatchInfoPlayer{index}"
					ontriggerlua=""
				/>
				<image texture="/ui/fe2/newui/res/match_stats/stats_bgs/glow.png" width="1024i" height="64i" align="left" valign="center" noclick="1" color="0 0 0 0"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0,
							SetVisible(false)
						);
						If(param1 != 0,
							SetVisible(true)
						);
						If(param1 == 0 or param1 == {team},
							Split(
								If(GetStringWidth('dyn_11', If(!StringEmpty(param57), '['#param57#']'#param0, param0)) gt GetWidth(),
									SetText(SubString('['#param57#']'#param0, param0)),
									SetText(If(!StringEmpty(param57), '['#param57#']'#param0, param0))
								),
								SetColor('#5473cb'),
								If({team} == 1 and {index} == 1, SetColor('#63c8b1')),
								If({team} == 1 and {index} == 2, SetColor('#844cac')),
								If({team} == 1 and {index} == 3, SetColor('#ccc954')),
								If({team} == 1 and {index} == 4, SetColor('#d0985c')),
								If({team} == 2 and {index} == 0, SetColor('#ce8ab3')),
								If({team} == 2 and {index} == 1, SetColor('#a1a1a2')),
								If({team} == 2 and {index} == 2, SetColor('#a3c4dd')),
								If({team} == 2 and {index} == 3, SetColor('#4a7465')),
								If({team} == 2 and {index} == 4, SetColor('#8f6b51'))
							)
						);"
				/>
			</panel>
			
			
			<!-- Hero Icon -->
			<panel noclick="1" valign="center" width="2.4%" height="100%" color="invisible">
				<image noclick="1" texture="$invis" height="48i" width="48i"  align="center" valign="center"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0,
							SetVisible(false),
							If(param1 == {team},
								If(!StringEquals(param10, ''),
									Split(SetVisible(true),
										SetOnMouseOver('
											ShowWidget(\'hero_info\');
											GetHeroInfo(\'' # param20 # '\');
										'),
										SetTexture(param10),
										CreateString('ui_MatchStatsName_' # {team} # '_' # {index}, param0)
									),
									SetVisible(false)
								)
							)
						);
						If(param1 != 0 and param1 == {team},
							SetOnClick('
								Trigger(\'matchstats_hero_helper\', \'' # param20 # '\');
							')
						);
					"
					ontriggerlua="if(param10 ~= '' and param1 == '{team}') then Rap_Info.StorePlayerIcon(({team}-1)*5+{index}, param10) end"

					onmouseover="ShowWidget('hero_info');"
					onmouseout="HideWidget('hero_info');"
					onevent1="CreateString('compendium_heroLastViewed', 'Hero_Accursed'); SetSave('compendium_heroLastViewed');"
				/>
				<frame noclick="1" color="invisible" height="48i" width="48i" align="center" valign="center" borderthickness="2i" bordercolor="black" />
				<!-- MVP Banner -->
				<image name="rewardstat_mvpbanner_{team}_{index}" texture="/ui/fe2/newui/res/match_stats/mvp_stats.png" height="64i" width="64i" align="center" valign="center" x=".4h" y="-.3h" visible="0" nocompress="1" noclick="1" />
			</panel>
			
			<!-- Player Name-->
			<panel noclick="0" width="13.55%" height="75%" valign="center"
				onclick="Set('_player_stats_searchname', ui_MatchStatsName_{team}_{index}); Trigger('ViewStatsTrigger');"
				onmouseoverlua="
					local title = GetWidget('rewardstat_general_label_player_name_' .. '{team}' .. '_' .. '{index}'):GetText()
					local desc = Translate('ui_items_cc_right_click_view_stats')
					Common_V2:ShowSimpleTip(true, desc, '140i')
					GetWidget('rewardstat_general_label_player_name_' .. '{team}' .. '_' .. '{index}'):SetColor('#ffdcc5')
					"
				onmouseoutlua="
					Common_V2:ShowSimpleTip(false)
					GetWidget('rewardstat_general_label_player_name_' .. '{team}' .. '_' .. '{index}'):SetColor('#d7b6a2')
					"
			>
				<instance name="rewardstat_label_general" align="left" valign="center" textalign="left" textvalign="center" font="dyn_12"
					width="200%" noclick="1" color="#d7b6a2"
					text="" id="player_name_{team}_{index}"					
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0 or param1 == {team},
								If(GetStringWidth('dyn_11', If(!StringEmpty(param57), '['#param57#']'#param0, param0)) gt GetWidth(),
									SetText(SubString('['#param57#']'#param0, param0)),
									SetText(If(!StringEmpty(param57), '['#param57#']'#param0, param0))
								)
							)
						);"
				/>
			</panel>
			
			<!-- MVP Medals -->
			<panel noclick="1" valign="center" width="7.5%" height="100%">
				
				<frame name="rewardstat_player_mvprewards_{team}_{index}_top" noclick="1" width="60%" height="55%" visible="1"
					align="center" valign="top" color="invisible"
					float="right" padding=".8h" grow="1" growinvis="0" regrow="1"
					watch2="ResetPlayerMVPMedals"
					ontrigger2lua="RewardStat_ResetMatchStatsMVP()"
				/>
				
				<frame name="rewardstat_player_mvprewards_{team}_{index}_bottom" noclick="1" width="60%" height="55%" visible="1"
					align="center" valign="bottom" color="invisible"
					float="right" padding=".8h" grow="1" growinvis="0" regrow="1"
					watch2="ResetPlayerMVPMedals"
					ontrigger2lua="RewardStat_ResetMatchStatsMVP()"
				/>
			
			</panel>
			
			<!-- Rank  -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<image texture="$invis" noclick="1" height="64i" width="64i"  align="center" valign="center"
					name="rewardstat_rankimage_{team}_{index}"
					watch="MatchInfoPlayer{index}"
					ontriggerlua="
						if (tonumber(param1) == 0 or tonumber(param1) == {team}) then
							if NotEmpty(param155) and tonumber(param155) > 0 then
								if param168 and tonumber(param168) > 6 and 1000 > tonumber(param168) then
									self:SetTexture('/ui/fe2/season/icon_mini/'..GetRankIconNameRankLevelAfterS6(tonumber(param155)))
								else
									self:SetTexture('/ui/fe2/season/icon_mini/'..GetRankIconNameRankLevel(tonumber(param155)))
								end
							else
								self:SetTexture('$invis')
							end
						end"
				/>
			</panel>
			<!-- Level -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_lvl_{team}_{index}"
					watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetText(param3));"
				/>
			</panel>
			<!-- KDA -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" width="7.8h" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_kda_{team}_{index}"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(
							param1 == 0 or param1 == {team},
							if(
								StringLength(param4) gt 0,
								SetText(Translate('game_end_stats_kda', 'kills', param4, 'deaths', param17, 'assists', param18)),
								ClearText()
							)
						);
					"
				/>
			</panel>
			<!-- Creep Kills -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_ck_{team}_{index}"
					watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetText(param5));"
				/>
			</panel>
			<!-- Creep Denies -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_assists_{team}_{index}"
					watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetText(param9));"
				/>
			</panel>
			<!-- Experience -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_exp_{team}_{index}"
					watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetText(param6));"
				/>
			</panel>
			<!-- GPM -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_gpm_{team}_{index}"
					watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetText(param7));"
				/>
			</panel>
			<!-- APM -->
			<panel noclick="1" valign="center" width="4.3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="" id="player_apm_{team}_{index}"
					watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, If(param8 gt 0, SetText(Round(param8)), SetText('')));"
				/>
			</panel>
			<!-- Wards -->
			<panel noclick="0" valign="center" width="3%" height="100%" color="invisible">
				<instance name="rewardstat_label_general" align="center" width="7.8h" valign="center" textalign="center" textvalign="center" y="h" font="dyn_11"
					text="5" id="player_wards_{team}_{index}"
					watch="MatchInfoPlayer{index}"
					ontrigger="If(param1 == 0 or param1 == {team}, SetText(Round(param74)));"
				/>
			</panel>
			<!-- Items -->
			<panel noclick="1" valign="center" width="18%" height="100%" color="invisible" float="right" padding=".2h" >
				<panel noclick="1" height="36i" width="36i" valign="center">
					<!-- 1 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param11#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param11#'\')); '), SetVisible(!StringEquals(param11, '')), SetTexture(GetEntityIconPath(param11)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="36i" width="36i" valign="center">
					<!-- 2 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param12#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param12#'\')); '), SetVisible(!StringEquals(param12, '')), SetTexture(GetEntityIconPath(param12)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="36i" width="36i" valign="center">
					<!-- 3 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param13#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param13#'\')); '), SetVisible(!StringEquals(param13, '')), SetTexture(GetEntityIconPath(param13)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="36i" width="36i" valign="center">
					<!-- 4 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param14#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param14#'\')); '), SetVisible(!StringEquals(param14, '')), SetTexture(GetEntityIconPath(param14)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="36i" width="36i" valign="center">
					<!-- 5 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param15#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param15#'\')); '), SetVisible(!StringEquals(param15, '')), SetTexture(GetEntityIconPath(param15)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="36i" width="36i" valign="center">
					<!-- 6 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param16#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param16#'\')); '), SetVisible(!StringEquals(param16, '')), SetTexture(GetEntityIconPath(param16)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
			</panel>
			
			<panel name="targetme{team}_{index}" width="4.5%" valign="center" noclick="1" height="71%" color="invisible" float="right" padding=".1h">
				<!-- Report a Player -->
				<button name="rewardstat_report_btn{team}_{index}" color="invisible" width="2.5h" height="2.5h"
						onclicklua="Rap_Info.MatchStatsReport('{team}', '{index}', GetCvarString('ui_MatchStatsName_{team}_{index}'))"
						onmouseoverlua="local title = Translate('game_menu_report_a_player')
										Common_V2:ShowSimpleTip(true, title, '200i')"
						onmouseoutlua="Common_V2:ShowSimpleTip(false)"
						watch="MatchInfoPlayer{index}"
						ontriggerlua=
						"
							if(param1 == '{team}' or param1 == '0') then
								local rap2Enable = GetCvarBool('cl_Rap2Enable')
								if rap2Enable then
									if param1 == '0' then
										Rap_Info.ResetCurrentPlayerTeam()
									end
								end
								Rap_Info.SetVisibleRapButtonPlayer(self, {team}, {index}, param0)
							end
						"
						watch2="MatchInfoSummary"
						ontrigger2lua=
						"
							Rap_Info.SetVisibleRapButtonSummary(self, {team}, {index}, param37, param1, param40, param25)
						"
				>
					<widgetstate statename="up">
						<image texture="/ui/fe2/NewUI/Res/match_stats/stats_icons/viewstats.png" noclick="1" height="32i" width="32i"  align="center" valign="center" color="1 1 1" />
					</widgetstate>
					<widgetstate statename="over">
						<image texture="/ui/fe2/NewUI/Res/match_stats/stats_icons/viewstats.png" noclick="1" height="32i" width="32i" align="center" valign="center" color="1 1 1" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image texture="/ui/fe2/NewUI/Res/match_stats/stats_icons/viewstats.png" noclick="1" height="32i" width="32i"  align="center" valign="center" />
					</widgetstate>
					<widgetstate statename="disabled">
						<image texture="/ui/fe2/NewUI/Res/match_stats/stats_icons/viewstats.png" noclick="1" height="32i" width="32i"  align="center" valign="center" rendermode="grayscale" />
					</widgetstate>
				</button>
				
				<panel noclick="1" color="invisible" width="2.5h" height="2.5h">
				
					<!-- Add Friend -->
					<button color="invisible" width="2.5h" height="2.5h" visible="0"
						name="MatchStatsAddBuddy{team}_{index}"
						watch="MatchInfoPlayer{index}"
						oninstantiate="CreateString('ui_MatchStatsName_{team}_{index}');"
						ontrigger="If(param1 == {team} or param1 == 0, SetVisible(!StringEquals(StripClanTag(GetAccountName()), StripClanTag(param0)) and !StringEmpty(param0) and !IsBuddy(param0)));"
						onclick="If(!IsBuddy(ui_MatchStatsName_{team}_{index}) and !StringEquals(StripClanTag(GetAccountName()), StripClanTag(ui_MatchStatsName_{team}_{index})), Split(ChatAddBuddy(ui_MatchStatsName_{team}_{index}),ShowWidget('MatchStatsRemoveBuddy{team}_{index}'),HideWidget('MatchStatsAddBuddy{team}_{index}')));"
						onmouseoverlua="local title = Translate('general_add_friend')
										Common_V2:ShowSimpleTip(true, title, '200i')"
						onmouseoutlua="Common_V2:ShowSimpleTip(false)"
					>
						<widgetstate statename="up">
							<image texture="/ui/fe2/NewUI/Res/playerstats/add_friend_hover.png" noclick="1" height="64i" width="64i"  align="center" valign="center" color=".85 .85 .85" />
						</widgetstate>
						<widgetstate statename="over">
							<image texture="/ui/fe2/NewUI/Res/playerstats/add_friend_hover.png" noclick="1" height="64i" width="64i" align="center" valign="center" color="1 1 1" />
						</widgetstate>
						<widgetstate statename="down">
							<image texture="/ui/fe2/NewUI/Res/playerstats/add_friend_up.png" noclick="1" height="64i" width="64i"  align="center" valign="center" />
						</widgetstate>
						<widgetstate statename="disabled">
							<image texture="/ui/fe2/NewUI/Res/playerstats/add_friend_hover.png" noclick="1" height="64i" width="64i"  align="center" valign="center" color=".8 .8 .8" />
						</widgetstate>
					</button>
					<!-- Remove Friend -->
					<button color="invisible" width="2.5h" height="2.5h" visible="0"
						name="MatchStatsRemoveBuddy{team}_{index}"
						watch="MatchInfoPlayer{index}"
						oninstantiate="CreateString('ui_MatchStatsName_{team}_{index}');"
						ontrigger="If(param1 == {team} or param1 == 0, SetVisible(!StringEquals(StripClanTag(GetAccountName()), StripClanTag(param0)) and !StringEmpty(param0) and IsBuddy(param0)));"
						onclick="If(IsBuddy(ui_MatchStatsName_{team}_{index}), Split(ChatRemoveBuddy(ui_MatchStatsName_{team}_{index}),ShowWidget('MatchStatsAddBuddy{team}_{index}'),HideWidget('MatchStatsRemoveBuddy{team}_{index}')));"
						onmouseoverlua="local title = Translate('general_remove_friend')
										Common_V2:ShowSimpleTip(true, title, '200i')"
						onmouseoutlua="Common_V2:ShowSimpleTip(false)"
					>
						<widgetstate statename="up">
							<image texture="/ui/fe2/NewUI/Res/playerstats/delete_friend_hover.png" noclick="1" height="64i" width="64i"  align="center" valign="center" color=".85 .85 .85" />
						</widgetstate>
						<widgetstate statename="over">
							<image texture="/ui/fe2/NewUI/Res/playerstats/delete_friend_hover.png" noclick="1" height="64i" width="64i" align="center" valign="center" color="1 1 1" />
						</widgetstate>
						<widgetstate statename="down">
							<image texture="/ui/fe2/NewUI/Res/playerstats/delete_friend_up.png" noclick="1" height="64i" width="64i"  align="center" valign="center" />
						</widgetstate>
						<widgetstate statename="disabled">
							<image texture="/ui/fe2/NewUI/Res/playerstats/delete_friend_hover.png" noclick="1" height="64i" width="64i"  align="center" valign="center" color=".8 .8 .8" />
						</widgetstate>
					</button>
				
				</panel>
				
			</panel>
			
		</panel>
	</template>
	
	<!-- Simple Stats Player -->
	<template name="rewardstat_simplestats_playerlist_instance">
		
		<!-- <frame noclick="1" color="invisible" borderthickness="1" bordercolor="white" width="23h" height="28h" /> -->
		
		<panel name="rewardstat_simplestats_player{index}_{team}" noclick="1" width="23.2h"
				watch="MatchInfoPlayer{index}"
				ontriggerlua="if not NotEmpty(param0) then self:SetVisible(0) else self:SetVisible(1) end"
		>
		
			<!-- Frame -->
			<instance name="rewardstat_main_border" />	
			
			<!-- Hero Icon -->
			<panel noclick="1" align="left" valign="top" width="2.4%" height="100%" color="invisible" x="2.3h" y="2.3h">
				<image noclick="1" texture="$invis" height="6.1h" width="6.1h" align="left" valign="top"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0,
							SetVisible(false),
							If(param1 == {team},
								If(!StringEquals(param10, ''),
									Split(SetVisible(true),
										SetOnMouseOver('
											ShowWidget(\'hero_info\');
											GetHeroInfo(\'' # param20 # '\');
										'),
										SetTexture(param10),
										CreateString('simple_ui_MatchStatsName_' # {team} # '_' # {index}, param0)
									),
									SetVisible(false)
								)
							)
						);
						If(param1 != 0 and param1 == {team},
							SetOnClick('
								Trigger(\'matchstats_hero_helper\', \'' # param20 # '\');
							')
						);
					"
					ontriggerlua=""

					onmouseover="ShowWidget('hero_info');"
					onmouseout="HideWidget('hero_info');"
					onevent1="CreateString('compendium_heroLastViewed', 'Hero_Accursed'); SetSave('compendium_heroLastViewed');"
				/>
				<frame noclick="1" color="invisible" width="6.1h" height="6.1h" borderthickness=".2h" bordercolor="white"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0,
							SetVisible(false)
						);
						If(param1 != 0,
							SetVisible(true)
						);
						If(param1 == 0 or param1 == {team},
							Split(
								If(GetStringWidth('dyn_11', If(!StringEmpty(param57), '['#param57#']'#param0, param0)) gt GetWidth(),
									SetText(SubString('['#param57#']'#param0, param0)),
									SetText(If(!StringEmpty(param57), '['#param57#']'#param0, param0))
								),
								SetBorderColor('#5473cb'),
								If({team} == 1 and {index} == 1, SetBorderColor('#63c8b1')),
								If({team} == 1 and {index} == 2, SetBorderColor('#844cac')),
								If({team} == 1 and {index} == 3, SetBorderColor('#ccc954')),
								If({team} == 1 and {index} == 4, SetBorderColor('#d0985c')),
								If({team} == 2 and {index} == 0, SetBorderColor('#ce8ab3')),
								If({team} == 2 and {index} == 1, SetBorderColor('#a1a1a2')),
								If({team} == 2 and {index} == 2, SetBorderColor('#a3c4dd')),
								If({team} == 2 and {index} == 3, SetBorderColor('#4a7465')),
								If({team} == 2 and {index} == 4, SetBorderColor('#8f6b51'))
							)

						);"
				/>
			</panel>
			
			<!-- Player Name-->
			<panel noclick="1" width="59%" height="29%" valign="top" align="right">
				<instance name="newui_longtext_label_template" textalign="left" textvalign="center" font="dyn_12"
					width="100%" color="#ffdcc5"
					content="" label_name="simple_player_name_{team}_{index}"
					watch="MatchInfoPlayer{index}"
					ontriggerlua="
					if param1 == tostring({team}) or param1 == '0' then
						local textWidget = self:GetName()
						Common_V2:SetLongTextLabel(textWidget, param0)
					end"
				/>
			</panel>
			
			<!-- Hero Name -->
			<panel noclick="1" width="59%" height="29%" valign="top" align="right" y="2.3h">
				<instance name="rewardstat_label_general" textalign="left" textvalign="center" font="dyn_10"
					width="100%" text="" id="simple_hero_name_{team}_{index}" watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0 or param1 == {team},
							Split(
								If(GetStringWidth('dyn_11', If(!StringEmpty(param57), '['#param57#']'#param19, param19)) gt GetWidth(),
									SetText(''),
									SetText(param19)
								),
								SetColor('#a78d7d'))
							)

						);"
				/>
			</panel>
			
			<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/seperate_line2.png" width="256i" height="1i" align="center" valign="center" y="-3.1h" />

			<!-- Fun Awards -->
			
			<!-- watch="MatchInfoPlayer{index}" -->
			<!-- ontriggerlua="if not NotEmpty(param0) then self:SetVisible(0) else self:SetVisible(1) end" -->
			
			<panel name="rewardstats_funrewardspanel_{index}_{team}" noclick="1" width="61%" height="22%" align="center" valign="center" y="1.9h" x="6i" float="right" padding="1h">
				<panel noclick="1" width="6h" height="6h">
					<image texture="$invis" name="rewardstats_player_award_1_{index}_{team}"
						onmouseoverlua="
							local title = '...'
							local desc = '...'
							Common_V2:ShowGenericTip(true, title, desc, '300i')
							"
						onmouseoutlua="Common_V2:ShowGenericTip(false)"
						watch="MatchInfoPlayer{index}"
						ontriggerlua="self:SetVisible(1)"
						onframelua="
							local playerLabel = GetWidget('rewardstat_general_label_player_name_{team}_{index}'):GetText()
							if string.len(playerLabel) == 0 then
								self:SetVisible(0)
							else
								self:SetVisible(1)
							end"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" width="6h" height="6h">					
					<image texture="$invis" width="6h" height="6h" name="rewardstats_player_award_2_{index}_{team}"
						onmouseoverlua="
							local title = '...'
							local desc = '...'
							Common_V2:ShowGenericTip(true, title, desc, '300i')
							"
						onmouseoutlua="Common_V2:ShowGenericTip(false)"
						watch="MatchInfoPlayer{index}"
						ontriggerlua="self:SetVisible(1)"
						onframelua="
							local playerLabel = GetWidget('rewardstat_general_label_player_name_{team}_{index}'):GetText()
							if string.len(playerLabel) == 0 then
								self:SetVisible(0)
							else
								self:SetVisible(1)
							end"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
			</panel>
			
			<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/seperate_line2.png" width="256i" height="1i" align="center" valign="bottom" y="-7.1h" />
			
			<!-- Items -->
			<panel noclick="1" valign="bottom" y="-1.3h" align="center" width="85%" height="17%" float="right" padding=".35h" >
				<panel noclick="1" height="3.0h" width="3.0h" valign="center">
					<!-- 1 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param11#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param11#'\')); '), SetVisible(!StringEquals(param11, '')), SetTexture(GetEntityIconPath(param11)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="3.0h" width="3.0h" valign="center">
					<!-- 2 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param12#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param12#'\')); '), SetVisible(!StringEquals(param12, '')), SetTexture(GetEntityIconPath(param12)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="3.0h" width="3.0h" valign="center">
					<!-- 3 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param13#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param13#'\')); '), SetVisible(!StringEquals(param13, '')), SetTexture(GetEntityIconPath(param13)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="3.0h" width="3.0h" valign="center">
					<!-- 4 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param14#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param14#'\')); '), SetVisible(!StringEquals(param14, '')), SetTexture(GetEntityIconPath(param14)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="3.0h" width="3.0h" valign="center">
					<!-- 5 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param15#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param15#'\')); '), SetVisible(!StringEquals(param15, '')), SetTexture(GetEntityIconPath(param15)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					
					/>
					<frame color="invisible" noclick="1" borderthickness="1" bordercolor="#543939" />
				</panel>
				<panel noclick="1" height="3.0h" width="3.0h" valign="center">
					<!-- 6 -->
					<image texture="/ui/common/empty_pack_garena.tga" noclick="1" />
					<image texture="$invis"
						watch="MatchInfoPlayer{index}"
						ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param16#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param16#'\')); '), SetVisible(!StringEquals(param16, '')), SetTexture(GetEntityIconPath(param16)))));"
						onmouseout="HideWidget('endgameItemTooltip');"
					/>
