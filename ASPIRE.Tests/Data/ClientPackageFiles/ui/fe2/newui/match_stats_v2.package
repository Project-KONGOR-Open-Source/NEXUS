	<template name="rewardstats_match_fetch_fail_body">
		<panel width="100%" grow="true" align="center" float="bottom" padding="1.0h" noclick="true">
			<panel grow="true" y="1.0h" width="100%">
				<label fity="true" width="-1.0h" align="center" textalign="center" textvalign="top" font="dyn_11" color="white" shadow="true" wrap="true" content="main_stats_failed_retrieval"/>
			</panel>
			<panel height="5h" noclick="true">
				<instance name="newui_common_button_2_template" button_name="fetch_match_cancel"
					x="-7.0h"
					width="12.0h"
					align="center"
					valign="center"
					label="main_stats_cancel"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclicklua="
						GetWidget('endgame_stats_fetch_match'):EraseInputLine()
						GetWidget('rewardstats_match_fetch_fail_mask'):FadeOut(250)
						"
					interactive="{interactive}"
				/>
				<instance name="newui_common_button_2_template" button_name="fetch_match_retry"
					x="7.0h"
					width="12.0h"
					align="center"
					valign="center"
					label="main_stats_retry"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclicklua="
						GetWidget('rewardstats_match_fetch_fail_mask'):FadeOut(250)
						GetWidget('endgame_stats_fetch_match'):DoEventN(0)
						"
					interactive="{interactive}"
				/>
			</panel>
		</panel>
	</template>

	<!-- Layout -->
	<template name="match_stats">
		<panel name="match_stats" visible="{visible=0}" width="180h" height="101h" align="center" valign="center" 
			onload="CreateBool('ui_match_replays_blockSimpleStats', false); CreateBool('ui_match_stats_waitingToShow', false);"
			watch5="ChatShowPostGameStats"
			ontrigger5="##Echo('ChatShowPostGameStats');##"
			onshowlua="RewardStat_OnOpen()"
			onshow="##Echo('onshow - Match_Stats.OpenedMatchStats() ');##"
			onhidelua="RewardStat_OnClose()"
			onhide="##Echo('onhide - Match_Stats.ClosedMatchStats() ');## HideWidget('match_replays_reward_event01'); HideWidget('match_replays_reward_event02');"
			watch6="EntityDefinitionsLoaded"
			ontrigger6="##Echo('EntityDefinitionsLoaded');##"
			hotkey="ESC"
			onhotkeylua="
						local parent = GetCvarString('_match_stats_parent_panel')
						if NotEmpty(parent) then
							Set('_mainmenu_currentpanel', parent) 
							GetWidget('MainMenuPanelSwitcher'):DoEvent()
							Set('_match_stats_parent_panel', '')
						else
							GetWidget('match_stats'):FadeOut(150)
						end
					"
		>
			<image texture="/ui/fe2/NewUI/Res/common/main_bg.png" width="2048i" height="2048i" noclick="1" visible="1" align="center" valign="center" />

			<!-- Temp Fetch Panel -->
			<!--
					onclick="
					Set('ui_match_replays_blockSimpleStats', false);
					_stats_last_match_id = 21300;
					If(!StringEmpty(_stats_last_match_id), GetMatchInfo(_stats_last_match_id)); EraseInputLine();"
					SetInputLine('21300');
			-->
			
			<panel noclick="1" width="50h" height="4.5h" align="center" valign="bottom" y="-2h" x="-8h">
				<instance name="button2" label="Test" enabled="1" font="dyn_7" visible="0"
					width="6h" height="1.8h" align="left" valign="center" x="-21h"
					onclicklua="TestButton()"
				/>
				<instance name="button2" label="Test2" enabled="1" font="dyn_7" visible="0"
					width="6h" height="1.8h" align="left" valign="center" x="-29h"
					onclicklua="Test2()"
				/>
				<instance name="button2" label="Test3" enabled="1" font="dyn_7" visible="0"
					width="6h" height="1.8h" align="left" valign="center" x="-37h"
					onclicklua="Test3()"
				/>
				<instance name="button2" label="Test Placement Animation (w-l-w-l-w)" enabled="1" font="dyn_8" visible="0"
					width="23h" height="2.1h" align="left" valign="center" x="57h" color="orange"
					onclicklua="TestPlacementAnim()"
				/>
				<instance name="button2" label="3 MvP Awards" enabled="1" font="dyn_8" visible="0"
					width="10h" height="2.1h" align="left" valign="center" x="82h" color="orange"
					onclicklua="MVPAwardTest()"
				/>
				<instance name="button2" label="EXP Anim" enabled="1" font="dyn_8" visible="0"
					width="8h" height="2.1h" align="left" valign="center" x="94.5h" color="orange"
					onclicklua="RewardStat_PlayerEXPAnimation(37700.0000, 16520.0000, 90, 26, 'HyperXewl', 4455)"
				/>
				<instance name="button2" label="Mastery XP AnimTest (lvl 2-6)" enabled="0" font="dyn_8" visible="0"
					width="19.8h" height="2.1h" align="left" valign="center" x="35h" color="orange"
					onclicklua="RewardStat_MasteryXPAnimation('/heroes/frosty/icon.tga', 5500, 2000, 0, 500, 500)"
				/>
				<instance name="button2" label="RegisterDefs" enabled="1" font="dyn_7" visible="0"
					width="10h" height="1.8h" align="left" valign="center" x="-13h"
					onclicklua="Cmd('RegisterEntityDefinitions')"
				/>
				<!-- 21300 -->
				<instance name="button2" label="21300" enabled="1" font="dyn_7" visible="0"
					width="4h" height="1.8h" align="left" valign="center" x="0h"
					onclicklua="GetWidget('rewardstats_textboxfetch_debug'):SetInputLine('21300')"
				/>
			</panel>
			<!-- Victory/Defeat -->
			<panel noclick="1">
				<!-- if(param == 1, Split(StartEffect('/ui/fe2/newui/res/match_stats/effects/viotory.effect', 0.5, 0.52, '1 1 1 1'), PlaySound('/shared/sounds/ui/menu/slide_in.wav'))); -->
				<!-- align="center" valign="top" width="1024i" height="512i" y="0h" -->
				<modelpanel name="rewardstat_victoryloose"
					align="center"
					valign="top"
					height="110h"
					y="-.1h"
					width="177.7h"
					noclick="true"
					anim="idle"
					camerapos="0 -1500 00"
					cameraangles="0 0 0"
					camerafov="45"
					modelangles="0 0 180"
					modelpos="0 0 0"
					lookat="1"
					watch1="ModelWin"
					watch2="ModelLoose"
					watch3="ModelReset"
					ontrigger1="SetModel('/ui/fe2/mainmenu/bg_effects/debug.mdf'); SetEffect('/ui/fe2/newui/res/match_stats/effects/viotory.effect'); SetAnim('idle');"
					ontrigger2="SetModel('/ui/fe2/mainmenu/bg_effects/debug.mdf'); SetEffect('/ui/fe2/newui/res/match_stats/effects/defeat.effect'); SetAnim('idle');"
					ontrigger3="SetModel('/ui/fe2/mainmenu/bg_effects/debug.mdf'); SetEffect(''); SetAnim('idle');"
				/>
				<!-- Victory/Defeat Image -->
				<image texture="$invis" noclick="1" width="512i" height="128i" valign="top" align="center" y="2h" visible="1"
					watch1="ModelWin"
					watch2="ModelLoose"
					watch3="ModelReset"
					ontrigger1lua="self:SetTexture('/shared/effects/textures/victory_0.tga')"
					ontrigger2lua="self:SetTexture('/shared/effects/textures/defeat_0.tga')"
					ontrigger3lua="self:SetTexture('$invis')"
				/>
			</panel>
			<!-- Center Frame -->
			<panel name="rewardstat_centerframe" noclick="0" width="70%" height="75%" x=".3h" y="-8.1h" align="center" valign="bottom" >
				<!-- Main Border Frame -->
				<panel height="0i" float="right" noclick="1">
					<panel width="70.8%" x="395i" noclick="1">
						<image texture="/ui/fe2/newui/res/match_stats/tab/tab_line.png" valign="bottom" height="64i" noclick="0"/>
					</panel>
				</panel>
				<panel height="840i" float="right">
					<image texture="/ui/fe2/newui/res/match_stats/back_lines/back_l.png" width="16i" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/back_lines/back_c.png" width="-32i" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/back_lines/back_l.png" width="16i" noclick="1" hflip="1"/>
				</panel>
				
				<!-- Loading [Temp label atm] -->
				<label name="rewardstat_loadinglabel" noclick="1" content="LOADING MATCH ID LOOOLOL BEST LABEL HIGH QUALITY" visible="0"
					align="center" valign="center" font="dyn_16" textalign="center" textvalign="center" color="orange"
				/>
				
				<!-- Rewards Frame -->
				<panel name="rewardstat_rewardframe" x="-25i" noclick="1" visible="1">
					
					<!-- Model Panels -->
					<instance name="rewardstat_modelpanel_instance" />
					
					<!-- Rank Progression Info -->
					<instance name="rewardstat_rankprogression_info_instance" />
					
					<!-- Rank Progression Visual -->
					<instance name="rewardstat_rankprogression_visual_instance" />
					
					<!-- Hero Mastery Info -->
					<instance name="rewardstat_heromastery_info_instance" />
					
					<!-- Hero Mastery Visual -->
					<instance name="rewardstat_heromastery_visual_instance" />
					
					<!-- Total Earned -->
					<instance name="rewardstat_totalearned_instance" />
					
					<!-- Player Name/EXP/Icon -->
					<instance name="rewardstat_playername_instance" />
					
					<image texture="/ui/fe2/newui/res/common/line2.png" width="2i" height="90i" align="left" valign="top" x="39.5h" y="35i" noclick="1"/>
					
					<!-- Items/GPM/KDA/Level -->
					<instance name="rewardstat_items_gpm_kda_etc_instance" />

					
					
					<panel name="rewardstat_mvp_panel" noclick="1" width="12h" height="12h" align="center" valign="bottom" x="35h" y="-1.2h" visible="0">					
							<frame name="rewardstat_test_frame" noclick="1" borderthickness="32i" visible="1"
								texture="/ui/fe2/NewUI/Res/match_stats/mvp_frame/mvpframe.tga"
							/>
							<listbox
								name="rewardstat_mvp_listbox"
								height="100%"
								itemwidth="9h"
								itemheight="10h"
								itemheightfudge="0h"
								itemwidthfudge="0h"
								itemoffsety=".1h"
								itemoffsetx="1.3h"
								handleheight="1.4h"
								handlewidth="2.3h"
								scrollbarsize="16i"
								shadow="true"
								usescrollbars="true"
								scrolltexture="/ui/fe2/newui/Res/common/hscroll/scroll.tga"
								scrollinterval="0"
								hpadding="0h"
								wrap="column"
								hoverselect="false"
								select="0"
								hoverhighlight="false"
								scrollbaroffset="1.35h"
								color="invisible"
								watch="RewardStat_ClearList"
								ontrigger="ClearItems();"
							/>
					</panel>
					
				</panel>
				<!-- Stats Frame -->
				<panel name="rewardstat_statframe" noclick="1" visible="0">
					<!-- Simple Stats Button -->
					<instance name="newui_common_button_2_template" button_name="rewardstat_statframe_ms_switch_view"
						y="2.7h" x="-3.8h"
						width="12h" height="2.5h"
						align="right"
						valign="top"
						label="ms_switch_view"
						onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
						onclicklua="Match_Stats_V2:SwitchDetailedSimple()"
						interactive="{interactive}"
					/>
					<!-- Detailed Stats -->
					<panel name="rewardstat_detailedstats_panel" visible="1" noclick="1">
					
						<!-- CTF Stats -->
						<panel name="rewardstat_detailedstats_ctf" noclick="1" visible="0">
							<instance name="rewardstat_detailed_ctf_instance" />
						</panel>
						
						<!-- Soccer Stats -->
						<panel name="rewardstat_detailedstats_soccer" noclick="1" visible="0">
							<instance name="rewardstat_detailed_soccer_instance" />
						</panel>						
						
						<panel name="rewardstat_detailedstats_standard" noclick="1" visible="1">
							<!-- Legion -->
							<panel noclick="1" width="95%" align="center">
								<!-- Player List -->
								<panel noclick="1" width="120.25h" height="5.1%" float="bottom" padding="1.85h" x="-.6h" y="8.9%">
									<instance name="reward_detailedstats_playerlist" team="1" />
								</panel>
								<!-- Frame -->
								<instance name="rewardstat_detailedstats_team_instance" team="1" legion="1"
									y="-26%" valign="center"
								/>
							</panel>
							<!-- Hellbourne -->
							<panel noclick="1" width="95%" y="46.5%" valign="center" align="center">
								<!-- Player List -->
								<panel noclick="1" width="120.25h" height="5.1%" float="bottom" padding="1.85h" x="-.6h" y="8.9%">
									<instance name="reward_detailedstats_playerlist" team="2" />
								</panel>
								<!-- Frame -->
								<instance name="rewardstat_detailedstats_team_instance" team="2" hellbourne="1"
									y="-26%" valign="center"
								/>
							</panel>
						</panel>
					</panel>
					<!-- Simple Stats -->
					<panel name="rewardstat_simpledstats_panel" visible="0" noclick="1">
						<!-- Legion -->
						<panel noclick="1" width="95%" align="center">
							<!-- Player List -->
							<panel name="rewardstats_simple_panel1" sticky="0" stickytoinvis="1" noclick="1" height="37.1%" grow="1" growinvis="0" regrow="1" align="center" float="right" padding=".8h" y="8.3%" x="0">
								<instance name="reward_simplestats_playerlist" team="1" />
							</panel>
							<!-- Frame -->
							<instance name="rewardstat_simplestats_team_instance" team="1" legion="1"
								y="-26%" valign="center"
							/>
						</panel>
						<!-- Hellbourne -->
						<panel noclick="1" width="95%" y="46.5%" valign="center" align="center">
							<!-- Player List -->
							<panel noclick="1" sticky="0" stickytoinvis="1" height="37.1%" grow="1" growinvis="0" regrow="1" align="center" float="right" padding=".8h" y="8.3%" x="0">
								<instance name="reward_simplestats_playerlist" team="2" />
							</panel>
							<!-- Frame -->
							<instance name="rewardstat_simplestats_team_instance" team="2" hellbourne="1"
								y="-26%" valign="center"
							/>
						</panel>
					</panel>
					
					<!-- Match ID -->
					<panel width="150i" height="3h" align="left" valign="bottom" y="-2.4h" x="40i" noclick="1"
					>
						<label content="endstats_label_match_id" textalign="left" textvalign="center" font="dyn_11" x="0i" color="#967569" shadow="1" shadowoffset="2" outline="0" width="75i"/>
						<!-- Fetch Match -->
						<panel x="80i" align="left" valign="center" width="185i" noclick="1">
							<instance name="newui_custom_frame_template"/>
							<label name="endgame_stats_matchid_label" x="5i" width="150i" textalign="left" textvalign="center" align="left" valign="center" font="dyn_11" color="#967569" shadow="1" shadowoffset="2" outline="0"/>
							<panel name="endgame_stats_matchid_label_cover" x="5i" width="150i" align="left" valign="center" noclick="0"
								onclicklua="
										GetWidget('endgame_stats_matchid_label'):SetVisible(0)
										GetWidget('endgame_stats_matchid_label_cover'):SetVisible(0)
										GetWidget('endgame_stats_fetch_match_container'):SetVisible(1)
										GetWidget('endgame_stats_fetch_match'):SetValue('')
										GetWidget('endgame_stats_fetch_match'):SetFocus(1)
									"
							/>
							<panel name="endgame_stats_fetch_match_container" x="5i" width="150i" height="28i" align="left" valign="center" visible="0">
								<textbox name="endgame_stats_fetch_match"
										color="0 0 0 0" font="dyn_11" textcolor="#f0d3c1" selectonfocus="1"
										width="132i" height="24i"
										textalign="left" textvalign="center" align="left" valign="center"
										onesc="
											EraseInputLine();
											Call('endgame_stats_fetch_match_container', 'SetVisible(0);');
											Call('endgame_stats_matchid_label', 'SetVisible(1);');
											Call('endgame_stats_matchid_label_cover', 'SetVisible(1);');
											"
										onenter="DoEvent(0);"
										onevent0lua="
											local matchid = tonumber(self:GetValue())
											if matchid ~= nil and matchid ~= 0 then
												RewardStat_GetMatchInfo(matchid)
											end
											"
								>
								</textbox>
								<button name="endgame_stats_remove_input_button" x="-2i" width="28i" height="100%" align="right" valign="center" color="invisible"
									onclicklua="
											GetWidget('endgame_stats_fetch_match'):EraseInputLine()
											GetWidget('endgame_stats_matchid_label'):SetVisible(1)
											GetWidget('endgame_stats_matchid_label_cover'):SetVisible(1)
											GetWidget('endgame_stats_fetch_match_container'):SetVisible(0)
										"
								>
									<widgetstate statename="up">
										<image texture="/ui/fe2/NewUI/res/common/close.png" width="28i" height="100%" align="center" valign="center" noclick="1"/>
									</widgetstate>
									<widgetstate statename="over">
										<image texture="/ui/fe2/NewUI/res/common/close_over.png" width="28i" height="100%" align="center" valign="center" noclick="1"/>
									</widgetstate>
									<widgetstate statename="down" y="1">
										<image texture="/ui/fe2/NewUI/res/common/close.png" width="28i" height="100%" align="center" valign="center" noclick="1"/>
									</widgetstate>
									<widgetstate statename="disabled">
										<image texture="/ui/fe2/NewUI/res/common/close.png" width="28i" height="100%" align="center" valign="center" rendermode="grayscale" noclick="1"/>
									</widgetstate>
								</button>
							</panel>
							<image texture="/ui/fe2/newui/res/common/line2.png" x="150i" width="2i" height="100%" align="left" valign="center" noclick="1" />
							<button name="endgame_stats_fetch_match_button" width="32i" height="32i" align="right" valign="center" color="invisible"
								onclicklua="
										if GetWidget('endgame_stats_fetch_match_container'):IsVisible() then
											GetWidget('endgame_stats_fetch_match'):DoEventN(0)
										else
											GetWidget('endgame_stats_matchid_label'):SetVisible(0)
											GetWidget('endgame_stats_matchid_label_cover'):SetVisible(0)
											GetWidget('endgame_stats_fetch_match_container'):SetVisible(1)
											GetWidget('endgame_stats_fetch_match'):SetValue('')
											GetWidget('endgame_stats_fetch_match'):SetFocus(1)
										end
									"
								onmouseoverlua="Common_V2:ShowSimpleTip(true, 'game_end_stats_fetch_tooltip', '300i', 'left')"
								onmouseoutlua="Common_V2:ShowSimpleTip(false)"
							>
								<widgetstate statename="up">
									<image texture="/ui/fe2/newui/res/playerstats/fetchplayer.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
								</widgetstate>
								<widgetstate statename="over">
									<image texture="/ui/fe2/newui/res/playerstats/fetchplayer_up.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
								</widgetstate>
								<widgetstate statename="down" y="1">
									<image texture="/ui/fe2/newui/res/playerstats/fetchplayer.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
								</widgetstate>
								<widgetstate statename="disabled">
									<image texture="/ui/fe2/newui/res/playerstats/fetchplayer.png" width="32i" height="32i" align="center" valign="center" rendermode="grayscale" noclick="1"/>
								</widgetstate>
							</button>
						</panel>
					</panel>

					 <!--Game Version & Server Name / Date -->
					<panel noclick="1" width="45h" height="3h" align="left" valign="bottom" y="-2.4h" x="340i" float="right" padding=".4h">
						<image noclick="1" texture="/ui/fe2/NewUI/Res/playerstats/icon_winstreak.png" width="32i" height="32i" />
						<instance name="rewardstat_label_general" id="version_num" text="..." textalign="left" textvalign="center" valign="center" y="" font="dyn_11" color="#967569" shadow="1" shadowoffset="2" outline="0" width="8.6h"
							watch="MatchInfoSummary" ontriggerlua="self:SetText(param18)"
						/>
						<instance name="rewardstat_label_general" id="endstats_label_server" text="..." textalign="left" textvalign="center" valign="center" y="" font="dyn_11" color="#967569" shadow="1" shadowoffset="2" outline="0" width="8.6h"
							watch="MatchInfoSummary" ontriggerlua="self:SetText(param4)"
						/>
						<image noclick="1" texture="/ui/fe2/NewUI/Res/playerstats/summary_winning_percent.png" width="32i" height="32i" align="center" valign="center" />
						<instance name="rewardstat_label_general" id="date" text="..." textalign="left" textvalign="center" valign="center" y="" font="dyn_11" color="#967569" shadow="1" shadowoffset="2" outline="0" width="20h"
							watch="MatchInfoSummary" ontriggerlua="self:SetText(param2..' '..param3)"
						/>
					</panel>
					
					<!-- Game Option Circles -->
					<panel name="endgame_stats_mode_panel" y="-2.3h" x="-3.5h" width="3.7h" height="3.7h" align="right" valign="bottom" color="invisible" noclick="1" float="right" padding="0.5h">
						<panel align="right" grow="true" regrow="true" growinvis="false" float="right" padding="0.5h" x="-0.5h" height="75%" valign="center">
							<instance name="rewardstat_gameoptions" />
						</panel>
					</panel>
				</panel>
				
				<!-- (DEBUG) Replays (DEBUG) -->
				<panel noclick="1" width="80h" height="50h" align="center" valign="center">
					<instance name="rewardstat_replay_download_box" debugvis="0" />
				</panel>
				<panel noclick="1" align="center" valign="center" width="20h" height="8h" x="-46h" y="15h">
					<instance name="rewardstat_replay_download_button" />
				</panel>
				
				<!-- Tabs -->
				<panel noclick="1" width="43h" height="5h" y="-5h" float="right" padding="2h">
					<!-- Rewards / Stats Tab -->
					<panel height="46i" float="right" y=".8h" noclick="1">
						<instance name="rewardstat_tab_instance" width="198i" enabled="0" type="rewards" content="REWARDS"/>
						<instance name="rewardstat_tab_instance" width="198i" enabled="0" type="stats" content="STATS"/> 
					</panel>
				</panel>

				<!-- Top Right -->
				<panel noclick="1" y="-3.9h" width="40%" height="5%" align="right" valign="top">
					<instance name="rewardstat_topright_instance" />
				</panel>
			
				<panel name="rewardstats_match_fetch_fail_mask" visible="0" y="-8.1h" align="center" valign="center" width="100w" height="100h" color="0 0 0 .7">
					<instance name="newui_common_popup" width="400i" id="fetch_match_fail" visible="1" show_close="1"
						title="newui_lobby_popup_error" 
						content="rewardstats_match_fetch_fail_body"
						oncloselua="GetWidget('rewardstats_match_fetch_fail_mask'):FadeOut(250)"
					/>
				</panel>
			
				<panel name="rewardstats_loadingentity_mask" width="100w" height="100h" align="center" valign="center" visible="0" color="0 0 0 .7"
					onloadlua="self:RegisterWatch('EntityDefinitionsLoaded', function(_, ...) RewardStat_OnEntityDefinitionsLoaded(...) end)"
				>
					<label textalign="center" textvalign="center" font="dyn_18" color="#f0d3c1" outline="1" outlinecolor="#230000" content="newui_playerstats_loading" noclick="0"/>
					<panel width="682i" height="64i" y="40i" align="center" valign="center">
						<image texture="/ui/fe2/newui/res/playerstats/loading_progress_bg.png" width="1024i" noclick="0"/>
						<panel>
							<panel width="0%" clip="1" 
								watch="EntityDefinitionsProgress" 
								ontriggerlua="
									local percent = tonumber(param0) / tonumber(param1) * 100
									self:SetWidth(tostring(percent)..'%')
									"
							>
							<image texture="/ui/fe2/newui/res/playerstats/loading_progress.png" width="1024i" height="64i" valign="center" noclick="0"/>
							</panel>
						</panel>
					</panel>
				</panel>

				<panel name="endgame_stats_waiting_mask" visible="0" y="-8.1h" align="center" valign="center" width="100w" height="100h" color="0 0 0 .7">
					<animatedimage texture="/ui/fe2/elements/store2/loading/loading_.png" width="512i" height="128i" align="center" valign="center" fps="25" loop="true" loopbackframe="0" startframe="0" onshow="StartAnim();" />
				</panel>
				

			</panel>
			
			<!-- Reborn Feedback (PTM) Instance -->
			<instance name="rewardstat_report_feedback_ptm" />
			
			<!-- Loading Mask -->
			<instance name="rewardstat_operation_mask" />
			
			<!-- Reborn Feedback (PTM) Response Box -->
			<instance name="rewardstat_report_feedback_ptm_response_popup" />
		
			<panel name="rewardstat_debugs2" noclick="1" visible="0">
				<instance name="button2" label="Fetch ID [Debug]" enabled="1" font="dyn_8"
						width="15h" height="2.5h" align="left" valign="center" x="5h"
						onclicklua="RewardStat_GetMatchInfo(GetCvarString('_stats_testfetch')) Trigger('ModelReset')"
				/>
				<textbox name="rewardstats_textboxfetch_debug"
						color="0 0 .2 .5" font="dyn_9" textcolor="#f0d3c1"
						textalign="left" textvalign="center" align="left" valign="center"
						width="9h" height="1.8h" x="7h" y="5h"
						onesc="EraseInputLine();"
						onenter="Set('_stats_testfetch', this); Set('_stats_last_replay_id', this);"
						onchange=""
						onload="CreateString('_stats_testfetch');"
						onloadlua="self:SetInputLine('21426')"
				/>
			</panel>
		
		</panel>

		
	</template>
	
	
	
</package>