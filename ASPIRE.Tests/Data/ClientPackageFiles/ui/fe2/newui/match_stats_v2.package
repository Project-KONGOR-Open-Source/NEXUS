			</widgetstate>
			 <widgetstate statename="disabled">
				<image name="mastery_boost_btn_disable" y="0.5h" align="center" valign="center" width="200%" height="200%" texture="/ui/fe2/mastery/boost_disable.tga" />
			</widgetstate>
		</button>
		-->
		
	</template>
	
	<!-- Temp Buttons -->
	<template name="rewardstat_buttontemp_instance">
		<instance
			name="button2" button_name="{button_name}"
			x="{x=0h}" y="{y=0h}"
			width="{width=10h}" height="{height=3h}"
			align="{align}"
			valign="{valign}"
			label="{label=changeme}" font="{font=dyn_8}"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
			onclicklua="{onclicklua}"
		/>
	</template>
	
	<!-- Temp Label -->
	<template name="rewardstat_temp_label">
		<label noclick="1" align="{align=center}" valign="{valign=top}"
			textalign="{textalign=center}" textvalign="{textvalign=top}" x="{x}" y="{y=1h}"
			color="#f1dbcb" font="{font=dyn_11}" shadow="1" outline="1" outlinecolor="black"
			content="{text=changeme}"
		/>
	</template>
	
	<!-- Total Extra Stats Progress Bar -->
	<template name="rewardstat_total_extra_progressbar">
		<panel name="{id}_body" noclick="1" x="{x}" y="{y}" width="51%" height="16i" valign="{valign=center}">
			<panel noclick="1" width="32h" >
				<panel name="{id}" width="32h" noclick="1" clip="1" align="left" valign="center"> 
					<image width="100%" height="5i" align="center" valign="center" color="#C4C4C4" texture="/ui/fe2/newui/res/homepage/exp.png" />
				</panel>
				<image texture="/ui/fe2/newui/res/match_stats/stats_extrabar_alpha.tga" color="1 1 1 .7" nocompress="1" width="32h" height="16i" align="center" />
			</panel>
		</panel>
	</template>
	
	<!-- Replays Download/Compatanize Box -->
	<template name="rewardstat_replay_download_box">
		<panel name="main_stats_download_box" width="150%" height="150%" align="center" valign="center" blockinput="true" visible="0" watch="MatchInfoSummary" ontrigger="CreateString('_stats_last_replay_host', param18); CreateString('_stats_last_replay_name', param19);">
			<panel visible="false" name="download_progress_bar" width="-2.5h" watch="MatchInfoSummary"
				onload="
					CreateString('_stats_last_replay_url', '');
					CreateString('_stats_last_replay_version', '');
					CreateString('_stats_last_replay_path', '');
				"
				ontrigger="
					If(!StringEmpty(param1), Set('_stats_last_replay_id', param1));
					Set('_stats_last_replay_url', param19);
					Set('_stats_last_replay_version', param18);
					Set('_stats_last_replay_path', param23);
					HideWidget();
				"
				onframe="
					If(ReplayDownloadErrorEncountered(), Split(HideWidget(), ShowWidget('download_replay_retry_btn'))); If(!ReplayDownloadInProgress(), HideWidget());
				"
			>
			</panel>
			<panel align="center" noclick="0">

				<panel height="19.5h" width="26.0h" align="center" valign="center" noclick="1">
					<panel color="0.035 0.012 0.004" x="1" y="1" width="-2" height="-2" noclick="1"/>
					<frame texture="/ui/fe2/newui/res/common/frames/custom/frame.png" borderthickness="4" noclick="1"/>
					<!-- Info -->
					<panel y="0.5h" height="-8.1h" width="-1.0h" align="center" color="invisible" noclick="1">
						

						<panel y="0.5h" height="4.2h" width="-1.0h" align="center"
							watch="ReplayDownloadPercent"
							ontriggerlua="if tonumber(param) >= 1.0 then RewardStat_GetMatchInfo(GetCvarString('_stats_last_replay_id')) end"
						>
							<frame texture="/ui/fe2/newui/res/common/frames/custom/frame.png" borderthickness="4" noclick="1"/>
							<label width="100%" textvalign="center" textalign="center" wrap="true" shadow="true" font="dyn_10" color="#c9a38b" noclick="1" onframe="If(ReplayDownloadErrorEncountered(), Split(SetText(Translate('main_stats_error_downloading_replay')), ShowWidget('main_stats_replay_retry')), Split(HideWidget('main_stats_replay_retry'), If(ReplayDownloadInProgress(), SetText(Translate('main_stats_downloading_replay')), Call('main_stats_download_box', 'HideWidget();'), Call('stats_downloading_replay', 'HideWidget();'))));">main_stats_downloading_replay</label>
						</panel>
						<panel height="-5.2h" align="center" valign="bottom" noclick="true" float="bottom" padding="0.2h" passivechildren="true">
							<label fity="true" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_10" color="#f5eae3" watch="ReplayDownloadProgress" ontrigger="SetText(Translate('main_stats_download_replay_progress', 'count', param0, 'total', param1));"  />
							<label fity="true" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_10" color="#f5eae3" watch="ReplayDownloadSpeed" ontrigger="SetText(Translate('main_stats_download_replay_speed', 'speed', param));"  />
							<label fity="true" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_10" color="#f5eae3" watch="ReplayDownloadTime" ontrigger="SetText(Translate('main_stats_download_replay_remaining', 'time', param));"  />
						</panel>
					</panel>

					<!-- Progress Bar -->
					<panel height="2.4h" y="-4.4h" width="-1.0h" align="center" valign="bottom" color=".1 .1 .1 1" noclick="1">

						<panel watch="ReplayDownloadPercent" ontrigger="SetWidth(FtoP(param0));" noclick="1">
							<image watch="ReplayDownloadPercent" ontrigger="SetUScale(1 / param);" texture="../loadingscreens/loading_bar_fg.tga" noclick="1" />
						</panel>

						<label color="white" font="dyn_10" shadow="true" textalign="center" textvalign="center" watch="ReplayDownloadPercent" ontrigger="SetText(FtoP(param0, 0, 2));"/>

						<frame texture="/ui/frames/black_corners.tga" color="1 1 1 1" borderthickness="0.8h"/>
						<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness="0.6h"/>
					</panel>

					<!-- Control Buttons -->
					<panel y="-0.5h" width="-1.0h" height="3.4h" valign="bottom" align="center" color="invisible" noclick="1">
						<instance
							name="newui_common_button_2_template"
							width="48%"
							align="left"
							valign="center"
							visible="true"
							label="main_stats_retry"
							button_name="main_stats_replay_retry"
							onclick="StopReplayDownload(); DownloadReplay(_stats_last_replay_url); HideWidget();"
						/>

						<instance
							name="newui_common_button_2_template" button_name="unnamedButton200"
							width="48%"
							align="right"
							valign="center"
							label="main_stats_cancel"
							onclick="StopReplayDownload(); Call('main_stats_download_box', 'FadeOut(250);');"
						/>
					</panel>

				</panel>

			</panel>

		</panel>
		
		<!-- Compatibilty archive calculating -->
		<panel name="replays_archive_calc" width="150%" height="150%" visible="0" align="center" valign="center" noclick="0" watch="CompatCalculating" ontrigger="SetVisible(param);">
			<panel width="24h" height="9.5h" align="center" valign="center" color="invisible" noclick="1">
				<panel color="0.035 0.012 0.004" x="1" y="1" width="-2" height="-2" noclick="1"/>
				<frame texture="/ui/fe2/newui/res/common/frames/custom/frame.png" borderthickness="4" noclick="1"/>

				<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
					<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" font="dyn_12" color="#cba58e" outline="1" outlinecolor="#230000" noclick="1" content="replay_compat_calculating" />
					<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="#d7b7a4" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" content="replay_compat_version" />

					<instance
						name="newui_common_button_2_template" button_name="unnamedButton185"
						id="replay_compat_button2"
						y="-0.5h"
						width="13h"
						height="2.2h"
						align="center"
						valign="bottom"
						font="dyn_9"
						label="general_cancel"
						onclick="CancelCompat(); Call('replays_archive_calc', 'SetVisible(0);');"
						enabled="false"
					/>
				</panel>
			</panel>
		</panel>

		<!-- Compatibilty archive downloading -->
		<panel name="replays_archive_dl" width="150%" height="150%" visible="0" align="center" valign="center" noclick="0" watch="CompatDownloading" ontrigger="SetVisible(param);">
			<panel width="24h" height="22h" align="center" valign="center" color="invisible" noclick="1">
				<panel color="0.035 0.012 0.004" x="1" y="1" width="-2" height="-2" noclick="1"/>
				<frame texture="/ui/fe2/newui/res/common/frames/custom/frame.png" borderthickness="4" noclick="1"/>

				<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
					<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" font="dyn_12" color="#cba58e" outline="1" outlinecolor="#230000" noclick="1" content="replay_compat_downloading" />
					<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="#d7b7a4" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" />

					<panel x="1.0h" y="5.0h" width="100%" height="0" align="right" color="invisible" noclick="true" passivechildren="true">
						<label y="0.1h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="#e8ccbb" watch="CompatFilesLeft" ontrigger="SetText(Translate('replay_compat_files', 'count', param0, 'total', param1));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);"  />
						<label y="1.9h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="#e8ccbb" watch="CompatProgress" ontrigger="SetText(Translate('replay_compat_progress', 'count', param0, 'total', param1));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
						<label y="3.8h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="#e8ccbb" watch="CompatSpeed" ontrigger="SetText(Translate('replay_compat_speed', 'speed', param));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
						<label y="5.7h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="#e8ccbb" watch="CompatTime" ontrigger="SetText(Translate('replay_compat_time', 'time', param));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
					</panel>

					<frame
						y="-4.5h"
						width="90%" height="3h"
						align="center" valign="bottom"
						borderthickness="0.3h"
						color="invisible" bordercolor="white"
						watch="CompatPercent" ontrigger="SetVisible(param != 2);"
					>
						<panel x="0.7h" y="0.7h" width="-1.4h" height="-1.4h">
							<panel
								width="50%"
								color="white"
								watch="CompatPercent"
								ontrigger="SetWidth(FtoP(param));"
							/>
						</panel>
					</frame>

					<instance
						name="newui_common_button_2_template" button_name="unnamedButton186"
						id="replay_compat_button"
						y="-0.5h"
						width="13h"
						height="2.2h"
						align="center"
						valign="bottom"
						font="dyn_9"
						label="general_cancel"
						onclick="CancelCompat(); Call('replays_archive_dl', 'SetVisible(0);');"
					/>
				</panel>
			</panel>
		</panel>

		<!-- Compatibilty archive writing -->
		<panel name="replays_archive_write" width="100%" height="100%" visible="false" color="0.0 0.0 0.0 0.66" align="center" noclick="1" watch="CompatWriting" ontrigger="SetVisible(param);"
			onhidelua="RewardStat_GetMatchInfo(GetCvarString('_stats_last_replay_id'))"
		>
			<panel width="24h" height="13.5h" align="center" valign="center" color="invisible" noclick="1">
				<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
				<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

				<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
					<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_writing" />
					<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" content="replay_compat_version" />

					<frame
						y="-4.5h"
						width="90%" height="3h"
						align="center" valign="bottom"
						borderthickness="0.3h"
						color="invisible" bordercolor="white"
						watch="CompatWritePercent" ontrigger="SetVisible(param != 2);"
					>
						<panel x="0.7h" y="0.7h" width="-1.4h" height="-1.4h">
							<panel
								width="50%"
								color="white"
								watch="CompatWritePercent"
								ontrigger="SetWidth(FtoP(param));"
							/>
						</panel>
					</frame>

					<instance
						name="newui_common_button_2_template" button_name="unnamedButton187"
						id="replay_compat_button2"
						y="-0.5h"
						width="13h"
						height="2.2h"
						align="center"
						valign="bottom"
						font="dyn_9"
						label="general_cancel"
						onclick="CancelCompat(); Call('replays_archive_write', 'SetVisible(0);');"
					/>
				</panel>
			</panel>
		</panel>
		
	</template>
	
	<!-- Hero Info Panel -->
	<template name="rewardstat_hero_info_panel">
		<panel name="hero_info" color="0 0 0 0" noclick="true" visible="false">

			<panel x="0" y="-0.5h" width="114.0h" height="38.5h" align="center" valign="bottom">				
				<frame color="0 0 0 .9" borderthickness="1" bordercolor="#445064" />				
				
				<panel width="-1.2h" height="-1.2h" align="center" valign="center">
				
					<!-- Hero Info -->
					<panel x="0.5h" width="29.0h" float="bottom" padding="1.0h">
					
						<panel y="0.3h" width="100%" height="9.2h">					
							<!-- Hero Icon -->
							<panel y="0.6h" width="100@" height="100%">
								<image texture="$checker" watch="HeroSelectHeroInfo" ontrigger="SetTexture(param1);" />
								<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1"/>
								<image x="-0.6h" y="0.8h" width="3.0h" height="3.0h" align="left" valign="bottom" texture="$white" watch="HeroSelectHeroInfo" ontriggerlua="self:SetTexture('/ui/fe2/lobby/' .. param23 .. '.tga')" context="lobby" />
							</panel>
							<!-- Dmg/Attk/Mov -->
							<panel width="-107@" align="right" float="bottom" padding="0.2h">
								<label fity="true" width="100%" font="dyn_14" color="#ffab01" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(param2)" />
								<panel width="100%" height="0.2h">
									<panel width="100%" height="1" valign="bottom" color=".2 .2 .2 1" />
								</panel>
								<panel width="100%" height="1.8h" float="right" padding="0.5h">
									<image width="94@" height="94%" valign="center" texture="/ui/common/damage_icon.tga" />
									<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(Translate('game_hero_select_label_damage', 'damage', round(param15) .. ' - ' .. round(param16)))" />
								</panel>								
								<panel width="100%" height="1.8h" float="right" padding="0.5h">
									<panel width="94@" height="94%" valign="center" />
									<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(Translate('game_hero_select_label_attack_range', 'range', round(param13)))" />
								</panel>
								<panel width="100%" height="1.8h" float="right" padding="0.5h">
									<panel width="94@" height="94%" valign="center" />
									<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(Translate('game_hero_select_label_attack_speed', 'speed', FtoA(1000 / tonumber(param14), 2)))" />
								</panel>								
								<panel width="100%" height="1.8h" float="right" padding="0.5h">
									<image width="94@" height="94%" valign="center" texture="/ui/common/move_speed_icon.tga" />
									<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(Translate('game_hero_select_label_mvspeed', 'mvspeed', round(param11)))" />
								</panel>
								<panel width="100%" height="1.8h" float="right" padding="0.5h">
									<image width="94@" height="94%" valign="center" texture="/ui/common/armor_icon.tga" />
									<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(Translate('game_hero_select_label_armor', 'armor', FtoA(param17, 2)))" />
								</panel>
								<panel width="100%" height="1.8h" float="right" padding="0.5h">
									<image width="94@" height="94%" valign="center" texture="/ui/common/magic_armor_icon.tga" />
									<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(Translate('game_hero_select_label_magicarmor', 'armor', FtoA(param18, 2)))" />
								</panel>
							</panel>						
						</panel>
						
						<panel width="100%" height="0.2h" />
						
						<!-- Mastery -->
						
						<!-- <panel width="100%" height="2.38h" watch="HeroSelectHeroInfo" ontriggerlua="HoN_Learner:SetMasteryInfo(param34)">
							<instance name="learner_mastery_heroinfo" y="0.0h" font="dyn_9" valign="center" width="11.85h" height="2.95h" id_debug="id_hero_tooltip"
								barwidth="7.42h" barheight="1.2h" barx="3.0h" bary="-1.12h" type="1" 
							/>
						</panel> -->

						
						
						<!-- STR/AGI/INT -->
						<panel height="4.3h" width="100%">
							<panel width="32.5%" height="100%" align="left">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#320000"/>
								<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#4e0000" />								
								<panel y="0.1h" height="4.0h">
									<image y="0.1h" width="92@" height="92%" valign="center" texture="/ui/fe2/lobby/strength.tga" />
									<label width="-72@" height="60%" align="right" textvalign="center" textalign="center" font="dyn_12" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="if (param4 == 'strength') then self:SetColor('yellow') else self:SetColor('white') end self:SetText(round(param5))" />
									<label width="-80@" height="60%" align="right" valign="bottom" textvalign="center" textalign="center" font="dyn_10" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="if (param4 == 'strength') then self:SetColor('yellow') else self:SetColor('white') end self:SetText('(+'..FtoA(param6, 1)..')')" />
								</panel>
							</panel>
							
							<panel width="32.5%" height="100%" align="center">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#0b3200"/>
								<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#104b00" />
								<panel y="0.1h" height="4.0h">
									<image y="0.1h" width="92@" height="92%" valign="center" texture="/ui/fe2/lobby/agility.tga" />
									<label width="-72@" height="60%" align="right" textvalign="center" textalign="center" font="dyn_12" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="if (param4 == 'agility') then self:SetColor('yellow') else self:SetColor('white') end self:SetText(round(param7))" />
									<label width="-80@" height="60%" align="right" valign="bottom" textvalign="center" textalign="center" font="dyn_10" color="white" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="if (param4 == 'agility') then self:SetColor('yellow') else self:SetColor('white') end self:SetText('(+'..FtoA(param8, 1)..')');" />
								</panel>
							</panel>
							
							<panel width="32.5%" height="100%" align="right">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#002b39"/>
								<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#003f54" />
								<panel y="0.1h" height="4.0h">
									<image y="0.1h" width="92@" height="92%" valign="center" texture="/ui/fe2/lobby/intelligence.tga" />
									<label width="-72@" height="60%" align="right" textvalign="center" textalign="center" font="dyn_12" color="yellow" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="if (param4 == 'intelligence') then self:SetColor('yellow') else self:SetColor('white') end self:SetText(round(param9))" />
									<label width="-80@" height="60%" align="right" valign="bottom" textvalign="center" textalign="center" font="dyn_10" color="yellow" shadow="true" watch="HeroSelectHeroInfo" ontriggerlua="if (param4 == 'intelligence') then self:SetColor('yellow') else self:SetColor('white') end self:SetText('(+'..FtoA(param10, 1)..')')" />
								</panel>
							</panel>
						</panel>
						
						<panel grow="true" width="100%">
							<label fity="true" wrap="true" font="dyn_10" color=".9 .9 .9 1" shadow="true" content="hero role string" watch="HeroSelectHeroInfo" ontriggerlua="self:SetText(param24)"/>
						</panel>
					
					</panel>					
					
					<!-- Abilities -->
					<panel width="-31.0h" align="right" float="right" padding="1.0%">				
						<instance name="ability_boxv3" id="ability_boxv3_0" index="0" paramindex="24" />
						<instance name="ability_boxv3" id="ability_boxv3_1" index="1" paramindex="25" />
						<instance name="ability_boxv3" id="ability_boxv3_2" index="2" paramindex="26" />
						<instance name="ability_boxv3" id="ability_boxv3_3" index="3" paramindex="27" />			
					</panel>
				</panel>
			</panel>
		</panel>
	</template>
	
	<!-- General Label -->
	<template name="rewardstat_label_general">
		<label name="rewardstat_general_label_{id}" width="{width=5h}"
			noclick="{noclick=1}"
			align="{align=center}" valign="{valign=center}"
			textalign="{textalign=center}" textvalign="{textvalign=center}"
			x="{x}" y="{y}"
			color="{color=#d7b6a2}" font="{font=dyn_11}" shadow="{shadow=0}" shadowoffset="{shadowoffset=0}" outline="{outline=1}" outlinecolor="{outlinecolor=#230000}"
			content="{text=changeme}"
			watch="{watch}" ontrigger="{ontrigger}" ontriggerlua="{ontriggerlua}"
			watch1="{watch1}" ontrigger1="{ontrigger1}"
			onmouseoverlua="{onmouseoverlua}" onmouseoutlua="{onmouseoutlua}"
			onmouseover="{onmouseover}" onmouseout="{onmouseout}" onevent1="{onevent1}"
			watch2="{watch2}" ontrigger2lua="{ontrigger2lua}"
			onclicklua="{onclicklua}" onmouseldownlua="{onmouseldown}" onmouseluplua="{onmouseluplua}"

		/>
	</template>
	
	<!-- Reborn Report Feedback Response Popup -->
	<template name="rewardstat_report_feedback_ptm_response_popup">
		<panel name="rewardstat_report_feedback_ptm_response_popup_panel" color="0 0 0 .5" visible="0">
			<panel width="35h" height="15h" visible="1" align="center" valign="center">		
				<instance name="newui_custom_frame_template" alpha="0.98"/>
				
				<!-- Error/Success Label -->
				<label name="rewardstat_report_feedback_errorlabel" width="350i" height="2h" y="4.5h" textalign="center" textvalign="center" align="center" valign="top" font="dyn_11" color="#b39185" shadow="1" shadowoffset="2" outline="0" 
					content="..."
				/>
				
				<!-- Close Button -->
				<instance name="newui_common_button_2_template" width="10.5h" height="2.5h" align="center" valign="bottom" y="-1.5h"
					label="Close"
					onclicklua="
						GetWidget('rewardstat_report_feedback_ptm_response_popup_panel'):FadeOut(300)
					"						
			/>
			</panel>
		</panel>
	</template>
	
	<!-- Reborn Report Feedback (PTM) -->
	<template name="rewardstat_report_feedback_ptm">
		<panel name="rewardstat_report_feedback_ptm_panel" color="0 0 0 .5" visible="0" noclick="1" hotkey="ESC" onhotkeylua="GetWidget('rewardstat_report_feedback_ptm_panel'):FadeOut(300)"
			onshowlua="PBTFeedback_PanelShowHide('onshowlua')"
			onhidelua="PBTFeedback_PanelShowHide('onhidelua')"
		>
			<panel name="rewardstat_report_feedback_mainframe" width="44h" height="27h" visible="1" align="center" valign="center"
				onhidelua="PBTFeedback_StarRating('reset')"
			>						
				<instance name="newui_popup_caption_frame" title="rewardstat_feedback_title" onclicklua="GetWidget('rewardstat_report_feedback_ptm_panel'):FadeOut(300)"/>

				<!-- Star Rating Template -->
				<panel name="rewardstat_report_feedback_ptm_starratingtemplate" visible="0" noclick="1">

					<!-- Label Question -->
					<frame color="invisible" noclick="1" 
						width="85%" height="8.5h"
						align="center" valign="top"
						x="0h" y="3.5h"
					>
						<label name="rewardstat_feedback_starratingtemplatequestion" noclick="1" content="starrating_question_description" color="#e6bda4" font="verdana_12" textalign="center" textvalign="center"
							width="28h" align="center" valign="center" wrap="1"
						/>
						
						<!-- Stars Feedback Buttons -->
						<panel noclick="1" float="right" align="center" width="36%" height="16%" y="9.7h" onload="CreateInt('_rewardstat_star', 0)">
							<image name="rewardstat_ptm_star_1" onclicklua="PBTFeedback_StarRating(1)" width="32i" height="32i" texture="/ui/fe2/NewUI/Res/match_stats/star_feedback_off.png" />
							<image name="rewardstat_ptm_star_2" onclicklua="PBTFeedback_StarRating(2)" width="32i" height="32i" texture="/ui/fe2/NewUI/Res/match_stats/star_feedback_off.png" />
							<image name="rewardstat_ptm_star_3" onclicklua="PBTFeedback_StarRating(3)" width="32i" height="32i" texture="/ui/fe2/NewUI/Res/match_stats/star_feedback_off.png" />
							<image name="rewardstat_ptm_star_4" onclicklua="PBTFeedback_StarRating(4)" width="32i" height="32i" texture="/ui/fe2/NewUI/Res/match_stats/star_feedback_off.png" />
							<image name="rewardstat_ptm_star_5" onclicklua="PBTFeedback_StarRating(5)" width="32i" height="32i" texture="/ui/fe2/NewUI/Res/match_stats/star_feedback_off.png" />						
						</panel>
						
					</frame>
				
				</panel>
				
				<!-- Checkbox Template -->
				<panel name="rewardstat_report_feedback_ptm_checkboxtemplate" visible="0" noclick="1">

					<!-- Label Question -->
					<frame color="invisible" noclick="1" 
						width="85%" height="8.5h"
						align="center" valign="top"
						x="0h" y="3.5h"
					>
						<label name="rewardstat_feedback_chkboxtemplatequestion" noclick="1" content="chkbox_question_description" color="#e6bda4" font="verdana_12" textalign="center" textvalign="center"
							width="28h" align="center" valign="center" wrap="1"
						/>
						
					</frame>
					
					<!-- Checkboxes -->
					<frame color="invisible" noclick="1" 
						width="39%" height="8.5h"
						align="center" valign="bottom"
						x="1h" y="-7.3h"
					>
						<instance name="newui_checkbox_template" widget_name="rewardstats_feedback_opt1" type="2" height="2.0h" font="dyn_12" outline="1" outlinecolor="#241410"
							unselectedupcolor="#f0d3c5" unselectedovercolor="#f5ece6" selectedupcolor="#c4a693" selectedovercolor="#f5ece6" width="5h" valign="center" align="left"
							content="general_yes"
							onclicklua=
								"
								GetWidget('rewardstats_feedback_opt2'):SetButtonState(0)
								
								if self:GetButtonState() == 0 then
									GetWidget('rewardstats_feedback_next'):SetEnabled(0)
								else
									GetWidget('rewardstats_feedback_next'):SetEnabled(1)
								end
								
								"
						/>
						<instance name="newui_checkbox_template" widget_name="rewardstats_feedback_opt2" type="2" height="2.0h" font="dyn_12" outline="1" outlinecolor="#241410"
							unselectedupcolor="#f0d3c5" unselectedovercolor="#f5ece6" selectedupcolor="#c4a693" selectedovercolor="#f5ece6" width="5h" valign="center" align="right"
							content="general_no"
							onclicklua=
								"
								GetWidget('rewardstats_feedback_opt1'):SetButtonState(0)
								
								if self:GetButtonState() == 0 then
									GetWidget('rewardstats_feedback_next'):SetEnabled(0)
								else
									GetWidget('rewardstats_feedback_next'):SetEnabled(1)
								end
								
								"
						/>
					</frame>
				
				</panel>
				
				<!-- Form Template -->
				<panel name="rewardstat_report_feedback_ptm_formtemplate" visible="0" noclick="1"
					onframelua="
						local feedbackTextBox = GetWidget('rewardstats_report_feedback_editbox')
						local nextButton = GetWidget('rewardstats_feedback_next')
						local endButton = GetWidget('rewardstats_feedback_end')
						local chars = feedbackTextBox:GetInputLine()
						local formType = tostring(PBT_FormType)
						
						if formType == 'checkbox' then
							
						elseif formType == 'form500' then
							if string.len(chars) > 9 then
								nextButton:SetEnabled(1)
								endButton:SetEnabled(1)
							else
								nextButton:SetEnabled(0)
								endButton:SetEnabled(0)
							end
						elseif formType == 'form100' then
							if string.len(chars) > 4 then
								nextButton:SetEnabled(1)
								endButton:SetEnabled(1)
							else
								nextButton:SetEnabled(0)
								endButton:SetEnabled(0)
							end
						else
							
						end
					"				
				>

					<!-- Label Question -->
					<frame color="invisible" noclick="1" 
						width="85%" height="8.5h"
						align="center" valign="top"
						x="0h" y="3.5h"
					>
						<label name="rewardstat_feedback_formtemplatequestion" noclick="1" content="form_question_description" color="#e6bda4" font="verdana_12" textalign="center" textvalign="center"
							width="28h" align="center" valign="center" wrap="1"
						/>
						
					</frame>
					
					<frame name="rewardstats_report_feedback_panel" color="#190f0d" bordercolor="#634334" borderthickness="1" width="85%" height="24h" align="center" valign="center" y="2.2h" >
						<!-- Feedback Textbox -->
						<textbox name="rewardstats_report_feedback_editbox"
							 width="-12i" y="2i"
							 wrap="1"
							 align="center"
							 onshow="SetFocus(1);"						 
							 font="dyn_10"
							 color="invisible"
							 textcolor="white"
							 maxlength="1"
							 onloadlua=""
							 onhide="SetInputLine('');"
							 onchangelua="
								local labelwidget = GetWidget('rewardstat_charlimit_widgetlabel')
								local letters = string.len(self:GetInputLine())
								
								labelwidget:SetText(Translate('rewardstat_charlimit') .. ' ' .. tonumber(self:GetMaxLength() - letters))
							 "
						/>
						
						<!-- Char Limit Label -->
						<label noclick="1" name="rewardstat_charlimit_widgetlabel" color="#ba9280" shadow="1" font="dyn_10" textalign="right" textvalign="center"
							width="12h" height="2.3h"
							align="right" valign="bottom"
							x="-1h" y="2.3h"
							content="rewardstat_charlimit"
						/>
						
					</frame>
					
				</panel>
				
				<!-- Back -->
				<instance name="newui_common_button_2_template" button_name="rewardstats_feedback_back" label="general_back"
					width="9h" height="2.5h" align="center" valign="bottom" y="-3h" visible="1" enabled="0" x="-6h"
					onclicklua="PBTFeedback_NextQ(true)"
				/>
				
				<!-- Next -->
				<instance name="newui_common_button_2_template" button_name="rewardstats_feedback_next" label="general_next"
					width="9h" height="2.5h" align="center" valign="bottom" y="-3h" visible="1" enabled="0" x="6h"
					onclicklua="PBTFeedback_NextQ()"
				/>
				
				<!-- End -->
				<instance name="newui_common_button_2_template" button_name="rewardstats_feedback_end" label="general_submit"
					width="9h" height="2.5h" align="center" valign="bottom" y="-3h" visible="0" x="6h"
					onclicklua="PBTFeedback_End()"
				/>
				
			</panel>
		</panel>
	</template>
	
	<!-- Record Button -->
	<template name="rewardstat_record_btn">
		<button name="{id}" color="invisible" width="{width=100%}" height="{height=100%}" align="{align}" valign="{valign}" enabled="{enabled=true}" x="{x}" y="{y}"
			onclicklua="{onclicklua}"
			onframe="{onframe}"
			onframelua="{onframelua}"
			onmouseover="{onmouseover}"
			onclick="{onclick}"
			visible="{visible=1}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			ontrigger2lua="{ontrigger2lua}"
			ontriggerlua="{ontriggerlua}"
			watch2="{watch2}"
			ontrigger2="{ontrigger2}"
			onshowlua="{onshowlua}"
		>
			<widgetstate statename="up">
				<panel>
					<label noclick="1" name="{id}_1" content="{text}" color="#ba9280" shadow="1" font="dyn_11" height="2.3h" textalign="left" valign="center" textvalign="center" x="4h" width="150%" />		
					<image noclick="1" name="{id}_image_1" texture="/ui/fe2/NewUI/Res/match_stats/replay_button.tga" width="256i" height="32i" align="left" valign="center" />
				</panel>
			</widgetstate>
			<widgetstate statename="over">
				<panel>
					<label noclick="1" name="{id}_2" content="{text}" color="#ba9280" shadow="1" font="dyn_11" height="2.3h" textalign="left" valign="center" textvalign="center" x="4h" width="150%" />
					<image noclick="1" name="{id}_image_2" texture="/ui/fe2/NewUI/Res/match_stats/replay_button_over.tga" width="256i" height="32i" align="left" valign="center" />
				</panel>
			</widgetstate>
			<widgetstate statename="down">
				<panel x="1" y="1">
					<label noclick="1" name="{id}_3" content="{text}" color="#ba9280" shadow="1" font="dyn_11" height="2.3h" textalign="left" valign="center" textvalign="center" x="4h" width="150%" />	
					<image noclick="1" name="{id}_image_3" texture="/ui/fe2/NewUI/Res/match_stats/replay_button_over.tga" width="256i" height="32i" align="left" valign="center" />
				</panel>
			</widgetstate>
			<widgetstate statename="disabled">
				<panel>
					<label noclick="1" content="{text}" color="gray" shadow="1" font="dyn_11" height="2.3h" textalign="left" valign="center" textvalign="center" x="4h" width="150%" />
					<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/replay_button.tga" width="256i" height="32i" align="left" valign="center" rendermode="grayscale" />
				</panel>
			</widgetstate>
		</button>
	</template>
	
	<!-- Top Right -->
	<template name="rewardstat_topright_instance">
		<panel noclick="1" width="20h" x="-36h">
			<instance name="newui_common_button_1_template" content="reborn_feedback_button" button_name="rewardstat_ptm_feedback_button" width="20h" height="3.2h" visible="0"
				onclicklua="GetWidget('rewardstat_report_feedback_ptm_panel'):FadeIn(300)"
			/>
			<modelpanel
				name="rewardstat_ptm_feedback_effect"
				width="150%" height="6.2h"
				y="-.2h"
				align="center" valign="center"
				noclick="true"
				model="/ui/common/models/main/button.mdf"
				anim="idle"
				camerapos="0 -1500 2"
				cameraangles="0 0 0"
				camerafov="7.42"
				visible="0"
				carmerafar="7000"
				depthclear="false"
				depthcompress="true"
				sunazimuth="140"
				sunaltitude="10"
				suncolor="1.4 1.3 5"
				onshow="SetEffect('/ui/fe2/newui/res/effects/button_pbt_fb.effect'));"
				onload="SetEffect('/ui/fe2/newui/res/effects/button_pbt_fb.effect'));"
			/>
		</panel>
		<panel noclick="1" float="right" padding="1h" x="-1.9h" y="-.2h">
			<panel noclick="1" width="16h">
				<!-- Game Map -->
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/map.png" width="16i" height="16i" align="left" valign="center" />
				<label name="rewardstat_topright_gamemap" noclick="1" content="" color="#e2b09a" shadow="1" shadowoffset="1" font="dyn_11"
					height="2.3h" textalign="left" valign="center" textvalign="center" x="2h" 
					watch="MatchInfoSummary" ontriggerlua="
						local stringParam = tostring(TranslateOrEmpty('map_' .. param25))
						if string.len(stringParam) >= 20 then
							self:SetFont('dyn_9')
						else
							self:SetFont('dyn_11')
						end
						self:SetText(TranslateOrEmpty('map_' .. param25))
						"
				/>
			</panel>
			<panel noclick="1" width="2i">
				<image texture="/ui/fe2/NewUI/Res/communicator/line.png" noclick="1" width="2i" height="64i" valign="center" />
			</panel>
			<!-- Game Mode (REMOVED) -->
			<!--<panel noclick="1" width="11h">
				
				 <label name="rewardstat_topright_gamemode" noclick="1" content="" color="#e2b09a" shadow="1" shadowoffset="1" font="dyn_11"
					height="2.3h" textalign="center" valign="center" textvalign="center"
					watch="MatchInfoSummary" 
					ontriggerlua="
					if NotEmpty(param31) then
						local normode = Translate('general_normal_mode')
						local casmode = Translate('general_mode_casual_mode')
						local function ModeCheck() if param31 == 1 then return casmode else return normode end end self:SetText(ModeCheck())
					end
					"
				/>
			</panel> -->
			<panel noclick="1" width="9h">
				<!-- Game Time -->
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/time.png" width="16i" height="16i" align="left" valign="center" />
				<label name="rewardstat_topright_gametime" noclick="1" content="" color="#e2b09a" shadow="1" shadowoffset="1" font="dyn_11"
					height="2.3h" textalign="left" valign="center" textvalign="center" x="2h"
					watch="MatchInfoSummary" ontriggerlua="RewardStat_GameTime(self, param5)"
				/>
			</panel>
			<panel noclick="1" width="20.2h">
				<!-- Record -->
				<instance name="rewardstat_record_btn" enabled="1" id="rewardstat_replaybutton" labelgroup="rewardstat_replaylabels" text="-" visible="1"
					onclicklua="RewardStats_ReplayButton()"
					onframelua="RewardStat_ReplayHandle()"
					watch="ReplayURLStatus"
					ontriggerlua="matchStats_ReplayURLStatus = param"
					watch2="MatchInfoSummary"
					ontrigger2lua="
						matchStats_ReplayUnav = param20
						matchStats_Compat1 = param22
						matchStats_Compat2 = param24
					"
				/>
				<label name="rewardstat_replay_uploadinglabel" content="..." noclick="1" font="dyn_12" color="#ba9280" align="center" valign="center" textalign="center" textvalign="center" visible="0" />
			</panel>
			<panel noclick="1" width="5h">
				<!-- Close -->
				<instance name="newui_button_close_template" x="-1h" y=".5h" 
					onclicklua="
						local parent = GetCvarString('_match_stats_parent_panel')
						if NotEmpty(parent) then
							Set('_mainmenu_currentpanel', parent) 
							GetWidget('MainMenuPanelSwitcher'):DoEvent()
							Set('_match_stats_parent_panel', '')
						else
							GetWidget('match_stats'):FadeOut(150)
						end
					"
				/>
			</panel>

		</panel>
	</template>
	
	<!-- Game Options -->
	<template name="rewardstat_gameoptions">
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(1); If(param33, Split(SetOnMouseover('ShowWidget(\'general_verified\');'), SetTexture('/ui/fe2/NewUI/Res/icons/verified.tga')), Split(SetOnMouseover('ShowWidget(\'general_basic\');'), SetTexture('/ui/fe2/NewUI/Res/icons/basic.tga')));" texture="/ui/fe2/NewUI/Res/icons/basic.tga"  onmouseout="HideWidget('general_verified'); HideWidget('general_basic');" onhide="HideWidget('general_verified'); HideWidget('general_basic');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param34);" onmouseover="Trigger('genericMainFloatingTip', true, '25h', '/ui/fe2/NewUI/Res/icons/gated.tga', 'game_setup_gated', 'game_setup_gated_desc', '', '', '3h', '-2h')" onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');" texture="/ui/fe2/NewUI/Res/icons/gated.tga" />
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param36  or StringEquals(param44, 'bm'));" onmouseover="Trigger('genericMainFloatingTip', true, '25h', '/ui/fe2/NewUI/Res/icons/botmatch.tga', 'game_setup_botmatch', 'game_setup_botmatch_desc', '', '', '3h', '-2h')" onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');" texture="/ui/fe2/NewUI/Res/icons/botmatch.tga" />
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible((param12 or StringEquals(param44, 'ap')) and param40 != '11');" texture="/ui/fe2/NewUI/Res/icons/normal.tga" onmouseover="ShowWidget('gameopt_normal');" onmouseout="HideWidget('gameopt_normal');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'cp'));" texture="/ui/fe2/NewUI/Res/icons/counterpick.tga" onmouseover="ShowWidget('gameopt_counterpick');" onmouseout="HideWidget('gameopt_counterpick');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param26 or StringEquals(param44, 'bd'));" texture="/ui/fe2/NewUI/Res/icons/banningdraft.tga" onmouseover="ShowWidget('gameopt_banningdraft');" onmouseout="HideWidget('gameopt_banningdraft');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param27 or StringEquals(param44, 'bp'));" texture="/ui/fe2/NewUI/Res/icons/banningpick.tga" onmouseover="ShowWidget('gameopt_banningpick');" onmouseout="HideWidget('gameopt_banningpick');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param41 or StringEquals(param44, 'lp'));" texture="/ui/fe2/NewUI/Res/icons/lockpick.tga" onmouseover="ShowWidget('gameopt_lockpick');" onmouseout="HideWidget('gameopt_lockpick');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param38 or StringEquals(param44, 'cm'));" texture="/ui/fe2/NewUI/Res/icons/captainsmode.tga" onmouseover="ShowWidget('gameopt_captainsmode');" onmouseout="HideWidget('gameopt_captainsmode');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param39 == '1' or StringEquals(param44, 'km'));" texture="/ui/fe2/NewUI/Res/icons/krosmode.tga" onmouseover="ShowWidget('gameopt_krosmode');" onmouseout="HideWidget('gameopt_krosmode');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param15 or StringEquals(param44, 'sd'));" texture="/ui/fe2/NewUI/Res/icons/singledraft.tga" onmouseover="ShowWidget('gameopt_singledraft');" onmouseout="HideWidget('gameopt_singledraft');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param13 or StringEquals(param44, 're'));" texture="/ui/fe2/NewUI/Res/icons/randomdraft.tga" onmouseover="ShowWidget('gameopt_randomdraft');" onmouseout="HideWidget('gameopt_randomdraft');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param8 or StringEquals(param44, 'dm'));" texture="/ui/fe2/NewUI/Res/icons/deathmatch.tga" onmouseover="ShowWidget('gameopt_deathmatch');" onmouseout="HideWidget('gameopt_deathmatch');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param43 or StringEquals(param44, 'bb'));" texture="/ui/fe2/NewUI/Res/icons/blindban.tga" onmouseover="ShowWidget('gameopt_blindban');" onmouseout="HideWidget('gameopt_blindban');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'hb'));" texture="/ui/fe2/NewUI/Res/icons/heroban.tga" onmouseover="ShowWidget('gameopt_heroban');" onmouseout="HideWidget('gameopt_heroban');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'mwb'));" texture="/ui/fe2/NewUI/Res/icons/midwarsbeta.tga" onmouseover="ShowWidget('gameopt_midwarsbeta');" onmouseout="HideWidget('gameopt_midwarsbeta');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'ar'));" texture="/ui/fe2/NewUI/Res/icons/allrandom.tga" onmouseover="ShowWidget('gameopt_allrandom');" onmouseout="HideWidget('gameopt_allrandom');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'br'));" texture="/ui/fe2/NewUI/Res/icons/allrandom.tga" onmouseover="ShowWidget('gameopt_balancedrandom');" onmouseout="HideWidget('gameopt_balancedrandom');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'ss'));" texture="/ui/fe2/NewUI/Res/icons/solosame.tga" onmouseover="ShowWidget('gameopt_solosame');" onmouseout="HideWidget('gameopt_solosame');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(StringEquals(param44, 'sm'));" texture="/ui/fe2/NewUI/Res/icons/solodiff.tga" onmouseover="ShowWidget('gameopt_solodiff');" onmouseout="HideWidget('gameopt_solodiff');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param6);" texture="/ui/fe2/NewUI/Res/icons/allheroes.tga" onmouseover="ShowWidget('gameopt_allheroes');" onmouseout="HideWidget('gameopt_allheroes');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param31);" texture="/ui/fe2/NewUI/Res/icons/casual.tga" onmouseover="ShowWidget('gameopt_casual');" onmouseout="HideWidget('gameopt_casual');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param9);" texture="/ui/fe2/NewUI/Res/icons/easymode.tga" onmouseover="ShowWidget('gameopt_easymode');" onmouseout="HideWidget('gameopt_easymode');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param7);" texture="/ui/fe2/NewUI/Res/icons/alternatepicks.tga" onmouseover="ShowWidget('gameopt_altpicks');" onmouseout="HideWidget('gameopt_altpicks');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param11);" texture="/ui/fe2/NewUI/Res/icons/noleaver.tga" onmouseover="ShowWidget('gameopt_noleaver');" onmouseout="HideWidget('gameopt_noleaver');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param14);" texture="/ui/fe2/NewUI/Res/icons/shuffleteams.tga" onmouseover="ShowWidget('gameopt_shuffleteams');" onmouseout="HideWidget('gameopt_shuffleteams');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param28);" texture="/ui/fe2/NewUI/Res/icons/autobalance.tga" onmouseover="ShowWidget('gameopt_autobalance');" onmouseout="HideWidget('gameopt_autobalance');"/>
		<image width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(param32);" texture="/ui/fe2/NewUI/Res/icons/official_2.tga" onmouseover="ShowWidget('gameopt_nostats');" onmouseout="HideWidget('gameopt_nostats');"/>
	</template>
	
	<!-- Rank Progression Info --> 
	<template name="rewardstat_rankprogression_info_instance">
		<panel name="rewardstat_rankprogression_info_panel" noclick="1"
			width="25%" height="32%" align="left" valign="bottom"
			x="5.2h" y="-1.2h"
		>

			<!-- Frame -->
			<instance name="rewardstat_main_border" />	
			
			<!-- Rank Progression -->
			<panel noclick="1" height="16%" width="90%" align="center">
				<label name="rewardstat_label_rankprogression_desc" noclick="1" color="#f1dbcb" font="dyn_12"
					align="center" textalign="left" textvalign="center" content="mastery_replay_rewardtab_con" shadow="1" shadowoffset="2"
				/>
				<image noclick="1" texture="/ui/fe2/NewUI/Res/system_message/item_line.png" width="512i" height="1i" align="center" valign="bottom" />
			</panel>
			
			<panel noclick="1" width="80%" height="64%" align="center" valign="center" y="-.5h">
				<image name="rewardstat_rankprogression_info_chest" texture="$invis" y="-10i" width="256i" height="128i" align="center" valign="center"
					onmouseoverlua="Common_V2:ShowGenericTip(true, Translate('mastery_replay_rewardtab_con'), Translate('mastery_replay_rewardtab_con_tip'), '{width=300i}')"
					onmouseoutlua="Common_V2:ShowGenericTip(false)"
				/>
				<panel y="-10i" width="320i" height="320i" align="center" valign="center" noclick="true">
					<modelpanel name="rewardstat_rankprogression_levelup_effect" align="center" valign="center" noclick="true"
						model="/shared/models/invis.mdf"
						modelpos="0 0 0"
						modelscale="1.0"
						modelangles="0 0 0"
						cameradistance="30"
						camerapos="0 850 0"
						cameraangles="0 0 180"
						camerafov="7"
						cameranear="100.0"
						camerafar="20000.0"
						depthclear="1"
						depthcompress="0"
						sunazimuth="120"
						sunaltitude="20"
						suncolor="0.9 0.9 0.9"
						ambientcolor="0.6 0.7 0.7"
						scenebuffer="1"
						lookat="0"
						visible="1"
					/>
				</panel>
				<panel name="rewardstat_rankprogression_info_expbar_body" align="center" valign="bottom" y="-10i" width="200i" height="15i">
					<frame borderthickness="1i" color="invisible" bordercolor="#36261e" noclick="1" />
					<panel width="198i" height="13i" align="center" valign="center">
						<panel name="rewardstat_rankprogression_info_expbar_after" valign="center" width="100%" noclick="1" clip="1">
							<image texture="/ui/fe2/newui/res/homepage/exp.png" width="196i" color="#075661" noclick="0"/>
						</panel>
						<panel name="rewardstat_rankprogression_info_expbar_before" valign="center" width="100%" noclick="1" clip="1">
							<image texture="/ui/fe2/newui/res/homepage/exp.png" width="196i" noclick="0"/>
						</panel>
					</panel>
					<label name="rewardstat_rankprogression_info_expvalue" textalign="center" textvalign="center" font="dyn_9" color="#e4ffff" outline="1" outlinecolor="#0d5a68" noclick="1"/>
				</panel>
			</panel>
			
			<!-- Next Rank -->
			<panel noclick="1" width="85%" height="20%" align="center" valign="bottom">
				<image noclick="1" texture="/ui/fe2/NewUI/Res/system_message/item_line.png" width="512i" height="1i" align="center" valign="top" />
				<label noclick="1" name="rewardstat_label_conrewards_desc" content="" color="#a78d7d" font="dyn_10" shadow="1" shadowoffset="2"
					textalign="left" textvalign="center" wrap="1"
				/>
			</panel>

			<panel name="rewardstat_rankprogression_noinfo" align="center" valign="center" visible="0">
				<frame color="0 0 0 .8" borderthickness="1" noclick="true" />
				<instance name="rewardstat_main_border" />	
				<label height="100%" width="-8.0h" align="center" textalign="center" textvalign="center" wrap="true" font="dyn_12" color="#f1dbcb" content="mastery_replay_rewardtab_con_noinfo"/>
			</panel>

		</panel>
	</template>
	
	<!-- Rank Progression Visual -->
	<template name="rewardstat_rankprogression_visual_instance">
