						<label content="newui_replay_legion" width="29.5h" textalign="left" textvalign="center" valign="center" color="#c1eef0" font="dyn_14" shadow="1" shadowoffset="1" visible="{legion=0}" />
						<label content="newui_replay_hellbourne" width="29.5h" textalign="left" textvalign="center" valign="center" color="#f7d3d3" font="dyn_14" shadow="1" shadowoffset="1" visible="{hellbourne=0}" />
					</panel>
				</panel>
