				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/winner.png" width="128i" height="32i" x="14h" y=".65h" nocompress="1" watch="MatchInfoSummary" visible="0"
					ontriggerlua="local teamwig = '{hellbourne}' if tonumber(param17) == 2 and tonumber(teamwig) == 1 then self:SetVisible(1) else self:SetVisible(0) end" 
				/>
				<panel noclick="1" float="right" padding="1.7h" align="center" height="110%">
