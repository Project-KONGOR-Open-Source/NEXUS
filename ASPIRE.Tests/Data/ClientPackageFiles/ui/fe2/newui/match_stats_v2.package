		</panel>
	</template>
	
	<!-- Detailed Stats Player Instance List -->
	<template name="reward_detailedstats_playerlist">
		<instance name="rewardstat_detailedstats_playerlist_instance" index="0" team="{team}" />
		<instance name="rewardstat_detailedstats_playerlist_instance" index="1" team="{team}" />
		<instance name="rewardstat_detailedstats_playerlist_instance" index="2" team="{team}" />
		<instance name="rewardstat_detailedstats_playerlist_instance" index="3" team="{team}" />
		<instance name="rewardstat_detailedstats_playerlist_instance" index="4" team="{team}" />
	</template>
	
	<!-- Simple Stats Player Instance List -->
	<template name="reward_simplestats_playerlist">
		<instance name="rewardstat_simplestats_playerlist_instance" index="0" team="{team}" />
		<instance name="rewardstat_simplestats_playerlist_instance" index="1" team="{team}" />
		<instance name="rewardstat_simplestats_playerlist_instance" index="2" team="{team}" />
		<instance name="rewardstat_simplestats_playerlist_instance" index="3" team="{team}" />
		<instance name="rewardstat_simplestats_playerlist_instance" index="4" team="{team}" />
	</template>
	
	<!-- Detailed Stats Team Instance -->
	<template name="rewardstat_detailedstats_team_instance">
		<panel name="rewardstat_detailedstats_team_panel_{team}" noclick="1"
			height="{height=43%}" valign="{valign=center}"
			x="{x=0.2h}" y="{y=1.9h}"
		>
			
			<!-- Legion/Hellbourne Detailed Stats Title -->
			<panel noclick="1" height="12%">
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/stats_bgs/hellbourne.png" width="1024i" height="64i" x="-5i" y="-1.0h" nocompress="1" visible="{hellbourne=0}" />
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/stats_bgs/legion.png" width="1024i" height="64i" x="-5i" y="-1.0h" nocompress="1" visible="{legion=0}" />
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/winner.png" width="128i" height="32i" x="10h" y=".65h" watch="MatchInfoSummary" visible="0"
					ontriggerlua="local teamwig = '{legion}' if tonumber(param17) == 1 and tonumber(teamwig) == 1 then self:SetVisible(1) else self:SetVisible(0) end" 
				/>
				<image noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/winner.png" width="128i" height="32i" x="14h" y=".65h" watch="MatchInfoSummary" visible="0"
					ontriggerlua="local teamwig = '{hellbourne}' if tonumber(param17) == 2 and tonumber(teamwig) == 1 then self:SetVisible(1) else self:SetVisible(0) end" 
				/>
				<panel noclick="1" float="right" padding="1.7h" align="center" height="110%">
					<panel noclick="1" width=".75h" />
					<panel noclick="1" width="29.5h" valign="center">
						<label content="newui_replay_legion" width="29.5h" textalign="left" textvalign="center" valign="center" color="#c1eef0" font="dyn_14" shadow="1" shadowoffset="1" visible="{legion=0}" />
						<label content="newui_replay_hellbourne" width="29.5h" textalign="left" textvalign="center" valign="center" color="#f7d3d3" font="dyn_14" shadow="1" shadowoffset="1" visible="{hellbourne=0}" />
					</panel>
					<instance name="rewardstats_stats_title_icon" statsname="rank" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="lvl" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="kda" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="deaths" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="defense" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="ep" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="gold" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="a" islegion="{legion}" ishellbourne="{hellbourne}"/>
					<instance name="rewardstats_stats_title_icon" statsname="ward" islegion="{legion}" ishellbourne="{hellbourne}"/>
				</panel>
			</panel>


		</panel>
	</template>
	
	<!-- Simple Stats Team Instance -->
