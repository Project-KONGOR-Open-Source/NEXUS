						content="-"  shadow="1" shadowoffset="2" width="20h" height="3h" visible="0" x="2h" y="3h"
						onloadlua="local str = Translate('player_stats_nodata_mask_text') self:SetText(string.upper(str))"
						watch="MatchInfoSummary" ontrigger="SetVisible(param32);"
					/>
