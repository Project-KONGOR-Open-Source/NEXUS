<?xml version="1.0" encoding="UTF-8"?>
<package>
	
	<!-- Lua -->
	<lua file="/ui/scripts/newui/match_stats_v2.lua" />
	<lua file="/ui/scripts/newui/match_stats_feedbackscript_v2.lua" />
	
	<!-- Cvar -->
	<cvar name="_stats_last_match_id" type="string" value="" />
	<cvar name="_stats_latest_match_played" type="string" value="" />
	<cvar name="_player_stats_searchname" type="string" value="" />
	
	<panel noclick="1"
			onload="
			CreateString('_match_stats_parent_panel', '');
			CreateInt('_stats_last_replay_id', -1);
			CreateString('_stats_last_replay_url', '');
			CreateString('_stats_last_replay_version', '');
			CreateString('_stats_last_replay_path', '');"
	/>
	
	<!-- Triggers -->
	<trigger name="RMMStats" />
	<trigger name="matchstats_viewuser"/>
	<trigger name="PlayerRecentGamesListStatus"/>
	<trigger name="PlayerRecentGamesListResult"/>
	<trigger name="MatchEntry2"/>
	<trigger name="MatchEntriesFinished2"/>
	<trigger name="MatchInfoPlayerHover" />
	<trigger name="SetMasteryBoostTipText" />
	<trigger name="SetSuperMasteryBoostTipText" />
	<trigger name="ReplayMasteryError"/>

	<form
		name="PlayerRecentGamesList"
		host="!masterserver"
		method="post"
		target="/client_requester.php"
		statustrigger="PlayerRecentGamesListStatus"
		resulttrigger="PlayerRecentGamesListResult"
		resultparam0="last_stats"
		resultparam1="success"
	/>
	
	<trigger name="RewardStat_ClearList" />
	
	<trigger name="AfterMatchStatsTrigger" />
	<trigger name="ViewStatsTrigger" />
	
	<trigger name="ModelWin" />
	<trigger name="ModelLoose" />
	<trigger name="ModelReset" />
	<trigger name="ResetPlayerMVPMedals" />
	<trigger name="RankUpVisual" />
	<trigger name="RankUpStop" />
	
	<panel noclick="1" watch="AfterMatchStatsTrigger" ontriggerlua="RewardStat_GetMatchInfo(GetShowStatsMatchID()) Echo('^g~~~~~~~~~~ Set HoN_Codex.autopopup true ~~~~~~~~') HoN_Codex.autopopup = true matchStats_showPopupIfGated = 1" />
	<panel noclick="1" watch="ViewStatsTrigger" ontriggerlua=" Set('_mainmenu_currentpanel', 'match_stats') GetWidget('MainMenuPanelSwitcher'):DoEvent() Player_Stats_V2:Show(GetCvarString('_player_stats_searchname'))" />
	
	<!-- Debug Trigger -->
	<trigger name="MatchInfoSummaryTest" />
	
	<!-- 21300 & 21300 -->
	
	<!-- Auto Load Stats LUA -->
	<!-- <panel noclick="1" onloadlua="RewardStatsEmulator_InstantX()" /> -->
	
	<trigger name="RewardStatModelTest" />
	<panel noclick="1" watch="RewardStatModelTest" ontriggerlua="RewardStatsEmulator_TestScript(param, param1)" />
	
	<panel noclick="1"
		watch="PTMFeedback"
		ontriggerlua="
			GetWidget('rewardstat_operation_mask'):SetVisible(0)
			GetWidget('rewardstat_report_feedback_ptm_response_popup_panel'):SetVisible(1)
			GetWidget('rewardstat_report_feedback_errorlabel'):SetText(Translate(tostring(param0)))
		"
	/>

	<!-- Main Border -->
	<template name="rewardstat_main_border">
		<frame noclick="1" texture="/ui/fe2/NewUI/Res/match_stats/rewardstat_frame/frame.png"
			color="1 1 1 1" bordercolor="1 1 1 1" borderthickness="8i"
		/>
	</template>
	
	<!-- Tab -->
	<template name="rewardstat_tab_instance">
		<button name="match_stats_tabbutton_{type}" color="invisible" width="{width=100%}" height="{height=100%}" align="{align}" valign="{valign}" enabled="{enabled=true}"
				onclicklua="Match_Stats_V2:OnClickMainTab('{type}')"
				onmouseoverlua="
					local tabtype = '{type}'
					
					if tabtype == 'rewards' and matchStats_RewardsDisabled == 1 then					
						local title = Translate('match_stat_rewards_tooltip_reward_disabled')
						local desc = Translate('match_stat_rewards_tooltip_reward_disabled_desc')
						Common_V2:ShowGenericTip(true,  title, desc, '{width=300i}')
					end
					"
				onmouseoutlua="Common_V2:ShowGenericTip(false)"
				>
			<widgetstate statename="up">
				<panel float="right">
					<image name="match_stats_tabbutton_{type}_img1" texture="/ui/fe2/newui/res/match_stats/tab/tab_up_l.png" width="16i" height="64i" valign="bottom" noclick="1"/>
					<image name="match_stats_tabbutton_{type}_img2" texture="/ui/fe2/newui/res/match_stats/tab/tab_up_c.png" width="-32i" height="64i" valign="bottom" noclick="1"/>
					<image name="match_stats_tabbutton_{type}_img3" texture="/ui/fe2/newui/res/match_stats/tab/tab_up_l.png" width="16i" height="64i" valign="bottom" noclick="1" hflip="1"/>
				</panel>
				<image texture="/ui/fe2/newui/res/match_stats/tab/{type}_up.png" width="32i" height="32i" x="{iconxoffset=-60i}" align="center" valign="center" noclick="1" /> 
				<label textalign="center" textvalign="center" font="dyn_12" content="{content}" color="#765c50" noclick="1" />
			</widgetstate>
			<widgetstate statename="over"> 
				<panel float="right">
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_over_l.png" width="16i" height="64i" valign="bottom" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_over_c.png" width="-32i" height="64i" valign="bottom" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_over_l.png" width="16i" height="64i" valign="bottom" noclick="1" hflip="1"/>
				</panel>
				<image texture="/ui/fe2/newui/res/match_stats/tab/{type}_over.png" width="32i" height="32i" x="{iconxoffset=-60i}" align="center" valign="center" noclick="1" />
				<label textalign="center" textvalign="center" font="dyn_12" content="{content}" color="#987e71" noclick="1" /> 
			</widgetstate>
			<widgetstate statename="down">
				<panel float="right">
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_over_l.png" width="16i" height="64i" valign="bottom" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_over_c.png" width="-32i" height="64i" valign="bottom" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_over_l.png" width="16i" height="64i" valign="bottom" noclick="1" hflip="1"/>
				</panel>
				<image texture="/ui/fe2/newui/res/match_stats/tab/{type}_over.png" width="32i" height="32i" x="{iconxoffset=-60i}" align="center" valign="center" noclick="1" /> 
				<label textalign="center" textvalign="center" font="dyn_12" content="{content}" color="#987e71" noclick="1" />
			</widgetstate>
			<widgetstate statename="disabled">
				<panel float="right">
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_disabled_l.png" width="16i" height="64i" valign="bottom" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_disabled_c.png" width="-32i" height="64i" valign="bottom" noclick="1"/>
					<image texture="/ui/fe2/newui/res/match_stats/tab/tab_disabled_l.png" width="16i" height="64i" valign="bottom" noclick="1" hflip="1"/>
				</panel>
				<image texture="/ui/fe2/newui/res/match_stats/tab/{type}_over.png" width="32i" height="32i" x="{iconxoffset=-60i}" align="center" valign="center" noclick="1" /> 
				<label textalign="center" textvalign="center" font="dyn_12" content="{content}" color="#987e71" noclick="1" />
			</widgetstate>
		</button>
	</template>
	
	<!-- MVP Awards (/ui/fe2/NewUI/Res/match_stats/11.20/icon09.png) -->
	<template name="rewardstat_mvp_award">
		<panel name="rewardstat_mvp_award_panel_{id}" noclick="1" width="12.0h" visible="1" align="center" valign="center">
			<image texture="{icon}" width="7.6h" height="7.6h" noclick="1" y="-.4h" align="center" valign="top" />
			<label content="{content=-}" color="#a78d7d" font="dyn_9" shadow="1" height="3h"
				align="center" valign="center" textalign="center" textvalign="center" y="2.7h" width="8h" wrap="1"
			/>
			<label content="{data}" color="#f1dbcb" font="dyn_8" shadow="1"
				align="center" valign="center" textalign="center" textvalign="center" y="5.3h" width="128i" 
			/>
		</panel>
	</template>
	
    <!-- Mastery Boost Processing/Loading Mask -->
	<template name="rewardstat_operation_mask">
    	<panel name="rewardstat_operation_mask" visible="0" color="0 0 0 .6" onframelua="RewardStats_OnMasteryFrame()">
    		<panel noclick="1" y="-17h" >
				<label width="-10.0h" y="4h" height="100%" align="center" textalign="center" textvalign="center" wreferral="1" font="dyn_10" color="white" shadow="1" content="mstore_processing_elipses" noclick="1" />
				<animatedimage width="4.5h" height="4.5h" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" visible="1" align="center" valign="center" />
			</panel>
    	</panel>
    </template>
	
	<!-- Player MVP Award -->
	<template name="rewardstat_player_mvp_award">
		<panel noclick="1" width="18i" height="16i" visible="1" valign="{valign}">
			<image name="{widget}" texture="{icon}" width="26i" height="26i"
				onmouseoverlua="									
						local title = Translate(self:GetName())
						Common_V2:ShowSimpleTip(true, title, '200i')
					"
				onmouseoutlua="Common_V2:ShowSimpleTip(false)"
			/>
		</panel>
	</template>
	
	<!-- Mastery Boost Template -->
	<template name="rewardstat_use_mastery_boost_body">
		<panel width="35h" grow="true" align="center" valign="center" float="bottom" padding="1.0h" noclick="true">

			<instance name="newui_custom_frame_template" alpha="1" />
		
			<panel grow="true" y="1.0h" width="100%">
				<label align="center" width="20h" height="3h" textalign="center" textvalign="center" content="confirm_use_mastery_boost_msg" font="dyn_12" color="#f0d3c1" outline="true" outlinecolor="#230000" noclick="1"/>
			</panel>
			
			<panel height="2.4h" noclick="true">	
			
				<instance
					name="newui_common_button_2_template"
					x="-8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					visible="true"
					label="general_cancel"
					button_name="confirm_use_mastery_boost_cancel"
					onclick="Call('use_mastery_boost_confirm', 'FadeOut(250);');"
				/>

				<instance
					name="newui_common_button_2_template"
					x="8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					visible="true"
					label="general_ok"
					button_name="confirm_use_mastery_boost_ok"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclick="Call('use_mastery_boost_confirm', 'FadeOut(250);');"
					onclicklua="
						Cmd('UseMasteryBoost ' .. matchStats_match_id)
						GetWidget('rewardstat_operation_mask'):SetVisible(true)
						Match_Stats_MasteryInfo_masktimer = GetTime()
					"
				/>				
				
			</panel>
			<panel height="0.2h" />
		</panel>
	</template>

	<!-- Stats Title Icon -->
	<template name="rewardstats_stats_title_icon">
		<panel noclick="1" width="{tabwidth=5h}">
			<image texture="/ui/fe2/newui/Res/match_stats/stats_icons/{statsname}_ico.png" width="{icowidth=64i}" height="{icoheight=64i}" valign="center" color="{color}" visible="{islegion=0}" nocompress="1"  onclicklua="Match_Stats_V2:SortStats(1, '{statsname}')" />
			<image texture="/ui/fe2/newui/Res/match_stats/stats_icons/{statsname}_ico_hell.png" width="{icowidth=64i}" height="{icoheight=64i}" valign="center" color="{color}" visible="{ishellbourne=0}" nocompress="1"  onclicklua="Match_Stats_V2:SortStats(2, '{statsname}')" />
		</panel>
	</template>

	<!-- Super Mastery Boost Template -->
	<template name="rewardstat_use_mastery_super_boost_body">
		<panel width="35h" grow="true" align="center" valign="center" float="bottom" padding="1.0h" noclick="true">

			<instance name="newui_custom_frame_template" alpha="1" />
		
			<panel grow="true" y="1.0h" width="100%">
				<label align="center" width="20h" height="3h" textalign="center" textvalign="center" content="confirm_use_mastery_super_boost_msg" font="dyn_12" color="#f0d3c1" outline="true" outlinecolor="#230000" noclick="1"/>
			</panel>
			<panel height="2.4h" noclick="true">
				<instance
					name="newui_common_button_2_template"
					x="-8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					visible="true"
					label="general_cancel"
					button_name="confirm_use_mastery_super_boost_cancel"
					onclick="Call('use_mastery_super_boost_confirm', 'FadeOut(250);');"
				/>

				<instance
					name="newui_common_button_2_template"
					x="8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					visible="true"
					label="general_ok"
					button_name="confirm_use_mastery_super_boost_ok"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclick="Call('use_mastery_super_boost_confirm', 'FadeOut(250);');"
					onclicklua="
						Cmd('UseMasteryBoost ' .. matchStats_match_id .. ' true')
						GetWidget('rewardstat_operation_mask'):SetVisible(true)
						Match_Stats_MasteryInfo_masktimer = GetTime()
					"
				/>
			</panel>
			<panel height="0.2h" />
		</panel>
	</template>

	<!-- Super Mastery Boost Panel -->
	<panel name="use_mastery_super_boost_confirm" visible="{visible=0}" color="0 0 0 .7" onshow="BringToFront();">
		<panel>
			<instance name="rewardstat_use_mastery_super_boost_body" />
		</panel>
	</panel>
	
	<!-- Mastery Boost Panel -->
	<panel name="use_mastery_boost_confirm" visible="{visible=0}" color="0 0 0 .7" onshow="BringToFront();">
		<panel>
			<instance name="rewardstat_use_mastery_boost_body" />
		</panel>
	</panel>
	
	<!-- Extra Earned -->
	<template name="rewardstat_extra_earned">
		<button name="rewardstat_extra_earned"
				x="0h" y="{y}"
				align="center"
				width="2h"
				height="2h"
				color="invisible"
				onmouseoverlua=""
				onmouseoutlua=""
				onclicklua="
					RewardStat_ExtraEarned('toggle')
					"
		>
			<widgetstate statename="up">
				<image name="match_stats_rewards_normal_expand_flash" texture="/ui/fe2/newui/res/match_stats/arrow.png" width="16i" height="16i" x="0h" y="1" noclick="true" align="center" valign="center" />
			</widgetstate>
			<widgetstate statename="over">
				<image name="match_stats_rewards_normal_expand_flash_over" texture="/ui/fe2/newui/res/match_stats/arrow_over.png" width="16i" height="16i" x="0h" y="1" noclick="true" align="center" valign="center" />
			</widgetstate>
			<widgetstate statename="down" y="1">
				<image name="match_stats_rewards_normal_expand_down" texture="/ui/fe2/newui/res/match_stats/arrow_over.png" width="16i" height="16i" x="0h" y="1" noclick="true" align="center" valign="center" />
			</widgetstate>
		</button>
	</template>
	
	<!-- Detail Icon Mouseover Tooltip -->
	<template name="rewardstat_icon_mouseover">
		<button name="mastery_match_bonus_tipbutton_{id}" color="invisible"
				onmouseoverlua="{onmouseoverlua}"
				onmouseoutlua="Common_V2:ShowGenericTip(false)"
		>
			<widgetstate statename="up">
				<image noclick="1" texture="{icon}" width="32i" height="32i" valign="center" />
			</widgetstate>
			<widgetstate statename="over">
				<image noclick="1" texture="{icon}" width="32i" height="32i" valign="center" />
				<image noclick="1" texture="{icon}" width="32i" height="32i" valign="center" />
			</widgetstate>
			<widgetstate statename="down">
				<image noclick="1" texture="{icon}" width="32i" height="32i" valign="center" />
				<image noclick="1" texture="{icon}" width="32i" height="32i" valign="center" />
			</widgetstate>
		</button>
	</template>
	
	<!-- Boost Button -->
	<template name="rewardstat_boostbutton">
		<button name="rewardstat_boostbutton_{type}" color="invisible" width="{width=100%}" height="{height=100%}" align="{align}" valign="{valign}" enabled="{enabled=true}" x="{x}" y="{y}"
				onclicklua="{onclicklua=Echo('SPEED BOOST')}"
				onmouseoverlua="{onmouseoverlua}"
				onmouseoutlua="{onmouseoutlua}"
				watch="{watch}"
				ontrigger="{ontrigger}"
				ontriggerlua="{ontriggerlua}"
				watch1="{watch1}"
				ontrigger1lua="{ontrigger1lua}"
				>
			<widgetstate statename="up">
				<panel>
					<image texture="{texture}_up.tga" width="9h" height="9h" noclick="1" align="center" valign="center" />
					<image name="rewardstat_buyboost_{type}_1" texture="/ui/fe2/newui/res/match_stats/boost_icon_up.png" x=".3h" y=".3h" width="32i" height="32i" noclick="1" align="right" valign="bottom" visible="0" />
				</panel>
			</widgetstate>
			<widgetstate statename="over">
				<panel>
					<image texture="{texture}_over.tga" width="9h" height="9h" noclick="1" align="center" valign="center" />
					<image name="rewardstat_buyboost_{type}_2" texture="/ui/fe2/newui/res/match_stats/boost_icon_over.png" x=".3h" y=".3h" width="32i" height="32i" noclick="1" align="right" valign="bottom" visible="0" />
				</panel>
			</widgetstate>
			<widgetstate statename="down">
				<panel>
					<image texture="{texture}_down.tga" width="9h" height="9h" noclick="1" align="center" valign="center" y="1" />
					<image name="rewardstat_buyboost_{type}_3" texture="/ui/fe2/newui/res/match_stats/boost_icon_over.png" x=".3h" y=".3h" width="32i" height="32i" noclick="1" align="right" valign="bottom" visible="0" />
				</panel>
			</widgetstate>
			<widgetstate statename="disabled">
				<panel>
					<image texture="{texture}_up.tga" width="9h" height="9h" noclick="1" align="center" valign="center" rendermode="grayscale" />
				</panel>
			</widgetstate>
		</button>
		
		<!--
		<button name="mastery_boost_btn"
				align="center"
				valign="center"
				y="-20@"
				width="84.56%"
				height="84.56@"
