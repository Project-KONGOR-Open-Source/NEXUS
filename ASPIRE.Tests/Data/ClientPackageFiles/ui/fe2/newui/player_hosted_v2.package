			<scrollbar  name="hosted_game_gamelist_scroll"
						x="675i"
						y="170i"
						align="center"
						width="12i"
						height="800i"
						valign="top"
						scrollbarsize="12i"
						handlewidth="12i"
						handleheight="25i"							
						texture="/ui/fe2/newui/res/common/scroll/scroll.png"
						scrollbarplaceholder="true"
						minvalue="1"
						maxvalue="1"							
						step="1"
						value="1"
						vertical="true"
						slotwidth="0.6h" slotheight="1"
						onevent1="SetValue(GetValue+1);"
						onevent0="SetValue(GetValue-1);"
						onslidelua="Player_Hosted_V2:UpdateGameList()"
						visible="0"
			/>
			
			<instance name="newui_common_button_1_template" button_name="hosted_game_join" y="-20i"
			     	  width="209i" height="47i" align="right" valign="bottom" font="dyn_16" content="newui_hosted_join"
			     	  onclicklua="Player_Hosted_V2:OnClickJoin()"
			     	  clicksound="/shared/sounds/ui/revamp/startgame.wav"
			/>

			<button x="-210i" y="-11i" width="64i" height="64i" align="right" valign="bottom" color="invisible" 
					onclicklua="PlaySound('/shared/sounds/ui/revamp/refresh.wav') Player_Hosted_V2:OnClickRefreshGameList()"
					onmouseoverlua="PlaySound('/shared/sounds/ui/revamp/region_hover.wav') Common_V2:ShowSimpleTip(true, 'general_refresh', '150i')"
					onmouseoutlua="Common_V2:ShowSimpleTip(false)"
			>
