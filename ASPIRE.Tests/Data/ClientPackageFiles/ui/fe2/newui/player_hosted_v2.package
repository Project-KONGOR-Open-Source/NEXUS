				<panel name="hosted_game_create_serverlist" visible="0" width="+4i" align="center" color="0 0 0 .8" hotkey="ESC" onhotkeylua="self:FadeOut(150)">
					<panel width="700i" height="674i" align="center" valign="center">
						<image texture="/ui/fe2/newui/res/hosted/bg3.png" width="1024i" height="1024i" align="center" valign="center" noclick="1"/>
						<instance name="newui_button_close_template" x="-5i" y="10i" align="right" valign="top" onclicklua="Player_Hosted_V2:CloseServerList()"/>
					
						<panel y="10i" height="32i" noclick="1">
							<label textalign="center" textvalign="center" font="dyn_16" color="#f0d3c1" outline="1" outlinecolor="#230000" content="newui_hosted_selectserver_title" noclick="1"/>
						</panel>

						<panel y="130i" width="-20i" height="40i" align="center" noclick="1" float="right">
							<panel width="42i" />
							<panel width="205i" onclicklua="Player_Hosted_V2:OnClickSortServerList('region')">
								<label x="10i" textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" content="newui_hosted_region" noclick="1"/>
							</panel>
							<panel width="205i" onclicklua="Player_Hosted_V2:OnClickSortServerList('ping')">
								<label x="10i" textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" content="newui_hosted_ping" noclick="1"/>
							</panel>
							<panel width="205i" onclicklua="Player_Hosted_V2:OnClickSortServerList('name')">
								<label x="10i" textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" content="newui_hosted_name" noclick="1"/>
							</panel>

						</panel>
						<panel y="171i" width="-18i" height="373i" align="center">
							<panel width="-20i" float="bottom"
								onmousewheeldown="CallEvent('hosted_game_create_serverlist_scroll', 1);"
								onmousewheelup="CallEvent('hosted_game_create_serverlist_scroll', 0);"
							>
								<instance name="hosted_game_serverlist_item_template" index="1"/>
								<instance name="hosted_game_serverlist_item_template" index="2"/>
								<instance name="hosted_game_serverlist_item_template" index="3"/>
								<instance name="hosted_game_serverlist_item_template" index="4"/>
								<instance name="hosted_game_serverlist_item_template" index="5"/>
								<instance name="hosted_game_serverlist_item_template" index="6"/>
								<instance name="hosted_game_serverlist_item_template" index="7"/>
								<instance name="hosted_game_serverlist_item_template" index="8"/>
								<instance name="hosted_game_serverlist_item_template" index="9"/>
							</panel>
							<scrollbar  name="hosted_game_create_serverlist_scroll"
										align="right"
										width="20i"
										valign="center"
										scrollbarsize="20i"
										handlewidth="20i"
										handleheight="30i"							
										texture="/ui/fe2/newui/res/common/scroll/scroll.png"
										scrollbarplaceholder="true"
										minvalue="1"
										maxvalue="1"							
										step="1"
										value="1"
										vertical="true"
										slotwidth="0.6h" slotheight="1"
										onevent1="SetValue(GetValue+1);"
										onevent0="SetValue(GetValue-1);"
										onslidelua="Player_Hosted_V2:UpdateServerList()"
							/>
						</panel>

						<panel y="70i" width="-120i" height="50i" align="center">
							<label textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" noclick="1" content="newui_hosted_region"/>
							<panel x="100i" width="274i" height="32i" align="center" valign="center">
								<instance name="newui_combobox_template" widgetname="hosted_game_create_serverlist_region" onselectlua="Player_Hosted_V2:OnSelectServerRegion()"/>
							</panel>
						</panel>

						<panel y="-80i" height="40i" align="center" valign="bottom">
							<panel x="0" width="35%" align="center" watch="GameListStatus" ontrigger="SetVisible(param0);">
								<instance name="newui_custom_frame_template"/>
								<panel x="0.4h" y="0.4h" width="-0.8h" height="-0.8h">
									<panel width="0" color="green" watch="GameListStatus" ontrigger="SetWidth(FtoP(param2 / param3));" />
								</panel>
								<label width="100%" height="100%" textalign="center" textvalign="center" font="dyn_10" color="#f0d3c1" outline="1" outlinecolor="#230000" content="mainlobby_label_custom_retrieving_list" watch="GameListStatus" ontrigger="SetVisible(!param1);" />
								<label width="100%" height="100%" textalign="center" textvalign="center" font="dyn_10" color="#f0d3c1" outline="1" outlinecolor="#230000" watch="GameListStatus" ontrigger="SetVisible(param1); SetText(param2 # '/' # param3);" />
							</panel>
							<panel x="0" width="35%" align="center" watch="GameListStatus" ontrigger="SetVisible(!param0);">
								<label width="100%" height="100%" textalign="center" textvalign="center" font="dyn_10" color="#f0d3c1" outline="1" outlinecolor="#230000" watch="GameListStatus" ontrigger="If(param4 != 1, SetText(Translate('main_lobby_responses', 'visible', param5, 'count', param4)), SetText(Translate('main_lobby_response', 'visible', param5, 'count', param4)));" />
							</panel>
						</panel>
						<panel y="-10i" height="40i" align="center" valign="bottom">
							<instance name="newui_common_button_2_template" x="-70i" width="110i" align="center" valign="center" label="newui_hosted_refresh" onclicklua="Player_Hosted_V2:OnClickRefreshServerList()"/>

							<instance name="newui_common_button_2_template" button_name="hosted_game_create_serverlist_select_btn" x="70i" width="110i" align="center" valign="center" label="newui_hosted_select" onclicklua="Player_Hosted_V2:OnClickSelectServer()"/>
						</panel>

						<panel name="hosted_game_create_serverlist_mask" visible="0" height="-40i" valign="bottom">
							<animatedimage texture="/ui/fe2/elements/store2/loading/loading_.png" width="512i" height="128i" align="center" valign="center" fps="25" loop="true" loopbackframe="0" startframe="0" onshow="StartAnim();" />
						</panel>
					</panel>
				</panel>
			</panel>

