						<instance name="newui_common_button_3_template" width="178i" align="right" valign="center" label="newui_hosted_showadvanced"
								onclicklua="GetWidget('hosted_game_filter_advance_gamemode'):FadeOut(150)
											local widget =GetWidget('hosted_game_filter_advance_options')
