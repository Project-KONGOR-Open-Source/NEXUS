						<panel x="50i" width="274i" height="32i" align="center" valign="center">
							<instance name="newui_custom_frame_template"/>
							<textbox name="hosted_game_create_simple_gamename" y="5i" width="-20i" align="center" color="invisible" font="dyn_12" textcolor="#f0d3c1" outline="1" outlinecolor="#230000"
									onesc="SetInputLine(''); SetFocus(false);"
									onenter="SetFocus(false);"
									maxlength="30"
