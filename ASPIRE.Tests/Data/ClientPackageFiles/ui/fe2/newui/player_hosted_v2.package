						<image texture="/ui/fe2/newui/res/mapselection/hg_up.png" width="256i" height="32i" align="center" valign="center" noclick="1"/>
						<image texture="/ui/fe2/newui/res/hosted/hammer_up.png" x="3i" width="32i" height="32i" valign="center" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_create_title" noclick="1"/>
					</widgetstate>
					<widgetstate statename="over">
						<image texture="/ui/fe2/newui/res/mapselection/hg_over.png" width="256i" height="32i" align="center" valign="center" noclick="1"/>
						<image texture="/ui/fe2/newui/res/hosted/hammer_over.png" x="3i" width="32i" height="32i" valign="center" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_create_title" noclick="1"/>
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image texture="/ui/fe2/newui/res/mapselection/hg_over.png" width="256i" height="32i" align="center" valign="center" noclick="1"/>
						<image texture="/ui/fe2/newui/res/hosted/hammer_over.png" x="3i" width="32i" height="32i" valign="center" noclick="1"/>
						<label textalign="center" textvalign="center" font="dyn_11" x="13i" color="#ecf9fa" outline="1" outlinecolor="#215d64" content="newui_hosted_create_title" noclick="1"/>
					</widgetstate>
				</button>
				<instance name="newui_button_close_template" align="right" valign="center" type="2" onclicklua="Player_Hosted_V2:Hide()"/>
			</panel>
			
			<panel float="bottom" padding="8i" noclick="1"
					onmousewheeldown="CallEvent('hosted_game_gamelist_scroll', 1);"
					onmousewheelup="CallEvent('hosted_game_gamelist_scroll', 0);"
			>
				<anchor y="134i"/>
				<panel height="40i" noclick="1">
					<image texture="/ui/fe2/newui/res/hosted/title_bg.png" width="1024i" height="64i" valign="center" noclick="1"/>
					<panel float="right">
						<anchor x="18i"/>
						<instance name="hosted_game_title_template" width="200i" id="1" content="newui_hosted_list_title_name" onclicklua="Player_Hosted_V2:OnClickSortGameList('name')"/>
						<instance name="hosted_game_title_template" width="230i" id="2" content="newui_hosted_list_title_map" onclicklua="Player_Hosted_V2:OnClickSortGameList('map')"/>
						<instance name="hosted_game_title_template" width="205i" id="3" content="newui_hosted_list_title_mode" onclicklua="Player_Hosted_V2:OnClickSortGameList('gameMode')"/>
						<instance name="hosted_game_title_template" width="85i" id="4" content="newui_hosted_list_title_size" onclicklua="Player_Hosted_V2:OnClickSortGameList('teamSize')"/>
						<instance name="hosted_game_title_template" width="85i" id="5" content="newui_hosted_list_title_ping" onclicklua="Player_Hosted_V2:OnClickSortGameList('ping')"/>
						<instance name="hosted_game_title_template" width="90i" id="6" content="newui_hosted_list_title_slots" onclicklua="Player_Hosted_V2:OnClickSortGameList('emptySlots')"/>
						<instance name="hosted_game_title_template" width="105i" id="7" content="newui_hosted_list_title_minpsr" onclicklua="Player_Hosted_V2:OnClickSortGameList('minPsr')"/>
						<instance name="hosted_game_title_template" width="110i" id="8" content="newui_hosted_list_title_maxpsr" onclicklua="Player_Hosted_V2:OnClickSortGameList('maxPsr')"/>
						<instance name="hosted_game_title_template" width="197i" id="9" content="newui_hosted_list_title_options"/>
					</panel>
				</panel>
				<instance name="hosted_game_gamelist_item_template" index="1"/>
				<instance name="hosted_game_gamelist_item_template" index="2"/>
				<instance name="hosted_game_gamelist_item_template" index="3"/>
				<instance name="hosted_game_gamelist_item_template" index="4"/>
				<instance name="hosted_game_gamelist_item_template" index="5"/>
				<instance name="hosted_game_gamelist_item_template" index="6"/>
				<instance name="hosted_game_gamelist_item_template" index="7"/>
				<instance name="hosted_game_gamelist_item_template" index="8"/>
