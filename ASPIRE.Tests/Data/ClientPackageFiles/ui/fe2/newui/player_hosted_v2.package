						<instance name="hosted_game_create_setting_template" height="32i" id="banningdraft" icon="banningdraft.tga" content="mainlobby_label_banning_draft" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('banningdraft')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="lockpick" icon="lockpick.tga" content="mainlobby_label_lockpick" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('lockpick')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="krosmode" icon="krosmode.tga" content="mainlobby_label_krosmode" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('krosmode')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="banningpick" icon="banningpick.tga" content="mainlobby_label_banning_pick" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('banningpick')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="midwars_beta" icon="midwarsbeta.tga" content="mainlobby_label_midwars_beta" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('midwars_beta')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="heroban" icon="heroban.tga" content="mainlobby_label_heroban" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('heroban')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="solosame" icon="solosame.tga" content="mainlobby_label_solo_same_playerhosted" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('solosame')"/>
						<instance name="hosted_game_create_setting_template" height="32i" id="solodiff" icon="solodiff.tga" content="mainlobby_label_solo_diff_playerhosted" hasicon="1" onclicklua="Player_Hosted_V2:OnClickCreateGameMode('solodiff')"/>
