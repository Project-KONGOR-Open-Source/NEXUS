<?xml version="1.0" encoding="UTF-8"?>
<package>
	<lua file="/ui/scripts/newui/player_hosted_v2.lua"/>

	<template name="hosted_game_checkbox_template">
		<button name="{widget_name}" x="{x}" y="{y}" width="{width=100%}" height="{height=100%}" align="{align}" valign="{valign}" color="invisible" numstates="2" 
				onclicklua="PlaySound('/shared/sounds/ui/revamp/region_click.wav') {onclicklua}" 
				watch="{watch}" 
				ontrigger="{ontrigger}"
				watch1="{watch1}"
				ontrigger1="{ontrigger1}"
				onmouseoverlua="PlaySound('/shared/sounds/ui/revamp/region_hover.wav')"
		>
			<widgetstate statename="up1">
				<panel width="16i" height="16i" valign="center">
					<image texture="/ui/fe2/newui/res/common/unselected_up.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				</panel>
				<label x="24i" textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" noclick="1" content="{content}"/>
			</widgetstate>
			<widgetstate statename="over1">
				<panel width="16i" height="16i" valign="center">
					<image texture="/ui/fe2/newui/res/common/unselected_over.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				</panel>
				<label x="24i" textalign="left" textvalign="center" font="dyn_12" color="#f3e8e2" outline="1" outlinecolor="#230000" noclick="1" content="{content}"/>
			</widgetstate>
			<widgetstate statename="down1">
				<panel width="16i" height="16i" valign="center">
					<image texture="/ui/fe2/newui/res/common/unselected_over.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				</panel>
				<label x="24i" textalign="left" textvalign="center" font="dyn_12" color="#f3e8e2" outline="1" outlinecolor="#230000" noclick="1" content="{content}"/>
			</widgetstate>
			<widgetstate statename="up2">
				<panel width="16i" height="16i" valign="center">
					<image texture="/ui/fe2/newui/res/common/selected_up.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				</panel>
				<label x="24i" textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" noclick="1" content="{content}"/>
			</widgetstate>
			<widgetstate statename="over2">
				<panel width="16i" height="16i" valign="center">
					<image texture="/ui/fe2/newui/res/common/selected_over.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				</panel>
				<label x="24i" textalign="left" textvalign="center" font="dyn_12" color="#f3e8e2" outline="1" outlinecolor="#230000" noclick="1" content="{content}"/>
			</widgetstate>
			<widgetstate statename="down2">
				<panel width="16i" height="16i" valign="center">
					<image texture="/ui/fe2/newui/res/common/selected_over.png" width="32i" height="32i" align="center" valign="center" noclick="1"/>
				</panel>
				<label x="24i" textalign="left" textvalign="center" font="dyn_12" color="#f3e8e2" outline="1" outlinecolor="#230000" noclick="1" content="{content}"/>
			</widgetstate>
		</button>
	</template>

	<template name="hosted_game_title_template">
		<panel width="{width=100%}" height="{height=100%}" 
			onclicklua="{onclicklua} PlaySound('/shared/sounds/ui/revamp/region_click.wav')"
			onmouseoverlua="GetWidget('hosted_game_title_{id}_uparrow'):SetTexture('/ui/fe2/newui/res/hosted/arrow_over.png')
							GetWidget('hosted_game_title_{id}_downarrow'):SetTexture('/ui/fe2/newui/res/hosted/arrow_over.png')
							PlaySound('/shared/sounds/ui/revamp/region_hover.wav')
							"
			onmouseoutlua="GetWidget('hosted_game_title_{id}_uparrow'):SetTexture('/ui/fe2/newui/res/hosted/arrow.png')
							GetWidget('hosted_game_title_{id}_downarrow'):SetTexture('/ui/fe2/newui/res/hosted/arrow.png')
							"
		>
			<panel grow="1" regrow="1" height="100%" align="center" float="right" noclick="1">
				<label font="dyn_12" color="#f7d3d3" outline="1" textalign="center" textvalign="center" outlinecolor="#3f0c0c" noclick="1" content="{content}"
					   onloadlua="local width = self:GetStringWidth(Translate('{content}'))
					   			  self:SetWidth(width)
					   			 "
				/>
				<panel width="5i" noclick="1"/>
				<panel noclick="1" width="16i" height="16i" valign="center">
					<image name="hosted_game_title_{id}_uparrow" texture="/ui/fe2/newui/res/hosted/arrow.png" noclick="1" vflip="1" visible="0"/>
					<image name="hosted_game_title_{id}_downarrow" texture="/ui/fe2/newui/res/hosted/arrow_over.png" noclick="1" visible="0"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="hosted_game_gamelist_item_template">
		<panel width="{width=100%}" height="{height=54i}" align="center">
			<instance name="newui_custom_frame_template" alpha="0.5"/>
			<panel name="hosted_game_gamelist_item_{index}" visible="0" float="right"
					onmousewheeldown="CallEvent('hosted_game_gamelist_scroll', 1);"
					onmousewheelup="CallEvent('hosted_game_gamelist_scroll', 0);"
					onclicklua="Player_Hosted_V2:OnClickGame({index})"
					ondoubleclicklua="Player_Hosted_V2:OnClickGame({index}) Player_Hosted_V2:OnClickJoin()"
			>
				<panel name="hosted_game_gamelist_item_{index}_selected" align="center" valign="center" noclick="1" visible="0">
					<frame borderthickness="2i" color="invisible" bordercolor="yellow" noclick="1" />
				</panel>
				<anchor x="18i"/>
				<panel width="200i" noclick="1">
					<instance name="newui_longtext_label_template" label_name="hosted_game_gamelist_item_{index}_gamename" 
						      width="-10i" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" tipx="-18i"
						      onmousewheeldown="CallEvent('hosted_game_gamelist_scroll', 1);"
							  onmousewheelup="CallEvent('hosted_game_gamelist_scroll', 0);"
							  onclicklua="Player_Hosted_V2:OnClickGame({index})"
							  ondoubleclicklua="Player_Hosted_V2:OnClickGame({index}) Player_Hosted_V2:OnClickJoin()"
					/>
				</panel>
				<panel name="hosted_game_gamelist_item_{index}_map" width="230i"
						onmouseoutlua="Common_V2:ShowGenericTip(false)"
						onmousewheeldown="CallEvent('hosted_game_gamelist_scroll', 1);"
						onmousewheelup="CallEvent('hosted_game_gamelist_scroll', 0);"
						onclicklua="Player_Hosted_V2:OnClickGame({index})"
						ondoubleclicklua="Player_Hosted_V2:OnClickGame({index}) Player_Hosted_V2:OnClickJoin()"
				>
					<image name="hosted_game_gamelist_item_{index}_map_icon" x="10i" texture="$invis" width="26i" height="26i" valign="center" noclick="1"/>
					<label name="hosted_game_gamelist_item_{index}_map_text" x="45i" width="-45i" textalign="left" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1" autofont="1" autofontmax="12"/>
				</panel>
				<panel name="hosted_game_gamelist_item_{index}_gamemode" width="205i"
						onmouseoutlua="Common_V2:ShowGenericTip(false)"
						onmousewheeldown="CallEvent('hosted_game_gamelist_scroll', 1);"
						onmousewheelup="CallEvent('hosted_game_gamelist_scroll', 0);"
						onclicklua="Player_Hosted_V2:OnClickGame({index})"
						ondoubleclicklua="Player_Hosted_V2:OnClickGame({index}) Player_Hosted_V2:OnClickJoin()"
				>
					<image name="hosted_game_gamelist_item_{index}_gamemode_icon" x="10i" texture="$invis" width="26i" height="26i" valign="center" noclick="1"/>
					<label name="hosted_game_gamelist_item_{index}_gamemode_text" x="45i" textalign="left" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1"/>
				</panel>
				<panel width="85i" noclick="1">
					<label name="hosted_game_gamelist_item_{index}_teamsize" width="-20i" textalign="center" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1"/>
				</panel>
				<panel width="85i" noclick="1">
					<label name="hosted_game_gamelist_item_{index}_ping" width="-20i" textalign="center" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1"/>
				</panel>
				<panel width="90i" noclick="1">
					<label name="hosted_game_gamelist_item_{index}_slots" width="-20i" textalign="center" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1"/>
				</panel>
				<panel width="105i" noclick="1">
					<label name="hosted_game_gamelist_item_{index}_minpsr" width="-20i" textalign="center" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1"/>
				</panel>
				<panel width="110i" noclick="1">
					<label name="hosted_game_gamelist_item_{index}_maxpsr" width="-20i" textalign="center" textvalign="center" font="dyn_12" color="#ac9282" outline="0" outlinecolor="#230000" noclick="1"/>
				</panel>
				<panel width="197i" noclick="1">
					<panel grow="1" regrow="1" growinvis="0" align="center" height="100%" noclick="1" float="right" padding="2i">
						<image name="hosted_game_gamelist_item_{index}_options1" texture="$invis" width="26i" height="26i" valign="center" stickytoinvis="false"/>
						<image name="hosted_game_gamelist_item_{index}_options2" texture="$invis" width="26i" height="26i" valign="center" stickytoinvis="false"/>
						<image name="hosted_game_gamelist_item_{index}_options3" texture="$invis" width="26i" height="26i" valign="center" stickytoinvis="false"/>
						<image name="hosted_game_gamelist_item_{index}_options4" texture="$invis" width="26i" height="26i" valign="center" stickytoinvis="false"/>
						<image name="hosted_game_gamelist_item_{index}_options5" texture="$invis" width="26i" height="26i" valign="center" stickytoinvis="false"/>
						<image name="hosted_game_gamelist_item_{index}_options6" texture="$invis" width="26i" height="26i" valign="center" stickytoinvis="false"/>
					</panel>
				</panel>
				<anchor x="0"/>
				<panel name="hosted_game_gamelist_item_{index}_invalid" color="0 0 0 .7"/>
			</panel>
		</panel>
	</template>

	<template name="hosted_game_filter_gamemode_template">
		<button name="hosted_game_filter_gamemode_{id}" width="{width=100%}" height="{height=100%}" color="invisible" numstates="2"
				onclicklua="PlaySound('/shared/sounds/ui/revamp/region_click.wav')"
