	<template name="hosted_game_serverlist_item_template">
		<panel name="hosted_game_serverlist_item_{index}" width="{width=100%}" height="{height=11.1%}" float="right" visible="0"
			onmousewheeldown="CallEvent('hosted_game_create_serverlist_scroll', 1);"
			onmousewheelup="CallEvent('hosted_game_create_serverlist_scroll', 0);"
			onclicklua="Player_Hosted_V2:OnClickServer({index})"
			ondoubleclicklua="Player_Hosted_V2:OnClickServer({index}) Player_Hosted_V2:OnClickSelectServer()"
		>
			<panel width="43i" noclick="1">
				<image name="hosted_game_serverlist_item_{index}_official" texture="/ui/icons/official.tga" width="80@" height="80%" align="center" valign="center" noclick="1"/>
			</panel>
			<panel width="206i" noclick="1">
				<label name="hosted_game_serverlist_item_{index}_region" x="10i" textalign="left" textvalign="center" font="dyn_12" color="#897766" outline="1" outlinecolor="#230000" noclick="1"/>
			</panel>
			<panel width="206i" noclick="1">
				<label name="hosted_game_serverlist_item_{index}_ping" x="10i" textalign="left" textvalign="center" font="dyn_12" color="#897766" outline="1" outlinecolor="#230000" noclick="1"/>
			</panel>
			<panel width="206i" noclick="1">
				<label name="hosted_game_serverlist_item_{index}_name" x="10i" textalign="left" textvalign="center" font="dyn_12" color="#897766" outline="1" outlinecolor="#230000" noclick="1"/>
			</panel>
			<anchor x="0"/>
			<panel name="hosted_game_serverlist_item_{index}_selected" align="center" valign="center" noclick="1">
				<frame borderthickness="2i" color="invisible" bordercolor="yellow" noclick="1" />
			</panel>
		</panel>
	</template>

	<panel name="hosted_game" onloadlua="Player_Hosted_V2:Init()" visible="0" hotkey="ESC" onhotkeylua="Player_Hosted_V2:Hide()"
		onload="CreateInt('_prev_button_state', 0);"
	>
		<image texture="/ui/fe2/newui/res/common/bg.png" width="2048i" height="2048i" align="center" valign="center" noclick="1"/>
		<image texture="/ui/fe2/newui/res/hosted/line.png" y="118i" width="1600i" height="4i" align="center" noclick="1"/>

		<panel width="1327i" align="center" noclick="1">
			<panel y="60i" height="60i" noclick="1">
				<image texture="/ui/fe2/newui/res/hosted/title_icon.png" x="16i" width="32i" height="32i" valign="center" noclick="1"/>
				<panel x="70i" float="right" grow="1" regrow="1" height="100%">
					<label textalign="left" textvalign="center" font="dyn_24" color="#a1867d" outline="1" outlinecolor="#230000" noclick="1"
							onshowlua="local str = Translate('newui_hosted_title') 
									   self:SetWidth(tostring(self:GetStringWidth(str))) 
									   self:SetText(str)" />
				</panel>

				<button x="-60i" width="156i" height="32i" valign="center" align="right" color="invisible" onclicklua="Player_Hosted_V2:OpenCreate()">
