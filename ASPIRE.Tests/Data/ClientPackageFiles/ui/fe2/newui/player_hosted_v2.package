					<panel height="27i">
						<label textalign="left" textvalign="center" font="dyn_12" color="#f0d3c1" outline="1" outlinecolor="#230000" noclick="1" content="newui_hosted_gamemode"/>
						<instance name="newui_common_button_3_template" width="178i" align="right" valign="center" label="newui_hosted_showadvanced"
								onclicklua="GetWidget('hosted_game_filter_advance_options'):FadeOut(150)
