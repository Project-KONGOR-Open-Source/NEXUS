			    <instance name="newui_common_button_2_template" x="20i" y="-10i" width="110i" valign="bottom" label="newui_hosted_detail" onclicklua="Player_Hosted_V2:SwitchCreatePanel(false)"/>

				<panel y="70i" width="-70i" height="268i" float="bottom" align="center" noclick="1">
