	</template>

	<template name="hosted_game_create_setting_template">
		<button name="hosted_game_create_setting_{id}" width="{width=100%}" height="{height=100%}" color="invisible" numstates="2" 
				onclicklua="PlaySound('/shared/sounds/ui/revamp/region_click.wav') {onclicklua}"
				onmouseoverlua="PlaySound('/shared/sounds/ui/revamp/region_hover.wav')"
		>
			<widgetstate statename="up1">
				<panel height="32i" valign="center" float="right" grow="1">
					<panel width="100@" height="100%" stickytoinvis="0" visible="{hasicon=false}">
						<image align="center" valign="center" noclick="1" texture="/ui/fe2/newui/res/icons/{icon}"/>
					</panel>
					<image texture="/ui/fe2/newui/res/hosted/state0.png" color="#02b5ff" width="100@" height="100%"/>
					<panel width="100%" noclick="1">
						<label width="500i" textalign="left" textvalign="center" font="dyn_10" color="#02b5ff" noclick="1" content="{content}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="over1">
				<panel height="32i" valign="center" float="right" grow="1">
					<panel width="100@" height="100%" stickytoinvis="0" visible="{hasicon=false}">
						<image align="center" valign="center" noclick="1" texture="/ui/fe2/newui/res/icons/{icon}"/>
					</panel>
					<image texture="/ui/fe2/newui/res/hosted/state0.png" color="#1ccbfe" width="100@" height="100%"/>
					<panel width="100%" noclick="1">
						<label width="500i" textalign="left" textvalign="center" font="dyn_10" color="#1ccbfe" noclick="1" content="{content}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="down1" y="1">
				<panel height="32i" valign="center" float="right" grow="1">
					<panel width="100@" height="100%" stickytoinvis="0" visible="{hasicon=false}">
						<image align="center" valign="center" noclick="1" texture="/ui/fe2/newui/res/icons/{icon}"/>
					</panel>
					<image texture="/ui/fe2/newui/res/hosted/state0.png" color="#1ccbfe" width="100@" height="100%"/>
					<panel width="100%" noclick="1">
