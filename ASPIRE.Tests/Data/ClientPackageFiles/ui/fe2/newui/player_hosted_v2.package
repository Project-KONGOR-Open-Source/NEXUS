						<image align="center" valign="center" noclick="1" texture="/ui/fe2/newui/res/icons/{icon}"/>
					</panel>
					<image texture="/ui/fe2/newui/res/hosted/state2.png" color="#d9001a" width="100@" height="100%"/>
					<panel width="100%" noclick="1">
						<label textalign="left" textvalign="center" font="dyn_10" color="#d9001a" noclick="1" content="{content}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="over2">
				<panel height="32i" valign="center" float="right">
					<panel width="100@" height="100%">
						<image align="center" valign="center" noclick="1" texture="/ui/fe2/newui/res/icons/{icon}"/>
					</panel>
					<image texture="/ui/fe2/newui/res/hosted/state2.png" color="#ff0422" width="100@" height="100%"/>
					<panel width="100%" noclick="1">
						<label textalign="left" textvalign="center" font="dyn_10" color="#ff0422" noclick="1" content="{content}"/>
					</panel>
				</panel>
			</widgetstate>
			<widgetstate statename="down2" y="1">
				<panel height="32i" valign="center" float="right">
					<panel width="100@" height="100%">
						<image align="center" valign="center" noclick="1" texture="/ui/fe2/newui/res/icons/{icon}"/>
					</panel>
					<image texture="/ui/fe2/newui/res/hosted/state2.png" color="#ff0422" width="100@" height="100%"/>
					<panel width="100%" noclick="1">
						<label textalign="left" textvalign="center" font="dyn_10" color="#ff0422" noclick="1" content="{content}"/>
					</panel>
				</panel>
			</widgetstate>
		</button>
	</template>

	<template name="hosted_game_filter_option_template">
