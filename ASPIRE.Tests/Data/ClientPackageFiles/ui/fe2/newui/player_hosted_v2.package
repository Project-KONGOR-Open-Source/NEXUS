					onmouseoverlua="PlaySound('/shared/sounds/ui/revamp/region_hover.wav') Common_V2:ShowSimpleTip(true, 'newui_hosted_filter', '150i')"
					onmouseoutlua="Common_V2:ShowSimpleTip(false)"
