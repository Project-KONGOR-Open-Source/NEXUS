					</panel>
					<panel height="-27i">
						<panel width="-64i" height="32i" y="-20i" align="center" valign="center">
							<panel width="33%" align="left">
								<instance name="hosted_game_filter_gamemode_template" id="normal" icon="normal.tga" content="mainlobby_label_normal"/>
							</panel>
							<panel width="33%" align="center">
								<instance name="hosted_game_filter_gamemode_template" id="blindban" icon="blindban.tga" content="mainlobby_label_blind_ban"/>
							</panel>
							<panel width="33%" align="right">
								<instance name="hosted_game_filter_gamemode_template" id="singledraft" icon="singledraft.tga" content="mainlobby_label_single_draft"/>
							</panel>
						</panel>
						<panel width="-64i"  height="32i" y="20i" align="center" valign="center">
							<panel width="33%" align="left">
								<instance name="hosted_game_filter_gamemode_template" id="botmatch" icon="botmatch.tga" content="general_mode_bots"/>
							</panel>
