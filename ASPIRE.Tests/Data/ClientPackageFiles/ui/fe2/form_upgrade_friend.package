<?xml version="1.0" encoding="UTF-8"?>
<package>

	<!-- Upgrade Friend's account (probably won't need this one soon) -->
	<trigger name="UpdateFriendUpgradeForm"/>
	<trigger name="FriendUpgradeStatus"/>
	<trigger name="FriendUpgradeResult"/>
	<form
		name="FriendUpgrade"
		host="!hon"
		target="/signup/test_upgrade_friend.php"
		statustrigger="FriendUpgradeStatus"
		resulttrigger="FriendUpgradeResult"
		resultparam0="success"
		resultparam1="errors"
		resultparam2="connect"
		resultparam3="code"
		resultparam4="sea"
	/>
	
	<template name="form_upgrade_friend">
		
		<panel y="-110%" align="center" width="100.0h" name="form_upgrade_friend" visible="{visible=0}" noclick="true" valign="center">
			
			<panel x="0" y="-100%" height="203.6%" width="90%"  align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel x="18h" y="-100%" height="203.6%" width="50@"  align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-18h" y="-100%" height="203.6%" width="50@"  align="left" texture="mainmenu/upper_frame_left.tga"/>
			
			<panel y="1.0h" width="-6.0h" height="-3.0h" align="center">
			
			
				<panel float="bottom" padding="0.5h">
				
					<panel width="100%" height="2.8h" noclick="1">
						<instance name="header_bar" lbl="web_form_upgradefriend_title" lbl_font="dyn_12" show_close="1" onclick="{close_cmd}" />
					</panel>					
					
					<panel width="100%" height="44.0h" grow="true">
						
						<!-- Left -->
						<panel width="50%" float="bottom" padding="0.5h" align="left" reverse="true" onload="CreateBool('_friend_nick_valid', false);">
					
							<!-- Friends Name -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="web_form_friend_nickname"
										hastip="true"
										order="100"
										fieldwidth="-1.8h"
										fieldname="friend_upgrade_friendnick"
										ontrigger="If(!StringEmpty(friend_upgrade_friendnick) and (_friend_nick_valid), SetColor('white'), SetColor('red'));"
										tip_id="web_form_tip_friend_nickname"
										form="FriendUpgrade" data="friend_nickname"
										updatetrigger="UpdateFriendUpgradeForm"
									/>
								</panel>
							</panel>
							
							<!-- Promo Code -->
							<panel width="100%" grow="true">								
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<panel width="-10.0h">
										<instance
											name="web_form_field"
											label="web_form_promo_code"
											hastip="true"
											order="101"
											fieldwidth="-1.8h"
											fieldname="friend_upgrade_upgpromocode"
											ontrigger="If((StringLength(friend_upgrade_upgpromocode) gt 0) and (StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20), SetColor('red'), SetColor('white'));"
											tip_id="web_form_tip_promo code"
											form="FriendUpgrade" data="promo_code"
											updatetrigger="UpdateFriendUpgradeForm"
										/>
									</panel>
									<instance
										name="button2" button_name="unnamedButton136"
										x="-0.5h"
										width="9.0h" height="2.4h"
										align="right" valign="center"
										borderthickness="0.6h"
										label="general_apply"
										watch="UpdateFriendUpgradeForm"
										ontrigger="If((StringLength(friend_upgrade_upgpromocode) gt 0) and (StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20), SetEnabled('false'), SetEnabled('true'));"
										enabled="false"
									/>
								</panel>
								
								<!-- Have a Code? -->
								<panel name="have_promo_code_friend_upgrade" height="4h" color="0 0 0 1">
									<frame texture="/ui/info/backdrop.tga" borderthickness="1.0h" color="1 1 1 .6" noclick="1" />
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<label x="0.5h" height="100%" textvalign="center" color="white" font="dyn_11" shadow="true" content="create_acc_havecode" noclick="true" />
									<instance
										name="button2" button_name="unnamedButton137"
										x="-0.5h"
										width="14.0h" height="2.4h"
										borderthickness="0.6h"
										align="right" valign="center"
										label="create_acc_entercode_btn"
										onclick="Call('have_promo_code_friend_upgrade', 'FadeOut(250);');"
									/>
								</panel>
								
							</panel>
	
							<!-- First Name -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_first_name"
										hastip="true"
										order="102"
										fieldwidth="-1.8h"
										fieldname="friend_upgrade_ccfirstname"
										ontrigger="If(StringEmpty(friend_upgrade_ccfirstname) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_first_name"
										form="FriendUpgrade" data="bill_first_name"
										updatetrigger="UpdateFriendUpgradeForm"
									/>
								</panel>
							</panel>

							<!-- Last Name -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_last_name"
										hastip="true"
										order="103"
										fieldwidth="-1.8h"
										fieldname="friend_upgrade_cclastname"
										ontrigger="If(StringEmpty(friend_upgrade_cclastname) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_last_name"
										form="FriendUpgrade" data="bill_last_name"
										updatetrigger="UpdateFriendUpgradeForm"
									/>
								</panel>
							</panel>

							<!-- Zip Code -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_billing_zip"
										hastip="true"
										order="104"
										fieldwidth="-1.8h"
										fieldname="friend_upgrade_cczip"
										ontrigger="If(StringEmpty(friend_upgrade_cczip) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_zip"
										form="FriendUpgrade" data="zip"
										updatetrigger="UpdateFriendUpgradeForm"
									/>
								</panel>
							</panel>

							<!-- CC Number -->
							<panel width="100%" grow="true">
								<panel height="6h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<image texture="/ui/elements/cc.tga" width="8.0h" height="2.0h" valign="bottom" x="1h" y="-0.8h" />
									<instance
										name="web_form_field"
										y="0.8h"
										valign="top"
										label="creditcard_label_prime_card_number"
										hastip="false"
										order="105"
										fieldwidth="-1.8h"
										fieldname="friend_upgrade_ccnum"
										ontrigger="If(!IsValidCCNumber(friend_upgrade_ccnum) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)), SetColor('red'), SetColor('white'));"
										tip_id="web_form_tip_cc_num"
										form="FriendUpgrade" data="card_number"
										updatetrigger="UpdateFriendUpgradeForm"
									/>
								</panel>
							</panel>

							<!-- Expiration Date -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									
									<panel align="center" width="-1h" height="2.4h" valign="center" float="right">
										<label name="friend_upgrade_exp_label" width="33%" height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" content="creditcard_label_prime_expiration" watch="UpdateFriendUpgradeForm" ontrigger="If(
										(
										friend_upgrade_ccmonth lt 1 or
										friend_upgrade_ccmonth gt 12 or
										friend_upgrade_ccyear lt GetYear() or
										(friend_upgrade_ccyear == GetYear() and friend_upgrade_ccmonth lt GetMonth())
										) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)),
											SetColor('red'),
											SetColor('white')
										);"/>									
										<panel width="5%">
											<image align="right" width="1.2h" height="1.0h" valign="center" texture="/ui/info/arrow.tga" />
										</panel>
										
										<panel width="57%">
											<label
												width="100%" height="100%"
												align="center" valign="center"
												textalign="left" textvalign="center"
												font="dyn_10" color="white" shadow="true" shadowcolor="black" noclick="1"
												content="creditcard_label_prime_month"
												watch="UpdateFriendUpgradeForm"
												ontrigger="
													If(
														(
														friend_upgrade_ccmonth lt 1 or
														friend_upgrade_ccmonth gt 12 or
														friend_upgrade_ccyear lt GetYear() or
														(friend_upgrade_ccyear == GetYear() and friend_upgrade_ccmonth lt GetMonth())
														) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)),
															SetColor('red'),
															SetColor('white')
														);
													"
											/>
											
											<panel width="8h" x="5h" height="2.2h" valign="center" reverse="true">
												<instance
													name="Moptions_combobox"
													id="friend_upgrade_ccmonth"
													align="right" width="8.0h" itemwidth="100%" maxlistheight="5"
													onload="CreateString('_purchase_month', '01');"
													onshow="ListBoxCmd('Select 0');"
													onselect="Trigger('UpdateFriendUpgradeForm');"
													populate="
														AddTemplateListItem('Ncombobox_item', '01', 'label', '01');
														AddTemplateListItem('Ncombobox_item', '02', 'label', '02');
														AddTemplateListItem('Ncombobox_item', '03', 'label', '03');
														AddTemplateListItem('Ncombobox_item', '04', 'label', '04');								
														AddTemplateListItem('Ncombobox_item', '05', 'label', '05');
														AddTemplateListItem('Ncombobox_item', '06', 'label', '06');
														AddTemplateListItem('Ncombobox_item', '07', 'label', '07');
														AddTemplateListItem('Ncombobox_item', '08', 'label', '08');
														AddTemplateListItem('Ncombobox_item', '09', 'label', '09');
														AddTemplateListItem('Ncombobox_item', '10', 'label', '10');
														AddTemplateListItem('Ncombobox_item', '11', 'label', '11');								
														AddTemplateListItem('Ncombobox_item', '12', 'label', '12');
														"
													form="FriendUpgrade" formdata="month"
												/>
												
											</panel>
											
											<label
												width="100%" height="100%"
												textvalign="center" textalign="left"
												valign="center" x="13.5h"
												font="dyn_10" color="white" shadow="true" shadowcolor="black" noclick="1"
												content="creditcard_label_prime_year"
											watch="UpdateFriendUpgradeForm"
											ontrigger="If(friend_upgrade_ccyear lt GetYear() and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)), SetColor('red'), SetColor('white'));"
											/>
											
											<panel width="8h" x="17h" height="2.2h" valign="center" reverse="true">
												<instance
													name="Moptions_combobox"
													id="friend_upgrade_ccyear"
													align="right" width="8.0h" itemwidth="100%" maxlistheight="5"
													onload="CreateString('_purchase_month', '01');"
													onshow="ListBoxCmd('Select 0');"
													onselect="Trigger('UpdateFriendUpgradeForm');"
													populate="
														AddTemplateListItem('Ncombobox_item', '2010', 'label', '2010');
														AddTemplateListItem('Ncombobox_item', '2011', 'label', '2011');								
														AddTemplateListItem('Ncombobox_item', '2012', 'label', '2012');
														AddTemplateListItem('Ncombobox_item', '2013', 'label', '2013');
														AddTemplateListItem('Ncombobox_item', '2014', 'label', '2014');
														AddTemplateListItem('Ncombobox_item', '2015', 'label', '2015');
														AddTemplateListItem('Ncombobox_item', '2016', 'label', '2016');
														AddTemplateListItem('Ncombobox_item', '2017', 'label', '2017');
														AddTemplateListItem('Ncombobox_item', '2018', 'label', '2018');								
														AddTemplateListItem('Ncombobox_item', '2019', 'label', '2019');
														AddTemplateListItem('Ncombobox_item', '2020', 'label', '2020');
														"
													form="FriendUpgrade" formdata="year"
												/>
											</panel>										
										</panel>
												
										<panel width="5%">
											<instance name="tip_mark" tip_id="web_form_tip_cc_exp" width="90@" height="90%" valign="center" align="right" />
										</panel>
										
									</panel>
								</panel>
							</panel>
							
							<!-- CVV Number -->
							<panel width="100%" grow="true">
								<panel height="4h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<instance
										name="web_form_field"
										label="creditcard_label_prime_cvv_number"
										hastip="false"
										order="106"
										fieldwidth="-1.8h"
										fieldname="friend_upgrade_cccvv"
										ontrigger="If((StringLength(friend_upgrade_cccvv) lt 3 or !StringContainsOnly(friend_upgrade_cccvv, '', '0')) and ((StringLength(friend_upgrade_upgpromocode) != 18) and (StringLength(friend_upgrade_upgpromocode) != 20)),
											SetColor('red'),
											SetColor('white')
											);"
										tip_id="web_form_tip_cc_cvv2"
										form="FriendUpgrade" data="cvv"
										updatetrigger="UpdateFriendUpgradeForm"
										onfocus="ShowWidget('upgrade_friend_cccvv_img');" onlosefocus="HideWidget('upgrade_friend_cccvv_img');"
									/>
									
								</panel>
							</panel>

							<!-- Secure Info -->
							<panel width="100%" height="6.0h">
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<image width="4.5h" height="4.5h" x="1.0h" valign="center" texture="/ui/elements/thawte.tga" />			
								<label x="-1.0h" width="-7.0h" height="100%" align="right" valign="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" noclick="1">create_acc_secure_transfer</label>
							</panel>
							
						</panel>
						
						<!-- Promo code usage notification -->
						<panel height="28.5h" y="9.0h" width="50%" watch="UpdateFriendUpgradeForm" visible="false" ontrigger="SetVisible((StringLength(friend_upgrade_upgpromocode) == 18) or (StringLength(friend_upgrade_upgpromocode) == 20));">
							<panel color="0 0 0 .75">
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<panel width="-8h" grow="true" align="center" valign="center" color="0 0 0 .75">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<label color="white" shadow="true" font="dyn_10" wrap="true" fity="true" fitypadding="1h" align="center" textalign="center" textvalign="center" width="-1h" content="create_acc_nocc_xfer" />
								</panel>
							</panel>
						</panel>
						
						<!-- Right -->
						<panel width="49.0%" align="right">
						
							<!-- ToS -->
							<panel width="100%" height="31.5h">
								<instance height="2.5h" name="header_bar" color=".7 .7 .7 1" lbl="tos_header" lbl_font="dyn_10" show_close="0" />
								<panel valign="bottom" height="-2.7h">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
									<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 .5" noclick="1" />
									<textbuffer
										scrolltexture="/ui/info/combobox.tga"
										handleheight="2.0h"
										scrollbarsize="2.0h"				
										exteriorscrollbars="false"
										textalign="left"
										font="dyn_10"
										textcolor="white"
										color="invisible"
										shadow="1"
										wrap="true"
										noclick="0"				
										file=":/tos.txt"
										width="-1.0h" height="-2.1h"
										align="center" valign="center"
									/>
								</panel>
							</panel>
	
							<!-- Price / Button -->
							<panel width="100%" valign="bottom" grow="true">
								
								<!-- Price -->
								<panel height="9.2h" width="13.0h" align="left">
									<instance height="2.5h" name="header_bar" color=".7 .7 .7 1" lbl="Total Price" lbl_font="dyn_10" show_close="0" />
									
									<panel height="-2.7h" valign="bottom">
										<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
										
										<panel width="100%" valign="center" grow="true" float="bottom">
											<label fity="true" width="100%" textalign="center" textvalign="center" font="dyn_14" color="#3abde7" content="$--.--"/>
											<label fity="true" width="-0.8h" align="center" valign="bottom" textalign="center" textvalign="center" font="dyn_8" color=".8 .8 .8 1" wrap="true" content="create_acc_price_usd"/>
										</panel>
										
									</panel>
								
								</panel>
								
								<!-- Button -->
								<panel height="9.2h" width="-14.0h" align="right">
									<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />									
									<panel
										visible="false"
										watch="UpdateFriendUpgradeForm" ontrigger="
											if (
												!StringEmpty(friend_upgrade_friendnick) and
												(_friend_nick_valid) and
												!StringEmpty(friend_upgrade_ccfirstname) and
												!StringEmpty(friend_upgrade_cclastname) and
												!StringEmpty(friend_upgrade_cczip) and
												IsValidCCNumber(friend_upgrade_ccnum) and
												StringLength(friend_upgrade_cccvv) ge 3 and
												StringLength(friend_upgrade_cccvv) le 4 and
												StringContainsOnly(friend_upgrade_cccvv, '', '0') and
												friend_upgrade_ccmonth ge 1 and
												friend_upgrade_ccmonth le 12 and
												friend_upgrade_ccyear ge GetYear() and
												(friend_upgrade_ccyear gt GetYear() or friend_upgrade_ccmonth ge GetMonth()) and
												GetAccountID() != -1
												
											, SetVisible(true), SetVisible(false));
										"
									>
										<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 1" noclick="1"/>
										<frame color="invisible" bordercolor="#4b628b" borderthickness="1" noclick="1" />
									</panel>
									
									<panel y="1.0h" float="bottom" padding=".5h" grow="true" width="-1h">
									
										<panel height="0" />									
										
										<label wrap="true" align="center" textalign="center" font="dyn_9" color="white" shadow="true" fity="true" width="-2.0h">web_form_acc_tos_generic</label>										
									
										<panel grow="true" width="-8.0h" align="center">
										
											<instance
												name="button2" button_name="unnamedButton138"
												width="18h" height="2.5h"
												enabled="false"
												align="center"
												label="creditcard_label_upgrade_prime"
												font="dyn_10"
												watch="UpdateFriendUpgradeForm" ontrigger="
													if (
														!StringEmpty(friend_upgrade_friendnick) and
														(_friend_nick_valid) and
														!StringEmpty(friend_upgrade_ccfirstname) and
														!StringEmpty(friend_upgrade_cclastname) and
														!StringEmpty(friend_upgrade_cczip) and
														IsValidCCNumber(friend_upgrade_ccnum) and
														StringLength(friend_upgrade_cccvv) ge 3 and
														StringLength(friend_upgrade_cccvv) le 4 and
														StringContainsOnly(friend_upgrade_cccvv, '', '0') and
														friend_upgrade_ccmonth ge 1 and
														friend_upgrade_ccmonth le 12 and
														friend_upgrade_ccyear ge GetYear() and
														(friend_upgrade_ccyear gt GetYear() or friend_upgrade_ccmonth ge GetMonth()) and
														GetAccountID() != -1
														
													, SetEnabled(true), SetEnabled(false));
												"
												onclick="SubmitForm('FriendUpgrade');"
											/>											
			
											<panel align="center" valign="bottom" width="100%" height="2.5h" visible="false" name="FriendUpgradeStatusIndicator" color="0 0 0 1" watch="FriendUpgradeStatus" ontrigger="SetVisible(param == 1);">
												<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 .5" noclick="1" />
												<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
												<label width="-1h" height="-1h" textvalign="center" textalign="center" align="center" valign="center" shadow="true" color="white" font="dyn_11">credit_card_processing</label>
											</panel>
										
										</panel>
									
									</panel>

								</panel>

							</panel>
					
						</panel>
					
					</panel>
					
					<panel name="upgrade_friend_cccvv_img" width="21.3h" height="10.65h" x="5%" y="0" align="left" valign="bottom" visible="0" noclick="true">
						<image texture="/ui/elements/cvv.tga" noclick="true"/>
					</panel>

				</panel>
				
				
				<!-- Successful account upgrade -->
				<panel color="0 0 0 .5" name="FriendUpgradeSuccessIndicator" watch="FriendUpgradeResult" visible="false" ontrigger="
				If(
					StringEquals(param0,'YES'),
					Split(
						SetVisible(true),
						Call('friend_upgrade_friendnick', 'EraseInputLine();'),
						Call('friend_upgrade_ccfirstname', 'EraseInputLine();'),
						Call('friend_upgrade_cclastname', 'EraseInputLine();'),
						Call('friend_upgrade_cczip', 'EraseInputLine();'),
						Call('friend_upgrade_ccnum', 'EraseInputLine();'),
						Call('friend_upgrade_cccvv', 'EraseInputLine();'),
						Call('friend_upgrade_ccmonth', 'SetSelectedItemByIndex(-1);'),
						Call('friend_upgrade_ccyear', 'SetSelectedItemByIndex(-1);')
					),
					SetVisible(false)
				);
				">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="create_acc_label_account_success" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="create_acc_success" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton139"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclick="Call('FriendUpgradeSuccessIndicator', 'FadeOut(250);');"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_friend', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>

				<!-- Need to log in first -->				
				<panel color="0 0 0 .5" name="FriendUpgradePurchasedNotice" watch="AccountInfo" visible="true" ontrigger="setvisible(GetAccountID() == -1));">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="web_form_must_login" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="web_form_must_login_text" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton140"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_friend', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>				
				
				<!-- Failed account upgrade -->
				<panel color="0 0 0 .5" name="FriendUpgradeFailureIndicator" watch="FriendUpgradeResult" visible="false" ontrigger="SetVisible(StringEquals(param0, 'NO'));">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="credit_card_error_plain" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" watch="FriendUpgradeResult" ontrigger="SetText(param1 # '  ' # param2);" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton141"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclick="HideWidget('FriendUpgradeFailureIndicator');"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>
				
				<!-- Feature unavailable (for now) -->				
				<panel color="0 0 0 .5" visible="true" onload="If(ui_disableAccountCreation or ui_disableAccountForms, ShowWidget());">
					<panel align="center" valign="center" width="38.0h" grow="true" color="0 0 0 1">						
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />						
						<panel width="100%" height="2.5h" noclick="1">
							<instance name="header_bar" lbl="web_form_feature_unavailable_title" lbl_font="dyn_10" show_close="0" />
						</panel>						
						<panel y="3.0h" align="center" grow="true" width="-1h" float="bottom">							
							<panel width="100%" grow="true">
								<label color="white" shadow="true" font="dyn_10" width="-1.0h" align="center" wrap="true" fity="true" content="web_form_feature_unavailable" />
							</panel>							
							<panel width="100%" height="4.0h">							
								<instance
									name="button2" button_name="unnamedButton142"
									y="-1.0h"
									align="center" valign="bottom"
									width="9h" height="2.5h"
									label="general_ok"
									font="dyn_10"
									onclicklua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'form_upgrade_friend', nil, false)"
								/>						
							</panel>							
						</panel>
					</panel>
				</panel>
				
				
			</panel>
			
			

			
		</panel>
		
	</template>

</package>