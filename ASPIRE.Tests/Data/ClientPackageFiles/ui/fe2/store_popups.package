			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_10" style="microStorePaperText" content="web_form_subaccount_success"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="storeButton" width="8h" height="3h" label="general_ok" align="center" onclick="CallEvent('store_popup_sub_account', 1); CallEvent('store_popup_SubAccount_success', 1);"/>
			</panel>
		</panel>
	</template>

