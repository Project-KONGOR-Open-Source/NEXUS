	<template name="storePopupBuyCoinFriendSuccess">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_10" style="microStorePaperText" content="mstore_buycoin_friend_success_body"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="storeButton" width="8h" height="3h" label="general_ok" align="center" onclick="CallEvent('store_popup_buy_coin_friend_success', 1);"/>
