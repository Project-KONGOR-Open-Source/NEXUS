							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'smackdown', 'sound_set', _microStore_voicePack_code, 'sound', 'smackdown');
							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'humiliation', 'sound_set', _microStore_voicePack_code, 'sound', 'humiliation');
							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'nemesis', 'sound_set', _microStore_voicePack_code, 'sound', 'rival');
							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'payback', 'sound_set', _microStore_voicePack_code, 'sound', 'payback');
							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'ragequit', 'sound_set', _microStore_voicePack_code, 'sound', 'rage_quit');
							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'victory', 'sound_set', _microStore_voicePack_code, 'sound', 'victory');
							AddTemplateListItem('storeVoicePreviewItem', 0, 'model_set', _microStore_voicePack_models, 'model', 'defeat', 'sound_set', _microStore_voicePack_code, 'sound', 'defeat');
						"
						itemheight="3h"
						exteriorscrollbars="true"
						scrollbarsize="2.0h"
						scrollbaroffset="0.75h"
						scrolltexture="/ui/info/combobox.tga"
						handleheight="2.0h"
						select="false" hoverselect="false"
					/>
				</panel>

			</panel>
			<panel height="3h">
				<panel width="11.5h">
					<label textalign="center" textvalign="center" style="microStorePaperTitle" font="dyn_10" content="mstore_purchased"/>
					<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_purchase" visible="false" onclick="
						CallEvent('store_popup_voice_preview', 1);
						Trigger('MicroStoreUpdateSelection');
						If(
							## *('microStorePremium' # _microStore_SelectedItem) and ## *('microStoreSilverPrice' # _microStore_SelectedItem) gt 0,
							CallEvent('store_popup_confirm_purchase_choose', 0),
							CallEvent('store_popup_confirm_purchase_choose', 0)
						);

					"
					watch="MicroStoreVoicePreview" ontrigger="
						SetVisible(
							!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
							( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
						);
					"/>
					<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_needcoins" visible="false" onclick="CallEvent('store_popup_voice_preview', 1); Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"
					watch="MicroStoreVoicePreview" ontrigger="
						SetVisible(
							!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
							!( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
						);
					"
					/>
				</panel>
				<panel width="-12h" align="right">
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
					<panel width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
					<panel align="right" width="-110@">
						<label style="microStorePaperCost" noclick="true" font="dyn_11" watch="MicroStoreVoicePreview" textvalign="center" ontrigger="SetText(FtoA(*('microStorePrice' # _microStore_SelectedItem), 0, 0, ','));"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storePopupFirstVisit1">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_10" style="microStorePaperText" content="mstore_firstvisit1b_body"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="storeButton" width="8h" height="3h" label="general_ok" align="center" onclick="##Trigger('DoWalkthrough', 'store1', 1);## CallEvent('store_popup_firstvisit1', 1);"/>
			</panel>
		</panel>
	</template>

	<!-- ============================= ALT AVATAR PREVIEW WINDOW =============================  -->


	<!--
		Removing this for now - may reintegrate it if necessary later on
		name="altAvatarPreviewPanel{id}"
	-->
	<trigger name="loadAltAvatarPreview"/>
	<trigger name="StoreAvatarIsNewRequest"/>
	<trigger name="StoreAvatarIsNewResult"/>
	<template name="altAvatarPreviewPanel">
		<panel color="0 0 0 0.5" visible="false"
			group="storeAltAvatarInfoPanels"
			oneventlua="UIManager.GetInterface('main'):HoNStoreF('RegisterAltAvatar',
					{id=0},
					'{definition=}',
					{hasmodel=false},
					{hastexture=false},
					{haseffects=false},
					{hassounds=false},
					{hasanimations=false},
					{goldCollection=false},
					{limitedEdition=false},
					{holidayEdition=false},
					{collectorsEditionSet=0},
					{heroEntryID=1},
					{ultimateAvatar=false},
					{hasEnhancement=false}
				)"
			watch="getEAPAvatarData"
			ontrigger="
				If(
					StringEquals('{heroName}', param1),
					Trigger('instantiateEAPAvatarData', param0, param1, '{id}', '{product}', '{heroName}')
				);
			"
			watch1="getStoreAvatarDisplayData"
			ontrigger1="
				If(
					param1 == {id=0},
					Trigger(
						'buildStoreAvatarDisplayData',
						param1,			## product id ##
						param2,			## hero_name ##
						param3,			## product code ##
						param4,			## cost ##
						param5,			## silver cost if applicable ##
						param6,			## premium bool ##
						param7,			## Owned? ##
						'{definition=-}',	## entity file location ##
						'{hasmodel=false}',
						'{hastexture=false}',
						'{haseffects=false}',
						'{hassounds=false}',
						'{hasanimations=false}',
						{goldCollection=false},
						{limitedEdition=false},
						param8,			## Purchasable ##
						param9,
						{holidayEdition=false},
						{collectorsEditionSet=0},
						{heroEntryID=1},
						{ultimateAvatar=false},
						'z'
					)
				);
			"
			watch2="getStoreHeroListAvatarData"
			ontrigger2="
				## param0 is going to end up being the product ID to pass on teh way back ##
				If(
					StringEquals('{heroName}', param1),
					Trigger(
						'retStoreHeroListAvatarData',
						param0,		## Product ID ##
						param1,		## hero ##
						GetDelimitedString('{product}', '.', 1),
						{id=0},
						'{product}'
					)
				);
			"
			watch3="StoreAvatarIsNewRequest"
			ontrigger3="
				Trigger('StoreAvatarIsNewResult', {id=0}, '{new=false}', '{ultimateAvatar=false}');
			"
		/>
	</template>


	<!-- ================================ TAUNT PREVIEW PANEL ========================= -->
	<template name="tauntPreviewPanel">
		<panel color="0 0 0 0.5" visible="false" name="altAvatarPreviewPanel{id}"
			onevent0="
				FadeIn(100);
				SleepWidget(101, 'CallEvent(name # \'_plank\', 0);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slidein.wav');
				CallEvent(name # '_mc', 0);
				CallEvent(name # '_model', 0);
			"
			onevent1="
				CallEvent(name # '_mc', 1);
				CallEvent(name # '_model', 1);
				CallEvent(name # '_plank', 1);
				SleepWidget(551, 'FadeOut(100);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slideout.wav');
			"
			onevent2="
				Trigger('loadAltAvatarPreview', *('microStoreID' # _microStore_SelectedItem));
			"
			onload="If({debug=false}, DoEvent(0));"
		>
			<panel width="{width=28h}" grow="true" y="-110%" x="{x}" valign="center" align="center" name="altAvatarPreviewPanel{id}_plank"
				onevent0="SetVisible(true); SlideY('0', 250);"
				onevent1="SleepWidget(250, 'SlideY(\'-110%\', 250);');"
			>
				<instance name="woodenPlankFrame"/>
				<panel height="11h"/><!-- This is about the minimum height that this thing can have -->
				<label width="100%" height="2.5h" y="3.5h" content="" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperTitle" watch="loadAltAvatarPreview" ontrigger="If({id} == param0, SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_name')));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(Translate('mstore_product' # param2 # '_name')));"/>
				<instance visible="true" name="closexButtonPaper" y="4h" width="2h" height="2h" align="right" x="-3h" onclick="CallEvent('altAvatarPreviewPanel{id}', 1);"/>
				<panel width="-6h" align="center" grow="true" y="6h" float="bottom" padding="0.5h">

					<label style="microStorePaperText" font="dyn_10" wrap="true" fity="true" watch="loadAltAvatarPreview" ontrigger="If({id} == param0, SetText(*('microStoreDescription' # _microStore_SelectedItem)));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(Translate('mstore_product' # param2 # '_desc')));" />
					<panel width="100%" grow="true"
						float="bottom"
						padding="0.5h"
					>
						<panel height="18h">
							<panel align="center" width="-5h" height="-3h">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4"/>
								<modelpanel
									resourcecontext="altAvatarPreview{id}"
									noclick="false"
									model="/shared/models/invis.mdf"
									anim="idle"
									cameranear="1.0"
									camerafar="30000.0"
									depthclear="true"
									depthcompress="false"
									lookat="false"
									cameradistance="30"
									camerapos="0 1000 1000"
									cameraangles="-45 0 180"
									camerafov="7"
									modelpos="0 0 0"
									modelangles="0.0 0.0 0.0"
									modelscale="1.0"
									sunazimuth="120"
									sunaltitude="50"
									suncolor="0.9 0.9 0.9"
									ambientcolor="0.6 0.7 0.7"
									cull="false"
									name="altAvatarPreviewPanel{id}_model"
									visible="false"
									watch="loadAltAvatarPreview"
									onevent0="SleepWidget(350, 'DoEvent(2); SetVisible(1);');"
									onevent1="SleepWidget(250, 'SetVisible(0); DeleteResourceContext(\'altAvatarPreview{id}\');');"
									onevent2="
										SetTeamColor('1 0 0');
										LoadEntityDefinition('/heroes/scout/hero.entity');
										SetModel(GetHeroPreviewModelPathFromProduct('Hero_Scout'));
										SetEffect(GetHeroPassiveEffectPathFromProduct('Hero_Scout'));
										SetModelPos(GetHeroPreviewPosFromProduct('Hero_Scout'));
										SetModelAngles(GetHeroPreviewAnglesFromProduct('Hero_Scout'));
										SetModelScale(GetHeroPreviewScaleFromProduct('Hero_Scout'));
									"
									onevent3="
										SetEffect(param0);
									"
									usemodifiers="true"
									scenebuffer="true"
								/>

								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4" name="altAvatarPreviewPanel{id}_mc" onevent0="SleepWidget(350, 'FadeOut(250);');" onevent1="FadeIn(250);"/>
								<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h" noclick="true"/>
							</panel>
							<panel width="-5h" align="center" height="2.5h" valign="bottom">

								<panel width="-2.5h">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#9d5b1a66" />
									<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
									<slider
										name="altAvatarPreviewRotate_{id}"
										slotwidth="-1%" slotheight="0.6h"
										slotcolor="1 1 1 1"
										handlewidth="85@" handleheight="85%"
										handlecolor="1 1 1 1"
										cvar="altAvatarPreviewRotation_{id}"
										minvalue="-179" maxvalue="179"
										step="1"
										texture="/ui/fe2/store/slider2.tga"
										facecamera="false"
										onselect=""
										onchange="
											CreateString('_tmp1_', name);
											Call('altAvatarPreviewPanel{id}_model', 'RotateCameraAroundModel(evaluate(_tmp1_));');
										"
									/>
								</panel>



								<panel width="2h" align="right">
									<instance name="storePlayButton2" width="100%" height="100%" onclick="CallEventParamsX('altAvatarPreviewPanel{id}_model', 3, '{effectPath}');"/>
								</panel>

							</panel>
						</panel>

						<panel grow="true" width="100%">
							<panel align="right" width="-0.5h" valign="bottom" grow="true" float="bottom" padding="0.25h">
								<panel height="3h">
									<panel width="12.5h">
										<label textalign="center" textvalign="center" style="microStorePaperTitle" font="dyn_10" content="mstore_purchased"/>
										<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_purchase" visible="false"
											onclick="
												CallEvent('altAvatarPreviewPanel{id}', 1);
												Trigger('MicroStoreUpdateSelection');
												If(
													## *('microStorePremium' # _microStore_SelectedItem) and ## *('microStoreSilverPrice' # _microStore_SelectedItem) gt 0,
													CallEvent('store_popup_confirm_purchase_choose', 0),
													CallEvent('store_popup_confirm_purchase_choose', 0)
												);
											"
										watch="loadAltAvatarPreview" ontrigger="
											If(
												{id} == param0,
												SetVisible(
													!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
													( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
												)
											);
										"/>
										<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_needcoins" visible="false" onclick="CallEvent('altAvatarPreviewPanel{id}', 1); Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"
										watch="loadAltAvatarPreview" ontrigger="
											If(
												{id} == param0,
												SetVisible(
													!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
													!( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
												)
											);
										"
										/>
									</panel>
									<panel width="-13h" align="right">
										<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
										<panel width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
										<panel align="right" width="-110@">
											<label style="microStorePaperCost" font="dyn_11" watch="loadAltAvatarPreview" textalign="center" textvalign="center" ontrigger="If({id} == param0, SetText(FtoA(*('microStorePrice' # _microStore_SelectedItem), 0, 0, ',')));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(FtoA(param4, 0, 0, ',')));" />
										</panel>
									</panel>
								</panel>
							</panel>
						</panel>
					</panel>
					<panel height="4h" width="100%"/><!-- Spacer -->
				</panel>
			</panel>
		</panel>
	</template>


	<!-- ================================ COURIER VERSION OF AVATAR PREVIEW ========================= -->
	<template name="courierPreviewPanel">
		<panel color="0 0 0 0.5" visible="false" name="altAvatarPreviewPanel{id}"
			onevent0="
				FadeIn(100);
				SleepWidget(101, 'CallEvent(name # \'_plank\', 0);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slidein.wav');
				CallEvent(name # '_mc', 0);
				CallEvent(name # '_model', 0);
			"
			onevent1="
				CallEvent(name # '_mc', 1);
				CallEvent(name # '_model', 1);
				CallEvent(name # '_plank', 1);
				SleepWidget(551, 'FadeOut(100);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slideout.wav');
			"
			onevent2="
				Trigger('loadAltAvatarPreview', *('microStoreID' # _microStore_SelectedItem));
			"
			onload="If({debug=false}, DoEvent(0));"
		>
			<panel width="{width=28h}" grow="true" y="-110%" x="{x}" valign="center" align="center" name="altAvatarPreviewPanel{id}_plank"
				onevent0="SetVisible(true); SlideY('0', 250);"
				onevent1="SleepWidget(250, 'SlideY(\'-110%\', 250);');"
			>
				<instance name="woodenPlankFrame"/>
				<panel height="11h"/><!-- This is about the minimum height that this thing can have -->
				<label width="100%" height="2.5h" y="3.5h" content="" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperTitle" watch="loadAltAvatarPreview" ontrigger="If({id} == param0, SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_name')));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(Translate('mstore_product' # param2 # '_name')));"/>
				<instance visible="true" name="closexButtonPaper" y="4h" width="2h" height="2h" align="right" x="-3h" onclick="CallEvent('altAvatarPreviewPanel{id}', 1);"/>
				<panel width="-6h" align="center" grow="true" y="6h" float="bottom" padding="0.5h">

					<label style="microStorePaperText" font="dyn_10" wrap="true" fity="true" watch="loadAltAvatarPreview" ontrigger="If({id} == param0, SetText(*('microStoreDescription' # _microStore_SelectedItem)));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(Translate('mstore_product' # param2 # '_desc')));" />
					<panel width="100%" grow="true"
						float="bottom"
						padding="0.5h"
					>
						<panel height="18h">
							<panel align="center" width="-5h" height="-3h">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4"/>
								<modelpanel
									resourcecontext="altAvatarPreview{id}"
									noclick="true"
									model=""
									anim="idle"
									cameranear="1.0"
									camerafar="30000.0"
									depthclear="true"
									depthcompress="false"
									lookat="false"
									cameradistance="30"
									camerapos="0 1000 1000"
									cameraangles="-45 0 180"
									camerafov="7"
									modelpos="0 0 0"
									modelangles="0.0 0.0 0.0"
									modelscale="1.0"
									sunazimuth="120"
									sunaltitude="50"
									suncolor="0.9 0.9 0.9"
									ambientcolor="0.6 0.7 0.7"
									name="altAvatarPreviewPanel{id}_model"
									cull="false"
									visible="false"
									watch="loadAltAvatarPreview"
									ontrigger="
										If(
											param0 == {id=0},
											DoEvent(2)
										);
											"
									onevent0="SleepWidget(350, 'SetVisible(1);');"
									onevent1="SleepWidget(250, 'SetVisible(0); DeleteResourceContext(\'altAvatarPreview{id}\');');"
									onevent2="
										SetTeamColor('1 0 0');
										LoadEntityDefinition('/shared/automated_courier/pet_courier/courier.entity');
										SetModel(GetHeroPreviewModelPathFromProduct('Pet_AutomatedCourier.{product}'));
										SetEffect(GetHeroPassiveEffectPathFromProduct('Pet_AutomatedCourier.{product}'));
										SetModelPos(GetHeroPreviewPosFromProduct('Pet_AutomatedCourier.{product}'));
										SetModelAngles(GetHeroPreviewAnglesFromProduct('Pet_AutomatedCourier.{product}'));
										SetModelScale(GetHeroPreviewScaleFromProduct('Pet_AutomatedCourier.{product}'));
									"
									scenebuffer="true"
								/>
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4" name="altAvatarPreviewPanel{id}_mc" onevent0="SleepWidget(350, 'FadeOut(250);');" onevent1="FadeIn(250);"/>
								<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
							</panel>

							<panel width="-5h" align="center" height="2.5h" valign="bottom">
								<panel width="-2.5h">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#9d5b1a66" />
									<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
									<slider
										name="altAvatarPreviewRotate_{id}"
										slotwidth="-1%" slotheight="0.6h"
										slotcolor="1 1 1 1"
										handlewidth="85@" handleheight="85%"
										handlecolor="1 1 1 1"
										cvar="altAvatarPreviewRotation_{id}"
										minvalue="-179" maxvalue="179"
										step="1"
										texture="/ui/fe2/store/slider2.tga"
										facecamera="false"
										onselect=""
										onchange="Call('altAvatarPreviewPanel{id}_model', 'RotateModel(\'0 0 ' # *(name) # '\');');"
									/>
								</panel>
							</panel>
						</panel>

						<panel grow="true" width="100%">
							<panel align="right" width="-0.5h" valign="bottom" grow="true" float="bottom" padding="0.25h">
								<panel height="3h">
									<panel width="12.5h">
										<label textalign="center" textvalign="center" style="microStorePaperTitle" font="dyn_10" content="mstore_purchased"/>
										<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_purchase" visible="false"
											onclick="
												CallEvent('altAvatarPreviewPanel{id}', 1);
												Trigger('MicroStoreUpdateSelection');
												If(
													## *('microStorePremium' # _microStore_SelectedItem) and ## *('microStoreSilverPrice' # _microStore_SelectedItem) gt 0,
													CallEvent('store_popup_confirm_purchase_choose', 0),
													CallEvent('store_popup_confirm_purchase_choose', 0)
												);
											"
										watch="loadAltAvatarPreview" ontrigger="
											If(
												{id} == param0,
												SetVisible(
													!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
													( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
												)
											);
										"/>
										<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_needcoins" visible="false" onclick="CallEvent('altAvatarPreviewPanel{id}', 1); Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"
										watch="loadAltAvatarPreview" ontrigger="
											If(
												{id} == param0,
												SetVisible(
													!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
													!( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
												)
											);
										"
										/>
									</panel>
									<panel width="-13h" align="right">
										<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
										<panel width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
										<panel align="right" width="-110@">
											<label style="microStorePaperCost" font="dyn_11" watch="loadAltAvatarPreview" textalign="center" textvalign="center" ontrigger="If({id} == param0, SetText(FtoA(*('microStorePrice' # _microStore_SelectedItem), 0, 0, ',')));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(FtoA(param4, 0, 0, ',')));" />
										</panel>
									</panel>
								</panel>
							</panel>
						</panel>
					</panel>
					<panel height="4h" width="100%"/><!-- Spacer -->
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storePopupBuyAvatarNeedHero">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label width="100%" align="right" wrap="true" fity="true" fitypadding="1h" textalign="left" textvalign="center" font="dyn_10" style="microStorePaperText" content="mstore_buyavatar_needhero_desc"/>
			<panel grow="true" width="100%">
				<panel float="right" padding="0.75h" height="3h" grow="true" align="center">
					<instance name="storeButton" width="10h" height="100%" label="mstore_viewhero"
						onclick="
							If(
								IsEarlyAccessHero(microStore_heroSelectTarget),
								Set('_microStore_Category', 58),
								Set('_microStore_Category', 71)
							);

							Set('_microStore_RequestCode', 1);
							CallEvent('MicroStoreAction', 0);
							CallEvent('store_popup_buyavatar_needhero', 1);
						"
					/>
					<instance name="storeButton" width="8h" height="100%" label="general_cancel" onclick="CallEvent('store_popup_buyavatar_needhero', 1);"/>
				</panel>
			</panel>
		</panel>
	</template>


	<!-- ================================ WARD VERSION OF AVATAR PREVIEW ========================= -->


	<template name="wardPreviewPanel">
		<panel color="0 0 0 0.5" visible="false" name="altAvatarPreviewPanel{id}"
			onevent0="
				FadeIn(100);
				SleepWidget(101, 'CallEvent(name # \'_plank\', 0);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slidein.wav');
				CallEvent(name # '_mc', 0);
				CallEvent(name # '_mc_rev', 0);
				CallEvent(name # '_model', 0);
				CallEvent(name # '_model_rev', 0);
			"
			onevent1="
				CallEvent(name # '_mc', 1);
				CallEvent(name # '_mc_rev', 1);
				CallEvent(name # '_model', 1);
				CallEvent(name # '_model_rev', 1);
				CallEvent(name # '_plank', 1);
				SleepWidget(551, 'FadeOut(100);');
				PlaySound('/ui/fe2/store/sounds/plankwindow_slideout.wav');
			"
			onevent2="
				Trigger('loadAltAvatarPreview', *('microStoreID' # _microStore_SelectedItem));
			"
			onload="If({debug=false}, DoEvent(0));"
		>
			<panel width="{width=33h}" grow="true" y="-110%" x="{x}" valign="center" align="center" name="altAvatarPreviewPanel{id}_plank"
				onevent0="SetVisible(true); SlideY('0', 250);"
				onevent1="SleepWidget(250, 'SlideY(\'-110%\', 250);');"
			>
				<instance name="woodenPlankFrame"/>
				<panel height="11h"/><!-- This is about the minimum height that this thing can have -->
				<label width="100%" height="2.5h" y="3.5h" content="" textalign="center" textvalign="center" font="dyn_12" style="microStorePaperTitle" watch="loadAltAvatarPreview" ontrigger="If({id} == param0, SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_name')));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(Translate('mstore_product' # param2 # '_name')));"/>
				<instance visible="true" name="closexButtonPaper" y="4h" width="2h" height="2h" align="right" x="-3h" onclick="CallEvent('altAvatarPreviewPanel{id}', 1);"/>
				<panel width="-6h" align="center" grow="true" y="6h" float="bottom" padding="0.5h">

					<label style="microStorePaperText" font="dyn_10" wrap="true" fity="true" watch="loadAltAvatarPreview" ontrigger="If({id} == param0, SetText(*('microStoreDescription' # _microStore_SelectedItem)));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(Translate('mstore_product' # param2 # '_desc')));" />
					<!--<label style="microStorePaperText" font="dyn_10" wrap="true" fity="true" content="" />-->
					<panel width="100%" grow="true"
						float="bottom"
						padding="0.5h"
					>
						<panel height="18h">
							<label style="microStorePaperText" font="dyn_10" textalign="center" textvalign="center" width="13h" height="2h" content="mstore_ward_sight"/>
							<panel align="left" width="13h" height="-5.5h" valign="bottom" y="-3h">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4"/>
								<modelpanel
									resourcecontext="altAvatarPreview{id}"
									noclick="true"
									model=""
									anim="idle"
									cameranear="1.0"
									camerafar="30000.0"
									depthclear="true"
									depthcompress="false"
									lookat="false"
									cameradistance="30"
									camerapos="0 1000 1000"
									cameraangles="-45 0 180"
									camerafov="7"
									modelpos="0 0 0"
									modelangles="0.0 0.0 0.0"
									modelscale="1.0"
									sunazimuth="120"
									sunaltitude="50"
									suncolor="0.9 0.9 0.9"
									ambientcolor="0.6 0.7 0.7"
									name="altAvatarPreviewPanel{id}_model"
									cull="false"
									visible="false"
									watch="loadAltAvatarPreview"
									ontrigger="
										If(
											param0 == {id=0},
											DoEvent(2)
										);
											"
									onevent0="SleepWidget(350, 'SetVisible(1);');"
									onevent1="SleepWidget(250, 'SetVisible(0); DeleteResourceContext(\'altAvatarPreview{id}\');');"
									onevent2="
										SetTeamColor('1 0 0');
										LoadEntityDefinition('/items/basic/flaming_eye/gadget.entity');
										SetModel(GetHeroPreviewModelPathFromProduct('Gadget_FlamingEye.{product}'));
										SetEffect(GetHeroPassiveEffectPathFromProduct('Gadget_FlamingEye.{product}'));
										SetModelPos(GetHeroPreviewPosFromProduct('Gadget_FlamingEye.{product}'));
										SetModelAngles(GetHeroPreviewAnglesFromProduct('Gadget_FlamingEye.{product}'));
										SetModelScale(GetHeroPreviewScaleFromProduct('Gadget_FlamingEye.{product}'));
									"
									scenebuffer="true"
								/>
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4" name="altAvatarPreviewPanel{id}_mc" onevent0="SleepWidget(350, 'FadeOut(250);');" onevent1="FadeIn(250);"/>
								<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
								<panel width="3h" height="3h" x="-0.25h" y="-0.25h">
									<image texture="/items/basic/flaming_eye/icon.tga"/>
									<frame color="invisible" bordercolor="#0B0B0B" borderthickness="1"/>
								</panel>
							</panel>
							<label style="microStorePaperText" font="dyn_10" textalign="center" textvalign="center" width="13h" x="13.5h" height="2h" content="mstore_ward_revelation"/>
							<panel align="left" width="13h" x="13.5h" height="-5.5h" valign="bottom" y="-3h">

								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4"/>
								<modelpanel
									resourcecontext="altAvatarPreview{id}"
									noclick="true"
									model=""
									anim="idle"
									cameranear="1.0"
									camerafar="30000.0"
									depthclear="true"
									depthcompress="false"
									lookat="false"
									cameradistance="30"
									camerapos="0 1000 1000"
									cameraangles="-45 0 180"
									camerafov="7"
									modelpos="0 0 0"
									modelangles="0.0 0.0 0.0"
									modelscale="1.0"
									sunazimuth="120"
									sunaltitude="50"
									suncolor="0.9 0.9 0.9"
									ambientcolor="0.6 0.7 0.7"
									name="altAvatarPreviewPanel{id}_model_rev"
									cull="false"
									visible="false"
									watch="loadAltAvatarPreview"
									ontrigger="
										If(
											param0 == {id=0},
											DoEvent(2)
										);
											"
									onevent0="SleepWidget(350, 'SetVisible(1);');"
									onevent1="SleepWidget(250, 'SetVisible(0); DeleteResourceContext(\'altAvatarPreview{id}\');');"
									onevent2="
										SetTeamColor('1 0 0');
										LoadEntityDefinition('/items/basic/mana_eye/gadget.entity');
										SetModel(GetHeroPreviewModelPathFromProduct('Gadget_Item_ManaEye.{product}'));
										SetEffect(GetHeroPassiveEffectPathFromProduct('Gadget_Item_ManaEye.{product}'));
										SetModelPos(GetHeroPreviewPosFromProduct('Gadget_Item_ManaEye.{product}'));
										SetModelAngles(GetHeroPreviewAnglesFromProduct('Gadget_Item_ManaEye.{product}'));
										SetModelScale(GetHeroPreviewScaleFromProduct('Gadget_Item_ManaEye.{product}'));
									"
									scenebuffer="true"
								/>
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#eedcb4" name="altAvatarPreviewPanel{id}_mc_rev" onevent0="SleepWidget(350, 'FadeOut(250);');" onevent1="FadeIn(250);"/>
								<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
								<panel width="3h" height="3h" x="-0.25h" y="-0.25h">
									<image texture="/items/basic/mana_eye/icon.tga"/>
									<frame color="invisible" bordercolor="#0B0B0B" borderthickness="1"/>
								</panel>
							</panel>

							<panel width="13h" height="2.5h" valign="bottom">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#9d5b1a66" />
								<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
								<slider
									name="altAvatarPreviewRotate_{id}"
									slotwidth="-1%" slotheight="0.6h"
									slotcolor="1 1 1 1"
									handlewidth="85@" handleheight="85%"
									handlecolor="1 1 1 1"
									cvar="altAvatarPreviewRotation_{id}"
									minvalue="-179" maxvalue="179"
									step="1"
									texture="/ui/fe2/store/slider2.tga"
									facecamera="false"
									onselect=""
									onchange="Call('altAvatarPreviewPanel{id}_model', 'RotateModel(\'0 0 ' # *(name) # '\');');"
								/>
							</panel>
							<panel width="13h" x="13.5h" height="2.5h" valign="bottom">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" color="#9d5b1a66" />
								<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="1h"/>
								<slider
									name="altAvatarPreviewRotate_{id}_rev"
									slotwidth="-1%" slotheight="0.6h"
									slotcolor="1 1 1 1"
									handlewidth="85@" handleheight="85%"
									handlecolor="1 1 1 1"
									cvar="altAvatarPreviewRotation_{id}_rev"
									minvalue="-179" maxvalue="179"
									step="1"
									texture="/ui/fe2/store/slider2.tga"
									facecamera="false"
									onselect=""
									onchange="Call('altAvatarPreviewPanel{id}_model_rev', 'RotateModel(\'0 0 ' # *(name) # '\');');"
								/>
							</panel>
						</panel>

						<panel grow="true" width="100%">
							<panel align="right" width="-0.5h" valign="bottom" grow="true" float="bottom" padding="0.25h">
								<panel height="3h">
									<panel width="12.5h">
										<label textalign="center" textvalign="center" style="microStorePaperTitle" font="dyn_10" content="mstore_purchased"/>
										<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_purchase" visible="false"
											onclick="
												CallEvent('altAvatarPreviewPanel{id}', 1);
												Trigger('MicroStoreUpdateSelection');
												If(
													## *('microStorePremium' # _microStore_SelectedItem) and ## *('microStoreSilverPrice' # _microStore_SelectedItem) gt 0,
													CallEvent('store_popup_confirm_purchase_choose', 0),
													CallEvent('store_popup_confirm_purchase_choose', 0)
												);
											"
										watch="loadAltAvatarPreview" ontrigger="
											If(
												{id} == param0,
												SetVisible(
													!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
													( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
												)
											);
										"/>
										<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_needcoins" visible="false" onclick="CallEvent('altAvatarPreviewPanel{id}', 1); Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"
										watch="loadAltAvatarPreview" ontrigger="
											If(
												{id} == param0,
												SetVisible(
													!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
													!( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
												)
											);
										"
										/>
									</panel>
									<panel width="-13h" align="right">
										<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
										<panel width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
										<panel align="right" width="-110@">
											<label style="microStorePaperCost" font="dyn_11" watch="loadAltAvatarPreview" textalign="center" textvalign="center" ontrigger="If({id} == param0, SetText(FtoA(*('microStorePrice' # _microStore_SelectedItem), 0, 0, ',')));" watch1="MicroStoreAvatarItem" ontrigger1="If(param2 == {id=0}, SetText(FtoA(param4, 0, 0, ',')));" />
										</panel>
									</panel>
								</panel>
							</panel>
						</panel>
					</panel>
					<panel height="4h" width="100%"/><!-- Spacer -->
				</panel>
			</panel>
		</panel>
	</template>


</package>
