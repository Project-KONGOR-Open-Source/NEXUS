	<template name="storeBundlePreviewItem">
		<panel>
			<panel height="-0.25h" valign="center">
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#eedcb4" borderthickness="0.5h"/>
				<panel width="-0.25h" height="-0.25h" align="center" valign="center">
					<panel height="90%" width="90@" valign="center" x="5@">
						<panel color="0 0 0 0.5" x="1" y="1"/>
						<image texture="{iconpath}" resourcecontext="store"

							onmouseover="
								if(
									{product_id} != 228,
									Split(
										Trigger(
											'StoreImagePreviewInit',
											GetWidth(),
											GetHeight(),
											GetAbsoluteX(),
											GetAbsoluteY(),
											false,
											GetTexture()
										),
										Trigger('StoreImagePreviewVis', true, '250%')
									)
								);

							"
							onmouseout="
								DoEvent(1);

							"
							onhide="
								DoEvent(1);
							"
							onevent1="
								Trigger('StoreImagePreviewVis', false, '100%');
							"

						/>
						<frame color="invisible" bordercolor="#FFCC00" borderthickness="1" noclick="true" />
					</panel>
					<label x="110@" style="microStorePaperTitle" font="dyn_10" textvalign="center" content="mstore_product{product_id}_name" noclick="true"/>
					<label x="-10@" style="microStorePaperCost" font="dyn_10" textvalign="center" textalign="right" content="{cost}" noclick="true"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storePopupBundlePreview">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<panel regrow="true" grow="true" width="100%">
				<label align="right" width="-3.5h" wrap="true" fity="true" textvalign="center" font="dyn_10" style="microStorePaperText" content="" watch="MicroStoreBundlePreview" ontrigger="SetText(Translate('mstore_product' # *('microStoreID' # _microStore_SelectedItem) # '_desc'));"/>
				<panel>
					<panel width="3h" height="3h" valign="center">
						<panel x="1" y="1" color="0 0 0 0.5"/>
						<image name="storeBundlePreviewIcon"
							resourcecontext="store"
							onevent="
								If(
									!StringEquals(*('microStoreLocalContent' # _microStore_SelectedItem), '-1'),
									SetTexture(*('microStoreLocalContent' # _microStore_SelectedItem)),
									If(
										!StringEquals(*('microStoreWebContent' # _microStore_SelectedItem), '-1'),
										SetTextureURL(*('microStoreWebContent' # _microStore_SelectedItem)),
										SetTexture('/ui/legion/ability_coverup.tga')
									)
								);
							"
						/>
						<frame color="invisible" bordercolor="#FFCC00" borderthickness="1" noclick="true" />
					</panel>
				</panel>
			</panel>

			<panel height="12.5h" width="100%">
				<panel width="-2h">

					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="1h" style="microStorePaperText"/>
					<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="1h"/>

					<panel float="bottom"
						height="-0.25h"
						width="-0.75h"
						valign="center"
						x="0.25h"
					>
						<panel height="3h">
							<panel height="-0.25h" valign="center">
								<frame texture="/ui/frames/rounded_bg_white.tga" color="#48230f" borderthickness="0.5h"/>
							</panel>
						</panel>
						<panel height="3h">
							<panel height="-0.25h" valign="center">
								<frame texture="/ui/frames/rounded_bg_white.tga" color="#48230f" borderthickness="0.5h"/>
							</panel>
						</panel>
						<panel height="3h">
							<panel height="-0.25h" valign="center">
								<frame texture="/ui/frames/rounded_bg_white.tga" color="#48230f" borderthickness="0.5h"/>
							</panel>
						</panel>
						<panel height="3h">
							<panel height="-0.25h" valign="center">
								<frame texture="/ui/frames/rounded_bg_white.tga" color="#48230f" borderthickness="0.5h"/>
							</panel>
						</panel>
					</panel>
					<listbox
						align="left"
						x="0.25h"
						valign="center"
						height="-0.25h"
						width="-0.75h"
						color="invisible"
						watch0="MicroStoreBundlePreview"
						ontrigger0="
							ClearItems();
							Set('_bundleFullPriceInt', 0);
							ExplodeTrigger('MicroStoreBundleItem', _microStore_bundleContents, '|', ':');
							CallEvent('mstore_bundlePreview_costDiff');
							CallEvent('storeBundlePreviewIcon');
						"
						watch1="MicroStoreBundleItem"
						ontrigger1="
							AddTemplateListItem('storeBundlePreviewItem', param1, 'code', param2, 'cost', param3, 'iconpath', param4, 'product_id', param1);
							Set('_bundleFullPriceInt', _bundleFullPriceInt + param3);
						"
						itemheight="3h"
						exteriorscrollbars="true"
						scrollbarsize="2.0h"
						scrollbaroffset="0.75h"
						scrolltexture="/ui/info/combobox.tga"
						handleheight="2.0h"
						select="false" hoverselect="false"
					/>
				</panel>

			</panel>
			<panel height="3h">
				<panel width="11.5h">
					<label textalign="center" textvalign="center" style="microStorePaperTitle" font="dyn_10" content="mstore_purchased"/>
					<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_purchase" visible="false"
						onclick="
							CallEvent('store_popup_bundle_preview', 1);
							Trigger('MicroStoreUpdateSelection');
							If(
								## *('microStorePremium' # _microStore_SelectedItem) and ## *('microStoreSilverPrice' # _microStore_SelectedItem) gt 0,
								CallEvent('store_popup_confirm_purchase_choose', 0),
								CallEvent('store_popup_confirm_purchase_choose', 0)
							);
						"
					watch="MicroStoreBundlePreview" ontrigger="
						SetVisible(
							!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
							( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
						);
					"/>
					<instance name="storeButton" align="center" valign="center" font="dyn_12" label="mstore_needcoins" visible="false" onclick="CallEvent('store_popup_bundle_preview', 1); Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0);"
					watch="MicroStoreBundlePreview" ontrigger="
						SetVisible(
							!( *('microStoreAlreadyOwned' # _microStore_SelectedItem) ) and
							!( (*('microStorePrice' # _microStore_SelectedItem) le _microStore_TotalCoins + _microStore_TotalSilverCoins and !*('microStorePremium' # _microStore_SelectedItem)) or (*('microStorePremium' # _microStore_SelectedItem) and ((*('microStoreSilverPrice' # _microStore_SelectedItem) gt 0 and _microStore_TotalSilverCoins ge *('microStoreSilverPrice' # _microStore_SelectedItem)) or _microStore_TotalCoins ge *('microStorePrice' # _microStore_SelectedItem))) )
						);
					"
					/>
				</panel>
				<panel width="-12h" align="right">
					<frame texture="/ui/frames/roundframe.tga" color="#9d5b1a" borderthickness="0.5h"/>
					<panel width="100@" height="100%" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/gold_coins.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures"/>
					<panel align="right" width="-110@">
						<label style="microStorePaperCost" noclick="true" font="dyn_11" watch="MicroStoreBundlePreview" textvalign="center" ontrigger="SetText(FtoA(*('microStorePrice' # _microStore_SelectedItem), 0, 0, ','));"/>
						<label style="microStorePaperItem" noclick="true" x="-0.5h" font="dyn_11" textalign="right" textvalign="center" name="mstore_bundlePreview_costDiff" onevent="SetText(Translate('mstore_bundle_yousave', 'costdifference', FtoA(Ceil(_bundleFullPriceInt - *('microStorePrice' # _microStore_SelectedItem)), 0, 0, ',')));"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="storeVoicePreviewItem">
		<panel>
			<panel height="-0.25h" valign="center">
				<frame texture="/ui/frames/rounded_bg_white.tga" color="#eedcb4" borderthickness="0.5h"/>
				<panel width="-0.25h" height="-0.25h" align="center" valign="center">
					<label style="microStorePaperTitle" font="dyn_10" textvalign="center" content="announcement_{model}" noclick="true"/>
					<instance name="magnifierButton" align="right" valign="center" x="-10@" width="90@" height="90%"
						onclick="
							PlaySound('/shared/sounds/announcer/{sound_set}/{sound}.wav', 1.0, 1);
							Trigger('PreviewAnnouncerText', '{model_set}/{model}');
						"
					/>
				</panel>
			</panel>
		</panel>
	</template>

