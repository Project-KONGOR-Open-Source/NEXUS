	</template>

	<template name="storePopupBuyItemSuccess">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_10" style="microStorePaperText" content="mstore_buyitem_success_body"
				watch="MicroStoreResults"
				ontrigger="
					SetText(
						Translate(
							If(
								_microStore_Category == 3 or
								_microStore_Category == 4 or
								_microStore_Category == 5 or
								_microStore_Category == 6 or
								_microStore_Category == 16 or
								_microStore_Category == 27 or
								_microStore_Category == 59 or
								_microStore_Category == 60 or
								_microStore_Category == 61,
								'mstore_buyitem_success_body_vault',
								'mstore_buyitem_success_body'
							)
						)
					);

				"
			/>
			<panel grow="true" width="100%" regrow="true">
				<panel float="right" padding="0.5h" align="center" grow="true" height="3h" regrow="true" growinvis="false">
					<instance name="storeButton" buttonName="store_button_purchase_success_confirm" width="8h" label="general_ok" onclick="CallEvent('store_popup_buy_item_success', 1);"/>
					<instance name="storeButton" tip_id="mstore_tip_open_vault" label="mstore_openvault" watch="MicroStoreProcessing" ontrigger="SetEnabled(!param0);" visible="false"
						watch1="MicroStoreResults"
						ontrigger1="
							SetVisible(
								_microStore_Category == 3 or
								_microStore_Category == 4 or
								_microStore_Category == 5 or
								_microStore_Category == 6 or
								_microStore_Category == 16 or
								_microStore_Category == 27 or
								_microStore_Category == 59 or
								_microStore_Category == 60 or
								_microStore_Category == 61
							);
						"
						onclick="
							If(
								_microStore_Category == 1 or _microStore_Category == 7,
								Set('_microStore_Category', 2)
							);
							Set('_microStore_currentPage', 1);
							Trigger('ShopkeeperAction', 18);
							Set('_microStore_RequestCode', 2);
							CallEvent('MicroStoreAction', 0);
							CallEvent('store_popup_buy_item_success', 1);"
							width="12h"
					/>
				</panel>

			</panel>
		</panel>
	</template>

	<template name="storePopupResetStatsSuccess">
		<panel width="100%" grow="true" float="bottom" padding="1h" regrow="true">
			<label align="right" wrap="true" fity="true" textalign="center" textvalign="center" font="dyn_10" style="microStorePaperText" content="web_form_resetstats_success"/>
			<panel grow="true" width="100%" regrow="true">
				<instance name="storeButton" width="8h" height="3h" label="general_ok" align="center" onclick="CallEvent('store_popup_reset_stats', 1); CallEvent('store_popup_resetstats_success', 1);"/>
			</panel>
		</panel>
	</template>

	<template name="storePopupSubAccountSuccess">
