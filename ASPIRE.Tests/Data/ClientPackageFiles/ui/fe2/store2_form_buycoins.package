							<image ontrigger9lua="ResourceManager.RegisterTexture(GetCvarString('ui_useRegionalCurrencyIcon'), 'store', self)" watch7="MicroStoreUpdateCoins" ontrigger7="SetTexture(ui_useRegionalCurrencyIcon);" resourcecontext="store" watch9="MainRegisterTextures"/>
						</panel>
						<label name="store_form_buy_regcur_info" visible="1" content="-" x="-1.0h" width="-7.0h" height="100%" align="right" valign="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" style="microStorePaperTitle" noclick="1"/>
					</panel>
				</panel>
