<?xml version="1.0" encoding="UTF-8"?>
<package>

	<trigger name="CoinsFriendNameStatus"/>
	<trigger name="CoinsFriendNameResult"/>
	<if condition="cl_garenaEnable">
		<form
			name="CoinsFriendName"
			host="!hon"
			target="/signup/garena_store_nick_check.php"
			statustrigger="CoinsFriendNameStatus"
			resulttrigger="CoinsFriendNameResult"
			resultparam0="responseCode"
		/>
	</if>

	<if condition="!cl_garenaEnable">
		<form
			name="CoinsFriendName"
			host="!hon"
			target="/signup/nick_exists_check.php"
			statustrigger="CoinsFriendNameStatus"
			resulttrigger="CoinsFriendNameResult"
			resultparam0="responseCode"
		/>
	</if>

	<template name="storePopupBuyCoinsForm">
		<panel name="storePopupBuyCoinsForm_cover" width="100%" height="100%" color="invisible" visible="0">
			<image height="75%" width="75@" color="1 1 1 0.25" valign="bottom"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/full_chest.tga', 'store', self)"
				resourcecontext="store" watch9="MainRegisterTextures"
			/>

			<image height="80%" width="80@" color="1 1 1 0.25" valign="bottom" align="right" x="-5%" y="-12%"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/money_bag.tga', 'store', self)"
				resourcecontext="store" watch9="MainRegisterTextures"
			/>

			<image height="90%" width="45@" color="1 1 1 0.25" valign="bottom" align="right"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coinstack_large.tga', 'store', self)"
				resourcecontext="store" watch9="MainRegisterTextures"
			/>
			<image height="45%" width="45@" color="1 1 1 0.25" valign="bottom" align="right" x="-12%"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coinstack_med.tga', 'store', self)"
				resourcecontext="store" watch9="MainRegisterTextures"
			/>
			<image height="45%" width="45@" color="1 1 1 0.25" valign="bottom" align="right" x="-24%" y="5%"
				ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/coinstack_sml.tga', 'store', self)"
				resourcecontext="store" watch9="MainRegisterTextures"
			/>

			<label name="storePopupBuyCoinsForm_cover_text" width="75%" align="center" wrap="1" style="microStorePaperText" font="dyn_18" textvalign="center" textalign="center" noclick="1"/>
		</panel>

		<panel name="storePopupBuyCoinsForm_web" width="100%" height="100%" visible="0" onshowlua="UIManager.GetInterface('main'):HoNRegionF('OpenGoldCoinsWebpage')"/>

		<panel name="storePopupBuyCoinsForm_main" width="100%" grow="1" regrow="1" growinvis="0" float="bottom" padding="1h" visible="0" noclick="1">
			<panel width="100%" grow="1" regrow="1" growinvis="0" noclick="1">
				<label name="store_form_buycoins_blurb_label" wrap="1" fity="1" textvalign="center" font="dyn_12" color="#d3bbac" content="mstore_buycoins_form_blurb" noclick="1"/>
			</panel>

			<panel width="100%" height="0.5h" noclick="1">
				<panel width="-.5h" valign="center" align="center" height="1" color="#423330" noclick="1"/>
			</panel>

			<panel width="100%" grow="1" regrow="1" growinvis="0" noclick="1">
				<panel width="57%" align="left" grow="1" regrow="1" growinvis="0" float="bottom" padding="1.5h" noclick="1">
					<!-- Point Package Buttons -->
					<panel height="25h" width="100%" float="right" padding="0.5h" noclick="1"
						onload="Set('_microStore_buyCoins_package', 0);"
						watch9="UIUpdateRegion"
						ontrigger9="DoEvent(9);"
						onevent9lua="
							groupfcall('store_buycoins_radiobuttons_group', function(index, widget, groupName) widget:Destroy() end)
							UIManager.GetInterface('main'):HoNRegionF('PopulatePointPackageButtons', self)
							"
						watch8="MicroStoreUpdatePackages"
						ontrigger8lua="UIManager.GetInterface('main'):HoNStoreF('UpdateCoinPackageLabels')"
					/>
					<!-- PayPal Notice -->
					<panel name="store_form_buycoins_paypal_label" height="6h" visible="1" stickytoinvis="0" noclick="1">
						<instance name="store2_frame"/>
						<panel height="5h" valign="center" align="center" width="-1h" noclick="1">
							<image x="0.5h" y=".5h" width="6h" height="6h" texture="/ui/elements/paypal_icon.tga"/>
							<label width="-7h" x="7h" valign="center" textvalign="center" wrap="1" font="dyn_10" style="microStorePaperTitle" content="web_form_paypal_notice" noclick="1"/>
						</panel>
					</panel>
				</panel>

				<panel width="42%" align="right" grow="1" regrow="1" growinvis="0" float="bottom" padding="0.75h" reverse="1">
					<panel width="100%" height="2.5h" onload="CreateString('buy_coins_friendnick', ''); CreateBool('buy_coins_friendnick_valid', false);">
						<instance name="paperForm_combobox_container" hastip="false" label="mstore_purchasefor" form="" id="buy_coins_forfriend" updatetrigger="UpdatePurchaseCoinsForm" fieldwidth="25%" labelwidth="30%"
							fieldname="store_buycoins_purchasefor_combobox"
							populate="
								AddTemplateListItem('paperform_combobox_item', '1', 'label', 'mstore_myself');
								If(ui_canBuyCoinsForFriend, AddTemplateListItem('paperform_combobox_item', '2', 'label', 'mstore_afriend'));
							"
							ontrigger="
								If(
									((StringEmpty(buy_coins_friendnick) and buy_coins_forfriend == 1) or (!StringEmpty(buy_coins_friendnick) and buy_coins_friendnick_valid) ),
									DoEvent(1), DoEvent(0)
								);
							"
						/>
						<label x="61%" style="microStorePaperText" font="dyn_10" textvalign="center" watch1="AccountInfo" ontrigger1="SetText(StripClanTag(GetAccountName()));" watch2="UpdatePurchaseCoinsForm" ontrigger2="SetVisible(buy_coins_forfriend == 1);" noclick="1"/>
						<panel x="0.5h" align="right" width="2.5h" noclick="1">
							<instance name="store2_tip_mark" tip_id="mstore_tip_buycoins_self" x="0.1h"/>
						</panel>
						<panel visible="0" noclick="1"
							watch="CoinsFriendNameResult"
							ontrigger="
								If(
									param0 == 0,
									Set('buy_coins_friendnick_valid', true)
								);
								Trigger('UpdatePurchaseCoinsForm');
							"
							watch1="UpdatePurchaseCoinsForm"
							ontrigger1="
								If(
									buy_coins_forfriend == 1,
									Split(
										Set('buy_coins_friendnick_valid', false),
										Set('buy_coins_friendnick', '')
									)
								);
								SetVisible(buy_coins_forfriend == 2);
							"
						>
							<panel y="-2.75h" x="57%" width="45%" height="2.5h" noclick="1"
								onevent0="SleepWidget(3000, 'If(buy_coins_friendnick_valid, FadeOut(3000));');"
								watch="CoinsFriendNameResult"
								ontrigger="SetVisible(1); If(param0 == 0, DoEvent(0));"
								watch1="UpdatePurchaseCoinsForm"
								ontrigger1="If(StringEmpty(buy_coins_friendnick_textbox) or buy_coins_forfriend == 1, SetVisible(0));"
							>
								<panel width="100%" grow="1" regrow="1" growinvis="1" valign="bottom">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#FFEBBE"/>
									<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="0.5h"/>
									<panel width="-1h" grow="1" regrow="1" growinvis="1" align="center" float="bottom">
										<panel width="100%" height="0.5h"/>
										<label textvalign="bottom" style="microStorePaperTitle" wrap="1" font="dyn_10" valign="bottom" fity="1" watch="CoinsFriendNameResult" ontrigger="SetText(Translate('nickname_exists_response' # param0)); If(param0 == 0, SetColor('0 0.5 0 1'), SetColor('0.6 0 0 1'));"/>
										<panel width="100%" height="0.5h"/>
									</panel>
								</panel>
							</panel>
							<instance
								name="paperForm_textbox_container"
								label=""
								hastip="false"
								order="138"
								width="100%"
								fieldwidth="26%"
								labelwidth="56%"
								showarrow="false"
								fieldname="buy_coins_friendnick_textbox"
								tip_id=""
								form="" data=""
								updatetrigger="UpdatePurchaseCoinsForm"
								textboxwatch="UpdatePurchaseCoinsForm"
								textboxontrigger="If(!StringEquals(buy_coins_friendnick, *(name)), EraseInputLine());"
								onesc="Trigger('ChatAutoCompleteClear');"
								onfocuslua="
									Set('buycoins_friend_auto', true)
									local wdgList = GetWidget('store2_autocomplete_buycoins_friend_listbox')
									if wdgList then
										wdgList:RegisterWatch('ChatAutoCompleteAdd', function(wdg, name) wdg:AddTemplateListItem('autocomplete_player', name, 'username', name) end)
										wdgList:RegisterWatch('ChatAutoCompleteClear', function(wdg) wdg:ClearItems() end)
									end
								"
								onlosefocuslua="
									Set('buycoins_friend_auto', false)
									local wdgList = GetWidget('store2_autocomplete_buycoins_friend_listbox')
									if wdgList then
										wdgList:UnregisterWatch('ChatAutoCompleteAdd')
										wdgList:UnregisterWatch('ChatAutoCompleteClear')
									end
								"
								onchange="
									CreateString('ui_autocompleteTextBox', name); ChatAutoCompleteNick(this);
									Set('buy_coins_friendnick_valid', false);
									Set('buy_coins_friendnick', *(name));
									If(
										!StringEmpty(buy_coins_friendnick),
										Split(
											HideWidget('CoinsFriendNameValid'),
											HideWidget('CoinsFriendNameInvalid'),
											ShowWidget('CoinsFriendNameThrob'),
											If(
												cl_garenaEnable,
												SleepWidget(250, 'SubmitForm(\'CoinsFriendName\', \'request_code\', \'nickname_exists\', \'nickname\', buy_coins_friendnick);'),
												SleepWidget(250, 'SubmitForm(\'CoinsFriendName\', \'nickname\', buy_coins_friendnick);')
											)
										),
										Split(
											HideWidget('CoinsFriendNameValid'),
											HideWidget('CoinsFriendNameInvalid'),
											HideWidget('CoinsFriendNameThrob')
										)
									);
								"
								onload="CreateBool('buycoins_friend_auto', false);"
							/>
							<panel width="29%" height="30.0h" y="2.25h" x="55%" visible="0" color="invisible" watch="ChatAutoCompleteClear" ontrigger="SetVisible(false);" watch2="ChatAutoCompleteAdd" ontrigger2="if(buycoins_friend_auto, SetVisible(true));">
								<instance name="store2_autocomplete_list" listbox_name="autocomplete_buycoins_friend" y="0.5h" x="0.5h" width="18.0h" height="12.5h" align="left" valign="top"/>
							</panel>
							<panel width="2.5h" height="2.5h" align="right" x="-2.5h">
								<animatedimage name="CoinsFriendNameThrob" texture="/ui/elements/throb/throb.tga" noclick="1" loop="1" fps="30" onshow="StartAnim(1);" visible="0" watch="CoinsFriendNameStatus" ontrigger="SetVisible(param == 1);"/>
								<image name="CoinsFriendNameValid" texture="/ui/elements/check_mark.tga" color="0 0.6 0 1" align="center" valign="center" width="-25%" height="-25%" visible="false" watch="CoinsFriendNameResult" ontrigger="SetVisible(param0 == 0);"/>
								<image name="CoinsFriendNameInvalid" ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/store/closex2.tga', 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" color="0.6 0 0 1" align="center" valign="center" width="-30%" height="-30%" visible="0" watch="CoinsFriendNameResult" ontrigger="SetVisible(param0 != 0);"/>
							</panel>
							<panel width="2.4h" x="0.25h" align="right" height="100%" valign="center">
								<instance name="store2_tip_mark" tip_id="mstore_tip_buycoins_other"/>
							</panel>
						</panel>
					</panel>

					<panel name="store_form_buycoins_cc_input" visible="1" noclick="1" float="bottom" padding="0.5h" reverse="1" stickytoinvis="0">
						<!-- First Name -->
						<instance
							name="paperForm_textbox_container"
							label="creditcard_label_first_name"
							hastip="true"
							order="139"
							width="100%"
							labelwidth="30%"
							fieldwidth="60%"
							fieldname="buy_coins_ccfirstname"
							ontrigger="If(StringEmpty(buy_coins_ccfirstname), DoEvent(0), DoEvent(1));"
							tip_id="web_form_tip_cc_first_name"
							form="" data="bill_first_name"
							updatetrigger="UpdatePurchaseCoinsForm"
							onfocus="Trigger('ChatAutoCompleteClear');"
							onhide="EraseInputLine();"
						/>

						<!-- Last Name -->
						<instance
							name="paperForm_textbox_container"
							label="creditcard_label_last_name"
							hastip="true"
							order="140"
							width="100%"
							labelwidth="30%"
							fieldwidth="60%"
							fieldname="buy_coins_cclastname"
							ontrigger="If(StringEmpty(buy_coins_cclastname), DoEvent(0), DoEvent(1));"
							tip_id="web_form_tip_cc_last_name"
							form="" data="bill_last_name"
							updatetrigger="UpdatePurchaseCoinsForm"
							onfocus="Trigger('ChatAutoCompleteClear');"
							onhide="EraseInputLine();"
						/>

						<!-- Zip Code -->
						<instance
							name="paperForm_textbox_container"
							label="creditcard_label_billing_zip"
							hastip="true"
							order="141"
							width="100%"
							labelwidth="30%"
							fieldwidth="60%"
							fieldname="buy_coins_cczip"
							ontrigger="If(StringEmpty(buy_coins_cczip), DoEvent(0), DoEvent(1));"
							tip_id="web_form_tip_cc_zip"
							form="" data="zip"
							updatetrigger="UpdatePurchaseCoinsForm"
							onfocus="Trigger('ChatAutoCompleteClear');"
							onhide="EraseInputLine();"
						/>

						<!-- CC Number -->
						<instance
							name="paperForm_textbox_container"
							width="100%"
							valign="top"
							label="web_form_ccnum_short"
							hastip="false"
							order="142"
							labelwidth="30%"
							fieldwidth="60%"
							fieldname="buy_coins_ccnum"
							ontrigger="If(!IsValidCCNumber(buy_coins_ccnum), DoEvent(0), DoEvent(1));"
							tip_id="web_form_tip_cc_num"
							form="" data="card_number"
							updatetrigger="UpdatePurchaseCoinsForm"
							onfocus="Trigger('ChatAutoCompleteClear');"
							onhide="EraseInputLine();"
						/>

						<!-- Exp Date -->
						<instance
							name="paperForm_expdate_container"
							width="100%"
							valign="top"
							label="creditcard_label_prime_expiration"
							hastip="false"
							labelwidth="30%"
							fieldwidth="60%"
							varprefix="buy_coins"
							order="143"
							fieldname="buy_coins_expdate"
							ontrigger="
								If(
									(
									buy_coins_ccmonth lt 1 or
									buy_coins_ccmonth gt 12 or
									buy_coins_ccyear lt GetYear() or
									(buy_coins_ccyear == GetYear() and buy_coins_ccmonth lt GetMonth())
									),
									DoEvent(0),
									DoEvent(1)
								);
							"
							tip_id="web_form_tip_cc_num"
							form="" data="card_number"
							updatetrigger="UpdatePurchaseCoinsForm"
						/>

						<!-- CVV2 -->
						<panel height="2.5h">
							<instance
								name="paperForm_textbox_container"
								label="creditcard_label_prime_cvv_number"
								hastip="true"
								order="144"
								labelwidth="30%"
								fieldwidth="60%"
								width="100%"
								fieldname="buy_coins_cccvv"
								ontrigger="If(StringLength(buy_coins_cccvv) lt 3 or !StringContainsOnly(buy_coins_cccvv, '', '0'),
									DoEvent(0),
									DoEvent(1)
								);"
								tip_id="web_form_tip_cc_cvv2"
								form="" data="cvv"
								updatetrigger="UpdatePurchaseCoinsForm"
								onfocus="Trigger('ChatAutoCompleteClear'); ShowWidget('buy_coins_cccvv_img');" onlosefocus="HideWidget('buy_coins_cccvv_img');"
								onkeydown="HideWidget('buy_coins_cccvv_img');"
								onhide="EraseInputLine();"
							/>
							<panel name="buy_coins_cccvv_img" width="21.3h" height="10.65h" x="2.6h" y="2.75h" align="right" visible="0" noclick="1">
								<image texture="/ui/elements/cvv.tga" noclick="1"/>
							</panel>
						</panel>
					</panel>

					<!-- Buy/Cancel Buttons -->
					<panel width="100%" height="4.25h">
						<panel grow="1" regrow="1" growinvis="0" valign="center" float="right" padding="1h" height="3.5h">
							<panel height="100%" grow="1" regrow="1" growinvis="0" float="right" padding="0.5h">
								<panel name="store_form_buycoins_regional_currency_display" visible="0" width="16h" height="100%" noclick="1" stickytoinvis="0">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#FFEBBE"/>
									<frame texture="/ui/frames/roundframe.tga" style="microStorePaperText" borderthickness="0.5h"/>

									<panel hmargin="0.4h" vmargin="0.4h" noclick="1">
										<panel width="100@" height="100%" noclick="1">
											<image ontrigger9lua="ResourceManager.RegisterTexture(GetCvarString('ui_useRegionalCurrencyIcon'), 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" watch7="MicroStoreUpdateCoins" ontrigger7="SetTexture(ui_useRegionalCurrencyIcon);" x="0.1h" y="0.1h" color="0 0 0 0.5" noclick="1"/>
											<image ontrigger9lua="ResourceManager.RegisterTexture(GetCvarString('ui_useRegionalCurrencyIcon'), 'store', self)" resourcecontext="store" watch9="MainRegisterTextures" watch7="MicroStoreUpdateCoins" ontrigger7="SetTexture(ui_useRegionalCurrencyIcon);" noclick="1"/>
										</panel>
										<label width="-110@" height="100%" align="right" noclick="1" font="dyn_16" style="microStorePaperTitle" textalign="right" textvalign="center" content="-" watch="MicroStoreUpdateCoins" ontrigger="If(ui_useRegionalCurrency and (_microStore_RequestCode == 0 or _microStore_RequestCode == 5), SetText(Ceil(_microStore_regionalBalance)));"/>
									</panel>
								</panel>

								<panel width="21h" height="100%" noclick="1">
									<panel name="store_form_buycoins_regcur_submit" width="20h" align="center" visible="0" noclick="1">
										<instance name="store2Button" enabled="0" texture="button2" width="20h" height="3.5h"
											align="center" valign="center"
											color="#e9f2f6" outlinecolor="#2f7182"
											label="mstore_buycoins_submit_purchase"
											onclick="Set('_microStore_RequestCode', 3); CallEvent('MicroStoreAction', 0);"
											tip_id="mstore_tip_buycoins_submit"
											watch="UpdatePurchaseCoinsForm"
											ontrigger="DoEvent();"
											watch1="MicroStoreProcessing"
											ontrigger1="DoEvent();"
											onshow="DoEvent();"
											onevent="
												If(
													!_microStore_processing and
													_microStore_buyCoins_package ge 1 and _microStore_buyCoins_package le 5 and
													((StringEmpty(buy_coins_friendnick) and buy_coins_forfriend == 1) or (!StringEmpty(buy_coins_friendnick) and buy_coins_friendnick_valid)) and
													*('microStorePackagePrice' # _microStore_buyCoins_package) le _microStore_regionalBalance
													,
													SetEnabled(true),
													SetEnabled(false)
												);
											"
											oneventlua="
												local package = GetCvarInt('_microStore_buyCoins_package')
												self:SetLabel(Translate(package == 0 and 'mstore_buycoins_select_package' or 'mstore_buycoins_submit_purchase'))
											"
										/>
									</panel>

									<panel name="store_form_buycoins_normal_submit" width="20h" align="center" visible="1" noclick="1">
										<instance name="store2Button" enabled="0" texture="button2" width="20h" height="3.5h"
											align="center" valign="center"
											color="#e9f2f6" outlinecolor="#2f7182"
											label="mstore_buycoins_select_package"
											onclick="Set('_microStore_RequestCode', 3); CallEvent('MicroStoreAction', 0);"
											buttonName="mstore_purchase_coins_submit_btn"
											tip_id="mstore_tip_buycoins_submit"
											watch="UpdatePurchaseCoinsForm"
											ontrigger="DoEvent();"
											watch1="MicroStoreProcessing"
											ontrigger1="DoEvent();"
											onshow="DoEvent();"
											onevent="
												If(
													!_microStore_processing and
													!StringEmpty(buy_coins_ccfirstname) and
													!StringEmpty(buy_coins_cclastname) and
													!StringEmpty(buy_coins_cczip) and
													IsValidCCNumber(buy_coins_ccnum) and
													!(
													buy_coins_ccmonth lt 1 or
													buy_coins_ccmonth gt 12 or
													buy_coins_ccyear lt GetYear() or
													(buy_coins_ccyear == GetYear() and buy_coins_ccmonth lt GetMonth())
													) and
													!(StringLength(buy_coins_cccvv) lt 3 or !StringContainsOnly(buy_coins_cccvv, '', '0')) and
													_microStore_buyCoins_package ge 1 and _microStore_buyCoins_package le 5 and
													((StringEmpty(buy_coins_friendnick) and buy_coins_forfriend == 1) or (!StringEmpty(buy_coins_friendnick) and buy_coins_friendnick_valid))
													,
													SetEnabled(true),
													SetEnabled(false)
												);
											"
											oneventlua="
												local package = GetCvarInt('_microStore_buyCoins_package')
												self:SetLabel(Translate(package == 0 and 'mstore_buycoins_select_package' or 'mstore_buycoins_submit_purchase'))
											"
										/>
									</panel>

									<panel width="20h" align="center" watch="MicroStoreProcessing" ontriggerlua="if (AtoB(param)) then self:SetVisible(true) else self:FadeOut(350) end"
									>
										<panel color="0 0 0 0.5">
											<frame color="invisible" bordercolor="0.75 0.5 0 0.5" borderthickness="0.15h" noclick="1"/>
											<label color="white" shadow="1" font="dyn_12" textvalign="center" textalign="center" width="-3h" content="mstore_processing_elipses"/>
											<animatedimage texture="/ui/elements/throb/throb.tga" noclick="1" loop="1" fps="30" onshow="StartAnim(1);" align="right" width="3h" height="3h" valign="center" x="-0.25h"/>
										</panel>
									</panel>
								</panel>
							</panel>
						</panel>
					</panel>

					<!-- Secure Info -->
					<panel width="100%" height="6h" noclick="1">
						<instance name="store2_frame"/>
						<image width="4.5h" height="4.5h" x="1.0h" valign="center" texture="/ui/elements/thawte.tga" noclick="1"/>
						<label x="6h" width="-6.0h" valign="center" textvalign="center" wrap="1" font="dyn_10" style="microStorePaperTitle" content="web_form_secure_transfer_generic" noclick="1"/>
					</panel>

					<!-- Garena Shell Info -->
					<panel name="store_form_buycoins_regcur_shellinfo" visible="0" stickytoinvis="0" width="100%" height="6h" noclick="1">
						<instance name="store2_frame"/>
						<panel width="4.5h" height="4.5h" x="1.0h" valign="center" noclick="1">
