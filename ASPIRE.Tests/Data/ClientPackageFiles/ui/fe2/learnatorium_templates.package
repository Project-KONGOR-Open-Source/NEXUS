	<template name="herodex_ability_box">
		<panel
			name="{id}"
			width="100%" height="{height=18.4h}"
			passivechildren="0"
			noclick="1"
		>
				
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="{boxBG=0 0 0 .55}"  noclick="1"/>
			<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#434d50"  noclick="1" />
			
			<panel grow="true" regrow="true" growinvis="false" y="0.8h" width="-1.2h" align="center" float="bottom" padding="0.4h"  noclick="1">
			
				<panel width="100%" height="3.6h"  noclick="1">			
					<panel float="right" sticky="true" stickytoinvisible="false" padding="0.5h" noclick="1">
						
						<!-- Icon -->
						<panel width="100@" height="100%">
							<image texture="$checker" watch="HeroSelectHeroAbilityInfo{index}" ontrigger="SetVisible(param0); SetTexture(param1);" />
							<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1"/>
						</panel>
						
						<!-- Name -->
						<panel width="-120@" height="100%" float="bottom" padding="0">
							<label fity="true" font="dyn_12" color="#ffab01" shadow="true" watch="HeroSelectHeroAbilityInfo{index}" ontrigger="SetText(param2);" />
						</panel>
						
					</panel>

					<!-- Mana -->
					<label x="116@" y="0.1h" height="100%" textvalign="bottom" textalign="left" font="dyn_10" color="white" shadow="true" 
						watch="HeroSelectHeroAbilityInfo{index}" ontrigger="If(!stringempty(param5), SetText(Translate('heroinfo_mana_cost') # '^w' # param5), ClearText()); SetVisible(!stringempty(param5));" 
						watch1="##ActiveInventoryMultiLevelDescription{slot}##" ontrigger1="##If(!stringempty(param2), SetText(Translate('tooltip_mana_cost') # '^w' # param2), ClearText()); SetVisible(!stringempty(param2));##"
					/>
					
					
					<!-- Range / Radius / CD / Passive-->
					<panel watch="HeroSelectHeroAbilityInfo{index}" ontrigger="SetVisible(param7  gt 0 or param11  gt 0 or param12  gt 0 or param6 gt 0 or !param10)" noclick="1">
						<label height="100%" textalign="right" textvalign="top" font="dyn_10" color="1 1 1 1" shadow="true"
							watch="HeroSelectHeroAbilityInfo{index}"
							ontrigger="
								SetText('');
								If(
									!StringEmpty(param7) and param7 gt 0,
									SetText(Translate('heroinfo_range') # param7))
								);
								If(
									!StringEmpty(param11) and param11 gt 0,
									SetText(Translate('heroinfo_radius') # param11))
								);
								If(
									!StringEmpty(param12) and param12 gt 0,
									SetText(Translate('heroinfo_aura') # ' ' # Translate('heroinfo_radius') # param12)
								);
							"
						/>
						<label height="100%" textvalign="bottom" textalign="right" font="dyn_10" color="1 1 1 1" shadow="true" watch="HeroSelectHeroAbilityInfo{index}" ontrigger="SetText(Translate('heroinfo_cooldown', 'time', param6))); SetVisible(!StringEmpty(param6) and param6 gt 0 and param10);" />
						<label height="100%" textvalign="bottom" textalign="right" font="dyn_10" color=".9 .9 .9 1" shadow="true" watch="HeroSelectHeroAbilityInfo{index}" onload="SetText(Translate('tooltip_activate_passive'));" ontrigger="SetVisible(!param10);" />

					</panel>

				</panel>				
				
				<panel width="100%" height="0.2h" noclick="1">
					<panel width="100%" height="1" valign="bottom" color=".2 .2 .2 1" />
				</panel>
				
				<panel height="16.4h" width="100%" noclick="1" clip="1" >
					<!--<label fity="true" font="dyn_9" wrap="true" color=".9 .9 .9 1" shadow="true" content="" watch="HeroSelectHeroAbilityInfo{index}" ontrigger="SetText(param8);"/>-->
					<textbuffer 
						watch="HeroSelectHeroAbilityInfo{index}" ontrigger="SetBufferText(NormalizeLineBreaks(param8));"
						watch1="##ActiveInventoryMultiLevelDescription{index}##" ontrigger1="##SetBufferText(NormalizeLineBreaks(param20));##"
						noclick="0" valign="top" align="center" font="dyn_9" wrap="true" shadow="1" shadowcolor="black"		
						fity="true" color="invisible" content="hero role string" 							
						scrollbarplaceholder="false"
						scrolltexture="/ui/info/combobox.tga"
						handleheight="1.8h"
						scrollbarsize="1.8h"
						exteriorscrollbars="false"
						textalign="left"
						textcolor="white"					
					/>											
				</panel>
						
			</panel>
				
		</panel>
	</template>	
	
	<template name="hero_info_compendium"> 
		<panel name="{id=hero_info_compendium}" width="113.5h" height="44.2h" noclick="true" visible="false">
			
			<!-- Left - Hero Info -->
			<panel width="92.0h" align="left">
				
				<!-- Hero Info -->
				<panel x="0.5h" width="22.5h" float="bottom" padding="1.0h">
				
					<panel y="0.3h" grow="true" width="100%" float="bottom" noclick="true">
						<label fity="true" width="100%" font="dyn_14" color="#ffab01" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(param2);" />
						<panel width="100%" height="0.2h">
							<panel width="100%" height="1" valign="bottom" color=".2 .2 .2 1" />
						</panel>
					</panel>
					
					<panel width="100%" height="6.4h" noclick="1" >
						<!-- Hero Icon -->
						<panel width="100@" height="100%" onclick="If(!CanAccessHeroProduct(compendium_heroLastViewed) or IsEarlyAccessHero(compendium_heroLastViewed), SleepWidget(200, 'CallEventParams(\'store_open_purchase_helper\', compendium_heroLastViewed);'));" >
							<panel texture="/ui/elements/button_bevel_sml_up.tga" watch="HeroSelectHeroInfo" ontrigger="SetVisible(!CanAccessHeroProduct(compendium_heroLastViewed) and !IsEarlyAccessHero(compendium_heroLastViewed) and !IsFreeHero(compendium_heroLastViewed));" noclick="1" >
								<image texture="$checker" watch="HeroSelectHeroInfo" ontrigger="SetTexture(param1);" valign="center" align="center" width="-4" height="-4" noclick="1" />
							</panel>
							
							<panel texture="/ui/elements/button_bevel_sml_free_up.tga" watch="HeroSelectHeroInfo" ontrigger="SetVisible(IsFreeHero(compendium_heroLastViewed));" noclick="1" >
								<image texture="$checker" watch="HeroSelectHeroInfo" ontrigger="SetTexture(param1);" valign="center" align="center" width="-4" height="-4" noclick="1" />
							</panel>								
							
							<panel texture="/ui/elements/button_bevel_sml_up.tga" watch="HeroSelectHeroInfo" ontrigger="SetVisible(CanAccessHeroProduct(compendium_heroLastViewed) and !IsEarlyAccessHero(compendium_heroLastViewed) and !IsFreeHero(compendium_heroLastViewed));" noclick="1" >
								<image texture="$checker" watch="HeroSelectHeroInfo" ontrigger="SetTexture(param1);" valign="center" align="center" width="-4" height="-4" noclick="1" />
							</panel>							
							
							<frame x="0" color="invisible" bordercolor="1 0.74 0 0.3" borderthickness="2" visible="1" watch="HeroSelectHeroInfo" ontrigger="SetVisible(IsEarlyAccessHero(compendium_heroLastViewed) and !IsFreeHero(compendium_heroLastViewed));" clip="1" noclick="1" >
								<image texture="/ui/specui/shinegradient.png"  color="1 1 1 1" width="150%" height="150%" valign="center" align="center" visible="1" noclick="1"
									onshow="SetWatch('HostTime');" onhide="SetWatch('');"  
									watch="" ontrigger="If(GetRotation() ge 360, SetRotation(0), SetRotation(GetRotation() + 1));" 
								/>								
								<image texture="$checker" watch="HeroSelectHeroInfo" ontrigger="SetTexture(param1);" valign="center" align="center" width="-4" height="-4" noclick="1" />							
								<panel texture="/ui/specui/shinegradient.png" y="100%" rotation="0" vscale="2" vspeed="-1.4" color="1 1 1 0.1" width="100%" height="400%" valign="center" align="center" noclick="1" />	
							</frame>							
							
							<image x="-0.6h" y="0.8h" width="2.8h" height="2.8h" align="left" valign="bottom" texture="$white" watch="HeroSelectHeroInfo" ontrigger="SetTexture('/ui/fe2/lobby/' # param23 # '.tga')" noclick="1" />

							<!-- Purchase button -->
							<button
								x="-2%" y="-2%"
								height="30%" width="30@"
								valign="bottom" align="right"
								color="0 0 0 .8"
								onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav'); SleepWidget(200, 'CallEventParams(\'store_open_purchase_helper\', compendium_heroLastViewed);');"
								visible="0"
								onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
								watch="HeroSelectHeroInfo" ontrigger="SetVisible(!CanAccessHeroProduct(compendium_heroLastViewed) and IsHeroProductPurchasable(compendium_heroLastViewed));"
							>
								<widgetstate statename="up">
									<image texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1" noclick="true"/>
									<image width="74@" height="74%" align="center" valign="center" color=".8 .8 .8 1" texture="/ui/icons/goldcoin.tga" />
								</widgetstate>
								<widgetstate statename="over">
									<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
									<image width="74@" height="74%" align="center" valign="center" texture="/ui/icons/goldcoin.tga" />
								</widgetstate>
								<widgetstate statename="down">
									<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
									<image x="1" y="1" width="74@" height="74%" align="center" valign="center" texture="/ui/icons/goldcoin.tga" />
								</widgetstate>
							</button>							
							
						</panel>
						<!-- Dmg/Armor/Mov -->
						<panel width="-107@" align="right" float="bottom" padding="0.2h">
							<panel width="100%" height="1.8h" float="right" padding="0.5h">
								<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(Translate('game_hero_select_label_damage', 'damage', Round(param15) # ' - ' # Round(param16)));" />
							</panel>								
							<panel width="100%" height="1.8h" float="right" padding="0.5h">
								<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(Translate('game_hero_select_label_attack_range', 'range', Round(param13)));" />
							</panel>
							<panel width="100%" height="1.8h" float="right" padding="0.5h">
								<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(Translate('game_hero_select_label_attack_speed', 'speed', FtoA(1000 / param14, 2)));" />
							</panel>								
						</panel>						
					</panel>
									
					<panel width="100%" height="6.6h" float="bottom" padding="0.3h">
						<panel width="100%" height="30%" float="right" padding="0.5h">
							<image width="100@" height="100%" texture="/ui/common/armor_icon.tga" />
							<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(Translate('game_hero_select_label_armor', 'armor', FtoA(param17, 2)));" />
						</panel>
						<panel width="100%" height="30%" float="right" padding="0.5h">
							<image width="100@" height="100%" texture="/ui/common/magic_armor_icon.tga" />
							<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(Translate('game_hero_select_label_magicarmor', 'armor', FtoA(param18, 2)));" />
						</panel>						
						<panel width="100%" height="30%" float="right" padding="0.5h">
							<image width="100@" height="100%" texture="/ui/common/move_speed_icon.tga" />
							<label height="100%" textvalign="center" font="dyn_11" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="SetText(Translate('game_hero_select_label_mvspeed', 'mvspeed', Round(param11)));" />
						</panel>
					</panel>						
					
					<!-- STR/AGI/INT -->
					<panel height="5.0h" width="100%">
					
						<panel width="32.5%" height="100%" align="left">
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#320000"/>
							<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#4e0000" />								
							<panel y="0.1h" height="60%">
								<image y="0.1h" width="100@" height="100%" valign="center" texture="/ui/fe2/lobby/strength.tga" />
								<label width="-72@" height="100%" align="right" textvalign="center" textalign="center" font="dyn_12" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="If(StringEquals(param4, 'strength'), SetColor('yellow'), SetColor('white')); SetText(Round(param5));" />
							</panel>
							<label y="-0.4h" width="100%" textalign="center" textvalign="bottom" font="dyn_10" color=".8 .8 .8 1" shadow="true" watch="HeroSelectHeroInfo" ontrigger="If(StringEquals(param4, 'strength'), SetColor('yellow'), SetColor('white')); SetText('(+'#FtoA(param6, 1) # ')');" />
						</panel>
						
						<panel width="32.5%" height="100%" align="center">
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#0b3200"/>
							<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#104b00" />
							<panel y="0.1h" height="60%">
								<image y="0.1h" width="100@" height="100%" valign="center" texture="/ui/fe2/lobby/agility.tga" />
								<label width="-72@" height="100%" align="right" textvalign="center" textalign="center" font="dyn_12" color="white" shadow="true" watch="HeroSelectHeroInfo" ontrigger="If(StringEquals(param4, 'agility'), SetColor('yellow'), SetColor('white')); SetText(Round(param7));" />
							</panel>
							<label y="-0.4h" width="100%" textalign="center" textvalign="bottom" font="dyn_10" color=".8 .8 .8 1" shadow="true" watch="HeroSelectHeroInfo" ontrigger="If(StringEquals(param4, 'agility'), SetColor('yellow'), SetColor('white')); SetText('(+'#FtoA(param8, 1) # ')');" />
						</panel>
						
						<panel width="32.5%" height="100%" align="right">
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#002b39"/>
							<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" bordercolor="#003f54" />
							<panel y="0.1h" height="60%">
								<image y="0.1h" width="100@" height="100%" valign="center" texture="/ui/fe2/lobby/intelligence.tga" />
								<label width="-72@" height="100%" align="right" textvalign="center" textalign="center" font="dyn_12" color="yellow" shadow="true" watch="HeroSelectHeroInfo" ontrigger="If(StringEquals(param4, 'intelligence'), SetColor('yellow'), SetColor('white')); SetText(Round(param9));" />								
							</panel>
							<label y="-0.4h" width="100%" textalign="center" textvalign="bottom" font="dyn_10" color=".8 .8 .8 1" shadow="true" watch="HeroSelectHeroInfo" ontrigger="If(StringEquals(param4, 'intelligence'), SetColor('yellow'), SetColor('white')); SetText('(+'#FtoA(param10, 1) # ')');" />
						</panel>
						
					</panel>
					
					<panel height="18.0h" width="100%" color="invisible" >
						<!--
						<label fity="true" wrap="true" font="dyn_10" color=".9 .9 .9 1" shadow="true" content="hero role string" 
							watch="HeroSelectHeroInfo" ontrigger="SetText(param24); If(GetHeight() gt GetHeightFromString('20.5h'), SetFont('dyn_8'), SetFont('dyn_10'));  SetText(param24);"/>
						-->
						<textbuffer 
							watch="HeroSelectHeroInfo" ontrigger="SetBufferText(NormalizeLineBreaks(param24));"
							noclick="0" valign="top" align="left" font="dyn_10" wrap="true" shadow="1" shadowcolor="black"		
							height="100%" width="-2.2h" color="invisible" content=""
							scrollbarplaceholder="false"
							scrolltexture="/ui/info/combobox.tga"
							handleheight="1.8h"
							scrollbarsize="1.8h"
							exteriorscrollbars="true"
							textalign="left"
							textcolor="white"					
						/>								
					</panel>
				
				</panel>					
				
				<!-- Abilities -->
				<panel width="-24.0h" align="right">				
					<panel width="49.8%" align="left" float="bottom" padding="0.2h">				
						<instance name="herodex_ability_box" height="21.9h" boxBG="0 .1 0 .5" index="0" paramindex="24" />
						<instance name="herodex_ability_box" height="21.9h" boxBG="0 .1 0 .5" index="1" paramindex="25" />
					</panel>					
					<panel width="49.8%" align="right" float="bottom" padding="0.2h">				
						<instance name="herodex_ability_box" height="21.9h" boxBG="0 .1 0 .5" index="2" paramindex="26" />
						<instance name="herodex_ability_box" height="21.9h" boxBG="0 .1 0 .5" index="3" paramindex="27" />
					</panel>				
				</panel>
		
			</panel>
		
			<!-- Right - Hero Stats -->
			<panel x="0" width="-92.5h" align="right">
			
				<!-- Hero Stat Background
				modeNormal_bg, modeCasual_bg, modePublic_bg				
				-->
				<frame y="0" x="0" texture="/ui/info/backdrop.tga" borderthickness="2.0h" style="modeNormal_bg" noclick="1" name="compendium_herostats_rnk_bg" visible="1" group="compendium_herostats_bg" />
				<frame y="0" x="0" texture="/ui/info/backdrop.tga" borderthickness="2.0h" style="modeCasual_bg" noclick="1" name="compendium_herostats_cs_bg" visible="0" group="compendium_herostats_bg"  />
				<frame y="0" x="0" texture="/ui/info/backdrop.tga" borderthickness="2.0h" style="modePublic_bg" noclick="1" name="compendium_herostats_ph_bg" visible="0" group="compendium_herostats_bg"  />
				<frame y="0" x="0" color=".05 .07 .1 .5" bordercolor="#455166" borderthickness="1" noclick="1" />		
			
				<label y="0.4h" width="-1.4h" align="center" fity="true" font="dyn_14" color="#ffab01" shadow="true" content="Your Average Game" />
				
				<panel noclick="0"  height="3.0h" width="-2" valign="top" align="center" x="0" y="0.2h" color="1 1 0 0.0" 
					onmouseover="SleepWidget(0, ''); SleepWidget(2500, 'Call(\'herodex_herostats_lookupName_input\', \'FadeIn(50);\');');"
				>
					<panel name="herodex_herostats_lookupName_input" x="0" width="100%" height="2.5h" valign="top" color="0 0 0 1.0" visible="0" noclick="1">
						<frame color="invisible" bordercolor="#7b8c9b55" borderthickness="1" noclick="1" />
						<textbox
							y="0.0h"
							width="-1.0h"
							valign="center" align="center"
							maxlength="250"
							textalign="left" textvalign="center"
							font="dyn_11"
							fontcolor="#ffab01"
							textcolor="white"
							shadow="false"
							color="invisible"
							onshow="SetFocus(false); SetInputLine(compendium_hero_stats_playerLookupName);"
							onenter="
								PlaySound('/shared/sounds/ui/chat_send.wav');
								Set(compendium_hero_stats_playerLookupName, this);
								SetFocus(false);
								Set(compendium_usage_useCache, 0); CallEvent('hero_stats_submit_compendium');
							"
							onesc="EraseInputLine(); SetFocus(false);"
							onchange="Set(compendium_hero_stats_playerLookupName, this);"
							onhide="Call('herodex_herostats_lookupName_input', 'SetVisible(0);');"
							onlosefocus="Call('herodex_herostats_lookupName_input', 'SetVisible(0);');"
						/>
					</panel>			
				</panel>				
					
				<panel noclick="1" y="6h" width="-1.4h" align="center" >
					<instance name="compendium_herostats_rnk_template" color="#3abde7" visible="1" style="modeNormal_txt" bg="modeNormal_bg" />
					<instance name="compendium_herostats_cs_template" color="#456645" visible="0" style="modeCasual_txt" bg="modeCasual_bg" />
					<instance name="compendium_herostats_ph_template" color="#664545" visible="0" style="modePublic_txt" bg="modePublic_bg" />				
				</panel>
					
				<panel y="3h" width="-1.4h" align="center" reverse="0" padding="0.1h" noclick="1" color="invisible"
						onload=" If(!VarExists('compendium_herostats_lastViewed'), DoEvent(0), DoEvent(1)); " 
						onevent0="CreateString('compendium_herostats_lastViewed', 'compendium_herostats_rnk'); SetSave('compendium_herostats_lastViewed');  ShowOnly(compendium_herostats_lastViewed);  "
						onevent1="ShowOnly(compendium_herostats_lastViewed);"				
				>
					<panel width="20h" height="2.6h" noclick="1" visible="1" color="invisible" >
						<instance
							name="Noptions_combobox"
							width="100%"
							itemwidth="100%"
							maxlistheight="3"
							populate="
									AddTemplateListItem('Ncombobox_item', 'compendium_herostats_rnk', 'label', 'general_normal_mode');
									AddTemplateListItem('Ncombobox_item', 'compendium_herostats_cs', 'label', 'general_casual_mode');
									AddTemplateListItem('Ncombobox_item', 'compendium_herostats_ph', 'label', 'general_public_mode');
									SetSelectedItemByValue(compendium_herostats_lastViewed);
									"
							onselect="
									ShowOnly(this); cmd('setsave compendium_herostats_lastViewed ' # this);
									ShowOnly(this#'_bg');
								"
						/>
					</panel>				
				</panel>	
				
				<panel y="0.0h" noclick="1" watch="HeroStatsStatus" ontrigger="SetVisible(param0 == 1);"  visible="1" width="100%" height="44.0h" color="0 0 0 .7" 
					onshow="Call('compendium_herostats_retry1', 'SetVisible(0); SleepWidget(0, \'\'); SleepWidget(1500, \'SetVisible(1);\');');"
				>
					<label width="-10.0h" y="4h" height="100%" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="Retrieving..." noclick="1" />
					<animatedimage width="4.5h" height="4.5h" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" visible="1" align="center" valign="center" />	
					<instance valign="center" y="8.6h" button_name="compendium_herostats_retry1"
						name="button2"
						width="12.0h" height="2.5h"
						align="center"
						label="main_stats_retry"
						font="dyn_10"
						onclick="Call('hero_stats_submit_compendium', 'DoEvent();'); Set(compendium_usage_useCache, 0); Set(compendium_guide_useCache, 0); Call('compendium_hero_stats_error', 'FadeOut(50);');"
					/>					
				</panel>
				<panel y="0.0h" name="compendium_hero_stats_error" noclick="1" watch="HeroStatsResult" ontrigger="SetVisible(!StringEmpty(param0) and param0 != 0);"  visible="0" width="100%" height="44.0h" color="0 0 0 .7" 
					onshow="Call('compendium_herostats_retry2', 'SetVisible(0); SleepWidget(0, \'\'); SleepWidget(1500, \'SetVisible(1);\');');"
				>
					<label width="-10.0h" height="100%" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="Error" noclick="1" />
					<instance valign="center" y="2.6h" button_name="compendium_herostats_retry2"
						name="button2"
						width="12.0h" height="2.5h"
						align="center"
						label="main_stats_retry"
						font="dyn_10"
						onclick="Call('hero_stats_submit_compendium', 'DoEvent();'); Set(compendium_usage_useCache, 0); Set(compendium_guide_useCache, 0); Call('compendium_hero_stats_error', 'FadeOut(50);');"
					/>
				</panel>		
				
			</panel>
		
		</panel>
	</template>	
	
	<template name="herodex_herolist_template" >
		<panel float="bottom" onload="CreateInt('_compendium_sort_key1');">
			<panel width="100%" grow="true">
				<panel height="2.5h" width="-2h" x="-1h" align="center" float="right" padding=".1h">
												
