						onclick="
							_prev_button_state = param;
							GroupCall('compendium_mastery_detailedlist_header', 'SetButtonState(0);');
							If(_prev_button_state == 0, SetButtonState(2));
							If(_prev_button_state == 1, SetButtonState(2));
							If(_prev_button_state == 2, SetButtonState(1));
							If(GetButtonState() == 1, Set('_compendium_sort_key{allheroes}', 10), Set('_compendium_sort_key{allheroes}', -11));
							Call('compendium_mastery_listbox_detailed{allheroes}', 'SortListboxSortIndexNumeric(_compendium_sort_key{allheroes}' # ', 0);');
						"
						onmouseover="ShowWidget('Mcompendium_tip_sort_gpm');"
						onmouseout="hideWidget('Mcompendium_tip_sort_gpm');"
					/>

					<instance
						name="column_header"
						group="compendium_mastery_detailedlist_header"
						width="6.3h"
						font="dyn_10"
						label="compendium_m_apm"
						borderthickness=".4h"
						onclick="
							_prev_button_state = param;
							GroupCall('compendium_mastery_detailedlist_header', 'SetButtonState(0);');
							If(_prev_button_state == 0, SetButtonState(2));
							If(_prev_button_state == 1, SetButtonState(2));
							If(_prev_button_state == 2, SetButtonState(1));
							If(GetButtonState() == 1, Set('_compendium_sort_key{allheroes}', 11), Set('_compendium_sort_key{allheroes}', -12));
							Call('compendium_mastery_listbox_detailed{allheroes}', 'SortListboxSortIndexNumeric(_compendium_sort_key{allheroes}' # ', 0);');
						"
						onmouseover="ShowWidget('Mcompendium_tip_sort_apm');"
						onmouseout="hideWidget('Mcompendium_tip_sort_apm');"
					/>

					<instance
						name="column_header"
						group="compendium_mastery_detailedlist_header"
						width="12h"
						font="dyn_10"
						label="compendium_m_mastery"
						borderthickness=".4h"
						onclick="
							_prev_button_state = param;
							GroupCall('compendium_mastery_detailedlist_header', 'SetButtonState(0);');
							If(_prev_button_state == 0, SetButtonState(2));
							If(_prev_button_state == 1, SetButtonState(2));
							If(_prev_button_state == 2, SetButtonState(1));
							If(GetButtonState() == 1, Set('_compendium_sort_key{allheroes}', 12), Set('_compendium_sort_key{allheroes}', -13));
							Call('compendium_mastery_listbox_detailed{allheroes}', 'SortListboxSortIndexNumeric(_compendium_sort_key{allheroes}' # ', 0);');
						"
						onmouseover="ShowWidget('Mcompendium_tip_sort_mastery');"
						onmouseout="hideWidget('Mcompendium_tip_sort_mastery');"
					/>				
					
				</panel>
			</panel>
			
			<listbox
				group="compendium_mastery_listboxes"
				name="compendium_mastery_listbox_detailed{allheroes}"
				width="-2.0h" height="-2.55h"
				color="invisible"
				font="dyn_10"
				itemwidth="100%"
				itemheight="3.15h"
				select="true"
				clearselection="true"
				hoverselect="true"
				hoverhighlight="true"
				highlight="over"
				highlightcolor="#FFFFFF33"
				highlightbordercolor="#FFFFFFFF"
				selectedcolor="#0077FF22"
				selectedbordercolor="#0077FFFF"
				backgroundimage="/ui/fe2/elements/comm_item_bg.tga"
				backgroundimagecolor="#1d2f3b"
				colortransition="true"
				colortransitiontime="250"
				exteriorscrollbars="true"
				scrollbarplaceholder="true"
				scrollbarsize="2.0h"
				scrolltexture="/ui/info/combobox.tga"
				handleheight="2.0h"
				watch1="MasteryHeroInfo"
				ontrigger1="
				If((IsFreeHero(param0) or {allheroes=1}) and !HasListItem(param0),
					AddTemplateListItemWithSort('hero_mastery_list_item', param0,
					(param1 # ',' # param5 # ',' # param6 # ',' # param7 # ',' # param8 # ',' # param9 # ',' # param10 # ',' # param11 # ',' # param12 # ',' # param13 # ',' # param14 # ',' # param15 # ',' # param16)
					, 'hero_name', param1, 'hero_icon', param2, 'm_wins', param5, 'm_loses', param6, 'm_winpercent', param7, 'm_kills', param8, 'm_deaths', param9, 'm_assists', param10, 'm_cks', param11, 'm_cds', param12, 'm_xpm', param13, 'm_gpm', param14, 'm_apm', param15, 'faction', param3, 'eap', IsEarlyAccessHero(param0), 'free', IsFreeHero(param0), 'ownership', param4, 'hero', param0)
				);"
				ontrigger1lua="	local masteryExp = GetMyMasteryExp(param0)
								local masteryLevel = GetMasteryLevelByExp(masteryExp)
								local masteryType = GetMasterTypeByLevel(masteryLevel)
								local minExp, maxExp = GetMasteryExpByLevel(masteryLevel)
								local rate = (masteryExp-minExp) / (maxExp-minExp)

								GetWidget('learner_masteryinfo_level_id_hero_herolistitem'..param0):SetText(tostring(masteryLevel))
								GetWidget('learner_masteryinfo_plate_id_hero_herolistitem'..param0):SetTexture('/ui/fe2/mastery/learner_sbg_'..masteryType..'.tga')
								GetWidget('learner_masteryinfo_experience_id_hero_herolistitem'..param0):SetText(tostring(masteryExp-minExp)..' / '..tostring(maxExp-minExp))
								if masteryLevel >= GetCvarInt('hero_mastery_maxlevel_new') then
									GetWidget('mastery_level_progressbar_bg_id_hero_herolistitem'..param0):SetWidth('100%')
									GetWidget('mastery_level_progressbar_bg_id_hero_herolistitem'..param0):SetTexture('/ui/fe2/mastery/m_gradient_maxlevel.tga')
								else
									GetWidget('mastery_level_progressbar_bg_id_hero_herolistitem'..param0):SetWidth(tostring(rate*100)..'%')
									GetWidget('mastery_level_progressbar_bg_id_hero_herolistitem'..param0):SetTexture('/ui/fe2/mastery/m_gradient.tga')
								end"
				watch2="MasteryClearInfo"
				ontrigger2="ClearItems();"
				watch3="MasteryFinishInfo"
				ontrigger3="Call('compendium_mastery_listbox_detailed{allheroes}', 'SortListboxSortIndex(_compendium_sort_key{allheroes}' # ', 0);');"
				onselect="If(IsVisible(), PlaySound('/shared/sounds/ui/button_click_01.wav'));  ShowHeroCompendiumInfo(this); Set(compendium_heroLastViewed, this);  SetSave('compendium_heroLastViewed');##"
				onselectlua="UIManager.GetInterface('main'):HoNLearnerF('ClickHero', self:GetValue())"
			>
			</listbox>
		</panel>

	</template>	
	
	<template name="mastery_level_progressbar">
		<panel name="mastery_level_progressbar_{id_debug}" noclick="1" height="{height=100%}" width="{width=100%}" x="{x=0}" y="{y=0}" 
			valign="{valign=top}" align="{align=left}" visible="{visible=1}" >
			<panel name="mastery_level_progressbar_panel_{id_debug}" width="-0.5h" align="center" height="-0.3h" valign="center" noclick="1" color=".07 .07 .07 1">
				<label name="learner_masteryinfo_experience_{id_debug}" visible="{type}" noclick="1" font="dyn_7" width="9h" height="3h" x="-1.17h" y="-0.25h" textalign="center" valign="center" 
					align="left" outline="1" color=".9 .8 .8" outlinecolor=".8 .8 .8 .1"
				/>
				<panel name="mastery_level_progressbar_bg_{id_debug}" width="0" nocompress="1" texture="/ui/fe2/mastery/m_gradient.tga" visible="1" noclick="1" />			
			</panel>
		</panel>
	</template>

	<template name="learner_mastery_heroinfo">
		<panel name="learner_mastery_heroinfo_panel{id_debug}" noclick="1" width="{width}" height="{height}" x="-1.1h" y="{y}" align="{align}" valign="{valign}" color="invisible">
			<instance name="mastery_level_progressbar" width="{barwidth}" height="{barheight}" x="{barx}" y="{bary}" valign="bottom" align="left" id_debug="{id_debug}" type="{type}" />
			<image name="learner_masteryinfo_plate_{id_debug}" noclick="1" width="{width}" height="{height}" x="-0.38h" y="-0.7h" valign="bottom" align="left" nocompress="1"/>
			<label name="learner_masteryinfo_level_{id_debug}" noclick="1" font="{font}" width="6h" height="6h" x="-1.15h" y="1.45h" textalign="center" valign="center" align="left" outline="1" color=".9 .8 .8"
				   outlinecolor=".8 .8 .8 .1" />
		</panel>
	</template>

</package>
