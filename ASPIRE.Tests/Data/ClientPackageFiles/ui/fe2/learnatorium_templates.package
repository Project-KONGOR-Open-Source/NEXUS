	<template name="herodex_header_bar">
		<panel group="{group}" x="{x}" y="{y}" width="{width=100%}" height="{height=100%}" align="{align}" valign="{valign}" color="invisible" noclick="{noclick=1}" blockinput="0">
			<image width="-64" align="center" texture="/ui/info/header_bar_c.tga" color="{color=#ffffff}" noclick="1" blockinput="0"/>
			<image height="50.1%" width="32" align="left" valign="top" texture="/ui/info/header_bar_tl.tga" color="{color=#ffffff}" noclick="1" blockinput="0"/>
			<image height="49.9%" width="32" align="left" valign="bottom" texture="/ui/info/header_bar_bl.tga" color="{color=#ffffff}" noclick="1" blockinput="0"/>
			<image height="50.1%" width="32" align="right" valign="top" texture="/ui/info/header_bar_tr.tga" color="{color=#ffffff}" noclick="1" blockinput="0"/>
			<image height="49.9%" width="32" align="right" valign="bottom" texture="/ui/info/header_bar_br.tga" color="{color=#ffffff}" noclick="1" blockinput="0"/>
		
			<label name="{label_name}" align="{label_align=left}" oninstantiate="{oninstantiate}" textvalign="{label_textvalign=center}"  x="0.7h" y="{label_y=0.1h}" width="100%" height="100%" font="{lbl_font=dyn_10}" color="{lbl_color=white}" watch="{watch}" ontrigger="{ontrigger}" shadow="true" noclick="1" blockinput="0">{lbl}</label>
			<button
				visible="{show_close}"
				x="-0.5h"			
				width="{buttonsize=1.7h}" height="{buttonsize=1.7h}"
				align="right"
				valign="center"
				color="invisible"
				onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); {onclick}"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav'); {onmouseover}"
				interactive="{interactive}"
			>
				<widgetstate statename="up">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />			
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
				</widgetstate>
			</button>
		</panel>
	</template>	
	
	<template name="hero_list_item">

		<panel width="-.5h" height="-.5h" align="center" valign="center" float="right" padding=".1h" >
			<anchor x="0" y="0" />
			<panel width="80@" height="100%" noclick="true">
				<image noclick="true" width="100%" height="100@" valign="center" texture="" oninstantiate="If(StringEquals('{faction}', 'Legion'), SetTexture('/ui/fe2/elements/icon_legion_shadow.tga'), SetTexture('/ui/fe2/elements/icon_hellbourne_shadow.tga'));"/>
			</panel>
			<panel width="84@" height="100%" noclick="true">
				<image noclick="true" width="100%" height="100@" valign="center" texture="{hero_icon}" />
			</panel>
			
			<label noclick="true" width="16h" color="white" textvalign="center" height="100%" font="dyn_10"
				oninstantiate="If({eap=0}, SetColor('1 0.74 0 1'), If({free=0}, SetColor('0.3 1 0.3 1'), If({ownership=0}, SetColor('1 1 1 1'), SetColor('0.6 0.6 0.6 1'))));"
			>   {hero_name}</label>

			<panel width="11.5h" float="right" padding="0">
				<image x="-0.4h" width="100@" height="100%" texture="{attribute_icon}" noclick="true" />
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{attribute}</label>
			</panel>

			<panel width="5.5h" height="100%">
				<image width="90@" height="90%" noclick="true" texture="/ui/elements/melee.tga" align="center" oninstantiate="If({attack_type_icon} == 1, SetTexture('/ui/fe2/lobby/melee.tga'), SetTexture('/ui/fe2/lobby/ranged.tga'));" />
			</panel>

			<panel noclick="true" width="9.3h" float="right">
				<label color="white" noclick="true" textvalign="center" height="100%" font="dyn_10" fitx="true" fitxpadding=".5h">{strength}</label>
				<label color=".7 .7 .7 1" noclick="true" textvalign="center" height="100%" font="dyn_9" fitx="true" oninstantiate="SetText( '(+{strength_per_level}/' # Translate('compendium_lvl') # ')');"></label>
			</panel>

			<panel noclick="true" width="9.3h" float="right">
				<label color="white" noclick="true" textvalign="center" height="100%" font="dyn_10" fitx="true" fitxpadding=".5h">{agility}</label>
				<label noclick="true" color=".7 .7 .7 1" textvalign="center" height="100%" font="dyn_9" fitx="true" oninstantiate="SetText( '(+{agility_per_level}/' # Translate('compendium_lvl') # ')');"></label>
			</panel>

			<panel noclick="true" width="9.3h" float="right">
				<label noclick="true" color="white" textvalign="center" height="100%" font="dyn_10" fitx="true" fitxpadding=".5h">{intelligence}</label>
				<label noclick="true" color=".7 .7 .7 1" textvalign="center" height="100%" font="dyn_9" fitx="true" oninstantiate="SetText( '(+{intelligence_per_level}/' # Translate('compendium_lvl') # ')');"></label>
			</panel>

			<panel noclick="true" height="100%" width="9.5h">
				<panel height="100%" grow="true" align="center" float="right">
					<label noclick="true" color="white" textvalign="center" height="100%" font="dyn_10" fitx="true" fitxpadding=".5h">{armor}</label>
					<label noclick="true" color=".7 .7 .7 1" textvalign="center" height="100%" font="dyn_9" fitx="true">({armor_percent}%)</label>
				</panel>
			</panel>
			
			<panel noclick="true" height="100%" width="9.5h">
				<panel height="100%" grow="true" align="center" float="right">
					<label noclick="true" color="white" textvalign="center" height="100%" font="dyn_10" fitx="true" fitxpadding=".5h">{atk_dmg_min} - {atk_dmg_max}</label>
				</panel>
			</panel>

			<label noclick="true" width="7h" color="white" textvalign="center" textalign="center" height="100%" font="dyn_10">{movespeed}</label>

			<!-- <label width="6h" color="white" textvalign="center" textalign="center" height="100%" font="dyn_9" onmouseover="ShowWidget('Mcompendium_tip_dps');" onmouseout="hideWidget('Mcompendium_tip_dps');">{DPS}</label> -->

			<image noclick="true" width="95@" height="95%" valign="center" texture="{ability_0_icon}" />
			<image noclick="true" width="95@" height="95%" valign="center" texture="{ability_1_icon}" />
			<image noclick="true" width="95@" height="95%" valign="center" texture="{ability_2_icon}" />
			<image noclick="true" width="95@" height="95%" valign="center" texture="{ability_3_icon}" />

		</panel>

	</template>
	
	<template name="hero_mastery_list_item">

		<panel width="-.5h" height="-.5h" align="center" valign="center" float="right" padding=".1h" >
			<anchor x="0" y="0" />
			<panel width="80@" height="100%" noclick="true">
				<image noclick="true" width="100%" height="100@" valign="center" texture="" oninstantiate="If(StringEquals('{faction}', 'Legion'), SetTexture('/ui/fe2/elements/icon_legion_shadow.tga'), SetTexture('/ui/fe2/elements/icon_hellbourne_shadow.tga'));"/>
			</panel>
			<panel width="84@" height="100%" noclick="true">
				<image noclick="true" width="100%" height="100@" valign="center" texture="{hero_icon}" />
			</panel>
			
			<label noclick="true" width="16h" color="white" textvalign="center" height="100%" font="dyn_10"
				oninstantiate="If({eap=0}, SetColor('1 0.74 0 1'), If({free=0}, SetColor('0.3 1 0.3 1'), If({ownership=0}, SetColor('1 1 1 1'), SetColor('0.6 0.6 0.6 1'))));"
			>   {hero_name}</label>

			<panel width="6.5h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_wins}</label>
			</panel>

			<panel width="7.7h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_loses}</label>
			</panel>

			<panel width="6.8h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_winpercent}</label>
			</panel>

			<panel width="6.13h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_kills}</label>
			</panel>

			<panel width="7.3h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_deaths}</label>
			</panel>

			<panel width="7.45h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_assists}</label>
			</panel>

			<panel width="5.25h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_cks}</label>
			</panel>

			<panel width="5.25h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_cds}</label>
			</panel>

			<panel width="6.23h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_xpm}</label>
			</panel>

			<panel width="6.23h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_gpm}</label>
			</panel>

			<panel width="6.23h" float="right" padding="0">
				<label width="10h" color="white" textvalign="center" noclick="true" height="100%" font="dyn_10" >{m_apm}</label>
			</panel>

			<panel width="0.8h" />
			<!-- Mastery -->
			<panel width="6.23h" float="right" padding="0">
				<instance name="learner_mastery_heroinfo" y="0.6h" font="dyn_9" valign="center" width="11.85h" height="2.95h"
					barwidth="7.42h" barheight="1.2h" barx="3.0h" bary="-1.07h"
					id_debug="id_hero_herolistitem{hero}" type="0" 
				/>
			</panel>

		</panel>
	</template>

	<template name="head_tab_button">
		<panel width="{width}" noclick="true" onload="{onload}" visible="{visible=1}"  >
			<button
				width="100%" height="100%"
				group="{group}"
				name="{button_name}"
				color="invisible"
				visible="{visible=true}"
				watch="{watch}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger}"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); If(!StringEmpty('{id}'), Call('{id}', 'SetAnim(0, \'start\');'));   If(!StringEmpty('{id}'), Call('{id}',  'SetEffect(0, \'/ui/effects/nebula/button_smoke.effect\');')); {onmouseover}"
				onmouseout="{onmouseout}"
				onclick="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav}'); {onclick}"
				onenter="PlaySound('{sound='/shared/sounds/ui/button_click_01.wav}'); {onenter}"
				onshow="{onshow}"
				hotkey="{hotkey}"
				onhotkey="PlaySound('{sound=/shared/sounds/ui/button_click_01.wav'}'); {onhotkey}"
				
			>
				<widgetstate statename="up">
					<frame texture="/ui/info/button.tga" borderthickness="0.5h" rendermode="grayscale"/>
					<label font="{font=dyn_11}" shadow="true" color="white" textalign="center" textvalign="center" content="{label}" watch="{labelwatch}" ontrigger="{labelontrigger}" ></label>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/info/button_over.tga" borderthickness="0.5h" />
					<label font="{font=dyn_11}" shadow="true" color="white" textalign="center" textvalign="center" content="{label}"  watch="{labelwatch}" ontrigger="{labelontrigger}" ></label>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="0.5h" color="white"/>
					<label font="{font=dyn_11}" shadow="true" color="white" textalign="center" textvalign="center" content="{label}"  watch="{labelwatch}" ontrigger="{labelontrigger}" ></label>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/info/button.tga" borderthickness="0.5h" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.5h" color=".3 .3 .3 .7"/>
					<label font="{font=dyn_11}" shadow="true" color="white" textalign="center" textvalign="center" content="{label}"  watch="{labelwatch}" ontrigger="{labelontrigger}" ></label>
				</widgetstate>
			</button>
			
			<panel name="{type}_cover" group="type_cover" visible="{cover_isvis=false}">
				<frame texture="/ui/info/button_down.tga" borderthickness="0.4h" color="#ff0a0a"/>
				<label font="dyn_11" shadow="true" color="white" textalign="center" textvalign="center" content="{label}"  watch="{labelwatch}" ontrigger="{labelontrigger}" ></label>
			</panel>
		</panel>
	</template>

	<template name="simple_compendium_hero_empty">
		<panel height="100%" width="100@" align="center" valign="center" noclick="true">
			<image texture="lobby/empty_hero_slot_{side}.tga" noclick="true" />
		</panel>
	</template>	

	<template name="empty_slots">
		<listbox
			noclick="1"
			align="{align}"
			valign="center"
			width="44.4h"
			itemwidth="4.4h"
			itemheight="4.4h"
			select="true"
			hoverselect="false"
			color="invisible"						
			highlight="over"
			exteriorscrollbars="false"
			scrollbarsize="2h"
			scrolltexture="/ui/info/combobox.tga"
			handleheight="2h"
			wrap="row"
			passivechildren="true"
		>							
			<listitem><instance name="simple_compendium_hero_empty" side="{side}"/></listitem>
			<listitem><instance name="simple_compendium_hero_empty" side="{side}"/></listitem>
