	<template name="simple_compendium_hero_item">
		<panel height="100%" width="100@" align="center" valign="center" color="0.3 0.3 0.3 1">
			<!-- Background -->
			<image width="100%" height="100%" texture="/ui/elements/hero_picker_icon.tga" noclick="1" />

			<!-- Hero Icon (Non EAP) -->
			<panel noclick="1" oninstantiate="SetVisible(!{eap=0});">
				<!-- Icon -->
				<image 	width="90@" height="90@"  align="center" valign="center" 
					texture="{icon}" oninstantiate="If({ownership=0} or {free=0}, SetRenderMode('normal'), SetRenderMode('grayscale'));"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); ShowWidget('simple_hero_list_tip'); Call('simple_hero_list_selector_{icon}', 'FadeIn(150);'); Trigger('SimpleHeroItemTooltip', '{name}', '{attribute}', '{attack_type}', '{trial}');"
					onmouseoverlua="GetWidget('learner_favorite_{heroentity}'):FadeIn(150)"
					onmouseout="HideWidget('simple_hero_list_tip'); Call('simple_hero_list_selector_{icon}', 'FadeOut(150);');"
					onmouseoutlua="UIManager.GetInterface('main'):HoNLearnerF('MouseOutFavorite', '{heroentity}')"
					onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickHero', '{heroentity}')"
					onshowlua="UIManager.GetInterface('main'):HoNLearnerF('ShowHeroFavorite', '{heroentity}')"
				/>
				
				<image noclick="1" align="center" valign="center" texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1"
					oninstantiate=" SetVisible({free=0} and !{eap=0}); SetTexture('/ui/elements/button_bevel_sml' # If({free=0}, '_free', '') # '_up.tga'); "
				/> 
				
				<!-- Icon Textured Border (Free and Owned) AGILITY -->
				<image noclick="1" align="center" valign="center" texture="/ui/elements/button_bevel_sml_up.tga" color="#4a8f4f" 
					oninstantiate="
						SetVisible(!{free=0} and !{eap=0});
						If(StringEquals('{attribute_icon}', '/ui/common/primary_strength.tga'),
							SetColor('#8f4a4a'),
							If(StringEquals('{attribute_icon}', '/ui/common/primary_intelligence.tga'),
								SetColor('#4a578f'),
								SetColor('#4a8f4f')
							)
						);
					"
				/>
				
			</panel>
			
			<!-- Hero Icon (EAP) -->
			<panel width="100%" height="100%" oninstantiate="SetVisible({eap=0});" noclick="1" >
				<frame x="0" color="invisible" bordercolor="1 0.74 0 0.3" borderthickness="2" visible="1" clip="1" noclick="1" >
					<image texture="/ui/specui/shinegradient.png"  color="1 1 1 1" width="150%" height="150%" valign="center" align="center" visible="1" noclick="1"
						onshow="SetWatch('HostTime');" onhide="SetWatch('');"  
						watch="" ontrigger="If(GetRotation() ge 360, SetRotation(0), SetRotation(GetRotation() + 1));"
					/>								
					<image texture="{icon}" oninstantiate="##If({ownership=0}, SetRenderMode('normal'), SetRenderMode('grayscale'));##" valign="center" align="center" width="-4" height="-4" noclick="0" 
						onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); ShowWidget('simple_hero_list_tip'); Call('simple_hero_list_selector_{icon}', 'FadeIn(150);'); Trigger('SimpleHeroItemTooltip', '{name}', '{attribute}', '{attack_type}', '{trial}');"
						onmouseoverlua="GetWidget('learner_favorite_{heroentity}'):FadeIn(150)"
						onmouseout="HideWidget('simple_hero_list_tip'); Call('simple_hero_list_selector_{icon}', 'FadeOut(150);');"
						onmouseoutlua="UIManager.GetInterface('main'):HoNLearnerF('MouseOutFavorite', '{heroentity}')"
						onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickHero', '{heroentity}')"
						onshowlua="UIManager.GetInterface('main'):HoNLearnerF('ShowHeroFavorite', '{heroentity}')"
					/>							
					<panel texture="/ui/specui/shinegradient.png" y="100%" rotation="0" vscale="2" vspeed="-1.4" color="1 1 1 0.1" width="100%" height="400%" valign="center" align="center" noclick="1" />	
				</frame>							
			</panel>			

			<!--<image noclick="true" width="30@" height="30%" texture="" oninstantiate="If(StringEquals('{faction}', 'Legion'), SetTexture('/ui/fe2/elements/icon_legion_shadow.tga'), SetTexture('/ui/fe2/elements/icon_hellbourne_shadow.tga'));" onmouseover="ShowWidget('Mcompendium_tip_faction');" onmouseout="hideWidget('Mcompendium_tip_faction');" />
			<image noclick="true" width="35@" height="35%" texture="{attribute_icon}" valign="bottom" align="right" onmouseover="ShowWidget('Mcompendium_tip_primary_attr');" onmouseout="hideWidget('Mcompendium_tip_primary_attr');" />-->
			<!-- <frame x="0" color="invisible" bordercolor="1 0.74 0 0.8" borderthickness="1"  visible="0" oninstantiate="SetVisible({ownership=0});" noclick="1"/> -->
			
			<!-- frame for agility hero -->
			<panel name="simple_hero_list_selector_{icon}" visible="false" color="#0cff0022" noclick="true"
				oninstantiate="
					##SetVisible(!{free=0} and !{eap=0});##
					If(StringEquals('{attribute_icon}', '/ui/common/primary_strength.tga'),
						SetColor('#ff000022'),
						If(StringEquals('{attribute_icon}', '/ui/common/primary_intelligence.tga'),
							SetColor('#008aff22'),
							SetColor('#0cff0022')
						)
					);
				"			
			>
				<frame color="invisible" borderthickness="1" bordercolor="#0cff00" noclick="true"
					oninstantiate="
						##SetVisible(!{free=0} and !{eap=0});##
						If(StringEquals('{attribute_icon}', '/ui/common/primary_strength.tga'),
							SetBorderColor('#ff0000'),
							If(StringEquals('{attribute_icon}', '/ui/common/primary_intelligence.tga'),
								SetBorderColor('#008aff'),
								SetBorderColor('#0cff00')
							)
						);
					"					
				/>
			</panel>		
			
			<!-- If Has Alt Avs
			<button
				x="5%" y="-5%"
				height="30%" width="30@"
				valign="bottom" align="left"
				color="0 0 0 .8"
				onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav');"
				visible="1"				
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
				onclicklua="Herodex.ClickedViewAvatars('{heroentity}')"
			>
				<widgetstate statename="up">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1" noclick="true"/>
					<image width="74@" height="74%" align="center" valign="center" color=".8 .8 .8 1" texture="/ui/icons/users.tga" />
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image width="74@" height="74%" align="center" valign="center" texture="/ui/icons/users.tga" />
				</widgetstate>
				<widgetstate statename="down">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image x="1" y="1" width="74@" height="74%" align="center" valign="center" texture="/ui/icons/users.tga" />
				</widgetstate>
			</button>			
			 -->
			  
			<!-- Purchase button  -->
			<button
				x="-5%" y="-5%"
				height="30%" width="30@"
				valign="bottom" align="right"
				color="0 0 0 .8" noclick="0"
				onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav');"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
				visible="0" oninstantiate="SetVisible(IsHeroProductPurchasable('{heroentity}') and !CanAccessHeroProduct('{heroentity}')); SetOnclick('PlaySound(\'/ui/fe2/store/sounds/popup.wav\'); ##Echo(\'{heroentity}\');## SleepWidget(200, \'CallEventParams(\\\'store_open_purchase_helper\\\', compendium_heroLastViewed);\'); ');"						
			>
				<widgetstate statename="up">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1" noclick="true"/>
					<image width="74@" height="74%" align="center" valign="center" color=".8 .8 .8 1" texture="/ui/icons/goldcoin.tga" />
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image width="74@" height="74%" align="center" valign="center" texture="/ui/icons/goldcoin.tga" />
				</widgetstate>
				<widgetstate statename="down">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image x="1" y="1" width="74@" height="74%" align="center" valign="center" texture="/ui/icons/goldcoin.tga" />
				</widgetstate>
			</button>

			<!-- Favorite Button -->
			<button group="learnatorium_list_favorite_buttons"
				name="learner_favorite_{heroentity}"
				x="6%" y="6%" visible="0"
				height="32%" width="32@"
				valign="top" align="left"
				numstates="2"
				color="0 0 0 .8"
				onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav');"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
				onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ToggleFavorite', '{heroentity}')"
				oninstantiatelua="UIManager.GetInterface('main'):HoNLearnerF('RegisterFavoriteButton', self, '{heroentity}')"
				onmouseoverlua="GetWidget('learner_favorite_{heroentity}'):FadeIn(150)"
				onmouseoutlua="UIManager.GetInterface('main'):HoNLearnerF('MouseOutFavorite', '{heroentity}')"

			>
				<widgetstate statename="up">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1" noclick="true"/>
					<image width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/lobby/filter_favorites.tga" color="yellow"/>
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/lobby/filter_favorites.tga" color="yellow" />
				</widgetstate>
				<widgetstate statename="down">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image x="1" y="1" width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/lobby/filter_favorites.tga" />
				</widgetstate>

				<widgetstate statename="up2">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1" noclick="true"/>
					<image width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/lobby/filter_favorites.tga"/>
				</widgetstate>
				<widgetstate statename="over2">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/lobby/filter_favorites.tga" />
				</widgetstate>
				<widgetstate statename="down2">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image x="1" y="1" width="125@" height="125%" align="center" valign="center" texture="/ui/fe2/lobby/filter_favorites.tga" color="yellow" />
				</widgetstate>
			</button>
			
			<!-- Token button
			<button
				x="-5%" y="-5%" noclick="1"
				height="30%" width="30@"
				valign="bottom" align="right"
				color="0 0 0 .8"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
				visible="0" oninstantiate="SetVisible({cantoken=0}); SetOnclick('PlaySound(\'/ui/fe2/store/sounds/popup.wav\'); Echo(\'{heroentity}\');');"			
			>
				<widgetstate statename="up">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="1 1 1 1" noclick="true"/>
					<image width="74@" height="74%" align="center" valign="center" color=".8 .8 .8 1" texture="/ui/icons/more.tga" />
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image width="74@" height="74%" align="center" valign="center" texture="/ui/icons/more.tga" />
				</widgetstate>
				<widgetstate statename="down">
					<image texture="/ui/elements/button_bevel_sml_up.tga" color="red" noclick="true"/>
					<image x="1" y="1" width="74@" height="74%" align="center" valign="center" texture="/ui/icons/more.tga" />
				</widgetstate>
			</button>
