		</panel>
	</template>
	
	<template name="compendium_tab_cat_button">
		<panel height="3.7h" width="19.0h" noclick="true" onload="{onload}" visible="{visible=1}" group="{group}">
		
			<frame texture="/ui/fe2/frames/top_tab.tga" borderthickness="0.8h" color="#2c3031" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>			
			<button
				color="invisible"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				onhide="{onmouseout}"
				onclick="PlaySound('/shared/sounds/ui/button_click_01.wav'); {onclick}"
				enabled="{enabled=true}"
			>
				<widgetstate statename="up"></widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/fe2/frames/top_tab.tga" borderthickness="0.8h" color="#35464c" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>
				<widgetstate statename="down">
					<frame texture="/ui/fe2/frames/top_tab.tga" borderthickness="0.8h" color="#35464c" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/fe2/frames/top_tab.tga" borderthickness="0.8h" color="#1c1e1f" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>
			</button>

			<panel group="type_cover" visible="{cover_isvis=false}" name="{type}_cover" width="100%" height="100%" noclick="true">
				<frame texture="/ui/fe2/frames/top_tab.tga" borderthickness="0.8h" color="#23485c" blockinput="false" noclick="true" />
				<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
			</panel>

			<label y="-0.2h" width="100%" height="100%" align="center" textalign="center" textvalign="center" noclick="true" font="dyn_11" color="white" shadow="true" visible="{enabled=true}" >{lbl}</label>
			<label y="-0.2h" width="100%" height="100%" align="center" textalign="center" textvalign="center" noclick="true" font="dyn_11" color=".4 .4 .4 1" shadow="true" visible="{disabledtxt=false}" >{lbl}</label>
			
		</panel>
	</template>
	
	<template name="compendium_tab_button">
		<panel height="{height=8.0h}" width="100%" noclick="true" onload="{onload}" visible="{visible=1}" sticky="true" stickytoinvis="false" >		
			<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#17242b" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>			
			<button
				color="invisible"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				onhide="{onmouseout}"
				onclick="PlaySound('/shared/sounds/ui/button_click_01.wav'); {onclick}"
			>
				<widgetstate statename="up"></widgetstate>
				<widgetstate statename="over">
					<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#1d333f" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>
				<widgetstate statename="down">
					<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#1d333f" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>				
			</button>			
			<panel group="type_cover" visible="0" name="{type}_cover" width="100%" height="100%"  noclick="true">
				<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#23485c" blockinput="false" noclick="true" />
				<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
			</panel>
			<panel y="18%" x="-4%" align="center" valign="center" noclick="true" float="bottom" padding=".25h">				
				<image y="0" noclick="true" align="center" width="4h" height="4h" texture="{icn}" group="compendium_tab_button_icon_{icongroup}" />
				<frame y="0" noclick="true" align="center" width="4h" height="4h" visible="{iconborder=0}" color="invisible" bordercolor="0.3 0.3 0.3 1.0" borderthickness="1" />
				<label noclick="true" font="dyn_11" color="white" height="2.5h" shadow="true" align="center" textalign="center">{lbl}</label>
			</panel>			
		</panel>
	</template>

	<template name="compendium_tab_create_guide">
		<panel name="{id}" height="{height=4.0h}" width="100%" noclick="true" onload="{onload}" visible="{visible=true}" sticky="true" stickytoinvis="false">		
			<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#17242b" blockinput="false" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>			
			<button
				color="invisible"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				onhide="{onmouseout}"
				onclick="PlaySound('/shared/sounds/ui/button_click_01.wav'); {onclick}"
				onclicklua="{onclicklua}"
			>
				<widgetstate statename="up"></widgetstate>
				<widgetstate statename="over">
					<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#1d333f" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>
				<widgetstate statename="down">
					<frame texture="frames/side_tab.tga" borderthickness="0.8h" color="#1d333f" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.8h" blockinput="false" noclick="true"/>
				</widgetstate>				
			</button>			
			<image x="-1.7h" width="3.0h" height="3.0h" align="center" valign="center" texture="{icn}" noclick="true" />
			<image x="1.2h" y="0.1h" width="2.5h" height="2.5h" align="center" valign="center" texture="/ui/fe2/elements/btn_cplus_up.tga" noclick="true" />		
		</panel>
	</template>
	
	<template name="graph_bar" >
		<frame group="{id}_graph_bars" onevent="DestroyWidget();" noclick="0" width="{width=3h}" color="orange" valign="bottom" bordercolor="red" height="{height=1%}" 
			onmouseover="SetColor('red'); Trigger('HeroUsageGraphTooltipUpdate', '{date}', '{value}'); ShowWidget('graph_bar_tooltip');" 
			onmouseout="HideWidget('graph_bar_tooltip'); SetColor('orange');" 
			onhide="HideWidget('graph_bar_tooltip'); SetColor('orange');"
		>
			<!--<label align="center" valign="bottom" textalign="center" textvalign="bottom" font="dyn_8" color="black" content="{index}" noclick="1" />-->
		</frame>
	</template>
		
	<template name="compendium_usage_graph" >
		<panel noclick="1" align="center" x="-12h" valign="top" color="1 1 0 0.0" width="20h" grow="1" height="2.0h" >
			<panel noclick="1" float="right" align="center" >
			
				<panel noclick="1" width="7h" >
					<!--<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" vmargin="0.25h" />-->
					<panel noclick="1" >
						<panel width="7h" align="right">
							<label width="-0.5h" textvalign="top" align="right" font="dyn_12" color="white" shadow="true" content="general_days" />
						</panel>	
					</panel>	
				</panel>	
			
				<panel noclick="1" width="7h" >
					<!--<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" vmargin="0.25h" />-->
					<panel vmargin="0.5h" hmargin="0.5h">
						<instance
							name="Noptions_radiobutton"
							radiobutton_name=""
							align="left"
							width="100%"
							font="dyn_10" label="30"
							labeloninstantiate=""
							tip_id=""
							cvar="compendium_usage_retrieveDays"
							value="30"
							group="purchase_points_choice"
							onclick="CallEvent('submit_herousagegraphform');"
							onload="If(compendium_usage_retrieveDays == 30, SetButtonState(1));"
						/>
					</panel>
				</panel>
	
				<panel noclick="1" width="7h" >
					<!--<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" vmargin="0.25h" />-->
					<panel vmargin="0.5h" hmargin="0.5h">
						<instance
							name="Noptions_radiobutton"
							radiobutton_name=""
							align="left"
							width="100%"
							font="dyn_10" label="60"
							labeloninstantiate=""
							tip_id=""
							cvar="compendium_usage_retrieveDays"
							value="60"
							group="purchase_points_choice"
							onclick="CallEvent('submit_herousagegraphform');"
							onload="If(compendium_usage_retrieveDays == 60, SetButtonState(1));"
						/>
					</panel>
				</panel>	
	
				<panel noclick="1" width="7h"  >
					<!--<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" vmargin="0.25h" />-->
					<panel vmargin="0.5h" hmargin="0.5h">
						<instance
							name="Noptions_radiobutton"
							radiobutton_name=""
							align="left"
							width="100%"
							font="dyn_10" label="90"
							labeloninstantiate=""
							tip_id=""
							cvar="compendium_usage_retrieveDays"
							value="90"
							group="purchase_points_choice"
							onclick="CallEvent('submit_herousagegraphform');"
							onload="If(compendium_usage_retrieveDays == 90, SetButtonState(1));"
						/>
					</panel>
				</panel>	
				
				<panel noclick="1" width="7h"  >
					<!--<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" vmargin="0.25h" />-->
					<panel vmargin="0.5h" hmargin="0.5h">
						<instance
							name="Noptions_radiobutton"
							radiobutton_name=""
							align="left"
							width="100%"
							font="dyn_10" label="120"
							labeloninstantiate=""
							tip_id=""
							cvar="compendium_usage_retrieveDays"
							value="120"
							group="purchase_points_choice"
							onclick="CallEvent('submit_herousagegraphform');"
							onload="If(compendium_usage_retrieveDays == 120, SetButtonState(1));"
						/>
					</panel>
				</panel>					
				
				<panel noclick="1" width="7h"  >
					<!--<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" vmargin="0.25h" />-->
					<panel vmargin="0.5h" hmargin="0.5h">
						<instance
							name="Noptions_radiobutton"
							radiobutton_name=""
							align="left"
							width="100%"
							font="dyn_10" label="180"
							labeloninstantiate=""
							tip_id=""
							cvar="compendium_usage_retrieveDays"
							value="180"
							group="purchase_points_choice"
							onclick="CallEvent('submit_herousagegraphform');"
							onload="If(compendium_usage_retrieveDays == 180, SetButtonState(1));"
						/>
					</panel>
				</panel>					
				
			</panel>
		</panel>	
		
		<panel noclick="1" x="-1.2h" y="1.0h" width="95%" height="90%" align="right" valign="top" group="compendium_hero_usage_graph_bars"  onevent1="SetVisible(1);" onevent2="SetVisible(0);" onevent3="SetVisible(0);"  >
			<panel noclick="1" float="right" valign="bottom" align="left" padding="1h" color="0.3 0.3 0.3 0.0" 
				onhide="SetHeight('1%'); SleepWidget(0, '');" 
				onshow="SetHeight('1%'); ScaleHeight('1%', 1);" onevent=""  
				onload="
					CreateInt('graph_totalBars', 1); 
					CreateFloat('graph_totalHeight', 1); 
					CreateFloat('graph_widthPerBar', 1);
				"
				watch1="HeroUsageGraphFormResult"
				ontrigger1="
					If((HeroUsageGraphFormStatus == 2 or compendium_usage_usingCache) and param3 gt 0 and param4 gt 0,
						Split(
							Set(graph_totalBars, param3),
							Set(graph_totalHeight, Ceil(param4)),
							Trigger('HeroUsageGraphAxisUpdate', 3, Ceil(param4)),
							GroupCall('compendium_hero_usage_graph_bars', 'DoEvent();'),
							If(graph_totalBars gt 0, 
								Split(
									Set(graph_widthPerBar,  (  (	 GetWidth() -  ( param3 * GetWidthFromString('1h') )  )  / param3  ) ),
									ExplodeTrigger('HeroUsageGraphFormResultExplode', param2, '|', '`'),
									ScaleHeight('100%', 750)
								)
							)
						)
					);
				"					
				watch2="HeroUsageGraphFormResultExplode"
				ontrigger2="
					If((HeroUsageGraphFormStatus == 2 or compendium_usage_usingCache),				
						Split( 
							If(param0 == 1, 
								Trigger('HeroUsageGraphAxisUpdate', 1, param1),
								If(param0 == graph_totalBars, 
									Trigger('HeroUsageGraphAxisUpdate', 2, param1)
								)
							),
							Instantiate('graph_bar', 
								'index', param0,
								'date', param1,
								'value', param2,
								'id', 'compendium_hero_usage',
								'width', graph_widthPerBar, 
								'height', (param2 * 100 / graph_totalHeight)#'%'    
							)
						)
					);
				"				
			>
			</panel>
			<label y="0.5%" x="-7%" watch="HeroUsageGraphAxisUpdate" ontrigger="If(param0 == 3, SetText(param1#'%'));" 
				width="5%" content="" textvalign="top" align="left"  valign="top" textalign="right"  font="dyn_10" noclick="1" color="#ffab01"   shadow="1" wrap="1" fity="true" fitypadding="0.8h"  
			/>
			<frame y="0" x="-1%" color="orange" height="100%" width="1" valign="top" align="left" />
			<frame y="1.5%" x="0" color="orange" height="1" width="100%" valign="bottom" />
			<label y="9.5%" x="0" watch="HeroUsageGraphAxisUpdate" ontrigger="If(param0 == 1, SetText(param1));" width="50%" content="Start Date" textvalign="top" align="left"  valign="bottom" textalign="left"  font="dyn_10" noclick="1" color="#ffab01"   shadow="1" wrap="1" fity="true" fitypadding="0.8h"  />	
			<label y="9.5%" x="0" watch="HeroUsageGraphAxisUpdate" ontrigger="If(param0 == 2, SetText(param1));" width="50%" content="End Date"   textvalign="top" align="right" valign="bottom" textalign="right" font="dyn_10" noclick="1" color="#ffab01"   shadow="1" wrap="1" fity="true" fitypadding="0.8h"  />
		</panel>
		<!-- Blockers -->
		<panel noclick="1" x="-1.2h" y="1.0h" width="95%" height="90%" align="right" visible="0" valign="top" group="compendium_hero_usage_graph_bars" onevent1="SetVisible(0);" onevent2="SetVisible(1);" onevent3="SetVisible(1);"
			  onshow="Call('compendium_herostats_retry3', 'SetVisible(0); SleepWidget(0, \'\'); SleepWidget(1500, \'SetVisible(1);\');');"
		>
			<label width="-10.0h" height="100%" y="-0h" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_12" color="white" shadow="1" content="Retrieving..." noclick="1" 
				group="compendium_hero_usage_graph_bars" onevent2="SetText(Translate('compendium_get_from_web'));" onevent3="SetText(Translate('compendium_get_from_cache'));"
			/>
			<instance valign="center" y="4h" button_name="compendium_herostats_retry3"
				name="button2" x="0"
				width="12.0h" height="2.5h"
				align="center"
				label="main_stats_retry"
				font="dyn_10"
				onclick=" Set(compendium_usage_useCache, 0); GroupCall('compendium_hero_usage_graph_bars', 'DoEvent(1);'); CallEvent('submit_herousagegraphform'); "
			/>
			<animatedimage y="-6h" align="center" texture="/ui/elements/throb/throb.tga" noclick="true" valign="center" loop="1" fps="30" onshow="StartAnim(1);" visible="1" height="4.5h" width="4.5h" />										
		</panel>		
			
	</template>
	
	<trigger name="compendium_guideRecommendedItemUpdate" />
	<template name="compendium_guide_recommended_item">
		<panel visible="0" width="100@" height="100%" group="compendium_guide_recommended_items" oninstantiate="DoEvent(); If(!VarExists('compendium_guide_recommendeditem_isscroll{id}'), DoEvent(1));" onevent="SetVisible(0); If(!VarExists('compendium_guide_fadein'), DoEvent(2)); FadeIn(compendium_guide_fadein*{id} * compendium_animSpeedMult);" onevent1="CreateBool('compendium_guide_recommendeditem_isscroll{id}', 0);" 
			onevent2="CreateInt('compendium_guide_fadein', 125); CreateInt('compendium_guide_lerptime', 1000); CreateInt('compendium_animSpeedMult', 1);"
			noclick="1"	
			watch="{watch}"	ontrigger="
			##Echo('{watch} | {id} | '#param0#' | '#param1);##
			If({id} == param0 and StringLength(param1) ge 5 and !StringEmpty(GetEntityIconPath(param1)), 
				SetOnTrigger(3, '
					DoEvent(); TriggerShopItem(\'compendium_guideRecommendedItemUpdate\', \''#param1#'\', 0);
				')
			);
			"
			watch3="compendium_guideRecommendedEvent"
			watch4="compendium_guideRecommendedClear" ontrigger4="##DestroyWidget();## SetVisible(0); SetOnTrigger(3, '');"							
		>
			<button noclick="0" passivechildren="1"
				color="invisible"
				interactive="false"
				watch4="compendium_guideRecommendedClear" ontrigger4="SetOnMouseOver(''); SetOnMouseOut(''); SetOnTrigger(1, ''); SetOnTrigger(2, ''); SetOnClick('');"
				watch="{watch}"
				ontrigger="
					If({id} == param0 and StringLength(param1) ge 5 and !StringEmpty(GetEntityIconPath(param1)),
						Split(
							SetOnMouseOver('
								TriggerItemTooltip(
									\'MSPlayerInventoryTip\',
									\''#param1#'\',
									false
								);
								Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param1#'\'));
								Trigger(\'compendium_guideRecommendedBorder\', {panel}, {id});
								Cmd(\'UICall endgameItemTooltip SetVisible(1)\');
							'),
							SetOnMouseOut('
								Trigger(\'compendium_guideRecommendedBorder\', \'\', \'\');
								Cmd(\'UICall endgameItemTooltip SetVisible(0)\');						
							'),
							SetOnTrigger(2, '
								If(StringEquals(param28, \''#param1#'\'), Set(compendium_guide_recommendeditem_isscroll{id}, (param8 and !param17 and !param18)) );
								If(StringEquals(param28, \''#param1#'\'), 
									SetOnMouseOver(
										\'					
										TriggerItemTooltip(
											\\\'MSPlayerInventoryTip\\\',
											\\\''#param1#'\\\',
											false
										);
										Trigger(\\\'MSPlayerInventoryTipIcon\\\', GetEntityIconPath(\\\''#param1#'\\\'));
										Trigger(\\\'compendium_guideRecommendedBorder\\\', {panel}, {id});
										Cmd(\\\'UICall endgameItemTooltip SetVisible(1)\\\');					
									\')
								);							
							')
						)
					);
				"
				watch1="MSPlayerInventoryTip"
				watch2="compendium_guideRecommendedItemUpdate"
			>
				<frame width="+2" height="+2" noclick="1" color="invisible" bordercolor="yellow" borderthickness="2" visible="0" 
					watch1="compendium_guideRecommendedBorder" ontrigger1="If(param0 == {panel} and param1 == {id}, SetVisible(1), SetVisible(0));"
					watch2="MSPlayerInventoryTip" ontrigger2="If(param39 gt 0, SetBorderColor('#00acff'), SetBorderColor('0 1 0 1'));"
				/>
				<widgetstate statename="up">
					<image texture="{icon}" watch2="{watch}" ontrigger2=" If({id} == param0 and StringLength(param1) ge 5 and !StringEmpty(GetEntityIconPath(param1)), SetTexture(GetEntityIconPath(param1)));" />					
					<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
					<frame width="+2" height="+2" noclick="1" color="invisible" bordercolor="yellow" borderthickness="2" visible="0" 
						watch1="QuickItemBorder" ontrigger1="If(param0 == {panel}{id} and param1 == -2, Split(SetVisible(1), SetBorderColor('1 1 0 1')), SetVisible(0));"
					/>							
				</widgetstate>
				<widgetstate statename="over">
					<image texture="{icon}" watch2="{watch}" ontrigger2=" If({id} == param0 and StringLength(param1) ge 5 and !StringEmpty(GetEntityIconPath(param1)), SetTexture(GetEntityIconPath(param1)));" 
				
					/>
					<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<image texture="{icon}" watch2="{watch}" ontrigger2=" If({id} == param0 and StringLength(param1) ge 5 and !StringEmpty(GetEntityIconPath(param1)), SetTexture(GetEntityIconPath(param1)));" 				
					/>
					<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="true"/>
				</widgetstate>
			</button>
		</panel>
	</template>
	
	<template name="compendium_guide_recommended">
		<panel grow="true" width="100%" float="bottom" padding="0.2h" noclick="1"  >
		
			<panel grow="true" width="100%" noclick="1">
				<label fity="true" font="dyn_12" color="#feaa00" content="{phaseName}" noclick="1" shadow="1" outline="1" />				
				<instance name="tip_mark" tip_id="{tip_id}" width="1.7h" height="1.7h" valign="center" align="right"  noclick="1" />
			</panel>
			
			<panel width="100%" height="8.3h"  noclick="1" >
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .5"  noclick="1" />
				<frame texture="/ui/frames/roundframe.tga" color="#667788" borderthickness="0.4h"  noclick="1" />
				
				<panel name="compendium_guide_recommended_panel_{panel}_1" y="1%" height="50%" width="-1.0h" valign="top" align="center" float="right" padding="0.5h" noclick="1" >
					<instance name="compendium_guide_recommended_item" id="1" watch="{watch}" panel="{panel}" />
					<instance name="compendium_guide_recommended_item" id="2" watch="{watch}" panel="{panel}" />
					<instance name="compendium_guide_recommended_item" id="3" watch="{watch}" panel="{panel}" />
					<instance name="compendium_guide_recommended_item" id="4" watch="{watch}" panel="{panel}" />
				</panel>
				
				<panel name="compendium_guide_recommended_panel_{panel}_2" y="-1%" height="50%" width="-1.0h" valign="bottom" align="center" float="right" padding="0.5h" noclick="1" >
					<instance name="compendium_guide_recommended_item" id="5" watch="{watch}" panel="{panel}" />
					<instance name="compendium_guide_recommended_item" id="6" watch="{watch}" panel="{panel}" />
					<instance name="compendium_guide_recommended_item" id="7" watch="{watch}" panel="{panel}" />
					<instance name="compendium_guide_recommended_item" id="8" watch="{watch}" panel="{panel}" />					
				</panel>
			
			</panel>
		</panel>
	</template>

	<template name="compendium_guide_ability_lvl">
		<panel group="guide_ability_lvl_group" height="3.1h" visible="0"  
			oninstantiate="If(Call(GetParent(), 'IsVisible()'), DoEvent());" 
			onevent="SetVisible(0); If(!VarExists('compendium_guide_fadein'), DoEvent(1)); SleepWidget((compendium_guide_fadein*{id}/5 * compendium_animSpeedMult), 'FadeIn(150 * compendium_animSpeedMult)');" 
			onevent1="CreateInt('compendium_guide_fadein', 125); CreateInt('compendium_guide_lerptime', 1000); CreateInt('compendium_animSpeedMult', 1);"			
			watch3="compendium_guideAbilityEvent" ontrigger3="DoEvent();"	
			watch4="compendium_guideAbilityClear" ontrigger4="SetVisible(0);"	
			noclick="1"
		>
			<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .5" noclick="1" />
			<frame texture="/ui/frames/roundframe.tga" color="#667788" borderthickness="0.4h" noclick="1" />
			<frame texture="/ui/frames/roundframe.tga" visible="0" borderthickness="0.4h" bordercolor="1 0.5 0 1.0" group="compendium_ability_hoverBorder_{id}" noclick="1" />
			
			<label width="-92@" textvalign="center" textalign="center" font="dyn_14" color="1 1 1 1" content="{id}" outline="1" noclick="1"   />
			
			<panel x="-0.2h" width="88@" height="88%" valign="center" align="right" noclick="1" >
				<image  watch="compendium_guideInfoFormResultExplodeAbilities" ontrigger="If({id} == param0, SetTexture(GetEntityIconPath(param1)));" noclick="1"  />
				<frame color="invisible" borderthickness="1" bordercolor=".2 .2 .2 1" noclick="1"/>
			</panel>
		
			<panel name="compendium_guide_ability_lvl_item_{id}"
				height="120%" y="-10%"
				width="120%" x="-10%"
				noclick="0" passivechildren="1"
				color="invisible"
				onmouseover="
					GetHeroInfo(compendium_heroLastViewed);
					Set(compendium_guide_ability_hoverName, '{abilityname}');
					GroupCall('ability_boxv3_ability_highlight', 'DoEvent(1);');
					Call('hero_info', 'FadeIn(50);'); 									
					SleepWidget(100, 'Set(compendium_guide_ability_hoverName, \'\');');
					GroupCall('compendium_ability_hoverBorder_{id}', 'SetVisible(1);');
				"
				onmouseout="
					Call('hero_info', 'FadeOut(50);'); 
					GroupCall('compendium_ability_hoverBorder_{id}', 'SetVisible(0);');
				"
				onhide="
					HideWidget('hero_info'); 
					GroupCall('compendium_ability_hoverBorder_{id}', 'SetVisible(0);');
				"		
				watch="compendium_guideInfoFormResultExplodeAbilities"
				ontrigger="
					If({id} == param0,
						Split(
							SetOnMouseOut('
								Call(\'hero_info\', \'FadeOut(50);\'); 
								GroupCall(\'compendium_ability_hoverBorder_{id}\', \'SetVisible(0);\');							
							'),
							SetOnMouseOver('							
								GetHeroInfo(compendium_heroLastViewed);
								Set(compendium_guide_ability_hoverName, \''#param1#'\');
								GroupCall(\'ability_boxv3_ability_highlight\', \'DoEvent(1);\');
								Call(\'hero_info\', \'FadeIn(50);\'); 									
								SleepWidget(100, \'Set(compendium_guide_ability_hoverName, \\\'\\\');\');
								GroupCall(\'compendium_ability_hoverBorder_{id}\', \'SetVisible(1);\');							
							')
						)
					);
				"	
				watch4="compendium_guideAbilityClear" ontrigger4="SetOnMouseOver(''); SetOnMouseOut('');"	
			>
				
			</panel>
		</panel>
	</template>

	<template name="compendium_guidelist_item">
		<panel height="100%" float="right" padding="1.0h" clip="1" >
	
			<!-- If featured, replace popularity with this --> 
			<panel x="0.8h" width="3.0h" height="100%" visible="0" oninstantiate="SetVisible({is_premium=0} and !{is_yours=0} and !{isfav=0} and !{isdef=0});" >
				<image width="1.6h" height="1.6h" valign="center" align="center" color="0.8 0 1 1" texture="/ui/elements/star.tga" />
			</panel>	
	
			<!-- If yours --> 
			<panel x="0.8h" width="3.0h" height="100%" visible="0" oninstantiate="SetVisible({is_yours=0} and !{isfav=0} and !{isdef=0});" >
				<image width="1.6h" height="1.6h" valign="center" align="center" color="green" texture="/ui/elements/star.tga" />
			</panel>		
		
			<!-- If favorite, replace popularity with this --> 
			<panel x="0.8h" width="3.0h" height="100%" visible="0" oninstantiate="SetVisible({isfav=0} and !{isdef=0});" >
				<image width="1.6h" height="1.6h" valign="center" align="center" texture="/ui/elements/star.tga" />
			</panel>
			
			<!-- If default, replace popularity with this --> 
			<panel x="0.8h" width="3.0h" height="100%" visible="0" oninstantiate="SetVisible({isdef=0});" >
				<image width="1.6h" height="1.6h" valign="center" align="center" color="yellow" texture="/ui/elements/star.tga" />
			</panel>			
			

			
			<!-- If Regular compendium_guide -->
			<label name="compendium_guidelist_item_{compendium_guideindex}" visible="1" x="0.8h" width="3.0h" height="100%" font="dyn_9" color="0 1 0 1" textvalign="center" textalign="right" shadow="true" 
				content="N/A" 
				oninstantiate="SetVisible(!{isfav=0} and !{isdef=0} and !{is_premium=0} and !{is_yours=0}); 
					If({pop} gt 0,
						Split(
							SetText('{pop=78}%'),
							SetColor(Saturate(1 - (({pop}/100) - 0.50) / 0.50), (({pop}/100) + (((({pop}/100) - 0.05) / 1.0)*0.2)) / 0.45, 	0, 1)
						), 
						Split(
							SetText('N/A'),
							SetColor('0.7 0.7 0.7 1')
						)
					);"
			/>			
			
			<label fitx="true" height="100%" font="dyn_9" color="1 1 1 1" textvalign="center" shadow="true" content="{compendium_guidename=compendium_guide Name}" />
			<label fitx="true" height="100%" font="dyn_9" color=".7 .7 .7 1" textvalign="center" shadow="true" content="{author=Author}"
				oninstantiatelua="
					self:SetVisible(HoN_Region.regionTable[HoN_Region.activeRegion].guideDetails)
				"
			/>
		</panel>
	</template>
		
	<template name="compendium_guidelist_combobox_state">
		<widgetstate statename="{state}">
			<panel color="invisible">
				<image height="100%" width="-200@" align="center" texture="/ui/info/combobox_background_c.tga" color="{color}"/>
				<image height="100%" width="100@" align="left" texture="/ui/info/combobox_background_l.tga" color="{color}"/>
				<image height="100%" width="100@" align="right" texture="/ui/info/combobox_background_r.tga" color="{color}"/>
				<image x="-1" width="100@" height="100%" align="right" valign="center" texture="/ui/info/combobox_button_{image}.tga" />
			</panel>
		</widgetstate>
	</template> 
	
	<template name="compendium_guide_vote_btn">
		<button 
			name="compendium_guide_vote_thumbs_{thumbs}_button"
			x="{x}"
			width="116@" height="100%"
			align="{align}"
			color="invisible"
			onmouseover=""
			onmouseout=""
			onclick="{onclick}"
			interactive="false"
			watch="{watch}"
			ontrigger="{ontrigger}"
			watch1="{watch1}"
			ontrigger1="{ontrigger1}"
			watch2="{watch2}"
			ontrigger2="{ontrigger2}"			
		>
			<widgetstate statename="up">
				<label y="-0.2h" textvalign="bottom" textalign="center" font="dyn_7" color=".8 .8 .8 1" content="{label}" />
				<image group="compendium_guide_vote_thumbs_{thumbs}" y="-0.3h" width="90%" height="90%" align="center" color=".9 .9 .9 1" texture="/ui/fe2/elements/{texture}" />				
			</widgetstate>
			<widgetstate statename="over">
				<label y="-0.2h" textvalign="bottom" textalign="center" font="dyn_7" color="1 1 1 1" content="{label}" />
				<image group="compendium_guide_vote_thumbs_{thumbs}"  y="-0.3h" width="90%" height="90%" align="center" texture="/ui/fe2/elements/{texture}" />
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<label y="-0.2h" textvalign="bottom" textalign="center" font="dyn_7" color="1 1 1 1" content="{label}" />
				<image group="compendium_guide_vote_thumbs_{thumbs}"  y="-0.3h" width="90%" height="90%" align="center" texture="/ui/fe2/elements/{texture}" />
			</widgetstate>
		</button>
	</template>	
	
	<template name="compendium_guide_bottom_template">
		<panel name="compendium_guide_lower_area" noclick="1" width="-31.4h" height="6.0h" >
				
					<!-- Default -->
					<instance interactive="false"
						button_name="compendium_guide_button_default"
						name="button2"
						x="0.4h" y="0.5h"
						width="13.0h" height="2.4h"
						label="general_set_default"
						onclick="Trigger('compendium_guideSetAsDefault', 1);"
						enabled="true"
						watch="compendium_guideDefaultFormResult"
						ontrigger="
						If(param2 and compendium_guideDefaultFormStatus == 2 and (compendium_guide_masterQueryTime == param4),
							If(StringEquals(param1, '1') and param2, Split(SetVisible(0), Call('compendium_guide_button_undefault', 'SetVisible(1)')))
						);
						"	
						watch2="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal"
						ontrigger2="							
						If((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19, 
							If(!param14, Split(SetVisible(1), Call('compendium_guide_button_undefault', 'SetVisible(0)')))
						);								
						"
						watch1="compendium_guideMasterStatus"
						ontrigger1="SetEnabled(param != 1);"						
					/>				
					<instance interactive="false"
						button_name="compendium_guide_button_undefault"
						name="button2"
						x="0.4h" y="0.5h"
						width="13.0h" height="2.4h"
						label="guide_remove_default"
						onclick="Trigger('compendium_guideSetAsDefault', 0);"
						enabled="true"
						watch="compendium_guideDefaultFormResult"
						ontrigger="
						If(param2 and compendium_guideDefaultFormStatus == 2 and (compendium_guide_masterQueryTime == param4),
							If(StringEquals(param1, '0') and param2, Split(SetVisible(0), Call('compendium_guide_button_default', 'SetVisible(1)')))
						);
						"		
						watch2="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal"
						ontrigger2="							
						If((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19, 
							If(param14, Split(SetVisible(1), Call('compendium_guide_button_default', 'SetVisible(0)')))
						);"	
						watch1="compendium_guideMasterStatus"
						ontrigger1="SetEnabled(param != 1);"						
					/>	
					
					<!-- Favorite -->
					<instance  interactive="false"
						button_name="compendium_guide_button_favorite"
						name="button2"
						x="0.4h" y="3.4h"
						width="13.0h" height="2.4h"
						label="general_addto_fav"
						onclick="Trigger('compendium_guideAddToFavorites', 1);"
						enabled="true"
						watch="compendium_guideFavoriteFormResult"
						ontrigger="
						If(param2 and compendium_guideFavoriteFormStatus == 2 and (compendium_guide_masterQueryTime == param4), 
							If(StringEquals(param1, '1') and param2, Split(SetVisible(0), Call('compendium_guide_button_unfavorite', 'SetVisible(1)')))
						);
						"	
						watch2="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal"
						ontrigger2="	
						If((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19, 
							If(!param13, Split(SetVisible(1), Call('compendium_guide_button_unfavorite', 'SetVisible(0)')))
						);"		
						watch1="compendium_guideMasterStatus"
						ontrigger1="SetEnabled(param != 1);"
					/>
					
					<instance  interactive="false"
						button_name="compendium_guide_button_unfavorite" visible="0"
						name="button2"
						x="0.4h" y="3.4h"
						width="13.0h" height="2.4h"
						label="guide_remove_favorite"
						onclick="Trigger('compendium_guideAddToFavorites', 0);"
						enabled="true"
						watch="compendium_guideFavoriteFormResult"
						ontrigger="
						If(param2 and compendium_guideFavoriteFormStatus == 2 and (compendium_guide_masterQueryTime == param4),
							If(StringEquals(param1, '0') and param2, Split(SetVisible(0), Call('compendium_guide_button_favorite', 'SetVisible(1)')))
						);
						"	
						watch2="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal"
						ontrigger2="							
						If((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19, 
							If(param13, Split(SetVisible(1), Call('compendium_guide_button_favorite', 'SetVisible(0)')))
						);"	
						watch1="compendium_guideMasterStatus"
						ontrigger1="SetEnabled(param != 1);"						
					/>
					 
					<!-- Voting -->
					<panel name="learnatorium_guidePopularity" x="14.3h" width="16.8h" height="4.2h" valign="center">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 0 .75"/>
						<frame texture="/ui/frames/roundframe.tga" color=".2 .2 .2 1" borderthickness="0.4h"/>				
						<!-- Current -->
						<label y="8%" width="100%" height="100%" textvalign="top" textalign="center" font="dyn_9" color=".8 .8 .8 1" noclick="true" content="game_guide_popularity" />
						<label name="compendium_guide_pop_display_label" y="34%" width="100%" height="100%" textvalign="top" textalign="center" font="dyn_16" color="0.7 0.7 0.7 1" noclick="true" content="N/A" />					
						<!-- Up -->
						<instance name="compendium_guide_vote_btn" thumbs="up" x="0.3h" align="left" texture="vote_up.tga" label="game_guide_vote_up" 
							onclick="
								if(compendium_guideMasterStatus != 1,
									Split(							
										Trigger('compendium_guideMasterQuery', 'compendium_guideVoteForm', HostTime),
										SubmitForm('compendium_guideVoteForm', 'f', 'guide_vote', 'account', GetAccountID(), 'cookie', GetCookie(), 'v', 1, 'compendium_guide', compendium_guide_selectedcompendium_guide, 'gid', compendium_guide_selectedcompendium_guide, 'hosttime', HostTime)
									)
								);"
							watch="compendium_guideVoteFormResult"
							ontrigger="
							If(compendium_guideVoteFormStatus == 2  and param3, 
								If(StringEquals(param1, '1'), 
									Split(
										Call('compendium_guide_vote_thumbs_up_button', 'SetEnabled(0);'),
										Call('compendium_guide_vote_thumbs_down_button', 'SetEnabled(1);'),
										GroupCall('compendium_guide_vote_thumbs_up', 'SetRenderMode(\'grayscale\');'),
										GroupCall('compendium_guide_vote_thumbs_down', 'SetRenderMode(\'normal\');')
									),
									If(StringEquals(param1, '0'), 
										Split(
											Call('compendium_guide_vote_thumbs_up_button', 'SetEnabled(1);'),
											Call('compendium_guide_vote_thumbs_down_button', 'SetEnabled(0);'),
											GroupCall('compendium_guide_vote_thumbs_up', 'SetRenderMode(\'normal\');'),
											GroupCall('compendium_guide_vote_thumbs_down', 'SetRenderMode(\'grayscale\');')
										)
									)
								)
							);
							"
							watch1="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal" 
							ontrigger1="
							If(!StringEmpty(param18) and ((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19),
								Split(
									If(StringEquals(param16, '1'), 
										Split(
											GroupCall('compendium_guide_vote_thumbs_up', 'SetRenderMode(\'grayscale\');'),
											GroupCall('compendium_guide_vote_thumbs_down', 'SetRenderMode(\'normal\');'),
											Call('compendium_guide_vote_thumbs_down_button', 'SetEnabled(1); '),
											Call('compendium_guide_vote_thumbs_up_button', 'SetEnabled(0); ') 
											)
										),
									If(StringEquals(param16, '0'), 
										Split(
											GroupCall('compendium_guide_vote_thumbs_up', 'SetRenderMode(\'normal\');'),
											GroupCall('compendium_guide_vote_thumbs_down', 'SetRenderMode(\'grayscale\');'),						
											Call('compendium_guide_vote_thumbs_down_button', 'SetEnabled(0); '), 
											Call('compendium_guide_vote_thumbs_up_button', 'SetEnabled(1); ')
										)
									)
								)
							);
							"
							watch2="compendium_guideLoadcompendium_guide"
							ontrigger2="GroupCall('compendium_guide_vote_thumbs_up', 'SetRenderMode(\'normal\');'); Call('compendium_guide_vote_thumbs_up_button', 'SetEnabled(1);');"
						/>		
						<!-- Down -->
						<instance name="compendium_guide_vote_btn" thumbs="down" x="-0.3h" align="right" texture="vote_down.tga" label="game_guide_vote_down" 
							onclick="
								if(compendium_guideMasterStatus != 1,
									Split(
										Trigger('compendium_guideMasterQuery', 'compendium_guideVoteForm', HostTime),
										SubmitForm('compendium_guideVoteForm', 'f', 'guide_vote', 'account', GetAccountID(), 'cookie', GetCookie(), 'v', 0, 'compendium_guide', compendium_guide_selectedcompendium_guide, 'gid', compendium_guide_selectedcompendium_guide, 'hosttime', HostTime)
									)
								);
								"
							watch2="compendium_guideLoadcompendium_guide"
							ontrigger2="GroupCall('compendium_guide_vote_thumbs_down', 'SetRenderMode(\'normal\');'); Call('compendium_guide_vote_thumbs_down_button', 'SetEnabled(1);');"							
						/>					
						<!-- Voting in progress -->
						<panel noclick="0" width="100%" height="100%" align="left" x="0" color=".2 .2 .2 1" visible="0" watch="compendium_guideVoteFormStatus" ontrigger="If(param == 1, SetVisible(1), SleepWidget(3000, 'FadeOut(500)'));" >
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 .07 .8" />
							<frame texture="/ui/frames/roundframe.tga" color="#667788" borderthickness="0.4h"/>						
							<label y="0" x="7%" width="100%" height="100%" textvalign="center" textalign="left" font="dyn_14" color="1.0 0.8 0.0 1" noclick="true" content="Voting..." outline="1" shadow="1" />
							<animatedimage x="55%" name="compendium_guideVoteThrob" texture="/ui/elements/throb/throb.tga" noclick="true" valign="center" loop="1" fps="30" onshow="StartAnim(1);" visible="0" height="66%" width="66@" 
								watch="compendium_guideVoteFormStatus" ontrigger="SetVisible(0); If(param0 == 1, SetVisible(1), FadeOut(10));" 
							/>
							<image x="75%" name="compendium_guideVoteValid" texture="/ui/elements/check_mark.tga" color="0 0.6 0 1" align="left" valign="center" visible="0" height="66%" width="66@" 
								watch="compendium_guideVoteFormResult" ontrigger="
									If(compendium_guideVoteFormStatus == 2  and param3, 
										Split(
											SetVisible(0),
											If((StringEquals(param1, '0') or StringEquals(param1, '1')) and param3, Split(SetVisible(0), FadeIn(50), SleepWidget(3000, 'FadeOut(500)')))
										)
									);"
							/>
							<image x="75%" name="compendium_guideVoteInvalid" texture="/ui/fe2/store/closex2.tga" color="0.6 0 0 1" align="left" valign="center" visible="0" height="66%" width="66@" 
								watch="compendium_guideVoteFormResult" ontrigger="
								##
								Echo(
									'compendium_guideVoteFormResult: ' # 
									compendium_guideVoteFormStatus#' | '#
									param0 #' | '#
									param1 #' | '#
									param2 #' | '#
									param3 #' | '
								);
								##
								If(compendium_guideVoteFormStatus == 2  and param3, 
									Split(
										SetVisible(0),
										If(!(StringEquals(param1, '0') or StringEquals(param1, '1')) or !param3, Split(SetVisible(0), FadeIn(50), SleepWidget(3000, 'FadeOut(500)')))
									)
								);"
							/>
						</panel>
						<panel name="compendium_guide_usingLocalPanel" noclick="0" width="100%" height="100%" align="left" x="0" color=".2 .2 .2 1" visible="0" >
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 .07 .8" />
							<frame texture="/ui/frames/roundframe.tga" color="#667788" borderthickness="0.4h"/>				
							<instance valign ="center" align="center" height="65%"
								name="button2" button_name="unnamedButton154"
								label="Retry Web Guides"
								onclick="
									Set(compendium_guide_newRound, 1);
									Set(compendium_usage_useCache, 0); Set(compendium_guide_useCache, 0);
									Trigger('compendium_guideHeroName', compendium_heroLastViewed);															
									CallEvent('shopcompendium_guideError', 1);
									Call('compendium_no_guides', 'FadeOut(250);');
								"
								enabled="true"
								width="95%"
							/>
						</panel>					
					</panel>
		
					<!-- Create Guide -->
					<instance  interactive="false"
						name="button2"
						button_name="learnatorium_guideCreation"
						x="-0.2h"
						align="right" valign="center"
						width="11.1h" height="2.4h"
						label="tooltip_compendium_createguide2"
						onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickCreateGuide')"
						enabled="true"
					/>
				
			</panel>		
	</template>	
	
	<template name="compendium_guide_top_template">
		<panel noclick="1"
			name="hero_compendium_guide"
			float="right" padding="1.0h"
			visible="1"
		><!-- whole entire left side including ability list, although not the guide list) -->

			<panel width="61.5h" noclick="true">
				<panel height="11.2h" noclick="true">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 .08 0 .8"  noclick="1" />
					<frame texture="/ui/frames/roundframe.tga" color="#58805e" borderthickness="0.4h"  noclick="1" />
					<panel hmargin="0.5h" vmargin="0.5h">
						<label x="0.75h" font="dyn_14" color="#9ff695" outline="true" noclick="true" content="game_guide_label_intro"/>
						<label y="0h" x="-0.6h" width="10h" height="2.4h" textalign="right" align="right" font="dyn_12" color="#8aff81" content="game_guide_label_premium" outline="true"  noclick="1" visible="0"
							watch0="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal"
							ontrigger0="	
							If((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19, 
								SetVisible(param21)
							);"			
						/>
						<textbuffer noclick="0" color="invisible"  y="2h" width="-1.75h" height="-3h" x="1.25h" font="dyn_10" wrap="true" shadow="1" shadowcolor="black"
							group="compendium_guide_label_group"
							watch4="compendium_guideTextClear" ontrigger4="ClearBufferText(); SetBufferText('');"
							watch3="compendium_guideLabelEvent"
							ontrigger3="##If(IsVisible(), DoEvent()); ## SetBufferText(NormalizeLineBreaks(compendium_guide_currentIntroString));"
							content=""							
							watch0="compendium_guideInfoFormResult compendium_guideInfoFormResultLocal"
							ontrigger0="
							SetBufferText(NormalizeLineBreaks(param10));
							Set(compendium_guide_currentIntroString, param10);
							If(GetStringWrapHeight('dyn_9', NormalizeLineBreaks(param10), GetWidth()) gt GetHeight(), SetNoClick(0), SetNoClick(1));
							## If((compendium_guideInfoFormStatus == 2  and (compendium_guide_masterQueryTime == param17) and param20) or param19, 							
								Split(										
									ClearBufferText(),
									Set(compendium_guide_currentIntroString, param10),
									If(GetStringWrapHeight('dyn_9', param10, GetWidth()) gt GetHeight(), SetNoClick(0), SetNoClick(1))
								)
							); ##							
							"						
							onshow="##DoEvent();##"
							onevent="
							If(compendium_guideInfoFormStatus == 2,
								If(StringLength(compendium_guide_currentIntroString) lt 100, 
									SetBufferText(NormalizeLineBreaks(compendium_guide_currentIntroString)),
									Split(
										CreateLerp('compendium_guideIntroTextLerp', StringLength(compendium_guide_currentIntroString), compendium_guide_lerptime * compendium_animSpeedMult, 0, 1),
										SleepWidget(compendium_guide_lerptime * compendium_animSpeedMult, 'CreateLerp(\'compendium_guideIntroTextLerp\', 0, 1, 0, -1)')
									)
								)
							);
							"
							watch1="compendium_guideIntroTextLerpTrigger"
							ontrigger1="
								If(param gt 0,
									SetBufferText(
										NormalizeLineBreaks(SubString(compendium_guide_currentIntroString, 0, param-15)#'^751'#SubString(compendium_guide_currentIntroString, param-15, 15))
									),
									SetBufferText(NormalizeLineBreaks(compendium_guide_currentIntroString))
								);
							"	
							scrolltexture="/ui/info/combobox.tga"
							handleheight="1.8h"
							scrollbarsize="1.8h"
							scrollbarplaceholder="false"
							exteriorscrollbars="false"
							textalign="left"
							textcolor="white"					
						/>		
					</panel>
				</panel>

				<!-- Recommended Items -->
				<panel name="guide_main_recommended_panel" height="-17.35h" y="11.45h" noclick="true"
					onshow="DoEvent();"
					onevent="Trigger('GuideRecommendedEvent');"
				>
					<instance name="compendiumGuideItemSection" title="game_guide_reco_3" bodyA="compendiumGuideRecommendedSectionBody" bodyB="compendiumGuideRecommendedSectionBody" panel1="1" panel2="2" watch1="compendium_guideInfoFormResultExplodeItemsStart" watch2="compendium_guideInfoFormResultExplodeItemsLaning"/>
					<instance name="compendiumGuideItemSection" title="game_guide_reco_5" titleA="game_guide_reco_7" titleB="game_guide_reco_8" align="right" bodyA="compendiumGuideRecommendedSectionBody" bodyB="compendiumGuideRecommendedSectionBody" panel1="3" panel2="4" watch1="compendium_guideInfoFormResultExplodeItemsCore" watch2="compendium_guideInfoFormResultExplodeItemsLux"/>
				</panel>
			</panel>




			
			
			<!-- Ability Order -->
			<panel noclick="1"
				width="11.5h"
				visible="true"
				onshow="Trigger('compendium_guideAbilityEvent');"
			>
				
				<panel name="compendium_guide_ability_panel_1" x="-6%" width="49.0%" align="left" float="bottom" padding="0.2h"  noclick="1" >
					<instance name="compendium_guide_ability_lvl" id="1" />
					<instance name="compendium_guide_ability_lvl" id="2" />
					<instance name="compendium_guide_ability_lvl" id="3" />
					<instance name="compendium_guide_ability_lvl" id="4" />
					<instance name="compendium_guide_ability_lvl" id="5" />
					<instance name="compendium_guide_ability_lvl" id="6" />
					<instance name="compendium_guide_ability_lvl" id="7" />
					<instance name="compendium_guide_ability_lvl" id="8" />
					<instance name="compendium_guide_ability_lvl" id="9" />
					<instance name="compendium_guide_ability_lvl" id="10" />
					<instance name="compendium_guide_ability_lvl" id="11" />
					<instance name="compendium_guide_ability_lvl" id="12" />
					<instance name="compendium_guide_ability_lvl" id="13" />
				</panel>						
				<panel name="compendium_guide_ability_panel_2" x="-6%" width="49.0%" align="right" float="bottom" padding="0.2h"  noclick="1">
					<instance name="compendium_guide_ability_lvl" id="14" />
					<instance name="compendium_guide_ability_lvl" id="15" />
					<instance name="compendium_guide_ability_lvl" id="16" />
					<instance name="compendium_guide_ability_lvl" id="17" />
					<instance name="compendium_guide_ability_lvl" id="18" />
					<instance name="compendium_guide_ability_lvl" id="19" />
					<instance name="compendium_guide_ability_lvl" id="20" />
					<instance name="compendium_guide_ability_lvl" id="21" />
					<instance name="compendium_guide_ability_lvl" id="22" />
					<instance name="compendium_guide_ability_lvl" id="23" />
					<instance name="compendium_guide_ability_lvl" id="24" />
					<instance name="compendium_guide_ability_lvl" id="25" />				
				</panel>
				
			</panel>	

		</panel>

		<!-- Space to get the compendium_guide errors filled out -->
		<panel noclick="1"
			y="6.8h"
			align="right"
			x="-0.25h"
			width="-1h"
			height="-2h"
			float="right" padding="1.0h"
			visible="true"
			onload="
				CreateString('_compendium_guideErrorString', '');
			"
			name="herocompendium_guideErrorDisplay"
			onevent0="
				If(
					!IsVisibleSelf(),
					SetVisible(1)
				);
				
			"
			onevent1="
				If(
					IsVisibleSelf(),
					SetVisible(0)
				);
			"
			
			watch="compendium_guideListFormStatus compendium_guideInfoFormStatus"
			ontrigger="if(param0 == 3 and IsVisible('hero_compendium_guide'), Split(Call('compendium_guide_error_popup_label', 'SetText(Translate(\'mstore_error_connect\'));'), CallEvent('shopcompendium_guideError', 0)));"					
			
		>
		
			<!-- Error popup and background-darking panel -->
			<panel color="0 0 0 0.0"
				name="shopcompendium_guideError"
				visible="false"
				onevent0="FadeIn(150 * compendium_animSpeedMult);"
				onevent1="FadeOut(150 * compendium_animSpeedMult);"
			>
				<panel color="0 0 0 0.5" grow="true" regrow="true" width="35h" align="center" valign="center">
					<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
					<panel grow="true" regrow="true" width="100%" float="bottom">
						<instance name="header_bar" width="100%" height="2.8h" lbl="mstore_error_generic" lbl_font="dyn_11" show_close="1" onclick="CallEvent('shopcompendium_guideError', 1);" />
						<panel height="0.5h"/>

						<panel width="100%" grow="true" regrow="true">
							<panel align="center" width="-1h" grow="true" regrow="true" color="black">
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
								<panel float="bottom" width="100%" grow="true" regrow="true">
									<panel height="0.5h"/>
									<panel grow="true" regrow="true" width="100%">
										<label name="compendium_guide_error_popup_label" fity="true" font="dyn_10" color="white" wrap="true" width="-1h" align="center"
											watch="compendium_guideMasterQuery"
											ontrigger="
												SetWatch(1, param0 # 'Status');
												SetWatch(2, param0 # 'Result');
											"
											ontrigger1="
												If(
													param == 3,
													DoEvent(9)
												);
											"
											ontrigger2="
												If(
													!StringEmpty(param0) and param0 != 0,
													Set('_compendium_guideErrorString', '')
												);
												
												If(
													!StringEmpty(param0) and param0 != 0,
													ExplodeTrigger('buildcompendium_guideErrorString', param0, '|')
												);
												
												If(
													!StringEmpty(param0) and param0 != 0,
													Split(
														SetText(FormatStringNewLine(_compendium_guideErrorString)),
														CallEvent('shopcompendium_guideError', 0)
													)
												);
											"
											watch3="buildcompendium_guideErrorString"
											ontrigger3="
												Set(
													'_compendium_guideErrorString', _compendium_guideErrorString #
													If(
														!StringEmpty(_compendium_guideErrorString),
														'\\n',
														''
													) #
													Translate(param1)
												)
											"
											onevent9="
												SetText(Translate('mstore_error_connect'));
												CallEvent('shopcompendium_guideError', 0);
											"
										/>
									</panel>
									<panel height="0.5h"/>
									<panel height="2.5h">
										<panel align="center" grow="true" height="100%" float="right" padding="1h">

											<instance
												name="button2" button_name="unnamedButton155"
												label="general_retry"
												onclick="
													Set(compendium_guide_newRound, 1);
													Set(compendium_usage_useCache, 0); Set(compendium_guide_useCache, 0);
													Trigger('compendium_guideHeroName', compendium_heroLastViewed);															
													CallEvent('shopcompendium_guideError', 1);
													Call('compendium_no_guides', 'FadeOut(250);');
												"
												enabled="true"
												width="7h"
											/>
											<instance
												name="button2" button_name="unnamedButton156"
												label="game_guide_label_getFeatured"
												onclick="
													Trigger('compendium_guideLoadFeatured');
													CallEvent('shopcompendium_guideError', 1);
												"
												enabled="true"
												width="14h"
											/>

										</panel>
									</panel>	
									<panel height="0.75h"/>

								</panel>
							</panel>
						</panel>
						
						<panel height="0.5h"/>
					</panel>
				</panel>
			</panel>
		</panel>
		
	</template>
	
	<template name="compendium_item_instance">
		<panel name="compendium_item_instance{id}" width="15.7h" height="7h" valign="center" color="invisible"
			onclicklua="HoN_Learner:SelectItem(self)"
		>
			<panel noclick="1" align="center">
				
				<frame name="compendium_item_instance{id}texture" texture="/ui/frames/tooltip_bg.tga" color=".28 .28 .28 .62" borderthickness=".25h" noclick="1" />
				
				<frame name="compendium_item_instance{id}frame" noclick="1" visible="1"
					texture="/ui/frames/roundframe.tga" 
					bordercolor=".09 .09 .14 .28"
					color="#A0A0A0"
					borderthickness=".6h" 
				/>
				
				<image name="compendium_item_instance{id}glow"
					noclick="1" color=".8 .8 .9 .35" texture="/ui/fps/selected.tga" 
					visible="0" x="3" y="3" width="-6" height="-6"
				/>
				
				<panel noclick="1" height="2h" x="0.1h" y="0.3h" width="95%" align="center">
					<label name="item_label_{id}" font="dyn_10" content="{itemname}" color="white" x=".3h" y=".2h" noclick="1"
						oninstantiatelua="local iName = tostring(self:GetText())
							if string.len(iName) > 20 then
								self:SetFont('dyn_9')
							end
						"
					/>
					<frame noclick="1" bordercolor="1 0 0 .2" color="invisible" borderthickness="1" visible="0" />
				</panel>
				<image noclick="1" texture="{texture=/heroes/dwarf_magi/icon.tga}" width="3.7h" height="3.7h" align="left" valign="bottom" x=".6h" y="-.6h" />
				<panel noclick="1" color="invisible" align="right" valign="bottom" width="55%" height="40%" y="-1h" x="-2h">
					<label noclick="1" name="item_gold_{id}" content="{gold}" font="dyn_10" align="right" valign="center" textalign="right" textvalign="center" color="white" />
				</panel>
				<image noclick="1" texture="/ui/fe2/store/gold_coins.tga" width="1.5h" height="1.5h" valign="center" align="right" x="-.4h" y="1.2h" />
			</panel>
		</panel>
	</template>
	
	<template name="compendium_item_tabinstance">
		<panel name="compendium_item_tabframe_{shoptype}" height="{height=2.6h}" y="{y}" width="90%" align="center" noclick="1">
			<panel noclick="1" visible="{visible=1}">
				<image texture="/ui/common/new_shop_interface/listing_bgx.tga" color="{framecolor1}" noclick="1" />
				<frame name="compendium_item_tabframe_{shoptype}frame" color="invisible" borderthickness="1" bordercolor="1 1 1 .05" noclick="1" />
			</panel>
			<label content="{titlename}" visible="{title=0}" noclick="1"
				align="center" valign="center"
				textalign="center" textvalign="center"
				color="#ffa905" font="dyn_14"
				shadow="1" shadowoffset="1" outline="1" outlinecolor="0 0 0 .8"
			/>
			<panel visible="{visible=1}"
				onclicklua="HoN_Learner:ItemPopulate('{shoptype}')"
				onmouseoverlua=
				"	
					local function bColor()
						if tonumber({cat}) == 1 then
							return '#226038'
						else
							return '#245469'
						end
					end
					
					local frameW = GetWidget('compendium_item_tabframe_{shoptype}frame')
					if tostring('{shoptype}') ~= tostring(HoN_Learner.currentItemTab) then
						PlaySound('/shared/sounds/ui/button_over_01.wav')
						frameW:SetBorderColor(bColor())
					end
				"
				onmouseoutlua=
				"
					local frameW = GetWidget('compendium_item_tabframe_{shoptype}frame')
					if tostring('{shoptype}') ~= tostring(HoN_Learner.currentItemTab) then
						frameW:SetBorderColor('1 1 1 .05')
					end
				"
			/>
			<frame noclick="1" bordercolor="1 1 1 .17" borderthickness="1" x=".3h" width="2.1h" height="2.1h" align="left" valign="center" visible="{visible=1}">
				<image texture="{icon}" width="90%" height="90%" align="center" valign="center" />
			</frame>
			<label content="{shoptype}" visible="{visible=1}"
				align="center" valign="center"
				textalign="left" textvalign="center"
				color="white" font="dyn_10"
				noclick="1" x="3.0h"
				watch="EntityDefinitionsLoaded"
				ontriggerlua="self:SetText(GetEntityDisplayName(self:GetText()))"
			/>
		</panel>
	</template>
	
	<template name="compendium_item_tabs">
		<panel noclick="1" width="{width=15h}" height="100%" valign="center" visible="{visible}">
			
			<panel name="compendium_tabinstance_collection" noclick="1" float="bottom" padding=".7h" y=".5h">
				<instance name="compendium_item_tabinstance" shoptype="Dummy_Space1" visible="0" title="1" titlename="game_shop_label_components" height="3.0h" />
				<instance name="compendium_item_tabinstance" cat="1" shoptype="Shop_Supplies" icon="/items/shops/shop_supplies.tga" framecolor1="#112016" />
				<instance name="compendium_item_tabinstance" cat="1" shoptype="Shop_Accessories" icon="/items/shops/shop_accessories.tga" framecolor1="#112016" />
				<instance name="compendium_item_tabinstance" cat="1" shoptype="Shop_Weapons" icon="/items/shops/shop_weapons.tga" framecolor1="#112016" />
				<instance name="compendium_item_tabinstance" cat="1" shoptype="Shop_Relics" icon="/items/shops/shop_relics.tga" framecolor1="#112016" />
				<instance name="compendium_item_tabinstance" cat="1" shoptype="Shop_Secret" icon="/items/shops/shop_secret.tga" framecolor1="#112016" />
				<instance name="compendium_item_tabinstance" shoptype="Dummy_Space2" visible="0" title="1" titlename="game_recipe" height="3.0h" />
				<instance name="compendium_item_tabinstance" cat="2" shoptype="Shop_Recipes1" icon="/items/shops/shop_recipes1.tga" framecolor1="#101d23" />
				<instance name="compendium_item_tabinstance" cat="2" shoptype="Shop_Recipes2" icon="/items/shops/shop_recipes2.tga" framecolor1="#101d23" />
				<instance name="compendium_item_tabinstance" cat="2" shoptype="Shop_Recipes3" icon="/items/shops/shop_recipes3.tga" framecolor1="#101d23" />
				<instance name="compendium_item_tabinstance" cat="2" shoptype="Shop_Recipes4" icon="/items/shops/shop_recipes4.tga" framecolor1="#101d23" />
				<instance name="compendium_item_tabinstance" cat="2" shoptype="Shop_Recipes5" icon="/items/shops/shop_recipes5.tga" framecolor1="#101d23" />
			</panel>
			
			<frame noclick="1" bordercolor="gray" color="invisible" borderthickness="1" visible="0" />
		</panel>
	</template>
	
	<template name="compendium_component_instance">
		<!-- Item -->
		<image name="compendium_detailed_component_{id}" texture="$invis" x="{x=0h}" y="{y=0h}" align="center" valign="center"
			watch="compendium_detailed_component_{id}_trigger"
			ontriggerlua=
			"
				local solutionTexture = tostring(GetWidget('compendium_detailed_itemicon'):GetTexture())
				self:SetTexture(solutionTexture)
				self:SetWidth('50%')
				self:SetHeight('50%')
			"
		/>
		<!-- Item Frame (doesnt show for recipies) -->
		<image name="compendium_detailed_component_{id}_frame" texture="/ui/common/ability_frame_devowars.tga" noclick="1"
			x="{x=0h}" y="{y=0h}" align="center" valign="center" visible="0"
			width="160%" height="160%" 
		/>
		
		<!-- Scroll Image -->
		<image name="compendium_detailed_component_{id}_recipe" texture="/ui/elements/shop/scroll_overlay.tga" 
			x="{x=0h}" y="{y=0h}" align="center" valign="center" visible="0"
			watch="compendium_detailed_component_{id}_trigger"
			ontriggerlua=
				"
					self:SetVisible(1)
				"
		/>
	</template>
	
	<template name="compendium_items_template">
		<!-- Header -->
		<label x="0.5h" y="-3.4h" font="dyn_18" fitx="1" fity="1" color="#ffaa00" outline="true" align="center" content="learn_items_center_title" />
		
		<!-- Refresher -->
		<panel name="learner_items_main"
			onshow="DoEvent();" color="black"
			oneventlua="UIManager.GetInterface('main'):HoNLearnerF('RefreshLearningItems')"
		/>
		
		<!-- BG -->
		<image texture="/ui/fe2/elements/compendium_item_bg.tga" valign="center" x=".15h" y="2.7h" width="1024i" height="512i" align="left" visible="1" />
		
		<!-- Main -->
		<panel noclick="1" visible="1" y=".5h">
			<panel noclick="1" float="right">
				<!-- Tabs -->
				<instance name="compendium_item_tabs" width="15%" visible="1" />
				<!-- Item List -->
				<panel name="compendium_item_rowspanel" width="63%" height="95%" noclick="1" visible="1" valign="center">
					<listbox
						name="compendium_item_listbox"
						height="95%"
						itemwidth="16.0h"
						itemheight="7.5h"
						itemheightfudge="0h"
						itemwidthfudge="0h"
						itemoffsetx=".7h"
						itemoffsety="0h"
						handleheight="3.6h"
						handlewidth="2.4h"
						scrollbarsize="16i"
						shadow="true"
						usescrollbars="true"
						scrolltexture="/ui/elements/watch_system/info/ws.tga"
						nocompress="true"
						scrollinterval="0"
						hpadding="0h"
						wrap="row"
						hoverselect="false"
						select="0"
						hoverhighlight="false"
						scrollbaroffset="-0.35h"
						color="invisible"
						watch="LearnaItemsClearList"
						ontrigger="ClearItems();"
					/>
					<frame bordercolor="green" color="invisible" borderthickness="1" noclick="1" visible="0" />
				</panel>
			</panel>
			<!-- Selection Info -->
			<panel noclick="1" visible="1" width="22%" height="100%" align="right" valign="center">
				<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" width="98%" />
				<!-- Item Title -->
				<label name="compendium_detailed_itemname" width="90%" height="2h" x="0.0h" y="2.0h" font="dyn_14" color="#ffaa00" outline="true" align="center" valign="top" content=""
					textalign="center" textvalign="center"
				/>
				<panel noclick="1" y="2h">
					<!-- Frame -->
					<panel noclick="1" name="compendium_detailed_itemicon_frame" visible="0">
						<image texture="/ui/common/new_shop_interface/left_circle_frame.tga" width="11.5h" height="11.5h" align="center" valign="top" y="3.5h" />
						<image name="compendium_detailed_itemicon" texture="$invis" width="6.5h" height="6.5h" align="center" valign="top" y="6h" />
						<image texture="/ui/common/button_gloss_up.tga" width="6.5h" height="6.5h" align="center" valign="top" y="6h" rendermode="additive" color="1 1 1 .6" />
					</panel>
					<!-- Detailed icon -->
					
				</panel>
				<label name="compendium_detailed_componentlabel" width="90%" height="2h" x="2.1h" y="-2.0h" font="dyn_12" color="#ededed" outline="true" align="left" valign="center"
					content="game_shop_label_components" textalign="left" textvalign="center" visible="0"
					onloadlua="self:SetText(self:GetText() .. ':')"
				/>
				<!-- Components -->
				<panel noclick="1" width="72%" height="12h" y="6.6h" align="center" valign="center">
					<panel noclick="1" width="4.4h" height="4.4h">
						<!-- Detailed item slots -->
						<instance name="compendium_component_instance" x="0h" y="0h" id="1" />
						<instance name="compendium_component_instance" x="6h" y="0h" id="2" />
						<instance name="compendium_component_instance" x="12h" y="0h" id="3" />
						<instance name="compendium_component_instance" x="0h" y="6h" id="4" />
						<instance name="compendium_component_instance" x="6h" y="6h" id="5" />
						<instance name="compendium_component_instance" x="12h" y="6h" id="6" />
					</panel>
				</panel>
				
			</panel>
		</panel>
		
	</template>
	
	<!-- Hero Stat Color
	modeNormal_txt, modeCasual_txt, modePublic_txt				
	-->
	<template name="hero_info_compendium_herostat_cs"> 
		<panel height="1.9h" noclick="1">
			<label width="60%" height="100%" align="left" textalign="right" textvalign="center" font="dyn_11" style="modeCasual_txt" shadow="1" content="{id}" noclick="1" />
			<label x="14%" width="100%" height="100%" textalign="center" textvalign="center" font="dyn_11" style="modeCasual_txt" shadow="1" content=":" noclick="1" />
			<label width="32%" height="100%" align="right" textalign="left" textvalign="center" font="dyn_11" color="white" shadow="1" noclick="1" content="0" watch="{resulttrigger}" ontrigger="{ontrigger}" />
		</panel>		
	</template>
	<template name="hero_info_compendium_herostat_rnk">
		<panel height="1.9h" noclick="1">
			<label width="60%" height="100%" align="left" textalign="right" textvalign="center" font="dyn_11" style="modeNormal_txt" shadow="1" content="{id}" noclick="1" />
			<label x="14%" width="100%" height="100%" textalign="center" textvalign="center" font="dyn_11" style="modeNormal_txt" shadow="1" content=":" noclick="1" />
			<label width="32%" height="100%" align="right" textalign="left" textvalign="center" font="dyn_11" color="white" shadow="1" noclick="1" content="0" watch="{resulttrigger}" ontrigger="{ontrigger}" />
		</panel>		
	</template>
	<template name="hero_info_compendium_herostat_ph">
		<panel height="1.9h" noclick="1">
			<label width="60%" height="100%" align="left" textalign="right" textvalign="center" font="dyn_11" style="modePublic_txt" shadow="1" content="{id}" noclick="1" />
			<label x="14%" width="100%" height="100%" textalign="center" textvalign="center" font="dyn_11" style="modePublic_txt" shadow="1" content=":" noclick="1" />
			<label width="32%" height="100%" align="right" textalign="left" textvalign="center" font="dyn_11" color="white" shadow="1" noclick="1" content="0" watch="{resulttrigger}" ontrigger="{ontrigger}" />
		</panel>		
	</template>	

	<template name="compendium_herostats_ph_template">
		<panel name="compendium_herostats_ph" group="compendium_herostats" visible="{visible=0}" >	
			
			<panel noclick="1" float="bottom" padding="0.3h" >
				<panel width="100%" height="0.8h">
					<panel y="0.1h" width="100%" height="1" valign="top" color=".2 .2 .2 1" />
				</panel>
				<panel height="5.0h">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="#1f1f1f" noclick="1"/>
					<frame texture="/ui/frames/roundframe.tga" borderthickness="0.6h" color="#666666" noclick="1" />						
					<panel y="0.5h" width="100%" height="2h" float="right">
						<label width="32%" style="{style=modeNormal_txt}" color="#ffab01" shadow="1" font="dyn_11" textvalign="top" textalign="center" noclick="1" content="player_stats_wins"/>
						<label width="32%" style="{style=modeNormal_txt}" color="#ffab01" shadow="1" font="dyn_11" textvalign="top" textalign="center" noclick="1" content="player_stats_losses"/>
						<label width="36%" style="{style=modeNormal_txt}" color="#ffab01" shadow="1" font="dyn_11" textvalign="top" textalign="center" noclick="1" content="compendium_win_percent"/>
					</panel>
					<panel y="2.5h" width="100%" height="2h" float="right">
						<label width="33.3%" color="1 1 1 1" shadow="1" font="dyn_11" textvalign="top" textalign="center" noclick="1" watch="HeroStatsResult" ontrigger="SetText(Round(param129));" content=""/>
						<label width="33.3%" color="1 1 1 1" shadow="1" font="dyn_11" textvalign="top" textalign="center" noclick="1" watch="HeroStatsResult" ontrigger="SetText(Round(param130));" content=""/>
						<label width="33.3%" color="1 1 1 1" shadow="1" font="dyn_11" textvalign="top" textalign="center" noclick="1" watch="HeroStatsResult" ontrigger="SetText(FtoP((param129/(param129+param130)), 1  ));" content=""/>
					</panel>
				</panel>
				<panel height="0" />	
				
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(FtoA2(param143/param128, 0, 2));" name="hero_info_compendium_herostat_ph" id="player_stats_kills" labeltextcolor="{color=#3abde7}" />
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(FtoA2(param148/param128, 0, 2));" name="hero_info_compendium_herostat_ph" id="player_stats_deaths" labeltextcolor="{color=#3abde7}" />
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(FtoA2(param147/param128, 0, 2));" name="hero_info_compendium_herostat_ph" id="player_stats_assists" labeltextcolor="{color=#3abde7}" />
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="If(param148 gt 0, SetText(FtoA2(param143/param148, 0, 2)), SetText(FtoA2(param143, 0, 2)));" name="hero_info_compendium_herostat_ph" id="player_stats_kd_ratio" labeltextcolor="{color=#3abde7}" />					
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="If(param148 gt 0, SetText(FtoA2((param143+param147)/param148, 0, 2)), SetText(FtoA2((param143+param147), 0, 2)));" name="hero_info_compendium_herostat_ph" id="player_stats_kad_ratio" labeltextcolor="{color=#3abde7}" />					
				<panel width="100%" height="0.8h">
					<panel y="0.1h" width="90%" height="1" align="center" valign="center" color=".2 .2 .2 1" />
				</panel>
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param151/param128));" name="hero_info_compendium_herostat_ph" id="player_avg_creep_kills" labeltextcolor="{color=#3abde7}" />
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param163/param128));" name="hero_info_compendium_herostat_ph" id="player_avg_creep_denies" labeltextcolor="{color=#3abde7}" />
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param155/param128));" name="hero_info_compendium_herostat_ph" id="player_stats_neutral_creeps" labeltextcolor="{color=#3abde7}" />	
				<panel width="100%" height="0.8h">
					<panel y="0.1h" width="90%" height="1" align="center" valign="center" color=".2 .2 .2 1" />
				</panel>
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param167/(param172/60)));" name="hero_info_compendium_herostat_ph" id="player_stats_experience_per_minute" labeltextcolor="{color=#3abde7}" />				
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param162/(param169/60)));" name="hero_info_compendium_herostat_ph" id="player_stats_gold_per_minute" labeltextcolor="{color=#3abde7}" />					
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param168/(param169/60)));" name="hero_info_compendium_herostat_ph" id="player_stats_apm" labeltextcolor="{color=#3abde7}" />
				<instance resulttrigger="HeroStatsResult" style="{style=modeNormal_txt}" base="{base=0}" ontrigger="SetText(Round(param171/param128));" name="hero_info_compendium_herostat_ph" id="player_stats_wards" labeltextcolor="{color=#3abde7}" />
				
			</panel>		
		</panel>	
	</template>	
	
	<template name="compendium_herostats_cs_template">
