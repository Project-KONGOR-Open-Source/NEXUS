			<listbox
				group="compendium_listboxes"
				name="compendium_listbox_detailed{allheroes}"
				width="-2.0h" height="-2.55h"
				color="invisible"
				font="dyn_10"
				itemwidth="100%"
				itemheight="3.15h"
				select="true"
				clearselection="true"
				hoverselect="true"
				hoverhighlight="true"
				highlight="over"
				highlightcolor="#FFFFFF33"
				highlightbordercolor="#FFFFFFFF"
				selectedcolor="#0077FF22"
				selectedbordercolor="#0077FFFF"
				backgroundimage="/ui/fe2/elements/comm_item_bg.tga"
				backgroundimagecolor="#1d2f3b"
				colortransition="true"
				colortransitiontime="250"
				exteriorscrollbars="true"
				scrollbarplaceholder="true"
				scrollbarsize="2.0h"
				scrolltexture="/ui/info/combobox.tga"
				handleheight="2.0h"
				watch1="CompendiumHeroInfo"
				ontrigger1="
				If((IsFreeHero(param0) or {allheroes=1}) and !HasListItem(param0),
					AddTemplateListItemWithSort('hero_list_item', param0,
					(param1 # ',' # param2 # ',' # param24 # ',' # param3 # ',' # param5 # ',' # param7 # ',' # param9 # ',' # ((param27+param28)/2) # ',' # param11 )
					, 'hero_name', param1, 'attribute', param2, 'strength', param3, 'strength_per_level', param4, 'agility', param5, 'agility_per_level', param6, 'intelligence', param7, 
					'intelligence_per_level', param8, 'armor', param9, 'atk_dmg_min', Ceil(param27), 'atk_dmg_max', Ceil(param28), 'movespeed', param11, 'mindamage', param12, 'maxdamage', param13, 
					'hero_icon', param14, 'ability_0_icon', param15, 'ability_1_icon', param16, 'ability_2_icon', param17, 'ability_3_icon', param18, 'attribute_icon', param19, 'armor_percent', 
					param20, 'magic_armor_percent', param21, 'DPS', param22, 'attack_range', param23, 'attack_type_icon', param24, 'faction', param25, 
					'ownership', param29, 'cost', param30, 'purchasable', param31, 'premium', param32, 'premiumsilvercost', param33,
					'eap', IsEarlyAccessHero(param0), 'free', IsFreeHero(param0), 'haseap', CanAccessEarlyAccessProduct(param0), 'value', param0, 'magicarmor', param10
					)
				);
				If((IsFreeHero(param0) or {allheroes=1}), SleepWidget(100, 'Call(\'compendium_listbox_detailed{allheroes}\', \'SortListboxSortIndex(0);\');'));
				"
				watch2="CompendiumClearInfo"
				ontrigger2="ClearItems();"
				onselect="If(IsVisible(), PlaySound('/shared/sounds/ui/button_click_01.wav'));  ShowHeroCompendiumInfo(this); Set(compendium_heroLastViewed, this);  SetSave('compendium_heroLastViewed');##"
				onselectlua="UIManager.GetInterface('main'):HoNLearnerF('ClickHero', self:GetValue())"
			>
			</listbox>
		</panel>
	
	</template>

