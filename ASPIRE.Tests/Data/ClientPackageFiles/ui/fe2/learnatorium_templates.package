<?xml version="1.0" encoding="UTF-8"?>
<package>
	
	<template name="learner_rotator">
		<button
			color="invisible"
			width="{width}" height="{height}"
			align="{align}" valign="{valign}"
			x="{x}" y="{y}"
			onmouseluplua="{onmouseluplua}" onmouseldownlua="{onmouseldownlua}" onmouserdownlua="{onmouseldownlua}" onmouseruplua="{onmouseluplua}"
			ondoubleclicklua="{ondoubleclicklua}"
		>
			<widgetstate statename="up">
				<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
				<image texture="/ui/fe2/elements/rotation_up.tga" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>
		
			<widgetstate statename="over">
				<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
				<image texture="/ui/fe2/elements/rotation_over.tga" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>		
			
			<widgetstate statename="down" x="1" y="1">
				<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>					
				<image texture="/ui/fe2/elements/rotation_over.tga" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>
			<widgetstate statename="disabled">
				<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>	
				<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
				<image texture="/ui/fe2/elements/rotation_up.tga" rendermode="grayscale" hflip="{hflip=false}" align="center" valign="center" width="-1h" height="-1h"/>
			</widgetstate>
		</button>
	</template>



	<template name="compendiumGuideRecommendedSectionBody">
		<panel height="50%" align="center">
			<panel float="right" height="-0.1h" padding="0.1h">
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
			</panel>
			<panel name="guide_recommended_panel_{panel}_1" float="right" height="-0.1h" padding="0.1h">
				<instance name="compendium_guide_recommended_item" id="1" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
				<instance name="compendium_guide_recommended_item" id="2" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
				<instance name="compendium_guide_recommended_item" id="3" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
				<instance name="compendium_guide_recommended_item" id="4" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
			</panel>
		</panel>
		<panel height="50%" align="center" valign="bottom">
			<panel float="right" height="-0.1h" padding="0.1h" valign="bottom">
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
				<image texture="/ui/common/empty_pack.tga" width="100@" height="100%"/>
			</panel>
			<panel name="guide_recommended_panel_{panel}_2" float="right" height="-0.1h" valign="bottom" padding="0.1h">
				<instance name="compendium_guide_recommended_item" id="5" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
				<instance name="compendium_guide_recommended_item" id="6" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
				<instance name="compendium_guide_recommended_item" id="7" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
				<instance name="compendium_guide_recommended_item" id="8" watch="{watch}" watch1="GuideRecommendedItemUpdate" panel="{panel}" />
			</panel>
		</panel>
	</template>

	<template name="compendiumGuideItemSectionGroup">
		<panel width="17.5h" height="9h" align="center" y="{y}" noclick="true">
			<panel height="2h" grow="true" align="center" valign="bottom" y="-100%" float="right" noclick="true">
				<label textvalign="center" fitx="true" color="#ffcd16" font="dyn_10" fitxpadding="0.25h" content="{title}"/>
				<panel width="100@" height="100%" noclick="true">
					<instance name="tip_mark" width="90@" height="90%" align="center" valign="center"
						onmouseoverlua="
							Trigger('genericMainFloatingTip', 'true', '26h', '', '{title}', '{title}_tip', '', '', '', '')
						"
						onmouseoutlua="
							Trigger('genericMainFloatingTip', '', '', '', '', '', '', '', '', '', '', '', '', '', '', '', '', '', '', '')
						"
					/>
				</panel>
			</panel>
			<frame texture="/ui/frames/thick.tga" color="#555459" borderthickness="0.5h"/>
			<panel hmargin="0.25h" vmargin="0.25h" name="guide_recommended_panel_{panel}">
				<instance name="{body}" panel="{panel}" watch="{watch}"/>
			</panel>
		</panel>
	</template>

	<template name="compendiumGuideItemSection">
		<panel width="50%" noclick="true" align="{align=left}">
			<panel width="-0.25h" align="{align=left}">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" color="0 0 .07 .8"  noclick="1" />
				<frame texture="/ui/frames/roundframe.tga" color="#667788" borderthickness="0.4h"  noclick="1" />
				<panel hmargin="0.5h" vmargin="0.5h" noclick="true">
					<label x="0.75h" font="dyn_12" color="#aa81ff" noclick="true" content="{title=game_guide_reco_3}"/>

					<instance name="compendiumGuideItemSectionGroup" title="{titleA=game_guide_reco_1}" y="3.75h" body="{bodyA}" watch="{watch1}" panel="{panel1}"/>
					<instance name="compendiumGuideItemSectionGroup" title="{titleB=game_guide_reco_6}" y="15.5h" body="{bodyB}" watch="{watch2}" panel="{panel2}"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="compendium_usage_hero_box" >
		
		<panel noclick="1" height="14.2h" width="16.75%" color="0 1 1 0.0"  group="compendium_hero_usage_list_boxes" onevent1="" onevent2="" onevent3="DestroyWidget();" >
			<panel noclick="1" x="0.1h" align="left" valign="top" height="97%" width="97%" color="1 1 0 0.0" >
			
				<instance name="herodex_header_bar" height="2.4h" valign="top" label_y="-0.2h" oninstantiate="SetText('^o{index} ^*' # GetEntityDisplayName('{hero}'));" show_close="false" />
				
				<panel noclick="1" height="-2.6h" valign="bottom"  >				
					<frame color="invisible" bordercolor="0.3 0.3 0.3 1" borderthickness="1" blockinput="false" noclick="true"/>
					
					<panel width="-0.8h" align="center" noclick="1" float="right" padding="3%" >
						<panel align="left" valign="top" noclick="true" padding=".25h" height="35@" width="35%" >											
							<frame y="0.4h" noclick="0" align="center" visible="1" color="invisible" bordercolor="0.3 0.3 0.3 1.0" borderthickness="1"  > 
								<image height="-2" width="-2" noclick="true" align="center" valign="center" oninstantiate="SetTexture(GetEntityIconPath('{hero}'));" group="compendium_tab_button_icon_{icongroup}" />
							</frame>	
						</panel>
						<panel height="100%" width="-38%" align="left">
							<panel y="0.5h" width="100%" height="100%" float="bottom">
								<label height="1.6h" color="#3abde7" shadow="1" font="dyn_11" textvalign="top" textalign="left" noclick="1" content="player_stats_used"/> 
								<label height="1.8h" color="1 1 1 1" shadow="1" font="dyn_10" textvalign="top" textalign="left" noclick="1" content="{total_use} ({use}%)" oninstantiate="SetText(FtoA({total_use}, 0, 0, ',') #' ('# FtoA2({use}, 0, 1)#'%)' );" />

								<label height="1.6h" color="#3abde7" shadow="1" font="dyn_11" textvalign="top" textalign="left" noclick="1" content="player_stats_wins"/> 
								<label height="1.8h" color="1 1 1 1" shadow="1" font="dyn_10" textvalign="top" textalign="left" noclick="1" content="{total_win} ({win}%)" oninstantiate="SetText(FtoA({total_win}, 0, 0, ',') #' ('# FtoA2({win}, 0, 1)#'%)' );" />
								
								<label height="1.6h" color="#3abde7" shadow="1" font="dyn_11" textvalign="top" textalign="left" noclick="1" content="player_stats_losses"/> 
								<label height="1.6h" color="1 1 1 1" shadow="1" font="dyn_10" textvalign="top" textalign="left" noclick="1" content="{total_lose} ({lose}%)"  oninstantiate="SetText(FtoA({total_lose}, 0, 0, ',') #' ('# FtoA2({lose}, 0, 1)#'%)' );" />
							</panel>

						</panel>
					</panel>
					<button noclick="0" color="invisible" 
						onclick="Set(compendium_heroLastViewed, '{hero}');  SetSave('compendium_heroLastViewed');"
						onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickHero', '{hero}')"
					/>					
				</panel>
				
			</panel>
		</panel>
			
	</template>
	
	<!-- RMM -->
	<template name="compendium_usage_list_row_template" >
		<panel noclick="1" height="15h" padding="0" group="compendium_hero_usage_list_boxes" onevent1="" onevent2="" onevent3="DestroyWidget();" >
			<panel name="compendium_usage_list_row_{id}" height="15h" noclick="1" float="right" padding="0.00h"  group="compendium_hero_usage_list_boxes" onevent1="" onevent2="DoEvent(3);" onevent3="DestroyWidget();" />		
		</panel>	
	</template>
	
	<template name="compendium_usage_list_top_row_template" >
		<panel noclick="1" height="7.5h" group="compendium_hero_usage_list_boxes" onevent1="" onevent2="" onevent3="DestroyWidget();" onshow="BringToFront();" >

			<panel noclick="1" width="-1.0h" align="center" float="right" padding="1.0h" >
				
				<label name="herodex_header_usage_list" textvalign="center" wrap="true" width="-32h" color="1 1 1 1" shadow="1" font="dyn_14" noclick="1" content="compendium_usage_list_header_2" />
				
				<panel width="2" noclick="true">
					<panel width="1" height="4.0h" valign="center" color="1 1 1 .2" />
					<panel width="1" height="4.0h" valign="center" align="right" color="0 0 0 .9" />
				</panel>
				
				<!-- Drop down  -->
				<panel noclick="1" visible="1" width="30h" 
					group="compendium_hero_usage_list_boxes" onevent1="" onevent2="" onevent3="DestroyWidget();"
				>
					<label height="100%" textvalign="center" font="dyn_12" color="white" shadow="1" content="general_sortby" noclick="1" />
					<instance name="Noptions_combobox" id="herodex_hero_usage_list_dropdown" width="20h" align="right" valign="center" itemwidth="100%"  noclick="0" visible="0"
						group="compendium_hero_usage_list_boxes" onevent1="SetVisible(1);" onevent2="SetVisible(0);" onevent3="DestroyWidget();"
						color="1.0 1.0 1.0 1" overcolor="1.0 1.0 1.0 1" downcolor="1.0 1.0 1.0 1"
						onshow="BringToFront();"
						onshowlua="UIManager.GetInterface('main'):HoNLearnerF('SetUsageSortBox', self)"
						onevent="
							AddTemplateListItem('Ncombobox_item', 'use', 'label', 'compendium_usage_sort_usage', 'font', 'dyn_10'); 
							AddTemplateListItem('Ncombobox_item', 'win', 'label', 'compendium_usage_sort_win', 'font', 'dyn_10'); 
							AddTemplateListItem('Ncombobox_item', 'loss', 'label', 'compendium_usage_sort_loss', 'font', 'dyn_10'); 
							SetVisible(1);
							## BringToFront(); ##
							"
						maxlistheight="5"  
						onselectlua="UIManager.GetInterface('main'):HoNLearnerF('SortHeroUsage', self:GetValue())"
					/>
				</panel>
			</panel>				

		</panel>
	</template>
	
	<template name="compendium_usage_list_template" >
		<panel width="100%" height="100%" visible="true" >
			<scrollbox name="compendium_usage_list_scrolbox" float="bottom"
				vscrollboxstep="4%"
				scrolltexture="/ui/info/combobox.tga"
				handleheight="1.8h"
				width="-2.0h" height="100%"
				scrollbarsize="1.8h"
				exteriorscrollbars="1"
				vscrollbar="1"
				hscrollbar="0"
				clipx="0"
				clipy="0"
				clipwidth="0"
				clipheight="0"
				scrollbaroffset="0.5h"
				clipoffsetx="0"
				clipoffsety="0"
				onslide="
					If(WidgetExists('compendium_usage_list_scrolbox_vscroll'),
						Call('compendium_usage_list_scrolbox_vscroll',
							'
							If(GetValue() gt 0,
								Call(\'compendium_usage_list_scrolbox\', \'SetVScrollbarStep(\\\'7.5h\\\'); \'),
								Call(\'compendium_usage_list_scrolbox\', \'SetVScrollbarStep(\\\'1\\\'); \')
							);
							'
						)
					);
					"
				onload="
					CreateInt('compendium_usage_list_currentHero', 0);
					CreateString('compendium_hero_usage_list_lastSuccessfulLookup', '');
				"
			>

			
			</scrollbox>
			
			<panel noclick="1" name="compendium_hero_usage_list_error" group="compendium_hero_usage_list_boxes" onevent1="SetVisible(0);" onevent2="SetVisible(1);" visible="1" >
				<label width="-10.0h" height="100%" y="-1h" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="Retrieving..." noclick="1"
					onload="CreateInt('compendium_hero_usage_list_error_random', 1);"
					onshow="Call('compendium_hero_usage_list_error_retry', 'SetVisible(0); SleepWidget(0, \'\'); SleepWidget(1500, \'SetVisible(1);\');');"
				/>
				<instance valign="center" y="2.9h"
					name="button2" x="0" button_name="compendium_hero_usage_list_error_retry"
					width="12.0h" height="2.5h"
					align="center"
					label="main_stats_retry"
					font="dyn_10"
					onclick=" CallEvent('compendium_hero_usage_list_error', 1); Set(compendium_usage_useCache, 0); Set(compendium_guide_useCache, 0); Set(compendium_guide_newRound, 1); CallEvent('submit_herousagelistform');"
				/>				
				<animatedimage y="-10h" x="0h" width="5.5h" height="5.5h" valign="center" align="center" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" visible="1"  />				
			</panel>
		</panel>
	</template>	

	<template name="column_header_nosort">
		<panel width="{width=100%}" height="{height=100%}" noclick="true">
			<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>				
			<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}" oninstantiate="if(!StringEquals('', '{image}'), HideWidget())">{label}</label>
			<image align="center" valign="center" width="100@" height="100%" texture="{image}" oninstantiate="if(StringEquals('', '{image}'), HideWidget())" />
		</panel>
	</template>

	<if condition="cg_newMainInterface">
	<template name="column_header">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true">
			<button
				group="{group}"
				name="{button_name}"
				color="invisible"
				visible="{visible=true}"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				onclick="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav}'); {onclick}"
				onenter="PlaySound('{sound='/shared/sounds/ui/ccpanel/button_click_02.wav}'); {onenter}"
				onshow="{onshow}"
				onload="{onload}"
				hotkey="{hotkey}"
				onhotkey="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav'}'); {onhotkey}"
				numstates="3"
			>
				<widgetstate statename="up">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="#FFFF00" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="#494c5f" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>

				<widgetstate statename="up2">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="over2">
					<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="down2" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="#FFFF00" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="disabled2">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="#494c5f" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>

				<widgetstate statename="up3">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
				<widgetstate statename="over3">
					<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
				<widgetstate statename="down3" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="#FFFF00" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
				<widgetstate statename="disabled3">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="left" valign="center" align="center" font="{font=dyn_9}" color="#494c5f" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="column_header_icon">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true">
			<button
				group="{group}"
				name="{button_name}"
				color="invisible"
				visible="{visible=true}"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				onclick="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav}'); {onclick}"
				onenter="PlaySound('{sound='/shared/sounds/ui/ccpanel/button_click_02.wav}'); {onenter}"
