			watch="store2TabMenuShow"
			ontriggerlua="if param == 'gamevanity' then self:SetVisible(true) end"
			watch1="store2TabMenuHide"
			ontrigger1lua="if param == 'all' or param == 'gamevanity' then self:SetVisible(false) end"
			watch2="store2VanityShow"
			ontrigger2lua="if param0 ~= '' then self:SetVisible(0) end"
			onmouseoverlua="HoN_Store:TabMenuFadeIncrease('gamevanity')"
