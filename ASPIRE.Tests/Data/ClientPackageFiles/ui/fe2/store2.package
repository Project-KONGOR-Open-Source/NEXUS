				namecolor="#b8d7ca" nameoutlinecolor="#2e4c4c" dotPanelColor="#9effff" dotPanelRenderMode="colorscale1"
				onshowlua="HoN_Store:Store2InitializeVaultUI('{vaultcategory}')"/>
