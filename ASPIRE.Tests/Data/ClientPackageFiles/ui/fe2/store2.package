				<image name="store2_vanity_frame_{cat}_{row}_{col}_owned" visible="0" noclick="1" texture="/ui/fe2/elements/store2/owned_2.png" x="-2i" y="-45i" width="32i" height="32i" align="right" valign="bottom" />

				<panel name="store2_vanity_frame_{cat}_{row}_{col}_name" align="left" valign="bottom" x='10i' y="-22i" width="128i" height="32i"
						onclicklua="HoN_Store:VanityItemOnClickAction('{cat}', {row}, {col})"
						onrightclicklua="HoN_Store:VanityItemOnRightClickAction('{cat}', {row}, {col})"
						onmouseoverlua="HoN_Store:VanityItemOnMouseOverAction('{cat}', {row}, {col})"
						onmouseoutlua="HoN_Store:VanityItemOnMouseOutAction('{cat}', {row}, {col})">
