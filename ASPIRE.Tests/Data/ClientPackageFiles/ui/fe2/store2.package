				<image name="store2_vanity_frame_{cat}_{row}_{col}_img" visible="1" width="128i" height="128i" y="0i" align="center" valign="top" noclick="1"/>
				<image name="store2_vanity_frame_{cat}_{row}_{col}_frame" texture="{texture=}" width="256i" height="256i" align="center" valign="center" noclick="1"/>
				<image name="store2_vanity_frame_{cat}_{row}_{col}_gca" texture="/ui/fe2/elements/store2/gca.png" width="64i" height="32i" align="left" valign="center" noclick="1" x="2i" y="24i" />
				<panel name="store2_vanity_frame_{cat}_{row}_{col}_frame_over" align="center" valign="center"
