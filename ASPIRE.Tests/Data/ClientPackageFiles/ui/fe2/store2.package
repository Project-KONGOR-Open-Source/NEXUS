<?xml version="1.0" encoding="UTF-8"?>
<package>

	<include file="store_promo.package"/>
	<include file="store2_templates.package"/>
	<include file="store_earlyaccess.package"/>
	<include file="store_featured.package"/>

	<include file="store2_form_namechange.package"/>
	<include file="store2_form_redeemcode.package"/>
	<include file="store2_form_buycoins.package"/>
	<if condition="cl_GarenaEnable">
		<include file="store2_form_resetstats_garena.package"/>
	</if>

	<if condition="!cl_GarenaEnable">
		<include file="store2_form_resetstats.package"/>
		<include file="store2_form_subaccount.package"/>
	</if>
	<include file="store2_popups.package"/>

	<if condition="cl_GarenaEnable">
		<include file="/content/store_avatars_sea.package"/>
	</if>
	<if condition="!cl_GarenaEnable">
		<include file="/content/store_avatars.package"/>
	</if>

	<instance name="store_avatars"/> 	<!-- should be singlecton -->

	<lua file="/ui/scripts/store.lua" />

	<cvar name="ui_isInWalkthrough" value="0" />

	<trigger name="populateHeroAvatarBundleInfo"/>
	<trigger name="UpdatePurchaseGiftForm" />
	<trigger name="vaultRefreshConfigButtons"/>
	<trigger name="vaultConfigureProduct"/>
	<trigger name="MicroStoreAddAvatarData"/>
	<trigger name="MicroStoreAvatarItem"/>
	<trigger name="MicroStoreUpdateSelection"/>
	<trigger name="MicroStoreUpdateChargeChoices"/>
	<trigger name="MicroStoreUpdateDurationChoices"/>
	<trigger name="MicroStoreChargeChoice"/>
	<trigger name="MicroStoreDurationChoice"/>
	<trigger name="MicroStoreUpdatePayStyleChoice"/>
	<trigger name="MicroStoreUpdatePaging"/>
	<trigger name="MicroStoreUpdateCategory"/>
	<trigger name="MicroStoreUpdateCoins"/>
	<trigger name="MicroStoreUpdatePackages"/>
	<trigger name="UpdatePurchaseCoinsForm"/>
