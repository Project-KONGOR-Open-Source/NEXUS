	<!-- Tabs -->
	<template name="store2_tab_bt">
		<button
			name="{btname}"
			color="invisible"
			onclick="{onclick}"
			onclicklua="PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav') {onclicklua}"
			onrightclicklua="PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav') {onrightclicklua}"
			onmouseoverlua="
				local title = '{tipTitle}'
				local body  = '{tipBody}'
				local tip	= '{tipId}'
				if tip ~= '' then
					title = 'mstore_category'..tip
					body  = title..'_desc'
				end
				if title ~= '' then
					HoN_Store:ShowToolTip(title, body, true)
				end
				PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
				{onmouseoverlua=}
			"
			onmouseoutlua="
				HoN_Store:HideToolTip()
				{onmouseoutlua=}
			"
			visible="{visible=visible}"
		>
			<widgetstate statename="up">
				<image visible="1" align="left" x="3i" width="-6i" valign="center" texture="/ui/fe2/elements/store2/b{s}_c.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<image visible="1" align="left" width="4i" valign="center" texture="/ui/fe2/elements/store2/b{s}_l.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<image visible="1" align="right" width="4i" valign="center" texture="/ui/fe2/elements/store2/b{s}_r.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label content="{text}" font="{font=dyn_12}" color="{color}" shadow="true" shadowcolor="{shadowcolor}" outline="true" outlinecolor="{outlinecolor}" align="center" valign="center" textalign="center" textvalign="center" uppercase="1" />
			</widgetstate>
			<widgetstate statename="over">
				<image visible="1" align="left" x="3i" width="-6i" valign="center" texture="/ui/fe2/elements/store2/b{s}_over_c.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<image visible="1" align="left" width="4i" valign="center" texture="/ui/fe2/elements/store2/b{s}_over_l.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<image visible="1" align="right" width="4i" valign="center" texture="/ui/fe2/elements/store2/b{s}_over_r.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label content="{text}" font="{font=dyn_12}" color="{overcolor}" shadow="true" shadowcolor="{shadowcolor}" outline="true" outlinecolor="{outlinecolor}" align="center" valign="center" textalign="center" textvalign="center" uppercase="1" />
			</widgetstate>
			<widgetstate statename="down">
				<image visible="1" align="left" x="3i" width="-6i" valign="center" texture="/ui/fe2/elements/store2/b{s}_over_c.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<image visible="1" align="left" width="4i" valign="center" texture="/ui/fe2/elements/store2/b{s}_over_l.png" nocompress="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<image visible="1" align="right" width="4i" valign="center" texture="/ui/fe2/elements/store2/b{s}_over_r.png" nocompress="1"  color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label content="{text}" font="{font=dyn_12}" color="{color}" shadow="true" shadowcolor="{shadowcolor}" outline="true" outlinecolor="{outlinecolor}" align="center" valign="center" textalign="center" textvalign="center" x=".1h" y=".2h" uppercase="1" />
			</widgetstate>
		</button>
	</template>

	<template name="store2_tab">
		<panel width="{width=128i}" height="{height=100%}" align="{align=left}" valign="{valign=center}" blockinput="{blockinput=false}" noclick="{noclick=false}" color="invisible"
			onframelua="{onframelua=}" >
			<instance name="store2_tab_bt" btname="store2_tab_{id}" visible="1" s="" color="#d7b6a2" overcolor="#ebd1c2" shadowcolor="#18000040" outlinecolor="#280b0b" text="{text}" tabname="{tabname}" onclick="{onclick}" onclicklua="{onclicklua}" onrightclicklua="{onrightclicklua}" onmouseoverlua="{onmouseoverlua}" onmouseoutlua="{onmouseoutlua}" tipId="{tipId}" tipTitle="{tipTitle}" tipBody="{tipBody}"/>
			<instance name="store2_tab_bt" btname="store2_tab_selected_{id}" visible="0" s="s" color="#fffefc" overcolor="#ffffff" shadowcolor="#66270099" outlinecolor="#c36000" text="{text}" tabname="{tabname}" onclick="{onclick}" onclicklua="{onclicklua}" onrightclicklua="{onrightclicklua}" onmouseoverlua="{onmouseoverlua=}" onmouseoutlua="{onmouseoutlua=}" tipId="{tipId}" tipTitle="{tipTitle}" tipBody="{tipBody}"/>
		</panel>
	</template>

	<template name="store2_tab_vault">
		<panel x="{x}" width="{width=128i}" height="{height=100%}" align="{align=left}" valign="{valign=center}" blockinput="{blockinput=false}" noclick="{noclick=false}" onframelua="{onframelua=}"
		>
			<instance name="store2_tab_bt" btname="store2_tab_{id}" visible="1" s="" color="#c4d1cc" overcolor="#dde8e4" shadowcolor="#051c1d" outlinecolor="#280b0b" text="{text}" tabname="{tabname}" onclick="{onclick}" onclicklua="{onclicklua}" onrightclicklua="{onrightclicklua}" onmouseoverlua="{onmouseoverlua=}" onmouseoutlua="{onmouseoutlua=}" bgcolor="#00fff4" rendermode="colorscale1" tipId="{tipId}" tipTitle="{tipTitle}" tipBody="{tipBody}"/>
			<instance name="store2_tab_bt" btname="store2_tab_selected_{id}" visible="0" s="s" color="#fffefc" overcolor="#ffffff" shadowcolor="#66270099" outlinecolor="#c36000" text="{text}" tabname="{tabname}" onclick="{onclick}" onclicklua="{onclicklua}" onrightclicklua="{onrightclicklua}" onmouseoverlua="{onmouseoverlua=}" onmouseoutlua="{onmouseoutlua=}" tipId="{tipId}" tipTitle="{tipTitle}" tipBody="{tipBody}"/>
		</panel>
	</template>

	<template name="model_panel_editor">
		<!-- model panel editor, for development only -->
		<!-- Not for retail -->
	</template>

	<template name="store2_top_backbutton">
		<button name="store2_top_backbutton_{id}" color="invisible" width="6h" height="3h" align="center" valign="top" x="-60h" y="2.2h"
			onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')"
			onclicklua="HoN_Store:NavigateBack()"
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/elements/store2/backbt{v}.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/elements/store2/backbt{v}_over.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
			</widgetstate>
			<widgetstate statename="down">
				<image texture="/ui/fe2/elements/store2/backbt{v}_over.png" y="1" color="{bgcolor=}" rendermode="{rendermode=}"/>
			</widgetstate>
			<widgetstate statename="disabled">
				<image texture="/ui/fe2/elements/store2/backbt{v}_over.png" color="1 1 1 0.2" rendermode="{rendermode=}"/>
			</widgetstate>
		</button>
	</template>

	<template name="store2_top">
		<panel name="store2_top" noclick="1" visible="{visible=1}" color="invisible" valign="top" height="12h" y="0h" x="0h">

			<!-- Chains -->
			<animatedimage texture="/ui/fe2/elements/store2/chain/sl_.png" width="100i" height="100i" align="center" x="-695i" y="52i"
				fps="25" loop="true" loopbackframe="0" startframe="0" />
			<animatedimage texture="/ui/fe2/elements/store2/chain/sl_.png" width="100i" height="100i" align="center" x="705i" y="52i"
				fps="25" loop="true" loopbackframe="0" startframe="2" loopclamp="false"/>

			<!-- Tab Background -->
			<image visible="1" name="top_tab_image" noclick="1" nocompress="1" width="2048i" height="128i" x="0" y="-20i" align="center" valign="top"
				texture="/ui/fe2/elements/store2/navbar_bg.png" />

			<!-- Tab Instances -->
			<panel name="store2_tabs" float="right" width="1240i" height="64i" x="1i" y="8i" align="center" noclick="1">
				<instance name="store2_tab" id="specials" text="mstore_specials" onclicklua="Store2Tab('specials')" width="156i" tipTitle="mstore_viewspecials" tipBody="mstore_specials_tip"/>

				<panel width="145i" noclick="true"
					watch="AccountInfo"
					ontriggerlua="self:DoEventN(1, '')"
					onloadlua="self:DoEventN(1, '')"
					onevent1lua="
						self:GetWidget('store2_tab_heroes_wrapper'):SetVisible(false)
						self:GetWidget('store2_tab_featured_wrapper'):SetVisible(false)
						self:GetWidget('store2_tab_ea_wrapper'):SetVisible(false)
						local tab = HoN_Store:GetHeroesTab()
						if tab == 'featured' then
							self:GetWidget('store2_tab_featured_wrapper'):SetVisible(true)
						else
							local parent = nil
							if tab == 'heroes' then
								self:GetWidget('store2_tab_heroes_wrapper'):SetVisible(true)
								parent = GetWidget('store2_heroes')
							else
								self:GetWidget('store2_tab_ea_wrapper'):SetVisible(true)
								parent = GetWidget('store2_ea')
							end
							GetWidget('store2_hero_ea'):SetParent(parent)
							GetWidget('store2_heroes_list'):SetParent(parent)
						end
					">
					<panel name="store2_tab_ea_wrapper" noclick="true">
						<instance name="store2_tab" id="ea" text="mstore_category58" width="145i"
							onclicklua="HoN_Store:SwitchToEaPage()" tipId="58"/>
						</panel>
					<panel name="store2_tab_heroes_wrapper" noclick="true">
						<instance name="store2_tab" id="heroes" text="mstore_category58b" width="145i" tipId="58b"
							onclicklua="HoN_Store:SwitchToEaPage()" />
						</panel>
					<panel name="store2_tab_featured_wrapper" noclick="true">
						<instance name="store2_tab" id="featured" text="mstore_category58c" width="145i" tipId="58c"
							onclicklua="HoN_Store:SwitchToFeaturedPage()" />
					</panel>
				</panel>

				<instance name="store2_tab" id="altavatars" text="mstore_category2_short" width="200i" tipId="2"
					onclicklua="HoN_Store:SwitchToAvatarListPage()" />
				<instance name="store2_tab" id="accountvanity" text="mstore_vanity" width="235i" tipTitle="mstore_vanity" tipBody="mstore_vanity_tip"
					onmouseoverlua="HoN_Store:TabMenuFadeIncrease('accountvanity', 'accountvanity tab')"
					onmouseoutlua="HoN_Store:TabMenuFadeDecrease('accountvanity', 'accountvanity tab')"
					onframelua="HoN_Store:TabMenuFadeCheck('accountvanity')" 
					onrightclicklua="HoN_Store:JumpToVaultPage('vault_accounticons')"/>
				<instance name="store2_tab" id="gamevanity" text="mstore_gamevanity" width="202i" tipTitle="mstore_gamevanity" tipBody="mstore_gamevanity_tip"
					onmouseoverlua="HoN_Store:TabMenuFadeIncrease('gamevanity', 'gamevanity tab')"
					onmouseoutlua="HoN_Store:TabMenuFadeDecrease('gamevanity', 'gamevanity tab')"
					onframelua="HoN_Store:TabMenuFadeCheck('gamevanity')" />
				<instance name="store2_tab" id="others" text="mstore_category6" onclicklua="HoN_Store:Store2ShowPage('others')" width="145i" tipId="6"
					onrightclicklua="HoN_Store:JumpToVaultPage('vault_others')"/>
				<instance name="store2_tab" id="bundles" text="mstore_category7" width="157i"
					onclicklua="HoN_Store:SwitchToBundleListPage(1)" tipId="7" />

				<anchor x="0"/>
				<instance name="store2_tab_account_vanity_menu" x="500i" y="55i" width="241i" onshowlua="self:BringToFront()" />
				<instance name="store2_tab_game_vanity_menu" x="735i" y="55i" width="206i" onshowlua="self:BringToFront()" />
			</panel>

			<!-- Back Button -->
			<instance name="store2_top_backbutton" id="shop"/>

			<!-- Close Button -->
			<instance name="store2_close" onclicklua="HoN_Store:CloseStoreCommand()"/>

		</panel>
	</template>

	<template name="store2_top_vault">
		<panel name="store2_top_vault" noclick="1" visible="{visible=1}" color="invisible" valign="top" height="12h" y="0h" x="0h">

			<!-- Chains -->
			<animatedimage texture="/ui/fe2/elements/store2/chain/sl_.png" width="100i" height="100i" align="center" x="-695i" y="52i"
				fps="25" loop="true" loopbackframe="0" startframe="0" color="#8cffff" rendermode="colorscale1"/>
			<animatedimage texture="/ui/fe2/elements/store2/chain/sl_.png" width="100i" height="100i" align="center" x="705i" y="52i"
				fps="25" loop="true" loopbackframe="0" startframe="2" loopclamp="false" onshowlua="self:StartAnim(1, 0)" color="#8cffff" rendermode="colorscale1"/>

			<!-- Tab Background -->
			<image visible="1" name="top_tab_image1" noclick="1" nocompress="1" width="2048i" height="128i" x="0h" y="-20i" align="center" valign="top"
				texture="/ui/fe2/elements/store2/navbar_v_bg.png" />

			<!-- Tab Instances -->
			<panel name="store2_tabs_vault" x="0i" y="8i" width="1240i" height="64i" align="center" float="right" noclick="1">
				<instance name="store2_tab_vault" id="vault_accountvanity" text="mstore_vanity" width="195i" tipTitle="mstore_vanity" tipBody="mstore_vanity_tip"
					onmouseoverlua="HoN_Store:TabMenuFadeIncrease('vault_accountvanity')"
					onmouseoutlua="HoN_Store:TabMenuFadeDecrease('vault_accountvanity')"
					onframelua="HoN_Store:TabMenuFadeCheck('vault_accountvanity')" />
				<instance name="store2_tab_vault" id="vault_gamevanity" text="mstore_gamevanity" width="195i" tipTitle="mstore_gamevanity" tipBody="mstore_gamevanity_tip"
					onmouseoverlua="HoN_Store:TabMenuFadeIncrease('vault_gamevanity')"
					onmouseoutlua="HoN_Store:TabMenuFadeDecrease('vault_gamevanity')"
					onframelua="HoN_Store:TabMenuFadeCheck('vault_gamevanity')" />
				<instance name="store2_tab_vault" id="vault_others" text="mstore_category6" width="120i" tipId="6" onclicklua="HoN_Store:Store2ShowPage('vault_others')"/>

				<anchor x="0"/>
				<instance name="store2_vault_tab_account_vanity_menu" x="0" y="55i" width="200i" onshowlua="self:BringToFront()" />
				<instance name="store2_vault_tab_game_vanity_menu" x="195i" y="55i" width="200i" onshowlua="self:BringToFront()" />
			</panel>

			<!-- Back Button -->
			<instance name="store2_top_backbutton" id="vault" v="_v" />

			<!-- Close Button -->
			<instance name="store2_close" onclicklua="HoN_Store:CloseStoreCommand()"/>

		</panel>
	</template>

	<template name="store2_store_common_elements">
		<panel name="stores_store_common_elements" x="{x=0}" y="{y=}" align="{align=center}" width='124h' height='2.067h' noclick="1" color="invisible">
			<instance name="store2_store_common_elements_button" id="open_vault" label="mstore_openvault" texture="open_vault" color="#f5f1e7" shadowcolor="#3e050d99" outlinecolor="#780513" onclicklua="HoN_Store:Store2OpenVault()" tipTitle="mstore_openvault" tipBody="mstore_openvault_desc" />
			<instance name="store2_store_common_elements_button" id="open_shop" label="mstore_openstore" texture="open_shop" color="#f8f7ef" shadowcolor="#c96700" outlinecolor="#d67e00" onclicklua="HoN_Store:Store2OpenShop()" tipTitle="mstore_openstore" tipBody="mstore_openstore_desc" />
			<instance name="store2_store_common_elements_button" id="back_to_list" x="140i" label="store2_back_to_list" texture="buy_coin" color="#ecf9fa" shadowcolor="#13373a99" outlinecolor="#006370" visible="0"
				onclicklua="
					if HoN_Store.BackToListCallback then
						HoN_Store.BackToListCallback()
						HoN_Store.BackToListCallback = nil
					else
						Store2Tab(GetStore2CurrentTab())
					end
				"/>

			<panel name="stores_store_common_elements_right" aligh="right" float="right" noclick="1">
				<instance name="store2_store_common_elements_button" id="buy_coin" align="right" label="mstore_buycoins" texture="buy_coin" color="#ecf9fa" shadowcolor="#13373a99" outlinecolor="#006370" watch="MicroStoreProcessing" ontriggerlua="self:SetEnabled(not AtoB(param))" onclick="Set('_microStore_RequestCode', 5); CallEvent('MicroStoreAction', 0); Cmd('script trackedUserFocus:openBuyCoins()');" onclicklua="UIManager.GetInterface('main'):HoNGMainF('UserAction', 2, true)" tipTitle="mstore_buycoins" tipBody="mstore_buycoins_desc"/>
			</panel>
			<panel align="right" width="136i" noclick="1"
				onloadlua="
					local show = GetCvarBool('ui_showCodeRedemption')
					self:SetVisible(show)
					GetWidget('stores_store_common_elements_right'):SetWidth(show and '-136i' or '100%')
				">
				<instance name="store2_store_common_elements_button" id="redeem_code" label="mstore_redeem_code" texture="open_shop" color="#f8f7ef" shadowcolor="#c96700" outlinecolor="#d67e00" tipTitle="mstore_redeem_code" tipBody="mstore_redeem_code_desc" watch="MicroStoreProcessing" ontriggerlua="self:SetEnabled(not AtoB(param))"
				onclicklua="GetWidget('store_popup_redeem_code'):DoEventN(0) trackedUserFocus:openRedeemCode()"/>

				<if condition="((!releaseStage_stable) and VarExists('ui_testRedeemRes'))">
					<instance name="store2_store_common_elements_button" y="3h" id="redeem_code_res" label="redeem res" texture="open_shop" color="#f8f7ef" shadowcolor="#c96700" outlinecolor="#d67e00" onclicklua="Store.StoreRedeemPromoCodeResult('0', '6', nil, '999,666,926~/heroes/artillery/alt8/icon.tga')"/>
				</if>
			</panel>
		</panel>
	</template>

