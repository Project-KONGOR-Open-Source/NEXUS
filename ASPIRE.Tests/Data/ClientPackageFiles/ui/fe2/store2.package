	<panel name="store2_soundSleeper" visible="0" noclick="1" />
	<panel name="store2_shopkeeperShowingSleeper" visible="0" noclick="1" />
	<panel name="store2_dailySpecialRequestHelper" visible="0" noclick="1" />
	<panel name="store2_vidOptionsHelper" visible="0" noclick="1" />
	<panel name="store2_firstEnterRequestHelper" visible="0" noclick="1" />
	<template name="store_container2">
		<panel name="store_container2" y="0h" x="0h" width="100%" height="100%" align="center" visible="{visible=0}" valign="top" color="invisible" noclick="0"
			onloadlua="
				Cvar.CreateCvar('store2_showModelDetail', 'bool', 'false')
				Cvar.CreateCvar('store2_showModelDetailArrow', 'bool', 'true')
				Cvar.CreateCvar('store2_isModelDetailShowing', 'bool', 'false')
				Cvar.CreateCvar('store2_isBundleModelDetail', 'bool', 'false')
				GetWidget('shopkeeper'):SetVisible(false)
			"
			onevent0lua="
				GetWidget('store_popup_container'):SetVisible(true)
				Trigger('ShopkeeperAction', 4)
				self:FadeIn(700)
				local w = GetWidget('store2_shopkeeperShowingSleeper')
				w:Sleep(1000, function()
					GetWidget('shopkeeper'):SetVisible(true)
				end)
			"
			onevent1lua="
				ResetAllTabs()
				Set('_microStore_shopkeeper_canIdle', false)
				Trigger('ShopkeeperAction', 3)
				self:FadeOut(700)
				GetWidget('shopkeeper'):SetVisible(false)
			"
			watch="MicroStoreResults"
			ontriggerlua="
				local responseCode	= param0
				local popupCode		= param1
				local prodcutIDs	= param2
				local productOwned	= param5
				local categoryID	= param13
				local errorCode		= param15
				local timestamp		= param29
				local grabbag		= param68
				HoN_Store:HandleStoreDataForHeroAvatars(
					responseCode, popupCode, categoryID, errorCode, timestamp, grabbag,...)
				HoN_Store:HandleDailySpecialData(popupCode, prodcutIDs, productOwned)
			"
			watch0="GameTokens"
			ontrigger0lua="HoN_Store.GameTokens = param0"
			watch1="GamePhase"
			ontrigger1lua="
				if GetCvarString('host_os') == 'windows' then
					if UIGamePhase() == 0 then
						Store2ModelContextManager.maxPageCount = 20
						Store2ModelContextManager.preferedPageCount = 10
					else
						Store2ModelContextManager.maxPageCount = 1
						Store2ModelContextManager.preferedPageCount = 1
					end
				end
			"
			onshowlua="
				local w = GetWidget('store2_soundSleeper')
				w:Sleep(50, function()
					PlaySound('/ui/fe2/store/sounds/store_open.wav')
					if (UIGamePhase() &lt;= 3) then
						w:Sleep(500, function()
							PlayMusic('/ui/fe2/store/sounds/bg_music.mp3', true)
						end)
					end
				end)
				HoN_Store:OnOpenStore()
			"
			onhidelua="
				playBgMusic()
				local tab = GetStore2CurrentTab()
				local time = 5
				if tab == 'ea' or tab == 'featured' or tab == 'heroes' then
					time = 2
				end
				local w = GetWidget('store2_soundSleeper')
				w:Sleep(time, function()
					PlaySound('/ui/fe2/store/sounds/store_close.wav')
				end)
				HoN_Store:OnCloseStore()
				UIManager.GetInterface('main'):HoNStoreF('StoreClosed')
			"
			onframelua="HoN_Store:Store2Frame()"
		>
			<!-- shop background -->
			<panel name="store2_store_bg" noclick="1">
				<if condition="!cg_newMainInterface">
					<image texture="/ui/fe2/elements/store2/back.png" y="-12i" width="192h" height="100%" align="center" noclick="1"/>
				</if>
				<if condition="cg_newMainInterface">
					<image texture="/ui/fe2/elements/store2/back.png" y="-10%" width="100%" height="110%" align="center" noclick="1"/>
				</if>
				<animatedimage onshow="StartAnim();" width="1100i" height="512i" valign="top" align="center" x="5i" y="-15i" fps="25" loop="1" loopbackframe="0" noclick="1" texture="/ui/fe2/elements/store2/animation/liaht_.png" />
			</panel>

			<!-- vault background -->
			<panel name="store2_vault_bg" noclick="1">
				<if condition="!cg_newMainInterface">
					<image texture="/ui/fe2/elements/store2/back.png" y="-12i" width="192h" height="100%" align="center" color="#9effff" rendermode="colorscale1" noclick="1"/>
				</if>
				<if condition="cg_newMainInterface">
					<image texture="/ui/fe2/elements/store2/back.png" y="-10%" width="192h" height="110%" align="center" color="#9effff" rendermode="colorscale1" noclick="1"/>
				</if>
				<animatedimage onshow="StartAnim();" width="1100i" height="512i" valign="top" align="center" x="5i" y="-15i" fps="25" loop="1" loopbackframe="0" texture="/ui/fe2/elements/store2/animation/liaht_.png" color="#8cffff" rendermode="colorscale1"/>
			</panel>

			<panel noclick="1">
				<panel name="store2_hero_detail_largeModel_wrapper" noclick="1" />
				<panel name="store2_bundle_detail_largeModel_wrapper" noclick="1" />
				<panel name="store2_ea_wrapper" noclick="1" />
			</panel>
			
			<!-- the vanity booth -->
			<panel name="store2_vanity_booth_container" align="center" width="1440i" noclick="1"
				watch2="UpgradesRefreshed"
				ontrigger2lua="HoN_Store:RefreshVanityBooth()">
				<instance name="store2_vanity_booth" id="vanity" x="-50i" y="-110i" align="right" valign="center" scale="1.6" buyScale="1.0" visible="0" showdiscount="0" />
				<instance name="store2OthersDetailPanel"/>
			</panel>

			<instance name="store2_store_common_elements" y="7.8h"/>

			<!-- store item exhibition -->
			<panel color="invisible" name="store2_store" noclick="1">

				<instance name="store2_hero_detail" />

				<instance name="store2_featured" />
				<instance name="store2_ea" />
				<instance name="store2_heroes" />
				<instance name="store2_specials" />
				<instance name="store2_altavatars" />
				<instance name="store2_accountvanity" />
				<instance name="store2_gamevanity" />
				<instance name="store2_others" />
				<instance name="store2_bundles" />

				<instance name="store2_hero_property_hover" />
				<instance name="store2_hero_skill_hover" />

				<instance name="store2_top" visible="1" />
			</panel>

			<!-- vault item exhibition -->
			<panel color="invisible" name="store2_vault" noclick="1">

				<instance name="store2_vault_accountvanity" />
				<instance name="store2_vault_gamevanity" />
				<!-- <instance name="store2_vault_announcers" />
				<instance name="store2_vault_couriers" />
				<instance name="store2_vault_taunts" />
				<instance name="store2_vault_wards" />
				<instance name="store2_vault_upgrades" />
				<instance name="store2_vault_creeps" /> -->
				<instance name="store2_vault_others" />

				<instance name="store2_top_vault" visible="1" />
			</panel>

			<instance name="store_promo" visible="true" />

			<instance name="store2_loading" />
			<instance name="storeMiscOverlays"/>
			<label name="store2_loadingTimeDisplay" align="right" textvalign="right" valign="top" visible="0" x="-130i" y="180i" width="500i" height="32i" font="dyn_12" noclick="1"/>

			<panel name="store2_TrashCan" width="1" height="1" color="invisible" />

			<if condition="releaseStage_dev or releaseStage_test">
				<instance name="model_panel_editor" y="12h" />
				<instance name="button2" button_name="store2Editor" y="2.5h" align="right" label="Editor" width="5h" height="2h" onclicklua="HoN_Store:ToggleHeroesPanelEditor()" />
			</if>
		</panel>
	</template>

	<!-- F2P systembar and herodex helper -->
	<panel name="store_open_purchase_helper" noclick="1"
		onevent="
			##Echo('Opening Store: '#param0);##
			If(!StringEquals(param0, 'token'),
				Split(
					Set('microStore_heroSelectTarget', param0),
					If(IsEarlyAccessHero(param0),
						Set('microStore_targetCategory', 58),
						Set('microStore_targetCategory', 71)
					)
				),
				Split(
					Set('microStore_targetCategory', 6),
					Set('microStore_heroSelectTarget', ''),
					Set('microStoreTargetPurchaseID', 655)
				)
			);
		"
		oneventlua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'store_container2', nil, true, nil, nil, 12)"
		onevent1lua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'store_container2', nil, true, nil, nil, 13)"
		onevent2="Set(microStore_targetRequest, 5);"
		onevent2lua="UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'store_container2', nil, true, nil, nil, 14)"
	>
	</panel>

	<panel height="50h" y="2.5h" name="store_cover" color="0 0 0 1" visible="false"/><!-- Covers up the store during in/out transition -->

</package>