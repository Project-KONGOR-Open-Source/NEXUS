	<!-- Hero Info & Alt Avatars -->
	<template name="store2_avatars_frame_icons">
		<panel name="{prefix}_{id}_icons_panel" x="{x=0}" y="{y=0}" width="{width=100%}" height="{height=24i}" valign="{valign=top}" visible="{visible=1}" noclick="1">
			<instance name="store2_frame" height="+10i" y="-5i" noclick="1" visible="{showframe=true}" />
			<panel float="right" padding="5i" noclick="1" x="+10@" width="-20@" y="10%" height="80%" >
				<panel name="{prefix}_{id}_icons_trial_panel" width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false"
					onmouseoverlua="HoN_Store:OnHoverAvatarCategoryIcon('{cat}','{id}', 'trial') {onmouseoverlua=}"
					onmouseoutlua="HoN_Store:OnHoverOutAvatarCategoryIcon()"
					onclicklua="HoN_Store:OnClickAvatarCategoryIcon('{cat}','{id}', 'trial')">
					<image texture="/ui/elements/trial_mark.tga" color="0 0 0 0.6" x="0.1h" y="0.1h" noclick="true"/>
					<image texture="/ui/elements/trial_mark.tga" noclick="true"/>
				</panel>
				<panel name="{prefix}_{id}_icons_enhancement_panel" width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false"
					onmouseoverlua="HoN_Store:OnHoverAvatarCategoryIcon('{cat}','{id}', 'enhancement') {onmouseoverlua=}"
					onmouseoutlua="HoN_Store:OnHoverOutAvatarCategoryIcon()"
					onclicklua="HoN_Store:OnClickAvatarCategoryIcon('{cat}','{id}', 'enhancement')">
					<image texture="/ui/fe2/store/avatars_display/icon_enhancement.tga" color="0 0 0 0.6" x="0.1h" y="0.1h" noclick="true"/>
					<image texture="/ui/fe2/store/avatars_display/icon_enhancement.tga" noclick="true"/>
				</panel>
				<panel name="{prefix}_{id}_icons_ultimate_panel" width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false"
					onmouseoverlua="HoN_Store:OnHoverAvatarCategoryIcon('{cat}','{id}', 'ultimate') {onmouseoverlua=}"
					onmouseoutlua="HoN_Store:OnHoverOutAvatarCategoryIcon()"
					onclicklua="HoN_Store:OnClickAvatarCategoryIcon('{cat}','{id}', 'ultimate')">
					<image texture="/ui/fe2/store/avatars_display/icon_ultimate_av.tga" color="0 0 0 0.6" x="0.1h" y="0.1h" noclick="true"/>
					<image texture="/ui/fe2/store/avatars_display/icon_ultimate_av.tga" noclick="true"/>
				</panel>
				<panel name="{prefix}_{id}_icons_ce_panel" width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false"
					onmouseoverlua="HoN_Store:OnHoverAvatarCategoryIcon('{cat}','{id}', 'ce') {onmouseoverlua=}"
					onmouseoutlua="HoN_Store:OnHoverOutAvatarCategoryIcon()"
					onclicklua="HoN_Store:OnClickAvatarCategoryIcon('{cat}','{id}', 'ce')">
					<image name="{prefix}_{id}_icons_ce" noclick="true" texture="$invis" />
				</panel>
				<panel name="{prefix}_{id}_icons_special_panel" width="100@" height="100%" visible="0" sticky="true" stickytoinvis="false"
					onmouseoverlua="HoN_Store:OnHoverAvatarCategoryIcon('{cat}','{id}', 'special') {onmouseoverlua=}"
					onmouseoutlua="HoN_Store:OnHoverOutAvatarCategoryIcon()"
					onclicklua="HoN_Store:OnClickAvatarCategoryIcon('{cat}','{id}', 'special')">
					<image name="{prefix}_{id}_icons_special" noclick="true" texture="$invis" />
				</panel>
			</panel>
		</panel>
	</template>

