						textalign="center" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12"  />
				</panel>

				<label name="store2_vanity_frame_{cat}_{row}_{col}_selected" align="center" valign="bottom" y="-3i" height="32i" noclick="1" visible="0"
					textalign="center" textvalign="center" font="dyn_10" content="store2_vault_selected" color="#f49f06" shadow="1" shadowcolor="#0d291d" />

			</panel>
			<panel name="store2_vanity_frame_{cat}_{row}_{col}_empty" noclick="1" color="invisible" >
				<image texture="/ui/fe2/elements/store2/vanity_empty{imgsuffix=}.png" width="256i" height="256i" align="center" valign="center" noclick="1"/>
			</panel>
			<modelpanel width="105%" height="108%" align="center" valign="center"
				name="store2_vanity_frame_{cat}_{row}_{col}_effect"
				visible="0"
				model="/ui/fe2/elements/store2/selectedeffect/model.mdf"
				modelangles="0 0 -90"
				anim="idle"
				camerapos="0 -2000 -3"
				cameraangles="0 0 0"
				camerafov="4.42"
				carmerafar="7000"
				depthclear="false"
				depthcompress="true"
				sunazimuth="140"
				sunaltitude="10"
				suncolor="1 1 1"
				onshowlua="
					self:SetAnim('')
					self:SetAnim('idle')
					self:SetEffect('/ui/fe2/elements/store2/selectedeffect/selected_efx.effect')
				"
				noclick="1"
				onframelua="self:BringToFront()"
				watch="Store2ShopClosing"
				ontriggerlua="self:SetVisible(0)"
			/>
		</panel>
	</template>

	<template name="store2_vanitylist_3x4">
		<panel color="invisible" y="0" width="99%" height="66%" align="center" valign="center" float="bottom" noclick="1"
			onshowlua="
				HoN_Store:InitializeVanityBoothUI(true, '{vanity}')
				{onshowlua=}
			"
			onhidelua="HoN_Store:InitializeVanityBoothUI(false)">
