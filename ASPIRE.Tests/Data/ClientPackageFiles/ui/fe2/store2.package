				onclicklua="HoN_Store:Store2ShowPage('taunts')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_taunts')"/>
		<!-- 	<instance name="store2_tab_vanity_menu_item" y="32i" id="tauntbadges" menu="gamevanity" text="mstore_category77"
				onclicklua="HoN_Store:Store2ShowPage('tauntbadges')"
