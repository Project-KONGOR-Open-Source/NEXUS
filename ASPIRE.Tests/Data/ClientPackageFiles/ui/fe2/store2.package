				onclicklua="HoN_Store:Store2ShowPage('announcers')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_announcers')"/>
			<instance name="store2_tab_vanity_menu_item" y="64i" id="couriers" menu="gamevanity" text="mstore_category57"
				onclicklua="HoN_Store:Store2ShowPage('couriers')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_couriers')"/>
			<instance name="store2_tab_vanity_menu_item" y="96i" id="wards" menu="gamevanity" text="mstore_category74"
				onclicklua="HoN_Store:Store2ShowPage('wards')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_wards')"/>
			<instance name="store2_tab_vanity_menu_item" y="128i" id="tpeffects" menu="gamevanity" text="mstore_category78"
				onclicklua="HoN_Store:Store2ShowPage('tpeffects')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_tpeffects')"/>
