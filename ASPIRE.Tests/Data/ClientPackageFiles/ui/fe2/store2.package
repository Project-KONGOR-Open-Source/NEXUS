	<template name="store2_accountvanity">
		<panel name="store2_accountvanity" width="122.5h" align="center" noclick="1" visible="{visible=0}"
			watch="store2VanityShow"
			ontriggerlua="HoN_Store:Store2VanitySetVisible(self, 'accountvanity', param0, param1)">

			<panel noclick="1" visible="0"
				watch="store2VanityShow"
				ontriggerlua="HoN_Store:Store2CategorySetVisible(self, 'accountvanity', 'accounticons', param0, param1, param2) "
				onshowlua="HoN_Store:Store2FormGetProducts('accounticons')"
				watch1="MicroStoreResults" ontrigger1lua="HoN_Store:Store2InitializeProductShow('accounticons', ...)"
				onhidelua="HoN_Store:AddNavHistoryVanity('accounticons')">
				<instance name="store2_vanitylist_3x8" vanity="accounticons" texture="/ui/fe2/elements/store2/vanityframe.png"
					namecolor="#d3bbac" nameoutlinecolor="#241410"/>

				<panel color="invisible" height="32i" align="left" x="0h" y="13h" noclick="1">
					<instance name="store2_title" cat="accounticons" label0="store2_shop" label="store2_accountvanity" haslabel2="1" label2="store2_accountvanity_accounticons" x="5i"/>
					<panel noclick="1" align="right" float="right" padding="15i" width="372i" >
						<panel noclick="1" width="184i">
							<instance name="store2_combobox" cat="accounticons" id="order" 
								onselectlua="HoN_Store:OnVanityConditionChange('accounticons', 'order')" />
						</panel>
						<panel noclick="1" width="257i" >
							<instance name="store2_searchbox" cat="accounticons" height="37i" y="-2i"
								oneventlua="HoN_Store:OnVanityConditionChange('accounticons', 'search', self:GetValue())"
								/>
						</panel>
					</panel>
				</panel>
			</panel>

			<panel noclick="1" visible="0"
				watch="store2VanityShow"
				ontriggerlua="HoN_Store:Store2CategorySetVisible(self, 'accountvanity', 'namecolors', param0, param1, param2) "
				onshowlua="HoN_Store:Store2FormGetProducts('namecolors')"
				watch1="MicroStoreResults" ontrigger1lua="HoN_Store:Store2InitializeProductShow('namecolors', ...)"
				onhidelua="HoN_Store:AddNavHistoryVanity('namecolors')">
				<panel color="invisible" height="32i" align="left" x="0h" y="13h" noclick="1">
					<instance name="store2_title" cat="namecolors" label0="store2_shop" label="store2_accountvanity" haslabel2="1" label2="store2_accountvanity_namecolors" x="5i"/>
				</panel>

				<instance name="store2_vanitylist_3x4" vanity="namecolors" texture="/ui/fe2/elements/store2/vanityframe3x4.png"
					namecolor="#d3bbac" nameoutlinecolor="#241410"/>
			</panel>

			<panel noclick="1" visible="0"
				watch="store2VanityShow"
				ontriggerlua="HoN_Store:Store2CategorySetVisible(self, 'accountvanity', 'symbols', param0, param1, param2) "
				onshowlua="HoN_Store:Store2FormGetProducts('symbols')"
				watch1="MicroStoreResults" ontrigger1lua="HoN_Store:Store2InitializeProductShow('symbols', ...)"
				onhidelua="HoN_Store:AddNavHistoryVanity('symbols') HoN_Store:ResetSymbolsType()">
				<instance name="store2_vanitylist_3x8" vanity="symbols" texture="/ui/fe2/elements/store2/vanityframe.png"
					namecolor="#d3bbac" nameoutlinecolor="#241410"/>
				<panel color="invisible" height="32i" align="left" x="0h" y="13h" noclick="1">
					<instance name="store2_title" cat="symbols" label0="store2_shop" label="store2_accountvanity" haslabel2="1" label2="store2_accountvanity_symbols" x="5i" />
					<panel noclick="1" align="right" float="right" padding="15i" width="547i">
						<panel noclick="1" width="160i">
							<instance name="store2_combobox" cat="symbols" id="types" 
								onselectlua="HoN_Store:OnSelectSymbolsType()" />
							</panel>
						<panel noclick="1" width="184i">
							<instance name="store2_combobox" cat="symbols" id="order" 
								onselectlua="HoN_Store:OnVanityConditionChange('symbols', 'order')" />
							</panel>
						<panel noclick="1" width="257i" >
							<instance name="store2_searchbox" cat="symbols" height="37i" y="-2i"
								oneventlua="HoN_Store:OnVanityConditionChange('symbols', 'search', self:GetValue())"
								/>
						</panel>
					</panel>
				</panel>
			</panel>

		</panel>
	</template>

	<template name="store2_gamevanity_show" >
		<panel noclick="1" visible="0"
			watch="store2VanityShow"
			ontriggerlua="HoN_Store:Store2CategorySetVisible(self, 'gamevanity', '{vanity}', param0, param1, param2) "
			onshowlua="HoN_Store:Store2FormGetProducts('{vanity}')"
			watch1="MicroStoreResults" ontrigger1lua="HoN_Store:Store2InitializeProductShow('{vanity}', ...)"
			onhidelua="HoN_Store:AddNavHistoryVanity('{vanity}')">
			<panel name="store2_gamevanity_top_bar{vanity}" noclick="1" color="invisible" height="32i" align="left" x="0h" y="13h">
				<instance name="store2_title" cat="{vanity}" label0="store2_shop" label="store2_gamevanity" haslabel2="1" label2="store2_gamevanity_{vanity}" x="5i"/>
			</panel>

			<instance name="store2_vanitylist_3x4" vanity="{vanity}" texture="/ui/fe2/elements/store2/vanityframe3x4.png"
					namecolor="#d3bbac" nameoutlinecolor="#241410"/>
		</panel>
	</template>

	<template name="store2_gamevanity">
		<panel name="store2_gamevanity" width="122.5h" align="center" noclick="1" visible="{visible=0}"
			watch="store2VanityShow"
			ontriggerlua="HoN_Store:Store2VanitySetVisible(self, 'gamevanity', param0, param1)">

			<instance name="store2_gamevanity_show" vanity="taunts" />
			<instance name="store2_gamevanity_show" vanity="tauntbadges" />
			<instance name="store2_gamevanity_show" vanity="announcers" />
			<instance name="store2_gamevanity_show" vanity="couriers" />
			<instance name="store2_gamevanity_show" vanity="wards" />
			<instance name="store2_gamevanity_show" vanity="tpeffects" />
			<instance name="store2_gamevanity_show" vanity="selectioncircles" />
			<instance name="store2_gamevanity_show" vanity="upgrades" />

		</panel>
	</template>

	<template name="store2_others" >
		<panel name="store2_others" width="122.5h" align="center" noclick="1" visible="{visible=0}"
			watch="store2VanityShow"
			ontriggerlua="HoN_Store:Store2VanitySetVisible(self, 'others', param0, param1)
							HoN_Store:Store2CategorySetVisible(self, 'others', 'others', param0, param1, param2) "
			onshowlua="HoN_Store:Store2FormGetProducts('others')"
			watch1="MicroStoreResults" ontrigger1lua="HoN_Store:Store2InitializeProductShow('others', ...)"
			onhidelua="HoN_Store:AddNavHistoryVanity('others')">

			<panel noclick="1" color="invisible" height="32i" align="left" x="0h" y="13h">
				<instance name="store2_title" cat="others" label0="store2_shop" label="store2_gamevanity_others" haslabel2="0" label2="" x="5i"/>
			</panel>

			<instance name="store2_vanitylist_3x4" vanity="others" texture="/ui/fe2/elements/store2/vanityframe3x4.png"
					namecolor="#d3bbac" nameoutlinecolor="#241410"/>
		</panel>
	</template>

	<!-- Bundle -->
	<template name="store2_bundle_frame">
		<panel name="store2_vanity_frame_bundles_{row}_{col}" width="420i" height="150i" color="invisible" noclick="1">
			<panel name="store2_vanity_frame_bundles_{row}_{col}_content" noclick="0" color="invisible"
				onclicklua="HoN_Store:SwitchToBundleDetailPage({row}, {col})"
				onmouseoverlua="
					PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
					GetWidget('store2_vanity_frame_bundles_{row}_{col}_over'):FadeIn(200)
					HoN_Store:VanityItemShowToolTip('bundles', {row}, {col})"
				onmouseoutlua="
					GetWidget('store2_vanity_frame_bundles_{row}_{col}_over'):FadeOut(200)
					HoN_Store:VanityItemOnMouseOutAction('{cat}', {row}, {col})"
				>

				<image texture="/ui/fe2/elements/store2/border_s_back.png" x="-140i" y="15i" width="256i" height="256i" align="center" valign="center" noclick="1"/>
				<image name="store2_vanity_frame_bundles_{row}_{col}_img" visible="1" width="128i" height="128i" x="8i" y="5i" align="left" valign="top" noclick="1"/>
				<image name="store2_vanity_frame_bundles_{row}_{col}_discount_mark" texture="/ui/fe2/elements/store2/bundle/bundle_mark_discount.png"
					visible="1" width="128i" height="128i" x="8i" y="5i" align="left" valign="top" noclick="1"/>
				<image name="store2_vanity_frame_bundles_{row}_{col}_lucky_mark" texture="/ui/fe2/elements/store2/bundle/bundle_mark_lucky.png"
					visible="1" width="128i" height="128i" x="8i" y="5i" align="left" valign="top" noclick="1"/>
				<image name="store2_vanity_frame_bundles_{row}_{col}_frame" texture="/ui/fe2/elements/store2/bundleframe.png" width="512i" height="256i"
					align="center" valign="center" color="{bgcolor=}" noclick="1"/>

				<panel name="store2_vanity_frame_bundles_{row}_{col}_over" align="center" valign="center"
					rendermode="overlay" color="{overlaycolor=#cebd9e80}" noclick="1" visible="0" x="0" y="0" width="98%" height="97%"/>

				<label name="store2_vanity_frame_bundles_{row}_{col}_name" align="left" valign="top" x='150i' y="1i" width="255i" height="32i" textalign="left" textvalign="center"
					font="dyn_12" color="#d3bbac" outline="true" outlinecolor="#241410" shadow="1" shadowcolor="#000000" autofont="1" autofontmax="12" noclick="1" />

				<label name="store2_vanity_frame_bundles_{row}_{col}_desc" align="right" valign="top" x='-5i' y="34i" width="63.5%" height="64i" textalign="left" textvalign="center"
					font="dyn_10" color="#bb9b87" outline="true" outlinecolor="#241410" shadow="1" shadowcolor="#000000" wrap="1" noclick="1" />

				<panel name="store2_vanity_frame_bundles_{row}_{col}_price" valign="bottom" width="-100i" x="144i" y="-11.5i" height="32i" noclick="1">
					<panel name="store2_vanity_frame_bundles_{row}_{col}_gold_panel" width="50%" align="center" x="-25%" noclick="1" >
						<image align="left" valign="bottom" x='2i' width="32i" texture="/ui/fe2/elements/store2/gold_right.png" noclick="1"/>
						<label name="store2_vanity_frame_bundles_{row}_{col}_gold" align="left" valign="bottom" x='32i' width="44i" textalign="left" textvalign="center"
							font="dyn_10" color="#ffae00" outline="true" outlinecolor="#241410" shadow="1" shadowcolor="#000000" noclick="1"/>
					</panel>
					<panel name="store2_vanity_frame_bundles_{row}_{col}_silver_panel" width="50%" align="center" x="25%" noclick="1" >
						<image align="left" valign="bottom" x='2i' width="32i" texture="/ui/fe2/elements/store2/silver_right.png" noclick="1"/>
						<label name="store2_vanity_frame_bundles_{row}_{col}_silver" align="left" valign="bottom" x='32i' width="44i" textalign="left" textvalign="center"
							font="dyn_10" color="#bb9b87" outline="true" outlinecolor="#1b1210" shadow="1" shadowcolor="#000000" noclick="1"/>
					</panel>
				</panel>
				<panel valign="bottom" width="-172i" x="144i" y="-11.5i" height="32i" noclick="1" visible="1" >
					<label name="store2_vanity_frame_bundles_{row}_{col}_owned" content="mstore_purchased" visible="1"
						textalign="center" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12" noclick="1" />
					<label name="store2_vanity_frame_bundles_{row}_{col}_price_lable" visible="1"
						textalign="center" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12" noclick="1" />
				</panel>
			</panel>
			<panel name="store2_vanity_frame_bundles_{row}_{col}_empty" noclick="1" color="invisible">
				<image texture="/ui/fe2/elements/store2/bundle_empty.png" width="512i" height="256i" align="center" valign="center"
					color="{bgcolor=}" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="store2_bundle_list">
		<panel name="store2_bundle_list" noclick="1"
			onhidelua="HoN_Store:OnHideBundleListPage()"
			onshowlua="HoN_Store:Store2SetCurrentPage('bundle_list') ">
			<panel noclick="1" color="invisible" height="32i" align="left" x="0h" y="13h">
				<instance name="store2_title" cat="{vaultcategory}" label0="store2_shop" label="store2_bundles" haslabel2="0" label2="" x="5i"/>
			</panel>

			<panel color="invisible" y="0" width="99%" height="66%" align="center" valign="center" float="bottom" noclick="1"
				onshowlua="HoN_Store:InitializeVanityBoothUI(false)">
				<panel float="right" padding="18i" height="24%" noclick="1">
					<instance name="store2_bundle_frame" row="1" col="1" />
					<instance name="store2_bundle_frame" row="1" col="2" />
					<instance name="store2_bundle_frame" row="1" col="3" />
				</panel>
				<panel float="right" padding="18i" height="24%" noclick="1">
					<instance name="store2_bundle_frame" row="2" col="1" />
					<instance name="store2_bundle_frame" row="2" col="2" />
					<instance name="store2_bundle_frame" row="2" col="3" />
				</panel>
				<panel float="right" padding="18i" height="24%" noclick="1">
					<instance name="store2_bundle_frame" row="3" col="1" />
					<instance name="store2_bundle_frame" row="3" col="2" />
					<instance name="store2_bundle_frame" row="3" col="3" />
				</panel>
				<panel float="right" padding="18i" height="24%" noclick="1">
					<instance name="store2_bundle_frame" row="4" col="1" />
					<instance name="store2_bundle_frame" row="4" col="2" />
					<instance name="store2_bundle_frame" row="4" col="3" />
				</panel>

				<instance name="store2_paging" y="0" valign="bottom" cat="bundles" />
			</panel>
		</panel>
	</template>

	<template name="store2_bundle_portrait_band">
		<panel name="store2_bundle_portrait_band_{id}" width="225i" height="56i" x="{x=0}">
			<image texture="/ui/fe2/elements/store2/{texname}" />
			<label name="store2_bundle_portrait_band_{id}_label" align="center" valign="center" textalign="center" textvalign="center" color="{color=white}" outline="true" outlinecolor="{outlinecolor=black}" height="32i" y="4i" content="{text}" font="dyn_12" />
		</panel>
	</template>

	<template name="store2_bundle_portrait_info">
		<panel name="{prefix}_info" align="left" valign="top" x="{x=17i}" y="{y=26i}" width="{width=100%}" height="{height=250i}" noclick="0" color="invisible" visible="{visible=true}"
			onmouseoverlua="{onmouseoverlua=}"
			onmouseoutlua="{onmouseoutlua=}"
			>
			<panel width="150i" height="150i" noclick="1" >
				<image name="{prefix}_portrait" noclick="1" width="102i" height="102i" align="center" valign="center" usealphamask="true" alphamaskfile="/ui/fe2/elements/store2/mask.png" />
				<image texture="/ui/fe2/elements/store2/head_border.png" width="256i" height="256i" align="center" valign="center" noclick="1" />
			</panel>
			<panel width="-200i" height="135i" x="180i" y="25i" noclick="0" >
				<label name="{prefix}_name" height="40i" font="dyn_16" color="#f0d3c1" outline="true" outlinecolor="#230000" noclick="1" fitx="true" />
				<panel y="50i" width="100%" float="bottom" grow="true" noclick="0">
					<label name="{prefix}_desc" fity="true" font="dyn_11" color="#d3bbac" outline="true" outlinecolor="#230000" wrap="true" noclick="1" />
					<panel height="56i" >
						<instance name="store2_bundle_portrait_band" id="lucky" texname="label_right.png" text="store2_lucky_bundle" x="-20i" color="white" outlinecolor="#83132b" />
						<instance name="store2_bundle_portrait_band" id="discount" texname="label_left.png" text="store2_discount_bundle" x="-20i" color="#f8ffff" outlinecolor="#04818b" />
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="store2_bundle_detail_content">
		<instance name="store2_detail_large_model" panelname="store2_bundle_detail_large_model" visible="0"
			onmouseldownlua="
				GetWidget('st2_sp_booth_vanity_info_container'):FadeOut(300)
			"
			onmouseluplua="
				GetWidget('st2_sp_booth_vanity_info_container'):FadeIn(300)
			"
		/>
		<panel name="store2_detail_{cat}_center" align="center" valign="top" width="1320i" height="820i" y="120i" noclick="1"
			watch2="UpgradesRefreshed"
			ontrigger2lua="HoN_Store:UpdateBundleItems()">
			<instance name="store2_bundle_portrait_info" prefix="store2_detail_{cat}" width="560i" />
			<instance name="store2_detail_frame2x4" cat="{cat}" rootname="store2_detail_{cat}_avatars"
				label="store2_goods" frameTemplate="store2_alt_small_frame" onclickframefunc="HoN_Store:OnClickBundleDetailFrame"/>
		</panel>
	</template>

	<template name="store2_bundle_detail">
		<instance name="store2_detail_template"
			cat="bundleDetail"
			contentTemplate="store2_bundle_detail_content"
			onshowlua="
				HoN_Store:OnShowBundleDetailPage()
				local wrapper = GetWidget('store2_bundle_detail_largeModel_wrapper')
				GetWidget('store2_bundle_detail_large_model'):SetParent(wrapper)
				GetWidget('store2_bundle_detail_largeModel_wrapper'):SetVisible(true)
				HoN_Store:Store2SetCurrentPage('bundle_detail') 
				HoN_Store.BundleDetail.IsShowing = true
				HoN_Store.BackToListCallback = function() HoN_Store:OnBundlesBackToList() end
			"
			onhidelua="
				HoN_Store:OnHideBundleDetailPage()
				HoN_Store.BackToListCallback = nil
				GetWidget('store2_bundle_detail_largeModel_wrapper'):SetVisible(false)
				HoN_Store.BundleDetail.IsShowing = false
			"
			/>
	</template>

	<template name="store2_bundles">
		<panel name="store2_bundles" width="122.5h" align="center" noclick="1" visible="{visible=0}"
			watch1="MicroStoreResults"
			ontrigger1lua="
				HoN_Store:Store2InitializeProductShow('bundles', ...)
			">
			<instance name="store2_bundle_list" />
			<instance name="store2_bundle_detail" visible="false" />
		</panel>
	</template>

	<template name="store2_tab_vanity_menu_item">
		<button y="{y=}" width="98%" height="30i" color="invisible" align="center" valign="top" onclicklua="{onclicklua}" noclick="0"
			onmouseoverlua="
				PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
				HoN_Store:TabMenuFadeIncrease('{menu}', 'menuitem')"
			onmouseoutlua="HoN_Store:TabMenuFadeDecrease('{menu}', 'menuitem')"
			onrightclicklua="PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav') {onrightclicklua}">
			<widgetstate statename="up">
				<panel height="36i" noclick="1" color="invisible">
					<label height='36i' content="{text}" font="{font=dyn_12}" color="{textColor=#8e6b5b}" shadow="true" shadowcolor="{shadowcolor}" outline="true" outlinecolor="#231310" align="center" valign="center" textalign="center" textvalign="center" />
					<image texture="/ui/fe2/elements/store2/line.png" align="center" height="64i" valign="bottom" y="26i" width="150%" visible="{showline=true}" rendermode="{rendermode=normal}" color="{linecolor=#ffffff}"/>
				</panel>
			</widgetstate>
			<widgetstate statename="over">
				<panel height="36i" noclick="1" color="invisible" 			
					>
					<label height='36i' content="{text}" font="{font=dyn_12}" color="{textColor=#8e6b5b}" shadow="true" shadowcolor="{shadowcolor}" outline="true" outlinecolor="#241410" align="center" valign="center" textalign="center" textvalign="center" />
					<image texture="/ui/fe2/elements/store2/line.png" align="center" height="64i" valign="bottom" y="26i" width="150%" visible="{showline=true}" rendermode="{rendermode=normal}" color="{linecolor=#ffffff}"/>
					<panel align="center" valign="center" rendermode="overlay" color="{overlaycolor=#cebd9e80}" noclick="1" width="100%" height="-4i" visible="1"/>
				</panel>
			</widgetstate>
		</button>
	</template>

	<template name="store2_tab_account_vanity_menu">
		<panel x="{x}" y="{y}" width="{width=220i}" height="100i" noclick="0" visible="0" align="left" valign="top" color="invisible"
			watch="store2TabMenuShow"
			ontriggerlua="if param == 'accountvanity' then self:SetVisible(true) end"
			watch1="store2TabMenuHide"
			ontrigger1lua="if param == 'all' or param == 'accountvanity' then self:SetVisible(false) end"
			watch2="store2VanityShow"
			ontrigger2lua="if param0 ~= '' then self:SetVisible(0) end"
			onmouseoverlua="HoN_Store:TabMenuFadeIncrease('accountvanity', 'menupanel')"
			onmouseoutlua="HoN_Store:TabMenuFadeDecrease('accountvanity', 'menupanel')">
			<instance name="store2_frame" />
			<instance name="store2_tab_vanity_menu_item" y="0i" id="accounticons" menu="accountvanity" text="mstore_category3"
				onclicklua="HoN_Store:Store2ShowPage('accounticons')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_accounticons')"/>
			<instance name="store2_tab_vanity_menu_item" y="32i" id="namecolors" menu="accountvanity" text="mstore_category16"
				onclicklua="HoN_Store:Store2ShowPage('namecolors')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_namecolors')"/>
			<instance name="store2_tab_vanity_menu_item" y="64i" id="symbols" menu="accountvanity" text="mstore_category4"
				onclicklua="HoN_Store:Store2ShowPage('symbols')" showline="false"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_symbols')"/>
		</panel>
	</template>

