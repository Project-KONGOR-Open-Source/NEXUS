				onclicklua="HoN_Store:Store2ShowPage('vault_couriers')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="128i" id="vault_wards" menu="vault_gamevanity" text="mstore_category74"
				onclicklua="HoN_Store:Store2ShowPage('vault_wards')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="160i" id="vault_tpeffects" menu="vault_gamevanity" text="mstore_category78"
				onclicklua="HoN_Store:Store2ShowPage('vault_tpeffects')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="192i" id="vault_creeps" menu="vault_gamevanity" text="mstore_category76"
				onclicklua="HoN_Store:Store2ShowPage('vault_creeps')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
