	<template name="store2_alt_small_frame">
		<panel width="140i" height="186i" visible="{visible=1}" >
			<image texture="/ui/fe2/elements/store2/border_blank_s.png" width="256i" height="256i" align="center" valign="center" noclick="1"/>
			<panel name="store2_alt_small_frame_{cat}_{id}_panel" noclick="0" visible="0"
					onevent1lua="self:GetWidget('store2_alt_small_frame_{cat}_{id}_model'):DoEventN(1)"
					onclicklua="
						PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav')self:DoEventN(1)"
					onevent2lua="GetWidget('store2_alt_small_frame_{cat}_{id}_over'):FadeIn(200)"
					onmouseoverlua="
						PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
						self:DoEventN(2)"
					onevent3lua="GetWidget('store2_alt_small_frame_{cat}_{id}_over'):FadeOut(200)"
					onmouseoutlua="self:DoEventN(3)">
				<image texture="/ui/fe2/elements/store2/border_s_back.png" width="256i" height="256i" align="center" valign="center" noclick="1" />
				<modelpanel
					name="store2_alt_small_frame_{cat}_{id}_model"
					scenebuffer="true"
					noclick="0"
					anim="idle"
					cameranear="0.0"
					camerafar="5000.0"
					depthclear="true"
					depthcompress="false"
					lookat="false"
					cameradistance="30"
					camerapos="-32 1100 1450"
					cameraangles="0 0 180"
					camerafov="7"
					modelpos="0 0 0"
					modelangles="0 0 0"
					modelscale="1.0"
					sunazimuth="120"
					sunaltitude="50"
					suncolor="0.9 0.9 0.9"
					ambientcolor="0.6 0.7 0.7"
					luatable="1"
					cull="false"
					resourcecontext="model"
					outlinecolor="white"
					processcursor="{processcursor=true}"
					width="92%" height="80%" y="-8%" x="0h" align="center" valign="center"
					onclicklua="
						PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav')
						if not GetCvarBool('releaseStage_stable') and GetCvarBool('store2_enable_edit') then
							HoN_Store:EditHeroFrame(self, {id}, 'small')
						else
							self:DoEventN(1)
						end
					"
					onevent1lua="
						{onclickframefunc}(self, {id})
						local editor = GetWidget('model_panel_editor')
						if editor ~= nil and editor:IsVisible() then
							GetWidget('store2_detail_heroAvatars_large_model'):DoEventN(1)
						end
					"
					onshowlua="
						if not GetCvarBool('releaseStage_stable') and GetCvarBool('store2_enable_edit') then
							self:SetNoClick(false)
						else
							self:SetNoClick(true)
						end
					"
					watch="Store2ShopClosing"
					ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
					/>

				<panel valign="top" y="8i" x="4i" width="-16i" height="24i" noclick="1">
					<instance name="store2_avatars_frame_icons" prefix="store2_alt_small_frame_{cat}" cat="{cat}" id="{id}" visible="0" showframe="false"
						onclicklua="GetWidget('store2_alt_small_frame_{cat}_{id}_model'):DoEventN(1)"
						onmouseoverlua="GetWidget('store2_alt_small_frame_{cat}_{id}_over'):FadeIn(200)" />
				</panel>

				<image texture="/ui/fe2/elements/store2/border_s.png" width="256i" height="256i" align="center" valign="center" noclick="1" />

				<image name="store2_alt_small_frame_{cat}_{id}_gca" texture="/ui/fe2/elements/store2/gca.png" width="64i" height="32i" align="left" valign="center" noclick="1" y="45i" />

				<panel name="store2_alt_small_frame_{cat}_{id}_over" align="center" valign="center"
					rendermode="overlay" color="{overlaycolor=#cebd9e80}" noclick="1" visible="0" x="-1i" y="-1i" width="94%" height="98%"/>

				<panel name="store2_alt_small_frame_{cat}_{id}_bottom" x="6i" width="-12i" valign="bottom" y="-2i" height="30i" noclick="1" >
					<panel name="store2_alt_small_frame_{cat}_{id}_gold_panel" noclick="1" width="50%" visible="0" >
						<image noclick="1" texture="/ui/fe2/elements/store2/gold_card.png" x="0" width="26i" height="26i" align="left" valign="center" />
						<label name="store2_alt_small_frame_{cat}_{id}_gold" noclick="1" x="24i" width="50i" align="left" valign="center" textalign="left" textvalign="center" color="#ff9c00" outline="true" outlinecolor="#241410" font="dyn_10" />
					</panel>

					<panel name="store2_alt_small_frame_{cat}_{id}_silver_panel" width="50%" x="50%" noclick="1" visible="0" >
						<image noclick="1" texture="/ui/fe2/elements/store2/silver_card.png" x="0" width="26i" height="26i" align="left" valign="center" />
						<label name="store2_alt_small_frame_{cat}_{id}_silver" noclick="1" x="24i" width="50i" align="left" valign="center" textalign="left" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_10" />
					</panel>

					<panel noclick="1" >
						<label name="store2_alt_small_frame_{cat}_{id}_price" content="" visible="0" noclick="1" align="center" autofont="1" autofontmax="12"
							textalign="center" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12"  />
					</panel>
				</panel>

				<image name="store2_alt_small_frame_{cat}_{id}_coupon" visible="0" noclick="1"
					texture="/ui/fe2/elements/store2/cou.png" x="0" y="0" width="108i" height="108i" align="right" valign="top" />

				<image name="store2_alt_small_frame_{cat}_{id}_owned" visible="0" noclick="1" texture="/ui/fe2/elements/store2/owned_2.png" x="4i" y="-20i" width="32i" height="32i" align="right" valign="bottom" />

				<panel name="store2_alt_small_frame_{cat}_{id}_icon_panel" noclick="1"
					align="center" valign="center" width="100i" height="100i" y="-13i" visible="0" >
					<image name="store2_alt_small_frame_{cat}_{id}_icon" noclick="1" />
				</panel>
			</panel>
		</panel>
	</template>

	<template name="store2_hero_hover_info_number">
		<panel name="store2_hero_hover_info_number_{id}_parent" x="{x=0}" y="{y=0}" width="{width=33%}" height="{height=20i}" color="{color=invisible}" float="right" padding="2i" noclick="1" >
			<image texture="{texture}" valign="center" align="left" visible="{imageVisible=1}" width="{imageWidth=14i}" height="14i" noclick="1" />
			<label name="store2_hero_hover_info_number_{id}" content="{content}" valign="center" textalign="left" textvalign="center" font="{font=dyn_10}" width="-20i" color="#fff7d2" noclick="1" />
		</panel>
	</template>

	<template name="store2_hero_hover_info_attr">
		<panel name="store2_hero_hover_info_attr_{id}_parent" x="{x=0}" y="{y=0}" width="{width=32%}" height="{height=100%}" valign="{valign=top}" noclick="1" >
			<image texture="{texture}" valign="center" align="left" visible="{imageVisible=1}" x="10@" y="2%" width="95@" height="95%" noclick="1" />
			<label name="store2_hero_hover_info_attr_{id}" textvalign="center" font="{font=dyn_9}" x="110@"  noclick="1" />
			<label name="store2_hero_hover_info_attrPerLevel_{id}" textvalign="center" font="{font=dyn_9}" x="150@"  noclick="1" />
		</panel>
	</template>

	<template name="store2_hero_property_hover">
		<floater name="store2_hero_property_hover" x="22i" width="448i" grow="1" visible="0">
			<instance name="store2_frame" />
			<panel y="22i"  height="22i" noclick="1">
				<instance name="store2_hero_hover_info_number" id="atkRange" 	x="15i" 	imageWidth="0" />
				<instance name="store2_hero_hover_info_number" id="damage" 	 	x="139i" 	texture="/ui/common/damage_icon.tga" />
				<instance name="store2_hero_hover_info_number" id="atkSpeed" 	x="294i" 	imageWidth="0" />
			</panel>

			<panel y="44i"  height="22i" noclick="1">
				<instance name="store2_hero_hover_info_number" id="armor" 	 	x="15i"		texture="/ui/common/armor_icon.tga" />
				<instance name="store2_hero_hover_info_number" id="moveSpeed" 	x="139i"	texture="/ui/common/move_speed_icon.tga" />
				<instance name="store2_hero_hover_info_number" id="magicArmor" 	x="294i" 	texture="/ui/common/magic_armor_icon.tga" />
			</panel>

			<panel y="73i"  height="64i" noclick="1" align="center" width="-28i">
				<image texture="/ui/fe2/elements/store2/attrgap.png" align="center" valign="center" width="512i" height="64i" noclick="1" y="-2i"/>
				<instance name="store2_line2" valign="top" />
				<panel valign="center" height="50i" noclick="1" >
					<instance name="store2_hero_hover_info_attr" id="strength" 		x="1%"  valign="center" texture="/ui/fe2/lobby/strength.tga" />
					<instance name="store2_hero_hover_info_attr" id="agility" 		x="34%" valign="center" texture="/ui/fe2/lobby/agility.tga" />
					<instance name="store2_hero_hover_info_attr" id="intelligence" 	x="67%" valign="center" texture="/ui/fe2/lobby/intelligence.tga" />
				</panel>
				<instance name="store2_line2" valign="bottom" />
			</panel>
			<panel y="140i" height="100i" grow="true" noclick="1" width="-28i" align="center" >
				<label name="store2_hero_hover_info_text_desc" content="" font="{font=dyn_10}" color="#d3bbac"
					wrap="true" noclick="1" fity="true" fitypadding="25i"/>
			</panel>
		</floater>
	</template>

	<template name="store2_hero_skill_hover">
		<floater name="store2_hero_skill_hover" x="22i" width="370i" grow="1" visible="0">
			<panel name="store2_hero_skill_hover_content" width="370i" grow="1" visible="0">
				<instance name="store2_frame" />
				<panel float="bottom" grow='1' y="18i" x="12i" width="-24i">
					<panel height="32i" noclick="1" >
						<label name="store2_hero_skill_hover_name" color="#f0d3c1"  font="dyn_14" noclick="1" />
						<label name="store2_hero_skill_hover_mana" color="#fff7d2" font="dyn_11" textalign="right" noclick="1" />
						<instance name="store2_line2" valign="bottom" />
					</panel>
					<panel height="5i" />
					<panel height="145i" grow="1" width="-1i" >
						<label name="store2_hero_skill_hover_desc" font="dyn_10" wrap="1" color="#d3bbac" noclick="1"
							width="100%" fity="1" fitypadding="20i"/>
					</panel>
					<panel height="44i" noclick="1" >
						<label name="store2_hero_skill_hover_range" font="dyn_12" wrap="1" height="50%" valign="top" textvalign="center" color="#fff7d2" noclick="1" />
						<label name="store2_hero_skill_hover_cd" font="dyn_12" wrap="1" height="50%" valign="top" y="50%" textvalign="center" color="#fff7d2" noclick="1" />
					</panel>
					<panel height="25i" />
				</panel>
			</panel>
		</floater>
	</template>

	<template name="store2_avatar_newfeature_button_template">
		<panel name="{id}_{type}" width="120@" height="100%" noclick="true" stickytoinvis="false" watch="populateAvatarDisplay" ontrigger="SetVisible({visparam});" visible="0">
			<button width="100@" height="100%" align="center" color="invisible"
				onmouseoverlua="HoN_Store:ShowToolTip('mstore_newfeature_{type}', 'mstore_newfeature_{type}_desc', true)"
				onmouseoutlua="HoN_Store:HideToolTip()"
				onclicklua="{onclicklua}"
				onframelua="if {flash=false} then
								local value = (GetTime() % 1500) / 1500
								local alpha = math.abs(math.sin(math.pi * 2 * value))
								GetWidget('{id}_{type}_bg'):SetColor('1 1 1 '..tostring(alpha))
							end"
				>
				<widgetstate statename="up">
					<image texture="/ui/fe2/store/icons/{icon}.tga"/>
					<image name="{id}_{type}_bg" texture="/ui/fe2/store/icons/{icon}_up.tga" visible="{flash=false}"/>
					<panel color="#aaaaaa" rendermode="overlay" visible="{over=false}"/>
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/fe2/store/icons/{icon}_up.tga"/>
					<panel color="#aaaaaa" rendermode="overlay" visible="{over=false}"/>
				</widgetstate>
				<widgetstate statename="down" y="1">
					<image texture="/ui/fe2/store/icons/{icon}_up.tga"/>
					<panel color="#aaaaaa" rendermode="overlay" visible="{over=false}"/>
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="store2_avatar_feature_icons">
		<panel name="{id}" align="{align=center}" valign="{valign=top}" height="{height=48i}" width="0" grow="true" regrow="1" growinvis="false" x="{x=0}" y="{y=0}" float="right" padding="0" visible="{visible=1}">
			<instance name="store2_avatar_newfeature_button_template" id="{id}" type="hasnewseteffect" icon="newseteffect" onclicklua="HoN_Store:OnShowNewSetEffect()" flash="true"/> 
			<instance name="store2_avatar_newfeature_button_template" id="{id}" type="hasneweffects"  icon="neweffects" onclicklua="HoN_Store:OnShowNewEffects()" flash="true"/>
			<instance name="store2_avatar_newfeature_button_template" id="{id}" type="hasnewmodels" icon="newmodels" onclicklua="HoN_Store:OnShowNewModels()" flash="true"/>
			<instance name="store2_avatar_newfeature_button_template" id="{id}" type="hasnewsounds" icon="newsounds" onclicklua="HoN_Store:OnPlayAvatarSound()"/>
			<instance name="store2_avatar_newfeature_button_template" id="{id}" type="hasnewanims" icon="newanims" onclicklua="HoN_Store:OnShowNewAnims()"/>		
		</panel>
	</template>

	<template name="store2_detail_frame2x4">
		<panel name="{rootname}" align="left" valign="top" x="5i" y="293i" width="678i" height="450i" visible="1" noclick="1" >
			<label name="{rootname}_label" x="43i" height="40i" textalign="left" textvalign="top" noclick="1"
				content="{label}" font="dyn_16" color="#f0d3c1" outline="true" outlinecolor="#280b0b" />
			<!-- Avatar Frames -->
			<panel x="0" width="-80i" y="50i" height="-50i" align="center" valign="top" float="bottom" padding="25i" noclick="1" >
				<!-- Top Row -->
				<panel height="186i" padding="12i" float="right" noclick="1">
					<instance name="{frameTemplate}" cat="{cat}" id="1" visible="1" onclickframefunc="{onclickframefunc}"/>
					<instance name="{frameTemplate}" cat="{cat}" id="2" visible="1" onclickframefunc="{onclickframefunc}"/>
					<instance name="{frameTemplate}" cat="{cat}" id="3" visible="1" onclickframefunc="{onclickframefunc}"/>
					<instance name="{frameTemplate}" cat="{cat}" id="4" visible="1" onclickframefunc="{onclickframefunc}"/>
				</panel>
				<!-- Bottom Row -->
				<panel height="186i" padding="12i" float="right" noclick="1" >
					<instance name="{frameTemplate}" cat="{cat}" id="5" visible="1" onclickframefunc="{onclickframefunc}"/>
					<instance name="{frameTemplate}" cat="{cat}" id="6" visible="1" onclickframefunc="{onclickframefunc}"/>
					<instance name="{frameTemplate}" cat="{cat}" id="7" visible="1" onclickframefunc="{onclickframefunc}"/>
					<instance name="{frameTemplate}" cat="{cat}" id="8" visible="1" onclickframefunc="{onclickframefunc}"/>
				</panel>
				<!-- Highlight -->
				<modelpanel width="110%" height="105%" align="center" valign="center"
					name="store2_detail_highlight_{cat}"
					visible="0"
					model="/ui/fe2/elements/store2/selectedeffect/model.mdf"
					effect="/ui/fe2/elements/store2/selectedeffect/selected_efx.effect"
					modelangles="0 0 -90"
					anim="idle"
					camerapos="0 -2000 0"
					cameraangles="0 0 0"
					camerafov="4.42"
					carmerafar="7000"
					depthclear="false"
					depthcompress="true"
					sunazimuth="140"
					sunaltitude="10"
					suncolor="1 1 1"
					noclick="1"
					onframelua="self:BringToFront()"
					watch3="Store2ShopClosing"
					ontrigger3lua="self:SetVisible(0)"
				/>
			</panel>
			<instance name="store2_paging2" cat="{cat}" valign="bottom" height="32i" y="35i" />
		</panel>
	</template>

	<template name="store2_detail_template">
		<panel name="store2_detail_{cat}" noclick="1" visible="{visible=0}" align="center" valign="center" width="100w" height="100h" x="0" y="0"
			onshowlua="
				HoN_Store:ShowBackToListButton(true)
				{onshowlua}
			"
			onhidelua="
				HoN_Store:ShowBackToListButton(false)
				{onhidelua}
			"
			watch="BeforeRefreshStore2Tabs"
			ontriggerlua="
				if self:IsVisible() then
					self:SetVisible(false)
				end
			">

			<instance name="{contentTemplate}" cat="{cat}" />
		</panel>
	</template>

	<template name="store2_detail_large_model">
		<modelpanel
			visible="{visible=1}"
			name="{panelname}"
			width="177.78h"
			height="100h"
			align="center"
			scenebuffer="true"
			noclick="0"
			anim="idle"
			cameranear="0.0"
			camerafar="5000.0"
			depthclear="true"
			depthcompress="false"
			lookat="false"
			cameradistance="30"
			camerapos="0 1100 1500"
			cameraangles="-12 0 180"
			camerafov="7"
			shadows="1"
			modelpos="0 0 0"
			modelangles="0 0 0"
			modelscale="1.0"
			sunazimuth="120"
			sunaltitude="50"
			suncolor="0.9 0.9 0.9"
			ambientcolor="0.6 0.7 0.7"
			luatable="1"
			cull="false"
			resourcecontext="model"
			outlinecolor="white"
			processcursor="{processcursor=true}"
			model0="/ui/fe2/elements/store2/pedestal/model.mdf"
			effect0="/ui/fe2/elements/store2/pedestal/seat_light.effect"
			rotate0="true"
			modelscale0=".38"
			modelpos0="-27.0000 0.0000 1249"
			onclicklua="{onclicklua}"
			onmouseldownlua="{onmouseldownlua}"
			onmouseluplua="{onmouseluplua}"
			onevent1lua="{onevent1lua}"
			watch="Store2ShopClosing"
			ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
			watch1="Store2ShopOpening"
			ontrigger1lua="self:SetModel(0, '/ui/fe2/elements/store2/pedestal/model.mdf')
							self:SetEffect(0, '/ui/fe2/elements/store2/pedestal/seat_light.effect')"
		/>
	</template>

	<template name="store2_hero_detail_content">
		<instance name="store2_detail_large_model" panelname="store2_detail_{cat}_large_model"
			onclicklua=""
			onrightclicklua="
					if not GetCvarBool('releaseStage_stable') and GetCvarBool('store2_enable_edit') then
						HoN_Store:EditHeroFrame(self, '', 'large')
					end
					"

			onevent1lua="
				if not GetCvarBool('releaseStage_stable') and GetCvarBool('store2_enable_edit') then
					HoN_Store:EditHeroFrame(self, '', 'large')
				end
			"
			onmouseldownlua="
				GetWidget('store2_detail_'..'{cat}'..'_container'):FadeOut(300)
			"
			onmouseluplua="
				GetWidget('store2_detail_'..'{cat}'..'_container'):FadeIn(300)
			"
		/>

		<panel name="store2_detail_{cat}_center" align="center" valign="top" width="1320i" height="820i" y="120i" noclick="1" >

			<instance name="store2_detail_frame2x4" cat="{cat}" rootname="store2_detail_{cat}_avatars"
				label="store2_avatars" frameTemplate="store2_alt_small_frame" onclickframefunc="HoN_Store:OnClickHeroAvatarFrame"/>

			<panel name="store2_detail_{cat}_right" align="right" width="580i" x="1" valign="bottom" height="272i" y="6i" noclick="1" >
				<panel align="center" width="580i" valign="bottom" y="-9h" height="155i" clip="1" noclick="1">
					<panel name="store2_detail_{cat}_container" y="5i" noclick="1"
						onloadlua="
							if not GetCvarBool('store2_showModelDetail') then
								self:DoEventN(0, 'false')
							end
						"
						onshowlua="
							self:DoEventN(0, tostring(GetCvarBool('store2_isModelDetailShowing')))
						"
						onevent0lua="
							local bShow = AtoB(param)

							self:SlideY((bShow and GetCvarBool('store2_showModelDetailArrow')) and '5i' or '93i', 150)
							Set('store2_isModelDetailShowing', param)

							if GetCvarBool('store2_showModelDetailArrow') then
								GetWidget('store2_detail_'..'{cat}'..'_button_down'):SetVisible(bShow)
								GetWidget('store2_detail_'..'{cat}'..'_button_up'):SetVisible(not bShow)
							end
						"
						onevent1lua="
							Set('store2_showModelDetailArrow', param)
							local bAvatar, bShowing = AtoB(param), GetCvarBool('store2_isModelDetailShowing')

							self:SetY((bAvatar and bShowing) and '5i' or '93i')
							GetWidget('store2_detail_'..'{cat}'..'_button_down'):SetVisible(bAvatar and bShowing or false)
							GetWidget('store2_detail_'..'{cat}'..'_button_up'):SetVisible(bAvatar and not bShowing or false)
						"
					>
						<instance name="store2_frame2"/>
						<label name="store2_detail_{cat}_right_name" height="32i" y="20i" font="dyn_16" color="#d7b6a2" outline="1" outlinecolor="#241410" textalign="center" textvalign="center" noclick="1"/>
						<image texture="/ui/fe2/elements/store2/line2.png" y="60i" width="512i" height="2i" align="center" noclick="1"/>
						<instance name="store2_avatar_feature_icons" y="-32i" height="32i" visible="0" align="right" id="store2_detail_{cat}_right_icons"/>

						<instance name="store2ToggleDetailButton" panelname="store2_detail_{cat}_button_down" x="-2h" y="1h"
							onclicklua="GetWidget('store2_detail_'..'{cat}'..'_container'):DoEventN(0, 'false')"
						/>
						<instance name="store2ToggleDetailButton" panelname="store2_detail_{cat}_button_up" x="-2h" y="1h" vflip="1"
							onclicklua="GetWidget('store2_detail_'..'{cat}'..'_container'):DoEventN(0, 'true')"
						/>
					</panel>
				</panel>
				<panel align="center" width="252i" valign="top" y="176i" height="55i" noclick="0" >
					<instance name="store2_buy_button" btname="store2_detail_{cat}_right_buy" label=""
						onclicklua="HoN_Store:OnPurchaseAvatar()" />
					<instance name="store2_buy_button" btname="store2_detail_{cat}_right_gift" x="260i" y="5i" width="126i" height="40i" visible="0" imgwidth="126i" imgheight="40i" font="dyn_10" label="mstore_purchase_gift" onclicklua="HoN_Store:OnPurchase()" />
					<panel noclick="1" name="store2_detail_{cat}_right_buy_locked" visible="0" width="400i" align="center">
						<image name="store2_detail_{cat}_right_buy_locked_image" texture="/ui/fe2/elements/store2/lock.png" width="32i" height="32i" align="center" valign="center" x="-40%"/>
						<label name="store2_detail_{cat}_right_buy_locked_label" font="dyn_16" color="#a17e6d" outline="1" outlinecolor="#181110" align="center" valign="center" textalign="center" textvalign="center" uppercase="true" />
					</panel>
					<panel name="store2_detail_{cat}_right_coupon" align="right" width="72i" height="65i" x="30i" y="-1i" noclick="1">
						<image texture="/ui/fe2/elements/store2/coupon.png" width="128i" height="128i" align="center" valign="center" noclick="1"/>
					</panel>
					<panel color="invisible" clickthru="true"
						onmouseoverlua="HoN_Store:OnHoverAvatarBuyButton(true)"
						onmouseoutlua="HoN_Store:OnHoverAvatarBuyButton(false)"
						/>
				</panel>
				<panel width="1" name="store2_specials_booth_price_parent_{cat}" grow="true" height="32i" align="center" valign="top" y="238i" float="right" noclick="1" />
			</panel>
			<panel name="store2_detail_{cat}_arrows" valign="center" noclick="1" height="32i" y="-8h">
				<image texture="/ui/fe2/elements/store2/arrow2.png" width="32i" onclicklua="HoN_Store:OnHeroAvatarViewSwitchHero(false)" x="-40i"/>
				<image texture="/ui/fe2/elements/store2/arrow2.png" width="32i" onclicklua="HoN_Store:OnHeroAvatarViewSwitchHero(true)"  hflip="1" align="right" x="40i"/>
			</panel>
			<instance name="store2_hero_portrait_info" prefix="store2_detail_{cat}" width="560i" />
		</panel>
	</template>

	<template name="store2_hero_detail">
		<instance name="store2_detail_template"
			cat="heroAvatars"
			contentTemplate="store2_hero_detail_content"
			onshowlua="
				local wrapper = GetWidget('store2_hero_detail_largeModel_wrapper')
				GetWidget('store2_detail_heroAvatars_large_model'):SetParent(wrapper)
				GetWidget('store2_hero_detail_largeModel_wrapper'):SetVisible(true)
				HoN_Store:Store2SetCurrentPage('store2_hero_detail')
				HoN_Store.HeroDetailPage.IsShowing = true
				HoN_Store.BackToListCallback = function() HoN_Store:OnHeroAvatarBackToList() end
			"
			onhidelua="
				HoN_Store:OnHideHeroAvatarsPage()
				GetWidget('store2_hero_detail_largeModel_wrapper'):SetVisible(false)
				HoN_Store.HeroDetailPage.IsShowing = false
				HoN_Store.BackToListCallback = nil
			" />
			<modelpanel
				name="store2_hero_detail_screen_effect"
				visible="0"
				noclick="1"
				width="177.78h"
				height="100h"
				align="center"
				scenebuffer="true"
				anim="idle"
				cameranear="0.0"
				camerafar="5000.0"
				depthclear="true"
				depthcompress="false"
				lookat="false"
				cameradistance="30"
				camerapos="0 1100 1500"
				cameraangles="-12 0 180"
				camerafov="7"
				shadows="1"
				modelangles="0 0 0"
				sunazimuth="120"
				sunaltitude="50"
				suncolor="0.9 0.9 0.9"
				ambientcolor="0.6 0.7 0.7"
				luatable="1"
				cull="false"
				resourcecontext="model"
				outlinecolor="white"
				model="/shared/effects/screen_efx/model.mdf"
				anim1="idle"
				modelscale="1"
				modelpos="-27.0000 0.0000 1249"
			/>
	</template>

	<!-- Heroes List -->
	<template name="store2_avatars_middle_frame">
		<panel width="240i" height="340i" visible="{visible=1}" >
			<image name="store2_avatars_middle_frame_{cat}_{id}_blank" visible="1" noclick="1" texture="/ui/fe2/elements/store2/border_blank.png" width="256i" height="512i" align="center" valign="center" y="{y}"  />
			<panel name="store2_avatars_middle_frame_{cat}_{id}_panel" visible="0"
				onclicklua="self:DoEventN(1)"
				onevent1lua="self:GetWidget('store2_avatars_middle_frame_{cat}_{id}_model'):DoEventN(1)"
				onevent2lua="self:GetWidget('store2_avatars_middle_frame_{cat}_{id}_over'):FadeIn(200)"
				onmouseoverlua="
					PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
					self:DoEventN(2)
				"
				onevent3lua="self:GetWidget('store2_avatars_middle_frame_{cat}_{id}_over'):FadeOut(200)"
				onmouseoutlua="self:DoEventN(3)"
				>

				<image texture="/ui/fe2/elements/store2/border_back.tga" width="256i" height="512i" align="center" valign="center" noclick="1" />
				<modelpanel
					name="store2_avatars_middle_frame_{cat}_{id}_model"
					scenebuffer="true"
					noclick="0"
					anim="idle"
					cameranear="0.0"
					camerafar="5000.0"
					depthclear="true"
					depthcompress="false"
					lookat="false"
					cameradistance="30"
					camerapos="-32 1100 1450"
					cameraangles="0 0 180"
					camerafov="7"
					modelpos="0 0 0"
					modelangles="0 0 0"
					modelscale="1.0"
					sunazimuth="120"
					sunaltitude="50"
					suncolor="0.9 0.9 0.9"
					ambientcolor="0.6 0.7 0.7"
					luatable="1"
					cull="false"
					resourcecontext="model"
					outlinecolor="white"
					processcursor="{processcursor=true}"
					width="21h" height="24.5h" y="-3.0h" x="0h" align="center" valign="center"
					onclicklua="
						if not GetCvarBool('releaseStage_stable') and GetCvarBool('store2_enable_edit') then
							HoN_Store:EditHeroFrame(self, {id}, 'middle')
						else
							self:DoEventN(1)
						end
					"
					onevent1lua="
						{onclicklua}(self, {id}, 'middle')
					"
					onshowlua="
						if not GetCvarBool('releaseStage_stable') and GetCvarBool('store2_enable_edit') then
							self:SetNoClick(false)
						else
							self:SetNoClick(true)
						end
					"
					watch="Store2ShopClosing"
					ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
				/>
				<image name="store2_avatars_middle_frame_{cat}_{id}_blank_cover" texture="/ui/fe2/elements/store2/border_back.tga" width="256i" height="512i" align="center" valign="center" noclick="1" />

				<instance name="store2_avatars_frame_icons" prefix="store2_avatars_middle_frame_{cat}" cat="{cat}" id="{id}" y="12i" x="8i" width="-16i" showframe="false" height="28i"
					onclicklua="GetWidget('store2_avatars_middle_frame_{cat}_{id}_panel'):DoEventN(1)"
					onmouseoverlua="GetWidget('store2_avatars_middle_frame_{cat}_{id}_over'):FadeIn(200)" />

				<panel valign="bottom" y="-76i" x="8i" width="-16i" height="22i" noclick="1">
					<instance name="store2_frame" height="+12i" y="-5i" noclick="1" />
					<instance name="store2_avatars_frame_difficulty" prefix="store2_avatars_middle_frame_{cat}" cat="{cat}" id="{id}" visible="0" width="-8i" x="4i" />
					<label name="store2_avatars_middle_frame_{cat}_{id}_heroname" visible="0" noclick="1" x="12i"
							textalign="left" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_11" />
				</panel>

				<image texture="/ui/fe2/elements/store2/border.tga" width="256i" height="512i" align="center" valign="center" noclick="1" />

				<image name="store2_avatars_middle_frame_{cat}_{id}_gca" texture="/ui/fe2/elements/store2/gca.png" width="64i" height="32i" align="left" valign="center" noclick="1" x="2i" y="55i" />

				<panel name="store2_avatars_middle_frame_{cat}_{id}_over" align="center" valign="center"
					rendermode="overlay" color="{overlaycolor=#cebd9e80}" noclick="1" visible="0" x="0" y="0" width="96%" height="97%"/>

				<!-- name & price -->
				<panel name="store2_avatars_middle_frame_{cat}_{id}_bottom" noclick="1"
					valign="bottom" y="-5i" height="56i" x="10i" width="-15i"
					onevent1lua="self:GetWidget('store2_avatars_middle_frame_{cat}_{id}_name_hover_panel'):SetVisible(true)"
					>
					<panel height="50%" clickthru="true"
						onmouseoverlua="self:GetParent():DoEventN(1)"
						>
						<label name="store2_avatars_middle_frame_{cat}_{id}_name" noclick="1"
							textalign="left" textvalign="center" color="#d3bbac" outline="true" outlinecolor="#241410" font="dyn_12" />
					</panel>

					<panel name="store2_avatars_middle_frame_{cat}_{id}_name_hover_panel" align="center" width="1" height="32i" x="-2.5i" y="-2i" grow="true" visible="0"
						onmouseoutlua="self:SetVisible(false)"
						onshowlua="
							self:GetParent():GetParent():GetParent():BringToFront()
							HoN_Store:TimedCheckCursorInSidePanel(self,
								HoN_Store.TimedCheckCursorInSidePanel,
								function(panel) self:SetVisible(false) end)
						"
						clickthru="true"
						>
						<image texture="/ui/fe2/elements/store2/dotc.png" width="-16i" align="center" noclick="1" />
						<image texture="/ui/fe2/elements/store2/dotl.png" width="8i" align="left" noclick="1" />
						<image texture="/ui/fe2/elements/store2/dotr.png" width="8i" align="right" noclick="1" />
						<label name="store2_avatars_middle_frame_{cat}_{id}_name_hover" align="center" textalign="center" textvalign="center" noclick="1"
							font="dyn_12" color="#d3bbac" outline="true" outlinecolor="#241410" height="100%" fitx="1" fitxpadding="16i"/>
					</panel>

					<panel name="store2_avatars_middle_frame_{cat}_{id}_gold_panel" y="50%" height="50%" align="left" width="50%" noclick="1" >
						<image noclick="1" texture="/ui/fe2/elements/store2/gold_card.png" x="-6i" width="32i" height="32i" align="left" valign="center" />
						<label name="store2_avatars_middle_frame_{cat}_{id}_gold" noclick="1" x="24i" width="50i" align="left" valign="center" textalign="left" textvalign="center" color="#ff9c00" outline="true" outlinecolor="#241410" font="dyn_12"/>
					</panel>

					<panel name="store2_avatars_middle_frame_{cat}_{id}_silver_panel" y="50%" height="50%" align="left" width="50%" x="50%" noclick="1" >
						<image noclick="1" texture="/ui/fe2/elements/store2/silver_card.png" x="-6i" width="32i" height="32i" align="left" valign="center" />
						<label name="store2_avatars_middle_frame_{cat}_{id}_silver" noclick="1" x="24i" width="50i" align="left" valign="center" textalign="left" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12" />
					</panel>

					<panel y="50%" height="50%" noclick="1" >
						<label name="store2_avatars_middle_frame_{cat}_{id}_price" content="" visible="0" noclick="1"
							textalign="center" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12"  />
					</panel>
				</panel>

				<image name="store2_avatars_middle_frame_{cat}_{id}_coupon" visible="1" noclick="1"
					texture="/ui/fe2/elements/store2/cou.png" x="0" y="0" width="128i" height="128i" align="right" valign="top" />

				<image name="store2_avatars_middle_frame_{cat}_{id}_owned" visible="1" noclick="1" texture="/ui/fe2/elements/store2/owned.png" x="18i" y="-44i" width="64i" height="64i" align="right" valign="bottom" />

				<image name="store2_avatars_middle_frame_{cat}_{id}_test_icon"
					width="100i" height="100i" align="center" valign="center" visible="0" />
			</panel>
		</panel>
	</template>

	<template name="store2_heroavatar_model_list">
		<panel y="17h" height="66.6h" align="center" valign="top" float="bottom" padding="1.3h" noclick="1">
			<!-- Top Row -->
			<panel height="32h" padding="30i" float="right" noclick="1">
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="1" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="2" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="3" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="4" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="5" visible="1" onclicklua="{onclicklua}" />
			</panel>
			<!-- Bottom Row -->
			<panel height="32h" padding="30i" float="right" noclick="1" >
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="6" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="7" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="8" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="9" visible="1" onclicklua="{onclicklua}" />
				<instance name="store2_avatars_middle_frame" cat="{cat}" id="10" visible="1" onclicklua="{onclicklua}" />
			</panel>
		</panel>
	</template>

	<template name="store2_heroes_list">
		<panel name="store2_heroes_list" width="122.5h" align="center" noclick="1" visible="{visible=1}"
			onhidelua="HoN_Store:OnHideHeroListPage()">
			<!-- Hero Frames -->
			<instance name="store2_heroavatar_model_list" cat="hero" onclicklua="HoN_Store:OnClickHeroFrame"/>
			<!-- top bar -->
			<panel name="store2_heroes_searchbar" noclick="1" color="invisible" height="32i" align="right" x="0h" y="13h">
				<instance name="store2_title" cat="hero" label0="store2_shop" label="store2_heroes" x="5i"/>
				<instance name="store2_radio_button" id="hero_owned" text="Owned" width="90i" x="-920i" align="right" onclicklua="HoN_Store:OnHeroConditionChange('owned')" visible="false" />
				<instance name="store2_combobox" cat="hero" id="sortOrder" width="184i" x="-722i" align="right" onselectlua="HoN_Store:OnHeroConditionChange('sortOrder')" />
				<instance name="store2_combobox" cat="hero" id="primAttr" width="180i" x="-532i" align="right" onselectlua="HoN_Store:OnHeroConditionChange('primAttr')" />
				<instance name="store2_combobox" cat="hero" id="attackType" width="141i" x="-385i" align="right" onselectlua="HoN_Store:OnHeroConditionChange('attackType')" />
				<instance name="store2_combobox" cat="hero" id="role" width="117i" x="-263i" align="right" onselectlua="HoN_Store:OnHeroConditionChange('role')" />
				<instance name="store2_searchbox" cat="hero" width="257i" x="0i" height="37i" y="-2i" align="right"
					oneventlua="HoN_Store:OnSearchHero(self:GetValue())"
					onentering="HoN_Store:OnSearchingHero(self, self:GetValue())"
					/>
			</panel>
			<!-- pagging -->
			<instance name="store2_paging" cat="hero"/>
		</panel>
	</template>

	<template name="store2_heroes">
		<panel name="store2_heroes" visible="{visible=0}" noclick="1" >
			<instance name="store2_hero_ea" visible="false"/>
			<instance name="store2_heroes_list" visible="false"/>
		</panel>
	</template>

	<!-- Alt Avatars List -->
	<template name="store2_avatar_list">
		<panel name="store2_avatars_list" width="122.5h" align="center" noclick="1" visible="{visible=1}"
			onshowlua="HoN_Store:Store2SetCurrentPage('store2_avatar_list')"
			onhidelua="HoN_Store:OnHideAvatarListPage()">
			<!-- Hero Frames -->
			<instance name="store2_heroavatar_model_list" cat="avatar" onclicklua="HoN_Store:OnClickAvatarFrame"/>
			<!-- top bar -->
			<panel name="store2_avatars_searchbar" noclick="1" color="invisible" height="32i" align="right" x="0h" y="13h">
				<instance name="store2_title" cat="avatars" label0="store2_shop" label="store2_altavatars" x="5i"/>
				<instance name="store2_combobox" cat="avatars" id="sortOrder" width="184i" x="-465i" align="right" onselectlua="HoN_Store:OnAvatarConditionChange('sortOrder')" />
				<panel width="190i" x="-265i" align="right"
					watch="AccountInfo" ontrigger="SetVisible(HasAllHeroes());">
					<instance name="store2_combobox" cat="avatars" id="owned" onselectlua="HoN_Store:OnAvatarConditionChange('owned')" />
				</panel>
				<panel width="190i" x="-265i" align="right"
					watch="AccountInfo" ontrigger="SetVisible(!HasAllHeroes());">
					<instance name="store2_combobox" cat="avatars" id="ownedHeroes" onselectlua="HoN_Store:OnAvatarConditionChange('ownedHeroes')" />
				</panel>
				<instance name="store2_searchbox" cat="avatars" width="257i" x="0i" height="37i" y="-2i" align="right"
					oneventlua="HoN_Store:OnSearchAvatar(self:GetValue())"
					onentering="HoN_Store:OnSearchingAvatar(self, self:GetValue())"/>
			</panel>
			<!-- pagging -->
			<instance name="store2_paging" cat="avatars" />
		</panel>
	</template>

	<template name="store2_altavatars">
		<panel name="store2_altavatars" noclick="1" visible="{visible=0}">
			<instance name="store2_avatar_list" />
		</panel>
	</template>

	<template name="store2_vanity_frame">
		<panel name="store2_vanity_frame_{cat}_{row}_{col}" width="148i" height="210i" color="invisible" noclick="1">
			<panel name="store2_vanity_frame_{cat}_{row}_{col}_content" noclick="0" color="invisible"
				onclicklua="HoN_Store:VanityItemOnClickAction('{cat}', {row}, {col})"
				onrightclicklua="HoN_Store:VanityItemOnRightClickAction('{cat}', {row}, {col})"
				onmouseoverlua="
					PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
					HoN_Store:VanityItemOnMouseOverAction('{cat}', {row}, {col}) HoN_Store:VaultItemShowToolTip('{cat}', {row}, {col})"
				onmouseoutlua="HoN_Store:VanityItemOnMouseOutAction('{cat}', {row}, {col})">

				<image texture="/ui/fe2/elements/store2/border_s_back.png" y="-7i" width="256i" height="256i" align="center" valign="center"
					color="{bgcolor=}" rendermode="{rendermode=}" noclick="1"/>
				<image name="store2_vanity_frame_{cat}_{row}_{col}_img" visible="1" width="128i" height="128i" y="8i" align="center" valign="top" noclick="1"/>
				<image name="store2_vanity_frame_{cat}_{row}_{col}_frame" texture="{texture=}" width="256i" height="256i" align="center" valign="center" noclick="1"/>
				<image name="store2_vanity_frame_{cat}_{row}_{col}_gca" texture="/ui/fe2/elements/store2/gca.png" width="64i" height="32i" align="left" valign="center" noclick="1" x="2i" y="15i" />
				<panel name="store2_vanity_frame_{cat}_{row}_{col}_frame_over" align="center" valign="center"
					rendermode="overlay" color="{overlaycolor=#cebd9e80}" noclick="1" visible="0" x="-1i" y="-1i" width="96%" height="96%"/>

				<image name="store2_vanity_frame_{cat}_{row}_{col}_owned" visible="0" noclick="1" texture="/ui/fe2/elements/store2/owned_2.png" x="-2i" y="-65i" width="32i" height="32i" align="right" valign="bottom" />

				<panel name="store2_vanity_frame_{cat}_{row}_{col}_name" align="left" valign="bottom" x='10i' y="-38i" width="128i" height="32i"
					onclicklua="HoN_Store:VanityItemOnClickAction('{cat}', {row}, {col})"
					onrightclicklua="HoN_Store:VanityItemOnRightClickAction('{cat}', {row}, {col})"
					onmouseoverlua="HoN_Store:VanityItemOnMouseOverAction('{cat}', {row}, {col})"
					onmouseoutlua="HoN_Store:VanityItemOnMouseOutAction('{cat}', {row}, {col})">
					<label textalign="left" textvalign="center" font="dyn_10" color="{namecolor=#d3bbac}" outline="true" outlinecolor="{nameoutlinecolor=#241410}" shadow="1" shadowcolor="#000000" noclick="1" />
				</panel>
				<panel name="store2_vanity_frame_{cat}_{row}_{col}_dot_panel" x='0' y="-38i" align="center" valign="bottom" width="1" height="32i" visible="0"
					onshowlua="self:GetParent():GetParent():BringToFront()"
					onclicklua="HoN_Store:VanityItemOnClickAction('{cat}', {row}, {col})"
					onrightclicklua="HoN_Store:VanityItemOnRightClickAction('{cat}', {row}, {col})"
					onmouseoverlua="HoN_Store:VanityItemOnMouseOverAction('{cat}', {row}, {col})"
					onmouseoutlua="HoN_Store:VanityItemOnMouseOutAction('{cat}', {row}, {col}) self:SetVisible(false)">
					<image texture="/ui/fe2/elements/store2/dotl.png" width="8i" height="32i" noclick="1" align="left"
						color="{dotPanelColor=#ffffff}" rendermode="{dotPanelRenderMode=}" />
					<panel name="store2_vanity_frame_{cat}_{row}_{col}_imagec_panel" noclick="1" >
						<image name="store2_vanity_frame_{cat}_{row}_{col}_imagec" texture="/ui/fe2/elements/store2/dotc.png" align="center" height="32i" noclick="1" color="{dotPanelColor=#ffffff}" rendermode="{dotPanelRenderMode=}" />
					</panel>
					<image texture="/ui/fe2/elements/store2/dotr.png" width="8i" height="32i" noclick="1" align="right"
						color="{dotPanelColor=#ffffff}" rendermode="{dotPanelRenderMode=}" />
					<label name="store2_vanity_frame_{cat}_{row}_{col}_name_expand" align="center" textalign="center" textvalign="center"
						font="dyn_12" color="{namecolor=#d3bbac}" outline="true" outlinecolor="#241410" noclick="1"/>
				</panel>

				<panel name="store2_vanity_frame_{cat}_{row}_{col}_price" valign="bottom" y="-5i" height="32i"
					onclicklua="HoN_Store:VanityItemOnClickAction('{cat}', {row}, {col})"
					onrightclicklua="HoN_Store:VanityItemOnRightClickAction('{cat}', {row}, {col})"
					onmouseoverlua="HoN_Store:VanityItemOnMouseOverAction('{cat}', {row}, {col}) HoN_Store:VanityItemShowToolTip('{cat}', {row}, {col})"
					onmouseoutlua="HoN_Store:VanityItemOnMouseOutAction('{cat}', {row}, {col})">
					<panel name="store2_vanity_frame_{cat}_{row}_{col}_gold_panel" width="50%" align="center" x="-25%" noclick="1" >
						<image align="left" valign="bottom" x='2i' width="32i" texture="/ui/fe2/elements/store2/gold_right.png" noclick="1"/>
						<label name="store2_vanity_frame_{cat}_{row}_{col}_gold" align="left" valign="bottom" x='32i' width="44i" textalign="left" textvalign="center" content="999"
							font="dyn_10" color="#ffae00" outline="true" outlinecolor="#241410" shadow="1" shadowcolor="#000000" noclick="1"/>
					</panel>
					<panel name="store2_vanity_frame_{cat}_{row}_{col}_silver_panel" width="50%" align="center" x="25%" noclick="1" >
						<image align="left" valign="bottom" x='-6i' width="32i" texture="/ui/fe2/elements/store2/silver_right.png" noclick="1"/>
						<label name="store2_vanity_frame_{cat}_{row}_{col}_silver" align="left" valign="bottom" x='24i' width="44i" textalign="left" textvalign="center" content="9999"
							font="dyn_10" color="#bb9b87" outline="true" outlinecolor="#1b1210" shadow="1" shadowcolor="#000000" noclick="1"/>
					</panel>
					<label name="store2_vanity_frame_{cat}_{row}_{col}_price_lable" content="mstore_free" visible="0" noclick="1" align="center"
						textalign="center" textvalign="center" color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12"  />
				</panel>

				<label name="store2_vanity_frame_{cat}_{row}_{col}_selected" align="center" valign="bottom" y="-12i" height="32i" noclick="1" visible="0"
					textalign="center" textvalign="center" font="dyn_10" content="store2_vault_selected" color="#f49f06" shadow="1" shadowcolor="#0d291d" />
			</panel>

			<panel name="store2_vanity_frame_{cat}_{row}_{col}_empty" noclick="1" color="invisible" >
				<image texture="/ui/fe2/elements/store2/vanity_empty_big{imgsuffix=}.png" width="256i" height="256i" align="center" valign="center" noclick="1"/>
			</panel>
		</panel>
	</template>

