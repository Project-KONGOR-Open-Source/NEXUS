				onclicklua="HoN_Store:Store2ShowPage('selectioncircles')"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_selectioncircles')"/> -->
			<instance name="store2_tab_vanity_menu_item" y="160i" id="upgrades" menu="gamevanity" text="mstore_category75"
				onclicklua="HoN_Store:Store2ShowPage('upgrades')"  showline="false"
				onrightclicklua="HoN_Store:JumpToVaultPage('vault_upgrades')"/>
		</panel>
	</template>

	<template name="store2_vault_tab_account_vanity_menu">
		<panel x="{x}" y="{y}" width="{width=}" height="100i" noclick="0" visible="0" align="left" valign="top" color="invisible"
			watch="store2TabMenuShow"
			ontriggerlua="if param == 'vault_accountvanity' then self:SetVisible(true) end"
			watch1="store2TabMenuHide"
			ontrigger1lua="if param == 'all' or param == 'vault_accountvanity' then self:SetVisible(false) end"
			watch2="store2VanityShow"
			ontrigger2lua="if param0 ~= '' then self:SetVisible(0) end"
			onmouseoverlua="HoN_Store:TabMenuFadeIncrease('vault_accountvanity')"
			onmouseoutlua="HoN_Store:TabMenuFadeDecrease('vault_accountvanity')">
			<instance name="store2_frame" color="#00fff4" rendermode="colorscale1"/>
			<instance name="store2_tab_vanity_menu_item" y="0i" id="vault_accounticons" menu="vault_accountvanity" text="mstore_category3"
				onclicklua="HoN_Store:Store2ShowPage('vault_accounticons')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="32i" id="vault_namecolors" menu="vault_accountvanity" text="mstore_category16"
				onclicklua="HoN_Store:Store2ShowPage('vault_namecolors')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="64i" id="vault_symbols" menu="vault_accountvanity" text="mstore_category4"
				onclicklua="HoN_Store:Store2ShowPage('vault_symbols')" textColor="#c4d1cc"  showline="false" rendermode="colorscale1" linecolor="#00fff4"/>
		</panel>
	</template>

	<template name="store2_vault_tab_game_vanity_menu">
		<panel x="{x}" y="{y}" width="{width=}" height="292i" noclick="0" visible="0" align="left" valign="top" color="invisible"
			watch="store2TabMenuShow"
			ontriggerlua="if param == 'vault_gamevanity' then self:SetVisible(true) end"
			watch1="store2TabMenuHide"
			ontrigger1lua="if param == 'all' or param == 'vault_gamevanity' then self:SetVisible(false) end"
			watch2="store2VanityShow"
			ontrigger2lua="if param0 ~= '' then self:SetVisible(0) end"
			onmouseoverlua="HoN_Store:TabMenuFadeIncrease('vault_gamevanity')"
			onmouseoutlua="HoN_Store:TabMenuFadeDecrease('vault_gamevanity')">
			<instance name="store2_frame" color="#00fff4" rendermode="colorscale1"/>
			<instance name="store2_tab_vanity_menu_item" y="0i" id="vault_taunts" menu="vault_gamevanity" text="mstore_category27"
				onclicklua="HoN_Store:Store2ShowPage('vault_taunts')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="32i" id="vault_tauntbadges" menu="vault_gamevanity" text="mstore_category77"
				onclicklua="HoN_Store:Store2ShowPage('vault_tauntbadges')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
			<instance name="store2_tab_vanity_menu_item" y="64i" id="vault_announcers" menu="vault_gamevanity" text="mstore_category5"
				onclicklua="HoN_Store:Store2ShowPage('vault_announcers')" textColor="#c4d1cc" rendermode="colorscale1" linecolor="#00fff4"/>
