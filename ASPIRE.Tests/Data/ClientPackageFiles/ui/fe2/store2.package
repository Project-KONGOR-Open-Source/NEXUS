	<template name="store2_vanity_booth">
		<panel name="store2_specials_booth_{id}" x="{x}" y="{y}" width="400i" height="620i" align="{align}" valign="{valign}" visible="{visible=0}" noclick="1"
			onloadlua="HoN_Store:SetWidgetScale(self, {scale})" >
			<!-- vanity booth the main model panel -->
			<panel x="0i" y="3%" width="80h" height="45h" align="center" valign="center" onloadlua="HoN_Store:SetWidgetScale(self, {scale})" noclick="1">
				<modelpanel
					onloadlua=""
					name="store2_specials_booth_model_{id}"
					scenebuffer="true"
					noclick="0"
					anim="idle"
					cameranear="0.0"
					camerafar="5000.0"
					depthclear="true"
					depthcompress="false"
					lookat="false"
					cameradistance="30"
					camerapos="0 2200 228"
					cameraangles="-6 0 180"
					camerafov="7"
					modelpos="0 0 0"
					modelangles="0 0 0"
					modelscale="1.0"
					sunazimuth="157.9"
					sunaltitude="71.05"
					suncolor="1.08 1.08 1.08"
					ambientcolor="0.56 0.56 0.56"
					luatable="1"
					cull="false"
					resourcecontext="store"
					processcursor="true"
					model0="/ui/fe2/elements/store2/pedestal/model.mdf"
					effect0="/ui/fe2/elements/store2/pedestal/seat_light.effect"
					rotate0="true"
					model1="/shared/models/invis.mdf"
					model2="/shared/models/invis.mdf"
					anim1="idle"
					anim2="idle"
					onmouseldownlua="
						GetWidget('st2_sp_booth_vanity_info_container'):FadeOut(300)
					"
					onmouseluplua="
						GetWidget('st2_sp_booth_vanity_info_container'):FadeIn(300)
					"
					watch="Store2ShopClosing"
					ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
				/>
			</panel>

			<!-- announcers preview model -->
			<panel x="0i" y="0i" width="64h" height="24h" align="center" valign="center" onloadlua="HoN_Store:SetWidgetScale(self, {scale=1})" noclick="1">
				<modelpanel
					width="177.78h" height="60h" y="-60i"
					name="store2_specials_booth_announcers_model_content_{id}"
					resourcecontext="store"
					visible="0"
					noclick="true"
					anim="idle"
					cameradistance="0"
					lookat="false"
					camerapos="-220 1200 -100"
					cameraangles="0 0 180"
					camerafov="50"
					cameranear="1"
					carmerafar="5000"
					modelpos="0 0 -10"
					modelscale=".4"
					depthclear="true"
					depthcompress="true"
					sunazimuth="-90"
					sunaltitude="180"
					suncolor="1 1 1"
					scenebuffer="1"
					watch="Store2ShopClosing"
					ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
				/>
			</panel>

			<!-- taunt preview models -->
			<panel align="center" valign="center" height="-20h" noclick="1">
				<modelpanel
					name="store2_{id}_booth_taunt_modelpanel"
					width="177.78h" height="75h"
					align="center"
					model="/shared/models/invis.mdf"
					model0="/shared/models/invis.mdf"
					anim="idle"
					cameranear="0.0"
					camerafar="5000.0"
					depthclear="true"
					depthcompress="false"
					lookat="false"
					cameradistance="30"
					camerapos="0 1100 1500"
					cameraangles="-12 0 180"
					camerafov="7"
					shadows="1"
					modelpos="0 0 1252"
					modelpos0="0 0 1252"
					modelscale="0.2"
					modelscale0=".26"
					sunazimuth="120"
					sunaltitude="50"
					suncolor="0.9 0.9 0.9"
					ambientcolor="0.6 0.7 0.7"
					cull="false"
					visible="0"
					resourcecontext="store2_taunt_preview"
					usemodifiers="true"
					scenebuffer="true"
					noclick="1"
					onhidelua="DeleteResourceContext('store2_taunt_preview')"
					onmouseldownlua="Echo('store2_'..'{id}'..'_booth_taunt_modelpanel: onmouseldownlua')"
					onmouseluplua="Echo('store2_'..'{id}'..':_booth_taunt_modelpanel onmouseluplua')"
					watch="Store2ShopClosing"
					ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
				/>
			</panel>

			<!-- vanity booth icon -->
			<panel name="st2_sp_booth_icon_panel_{id}" width="512i" height="512i" align="center" valign="center" x="0" y="-90i" noclick="1" color="invisible" >
				<modelpanel
					align="center"
					valign="center"
					height="300h"
					width="300h"
					noclick="true"
					anim="idle"
					camerapos="0 -1800 00"
					cameraangles="0 0 0"
					camerafov="35"
					modelangles="0 0 180"
					modelpos="0 0 0"
					lookat="0"
					visible="1"
					model="/shared/models/invis.mdf"
					effect="elements/store2/selectedeffect/item_image_bg.effect"
				/>
				<image texture="/ui/fe2/elements/store2/border_s_back.png" align="center" valign="center" y="-28i" width="260i" height="256i" noclick="1" onshowlua="
						local color = '#ffffff'
						local mode = 'normal'
						if HoN_Store:IsVaultOpened() then
							color = '#44DDEE'
							mode = 'colorscale1'
						end
						self:SetColor(color)
						self:SetRenderMode(mode)
					"/>
				<image name="st2_sp_booth_icon_{id}" align="center" valign="center" x="1i" y="-36i" width="128i" height="128i" noclick="1" />
				<image name="st2_sp_booth_icon_play_{id}" align="center" valign="center" x="1i" y="-36i" width="128i" height="128i" noclick="0"
					texture="/ui/fe2/elements/store2/boothplay.png"
					onmouseoverlua="GetWidget('st2_sp_booth_icon_play_over_{id}'):SetVisible(1) self:SetVisible(0)"/>
				<image name="st2_sp_booth_icon_play_over_{id}" align="center" valign="center" x="1i" y="-36i" width="128i" height="128i" noclick="0"
					texture="/ui/fe2/elements/store2/boothplayover.png"
					onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')"
					onmouseoutlua="GetWidget('st2_sp_booth_icon_play_{id}'):SetVisible(1) self:SetVisible(0)"/>
				<image texture="/ui/fe2/elements/store2/vanityboothframe.png" align="center" valign="center" width="512i" height="512i" noclick="1" onshowlua="
						local tex = '/ui/fe2/elements/store2/vanityboothframe.png'
						if HoN_Store:IsVaultOpened() then
							tex = '/ui/fe2/elements/store2/vanityboothframe_vault.png'
						end
						self:SetTexture(tex)
					"/>
				<label name="st2_sp_booth_icon_namecolor_{id}" y="45i" content="Name Color" align="center" valign="center" textalign="center" textvalign="center" height="32i" noclick="1" font="dyn_14" />
			</panel>

			<!-- bundle detail chest -->
			<panel name="store2_specials_booth_bundle_chest_panel_{id}" width="512i" height="512i" valign="center" align="center" y="150i">
				<modelpanel
					name="store2_specials_booth_bundle_chest_model_{id}"
					width="800i"
					height="800"
					align="center"
					valign="center"
					scenebuffer="true"
					noclick="0"
					anim="idle"
					cameranear="0.0"
					camerafar="5000.0"
					depthclear="true"
					depthcompress="false"
					lookat="true"
					cameradistance="30"
					camerapos="0 1400 585"
					cameraangles="-21 0 180"
					camerafov="7"
					shadows="1"
					sunazimuth="120"
					sunaltitude="50"
					suncolor="0.9 0.9 0.9"
					ambientcolor="0.6 0.7 0.7"
					luatable="1"
					cull="false"
					resourcecontext="model"
					processcursor="true"
					model="/ui/fe2/elements/store2/pedestal/model.mdf"
					effect="/ui/fe2/elements/store2/pedestal/seat_light.effect"
					modelscale="0.7"
					modelpos="0 0 0"
					modelangles="0 0 65"
					model0="/ui/fe2/grabbag/lucky_bundle/footlocker.mdf"
					effect0="/ui/fe2/grabbag/lucky_bundle/hover_effect.effect"
					modelscale0="0.5"
					modelpos0="0 0 0"
					modelangles0="0 0 65"
					rotate0="true"
				/>
			</panel>

			<panel name="st2_sp_booth_{id}_detail_panel" align="center" width="580i" x="1" valign="bottom" height="272i" y="0" noclick="1" visible="1">
				<panel name="st2_sp_booth_{id}_info_panel" align="center" width="580i" valign="bottom" y="-92i" height="255i" clip="1" noclick="1">

					<panel name="st2_sp_booth_{id}_info_container" width="580i" noclick="1" height="1" grow="1" float="bottom" valign="bottom" y="0i"
						onshowlua="
							self:DoEventN(1)
						"
						onevent0lua="
							Set('store2_isModelDetailShowing', param)
							local bShowing = AtoB(param)
							
							local y = 0
							if not bShowing then
								y = self:GetHeight() - self:GetYFromString('55i')
							end
							self:SlideY(y, 150)

							GetWidget('st2_sp_booth_'..'{id}'..'_info_button_down'):SetVisible(bShowing)
							GetWidget('st2_sp_booth_'..'{id}'..'_info_button_up'):SetVisible(not bShowing)
						"
						onevent1lua="
							local bShowArrow, bShowing = GetCvarBool('store2_showModelDetailArrow'), GetCvarBool('store2_isModelDetailShowing')

							local y = 0
							if bShowArrow and not bShowing then
								y = self:GetHeight() - self:GetYFromString('55i')
							end
							self:SetY(y)

							GetWidget('st2_sp_booth_'..'{id}'..'_info_button_down'):SetVisible(bShowArrow and bShowing or false)
							GetWidget('st2_sp_booth_'..'{id}'..'_info_button_up'):SetVisible(bShowArrow and not bShowing or false)
						"
					>
						<instance name="store2_frame2" />
						<!-- vanity booth name -->
						<label name="st2_sp_booth_name_label_{id}" font="dyn_16" color="#d7b6a2" outline="true" outlinecolor="#241410" textalign="center" textvalign="top" y="18i" noclick="1" fity="1" />

						<image texture="/ui/fe2/elements/store2/line2.png" width="512i" height="2i" align="center" y="52i" noclick="1"
							onshowlua="
								local color = '#ffffff'
								local mode = 'normal'
								if HoN_Store:IsVaultOpened() then
									color = '#44DDEE'
									mode = 'colorscale1'
								end
								self:SetColor(color)
								self:SetRenderMode(mode)
							"/>
						<!-- vanity booth name -->
						<label name="st2_sp_booth_description_label_{id}" width="80%" font="dyn_12" color="#d7b6a2" outline="1" outlinecolor="#241410" align="center" textalign="left" textvalign="top" y="70i" content="none" wrap="true" noclick="1" fity="1" fitypadding="20i" />
						<label name="st2_sp_booth_description2_label_{id}" width="80%" font="dyn_12" color="#d7b6a2" outline="1" outlinecolor="#241410" align="center" textalign="center" textvalign="top" y="70i" content="none" wrap="1" visible="0" noclick="1" fity="1" fitypadding="20i" />
						<panel name="st2_sp_booth_preview_list_panel" visible="1" noclick="1" height="1" width="100%" align="center">
							<image name="st2_sp_booth_line_{id}" texture="/ui/fe2/elements/store2/line2.png" y="10i" width="475i" height="2i" align="center" noclick="1"
								onshowlua="
									local color = '#ffffff'
									local mode = 'normal'
									if HoN_Store:IsVaultOpened() then
										color = '#44DDEE'
										mode = 'colorscale1'
									end
									self:SetColor(color)
									self:SetRenderMode(mode)
								"/>
							<!-- vanity booth announcer preview options -->
							<instance name="store2_specials_booth_announcers_preview_list" y="18i" id="{id}" width="515i" height="115i" visible="0" align="center"/>
							<instance name="store2_specials_booth_creeps_preview_list"  y="18i" id="{id}" width="515i" height="115i" visible="0" align="center"/>
						</panel>

						<instance name="store2ToggleDetailButton" panelname="st2_sp_booth_{id}_info_button_down" x="-2h" y="1h"
							onclicklua="GetWidget('st2_sp_booth_'..'{id}'..'_info_container'):DoEventN(0, 'false')"
						/>
						<instance name="store2ToggleDetailButton" panelname="st2_sp_booth_{id}_info_button_up" x="-2h" y="1h" vflip="1"
							onclicklua="GetWidget('st2_sp_booth_'..'{id}'..'_info_container'):DoEventN(0, 'true')"
						/>
					</panel>
 				</panel>
 				<panel name="st2_sp_booth_{id}_buttons" align="center" width="580i" valign="bottom" y="0i" height="255i" noclick="1" >
					<!-- vanity booth buy -->
					<panel align="center" width="200i" valign="top" y="176i" height="65i" noclick="1" >
						<instance name="store2_specials_booth_buy_button" id="{id}" align="center" valign="center" showdiscount="{showdiscount=1}" scale="{buyScale}" onclicklua="HoN_Store:OnPurchaseVanity()"/>
					</panel>
					<!-- vanity booth choose -->
					<panel align="center" width="200i" valign="top" y="176i" height="65i" noclick="1" >
						<instance name="store2_specials_booth_choose_button" id="{id}" align="center" valign="center" showdiscount="{showdiscount=1}" onclicklua="HoN_Store:Store2VanityChoose()"/>
					</panel>
					<!-- vanity booth owned/locked -->
					<panel align="center" width="200i" valign="top" y="176i" height="65i" noclick="1" >
						<instance name="store2_specials_booth_owned_button" id="{id}" align="center" valign="center" onmouseoverlua="HoN_Store:VanityItemShowToolTip()" onmouseoutlua="HoN_Store:HideToolTip()" onclicklua="HoN_Store:VanityBoothButtomOnClickAction()" onrightclicklua="HoN_Store:VanityItemOnRightClickAction()" enabled="true"/>
					</panel>
					<!-- gift button -->
					<panel align="center" width="200i" valign="top" x="200i" y="193i" height="30i" noclick="1">
						<instance name="store2_buy_button" btname="store2_specials_booth_gift_button_{id}" visible="0" align="center" valign="center" width="126i" height="40i" imgwidth="126i" imgheight="40i" font="dyn_10" label="mstore_purchase_gift" onclicklua="HoN_Store:Gift()" />
					</panel>
					<!-- vanity booth price -->
					<panel align="center" width="200i" valign="top" y="238i" height="30i" noclick="1">
						<panel width="1" name="store2_specials_booth_price_parent_{id}" grow="1" height="32i" align="center" valign="center" float="right"/>
					</panel>
 				</panel>
			</panel>

			<panel name="store2_vanity_switchbtn_root_{id}" grow="1" regrow="1" growinvis="false" align="right" valign="bottom" x="-40i" y="-205i" height="32i" visible="0" float="right" padding="4i">
				<instance name="store2_vanity_switchbtn_template" index="1" id="{id}"/>
				<instance name="store2_vanity_switchbtn_template" index="2" id="{id}"/>
				<instance name="store2_vanity_switchbtn_template" index="3" id="{id}"/>
				<instance name="store2_vanity_switchbtn_template" index="4" id="{id}"/>
			</panel>
			<!-- bundle detail -->
			<panel name="store2_specials_booth_bundle_panel_{id}" align="center" valign="bottom" height="250i" noclick="1" y="10i">
				<panel name="store2_specials_booth_bundle_price_{id}" align="center" valign="bottom" regrow="true" grow="true" growinvis="false" y="0" height="32i" float="right" padding="1i" noclick="1">
					<image name="store2_specials_booth_bundle_gold_icon_{id}" texture="/ui/fe2/elements/store2/gold_card.png" width="32i" height="32i" noclick="1" stickytoinvis="false"/>
					<label name="store2_specials_booth_bundle_gold_{id}" width="1" fitx="1" textalign="left" textvalign="center"
						color="#ff9c00" outline="true" outlinecolor="#241410" font="dyn_12" content="" noclick="1" fitxpadding="5i" stickytoinvis="false"/>
					<label name="store2_specials_booth_bundle_saves_{id}" width="1" fitx="1" textalign="left" textvalign="center"
						color="#d7b6a2" outline="true" outlinecolor="#241410" font="dyn_12" content="" noclick="1" fitxpadding="5i" stickytoinvis="false"/>
					<image name="store2_specials_booth_bundle_silver_icon_{id}" texture="/ui/fe2/elements/store2/silver_card.png" width="32i" height="32i" noclick="1" sticky="true" stickytoinvis="false"/>
					<label name="store2_specials_booth_bundle_silver_{id}" width="1" fitx="1" textalign="left" textvalign="center"
						color="#bb9b87" outline="true" outlinecolor="#241410" font="dyn_12" content="" noclick="1" fitxpadding="10i" sticky="true" stickytoinvis="false"/>	
				</panel>
				<panel width="128i" height="128i" align="center" valign="bottom" y="10i" x="158i" noclick="1">
					<panel name="store2_specials_booth_bundle_onsale_{id}" noclick="1">
						<image texture="/ui/fe2/elements/store2/onsale.png" noclick="1"/>
						<label name="store2_specials_booth_bundle_onsale_percent_{id}" content=""
							textalign="right" textvalign="bottom" x="8i" width="52%" height="30%" y="22%"
							font="dyn_18" color="#fdffff" shadow="true" shadowcolor="#076878" outline="true" outlinecolor="#076878" noclick="1"/>
					</panel>
					<panel name="store2_specials_booth_bundle_lucky_{id}" noclick="1">
						<image texture="/ui/fe2/elements/store2/chance.png" noclick="1"/>
						<label name="store2_specials_booth_bundle_lucky_count_{id}" content=""
							textalign="center" textvalign="bottom" x="0" width="100%" height="30%" y="20%" align="center"
							font="dyn_18" color="#fdffff" shadow="true" shadowcolor="#7f071d" outline="true" outlinecolor="#7f071d" noclick="1"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="store2_specials">
		<panel name="store2_specials" width="122.5h" align="center" noclick="0" visible="{visible=0}" height="80h" valign="center"
			onshowlua="
				HoN_Store:Store2SetCurrentPage('store2_specials') 
				HoN_Store:Store2DailySpecialFormGet(true)
				HoN_Store.MouseEverOverSpecials = false
			"
			onhidelua="HoN_Store:Store2SetCurrentPage('') HoN_Store:Store2DailySpecialOnHide()" 
			onmouseoverlua="HoN_Store.MouseEverOverSpecials = true">
			<instance name="store2_specials_booth" id="4" x="0%" y="-50i" align="left" valign="center" visible="0" scale="0.7" rsdate_scale="0.7" saleScale="0.8" autofontmax="12"/>
			<instance name="store2_specials_booth" id="5" x="0%" y="-50i" align="right" valign="center" visible="0" scale="0.7" rsdate_scale="0.7" saleScale="0.8" autofontmax="12"/>
			<instance name="store2_specials_booth" id="2" x="16%" y="0i" align="left" valign="center" visible="0" scale="0.78" rsdate_scale="0.78" saleScale="0.9" autofontmax="14"/>
			<instance name="store2_specials_booth" id="3" x="-16%" y="0i" align="right" valign="center" visible="0" scale="0.78" rsdate_scale="0.78" saleScale="0.9" autofontmax="14"/>
			<instance name="store2_specials_booth" id="1" x="0" y="20i" align="center" valign="center" visible="0" scale="1" rsdate_scale="1" saleScale="1" autofontmax="16"/>
		</panel>
	</template>

	<!-- common elements -->
	<template name="store2_title">
		<panel name="store2_title_{cat}" height="{height=3h}" x="{x=0h}" y="{y=0h}" float="right" noclick="1" >
			<panel grow="true" noclick="0" >
				<label height="3h" textalign="left" textvalign="bottom" fitx="true" noclick="0"
					content="{label0}" font="dyn_18" color="{color=#f0d3c1}" outline="true" outlinecolor="{outlinecolor=#422727}" />
			</panel>
			<panel grow="true" noclick="0" >
				<label height="2.6h" textalign="left" textvalign="bottom" fitx="true" noclick="0"
					content=" \ " font="dyn_12" color="{color=#f0d3c1}" outline="true" outlinecolor="{outlinecolor=#422727}" />
			</panel>
			<panel grow="true" noclick="0" >
				<label height="2.8h" textalign="left" textvalign="bottom" fitx="true" noclick="0"
					content="{label}" font="dyn_12" color="{color=#f0d3c1}" outline="true" outlinecolor="{outlinecolor=#422727}" />
			</panel>
			<panel grow="true" visible="{haslabel2=false}" noclick="1" >
				<label height="2.6h" textalign="left" textvalign="bottom" fitx="true" noclick="1"
					content=" \ " font="dyn_12" color="{color=#f0d3c1}" outline="true" outlinecolor="{outlinecolor=#422727}" />
			</panel>
			<panel grow="true" visible="{haslabel2=false}" noclick="1" >
				<label height="2.8h" textalign="left" textvalign="bottom" fitx="true" noclick="1"
					content="{label2=''}" font="dyn_12" color="{color=#f0d3c1}" outline="true" outlinecolor="{outlinecolor=#422727}" />
			</panel>
		</panel>
	</template>

	<template name="store2_line2">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=2i}" align="{align=}" valign="{valign=top}" visible="{visible=1}" color="{color=invisible}" noclick="1">
			<image texture="/ui/fe2/elements/store2/line2.png" width="{width=100%}" height="2i" align="center" valign="center" noclick="1"/>
		</panel>
	</template>

	<template name="store2_hline">
		<image texture="/ui/fe2/elements/store2/hline.png" x="{x=0}" y="{y=0}" width="3" height="{height=100%}" align="{align=left}" noclick="1" />
	</template>

	<template name="store2_hline2">
		<panel x="{x=0}" y="{y=0}" width="1" height="{height=100%}" align="{align=center}" valign="{valign=center}" color="#815b5480" noclick="1" />
	</template>

	<template name="store2_frame">
		<frame texture="/ui/fe2/elements/store2/frame/frame.png" borderthickness="16i" noclick="1" color="{color=white}" x="{x=0}" y="{y=0}" width="{width=100%}" height="{height=100%}" visible="{visible=1}"
			rendermode="{rendermode=}"/>
	</template>

	<template name="store2_frame2">
		<image texture="/ui/fe2/elements/store2/frame/frame2_top.png" align="center" y="-8i" width="256i" height="16i" noclick="1"
			onshowlua="
				local tex = '/ui/fe2/elements/store2/frame/frame2_top.png'
				if HoN_Store:IsVaultOpened() then
					tex = '/ui/fe2/elements/store2/frame/frame3_top.png'
				end
				self:SetTexture(tex)
			"/>
		<frame texture="/ui/fe2/elements/store2/frame/frame2.png" borderthickness="32i" noclick="1" color="{color=white}" x="{x=0}" y="{y=0}" width="{width=100%}" height="{height=100%}"
			onshowlua="
				local tex = '/ui/fe2/elements/store2/frame/frame2.png'
				if HoN_Store:IsVaultOpened() then
					tex = '/ui/fe2/elements/store2/frame/frame3.png'
				end
				self:SetTexture(tex)
			"/>
	</template>

	<template name="store2_searchbox">
		<panel name="store2_searchbox_{cat}" width="{width=16h}" height="{height=3h}" x="{x=0}" y="{y=0}" align="{align=left}" noclick="1" >
			<instance name="store2_frame" />
			<textbox name="store2_searchbox_{cat}_textbox" align="left" valign="center" width="-4h" height="-0.64h" x="10i" y=".32h"
				textvalign="center" textcolor="#8e6b5b" color="invisible" font="dyn_11"
				onevent1lua="{oneventlua=}"
				onevent2lua="{onentering}"
				onenter="DoEvent(1);"
				onesc=""
				ontab=""
				onchange="DoEvent(2);"
				onfocus="DoEvent(2);"
				onlosefocuslua="self:GetWidget('store2_searchbox_{cat}_listPanel'):SetVisible(false)"
				onshowlua=" local searchterm = GetCvarString('store2_initSearchTerm')
							if NotEmpty(searchterm) then
								self:SetInputLine(searchterm)
								self:DoEventN(1)
								Set('store2_initSearchTerm', '', 'string')
							end"
				/>
			<button name="store2_searchbox_{cat}_bt" color="invisible" width="32i" height="32i" valign="center" align="right" x="-0.2h"
				onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')"
				onclick="CallEvent('store2_searchbox_{cat}_textbox', 1);">
				<widgetstate statename="up">
					<image texture="/ui/fe2/elements/store2/search.png"/>
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/fe2/elements/store2/search_over.png"/>
				</widgetstate>
				<widgetstate statename="down">
					<image texture="/ui/fe2/elements/store2/search_over.png"/>
				</widgetstate>
			</button>
			<panel name="store2_searchbox_{cat}_listPanel" y="32i" width="100%" grow="true" visible="0" noclick="1">
				<instance name="store2_frame" />
				<panel name="store2_searchbox_{cat}_list" vmargin="10i" width="100%"
					height="0" grow="true" float="bottom">
				</panel>
			</panel>
		</panel>
	</template>

	<template name="store2_heroes_list_search_item">
		<panel height="50i" x="10i" width="-20i" y="{y}"
			onmouseoverlua="
				self:GetWidget('{prefix}_label'):SetColor('#af8775')
				self:GetWidget('{prefix}_difficulty'):SetColor('#af8775')
				self:GetWidget('{prefix}_highlight'):SetVisible(true)
			"
			onmouseoutlua="
				self:GetWidget('{prefix}_label'):SetColor('#8e6b5b')
				self:GetWidget('{prefix}_difficulty'):SetColor('#8e6b5b')
				self:GetWidget('{prefix}_highlight'):SetVisible(false)
			"
			onclicklua="
				HoN_Store:OnClickSearchingHeroItem({i})
			"
			>
			<frame name="{prefix}_highlight" color="#cda5963b" align="center" valign="center" width="+14i" visible="0" noclick="1" />
			<panel width="47i" height="47i" color="#8e6b5b" noclick="1" >
				<image name="{prefix}_icon" x="1i" y="1i" width="45i" height="45i" texture="{texture}" visible="1" noclick="1" />
			</panel>
			<panel x="60i" width="-60i" height="45i" noclick="1" >
				<label name="{prefix}_label" font="dyn_12" autofont="1" autofontmax="12" height="20i" content="{label}" color="#8e6b5b" noclick="1" onhidelua="self:SetFont('dyn_12')"/>
				<panel y="20i" height="20i" grow="true" float="right" noclick="1" padding="2i" >
					<label name="{prefix}_difficulty" font="dyn_10" fitx="true" content="mstore_difficulty" color="#8e6b5b" noclick="1" />
					<panel width="10i" noclick="1" />
					<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_1" width="80@" height="60%" noclick="1" />
					<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_2" width="80@" height="60%" noclick="1" />
					<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_3" width="80@" height="60%" noclick="1" />
					<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_4" width="80@" height="60%" noclick="1" />
					<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_5" width="80@" height="60%" noclick="1" />
				</panel>
			</panel>
			<instance name="store2_line2" valign="bottom" visible="{showline=true}" />
		</panel>
	</template>

	<template name="store2_heroes_list_search_item_end">
		<panel height="{height=32i}" width='-20i'
			onclicklua="GetWidget('store2_searchbox_{cat}_textbox'):DoEventN(1)">
			<label textalign="center" textvalign="top" font="dyn_12" autofont="1" autofontmax="12" content="{text}" color="#8e6b5b" noclick="1" onhidelua="self:SetFont('dyn_12')"/>
		</panel>
	</template>

	<template name="store2_avatars_list_search_item">
		<panel height="50i" x="10i" width="-20i" y="{y}"
			onmouseoverlua="
				self:GetWidget('{prefix}_label'):SetColor('#af8775')
				self:GetWidget('{prefix}_highlight'):SetVisible(true)
			"
			onmouseoutlua="
				self:GetWidget('{prefix}_label'):SetColor('#8e6b5b')
				self:GetWidget('{prefix}_highlight'):SetVisible(false)
			"
			onclicklua="
				HoN_Store:OnClickSearchingAvatarItem({i})
			"
			>
			<frame name="{prefix}_highlight" color="#cda5963b" align="center" valign="center" width="+14i" y="-1i" visible="0" noclick="1" />
			<panel width="47i" height="47i" color="#8e6b5b" noclick="1" >
				<image name="{prefix}_icon" x="1i" y="1i" width="-2i" height="-2i" texture="{texture}" visible="1" noclick="1" />
			</panel>
			<panel x="60i" width="-60i" height="45i" noclick="1" >
				<label name="{prefix}_label" font="dyn_12" autofont="1" autofontmax="12" height="20i" content="{label}" color="#8e6b5b" noclick="1" onhidelua="self:SetFont('dyn_12')"/>
				<panel y="20i" width="22i" height="22i" color="#8e6b5b" noclick="1" >
					<image name="{prefix}_icon2" x="1i" y="1i" width="-2i" height="-2i" texture="{texture2}" visible="1" noclick="1" />
				</panel>
				<label name="{prefix}_label2" font="dyn_10" autofont="1" autofontmax="10" height="-20i" content="{label2}" color="#8e6b5b" noclick="1" y="20i" textvalign="center" x="28i" width="-22i" onhidelua="self:SetFont('dyn_12')"/>
			</panel>
			<instance name="store2_line2" valign="bottom" visible="{showline=true}" />
		</panel>
	</template>

	<template name="store2_combobox_state">
		<widgetstate statename="{state}">
			<instance name="store2_frame" y="-2i" height="+4i"/>
			<image x="0" width="3h" height="3h" align="right" valign="center" texture="/ui/fe2/elements/store2/ar{texSuffix}.png" />
		</widgetstate>
	</template>

	<template name="store2_combobox_list_item">
		<listitem value="{value}">
			<label content="{label}" x="10i" height="3h" textalign="left" textvalign="center"
				font="dyn_11" color="{color=#8e6b5b}" outline="true" outlinecolor="{outlinecolor=#241410}" />
		</listitem>
	</template>

	<template name="store2_combobox">
		<combobox width="{width=100%}" height="{height=100%}" x="{x=0}" y="{y=0}" align="{align=left}" valign="top"
			name="store2_combobox_{cat}_{id}"
			color="invisible"
			itemwidth="100%"
			itemheight="32i"
			highlightcolor="0.5 0.5 0.5 0"
			highlightbordercolor="invisible"
			scrollbarsize="0"
			cvar="store2_combobox_{cat}_{id}_value"
			onmouseoverlua="PlaySound('/shared/sounds/ui/button_over_02.wav')"
			onloadlua="
				local items = HoN_Store.comboItems.{cat}.{id}
				for i,v in pairs(items) do
					self:Instantiate('store2_combobox_list_item', 'value', i, 'label', Translate(v.label))
				end
				Set('store2_combobox_{cat}_{id}_value', 1, 'int', true)
			"
			onselectlua="PlaySound('/shared/sounds/ui/button_click_05.wav') {onselectlua=}"
			>
			<instance name="store2_combobox_state" state="up" texSuffix="" />
			<instance name="store2_combobox_state" state="over" texSuffix="_over" />
			<instance name="store2_combobox_state" state="down" texSuffix="_over" />
			<widgetstate statename="listbg">
				<instance name="store2_frame" y="-2i" height="+4i"/>
			</widgetstate>
			<widgetstate statename="itembg">
				<image texture="/ui/fe2/elements/store2/line.png" align="center" valign="top" y="-37i" width="148%" height="64i"/>
			</widgetstate>
			<widgetstate statename="itemhighlight">
				<frame color="#cda5963b" align="center" valign="center" width="-6i" height="-1i" y="-1i" />
			</widgetstate>
		</combobox>
	</template>

	<template name="store2_radio_button">
		<panel name="store2_radio_button_{id}" width="{width=100i}" height="{height=3h}" x="{x=0}" y="{y=0}" align="{align=left}" visible="{visible=true}"
			onloadlua="
				Set('store2_radio_button_{id}_isOn', {isOn=true}, 'bool', true)
			"
			onclick="DoEvent(1);"
			onclicklua="{onclicklua=}"
			onevent1lua="
				local cvar = 'store2_radio_button_{id}_isOn'
				local isOn = not GetCvarBool(cvar)
				Set(cvar, isOn)
				local ap = (isOn and '_o') or ''
				self:GetWidget('store2_radio_button_{id}_image'):SetTexture('/ui/fe2/elements/store2/s'..ap..'.png')
			"
		>
			<image name="store2_radio_button_{id}_image" x="0" width="32i" texture="/ui/fe2/elements/store2/s_o.png" noclick="true" />
			<label content="{text}" x="32i" textalign="left" textvalign="center" font="dyn_11" noclick="true"
				color="#c6957f" outline="true" outlinecolor="#241410" shadow="true" shadowcolor="#0000007F" />
		</panel>
	</template>

	<template name="store2_difficulty_diamond">
		<panel width="{width=32i}" height="{height=32i}" noclick="{noclick=1}" >
			<image name="{id}" texture="/ui/fe2/elements/store2/DI.png" x="{x=0}" width="32i" height="32i" align="center" valign="center" noclick="1" />
		</panel>
	</template>

	<template name="store2_difficulty_diamond2">
		<panel width="{width=32i}" height="{height=32i}" noclick="{noclick=1}" >
			<image name="{id}" texture="/ui/fe2/elements/store2/DI.png" x="{x=0}" width="160%" height="160%" align="center" valign="center" noclick="1" />
		</panel>
	</template>

	<template name="store2_buy_button">
		<button
			name="{btname}"
			x="{x=}" y="{y=}"
			width="{width=252i}" height="{height=46i}"
			align="{align}" valign="{valign}"
			color="invisible"
			onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')"
			onclick="PlaySound('/shared/sounds/ui/ccpanel/button_click_02.wav'); {onclick}"
			onclicklua="{onclicklua}"
			visible="{visible=1}"
			enabled="{enabled=true}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			onevent="{onevent}"
			oneventlua="{oneventlua}"
			onevent0="{onevent0}" onevent0lua="{onevent0lua}"
			onevent1="{onevent1}" onevent1lua="{onevent1lua}"
			onevent2="{onevent2}" onevent2lua="{onevent2lua}"
			onevent3="{onevent3}" onevent3lua="{onevent3lua}"
			onevent4="{onevent4}" onevent4lua="{onevent4lua}"
			onevent5="{onevent5}" onevent5lua="{onevent5lua}"
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/elements/store2/button_buy.png" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center"/>
				<label name="{btname}_up" content="{label}" font="{font=dyn_16}" color="{color=#fffefc}" outline="1" outlinecolor="{outlinecolor=#c36000}" align="center" valign="center" textalign="center" textvalign="center" uppercase="true" />
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/elements/store2/button_buy_over.png" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center"/>
				<label name="{btname}_over" content="{label}" font="{font=dyn_16}" color="{color=#fffefc}" outline="1" outlinecolor="{outlinecolor=#c36000}" align="center" valign="center" textalign="center" textvalign="center" uppercase="true" />
			</widgetstate>
			<widgetstate statename="down">
				<image texture="/ui/fe2/elements/store2/button_buy_over.png" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center"/>
				<label name="{btname}_down" content="{label}" font="{font=dyn_16}" color="{color=#fffefc}" outline="1" outlinecolor="{outlinecolor=#c36000}" align="center" valign="center" textalign="center" textvalign="center" x=".1h" y=".2h" uppercase="true" />
			</widgetstate>
			<widgetstate statename="disabled">
				<image texture="/ui/fe2/elements/store2/button_lock.png" width="{imgwidth=256i}" height="{imgheight=64i}" align="center" valign="center"/>
				<label name="{btname}_disabled" content="{label}" font="{font=dyn_16}" color="#a99489" outline="1" outlinecolor="#67473b" align="center" valign="center" textalign="center" textvalign="center" uppercase="true" />
			</widgetstate>
		</button>
	</template>

	<template name="store2_store_common_elements_button">
		<button  x="{x=0}" y="{y=0}" width="128i" height="32i" align="{align=left}" valign="{valign=center}" visible="{visible=1}"
			name="store2_store_common_elements_button_{id}"
			color="invisible"
			onclick="{onclick}"
			onclicklua="PlaySound('/ui/fe2/store/sounds/woodbutton_click.wav') {onclicklua}"
			watch="{watch}"
			ontrigger="{ontrigger}"
			ontriggerlua="{ontriggerlua}"
			onmouseoverlua="
				local title = '{tipTitle}'
				local body  = '{tipBody}'
				if title ~= '' then
					HoN_Store:ShowToolTip(title, body, true)
				end
				PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
				{onmouseoverlua=}
			"
			onmouseoutlua="
				HoN_Store:HideToolTip()
				{onmouseoutlua=}
			"
			>
			<widgetstate statename="up">
				<image width="128i" height="32i" valign="center" texture="/ui/fe2/elements/store2/{texture}.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label content="{label}" font="{font=dyn_10}" color="{color=#d7b6a2}" shadow="0" shadowcolor="{shadowcolor=#180000}" outline="1" outlinecolor="{outlinecolor=#280b0b}" align="center" valign="center" textalign="center" textvalign="center" uppercase="1" />
			</widgetstate>
			<widgetstate statename="over">
				<image width="128i" height="32i" valign="center" texture="/ui/fe2/elements/store2/{texture}_over.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label content="{label}" font="{font=dyn_10}" color="{color=#d7b6a2}" shadow="0" shadowcolor="{shadowcolor=#180000}" outline="1" outlinecolor="{outlinecolor=#280b0b}" align="center" valign="center" textalign="center" textvalign="center" uppercase="1" />
			</widgetstate>
			<widgetstate statename="down">
				<image width="128i" height="32i" valign="center" texture="/ui/fe2/elements/store2/{texture}_over.png" color="{bgcolor=}" rendermode="{rendermode=}"/>
				<label x=".1h" y=".2h" content="{label}" font="{font=dyn_10}" color="{color=#d7b6a2}" shadow="0" shadowcolor="{shadowcolor=#180000}" outline="1" outlinecolor="{outlinecolor=#280b0b}" align="center" valign="center" textalign="center" textvalign="center" uppercase="1" />
			</widgetstate>
			<widgetstate statename="disabled">
				<image width="128i" height="32i" valign="center" texture="/ui/fe2/elements/store2/{texture}.png" color="{bgcolor=}" rendermode="{disabledrendermode=grayscale}"/>
				<label content="{label}" font="{font=dyn_10}" color="{disabledcolor=#c2c2c2}" shadow="0" shadowcolor="{disabledshadowcolor=#6a6a6a}" outline="1" outlinecolor="{disabledoutlinecolor=#353535}" align="center" valign="center" textalign="center" textvalign="center" uppercase="1" />
			</widgetstate>
		</button>
	</template>

	<floater name="store2_tooltip_floater" width="234i" grow="true" x="22" y="-22"
		passivechildren="true" noclick="1" visible="0" >
		<instance name="store2_frame" />
		<panel y="5i" width="-1.6h" align="center" grow="true" float="bottom" noclick="true" >
			<label name="store2_tooltip_floater_title" font="dyn_12" textvalign="center" noclick="1"
				color="#f1dbcb" shadow="1" wrap="1" fity="true" fitypadding="8i" />
			<image texture="/ui/fe2/elements/store2/line2.png" height="2i" align="center" />
			<label name="store2_tooltip_floater_desc" font="dyn_10" textvalign="center" noclick="1"
				color="#a4806f" shadow="1" wrap="1" fity="true" fitypadding="5i" />
			<panel height="5i" color="invisible" noclick="true"/>
		</panel>
	</floater>

	<floater name="store2_tooltip2_floater" width="234i" grow="true" x="22" y="-22"
		passivechildren="true" noclick="1" visible="0" >
		<instance name="store2_frame" />
		<panel y="5i" width="-1.6h" align="center" grow="false" float="bottom" noclick="true" >
			<label name="store2_tooltip2_floater_title" font="dyn_12" textvalign="center" noclick="1"
				color="#f1dbcb" shadow="1" wrap="1" fity="true" fitypadding="8i" />
			<image texture="/ui/fe2/elements/store2/line2.png" height="2i" align="center" />
			<label name="store2_tooltip2_floater_desc" font="dyn_10" textvalign="center" noclick="1"
				color="#a4806f" shadow="1" wrap="1" fity="true" fitypadding="5i"  sticky="true" stickytoinvis="false"/>

			<image name="store2_tooltip2_floater_desc2_line" texture="/ui/fe2/elements/store2/line2.png" height="2i" align="center" />
			<label name="store2_tooltip2_floater_desc2" font="dyn_10" textvalign="center" noclick="1"
					color="#a4806f" shadow="1" wrap="1" fity="true" fitypadding="5i" visible="0" sticky="true" stickytoinvis="false"/>

			<image name="store2_tooltip2_floater_desc3_line" texture="/ui/fe2/elements/store2/line2.png" height="2i" align="center" />
			<label name="store2_tooltip2_floater_desc3" font="dyn_10" textvalign="center" noclick="1"
					color="#a4806f" shadow="1" wrap="1" fity="true" fitypadding="5i" visible="0" sticky="true" stickytoinvis="false"/>
			<panel height="5i" color="invisible" noclick="true" sticky="true" stickytoinvis="false"/>
		</panel>
	</floater>

	<!-- Store2 CAI Slot FAQ Tooltip -->
	<floater
			name="store2_custom_slot_faq_tip"
			grow="true" x="22" y="-22" width="40.0h"
			visible="false"
	>
		<instance name="store2_frame" />

		<panel y="0.8h" width="-1.6h" height="3.6h" align="center" float="right" padding="0.5h">
			<!-- Icon -->
			<panel width="100@" height="100%">
				<image onshow="SetTexture('/ui/fe2/store/icons/custom_icon.tga');" resourcecontext="store" />
				<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1"/>
			</panel>
			<!-- Name / Lvl -->
			<panel width="-120@" height="100%" float="bottom" padding="0">
				<label fity="true" font="dyn_12" color="orange" shadow="true" content="mstore_custom_faq_title" />
				<label fity="true" font="dyn_10" color="#d3bbac" shadow="true" content="mstore_custom_faq_title2" />
			</panel>
		</panel>
		<panel grow="true" y="5.2h" width="-1.6h" align="center" float="bottom">
			<label fity="true" fitypadding="0.3h" font="dyn_10" color="#f1dbcb" shadow="true" textalign="left" content="mstore_custom_faq_Q1" />
			<label fity="true" fitypadding="1.0h" font="dyn_10" color="#a4806f" shadow="true" wrap="true" content="mstore_custom_faq_A1" />
			<label fity="true" fitypadding="0.3h" font="dyn_10" color="#f1dbcb" shadow="true" textalign="left" content="mstore_custom_faq_Q2" />
			<label fity="true" fitypadding="1.0h" font="dyn_10" color="#a4806f" shadow="true" wrap="true" content="mstore_custom_faq_A2" />
			<label fity="true" fitypadding="0.3h" font="dyn_10" color="#f1dbcb" shadow="true" textalign="left" content="mstore_custom_faq_Q3" />
			<label fity="true" fitypadding="1.0h" font="dyn_10" color="#a4806f" shadow="true" wrap="true" content="mstore_custom_faq_A3" />
		</panel>
	</floater>

	<!-- Store2 Empty CAI Slot Tooltip -->
	<floater
			name="store2_empty_custom_slot_tip"
			grow="true" x="22" y="-22" width="34.0h"
			visible="false"
	>
		<instance name="store2_frame" />

		<panel y="0.8h" width="-1.6h" height="3.6h" align="center" float="right" padding="0.5h">
			<!-- Icon -->
			<panel width="100@" height="100%">
				<image onshow="SetTexture('/ui/fe2/store/icons/custom_icon.tga');" resourcecontext="store" />
				<frame color="invisible" borderthickness="1" bordercolor=".3 .3 .3 1"/>
			</panel>
			<!-- Name / Lvl -->
			<panel width="-120@" height="100%" float="bottom" padding="0">
				<label fity="true" font="dyn_12" color="orange" shadow="true" content="mstore_custom_openslot" />
				<label fity="true" font="dyn_10" color="#d3bbac" shadow="true" content="mstore_custom_openslot2" />
			</panel>
		</panel>

		<panel grow="true" y="5.2h" width="-1.6h" align="center" float="bottom">
			<label fity="true" fitypadding="0.5h" font="dyn_10" color="#f1dbcb" shadow="true" wrap="true" content="mstore_custom_openslot_inst" />
			<label fity="true" fitypadding="0.8h" font="dyn_10" color="#a4806f" shadow="true" textalign="left" content="mstore_custom_openslot_url" />
		</panel>
	</floater>

	<!-- paging template -->
	<template name="store2_paging_arrow">
		<panel width="{width=32i}" height="{height=32i}" align="{align=left}" valign="{valign=center}" noclick="1" >
			<button
				name="store2_paging_arrow_{cat}_{id}"
				blockinput="{blockinput=false}"
				noclick="{noclick=false}"
				color="invisible"
				visible="{visible=true}"
				onclicklua="HoN_Store:OnClickPagingButton(self, '{cat}')"
			>
				<widgetstate statename="up">
					<image texture="/ui/fe2/elements/store2/arrow.png" hflip="{hflip=false}"/>
				</widgetstate>
				<widgetstate statename="down">
					<image texture="/ui/fe2/elements/store2/arrow.png" hflip="{hflip=false}"/>
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/fe2/elements/store2/arrow_over.png" hflip="{hflip=false}"/>
				</widgetstate>
				<widgetstate statename="disabled">
					<image texture="/ui/fe2/elements/store2/arrow.png" hflip="{hflip=false}"/>
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="store2_paging_index_botton_state">
		<widgetstate statename="{statename}">
			<label name="store2_page_index_{cat}_{id}_{statename}"
				content="" font="{font=dyn_12}" color="{color}" outline="true" outlinecolor="#000000" align="center" valign="center" textalign="center" textvalign="center"/>
		</widgetstate>
	</template>

	<template name="store2_paging_index">
		<button
			name="store2_page_index_{cat}_{id}"
			width="{width=2h}"
			height="{height=3h}"
			align="{align=left}"
			valign="{valign=center}"
			blockinput="{blockinput=false}"
			noclick="{noclick=false}"
			color="invisible"
			onclick="{onclick}"
			onclicklua="{onclicklua}"
		>
			<instance name='store2_paging_index_botton_state' cat="{cat}" id="{id}" statename="up" color="#8e6b5b" />
			<instance name='store2_paging_index_botton_state' cat="{cat}" id="{id}" statename="over" color="#d3bbac" />
			<instance name='store2_paging_index_botton_state' cat="{cat}" id="{id}" statename="down" color="#8e6b5b" />
			<instance name='store2_paging_index_botton_state' cat="{cat}" id="{id}" statename="disabled" color="#8e6b5b" />
		</button>
	</template>

	<template name="store2_paging">
		<panel name="store2_paging_{cat}" y="{y=83.3h}" width="{width=0}" grow="true" height="{height=3h}" align="{align=center}" valign="{valign=top}" float="right">
		</panel>
	</template>

	<template name="store2_paging_dot_yellow" >
		<image texture="/ui/fe2/elements/store2/dot_yellow.png" width="32i" height="32i" noclick="1"/>
	</template>

	<template name="store2_paging_dot_black" >
		<image texture="/ui/fe2/elements/store2/dot_black.png" width="32i" height="32i" onclicklua="HoN_Store:OnClickPagingDotButton('{cat}', {page})"
			onmouseoverlua="self:SetTexture('/ui/fe2/elements/store2/dot_black_over.png')"
			onmouseoutlua="self:SetTexture('/ui/fe2/elements/store2/dot_black.png')"/>
	</template>

	<template name="store2_paging2">
		<panel name="store2_paging_{cat}" x="{x=0}" y="{y=0}" height="{height=100%}" align="{align=center}" valign="{valign=top}" noclick="1" width="1" float="right" grow="1" >
			<instance name="store2_paging_arrow" cat="{cat}" id="prev" />
			<panel name="store2_paging_dot_panel{cat}" y="{doty=0}" width="1" height="32i" grow="1" float="right" noclick="1" x="32i" />
			<instance name="store2_paging_arrow" cat="{cat}" id="next" hflip="true" />
		</panel>
	</template>

	<!-- New Hero - EA -->
	<template name="store2_hero_portrait_ability">
		<panel width="{width=100@}" height="{height=100%}"
			onmouseoverlua="HoN_Store:ShowHeroAbilityHoverPanel(true, {id})"
			onmouseoutlua="HoN_Store:ShowHeroAbilityHoverPanel(false, {id})"
			>
			<image name="{prefix}_ability_icon_{id}" align="center" valign="center" width="95%" height="95%" noclick="1" />
			<image texture="/ui/fe2/elements/store2/skill_border.png" align="center" valign="center" width="128i" height="128i" noclick="1" />
		</panel>
	</template>

	<template name="store2_hero_portrait_voice">
		<panel name="{prefix}_voice" x="{x=0}" y="{y=0}" width="64i" height="64i" align="{align=left}" valign="{valign=top}"
			onmouseoverlua="self:GetWidget('{prefix}_voice_over'):SetVisible(true)"
			onmouseoutlua="self:GetWidget('{prefix}_voice_over'):SetVisible(false)"
			onclicklua="HoN_Store:OnClickHeroVoiceButton()"
			>
			<image name="{prefix}_voice_out" texture="/ui/fe2/elements/store2/voice.png" noclick="1" />
			<image name="{prefix}_voice_over" texture="/ui/fe2/elements/store2/voice_over.png" noclick="1" visible="0"/>
		</panel>
	</template>

	<template name="store2_hero_portrait_info">
		<panel name="{prefix}_info" align="left" valign="top" x="{x=17i}" y="{y=26i}" width="{width=100%}" height="{height=250i}" noclick="1" color="invisible" visible="{visible=true}">
			<panel width="1" height="1" grow="1" noclick="1"
				onshowlua="self:Sleep(1000, function() self:SetNoClick(false) end)"
				onhidelua="self:SetNoClick(true)"
				onmouseoverlua="HoN_Store:ShowHeroPropertyHoverPanel(true)"
				onmouseoutlua="HoN_Store:ShowHeroPropertyHoverPanel(false)"
				>
				<panel width="150i" height="150i" noclick="1" >
					<image name="{prefix}_portrait" noclick="1" width="102i" height="102i" align="center" valign="center" usealphamask="true" alphamaskfile="/ui/fe2/elements/store2/mask.png" />
					<image texture="/ui/fe2/elements/store2/head_border.png" width="256i" height="256i" align="center" valign="center" noclick="1" />
					<image width="32i" height="32i" align="left" x="18i" valign="bottom" y="-15i" texture="/ui/fe2/elements/store2/head_border2.png" noclick="1" />
					<image name="{prefix}_primAttr" width="32i" height="32i" align="left" x="18i" valign="bottom" y="-15i" texture="/ui/fe2/elements/store2/primary_none.png" noclick="1" />
				</panel>
				<panel width="1" height="135i" x="160i" y="25i" noclick="1" grow="1" >
					<label name="{prefix}_name" height="40i" font="dyn_16" content="" color="#f0d3c1" outline="true" outlinecolor="#280b0b" noclick="1" fitx="1"/>
					<panel y="53i" height="20i" float="right" padding="2i" noclick="1" grow="1" >
						<label font="dyn_12" content="mstore_difficulty" color="#d3bbac" outline="true" fitx="true" outlinecolor="#280b0b" noclick="1"  />
						<panel width="10i" noclick="1" />
						<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_1" width="100@" height="100%"/>
						<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_2" width="100@" height="100%"/>
						<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_3" width="100@" height="100%"/>
						<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_4" width="100@" height="100%"/>
						<instance name="store2_difficulty_diamond" id="{prefix}_difficulty_diamond_5" width="100@" height="100%"/>
					</panel>
					<panel y="83i" height="20i" noclick="1" grow="1" >
						<image name="{prefix}_attack" texture="/ui/fe2/elements/store2/melee.png" x="-8i" width="32i" height="32i" valign="center" noclick="1" />
						<label name="{prefix}_category" fitx="true" x="28i" y="10i" font="dyn_11" content="" color="#d3bbac" outline="true" outlinecolor="#280b0b" noclick="1" />
					</panel>
				</panel>
			</panel>
			<panel name="{prefix}_abilities" x="{abilityX=30i}" y="{alibiltyY=155i}" align="{abilityAlign=left}" width="0" grow="true" height="70i" float="right" padding="16i" noclick="1" >
				<instance name="store2_hero_portrait_ability" prefix="{prefix}" id="1" />
				<instance name="store2_hero_portrait_ability" prefix="{prefix}" id="2" />
				<instance name="store2_hero_portrait_ability" prefix="{prefix}" id="3" />
				<instance name="store2_hero_portrait_ability" prefix="{prefix}" id="4" />
			</panel>
		</panel>
	</template>

	<template name="store2_hero_portrait_ability2">
		<panel width="{width=100@}" height="{height=100%}"
			onmouseoverlua="HoN_Store:ShowHeroAbilityHoverPanel(true, {id})"
			onmouseoutlua="HoN_Store:ShowHeroAbilityHoverPanel(false, {id})"
			>
			<image name="{prefix}_ability_icon_{id}" align="center" valign="center" width="95%" height="95%" noclick="1" />
			<image texture="/ui/fe2/elements/store2/skill_border.png" align="center" valign="center" width="200@" height="200%" noclick="1" />
		</panel>
	</template>

	<template name="store2_hero_portrait_info2">
		<panel name="{prefix}_info" align="left" valign="top" x="{x=0}" y="{y=0}" width="1" height="{height=100%}" grow="1" noclick="1" visible="{visible=true}" >
			<panel noclick="1" clip="1" >
				<image texture="/ui/fe2/elements/store2/bg_m.png" width="143%" x="0" height="128i" align="center" valign="center" noclick="0" />
			</panel>
			<panel x="20i" width="100@" height="100%" noclick="1" align="left" valign="center">
				<image name="{prefix}_portrait" noclick="1" width="64i" height="64i" align="center" valign="center" usealphamask="true" alphamaskfile="/ui/fe2/elements/store2/mask.png" />
				<image texture="/ui/fe2/elements/store2/head_border.png" width="160i" height="160i" align="center" valign="center" noclick="1" />
				<image texture="/ui/fe2/elements/store2/head_border2.png" width="22i" height="22i" align="left" x="12i" valign="bottom" y="-10i" noclick="1" />
				<image name="{prefix}_primAttr" width="26i" height="26i" align="left" x="9i" valign="bottom" y="-6i" texture="/ui/fe2/elements/store2/primary_none.png" noclick="1" />
			</panel>
			<panel width="220i" x="130i" y="8i" height="-8i" noclick="1" >
				<label name="{prefix}_name" height="30i" font="dyn_16" content="Keep Of The Forest" color="#f0d3c1" outline="true" fitx="true" outlinecolor="#280b0b" noclick="1" />
				<panel y="35i" height="20i" float="right" padding="2i" noclick="1" >
					<label font="dyn_10" content="mstore_difficulty" color="#d3bbac" outline="true" outlinecolor="#280b0b" fitx="true" noclick="1" fitxpadding="5i" />
					<panel width="5i" noclick="1" />
					<instance name="store2_difficulty_diamond2" id="{prefix}_difficulty_diamond_1" width="80@" height="80%"/>
					<instance name="store2_difficulty_diamond2" id="{prefix}_difficulty_diamond_2" width="80@" height="80%"/>
					<instance name="store2_difficulty_diamond2" id="{prefix}_difficulty_diamond_3" width="80@" height="80%"/>
					<instance name="store2_difficulty_diamond2" id="{prefix}_difficulty_diamond_4" width="80@" height="80%"/>
					<instance name="store2_difficulty_diamond2" id="{prefix}_difficulty_diamond_5" width="80@" height="80%"/>
				</panel>
			</panel>
			<panel x="20i" width="1" height="100%" grow="1" float="right" noclick="1" >
				<panel width="300i" height="100%" grow="1" float="right" noclick="0"
					onmouseoverlua="HoN_Store:ShowHeroPropertyHoverPanel(true)"
					onmouseoutlua="HoN_Store:ShowHeroPropertyHoverPanel(false)"
					>
					<panel x="104i" y="60i" height="20i" grow="1" noclick="1">
						<image name="{prefix}_attack" texture="/ui/fe2/elements/store2/melee.png" valign="center" width="24i" height="24i" noclick="1" />
						<label name="{prefix}_category" x="28i" fitx="true" fitxpdding="20i" font="dyn_10" color="#d3bbac" outline="true" outlinecolor="#280b0b" noclick="1" textvalign="center" valign="center" />
					</panel>
				</panel>

				<panel width="20i" noclick="1" >
					<instance name="store2_hline2" y="20i" height="42i" />
				</panel>

				<panel width="1" grow="true" noclick="1" >
					<panel name="{prefix}_abilities" y="48i" width="1" grow="true" height="38i" float="right" padding="10i" noclick="1" >
						<instance name="store2_hero_portrait_ability2" prefix="{prefix}" id="1" />
						<instance name="store2_hero_portrait_ability2" prefix="{prefix}" id="2" />
						<instance name="store2_hero_portrait_ability2" prefix="{prefix}" id="3" />
						<instance name="store2_hero_portrait_ability2" prefix="{prefix}" id="4" />
					</panel>
				</panel>

				<panel width="20i" noclick="1" >
					<instance name="store2_hline2" y="20i" height="42i" />
				</panel>

				<panel name="{prefix}_voice_panel" width="1" height="100%" grow="0" float="right" visible="{showVoice=true}" noclick="1" 
					onshowlua="self:SetGrow(true) self:GetParent():RecalculateSize()"
					>
					<panel width="50i" noclick="1" >
						<instance name="store2_hero_portrait_voice" align="center" prefix="{prefix}" y="36i" />
					</panel>
				</panel>

				<panel name="{prefix}_heroes" width="1" height="100%" grow="0" float="right" visible="{showHeros=true}" noclick="1"
					onshowlua="self:SetGrow(true) self:GetParent():RecalculateSize()"
					>
					<panel width="20i" noclick="1" >
						<instance name="store2_hline2" y="20i" height="42i" />
					</panel>

					<panel width="14h" height="3.5h" noclick="1" >
						<instance name="store2Button" buttonName="{prefix}showAllHeroes" texture="button4" y="48i" width="14h"
						 	color="#ecf9fa" outlinecolor="#076878" label="store2_show_all_heroes"
						 	onclicklua="HoN_Store:SwitchToHeroListPage()" />
					</panel>
				</panel>

				<panel width="6h" noclick="1" />
			</panel>
		</panel>
	</template>

	<template name="store2_hero_ea_model_panel">
		<modelpanel
			name="store2_hero_ea_model_panel_{id}"
			scenebuffer="true"
			noclick="0"
			anim="idle_eap"
			cameranear="0.0"
			camerafar="10000.0"
			depthclear="true"
			depthcompress="false"
			lookat="false"
			cameradistance="30"
			camerapos="-28 3160 1938"
			cameraangles="-12 0 180"
			camerafov="7"
			modelpos="0 0 0"
			modelangles="0 0 0"
			modelscale="1.0"
			sunazimuth="120"
			sunaltitude="50"
			suncolor="0.9 0.9 0.9"
			ambientcolor="0.6 0.7 0.7"
			luatable="1"
			cull="false"
			resourcecontext="model"
			posteffects="true"
			posteffect=""
			outline="false"
			postoutline="/core/post/outline.posteffect"
			outlinecolor=".25 .25 .25 1"
			processcursor="{processcursor=false}"
			align="center"
			valign="top"
			onshowlua="self:SetWidth('100%')"
			onmouseoverlua="{onmouseovermodellua=}"
			onmouseoutlua="{onmouseoutmodellua=}"
			watch="Store2ShopClosing"
			ontriggerlua="HoN_Store:Store2ModelPanelHideContent(self)"
		/>
	</template>

	<template name="store2_hero_ea_bundle">
		<panel name="store2_hero_ea_bundle_{id}"
			width="{width=128i}" height="{height=128i}" align="{align=center}" x="{x=0}" valign="{valign=center}" y="{y=0}"
			onclicklua="{onclicklua=}"
			onmouseoverlua="
				local image = self:GetWidget('store2_hero_ea_bundle_{id}_image')
				local tex = image:GetTexture()
				if tex ~= '/ui/fe2/elements/store2/bundle2.png' then
					image:SetTexture('/ui/fe2/elements/store2/bundle3.png')
				end
				PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')
				{onmouseoverlua=}"
			onmouseoutlua="
				local image = self:GetWidget('store2_hero_ea_bundle_{id}_image')
				local tex = image:GetTexture()
				if tex ~= '/ui/fe2/elements/store2/bundle2.png' then
					image:SetTexture('/ui/fe2/elements/store2/bundle1.png')
				end
				{onmouseoutlua=}"
			>
			<image name="store2_hero_ea_bundle_{id}_image" texture="/ui/fe2/elements/store2/bundle1.png" width="128i" height="128i" align="center" valign="center" noclick="1"/>
			<panel valign="bottom" height="32i" y="-10i" noclick="0" >
				<image texture="/ui/fe2/elements/store2/bg_s.png" width="256i" height="32i" align="center" valign="center" noclick="1" />
				<label name="store2_hero_ea_bundle_{id}_label" content="{text=}" font="dyn_10" color="#a4806f" fitx="true" align="center" textalign="center" textvalign="center" noclick="1" />
			</panel>
		</panel>
	</template>

	<template name="store2_ea_special_booth">
		<panel name="store2_specials_booth_{id}" x="{x}" y="{y}" width="400i" height="620i" align="{align}" valign="{valign}" visible="{visible=true}" noclick="{noclick=1}"
			onloadlua="HoN_Store:SetWidgetScale(self, {scale})"
			>
			<image name="st2_sp_booth_jz_{id}" texture="/ui/fe2/elements/store2/jz.png" align="center" valign="center" y="18%" width="512i" height="256i" noclick="1"
				onloadlua="HoN_Store:SetWidgetScale(self, {scale})" />

			<panel x="0" y="{modelpanely=0}" width="160w" height="100h" align="center" valign="center" noclick="1"
				onloadlua="HoN_Store:SetWidgetScale(self, {scale})">
				<instance name="store2_hero_ea_model_panel" id="{id}" camerapos="{camerapos}"
					onmouseovermodellua="{onmouseovermodellua}"
					onmouseoutmodellua="{onmouseoutmodellua}"/>
			</panel>

			<!-- name -->
			<image name="st2_sp_booth_name_bck_{id}" texture="/ui/fe2/elements/store2/name_bck.png" align="center" valign="center" y="15.72%" width="512i" height="64i" noclick="1"
				onloadlua="HoN_Store:SetWidgetScale(self, {scale})" />
			<label name="st2_sp_booth_name_label_{id}" align="center" valign="center" textalign="center" textvalign="center" y="15.72%" font="dyn_18" color="#d7b6a2" outline="true" outlinecolor="#280b0b" height="64i" width="52%" noclick="1"
				onloadlua="HoN_Store:SetLabelText(self, 'heroname', '{id}', 'Hero Name')"  />

			<!-- owned -->
			<image name="st2_sp_booth_name_own_{id}" texture="/ui/fe2/elements/store2/owned.png" align="center" x="-30%" valign="center" y="15.72%" width="64i" height="64i" noclick="0" visible="0"
				onloadlua="HoN_Store:SetWidgetScale(self, {scale})" />

			<!-- info -->
			<image name="st2_sp_booth_info_back_{id}" texture="/ui/fe2/elements/store2/info_back.png" align="center" valign="center" y="{infoy=21.46%}" width="512i" height="32i" noclick="1"
				onloadlua="HoN_Store:SetWidgetScale(self, {scale})" />
			<label name="st2_sp_booth_info_label_{id}" align="center" valign="center" textalign="center" textvalign="center" y="{infoy=21.46%}" color="#d7b6a2" outline="true" outlinecolor="#280b0b" height="32i"
				onloadlua="HoN_Store:SetLabelText(self, 'info', '{id}', 'Sale Ends: Sep 17th!')" />

			<panel width="1" name="store2_specials_booth_price_parent_{id}" grow="true" height="32i" align="center" valign="center" y="{priceY=49%}" onloadlua="HoN_Store:SetWidgetScale(self, {scale})" float="right">
			</panel>
		</panel>
	</template>

	<template name="store2_hero_ea_booth">

		<panel x="{x=0}" y="{y=0}" width="400i" height="620i" align="center" valign="center" >
			<instance name="store2_ea_special_booth" id="{id}" x="0" y="0" align="center" valign="top"
				scale="{scale=1}" infoy="{infoy=22%}" visible="0" noclick="0" modelpanely="{modelpanely=0}" camerapos="{camerapos}" />

			<!-- release date-->
			<panel name="store2_hero_ea_booth_time_{id}" align="center" valign="top" y="{info2Y=0}" width="400i" height="32i" noclick="1" visible="{info2visible=0}" onloadlua="HoN_Store:SetWidgetScale(self, {scale})" >
				<image name="store2_hero_ea_booth_time_image_{id}" texture="/ui/fe2/elements/store2/info_back.png" align="center" valign="center" width="512i" height="32i" y="6i" noclick="1"
					onloadlua="HoN_Store:SetWidgetScale(self, {scale})" />
				<panel align="center" height="32i" float="right" padding="5i" width="65%" noclick="1">
					<image texture="/ui/fe2/elements/store2/clock.png" align="left" valign="center" height="16i" width="16i" y="6i" onloadlua="HoN_Store:SetWidgetScale(self, {scale})" noclick="1"/>
					<label name="store2_hero_ea_booth_timepre_label_{id}" content="" align="left" valign="center" textalign="left" textvalign="center" color="#a78672" outline="true" outlinecolor="#280b0b" fitx="true" onloadlua="HoN_Store:SetLabelText(self, 'info', '{id}', 'store2_sale_ends')" noclick="1"/>
					<label name="store2_hero_ea_booth_time_label_{id}" align="left" valign="center" textalign="left" textvalign="center" color="#d7b6a2" outline="true" outlinecolor="#280b0b" fitx="true" noclick="1"/>
				</panel>
			</panel>

			<!-- Left Alt Star (EA Exclusive Alt Av) -->
			<panel align="center" width="100%" height="14h" valign="center" x="0" y="22%" noclick="true">
				<panel name="ms_eap_left_star_1_{id}" width="14h" align="center" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/store2/star1.png" width="256i" height="256i" align="center" valign="center" noclick="1" />
					<panel noclick="1">
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="25%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#024a5e" shadow="true" shadowcolor="#68e0e6"
							content="mstore_noeap_includes" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="16" align="center" width="70%" y="35%" noclick="1"
							textalign="center" textvalign="center" font="dyn_16" color="#fdffff" shadow="true" shadowcolor="#076878" outline="true" outlinecolor="#076878"
							content="mstore_noeap_bonus" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="9" align="center" width="55%" y="53%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#024a5e" shadow="true" shadowcolor="#68e0e6"
							content="mstore_noeap_alt_avatar" onshowlua="self:SetText(string.upper(self:GetText()))"/>
					</panel>
				</panel>
				<panel name="ms_eap_left_star_2_{id}" width="14h" align="center" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/store2/star1.png" width="256i" height="256i" align="center" valign="center" rendermode="grayscale" noclick="1" />
					<panel noclick="1">
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="25%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#1e1e1e" shadow="true" shadowcolor="#9f9f9f"
							content="mstore_noeap_select" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="16" align="center" width="60%" y="38%" noclick="1"
							textalign="center" textvalign="center" font="dyn_16" color="#ffffff" shadow="true" shadowcolor="#000000" outline="true" outlinecolor="#525252"
							content="mstore_eap_bundle_2" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="53%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#1e1e1e" shadow="true" shadowcolor="#9f9f9f"
							content="mstore_noeap_to_unlock" onshowlua="self:SetText(string.upper(self:GetText()))"/>
					</panel>
				</panel>
			</panel>

			<!-- Right Alt Star (Regular Alt Av) -->
			<panel align="center" width="100%" height="14h" valign="center" x="0" y="22%" noclick="true">
				<panel name="ms_eap_right_star_1_{id}" width="14h" align="center" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/store2/star2.png" width="256i" height="256i" align="center" valign="center" />
					<panel noclick="1">
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="25%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#640017" shadow="true" shadowcolor="#ed5d79"
							content="mstore_noeap_includes" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="16" align="center" width="70%" y="35%" noclick="1"
							textalign="center" textvalign="center" font="dyn_16" color="#fdffff" shadow="true" shadowcolor="#7f071d" outline="true" outlinecolor="#7f071d"
							content="mstore_noeap_exclusive" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="53%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#640017" shadow="true" shadowcolor="#ed5d79"
							content="mstore_eap_only" onshowlua="self:SetText(string.upper(self:GetText()))"/>
					</panel>
				</panel>
				<panel name="ms_eap_right_star_2_{id}" width="14h" align="center" noclick="true" visible="0">
					<image texture="/ui/fe2/elements/store2/star2.png" width="256i" height="256i" align="center" valign="center" rendermode="grayscale" />
					<panel noclick="1">
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="25%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#1e1e1e" shadow="true" shadowcolor="#9f9f9f"
							content="mstore_noeap_select" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="16" align="center" width="60%" y="38%" noclick="1"
							textalign="center" textvalign="center" font="dyn_16" color="#ffffff" shadow="true" shadowcolor="#000000" outline="true" outlinecolor="#525252"
							content="mstore_eap_bundle_3" onshowlua="self:SetText(string.upper(self:GetText()))"/>
						<label fity="true" autofont="1" autofontmax="9" align="center" width="50%" y="53%" noclick="1"
							textalign="center" textvalign="center" font="dyn_9" color="#1e1e1e" shadow="true" shadowcolor="#9f9f9f"
							content="mstore_noeap_to_unlock" onshowlua="self:SetText(string.upper(self:GetText()))"/>
					</panel>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="store2_hero_ea">
		<panel noclick="1" name="store2_hero_ea"
			onshowlua="
				local wrapper = GetWidget('store2_ea_wrapper')
				GetWidget('store2_hero_ea_content'):SetParent(wrapper)
				GetWidget('store2_hero_ea_content'):SetVisible(true)
			"
			onhidelua="
				GetWidget('store2_hero_ea_content'):SetVisible(false)
			" >
			<panel name="store2_hero_ea_content" width="{width=1380i}" height="{height=820i}" x="{x=0}" y="{y=120i}" align="center" visible="{visible=1}" noclick="1"
				onshowlua="HoN_Store:Store2SetCurrentPage('store2_hero_ea')"
				onhidelua="HoN_Store:OnHideEapPage()"
				>
				<instance name="store2_hero_ea_booth" id="ea2" x="410i" y="60i" scale="0.8" info2visible="0" info2Y="0%" modelpanely="-5%" />
				<instance name="store2_hero_ea_booth" id="ea3" x="-410i" y="60i" scale="0.8" info2visible="0" info2Y="0%" modelpanely="-5%" />
				<instance name="store2_hero_ea_booth" id="ea1" x="0" y="8i" scale="1" info2visible="1" info2Y="70%" modelpanely="-5%" />

				<panel align="center" valign="center" height="680i" y="-120" color="invisible"
						onmouseldownlua="self:DoEventN(1)"
						onmouseluplua="self:DoEventN(2)"
						onhidelua="self:DoEventN(2)"
						onevent1lua="
							self:SetWatch('Frametime')
							HoN_Store:StartEapRotation()
						"
						onevent2lua="
							self:SetWatch('')
							HoN_Store:StopEapRotation(self)
						"
						ontriggerlua="
							HoN_Store:UpdateEapModelRotation(self, 'ea', 3)
						"
						>
				</panel>

				<panel name="store2_hero_ea_header" width="55%" height="96i" y="0" visible="1" noclick="1">
					<instance name="store2_hero_portrait_info2" height="96i" prefix="store2_hero_ea_header" visible="false"/>
				</panel>

				<panel name="store2_hero_ea_bundles" valign="bottom" height="128i" y="-75i" >
					<instance name="store2_hero_ea_bundle" id="3" text="store2_ea_immortal" x="-200i"
						onclicklua="HoN_Store:SelectEapBundle(3)"
						 />
					<instance name="store2_hero_ea_bundle" id="2" text="store2_ea_legendary" x="0"
						onclicklua="HoN_Store:SelectEapBundle(2)"
						 />
					<instance name="store2_hero_ea_bundle" id="1" text="store2_ea_heroonly" x="200i"
						onclicklua="HoN_Store:SelectEapBundle(1)"
						 />
				</panel>

				<panel width="208i" height="44i" x="0" y="-28i" noclick="1" align="center" valign="bottom">
					<instance name="store2_specials_booth_buy_button" id="ea" scale="1" showdiscount="0" align="center" mouseoversound="/shared/sounds/ui/ccpanel/button_over_02.wav"
						onclicklua="HoN_Store:OnPurchaseEapBundle()" />
					<instance name="store2_specials_booth_owned_button" id="ea" visible="0" />
				</panel>

				<panel name="store2_hero_ea_gold_panel" x="0" y="2i" align="center" valign="bottom" noclick="1" height="32i" width="100i" >
					<image noclick="1" texture="/ui/fe2/elements/store2/gold_card.png" x="-26i" width="32i" height="32i" align="center" valign="center" />
					<label name="store2_hero_ea_gold" noclick="1" x="12i" width="50i" align="center" valign="center" textalign="left" textvalign="center" color="#ff9c00" outline="true" outlinecolor="#241410" font="dyn_12" content="" />
				</panel>
			</panel>
		</panel>
	</template>

