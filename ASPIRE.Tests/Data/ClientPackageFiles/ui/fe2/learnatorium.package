							<!-- Detailed Hero List -->
							<panel name="learner_detailedList" y="-1.0h" width="-1.0h" height="-6.4h" align="center" valign="bottom" noclick="true" visible="0">
								<instance name="herodex_herolist_template" allheroes="1" />
							</panel>
							<!-- Mastery Hero List -->
							<panel name="learner_masteryList" y="-1.0h" width="-1.0h" height="-6.4h" align="center" valign="bottom" noclick="true" visible="0">
								<instance name="herodex_masterylist_template" allheroes="1" />
							</panel>
							<!-- Hero Usage List -->
							<panel name="learner_usageList" y="-1.0h" width="-1.0h" height="-5.0h" align="center" valign="bottom" noclick="true" visible="0">
								<instance name="compendium_usage_list_template" />
							</panel>
							<!-- Video Center! -->
							<panel name="learner_videoCenter" y="-1.0h" width="-1.0h" height="-5.0h" align="center" valign="bottom" noclick="true" visible="0"
								onhidelua="UIManager.GetInterface('webpanel'):HoNWebPanelF('UnloadPage')"
							>
								<label x="0.5h" y="-3.4h" font="dyn_18" fitx="1" fity="1" color="#ffaa00" outline="true" content="learn_video_center_title" />

								<panel name="learner_videocenter_browser" color="black"
									onshow="DoEvent();"
									oneventlua="UIManager.GetInterface('main'):HoNLearnerF('RefreshLearningCenter')"
								/>
							</panel>
							<!-- Items -->
							<panel name="learner_items" y="-1.0h" width="-1.0h" height="-5.0h" align="center" valign="bottom" noclick="true" visible="0">
								<instance name="compendium_items_template" />
							</panel>
							<!-- Walkthrough -->
							<panel name="learner_walkthrough" y="-1.0h" width="-1.0h" height="-5.0h" align="center" valign="bottom" noclick="true" visible="0">
								<label x="0.5h" y="-3.4h" font="dyn_18" fitx="1" fity="1" color="#ffaa00" outline="true" content="learn_walkthrough_title" />
								<instance name="button2" button_name="unnamedButton153" height="2.4h" width="14.0h" align="center" valign="bottom" label="prompt_tutorial_play" font="dyn_10"
									onclicklua="
										Main.walkthroughPrompted = GetDBEntry('walkthroughPrompted', 1, true, false, true)
										UIManager.GetInterface('main'):HoNMainF('MainMenuPanelToggle', 'main_splash_new_player', nil, nil, nil, nil, 63)
									"
								/>
							</panel>

						</panel>


					</panel>

					<!-- Tabs -->
					<panel width="14.0h" float="bottom" padding="1.0h" noclick="true">

						<!-- Heroes -->
						<instance
							name="sidetab_v3"
							y="0"
							icon="/ui/fe2/elements/learnatorium_icon_heroes.tga" iconsize="58"
							cat_label="learn_tab_hero"
							cat_sub_label="learn_tab_hero_2"
							onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickSideTab', 1)"
							id="learner_left_hero"
						/>
						
						<!-- Items -->
						<instance
							name="sidetab_v3"
							icon="/ui/fe2/elements/learnatorium_icon_notatut.tga"  iconsize="56"
							cat_label="learn_tab_items"
							cat_sub_label="learn_tab_items_2"
							onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickSideTab', 4)"
							id="learner_left_items"
						/>
						
						<!-- Not a Tutorial -->
						<if condition="cg_newMainInterface">
							<instance
								name="sidetab_v3"
								icon="/ui/fe2/elements/learnatorium_icon_notatut.tga"  iconsize="64"
								cat_label="learn_tab_walk" labelfont="dyn_14"
								cat_sub_label="learn_tab_walk_2"
								onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickSideTab', 3)"
								id="learner_left_walkthrough"
								visible="0"
							/>
						</if>
						<if condition="!cg_newMainInterface">
							<instance
								name="sidetab_v3"
								icon="/ui/fe2/elements/learnatorium_icon_notatut.tga"  iconsize="64"
								cat_label="learn_tab_walk" labelfont="dyn_14"
								cat_sub_label="learn_tab_walk_2"
								onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickSideTab', 3)"
								id="learner_left_walkthrough"
							/>
						</if>
					</panel>
				</panel>

				<!-- Load Progress -->
				<panel width="-2.0h" align="center" name="learnatorim_loading_progress" visible="1" blockinput="true" watch="EntityDefinitionsLoaded" ontrigger="SetVisible(false);" color="0 0 0 .7">
					<panel align="center" valign="center" width="25.0h" height="5h" y=".5h">
						<image height="100%" texture="../mainmenu/update_bar_bg.tga" />

						<panel watch="EntityDefinitionsProgress" width="1" ontrigger="If(param1 gt 0, SetWidth(((param0 / param1) * 100) # '%')); SetWidth(Max(GetWidth(), 32));">
							<image watch="EntityDefinitionsProgress" ontrigger="If(param1 gt 0 and param0 gt 0, SetUScale(1 / (param0 / param1)));" texture="../mainmenu/update_bar_fg.tga"/>
							<image width="32" texture="../loadingscreens/loading_bar_fg_l.tga"/>
							<image width="32" align="right" texture="../loadingscreens/loading_bar_fg_r.tga"/>
						</panel>
					</panel>
					<image align="center" valign="center" width="31.5h" height="9h" x="-.8h" color="1 1 1 1" texture="elements/loading_bar_frame.tga" />
					<panel color="invisible" y=".5h">
						<label width="-10.0h" height="100%" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="general_wait" />
					</panel>
				</panel>
			</panel>
		</panel>

		<instance name="generic_tooltip_floater" tip_id="shop_compendium_guide_reco_1_tip" title="game_guide_reco_1" label="game_guide_reco_1_tip" align="left" valign="top" y="1.4h" x="-23.7h" />
		<instance name="generic_tooltip_floater" tip_id="shop_compendium_guide_reco_2_tip" title="game_guide_reco_2" label="game_guide_reco_2_tip" align="left" valign="top" y="1.4h" x="-23.7h" />
		<instance name="generic_tooltip_floater" tip_id="shop_compendium_guide_reco_3_tip" title="game_guide_reco_3" label="game_guide_reco_3_tip" align="left" valign="top" y="1.4h" x="-23.7h" />
		<instance name="generic_tooltip_floater" tip_id="shop_compendium_guide_reco_4_tip" title="game_guide_reco_4" label="game_guide_reco_4_tip" align="left" valign="top" y="1.4h" x="-23.7h" />

	</template>


</package>
