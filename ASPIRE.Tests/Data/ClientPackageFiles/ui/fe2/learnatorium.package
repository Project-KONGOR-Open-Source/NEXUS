<?xml version="1.0" encoding="UTF-8"?>
<package>

	<trigger name="SimpleHeroItemTooltip" />
	<trigger name="matchstats_hero_helper" />
	<trigger name="trial_avatar_info" />
	<trigger name="LearnaItemsClearList" />
	<include file="learnatorium_forms.package" />
	<include file="learnatorium_templates.package" />
	
	<trigger name="compendium_detailed_component_1_trigger" />
	<trigger name="compendium_detailed_component_2_trigger" />
	<trigger name="compendium_detailed_component_3_trigger" />
	<trigger name="compendium_detailed_component_4_trigger" />
	<trigger name="compendium_detailed_component_5_trigger" />
	<trigger name="compendium_detailed_component_6_trigger" />

	<panel name="Learnatorium_TriggerHelper" color="invisible" noclick="true"/>

	<lua file="/ui/scripts/learnatorium.lua" />

	<floater width="10h" x="-23.0h" y="2.9h" grow="true" regrow="1" name="graph_bar_tooltip" color="invisible" visible="0" align="left">
		<frame texture="/ui/frames/tooltip_bg.tga" color="0 0 0 1.0" borderthickness=".6h" />
		<frame texture="/ui/frames/roundframe.tga" color="#A0A0A0" borderthickness=".6h" />
		<panel width="-1.5h" align="center" grow="true"  regrow="1" float="bottom">
				<panel height=".5h" />
				<label y="0.5h" x="0.5h" watch="HeroUsageGraphTooltipUpdate" ontrigger="SetWidth(GetStringWidth('dyn_10', '^w'#param1#'%  ^444-^*   '#param0)+GetXFromString('1h')); SetText('^w'#FtoA(param1, 2, 2)#'%  ^444-^*   '#param0);" textvalign="top" textalign="left" font="dyn_10" noclick="1" color="#ffab01" shadow="1" wrap="0" width="100%" fity="true" fitypadding="0.8h"></label>
		</panel>
	</floater>

	<template name="sidetab_v3">
		<panel width="100%" height="{height=100@}" y="{y}"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
			onclick="{onclick}"
			onclicklua="{onclicklua}"
			mouseoverdisabled="{mouseoverdisabled}"
			disabledmouseover="{disabledmouseover}"
			mouseoutdisabled="{mouseoutdisabled}"
			disabledmouseout="{disabledmouseout}"
			onmouseoverdisabled="{onmouseoverdisabled}"
			onmouseoutdisabled="{onmouseoutdisabled}"
			visible="{visible=1}"
		>
			<button
				name="{id}"
				color="invisible"
				noclick="1"
				numstates="2"
				onshow="{onshow}"
			>
				<widgetstate statename="up">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image width="100@" height="100%" align="center" texture="{icon}" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
						<panel x="1.0h" width="1.9h" height="100%" align="right" color="#183042">
							<image x="90%" y="10%" align="right" width="106%" height="212@" texture="/ui/frames/tabbox_arrow.tga" noclick="true" />
						</panel>
					</frame>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image width="100@" height="100%" align="center" texture="{icon}" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
						<panel x="1.0h" width="1.9h" height="100%" align="right" color="#183042">
							<image x="90%" y="10%" align="right" width="106%" height="212@" texture="/ui/frames/tabbox_arrow.tga" noclick="true" />
						</panel>
					</frame>
				</widgetstate>
				<widgetstate statename="down">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image width="100@" height="100%" align="center" texture="{icon}" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
						<panel x="1.0h" width="1.9h" height="100%" align="right" color="#183042">
							<image x="90%" y="10%" align="right" width="106%" height="212@" texture="/ui/frames/tabbox_arrow.tga" noclick="true" />
						</panel>
					</frame>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" rendermode="grayscale" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image width="100@" height="100%" align="center" texture="{icon}" rendermode="grayscale" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color=".5 .5 .5 1" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color=".4 .4 .4 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
					</frame>
				</widgetstate>

				<widgetstate statename="up2">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" rendermode="grayscale" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image width="100@" height="100%" align="center" texture="{icon}" rendermode="grayscale" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color=".5 .5 .5 1" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color=".4 .4 .4 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
					</frame>
				</widgetstate>
				<widgetstate statename="over2">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image width="100@" height="100%" align="center" texture="{icon}" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
					</frame>
				</widgetstate>
				<widgetstate statename="down2">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" noclick="true">
						<panel width="-6%" height="-6@" align="center" valign="center" noclick="true">
							<panel y="3%" width="100%" height="{iconsize=60}%">
								<image x="1" y="1" width="100@" height="100%" align="center" texture="{icon}" />
							</panel>
							<panel y="-2%" grow="true" width="100%" float="bottom" valign="bottom">
								<label fity="true" font="{labelfont=dyn_18}" textalign="center" color="#ffaa00" outline="true" content="{cat_label}" noclick="true" />
								<label fity="true" font="dyn_12" textalign="center" color="1 1 1 1" shadow="true" content="{cat_sub_label}" noclick="true" />
							</panel>
						</panel>
					</frame>
				</widgetstate>
			</button>
		</panel>
	</template>

	<!-- <template name="learner_breadcrumb">
		<panel name="learner_breadcrumb_{id}" grow="1" regrow="1" growinvis="0" sticky="1" stickytoinvis="0"
			onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickBreadCrumb', {id})"
		>
			<label name="learner_breadcrumb_{id}_text" sticky="0" fity="1" fitx="true" font="dyn_12" color="#37b2d9" shadow="true" noclick="1"/>
		</panel>
	</template> -->

	<template name="top_sub_tab">
		<panel grow="true" height="100%">
			<panel name="top_sub_tab{id}" grow="true" regrow="1" growinvis="false" height="100%" float="right" color="#282828">
				<panel width="2.2h" height="100%" />
				<label fitx="true" fitxpadding="2.2h" textvalign="center" font="dyn_14" color=".7 .7 .7 1" outline="true" outlinecolor=".1 .1 .1 1" content="{label}" />
				<panel name="top_sub_tab_arrow_{id}" width="3.0h" visible="0">
					<image x="-34@" y="-3%" width="80%" height="80@" valign="center" align="center" texture="/ui/elements/vote_remake.tga" hflip="true" />
				</panel>
				<panel x="0" height="1" color="0 0 0 1" valign="bottom" sticky="false" stickytoinvis="false" />
			</panel>
			<!-- Over/Current State -->
			<panel name="top_sub_tab_current{id}" group="top_sub_tab_current" grow="true" growinvis="false" regrow="1" height="100%" float="right" color="#1f3f57" visible="{current=false}">
				<panel width="2.2h" height="100%" />
				<label fitx="true" fitxpadding="2.2h" textvalign="center" font="dyn_14" color="#ffaa00" outline="true" outlinecolor="0 0 0 1" content="{label}" />
				<panel name="top_sub_tab_arrow2_{id}" width="3.0h" visible="0">
					<image x="-34@" y="-3%" width="80%" height="80@" valign="center" align="center" texture="/ui/elements/vote_remake.tga" hflip="true" />
				</panel>
			</panel>
			<!-- Hover / Click Action -->
			<panel
				onclick="{onclick}"
				onclicklua="{onclicklua}
							if GetWidget('top_sub_tab_arrow2_{id}'):IsVisible() then
								Trigger('genericMainFloatingTip', 'true', '8h', '', 'general_goback', '', '', '', '3h', '-2h')
							else
								GetWidget('genericMainFloatingTip'):SetVisible(0)
							end"
				onmouseover="Call('top_sub_tab{id}', 'SetColor(\'#1c3345\');');"
				onmouseoverlua="if GetWidget('top_sub_tab_arrow2_{id}'):IsVisible() then
									Trigger('genericMainFloatingTip', 'true', '8h', '', 'general_goback', '', '', '', '3h', '-2h')
								end"
				onmouseout="Call('top_sub_tab{id}', 'SetColor(\'#282828\');'); HideWidget('genericMainFloatingTip');"
			/>
			<panel width="1" color="0 0 0 1" align="right" />
		</panel>
	</template>

	<template name="heroDifficultyStarLEARN">
		<panel sticky="true" stickytoinvis="false" noclick="true" width="100@" height="100%">
			<panel width="100@" height="100%" sticky="false" stickytoinvis="false" visible="true" noclick="true">
				<image texture="/ui/fe2/elements/hero_popularity_pip.tga" color="1 1 1 1" rendermode="grayscale" visible="true" />
			</panel>
			<panel name="compendium_hero_difficulty_{difficulty}" width="100@" height="100%" sticky="false" stickytoinvis="false" visible="false" noclick="true" clip="1">
				<image width="100@" texture="/ui/fe2/elements/hero_popularity_pip.tga" color="1 1 1 1" visible="true" />
			</panel>
		</panel>
	</template>

	<template name="LEARNVoiceButtonState">
		<widgetstate statename="{statename}" x="{x}" y="{y}">
			<frame texture="/ui/frames/circle.tga" color="1 .9 .9 .1" bordercolor="1 .9 .9 .1" borderthickness="33%" visible="{over=false}" />
			<frame texture="/ui/frames/circle.tga" color="0 0 0 .2" bordercolor="0 0 0 .2" borderthickness="33%" visible="{down=false}" />
		</widgetstate>
	</template>
	<template name="LEARNVoiceButton">
		<button
			color="invisible"
			onclicklua="{onclicklua}"
		>
			<instance name="LEARNVoiceButtonState" statename="up"/>
			<instance name="LEARNVoiceButtonState" statename="over" over="true"/>
			<instance name="LEARNVoiceButtonState" statename="down" down="true"/>
			<instance name="LEARNVoiceButtonState" statename="disabled"/>
		</button>
	</template>

	<template name="hero_alt_button">
		<panel width="100%" height="5.6h" name="hero_alt_button_{id}" visible="0"
			onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickAltAvatar', {id})"
			onmouseldown="Call('hero_alt_button_{id}_helper', 'SetX(1); SetY(1);');"
			onmouselup="Call('hero_alt_button_{id}_helper', 'SetX(0); SetY(0);');"
		>
			<panel name="hero_alt_button_{id}_helper" color="invisible" noclick="1">
				<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="grayscale" />
				<frame name="hero_alt_button_{id}_selected" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" visible="0"/>
				<panel width="-1.2h" height="-1.2h" align="center" valign="center" noclick="true">
					<panel height="100%" width="100@" noclick="true">
						<image name="hero_alt_button_{id}_icon" noclick="true"/>
						<frame color="invisible" borderthickness="1" bordercolor="0 0 0 1" noclick="true"/>
					</panel>
					<panel width="-110@" align="right" float="bottom" noclick="true">
						<label name="hero_alt_button_{id}_name" fity="true" font="dyn_10" color="1 1 1 1" shadow="true" content="-" noclick="true" />
					</panel>
				</panel>
				<!-- Checkbox -->
				<panel name="hero_alt_button_{id}_default" x="25%" y="-16%" width="52%" height="36%" valign="bottom" noclick="true">
					<instance name="Noptions_checkbox2" checkbox_name="hero_alt_button_{id}_check" font="dyn_9" valign="center" cvar="" label="general_set_default" enabled="true"
						onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickDefaultAvatar', {id})"
					/>
				</panel>
				<panel y="55%" width="20%" height="30%" noclick="false" align="right">
					<label name="hero_alt_button_{id}_trial" fity="true" font="dyn_12" color="red" content="learn_trial" noclick="false" textalign="center"
						onmouseoverlua="HoN_Learner:MouseOverTrial({id})"
						onmouseout="HideWidget('trial_avatar_tip')"/>
				</panel>
				<panel name="hero_alt_button_{id}_label" visible="0" x="25%" y="-16%" grow="1" regrpw="1" height="36%" valign="bottom" noclick="1"
					onshow="##Call('hero_alt_button_{id}_label_text', 'SetX(0); SetY(0);'); Call('hero_alt_button_{id}_label_text', 'Setcolor(\'white\');');##"
					onmouseover="##Call('hero_alt_button_{id}_label_text', 'SetColor(\'#3abde7\');');##"
					onmouseout="##Call('hero_alt_button_{id}_label_text', 'Setcolor(\'white\');');##"
					onmouseldown="##Call('hero_alt_button_{id}_label_text', 'SetX(1); SetY(1);');##"
					onmouselup="##Call('hero_alt_button_{id}_label_text', 'SetX(0); SetY(0);');##"
					onclicklua="--UIManager.GetInterface('main'):HoNLearnerF('ClickAltGotoStore', {id})"
				>
					<label name="hero_alt_button_{id}_label_text" font="dyn_10" color="0.7 0.7 0.7 1" valign="center" content="learn_unowned" fitx="1" noclick="1" />
				</panel>
				<panel name="hero_alt_button_{id}_gcaicon" x="-0.5h" y="-1h" width="8.4h" height="2.1h" align="right" valign="bottom" visible="0">
					<image texture="/ui/fe2/elements/gca/icon_1.tga" />
				</panel>
			</panel>
		</panel>
	</template>

	<template name="hero_alt_scroll_btn">
		<panel name="hero_alt_scroll_{dir}" valign="{valign}" height="1.5h" width="100%" visible="{visible}">
			<image y="-0.8h" height="5.5h" width="100%" valign="bottom" texture="/ui/info/grad_vert.tga" color="0 0 0 1" noclick="true" vflip="true" visible="{blockfade=false}"/>
			<button
				color="invisible"
				visible="{visible}"
				onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ScrollAltAvatars', '{dir}')"
			>
				<widgetstate statename="up">
					<image width="200@" height="100%" texture="/ui/fe2/elements/scroll_arrow.tga" align="center" color=".6 .6 .6 1" vflip="{vflip}" />
				</widgetstate>
				<widgetstate statename="over">
					<image width="200@" height="100%" texture="/ui/fe2/elements/scroll_arrow.tga" align="center" color="1 1 1 1" vflip="{vflip}" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<image width="200@" height="100%" texture="/ui/fe2/elements/scroll_arrow.tga" align="center" color="1 1 1 1" vflip="{vflip}" />
				</widgetstate>
			</button>
		</panel>
	</template>

	<template name="learnatorium">

		<panel y="-110%" width="129.0h" align="center" name="compendium" visible="{visible=false}" noclick="true" hotkey="ESC" onhotkey="Set('_mainmenu_currentpanel', 'compendium'); CallEvent('MainMenuPanelSwitcher');"
			onshow="If(_entityDefinitionsLoaded, DoEvent(2), CallEvent('RegisterEntityDefinitionsHelper')); SubmitForm('PlayerStatsMastery', 'f', 'show_stats', 'nickname', StripClanTag(GetAccountName()), 'cookie', GetCookie(), 'table', 'mastery');"
			onshowlua="GetWidget('compendium_content'):SetY(isNewUI() and '2h' or '0')"
			watch="EntityDefinitionsLoaded" ontrigger="Call('learnatorium_main', 'SetVisible(1);'); DoEvent(2);"
			onevent2lua="if (self:IsVisible()) then UIManager.GetInterface('main'):HoNLearnerF('OnShow') end"
			onhidelua="UIManager.GetInterface('main'):HoNLearnerF('OnHide')"
		>
			<panel name="compendium_content" noclick="1">
				<panel x="0" y="-100%" height="203.6%" width="90%" align="center" texture="mainmenu/upper_frame_center.tga"/>
				<panel x="18h" y="-100%" height="203.6%" width="50@" align="right" texture="mainmenu/upper_frame_right.tga"/>
				<panel x="-18h" y="-100%" height="203.6%" width="50@" align="left" texture="mainmenu/upper_frame_left.tga"/>

				<panel name="learnatorium_main" visible="0" y="1.2h" height="-2.0h" width="-6.0h" align="center" noclick="true">

					<panel x="14.6h" width="-15.0h" noclick="true">
						<panel color="#183042" noclick="true"/>
						<panel width="-0.8h" height="-0.8h" align="center" valign="center" color="0 0 0 1" noclick="true">
							<panel y="1" width="-2" align="center" float="bottom" noclick="true">
								<!-- Tab Header -->
								<panel width="100%" height="3.6h" float="right" color="#1f3f57">
									<panel name="learner_top_tabs" grow="true" height="100%" float="right">
										<instance name="top_sub_tab" id="1" group="learntabs" label="compendium_list_simple" current="false" onclick="ShowOnly('top_sub_tab_current1');"
											onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickTopTab', 1)"
										/>
										<instance name="top_sub_tab" id="2" group="learntabs" label="compendium_list_detailed" current="false" onclick="ShowOnly('top_sub_tab_current2');"
											onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickTopTab', 2)"
										/>
										<!-- vvvTemporary, needs proper implementationvvv -->
										<instance name="top_sub_tab" id="8" group="learntabs" label="learn_tabs_mastery_list" current="false" onclick="ShowOnly('top_sub_tab_current8');"
											onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickTopTab', 8)"
										/>
										<!-- ^^^Temporary, needs proper implementation^^^ -->
										<instance name="top_sub_tab" id="3" group="learntabs" label="learn_tabs_usage_list" current="false" onclick="ShowOnly('top_sub_tab_current3');"
											onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickTopTab', 3)"
										/>
										<instance name="top_sub_tab" id="4" group="learntabs" label="learn_tabs_hero_info" current="false" onclick="ShowOnly('top_sub_tab_current4');"
											onclicklua="UIManager.GetInterface('main'):HoNLearnerF('ClickTopTab', 4)"
										/>
										<image width="40@" height="100%" align="center" valign="center" texture="/ui/info/grad_horiz.tga" color="0 0 0 .15" />
									</panel>
									<instance
										name="closex_btn"
										x="-0.5h" y="0.5h"
										width="2.1h" height="2.1h"
										align="right"
										onclick="Set('_mainmenu_currentpanel', 'compendium'); CallEvent('MainMenuPanelSwitcher');"
									/>
								</panel>
								<image height="36%" width="100%" align="center" texture="/ui/info/grad_vert.tga" color="#1f3f57" noclick="true" />
							</panel>

							<!-- Content -->
							<!-- Hero Info -->
							<panel name="learner_heroinfo" y="-1.0h" width="-1.0h" height="-5.0h" align="center" valign="bottom" noclick="true" visible="0">

								<panel width="-25.0h" noclick="true">

									<panel height="-1.8h" valign="bottom">

										<panel x="1.0h" width="-32.0h" align="left" noclick="true">

											<panel height="-10.0h" valign="bottom" noclick="true">
												<!-- Model -->
												<panel width="-23.0h" align="right" noclick="true">
													<modelpanel
														name="learner_hero_model"
														scenebuffer="true"
														noclick="1"
														model=""
														anim="idle"
														cameranear="3000.0"
														camerafar="5000.0"
														depthclear="true"
														depthcompress="false"
														lookat="false"
														cameradistance="30"
														camerapos="0 3600 80"
														cameraangles="0 0 180"
														camerafov="7"
														modelpos="0 0 0"
														modelangles="-15.0 0 0.0"
														modelscale="1.0"
														sunazimuth="120"
														sunaltitude="50"
														suncolor="0.9 0.9 0.9"
														ambientcolor="0.6 0.7 0.7"
														height="143.5%"
														y="-40%"
														width="288%"
														x="-94%"
														visible="true"
														luatable="1"
														cull="false"
													/>
