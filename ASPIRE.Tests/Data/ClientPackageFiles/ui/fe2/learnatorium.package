								<!-- Avg Game -->
								<panel width="23.0h" align="right" noclick="true">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.6h" color="0 0 0 1" blockinput="false" noclick="true"/>
									<frame texture="/ui/frames/roundframe.tga" color="invisible" borderthickness="0.6h" bordercolor="#455166" blockinput="false" noclick="true"/>

									<label y="0.8h" width="-1.8h" align="center" fity="true" font="dyn_14" color="#ffab01" shadow="true" content="learn_hero_avg_game" />

									<panel noclick="1" y="6.5h" width="-1.4h" align="center" >
										<instance name="compendium_herostats_rnk_template" color="#3abde7" visible="1" style="modeNormal_txt" bg="modeNormal_bg" />
										<instance name="compendium_herostats_cs_template" color="#456645" visible="0" style="modeCasual_txt" bg="modeCasual_bg" />
										<instance name="compendium_herostats_ph_template" color="#664545" visible="0" style="modePublic_txt" bg="modePublic_bg" />
										<instance name="compendium_herostats_con_normal_template" color="#3abde7" visible="0" style="modeNormal_txt" bg="modeNormal_bg" />
										<instance name="compendium_herostats_con_casual_template" color="#456645" visible="0" style="modeCasual_txt" bg="modeCasual_bg" />
									</panel>

									<panel y="3.5h" width="-1.4h" align="center" reverse="0" padding="0.1h" noclick="1" color="invisible"
											onload=" If(!VarExists('compendium_herostats_lastViewed'), DoEvent(0), DoEvent(1)); "
											onevent0="CreateString('compendium_herostats_lastViewed', 'compendium_herostats_rnk'); SetSave('compendium_herostats_lastViewed');  ShowOnly(compendium_herostats_lastViewed);  "
											onevent1="ShowOnly(compendium_herostats_lastViewed);"
									>
										<panel width="20h" height="2.6h" noclick="1" visible="1" color="invisible" >
											<if condition="!cl_GarenaEnable">
												<instance
													name="Noptions_combobox"
													width="100%"
													itemwidth="100%"
													maxlistheight="4"
													populate="
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_rnk', 'label', 'general_normal_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_cs', 'label', 'general_casual_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_ph', 'label', 'general_public_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_con_normal', 'label', 'general_con_normal_mode');
															SetSelectedItemByValue(compendium_herostats_lastViewed);
															"
													onselect="
															ShowOnly(this); cmd('setsave compendium_herostats_lastViewed ' # this);
															##ShowOnly(this#'_bg');##
														"
												/>
											</if>
											<if condition="cl_GarenaEnable">
												<instance
													name="Noptions_combobox"
													width="100%"
													itemwidth="100%"
													maxlistheight="5"
													populate="
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_rnk', 'label', 'general_normal_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_cs', 'label', 'general_casual_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_ph', 'label', 'general_public_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_con_normal', 'label', 'general_con_normal_mode');
															AddTemplateListItem('Ncombobox_item', 'compendium_herostats_con_casual', 'label', 'general_con_casual_mode');
															SetSelectedItemByValue(compendium_herostats_lastViewed);
															"
													onselect="
															ShowOnly(this); cmd('setsave compendium_herostats_lastViewed ' # this);
															##ShowOnly(this#'_bg');##
														"
												/>
											</if>
