														onclick=" CallEvent('shopcompendium_guideError', 1); Call('compendium_no_guides', 'FadeOut(250);'); Set(compendium_usage_useCache, 0); Set(compendium_guide_useCache, 0); Set(compendium_guide_newRound, 1); Trigger('compendium_guideHeroName', compendium_heroLastViewed); "
													/>
