													<animatedimage name="learner_usage_loading_throb" y="-3.0h" width="5.8h" height="5.8h" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" visible="1" align="center" valign="center" />
