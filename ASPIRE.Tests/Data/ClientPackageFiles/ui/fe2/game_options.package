												<panel x="27%" group="options_grow_panel_child" height="2.6h" noclick="true">
													<panel width="4" height="32%" align="center" noclick="true">
														<panel width="2" color="#24314b" align="left" noclick="true" />
														<panel width="2" color="#070c11" align="right" noclick="true" />
													</panel>
													<panel  width="4" height="32%" align="center" valign="bottom" noclick="true">
