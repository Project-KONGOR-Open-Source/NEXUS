												<label y="2.8h" x="2.3%" font="dyn_9" color="1 1 1 1" shadow="true" content="options_low" noclick="true" />
												<label y="2.8h" x="23%" font="dyn_9" color="1 1 1 1" shadow="true" content="options_medium" noclick="true" />
												<label y="2.8h" x="47.7%" font="dyn_9" color="1 1 1 1" shadow="true" content="options_high" noclick="true" />
												<label y="2.8h" x="70.5%" font="dyn_9" color="1 1 1 1" shadow="true" content="options_ultra" noclick="true" />
												<label y="2.8h" x="91.5%" font="dyn_9" color="1 1 1 1" shadow="true" content="options_custom" noclick="true" />
												<slider
													name="optn_graphics_slider"
													oninstantiate="CreateInt('_optn_graphics_slider_value', ui_options_gfxslider);"
													oninstantiatelua="HoN_Options.InitializeGraphicsOptions()"
													onload="CreateInt('temp_gfxslider_int', ui_options_gfxslider);"
													width="-2.0h" align="center"
													slotwidth="-1%" slotheight="0.6h"
													slotcolor="#51647b"
													handlewidth="100@" handleheight="100%"
													handlecolor="1 1 1 1"
													cvar="temp_gfxslider_int"
													minvalue="1" maxvalue="5"
													step="1"
													texture="/ui/info/slider.tga"
													onselect="PlaySound('/shared/sounds/ui/button_over_02.wav');"
													onchange="If(temp_gfxslider_int != _optn_graphics_slider_value, DoEvent(5));"
													onevent5="_optn_graphics_slider_value = temp_gfxslider_int; PlaySound('/shared/sounds/ui/button_slide_01.wav');"
													onevent5lua="UIManager.GetInterface('main'):HoNOptionsF('GraphicsSlideFunction', self:GetValue())"
													onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
													onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
																Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
												/>
											</panel>
										</panel>

										<panel height="1.0h" noclick="true" />
									</panel>

								</panel>

								<panel group="options_grow_panel_child" width="30%" align="right" float="bottom" padding="0.8h" noclick="1">
									<label fity="true" wrap="true" font="dyn_16" color="#ffaa00" outline="true" content="options_graphicslvl_set" noclick="1" />
									<label fity="true" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_graphicslvl_txt1" noclick="1" />
									<label fity="true" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_graphicslvl_txt2" noclick="1" />
									<label fity="true" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_graphicslvl_txt3" noclick="1"/>
									<!-- Apply Button (stolen from MM + tweaked) -->
									<panel height="3.6h" noclick="1">
										<button
											name="option_gfx_slider_apply"
											width="70%" height="2.6h"
											valign="bottom" align="center"
											color="invisible"
											onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
											onshow="If(ui_options_gfxslider != temp_gfxslider_int,
														If(temp_gfxslider_int == 5,
															Split(
																SetNoClick(false),
																SetEnabled(true)
															),
															Split(
																SetNoClick(true),
																SetEnabled(false)
															)
														),
														Split(
															SetNoClick(true),
															SetEnabled(false)
														)
													);"
											onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
											onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
														Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
										>
											<widgetstate statename="up">
												<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1" noclick="1"/>
												<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="general_apply" noclick="1"/>
											</widgetstate>
											<widgetstate statename="over">
												<frame texture="/ui/info/button_over.tga" borderthickness="0.6h"  noclick="1"/>
												<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="general_apply" noclick="1"/>
											</widgetstate>
											<widgetstate statename="down">
												<frame texture="/ui/info/button_down.tga" borderthickness="0.6h" color="white" noclick="1"/>
												<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="general_apply" noclick="1"/>
											</widgetstate>
											<widgetstate statename="disabled">
												<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1" noclick="1"/>
												<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.6h" color=".3 .3 .3 .7" noclick="1"/>
												<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color=".4 .4 .4 1" outline="true" content="general_apply" noclick="1"/>
											</widgetstate>
										</button>
										<modelpanel
											name="options_graphics_apply_glow"
											visible="0"
											width="70%" height="2.6h"
											valign="bottom" align="center"
											noclick="true"
											model="/ui/common/models/main/button.mdf"
											anim="idle"
											camerapos="0 -1500 2"
											cameraangles="0 0 0"
											camerafov="4.42"
											carmerafar="7000"
											depthclear="false"
											depthcompress="true"
											sunazimuth="140"
											sunaltitude="10"
											suncolor="1.4 1.3 1"
											onshow="SetEffect('/ui/common/models/main/button.effect'));"
										/>
										<frame width="100%" height="3.8h" valign="bottom" texture="/ui/frames/black_corners.tga" color="invisible" borderthickness="0.6h" bordercolor="red" noclick="true" />
									</panel>
								</panel>

							</panel>
							<panel height="0.5h" noclick="true" />

							<!-- Video -->
							<instance name="options_subcategory_header" cat="1" id="2" label="options_submen_video" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="32.5%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Fullscreen Mode -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="2"
										cvar="options_fullscreen"
										title="options_checkbox_full_screen_mode"
										sub_text1="options_simple_fullscreen_a"
									/>

									<if condition="StringEquals(host_os,'windows')">
										<!-- Frame Queuing -->
										<instance name="option_checkbox_v3"
											category="1" subcategory="2"
											cvar="options_framequeuing"
											title="options_checkbox_frame_queuing"
											tip_name="options_checkbox_frame_queuing" tip_text1="options_frame_queuing_tip"
											sub_text1="options_simple_framequeue_a"
											sub_text3="options_simple_framequeue_b"
											sub_text2=""
										/>
									</if>

									<!-- Vsync -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="2"
										cvar="options_vsync"
										title="options_vsync"
										tip_name="options_vsync" tip_text1="options_vsync_tip_text"
										sub_text1="options_simple_vsync_a"
										sub_text3="options_simple_vsync_b"
										sub_text2=""
									/>

									<if condition="StringEquals(host_os,'windows')" >
										<!-- Hardware Mem Mode -->
										<instance name="option_checkbox_v3"
											category="1" subcategory="2"
											cvar="options_d3dex"
											title="options_d3dex"
											tip_name="options_d3dex" tip_text1="options_d3dex_tip_text"
											sub_text1="options_simple_hardwaremem_a"
											sub_text3="options_simple_hardwaremem_b"
											sub_text2=""
										/>
									</if>

									<if condition="cl_AlienFXEnabled">
										<!-- Alien FX -->
										<instance name="option_checkbox_v3"
											category="1" subcategory="2"
											cvar="ui_EnableAlienFX"
											title="options_alienfx"
											tip_name="options_alienfx" tip_text1="options_alienfx_tip"
										/>
									</if>

								</panel>
								<panel group="options_grow_panel_child" width="32.5%" align="center" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<if condition="StringEquals(host_os,'linux')||StringEquals(host_os,'macos')">
										<!-- Display -->
										<instance name="option_dropdown_v3"
											category="1" subcategory="2"
											cvar="options_display"
											title="options_label_display"
											maxlistheight="5"
											tip_name="options_label_display" tip_text1="options_display_tip"
											data="AddDisplays"
											onselect="CreateString('_saved_options_resolution',options_resolution );Call('otpwdg_options_resolution','ComboBoxCmd(\'clear\');AddResolutions(\'Ncombobox_item\');SetSelectedItemByValue(_saved_options_resolution);If(StringEmpty(options_resolution), SetSelectedItemByIndex(0))');"
											populate=""
										/>

										<!-- Resolution -->
										<instance name="option_dropdown_v3"
											category="1" subcategory="2"
											cvar="options_resolution"
											title="options_label_resolution"
											maxlistheight="5"
											tip_name="options_label_resolution" tip_text1="options_resolution_tip"
											data="AddResolutions"
											onselect="CreateInt('_saved_options_refreshRate', options_refreshRate);Call('otpwdg_options_refreshrate','ComboBoxCmd(\'clear\');AddRefreshRates(\'Ncombobox_item\');SetSelectedItemByValue(_saved_options_refreshRate);If(StringEmpty(options_refreshRate) || options_refreshRate == 0, SetSelectedItemByIndex(0))');"
											populate=""
											sub_text1="options_simple_res_a"
											sub_text3="options_simple_reducesigperf"
										/>
									</if>

									<if condition="StringEquals(host_os,'windows')">
										<!-- Driver -->
										<instance name="option_dropdown_v3"
											category="1" subcategory="2"
											cvar="options_vidDriver"
											title="options_label_vid_quality"
											maxlistheight="5"
											tip_name="options_label_vid_quality" tip_text1="options_video_drivers_tip"
											populate="
												AddTemplateListItem('Ncombobox_item', 'vid_d3d9', 'label', 'DirectX 9');
												AddTemplateListItem('Ncombobox_item', 'vid_gl2', 'label', 'OpenGL');"
										/>

										<!-- Resolution -->
										<instance name="option_dropdown_v3"
											category="1" subcategory="2"
											cvar="options_resolution"
											title="options_label_resolution"
											maxlistheight="5"
											tip_name="options_label_resolution" tip_text1="options_resolution_tip"
											data="AddResolutions"
											sub_text1="options_simple_res_a"
											sub_text3="options_simple_reducesigperf"
										/>
									</if>

									<if condition="StringEquals(host_os,'windows')||StringEquals(host_os,'macos')">
										<!-- Color Depth -->
										<instance name="option_dropdown_v3"
											category="1" subcategory="2"
											cvar="options_bpp"
											title="options_label_color_depth"
											maxlistheight="5"
											tip_name="options_label_color_depth" tip_text1="options_color_depth_tip"
											data="AddColorDepths"
											sub_text1="options_simple_depth_a"
											sub_text2=""
											sub_text3="options_simple_depth_b"
										/>
									</if>

								</panel>

								<panel group="options_grow_panel_child" width="32.5%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<if condition="StringEquals(host_os,'windows')||StringEquals(host_os,'macos')">
										<!-- Exclusive Mode -->
										<instance name="option_checkbox_v3"
												  category="1" subcategory="2"
												  cvar="options_exclusive"
												  title="options_checkbox_exclusive_mode"
												  tip_name="options_checkbox_exclusive_mode" tip_text1="options_exclusive_mode_tip"
												  sub_text1="options_simple_exclusive_b"
												  sub_text2="options_simple_exclusive_a"
												  sub_text3=""
										/>
									</if>

									<!-- Brightness Slider -->
									<instance name="option_slider_integer_v3"
										category="1" subcategory="1"
										cvar="options_gamma"
										percent="false"
										numerictype="float"
										round_var="false"
										precision="2"
										maxvalue="2"
										title="options_label_brightness"
										tip_name="options_label_brightness" tip_text1="options_brightness_tip"
									/>

									<!-- Refresh Rate -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="2"
										cvar="options_refreshrate"
										title="options_label_refresh_rate"
										maxlistheight="5"
										tip_name="options_label_refresh_rate" tip_text1="options_tip_refresh_rate"
										data="AddRefreshRates"
									/>

									<!-- Aspect Ratio -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="2"
										cvar="options_aspect"
										title="options_label_aspect_ratio"
										maxlistheight="4"
										tip_name="options_label_aspect_ratio" tip_text1="options_label_aspect_ratio_tip"
										data="AddAspectModes"
									/>

								</panel>
							</panel>

							<!-- Advanced Options -->
							<instance name="options_subcategory_header" cat="1" id="3" label="mainlobby_label_more" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="32.5%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Anti-Aliasing -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="3"
										cvar="options_antialiasing"
										title="options_label_anti_aliasing"
										maxlistheight="5"
										tip_name="options_label_anti_aliasing" tip_text1="options_label_anti_aliasing_tip"
										data="AddAntiAliasingModes"
										onchange="temp_gfxslider_int = 5;"
										sub_text1="options_simple_aa_a"
										sub_text3="options_simple_reducesigperf"
										sub_text2=""
									/>

									<!-- Model Quality -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="3"
										cvar="options_modelQuality"
										title="options_label_model_quality"
										maxlistheight="3"
										tip_name="options_label_model_quality" tip_text1="options_model_quality_tip"
										populate="
											AddTemplateListItem('Ncombobox_item', 'low', 'label', 'options_low');
											AddTemplateListItem('Ncombobox_item', 'med', 'label', 'options_medium');
											AddTemplateListItem('Ncombobox_item', 'high', 'label', 'options_high');"
										onchange="temp_gfxslider_int = 5;"
										sub_text3="options_simple_morememperf"
									/>

									<!-- Texture Size -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="3"
										cvar="options_textureSize"
										title="options_label_texture_size"
										maxlistheight="3"
										tip_name="options_label_texture_size" tip_text1="options_texture_size_tip"
										populate="
											AddTemplateListItem('Ncombobox_item', '2', 'label', 'options_low');
											AddTemplateListItem('Ncombobox_item', '1', 'label', 'options_medium');
											AddTemplateListItem('Ncombobox_item', '0', 'label', 'options_high');"
										onchange="temp_gfxslider_int = 5;"
										sub_text3="options_simple_morememperf"
									/>

									<!-- Rim Lighting -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="3"
										cvar="options_rimlighting"
										title="options_rim_lighting"
										tip_name="options_rim_lighting" tip_text1="options_rim_lighting_tip"
										onclick="temp_gfxslider_int = 5"
										sub_text2="options_simple_rim_a"
									/>

								</panel>

								<panel group="options_grow_panel_child" width="32.5%" align="center" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Shader Quality -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="3"
										cvar="options_shaderQuality"
										title="options_shader_quality"
										maxlistheight="3"
										tip_name="options_shader_quality" tip_text1="options_shader_quality_tip"
										populate="
											AddTemplateListItem('Ncombobox_item', '2', 'label', 'options_low');
											AddTemplateListItem('Ncombobox_item', '1', 'label', 'options_medium');
											AddTemplateListItem('Ncombobox_item', '0', 'label', 'options_high');"
										onchange="temp_gfxslider_int = 5;"
										sub_text1="options_simple_shader_a"
										sub_text3="options_simple_mayreduceperf"
									/>

									<!-- Shadow Quality -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="3"
										cvar="options_shadowQuality"
										title="options_shadow_quality"
										maxlistheight="5"
										tip_name="options_shadow_quality" tip_text1="options_shadow_quality_tip"
										populate="
											AddTemplateListItem('Ncombobox_item', '4', 'label', 'options_disabled');
											AddTemplateListItem('Ncombobox_item', '3', 'label', 'options_low');
											AddTemplateListItem('Ncombobox_item', '2', 'label', 'options_medium');
											AddTemplateListItem('Ncombobox_item', '1', 'label', 'options_high');"
										onchange="temp_gfxslider_int = 5;"
										sub_text3="options_simple_mayreduceperf"
									/>

									<!-- Water Quality -->
									<instance name="option_dropdown_v3"
										category="1" subcategory="3"
										cvar="options_waterQuality"
										title="options_shader_water_quality"
										maxlistheight="5"
										tip_name="options_shader_water_quality" tip_text1="options_shader_water_quality_tip"
										populate="
											AddTemplateListItem('Ncombobox_item', '3', 'label', 'options_low');
											AddTemplateListItem('Ncombobox_item', '2', 'label', 'options_medium');
											AddTemplateListItem('Ncombobox_item', '1', 'label', 'options_high');
											AddTemplateListItem('Ncombobox_item', '0', 'label', 'options_very_high');"
										onchange="temp_gfxslider_int = 5;"
										sub_text3="options_simple_mayreduceperf"
									/>

									<!-- Texture Filtering -->
									<instance name="option_dropdown_v3"
											  category="1" subcategory="3"
											  cvar="options_textureFiltering"
											  title="options_label_texture_filtering"
											  maxlistheight="4"
											  tip_name="options_label_texture_filtering" tip_text1="options_label_texture_filtering_tip"
											  data="AddTextureFilteringModes"
											  onchange="temp_gfxslider_int = 5;"
											  sub_text1="options_simple_textfilter_a"
											  sub_text3="options_simple_reducesigperf"
											  sub_text2=""
									/>

								</panel>

								<panel group="options_grow_panel_child" width="32.5%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Foliage -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="3"
										cvar="options_foliage"
										title="options_display_foliage"
										tip_name="options_display_foliage" tip_text1="options_foliage_tip_text"
										onclick="temp_gfxslider_int = 5"
									/>

									<!-- Dynamic Lights -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="3"
										cvar="options_dynamiclights"
										title="options_dynamic_lights"
										tip_name="options_dynamic_lights" tip_text1="options_dynamic_lights_tip"
										onclick="temp_gfxslider_int = 5"
										sub_text1="options_simple_dynlight_a"
										sub_text3="options_simple_mayreduceperf"
										sub_text2=""
									/>

									<!-- Reflections -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="3"
										cvar="options_reflections"
										title="options_reflections"
										tip_name="options_reflections" tip_text1="options_reflections_tip"
										onclick="temp_gfxslider_int = 5"
										sub_text1="options_simple_reflection_a"
										sub_text3="options_simple_reducesigperf"
									/>

									<!-- Refractions -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="3"
										cvar="options_refraction"
										title="options_refraction"
										tip_name="options_refraction" tip_text1="options_refraction_tip"
										onclick="temp_gfxslider_int = 5"
										sub_text1="options_simple_refrac_a"
										sub_text3="options_simple_mayreduceperf"
									/>

									<!-- Post Processing -->
									<instance name="option_checkbox_v3"
										category="1" subcategory="3"
										cvar="options_postprocessing"
										title="options_post_processing"
										tip_name="options_post_processing" tip_text1="options_post_processing_tip"
										onclick="temp_gfxslider_int = 5"
										sub_text1="options_simple_refrac_a"
										sub_text3="options_simple_mayreduceperf"
									/>

									<!-- Skybox -->
									<instance name="option_checkbox_v3"
											  category="1" subcategory="3"
											  cvar="options_skybox"
											  title="options_display_skybox"
											  tip_name="options_display_skybox" tip_text1="options_skybox_tip_text"
											  onclick="temp_gfxslider_int = 5"
											  sub_text2="options_simple_skybox_a"
									/>

								</panel>
							</panel>
						</panel>

						<!-- Sound -->
						<panel name="options_main_category2" group="options_grow_panel_parent" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0" reverse="true">

							<instance name="optionH1" label="options_header_sound_options" />
							<!-- Volume -->
							<instance name="options_subcategory_header" cat="2" id="1" label="options_submen_vol" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="32.5%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Mute Sounds -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="1"
										cvar="sound_mute"
										title="options_checkbox_sound_mute"
									/>

									<!-- Mute Pings -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="1"
										cvar="cg_muteUIPing"
										title="options_checkbox_sound_mutePings"
										tip_name="options_checkbox_sound_mutePings" tip_text1="options_checkbox_sound_mutePings_tip"
									/>

									<!-- Unit Reactions -->
									<!-- tip_name="options_checkbox_unit_reactions" tip_text1="options_unit_reactions_tip" -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="1"
										cvar="cg_unitVoiceResponses"
										title="options_checkbox_unit_reactions"
										sub_text2="options_simple_unitreact"
									/>

									<!-- Reaction Delay -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="1"
										cvar="cg_unitVoiceResponsesDelay"
										round_var="false"
										percent="false"
										maxvalue="15000" step="500"
										title="options_unit_voice_reaction_delay"
										tip_name="options_unit_voice_reaction_delay" tip_text1="options_unit_voice_reaction_tip"
										sub_text2="options_simple_reactdelay"
									/>
								</panel>

								<panel group="options_grow_panel_child" width="32.5%" align="center" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Mute Music -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="1"
										cvar="sound_muteMusic"
										title="options_checkbox_sound_muteMusic"
									/>

									<!-- Master Volume -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="1"
										cvar="sound_masterVolume"
										title="options_label_master_volume"
									/>

									<!-- SoundFX Volume -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="1"
										cvar="sound_sfxVolume"
										title="options_label_sound_effects"
										tip_name="options_label_sound_effects" tip_text1="options_sound_effects_tip"
									/>

								</panel>

								<panel group="options_grow_panel_child" width="32.5%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Mute Announceer -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="1"
										cvar="cg_muteAnnouncerVoice"
										title="options_checkbox_mute_announcer"
										tip_name="options_checkbox_mute_announcer" tip_text1="options_checkbox_mute_announcer_tip"
									/>

									<!-- Interface Volume -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="1"
										cvar="sound_interfaceVolume"
										title="options_label_interface_volume"
										tip_name="options_label_interface_volume" tip_text1="options_interface_volume_tip"
									/>

									<!-- Music Volume -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="1"
										cvar="sound_musicVolume"
										title="options_label_music_volume"
										tip_name="options_label_music_volume" tip_text1="options_label_music_volume_tip"
									/>
								</panel>
							</panel>

							<!-- Sound -->
							<instance name="options_subcategory_header" cat="2" id="2" label="options_button_sound" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="32.5%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Sound Quality -->
									<instance name="option_dropdown_v3"
										category="2" subcategory="2"
										cvar="options_soundQuality"
										title="options_label_sound_quality"
										maxlistheight="3"
										tip_name="options_label_sound_quality" tip_text1="options_sound_quality_tip"
										populate="
											AddTemplateListItem('Ncombobox_item', '2', 'label', 'options_very_low');
											AddTemplateListItem('Ncombobox_item', '1', 'label', 'options_low');
											AddTemplateListItem('Ncombobox_item', '0', 'label', 'options_normal');"
										sub_text3="options_simple_morememperf"
									/>

									<!-- Sound Channels -->
									<!-- tip_name="options_label_sound_channels" tip_text1="options_sound_channels_tip" -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="2"
										cvar="options_sound_numChannels"
										round_var="false"
										minvalue="32" maxvalue="256"
										title="options_label_sound_channels"
										sub_text1="options_simple_soundchannels"
										sub_text3="options_simple_morememperf"
									/>
								</panel>

								<panel group="options_grow_panel_child" width="66.0%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Disable All Sounds -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="2"
										cvar="options_sound_disable"
										onclick="Cmd('SetSave sound_disable ' # options_sound_disable);"
										title="options_checkbox_disable_all_sounds"
										tip_name="options_checkbox_disable_all_sounds" tip_text1="options_disable_all_sounds_tip"
									/>

									<if condition="StringEquals(host_os,'linux')">
										<!-- Sound Output -->
										<instance name="option_dropdown_v3"
											category="2" subcategory="2"
											cvar="options_sound_output"
											title="options_label_sound_output"
											maxlistheight="5"
											tip_name="options_label_sound_output" tip_text1="options_sound_output_tip"
											data="AddSoundOutputs"
											onselect="CreateString('_saved_sound_output',sound_output);Set('sound_output',options_sound_output);CreateInt('_saved_options_sound_driver',options_sound_driver);CreateInt('_saved_options_sound_recording_driver',options_sound_recording_driver);RefreshSoundDrivers();Call('playback_drivers_combobox','ComboBoxCmd(\'clear\');AddSoundPlaybackDrivers(\'Ncombobox_item\',\'dyn_8\');SetSelectedItemByValue(_saved_options_sound_driver);');Call('recording_drivers_combobox', 'ComboBoxCmd(\'clear\');AddSoundRecordingDrivers(\'Ncombobox_item\',\'dyn_8\');SetSelectedItemByValue(_saved_options_sound_recording_driver);');Set('sound_output',_saved_sound_output);"
										/>
									</if>

									<!-- Playback Driver -->
									<instance name="option_dropdown_v3"
										category="2" subcategory="2"
										cvar="options_sound_driver"
										title="options_label_playback_driver"
										maxlistheight="5"
										tip_name="options_label_playback_driver" tip_text1="options_playback_driver_tip"
										data="AddSoundPlaybackDrivers"
										onwatchrefilltrigger="SoundPlaybackDriverListChanged"
										onrefilltrigger="AddSoundPlaybackDrivers('Ncombobox_item','dyn_9');"
									/>

									<!-- Recording Driver -->
									<instance name="option_dropdown_v3"
										category="2" subcategory="2"
										cvar="options_sound_recording_driver"
										title="options_label_recording_driver"
										maxlistheight="5"
										tip_name="options_label_recording_driver" tip_text1="options_recording_drive_tip"
										data="AddSoundRecordingDrivers"
										onwatchrefilltrigger="SoundRecordingDriverListChanged"
										onrefilltrigger="AddSoundRecordingDrivers('Ncombobox_item','dyn_9');"
									/>
								</panel>
							</panel>

							<!-- Voice -->
							<instance name="options_subcategory_header" cat="2" id="3" label="options_button_voice" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="66%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Test Mic Level -->
									<panel width="100%" align="center" height="4.2h" noclick="1" onhide="VoiceStopTest(); HideWidget('Mvoice_test_stop'); ShowWidget('Mvoice_test_start');">
										<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true"/>
										<panel width="-1.6h" height="-1.4h" valign="center" align="center" noclick="1">
											<panel width="-2.6h" height="100%" valign="center" align="left" noclick="1">
												<panel noclick="1">
													<panel width="50%" float="right" noclick="1">
														<label color="white" font="dyn_10" textvalign="center" shadow="true" fitx="true" fitxpadding=".5h" noclick="1">options_label_test_mic_level</label>
													</panel>
													<panel width="-50%" height="100%" align="right" noclick="1">
														<panel x="-400@" width="325@" height="100%" noclick="1">
															<instance name="button2" button_name="Mvoice_test_start" height="100%" width="100%" valign="center" font="dyn_9" label="options_button_begin_test"  borderthickness=".8h" onclick="VoiceStartTest(); ShowWidget('Mvoice_test_stop'); HideWidget();" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
															onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
															onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
																		Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
															/>
															<instance name="button2" button_name="Mvoice_test_stop" visible="false" height="100%" width="100%" valign="center" font="dyn_9" label="options_button_stop_test"  borderthickness=".8h" onclick="VoiceStopTest(); ShowWidget('Mvoice_test_start'); HideWidget();" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
															onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
															onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
																		Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
															/>
														</panel>
														<image x="-5%" width="50@" height="40%" valign="center" texture="/ui/info/arrow.tga" noclick="1"/>
														<image width="84%" align="center" texture="/ui/info/slider_backdrop_c.tga" color="#b0b0b0" noclick="1"/>
														<image height="100%" width="100@" align="left" texture="/ui/info/slider_backdrop_l.tga" color="#b0b0b0" noclick="1"/>
														<image height="100%" width="100@" align="right" texture="/ui/info/slider_backdrop_r.tga" color="#b0b0b0" noclick="1"/>
														<label x="1h" width="100%" height="100%" textalign="left" textvalign="center" align="left" font="dyn_9" color="white" shadow="true" noclick="1">0</label>
														<label x="-1h" width="100%" height="100%" textalign="right" textvalign="center" align="right" font="dyn_9" color="white" shadow="true" noclick="1">100</label>
														<panel height="2h" width="70%" align="center" valign="center" noclick="1">
															<panel color="#00008877" x="-5%" width="0" height="90%" valign="center" align="left" watch="VoiceLevel" ontrigger="SetWidth(param # '%');" noclick="1"/>
															<panel color="#88888877" x="-5%" width="4%" height="90%" valign="center" align="center" noclick="1"/>
														</panel>
													</panel>
												</panel>
											</panel>
											<instance name="tip_mark" tip_id="Mtestlevel_tip" width="2.2h" height="2.2h" valign="center" align="right"
											onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
											onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
														Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
											/>
										</panel>
									</panel>

									<if condition="StringEquals(host_os,'linux')||StringEquals(host_os,'macos')">
										<!-- Voice micGain -->
										<instance name="option_slider_integer_v3"
											category="2" subcategory="3"
											cvar="voice_micGainDB"
											percent="false"
											minvalue="-20.0" maxvalue="20.0"
											step="0.1"
											title="options_label_microphone_gain"
											tip_name="options_label_microphone_gain" tip_text1="options_mic_gain_tip"
										/>
									</if>

									<!-- Voice Chat Volume -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="3"
										cvar="voice_volume"
										title="options_label_voice_chat_volume"
										tip_name="options_label_voice_chat_volume" tip_text1="options_voice_chat_volume_tip"
									/>


								</panel>

								<panel group="options_grow_panel_child" width="32.5%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Disable Voice Chat -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="3"
										cvar="voice_disabled"
										title="options_checkbox_disable_voice_chat"
										tip_name="options_checkbox_disable_voice_chat" tip_text1="options_disable_voice_chat_tip"
									/>

									<!-- Auto Sound Dampen -->
									<instance name="option_slider_integer_v3"
										category="2" subcategory="3"
										cvar="voice_audioDampen"
										title="options_label_auto_sound_dampen"
										tip_name="options_label_auto_sound_dampen" tip_text1="options_auto_dampen_tip"
										sub_text2="options_simple_dampen"
									/>

								</panel>
							</panel>

							<!-- Voice Chat Talk (Not a menu item -->
							<panel height="2.4h" noclick="true" sticky="true" stickytoinvis="false">
								<label textvalign="center" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_header_voice_chat_talk_settings" noclick="1"/>
							</panel>
							<panel group="options_grow_panel_child" width="100%" noclick="1">

								<panel group="options_grow_panel_child" width="32.5%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- PTT -->
									<instance name="option_checkbox_v3"
										category="2" subcategory="3"
										cvar="voice_pushToTalk"
										onclick="Trigger('PressToTalkTrigger');"
										title="options_checkbox_push_to_talk"
										tip_name="options_checkbox_push_to_talk" tip_text1="options_push_to_talk_enable_tip"
										sub_text2="options_simple_ptt"
									/>

								</panel>

								<panel group="options_grow_panel_child" width="66.0%" align="right" noclick="1" reverse="true"
									onshowlua="
										local bPushToTalk = GetCvarBool('voice_pushToTalk')
										self:GetChildWidget('ptt_false'):SetVisible(not bPushToTalk)
										self:GetChildWidget('ptt_true'):SetVisible(bPushToTalk)
									">

									<!-- PTT False -->
									<panel grow="1" width="100%" visible="true" name="ptt_false" group="ptt_options"
										watch="PressToTalkTrigger"
										ontrigger="SetVisible(!voice_pushToTalk);"
										>

										<panel group="options_grow_panel_child" width="49%" align="left" noclick="true">
											<!-- Mic on sensitivity -->
											<instance name="option_slider_integer_v3"
												category="2" subcategory="3"
												cvar="voice_micOnLevel"
												minvalue="0" maxvalue="100"
												title="options_label_mic_on_sensitivity"
												tip_name="options_label_mic_on_sensitivity" tip_text1="options_mic_on_sensitivity_tip"
											/>
										</panel>

										<panel group="options_grow_panel_child" width="49%" align="right" noclick="true">
											<!-- Mic Off Time -->
											<instance name="option_slider_integer_v3"
												category="2" subcategory="3"
												cvar="voice_micOnTime"
												minvalue="0" maxvalue="2000"
												title="options_label_mic_off_time"
												tip_name="options_label_mic_off_time" tip_text1="options_mic_off_time_tip"
											/>
										</panel>

									</panel>

									<!-- PTT True -->
									<panel grow="1" width="100%" float="bottom" padding="0.6h" visible="true" name="ptt_true" group="ptt_options" noclick="1"
										watch="PressToTalkTrigger"
										ontrigger="SetVisible(voice_pushToTalk);"
										>

										<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" rendermode="grayscale">
											<panel height="2.4h" width="-1.8h" align="center" valign="center" float="right" padding="0" noclick="true">
												<label width="-24h" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="options_set_binds" noclick="true"/>
												<panel width="21.1h" align="right" noclick="true">
													<label width="50%" align="left" textalign="center" textvalign="center" font="dyn_12" color="#37b2d9" content="options_yellow_label_primary" noclick="true" />
													<label width="50%" align="right" textalign="center" textvalign="center" font="dyn_12" color="#37b2d9" content="options_yellow_label_secondary" noclick="true" />
												</panel>
											</panel>
										</frame>

										<!-- PTT Talk Binds-->
										<instance name="option_keybind_v3" title="options_label_push_to_talk_keybind" table="game" action="VoicePushToTalk" tip_name="options_label_push_to_talk_keybind" tip_text1="options_push_to_talk_tip" usemodifiers="false" />

										<!-- PTT Lane Talk Binds-->
										<instance name="option_keybind_v3" title="options_label_lane_talk_keybind" table="game" action="VoicePushToLaneTalk" tip_name="options_label_lane_talk_keybind" tip_text1="options_push_to_lane_talk_tip" usemodifiers="false" />

										<!-- PTT Mentor Talk Binds-->
										<instance name="option_keybind_v3" title="options_label_mentor_talk_keybind" table="game" action="VoicePushToMentorTalk" tip_name="options_label_mentor_talk_keybind" tip_text1="options_push_to_mentor_talk_tip" usemodifiers="false" />
									</panel>
								</panel>
							</panel>
						</panel>

						<!-- Troubleshooting -->
						<panel name="options_main_category3" group="options_grow_panel_parent" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0" reverse="true">

							<instance name="optionH1" label="options_troubleshooting" />

							<panel noclick="1" height=".2h" />

							<!-- Repair Install -->
							<instance name="options_subcategory_header" cat="3" id="1" label="general_repair_install" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="-22.0h" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<label fity="true" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_trouble_repair_info" />
								</panel>
								<panel group="options_grow_panel_child" width="22.0h" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<instance name="button2" button_name="unnamedButton147" height="2.6h" width="16h" valign="center" align="center" font="dyn_11" label="general_repair_install"  borderthickness=".8h" onclick="Trigger('TriggerDialogBox', 'options_repair_confirm_head', 'options_button_ok', 'general_cancel', 'Cmd(\'RestartAndRepair\')', '', 'options_repair_confirm', 'options_repair_confirm_desc')" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
									onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
									onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
												Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
									/>
								</panel>
							</panel>

							<!-- FAQ -->
							<instance name="options_subcategory_header" cat="3" id="2" label="options_submen_faq" />
							<panel group="options_grow_panel_child" width="100%" float="bottom" padding="1.5h" noclick="1">
								<panel name="options_faq_support_url"
									onclick="Echo(ui_support_url); CopyToClipboard(ui_support_url);" noclick="0"
									onmouseover="Trigger('genericMainFloatingTip', true, '30h', '', 'options_trouble_faq_mouseover', 'options_trouble_faq_mouseover_b', '', '', '3h', '-2h');"
									onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');"
									onshow="SetHeight(GetStringWrapHeight('dyn_12', Translate('options_trouble_faq_intro', 'value', ui_support_url), GetWidth()));"
								>
									<label noclick="1" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_trouble_faq_intro" onshow="SetText(Translate('options_trouble_faq_intro', 'value', ui_support_url));" />
								</panel>

								<panel group="options_grow_panel_child" width="96%" align="center" float="bottom" padding="1.5h" noclick="1" reverse="true">

									<!-- Change Password -->
									<instance name="options_faq_entry" id="1"
										question="options_trouble_faq1_q"
										answer="options_trouble_faq1_a"
										passvalue1="ui_hon_url"
									/>

									<!-- Refund -->
									<instance name="options_faq_entry" id="2"
										question="options_trouble_faq2_q"
										answer="options_trouble_faq2_a"
									/>

									<!-- My graphics are all messed up -->
									<instance name="options_faq_entry" id="3"
										question="options_trouble_faq3_q"
										answer="options_trouble_faq3_a"
										answer2="options_trouble_faq3_a2"
										answer3="options_trouble_faq3_a3"
										answer4=""
									/>

									<!-- The match I was in just crashed -->
									<instance name="options_faq_entry" id="4"
										question="options_trouble_faq4_q"
										answer="options_trouble_faq4_a"
										answer2="options_trouble_faq4_a2"
										answer3="options_trouble_faq4_a3"
									/>

									<!-- I cannot update, connect to chat, or join matchmaking -->
									<instance name="options_faq_entry" id="5"
										question="options_trouble_faq5_q"
										answer="options_trouble_faq5_a"
										answer2="options_trouble_faq5_a2"
									/>

									<!-- I'm crashing a lot -->
									<instance name="options_faq_entry" id="6"
										question="options_trouble_faq6_q"
										answer="options_trouble_faq6_a"
										answer2="options_trouble_faq6_a2"
										answer3="options_trouble_faq6_a3"
									/>

									<!-- I don't have any sound -->
									<instance name="options_faq_entry" id="7"
										question="options_trouble_faq7_q"
										answer="options_trouble_faq7_a"
									/>

								</panel>
							</panel>

						</panel>

						<!-- Interface -->
						<panel name="options_main_category4" group="options_grow_panel_parent" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0" reverse="true">

							<instance name="optionH1" label="options_interface_opts" />
							<!-- Game Overlays -->
							<instance name="options_subcategory_header" cat="4" id="1" label="options_submen_gameoverlays" />
							<instance name="option_dropdown_v3"
								category="4" subcategory="1" width="49%" height="50%"
								cvar="options_defaultInterface"
								title="options_dropdown_overlayselect"
								maxlistheight="6"
								populate="
									AddTemplateListItem('Ncombobox_item', '/ui/game_legacy.interface', 'label', 'options_interface_classic');
									AddTemplateListItem('Ncombobox_item', '/ui/game_apex.interface', 'label', 'options_interface_razor');
									AddTemplateListItem('Ncombobox_item', '/ui/game_garena_other.interface', 'label', 'options_interface_sentinel');
										"
								button_label="options_simple_gameoverlay"
								sub_text2="options_simple_gameoverlay"
								onchange=""
							/>
							<!-- Gameplay -->
							<instance name="options_subcategory_header" cat="4" id="2" label="options_submen_gameplay" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="49%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Always Show Health Bars -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_alwaysShowHealthBars"
										title="options_checkbox_health_always_on"
										tip_name="options_checkbox_health_always_on" tip_text1="options_screen_health_always_on_tip"
									/>

									<!-- Show Exp Numbers -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_drawRewardExp"
										title="options_checkbox_show_exp"
										tip_name="options_checkbox_show_exp" tip_text1="options_screen_show_exp_tip"
									/>
									
									<!-- Always Show Hero Selection Rings -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_alwaysShowHeroSelectionRings"
										title="options_checkbox_selection_rings"
										tip_name="options_checkbox_selection_rings" tip_text1="options_checkbox_selection_rings_tip"
									/>

									<!-- Show Crits -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_drawPopupCritical"
										title="options_checkbox_show_crit"
										tip_name="options_checkbox_show_crit" tip_text1="options_screen_show_crit_tip"
									/>

									<!-- Show Deny Effects -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="g_unitPlayDenyAnims"
										title="options_checkbox_show_deny"
										tip_name="options_checkbox_show_deny" tip_text1="options_screen_show_deny_tip"
									/>

									<!-- Enable dbl Activate Abils -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_cmdrDoubleActivate"
										title="options_double_activate_abilities"
										tip_name="options_double_activate_abilities" tip_text1="options_double_activate_abilities_tip"
										sub_text2="options_simple_dblactivate"
									/>

									<!-- Shop Buy Components Conf -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="shop_confirm_buyall"
										title="options_checkbox_shop_confirm_buyall"
										tip_name="options_checkbox_shop_confirm_buyall" tip_text1="options_checkbox_shop_confirm_buyall_tip"
									/>

									<!-- Show tower range indicators -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_towerTargetEffect"
										title="options_tower_range_indicator"
										tip_name="options_tower_range_indicator" tip_text1="options_tower_range_indicator_tip"
									/>

									<!-- Radial Menu Delay -->
									<instance name="option_slider_integer_v3"
										category="4" subcategory="2"
										cvar="cg_sendPingToUIDelay"
										round_var="false"
										percent="false"
										minvalue="50"
										maxvalue="1000" step="10"
										title="options_radial_delay"
										tip_name="options_radial_delay" tip_text1="options_radial_delay_tip"
									/>
								</panel>

								<panel group="options_grow_panel_child" width="49%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Hide Full Health Bars -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_hideFullHealthBars"
										title="options_checkbox_hide_full_healthbar"
										tip_name="options_checkbox_hide_full_healthbar" tip_text1="options_screen_hide_full_healthbar_trip"
									/>

									<!-- Minimap Right Click -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_enableMinimapRightclick"
										title="options_enable_minimap_rightclick"
										tip_name="options_enable_minimap_rightclick" tip_text1="options_enable_minimap_rightclick_tip"
										sub_text2="options_simple_rightclickmap"
									/>

									<!-- Swap Mini Map -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										oninstantiate="If(!VarExists('ui_minimap_rightside'), Split(CreateBool('ui_minimap_rightside', false),Cmd('setsave ui_minimap_rightside false'))); SetCloudSave('ui_minimap_rightside', true);"
										cvar="ui_minimap_rightside"
										onshow="If(ui_minimap_rightside, SetButtonState(1));"
										onclick="Cmd('setsave ui_minimap_rightside ' # ui_minimap_rightside);
												 If(_game_phase ge 5, Trigger('MiniMapPosition'));"
										title="options_checkbox_reverse_minimap"
										sub_text2="options_simple_swapminimap"
										onrefreshlua="if UIGamePhase() >= 5 then Trigger('MiniMapPosition') end"
									/>

									<!-- Limit Map Pings -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										oninstantiate="SetCloudSave('ui_unlimitedPings', true);"
										cvar="ui_unlimitedPings"
										inverted="1"
										title="options_limit_pings"
										tip_name="options_limit_pings" tip_text1="options_limit_pings_tip"
									/>
									
									<!-- Mute minimap pings from voice-muted allies -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_muteMinimapPing_VoiceMutedAllies"
										title="options_muteMinimapPings_VoiceMutedAllies"
										tip_name="options_muteMinimapPings_VoiceMutedAllies" tip_text1="options_muteMinimapPings_VoiceMutedAllies_tip"
									/>

									<!-- Center cam on respawn -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_cameraCenterOnRespawn"
										title="options_checkbox_camera_center_on_respawn"
										tip_name="options_checkbox_camera_center_on_respawn" tip_text1="options_checkbox_camera_center_on_respawn_tip"
									/>

									<!-- Move to spawn on disco -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="cg_moveHeroToSpawnOnDisconnect"
										title="options_enable_move_on_disconnect"
										tip_name="options_enable_move_on_disconnect" tip_text1="options_enable_move_on_disconnect_tip"
									/>

									<!-- Weather Conditions -->
									<instance name="option_dropdown_v3"
										category="4" subcategory="2"
										cvar="cg_current_weather"
										data="AddWeather"
										onshow="ComboBoxCmd('clear'); AddWeather('Ncombobox_item'); If(StringEmpty(cg_current_weather) or StringEquals(cg_current_weather, 'None'), SetSelectedItemByIndex(0), SetSelectedItemByValue(cg_current_weather));"
										title="options_current_weather"
										maxlistheight="4"
										tip_name="options_current_weather" tip_text1="options_current_weather_tip"
									/>

								</panel>
							</panel>

							<!-- Chat -->
							<instance name="options_subcategory_header" cat="4" id="3" label="options_submen_chat" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="49%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

									<!-- Profanity Filter -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="3"
										cvar="cg_censorChat"
										title="options_checkbox_censor_chat"
										tip_name="options_checkbox_censor_chat" tip_text1="options_screen_censor_chat_tip"
									/>

									<!-- Short Format -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="3"
										cvar="HoN_Options.gameChatFilters.shortFormat"
										cloudcvar="chat_filterShortFormat"
										title="chat_opt_tab_1"
									/>

									<!-- Hero Icons -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="3"
										cvar="HoN_Options.gameChatFilters.heroIcons"
										cloudcvar="chat_filterHeroIcons"
										title="chat_opt_tab_2"
									/>

									<!-- Chat Sounds -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="3"
										cvar="HoN_Options.gameChatFilters.chatSounds"
										cloudcvar="chat_filterChatSounds"
										title="chat_opt_tab_5_options"
									/>
								</panel>
								<panel group="options_grow_panel_child" width="49%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Chat Sounds -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="3"
										oninstantiate="SetCloudSave('ui_game_chat_sounds', true);"
										cvar="ui_game_chat_sounds"
										title="chat_opt_tab_5"
									/>

									<!-- Show Timestamps -->
									<instance name="option_checkbox_v3"
										category="4" subcategory="2"
										cvar="chat_showChatTimestamps"
										title="options_checkbox_show_timestamps"
										tip_name="options_checkbox_show_timestamps" tip_text1="options_checkbox_show_timestamps_tip"
									/>

									<!-- Hero Names -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="3"
										cvar="HoN_Options.gameChatFilters.heroNames"
										title="chat_opt_tab_3"
										cloudcvar="chat_filterHeroNames"
									/>
								</panel>
							</panel>

							<!-- Friends and Clan -->
							<instance name="options_subcategory_header" cat="4" id="4" label="options_submen_friendsclans" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">
								<panel group="options_grow_panel_child" width="49%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Show custom name colors -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="4"
										cvar="SHOW_CUSTOM_COLORS"
										title="sp_options_btn_1"
										onchangelua="if isNewUI() then Social_V2:UpdateOptions() else HoN_Social_Panel:UpdateOptions() end"
										cloudcvar="social_customColors"
									/>
									<!-- Sort by ingame status -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="4"
										cvar="USER_SORT_ONLINE_FIRST"
										title="sp_options_btn_2"
										onchangelua="if isNewUI() then Social_V2:UpdateOptions() else HoN_Social_Panel:UpdateOptions() end"
										cloudcvar="social_sortOnlineFirst"
										defvalue="true"
									/>
								</panel>
								<panel group="options_grow_panel_child" width="49%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Merge Friends/Clan -->
									<if condition="!cg_newMainInterface">
										<instance name="option_checkbox_v3_lua"
											category="4" subcategory="4"
											cvar="MERGE_CLAN_FRIENDS"
											title="sp_options_btn_3"
											onchangelua="HoN_Social_Panel:UpdateOptions()"
											cloudcvar="social_mergeClanFriends"
											onrefreshlua="self:UICmd('ChatRefresh()')"
										/>
									</if>
									<!-- Show offliners in custom groups -->
									<instance name="option_checkbox_v3_lua"
										category="4" subcategory="4"
										cvar="OFFLINE_IN_GROUPS"
										title="sp_options_btn_5"
										onchangelua="if isNewUI() then Social_V2:UpdateOptions() else HoN_Social_Panel:UpdateOptions() end"
										cloudcvar="social_offlineInGames"
									/>
								</panel>
							</panel>

							<!-- Notifications -->
							<instance name="options_subcategory_header" cat="4" id="5" label="options_submen_notifications" />
							<panel group="options_grow_panel_child" width="100%" float="bottom" padding="1.5h" noclick="1">

								<panel group="options_grow_panel_child" width="100%" float="right" padding="1.5h" noclick="1">
									<!-- Display Duration -->
									<instance name="option_slider_integer_v3"
										width="49%"
										category="2" subcategory="1"
										cvar="ui_notifications_toastDuration"
										oninstantiate="SetCloudSave('ui_notifications_toastDuration', true);"
										percent="false"
										minvalue="1" maxvalue="15" step="1"
										title="options_slider_notification_duration"
										tip_name="options_slider_notification_duration" tip_text1="options_slider_notification_duration_tip"
									/>
									<!-- Notification Sounds -->
									<instance name="option_checkbox_v3"
										width="49%"
										category="4" subcategory="5"
										oninstantiate="SetCloudSave('ui_not_opt_sound', true);"
										cvar="ui_not_opt_sound"
										onshow="SetButtonState(ui_not_opt_sound);"
										title="options_play_notification_sounds"
									/>
								</panel>

								<panel group="options_grow_panel_child" width="100%" float="bottom" padding="0.5h" noclick="1">
									<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" rendermode="grayscale">
										<label x="0.75h" width="-20h" height="2.4h" valign="center" textvalign="center" font="dyn_14" color="#ffaa00" shadow="1" content="sp_notifications_options_header_4" noclick="1"/>
									</frame>
									<panel group="options_grow_panel_child" width="100%" float="bottom" noclick="1">
										<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_19" label="options_notifications_friends_imreceived" />
										<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_17" label="options_notifications_miscellaneous_newpatch" />
										<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_25" label="options_notifications_miscellaneous_activestream" />
										<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_26" label="options_notifications_miscellaneous_replay" />
										<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_27" label="options_notifications_miscellaneous_cloudsave" />
									</panel>

									<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" rendermode="grayscale">
										<label x="0.75h" width="-20h" height="2.4h" valign="center" textvalign="center" font="dyn_14" color="#ffaa00" shadow="1" content="sp_notifications_options_header_1" noclick="1"/>
									</frame>
									<panel group="options_grow_panel_child" width="100%" float="bottom" noclick="1">
										<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_23" label="options_notifications_friends_request" enabled3="false" />
										<if condition="!cg_newMainInterface">
											<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_1" label="options_notifications_friends_add" enabled3="false" />
											<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_8" label="options_notifications_friends_signon" />
											<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_10" label="options_notifications_friends_signoff" />
											<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_11" label="options_notifications_friends_joingame" />
											<instance name="sp_options_notifications_checkbox_item" tip_id="" option="ui_not_opt_9" label="options_notifications_friends_leavegame" />
										</if>
									</panel>

									<if condition="!cg_newMainInterface">
