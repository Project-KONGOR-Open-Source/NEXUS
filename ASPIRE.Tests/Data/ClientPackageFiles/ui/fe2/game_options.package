<?xml version="1.0" encoding="UTF-8"?>
<package>
	<!--To add categories and sub catgories that will be automatically detected by the script, you MUST do the following
			For help, set 'build_db_output' at the top of 'options.lua' to true. It will tell you what is missing when the menu is first opened

		*For each category in the left menu, you must use the 'options_menu_cat' template and set the 'id' to the next available index
		(so for the 3rd category in the list, the 'id' must be 3)

		*For each category in the left menu, you must also make a panel named 'options_submenuX' were X is the number of the category (like above).
		Each of the sub menu items (the next bullet point) will be children to this panel.

		*For each sub category in the left menu, you must use the 'options_sub_menu' template with 'cat' set to the same number as the category
		that is it's parent and the 'id' for which entry in the sub menu it is. (so for the 3rd sub item in the 2nd catgory, 'cat' must be 2 and 'id' must be 3)

		*For each entry in the left menu, you must have corresponding entries in the main (right) panel

		*For each category you must have a panel named 'options_main_categoryX' where X is the same as the id/cat number used above for the category in the left menu.
		(so if your left menu has a category for Display that is the first one ('id' 1) then you would want a panel named 'options_main_category1' for the Display options main panel)

		*For each sub category, you must have an instance of 'options_subcategory_header' with 'cat' set to the same number as the category
		that is it's parent and an 'id' for which entry in the sub menu it is. Basically the same as the left menu sub category.

		This sounds like a lot, but it's not that bad. The easiest way to add things will be to copy paste existing categories and modifying them to fit your needs.
	-->

	<trigger name="PressToTalkTrigger" />
	<lua file="/ui/scripts/options.lua" />
	<include file="/ui/mod_options.package" />
	<include file="/ui/mod_options_templates.package" />

	<cvar name="game_options_ignore_change" type="bool" value="false" />

	<!-- Function to reset cg_defaultInterface cvar to default interface per region for people selecting retro after patch -->
	<panel noclick="1" onloadlua="RetroRevert()" />

	<!-- UI trigger engine that helps launch game options to the game overlays section from the original game.interface/depreciated game_retro.interface if somehow was selected -->
	<trigger name="revertUITrigger" />
	<panel noclick="1" watch="revertUITrigger" ontriggerlua="OpenOptions(param0, param1, param2)" />

	<!-- from old options, guess this isn't really a thing -->
	<!-- open and frame so that our dropdowns will have the right values and won't screw up our gfx slider -->

	<!-- onloadlua does a groupcall to panels that use to have grow set to true. This caused insane load times so
		it now doesn't grow, but after everything is created it sets them to grow, and has them all resize.
		the children ones are panels that need to grow, but are children of a panel that needs to grow
		parents are topmost growing panels. Only these recalculate since doing so causes it's children to recalculate
	-->

	<panel noclick="1"
		onload="
			OptionsOpen();
			CreateString('_keybind_command');
			CreateString('_keybind_table');
			CreateString('_keybind_action');
			CreateString('_keybind_param');
			CreateString('_keybind_num');
			CreateString('_keybind_old_button');
			CreateBool('_keybind_impulse');
			CreateBool('_keybind_cloudsave');
		"
		onloadlua="
			SetSave('cg_banjo_sound', false, 'bool', true)
			SetSave('hero_holdaftermove', false, 'bool', true)
			SetSave('cg_toolPersistantTargetIndicatorEnable', true, 'bool', true)
			SetSave('ui_hideGameHeroTips', false, 'bool', true)
			SetSave('ui_notifications_toastDuration', 7, 'float', true)
			SetSave('ui_unlimitedPings', false, 'bool', true)
			SetSave('ui_options_netslider', 5, 'int', true)
			SetSave('ui_options_gfxslider', 5, 'int', true)
			SetSave('ui_game_chat_sounds', true, 'bool', true)
			SetSave('ui_not_opt_sound', 'true', 'bool', true)
			groupfcall('options_grow_panel_child', function(_,w,_) w:SetGrow(true) w:SetHeight(0) end)
			groupfcall('options_grow_panel_parent', function(_,w,_) w:SetGrow(true) w:SetHeight(0) w:UICmd('RecalculateSize()') end)

			--[[these are from all the mods we moved over and are no longer mods]]
			SetSave('ebuff_cfgActive_timerbar', true, 'bool', true)
			SetSave('ebuff_cfgActive_showlbl', true, 'bool', true)
			SetSave('ebuff_cfgActive_overheadlbl', true, 'bool', true)
			SetSave('ebuff_cfgActive_popenabled', false, 'bool', true)
			SetSave('ebuff_cfgActive_popdispassive', false, 'bool', true)
			SetSave('ebuff_cfgActive_blinkenabled', false, 'bool', true)
			SetSave('ebuff_cfgActive_dectimer', false, 'bool', true)
		"
	/>

	<!-- from old options -->
	<!-- Loops to unbind the shop keys - crashes if there isn't a sleep (event for the widget gets called too many times in a single frame?) -->
	<panel name="FunctionUnbindShopKeys" noclick="1" onload="
		CreateInt('_shop_unbind_keys_loopint', 0);
		CreateString('_shop_unbind_key', '');
		CreateInt('_shop_unbind_key_int', 0);
		CreateString('_shop_unbind_key', '');
	"
	onevent="
		Call('button_clear_shop_hotkeys', 'SetEnabled(false);');
		Set('_shop_unbind_key', GetKeybindButton('shop', 'Shop', _shop_unbind_keys_loopint));
		If(!StringEquals(_shop_unbind_key, 'None'), Cmd('unbind shop ' # _shop_unbind_key));
		Set('_shop_unbind_keys_loopint', _shop_unbind_keys_loopint + 1);
		If(_shop_unbind_keys_loopint lt 20,
			SleepWidget(1, 'CallEvent(\'FunctionUnbindShopKeys\');'),
			Split(
				Set('_shop_unbind_keys_loopint', 0),
				Refresh(),
				Call('button_clear_shop_hotkeys', 'SetEnabled(true);')
			)
		);
	"/>

	<template name="options_menu_cat">
		<panel name="options_cat{id}_parent" height="2.8h" sticky="true" stickytoinvis="false" watch="{watch}" ontrigger="{ontrigger}">
			<panel
				name="options_cat{id}"
				color="invisible"
				enabled="{enabled=true}"
				onclick="##showOnly('options_submenu{id}'); showOnly('currentarrow{id}');##"
				onclicklua="UIManager.GetInterface('main'):HoNOptionsF('SelectSubCategory', {id}, 0)"
				onshow="BringToFront();"
				onmouseldown="Call('options_cat{id}_stuff', 'SetX(1); SetY(1):');"
				onmouselup="Call('options_cat{id}_stuff', 'SetX(0); SetY(0):');"
				visible="{visible=1}"
				watch="{watch}"
				ontrigger="{ontrigger}"
				ontriggerlua="{ontriggerlua}"
				onshowlua="{onshowlua}"
				onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverCategory', true, {id}, 0)"
				onmouseoutlua="UIManager.GetInterface('main'):HoNOptionsF('HoverCategory', false, {id}, 0)"
			>
				<panel name="options_cat{id}_stuff" float="right" padding="0.6h" noclick="1">
					<panel height="100%" width="100@" noclick="true">
						<image width="84@" height="84%" align="center" valign="center" texture="/ui/icons/options/{icon}" color="#66C2FF" noclick="1"/>
					</panel>
					<label name="options_cat{id}_lbl" fitx="true" height="100%" textvalign="center" font="dyn_14" color=".8 .8 .8 1" outline="true" content="{label}" noclick="1"/>
				</panel>
			</panel>
		</panel>
	</template>

	<template name="options_sub_menu">
		<panel height="1.8h" sticky="true" stickytoinvis="false" noclick="1"
			onloadlua="{onloadlua}"
			watch="{watch}"
			ontriggerlua="{ontriggerlua}"
		>
			<panel
				name="options_sub{cat}{id}"
				color="invisible"
				enabled="{enabled=true}"
				onclicklua="UIManager.GetInterface('main'):HoNOptionsF('SelectSubCategory', {cat}, {id})"
				visible="false"
				onmouseldown="Call('options_sub{cat}{id}_lbl', 'SetX(1); SetY(1);');"
				onmouselup="Call('options_sub{cat}{id}_lbl', 'SetX(0); SetY(0);');"
				onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverCategory', true, {cat}, {id})"
				onmouseoutlua="UIManager.GetInterface('main'):HoNOptionsF('HoverCategory', false, {cat}, {id})"
			>
				<label name="options_sub{cat}{id}_lbl" textvalign="center" font="dyn_11" color="#37b2d9" shadow="true" content="{label}" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="options_subcategory_header">
		<panel name="options_main_sub{cat}{id}" height="2.4h" noclick="true" visible="{visible=true}" sticky="true" stickytoinvis="false"
			onloadlua="{onloadlua}"
			watch="{watch}"
			ontriggerlua="{ontriggerlua}"
		>
			<panel y="1.6h" color=".2 .2 .2 1" height="1" noclick="true" />
			<panel x="1.0h" grow="true" height="100%" color="0 0 0 1" noclick="1">
				<label x="0.6h" fitx="true" fitxpadding="0.6h" font="dyn_14" color=".8 .8 .8 1" shadow="true" content="{label}" noclick="1"/>
			</panel>
		</panel>
	</template>

	<template name="optionH1">
		<label fity="true" fitypadding="1.0h" font="dyn_16" color="1 1 1 1" shadow="true" content="{label}" noclick="1"/>
	</template>

	<template name="optionH2">
		<panel height="3.0h" noclick="true" color="1 1 1 .2">
			<panel y="1.8h" color=".2 .2 .2 1" height="1" noclick="true" />
			<panel grow="true" height="100%" color="0 0 0 1" noclick="1">
				<label x="0.5h" fitx="true" fitxpadding="0.5h" font="dyn_14" color=".8 .8 .8 1" shadow="true" content="{label}" noclick="!" />
			</panel>
		</panel>
	</template>

	<template name="options_combobox_container">
		<panel width="{width=100%}" height="{height=2.5h}" align="center" noclick="1" onshow="{onshow}" sticky="true" stickytoinvis="false">
			<panel width="96%" align="center">
				<panel width="-2.6h" height="100%" valign="center" align="left" noclick="true">

					<panel width="{labelwidth=40%}">
						<label color="white" font="dyn_10" textvalign="center" shadow="true" fitx="true" fitxpadding=".5h">{label}</label>
					</panel>
					<panel width="-{labelwidth=40%}" height="2.2h" valign="center" align="right">
						<image x="-5%" width="50@" height="40%" valign="center" texture="/ui/info/arrow.tga" />
						<instance name="Moptions_combobox" id="{id}" font="{font=dyn_12}" x="0" width="100%" itemwidth="100%" maxlistheight="{maxlistheight=10}" cvar="{cvar}" data="{data}" onselect="{onselect}" populate="{populate}" />
					</panel>

				</panel>
				<instance name="tip_mark" tip_id="M{tip_id}" width="80@" height="80%" valign="center" align="right" />
				<!-- <instance name="generic_tooltip_float_resizey" x="-68@" y="0" width="23h" align="right" tip_id="M{tip_id}" title="{label}" label="{tip_label}" /> -->
			</panel>
		</panel>
	</template>

	<template name="option_checkbox_v3_lua">
		<panel
			grow="true"
			width="{width=100%}"
			oninstantiate="{oninstantiate};" group="{group=options_options_lua}"
			oninstantiatelua="
				local cvarName = '{cloudcvar}'
				if NotEmpty(cvarName) then
					if Cvar.GetCvar(cvarName) == nil then
						local cvarValue = {cvar}
						if cvarValue == nil and {defvalue=false} then
							cvarValue = {defvalue=false}
						end
						SetSave(cvarName, cvarValue, 'bool', true)
					end
					local cvar = Cvar.GetCvar(cvarName)
					if cvar then
						Cvar.SetCloudSave(cvar, true)
					end
				end
				{oninstantiatelua}"
			onevent7lua="
				local cvarName = '{cloudcvar}'
				if (NotEmpty(cvarName)) then
					Set(cvarName, {cvar})
					Set('host_pendingOptionsChanges', true)
				end
			"
			onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_checkbox_v3_lua', '{category}', '{subcategory}', '{cvar}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}', '{cloudcvar=}') end"
			onshow="DoEvent(9);"
			onclick="PlaySound('/shared/sounds/ui/button_click_06.wav'); {onclick};"
			ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav'); {onclick};"
			onclicklua="{cvar} = not {cvar} self:DoEventN(7) self:DoEventN(9) {onchangelua}"
			ondoubleclicklua="{cvar} = not {cvar} self:DoEventN(7) self:DoEventN(9) {onchangelua}"
		 	onevent9lua="
 				if (NotEmpty('{cvar=}') and WidgetExists('options_checkbox_frame_{cvar}{nameid}')) then
 					if ({cvar}) then
 						GetWidget('options_checkbox_frame_{cvar}{nameid}'):SetRenderMode('normal')
 					else
 						GetWidget('options_checkbox_frame_{cvar}{nameid}'):SetRenderMode('grayscale')
 					end
 					GetWidget('options_checkbox_check_{cvar}{nameid}'):SetVisible({cvar})
 				end"
			onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
			onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
						Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
			onrefreshlua="
				if (NotEmpty('{cloudcvar=}')) then
					{cvar} = GetCvarBool('{cloudcvar}')
					self:DoEventN(9)
				end
				{onrefreshlua}
			"
		>
			<frame name="options_checkbox_frame_{cvar}{nameid}" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1"/>
			<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">

				<panel height="1.8h" noclick="true" sticky="true" stickytoinvis="false">
					<panel width="-2.5h" noclick="true">
						<panel width="100@" height="100%" color="invisible" noclick="1">
							<panel width="1.5h" height="1.5h" noclick="1">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1"/>
								<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
								<panel name="options_checkbox_check_{cvar}{nameid}" x="0.1h" y="-0.2h" valign="bottom" align="center" width="125@" height="125%" nolclick="true" visible="false" noclick="1">
									<image x="1" y="1" texture="/ui/elements/check_mark_white.tga" color="0 0 0 1" noclick="1"/>
									<image texture="/ui/elements/check_mark_white.tga" color="#40cd3c" noclick="1"/>
								</panel>
							</panel>
						</panel>
						<label height="100%" textvalign="center" width="-130@" align="right" font="dyn_14" color="#ffaa00" shadow="true" content="{title}" noclick="true" />
					</panel>
					<instance name="tip_mark" tip_id="{tip_id}" width="2.2h" height="2.2h" valign="center" align="right" visible="0"
						oninstantiatelua="self:SetVisible(NotEmpty('{tip_text1=}'))"
						onmouseover="Trigger('genericMainFloatingTip', true, '30h', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '3h', '-2h');"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');
									HideWidget('genericMainFloatingTip');"
					/>
				</panel>
				<panel height="0.2h" noclick="true" />

				<!-- Txt 1 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text1=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".75 .85 .75 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".75 .85 .75 1" shadow="true" content="{sub_text1}" noclick="true" />
				</panel>
				<!-- Txt 2 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text2=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".8 .8 .8 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".8 .8 .8 1" shadow="true" content="{sub_text2}" noclick="true" />
				</panel>
				<!-- Txt 3 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text3=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".9 .7 .7 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".9 .7 .7 1" shadow="true" content="{sub_text3}" noclick="true" />
				</panel>
				<panel height="0.5h" noclick="true" sticky="true" stickytoinvis="false" />
			</panel>
		</panel>
	</template>

	<template name="option_checkbox_v3">
		<panel
			name="{cvar}{nameid}_cbpanel"
			grow="true"
			width="{width=100%}"
			oninstantiate="{oninstantiate};" group="{group=options_options}"
			oninstantiatelua="{oninstantiatelua}"
			onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_checkbox_v3', '{category}', '{subcategory}', '{cvar}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}') end"
			onshow="DoEvent(9);"
			onclick="PlaySound('/shared/sounds/ui/button_click_06.wav'); {cvar} = !{cvar}; DoEvent(7); DoEvent(9); {onclick};"
			ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav'); {cvar} = !{cvar}; DoEvent(7); DoEvent(9); {onclick};"
			onevent7="
						If(!StringEmpty('{enforce}'),
							If({inverted=false},
								If(!{cvar} or !{pair=false},
									Split(
										If(!StringEmpty('{enforce}'), Set('{enforce}', true)),
										If(!StringEmpty('{enforce2}'), Set('{enforce2}', true)),
										If(!StringEmpty('{enforce3}'), Set('{enforce3}', true)),
										If(!StringEmpty('{enforce4}'), Set('{enforce4}', true))
									),
									Split(
										If(!StringEmpty('{enforce}'), Set('{enforce}', false)),
										If(!StringEmpty('{enforce2}'), Set('{enforce2}', false)),
										If(!StringEmpty('{enforce3}'), Set('{enforce3}', false)),
										If(!StringEmpty('{enforce4}'), Set('{enforce4}', false))
									)
								),
								If({cvar} or {pair=false},
									Split(
										If(!StringEmpty('{enforce}'), Set('{enforce}', true)),
										If(!StringEmpty('{enforce2}'), Set('{enforce2}', true)),
										If(!StringEmpty('{enforce3}'), Set('{enforce3}', true)),
										If(!StringEmpty('{enforce4}'), Set('{enforce4}', true))
									),
									Split(
										If(!StringEmpty('{enforce}'), Set('{enforce}', false)),
										If(!StringEmpty('{enforce2}'), Set('{enforce2}', false)),
										If(!StringEmpty('{enforce3}'), Set('{enforce3}', false)),
										If(!StringEmpty('{enforce4}'), Set('{enforce4}', false))
									)
								)
							)
						);
						host_pendingOptionsChanges = true;
						"
		 	onevent9="If(!StringEmpty('{cvar=}'),
		 				Split(
		 					If(WidgetExists('options_checkbox_frame_{cvar}{nameid}'),
		 						If(!{inverted=false},
		 							If({cvar},
		 								Call('options_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'normal\')'),
		 								Call('options_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'grayscale\')')
		 							),
									If(!{cvar},
		 								Call('options_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'normal\')'),
		 								Call('options_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'grayscale\')')
		 							)
		 						)
		 					),
		 					If(WidgetExists('options_checkbox_frame_{cvar}{nameid}'),
		 						If(!{inverted=false},
		 							Call('options_checkbox_check_{cvar}{nameid}', 'SetVisible({cvar})'),
		 							Call('options_checkbox_check_{cvar}{nameid}', 'SetVisible(!{cvar})')
		 						)
		 					)
		 				)
		 			 ); {onchange};"
		 	onevent9lua="{onchangelua}"
			onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
			onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
						Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
			onrefreshlua="{onrefreshlua}"
		>
	 		<button
				name="{cvar}{nameid}_cbname"
				cvar="{cvar}"
				group="{group=options_options}"
				onbutton="If(WidgetExists('{cvar}{nameid}_cbpanel'), Call('{cvar}{nameid}_cbpanel', 'DoEvent(9);'));"
				visible="1"
				noclick="1"
				width="0" height="0"
				numstates="2"
			/>

			<frame name="options_checkbox_frame_{cvar}{nameid}" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1"/>
			<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">

				<panel height="1.8h" noclick="true" sticky="true" stickytoinvis="false">
					<panel width="-2.5h" noclick="true">
						<panel width="100@" height="100%" color="invisible" noclick="1">
							<panel width="1.5h" height="1.5h" noclick="1">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1"/>
								<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
								<panel name="options_checkbox_check_{cvar}{nameid}" x="0.1h" y="-0.2h" valign="bottom" align="center" width="125@" height="125%" nolclick="true" visible="false" noclick="1">
									<image x="1" y="1" texture="/ui/elements/check_mark_white.tga" color="0 0 0 1" noclick="1"/>
									<image texture="/ui/elements/check_mark_white.tga" color="#40cd3c" noclick="1"/>
								</panel>
							</panel>
						</panel>
						<label height="100%" textvalign="center" width="-130@" align="right" font="dyn_14" color="#ffaa00" shadow="true" content="{title}" noclick="true" />
					</panel>
					<instance name="tip_mark" tip_id="{tip_id}" width="2.2h" height="2.2h" valign="center" align="right" visible="0"
						oninstantiatelua="self:SetVisible(NotEmpty('{tip_text1=}'))"
						onmouseover="Trigger('genericMainFloatingTip', true, '30h', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '3h', '-2h');"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');
									HideWidget('genericMainFloatingTip');"
					/>
				</panel>
				<panel height="0.2h" noclick="true" />

				<!-- Txt 1 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text1=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".75 .85 .75 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".75 .85 .75 1" shadow="true" content="{sub_text1}" noclick="true" />
				</panel>
				<!-- Txt 2 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text2=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".8 .8 .8 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".8 .8 .8 1" shadow="true" content="{sub_text2}" noclick="true" />
				</panel>
				<!-- Txt 3 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text3=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".9 .7 .7 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".9 .7 .7 1" shadow="true" content="{sub_text3}" noclick="true" />
				</panel>
				<panel height="0.5h" noclick="true" sticky="true" stickytoinvis="false" />
			</panel>
		</panel>
	</template>

	<template name="option_slider_integer_v3">
		<panel
			grow="true"
			width="{width=100%}" group="{group=options_options}"
			noclick="1"
			oninstantiate="{oninstantiate}; CreateString('optstr_{cvar}{nameid}_value');"
			oninstantiatelua="{oninstantiatelua}"
			onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_slider_integer_v3', '{category}', '{subcategory}', '{cvar}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}') end"
			onshow="DoEvent(9);"
			onevent9lua="if (WidgetExists('optwdg_{cvar}{nameid}')) then GetWidget('optwdg_{cvar}{nameid}'):DoEvent() end"
		>
			<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />
			<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">

				<panel height="1.8h" noclick="true" sticky="true" stickytoinvis="false">
					<label width="-2.5h" height="100%" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="{title}" noclick="true" />
					<instance name="tip_mark" tip_id="{tip_id}" width="2.2h" height="2.2h" valign="center" align="right" visible="0"
						oninstantiatelua="self:SetVisible(NotEmpty('{tip_text1=}'))"
						onmouseover="Trigger('genericMainFloatingTip', true, '30h', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '3h', '-2h');"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');
									HideWidget('genericMainFloatingTip');"
					/>
				</panel>
				<panel height="0.3h" noclick="true" />

				<panel height="2.6h" noclick="true">
					<panel width="4.6h" noclick="true">
						<frame texture="/ui/frames/rounded_bg_flat.tga" borderthickness="0.5h" color="#142739" noclick="true" />
						<frame texture="/ui/frames/roundframe.tga" color="#1a3950" borderthickness="0.5h" noclick="true" />
						<cvarlabel textvalign="center" textalign="center" font="dyn_10" color="1 1 1 1" shadow="true" cvar="optstr_{cvar}{nameid}_value" noclick="1" numeric="true" numerictype="{numerictype=int}" precision="{precision=0}"/>
					</panel>

					<slider
						name="optwdg_{cvar}{nameid}"
						width="-5.1h"
						align="right"
						slotwidth="-1%" slotheight="0.6h"
						slotcolor="#51647b"
						handlewidth="90@" handleheight="90%"
						handlecolor="1 1 1 1"
						cvar="{cvar}"
						minvalue="{minvalue=0}" maxvalue="{maxvalue=1}"
						step="{step}"
						texture="/ui/info/slider.tga"
						oninstantiate="
							Set(optstr_{cvar}{nameid}_value, if({round_var=true}, (round ({cvar} * if({percent=true}, 100, 1))), {cvar}));
							SetValue({cvar});
						"
						onselect="PlaySound('/shared/sounds/ui/button_over_02.wav');"
						onchange="If(optstr_{cvar}{nameid}_value != if({round_var=true}, (round ({cvar} * if({percent=true}, 100, 1))), {cvar}), Split(host_pendingOptionsChanges = true, PlaySound('/shared/sounds/ui/button_slide_01.wav') )); Set(optstr_{cvar}{nameid}_value, if({round_var=true}, (round ({cvar} * if({percent=true}, 100, 1))), {cvar})); {action=}; {slideronchange};"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
						onevent="Set(optstr_{cvar}{nameid}_value, if({round_var=true}, (round ({cvar} * if({percent=true}, 100, 1))), {cvar}));"
					/>
				</panel>
				<panel height="0" noclick="true" />

				<!-- Txt 1 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text1=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".75 .85 .75 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".75 .85 .75 1" shadow="true" content="{sub_text1}" noclick="true" />
				</panel>
				<!-- Txt 2 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text2=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".8 .8 .8 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".8 .8 .8 1" shadow="true" content="{sub_text2}" noclick="true" />
				</panel>
				<!-- Txt 3 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text3=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".9 .7 .7 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".9 .7 .7 1" shadow="true" content="{sub_text3}" noclick="true" />
				</panel>

				<panel height="0.3h" noclick="true" sticky="true" stickytoinvis="false" />
			</panel>
		</panel>
	</template>

	<template name="option_slider_graduated_marker">
		<panel x="{x}" grow="true" height="100%" visible="0" oninstantiatelua="self:SetVisible(NotEmpty('{value=}'))" noclick="true">
			<image width="0.7h" height="0.7h" texture="/ui/elements/arrow_up.tga" align="center" noclick="true" />
			<label fitx="true" textvalign="bottom" textalign="center" align="center" font="dyn_9" color="1 1 1 1" shadow="true" content="{value}" noclick="true" />
		</panel>
	</template>

	<template name="option_slider_graduated_v3">
		<panel
			grow="true"
			width="{width=100%}"
			noclick="1"
			oninstantiate="{oninstantiate}" group="{group=options_options}"
			oninstantiatelua="{oninstantiatelua}"
			onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_slider_graduated_v3', '{category}', '{subcategory}', '{cvar}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction=NoSlideFunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}') end"
		>
			<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />
			<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">

				<panel height="1.8h" noclick="true" sticky="true" stickytoinvis="false">
					<label width="-2.5h" height="100%" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="{title}" noclick="true" />
					<instance name="tip_mark" tip_id="{tip_id}" width="2.2h" height="2.2h" valign="center" align="right" visible="0"
						oninstantiatelua="self:SetVisible(NotEmpty('{tip_text1=}'))"
						onmouseover="Trigger('genericMainFloatingTip', true, '30h', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '3h', '-2h')"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');
									HideWidget('genericMainFloatingTip');"
					/>
				</panel>
				<panel height="0" noclick="true" />

				<panel height="3.6h" noclick="true" >
					<!-- Graduation Markers -->
					<panel height="2.0h" valign="bottom" noclick="true">
						<instance name="option_slider_graduated_marker" x="{gradmark1_pos}" value="{gradmark1_name}" />
						<instance name="option_slider_graduated_marker" x="{gradmark2_pos}" value="{gradmark2_name}" />
						<instance name="option_slider_graduated_marker" x="{gradmark3_pos}" value="{gradmark3_name}" />
						<instance name="option_slider_graduated_marker" x="{gradmark4_pos}" value="{gradmark4_name}" />
						<instance name="option_slider_graduated_marker" x="{gradmark5_pos}" value="{gradmark5_name}" />
					</panel>
					<panel height="2.6h" noclick="true">
						<slider
							name="optwdg_{cvar}{nameid}"
							oninstantiate="CreateInt('optint_{cvar}{nameid}_value', {cvar});"
							width="-2.0h" align="center"
							slotwidth="-1%" slotheight="0.6h"
							slotcolor="#51647b"
							handlewidth="90@" handleheight="90%"
							handlecolor="1 1 1 1"
							cvar="{cvar}"
							minvalue="{minvalue=0}" maxvalue="{maxvalue=1}"
							step="{step=1}"
							texture="/ui/info/slider.tga"
							onselect="PlaySound('/shared/sounds/ui/button_over_02.wav');"
							onchange="If({cvar} != optint_{cvar}{nameid}_value, DoEvent(5));"
							onevent5="optint_{cvar}{nameid}_value = {cvar}; PlaySound('/shared/sounds/ui/button_slide_01.wav'); {action=}; {slideronchange};"
							onevent5lua="UIManager.GetInterface('main'):HoNOptionsF('{slidefunction=NoSlideFunction}', self:GetValue())"
							onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
							onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
										Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
						/>
					</panel>
				</panel>

				<!-- Txt 1 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text1=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".75 .85 .75 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".75 .85 .75 1" shadow="true" content="{sub_text1}" noclick="true" />
				</panel>
				<!-- Txt 2 -->
