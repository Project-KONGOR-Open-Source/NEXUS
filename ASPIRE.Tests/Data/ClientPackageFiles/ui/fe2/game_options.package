								</panel>
							</panel>

							<if condition="StringEquals(host_os,'windows') and IsWindowsGreaterThanXP() and StringEquals(host_vidDriver,'vid_d3d9')">
								<!-- Facebook Live -->
								<instance name="options_subcategory_header" cat="5" id="5" label="facebook_stream"
									onloadlua="self:SetVisible(GetCvarBool('cg_EnableFbStream'))"
									watch="DynamicCommandsExecuted"
									ontriggerlua="self:SetVisible(GetCvarBool('cg_EnableFbStream'))"
								/>

								<panel group="options_grow_panel_child" width="100%" noclick="1"
									onloadlua="self:SetVisible(GetCvarBool('cg_EnableFbStream'))"
									watch="DynamicCommandsExecuted"
									ontriggerlua="self:SetVisible(GetCvarBool('cg_EnableFbStream'))"
								>
									<!-- left -->
									<panel group="options_grow_panel_child" width="49%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">

										<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" rendermode="grayscale">
											<panel height="2.4h" width="-1.8h" align="center" valign="center" float="right" padding="0" noclick="true">
												<label width="-24h" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="" noclick="true"/>
												<panel width="21.1h" align="right" noclick="true">
													<label width="50%" align="left" textalign="center" textvalign="center" font="dyn_12" color="#37b2d9" content="options_yellow_label_primary" noclick="true" />
													<label width="50%" align="right" textalign="center" textvalign="center" font="dyn_12" color="#37b2d9" content="options_yellow_label_secondary" noclick="true" />
												</panel>
											</panel>
										</frame>

										<instance name="option_keybind_v3" title="facebook_stream_toggle_menu" table="game" action="ToggleFacebookStreamMenu" impulse="true"/>
									</panel>

									<!-- right -->
									<panel group="options_grow_panel_child" width="49%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">

										<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" rendermode="grayscale">
											<panel height="2.4h" width="-1.8h" align="center" valign="center" float="right" padding="0" noclick="true">
												<label width="-24h" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="" noclick="true"/>
												<panel width="21.1h" align="right" noclick="true">
													<label width="50%" align="left" textalign="center" textvalign="center" font="dyn_12" color="#37b2d9" content="options_yellow_label_primary" noclick="true" />
													<label width="50%" align="right" textalign="center" textvalign="center" font="dyn_12" color="#37b2d9" content="options_yellow_label_secondary" noclick="true" />
												</panel>
											</panel>
										</frame>

										<instance name="option_keybind_v3" title="facebook_stream_action_start" table="game" action="StartFacebookStream" impulse="true"/>
										<instance name="option_keybind_v3" title="facebook_stream_action_stop" table="game" action="StopFacebookStream" impulse="true"/>
									</panel>
								</panel>
							</if>
						</panel>

						<!-- Mods -->
						<panel name="options_main_category6" group="options_grow_panel_parent" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0" reverse="true">
							<instance name="optionH1" label="options_button_mods" />
							<instance name="options_subcategory_header" cat="6" id="1" label="options_submen_modopts" visible="0"/>
							<instance name="mod_lobby" />
						</panel>

						<!-- Referrals -->
						<panel name="options_main_category7" group="options_grow_panel_parent" growinvis="0" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0">
							<!-- <instance name="optionH1" label="Referrals" />	 -->
							<instance name="options_subcategory_header" cat="7" id="1" label="options_referral" visible="false"/>
							<panel name="options_referral_browser" height="41.3h" noclick="1"
								oneventlua="UIManager.GetInterface('main'):HoNOptionsF('ReferralPage')"
							/>
						</panel>

						<!-- Cloud Saves -->
						<panel name="options_main_category8" group="options_grow_panel_parent" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0" reverse="true">
							<instance name="optionH1" label="options_cloud_opts" />
							<instance name="options_subcategory_header" cat="8" id="1" label="options_submen_cloud_config" />

							<panel grow="true" growinvis="false" group="options_grow_panel_child" width="100%" align="right" padding="0.6h" noclick="1">

								<panel group="options_grow_panel_child" width="49%" align="center" float="bottom" padding="0.6h" noclick="1">
								<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />
								<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">
									<label fity="true" font="dyn_16" color="#ffaa00" outline="true" content="options_cloud_status" noclick="1" />
									<label fity="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" noclick="1" content="No cloud config found" watch="CloudConfigStatus"
									ontriggerlua="
										if (AtoB(param1)) then
											self:SetText(Translate('options_cloud_status_current') .. '\n' .. Translate('options_cloud_status_modified') .. ' ' .. param0)
											self:SetColor('0, 1, 0, 1')
										else
											self:SetText(Translate('options_cloud_status_notcurrent') .. '\n' .. Translate('options_cloud_status_modified') .. ' ' .. param0)
											self:SetColor('1, 0, 0, 1')
										end
									"/>
									<panel height="3" noclick="1" />
								</panel>
								</panel>
							</panel>

							<panel grow="true" growinvis="false" group="options_grow_panel_child" width="100%" align="left" padding="0.6h" noclick="1"
								name="host_cloudsave_parent"
								watch="CloudConfigGotStatus"
								ontriggerlua="self:RefreshWidget()"
								oneventlua="
									Client.SetEnrollCloudConfig(GetCvarBool('host_cloudAutoDownload'), GetCvarBool('host_cloudAutoUpload'))

									local v = GetWidget('host_cloudAutoDownload_cbpanel', nil, true)
									if v then
										v:SetNoClick(true)
										local t = v
										v:Sleep(2000, function() t:SetNoClick(false) end)
									end

									v = GetWidget('host_cloudAutoUpload_cbpanel', nil, true)
									if v then
										v:SetNoClick(true)
										local t = v
										v:Sleep(2000, function() t:SetNoClick(false) end)
									end

									v = GetWidget('host_cloudAutoDownload_search_cbpanel', nil, true)
									if v then
										v:SetNoClick(true)
										local t = v
										v:Sleep(2000, function() t:SetNoClick(false) end)
									end

									v = GetWidget('host_cloudAutoUpload_search_cbpanel', nil, true)
									if v then
										v:SetNoClick(true)
										local t = v
										v:Sleep(2000, function() t:SetNoClick(false) end)
									end
								"
								>
								<panel group="options_grow_panel_child" width="49%" align="left" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Auto Apply Cloud Config -->
									<instance name="option_checkbox_v3"
										category="6" subcategory="1"
										cvar="host_cloudAutoDownload"
										title="options_cloud_autodownload"
										sub_text2="options_cloud_autodownload_tip"
										onclick="CallEvent('host_cloudsave_parent');"
										onrefreshlua="self:SetNoClick(false)"
									/>
								</panel>
								<panel group="options_grow_panel_child" width="49%" align="right" float="bottom" padding="0.6h" noclick="1" reverse="true">
									<!-- Auto Apply Cloud Config -->
									<instance name="option_checkbox_v3"
										category="6" subcategory="1"
										cvar="host_cloudAutoUpload"
										title="options_cloud_autoupload"
										sub_text2="options_cloud_autoupload_tip"
										onclick="CallEvent('host_cloudsave_parent');"
										onrefreshlua="self:SetNoClick(false)"
									/>
								</panel>

							</panel>

							<!-- Upload and Download -->
							<panel group="options_grow_panel_child" width="100%" noclick="1">

								<!-- Download Cloud Config -->
								<panel grow="true" growinvis="false" group="options_grow_panel_child" width="49%" align="left" padding="0.6h" noclick="1">

									<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />
									<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">
										<label fity="true" wrap="true" font="dyn_16" color="#ffaa00" outline="true" content="options_cloud_download" noclick="1" />
										<label fity="true" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_cloud_download_tip" noclick="1" />
										<panel height="2" noclick="1" />
										<panel height="4h" noclick="1">
											<button
												name="options_cloud_download_button"
												width="70%" height="2.6h"
												valign="top" align="center"
												color="invisible"
												onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
												onclicklua="Client.RetrieveCloudConfig()"
												onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
												onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
															Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
											>
												<widgetstate statename="up">
													<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1" noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="options_cloud_download_button" noclick="1"/>
												</widgetstate>
												<widgetstate statename="over">
													<frame texture="/ui/info/button_over.tga" borderthickness="0.6h"  noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="options_cloud_download_button" noclick="1"/>
												</widgetstate>
												<widgetstate statename="down">
													<frame texture="/ui/info/button_down.tga" borderthickness="0.6h" color="white" noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="options_cloud_download_button" noclick="1"/>
												</widgetstate>
												<widgetstate statename="disabled">
													<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1" noclick="1"/>
													<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.6h" color=".3 .3 .3 .7" noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color=".4 .4 .4 1" outline="true" content="options_cloud_download_button" noclick="1"/>
												</widgetstate>
											</button>
										</panel>
									</panel>
								</panel>

								<!-- Upload Cloud Config -->
								<panel grow="true" growinvis="false" group="options_grow_panel_child" width="49%" align="right" padding="0.6h" noclick="1">
									<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />
									<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true">
										<label fity="true" wrap="true" font="dyn_16" color="#ffaa00" outline="true" content="options_cloud_upload" noclick="1" />
										<label fity="true" wrap="true" font="dyn_12" color=".8 .8 .8 1" shadow="true" content="options_cloud_upload_tip" noclick="1" />
										<panel height="2" noclick="1" />
										<panel height="4h" noclick="1">
											<button
												name="options_cloud_upload_button"
												width="70%" height="2.6h"
												valign="top" align="center"
												color="invisible"
												onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
												onclicklua="Client.PostCloudConfig()"
												onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
												onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
															Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
											>
												<widgetstate statename="up">
													<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1" noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="options_cloud_upload_button" noclick="1"/>
												</widgetstate>
												<widgetstate statename="over">
													<frame texture="/ui/info/button_over.tga" borderthickness="0.6h"  noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="options_cloud_upload_button" noclick="1"/>
												</widgetstate>
												<widgetstate statename="down">
													<frame texture="/ui/info/button_down.tga" borderthickness="0.6h" color="white" noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color="white" outline="true" content="options_cloud_upload_button" noclick="1"/>
												</widgetstate>
												<widgetstate statename="disabled">
													<frame texture="/ui/info/button.tga" borderthickness="0.6h" color="1 1 1 1" noclick="1"/>
													<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.6h" color=".3 .3 .3 .7" noclick="1"/>
													<label width="100%" height="100%" textvalign="center" textalign="center" font="dyn_10" color=".4 .4 .4 1" outline="true" content="options_cloud_upload_button" noclick="1"/>
												</widgetstate>
											</button>
										</panel>
									</panel>
								</panel>
							</panel>
						</panel>

						<!-- Search -->
						<!-- if the category index on this is changed the script needs to be tweaked -->
						<panel name="options_main_category9" regrow="1" grow="true" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0"
							onshowlua="HoN_Options.RegisterOptions()">
							<instance name="optionH1" label="general_search" />
							<instance name="options_subcategory_header" cat="9" id="1" label="general_search" />
							<panel height="30.0h" noclick="1">
								<panel name="options_search_insertion_point" noclick="1" height="0" grow="1" regrow="1" width="100%" color="0 0 0 0" float="bottom" padding="0.4h" reverse="true" />

								<panel name="options_search_insertion_point_cover" height="100%" width="100%" color="0 0 0 1" visible="1" >
									<animatedimage name="options_search_cover_throb" y="-3.0h" width="5.8h" height="5.8h" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" visible="0" align="center" valign="center" />
									<label name="options_search_cover_label" height="5h" width="66%" align="center" valign="top" textalign="center" textvalign="center" font="dyn_14" shadow="true" content="options_search_terms" noclick="1"/>
								</panel>
							</panel>
							<panel x="-3.6h" y="0" noclick="1" align="right" color="invisible" width="30h" height="4.5h" >
								<panel x="0h" height="3.0h" width="100%" valign="center" y="0" noclick="true">
									<panel width="100%" align="center" noclick="true">
										<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.4h" color="0 0 0 0.6" blockinput="false" noclick="true"/>
										<frame texture="/ui/frames/roundframe.tga" color="#30405d" borderthickness="0.6h" blockinput="false" noclick="true"/>

										<textbox
											name="options_search_input"
											hmargin="1.0h" vmargin="0.4h"
											maxlength="45"
											textalign="center" textvalign="center"
											font="dyn_14"
											textcolor="white"
											shadow="true"
											color="invisible"
											onload=""
											onshow="SetFocus(false);"
											onenter="
												SetFocus(false);
											"
											onesc="
												EraseInputLine();
												SetFocus(false);
												HideWidget('sp_footer_bot');
											"
											onchangelua="
												HoN_Options.SearchOptionsInput( self:GetValue() )
											"
											onchange="
												if(!StringEmpty(''#this),
													Call('options_search_input_cover', 'SetVisible(0)')
												);"
											onfocus="
												if(!StringEmpty(''#this),
													Call('options_search_input_cover', 'SetVisible(0)')
												);
											"
											onlosefocus="
												if(StringEmpty(''#this),
													Call('options_search_input_cover', 'SetVisible(1)')
												);
											"
											onhide="
												EraseInputLine();
												Call('options_search_input_cover', 'SetVisible(1)');
											"
										/>
										<label name="options_search_input_cover" x="1h" y="0" width="-0.5h" height="-0.4h" valign="center" align="center" textvalign="center" font="dyn_10" color="white" shadow="true" content="options_search_input" noclick="1" />
									</panel>
								</panel>
							</panel>
						</panel>

						<!-- Staff -->
						<panel name="options_main_category10" grow="true" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0">
							<instance name="optionH1" label="Staff" />
							<instance name="options_subcategory_header" cat="10" id="1" label="Staff" />
							<panel height="14.0h" noclick="1">
								<frame color="0 1 0 .1" borderthickness="1" bordercolor=".1 .1 .1 1" noclick="1"/>
							</panel>
						</panel>

						<!-- Lower Gradient Cover - Hides When at bottom -->
						<image name="options_bottom_grad" texture="/ui/fe2/elements/fade_gradient.tga" y="0" color="0 0 0 1" height="6.5h" valign="bottom" vflip="true" noclick="true" visible="1" />
						<!-- Upper Gradient Cover - Hides When at top -->
						<image name="options_top_grad" texture="/ui/fe2/elements/fade_gradient.tga" y="0" color="0 0 0 1" height="6.5h" valign="top" noclick="true" visible="0" />

						<!-- Scroller hovers, like in matchstats rewards -->
						<panel name="options_scrollbox_scroller_down"
							noclick="0" height="2.0h" valign="bottom" visible="0"
							onmouseover="Call('options_scrollbox_scroller_down_arrow', 'SetColor(\'1 1 1 .8\')');"
							onmouseout="Call('options_scrollbox_scroller_down_arrow', 'SetColor(\'1 1 1 .3\')');
										Call('options_scrollbox_scroller_down', 'FadeOut(150)');
										Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
							onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('StartScrollDown')"
							onmouseoutlua="UIManager.GetInterface('main'):HoNOptionsF('StopScroll')"
							onmouseldownlua="UIManager.GetInterface('main'):HoNOptionsF('MultiplyScrollSpeed', 3.0)"
							ondoubleclicklua="UIManager.GetInterface('main'):HoNOptionsF('MultiplyScrollSpeed', 3.0)"
							onmouseluplua="UIManager.GetInterface('main'):HoNOptionsF('MultiplyScrollSpeed', 1.0)"
						>
							<image name="options_scrollbox_scroller_down_arrow" y="0.2h" width="2.2h" height="2.2h" align="center" valign="bottom" texture="/ui/elements/expand_btn.tga" color="1 1 1 .3" noclick="true" />
						</panel>

						<panel name="options_scrollbox_scroller_up"
							noclick="0" height="2.0h" valign="top" visible="0" rotation="180"
							onmouseover="Call('options_scrollbox_scroller_up_arrow', 'SetColor(\'1 1 1 .8\')');"
							onmouseout="Call('options_scrollbox_scroller_up_arrow', 'SetColor(\'1 1 1 .3\')');
										Call('options_scrollbox_scroller_down', 'FadeOut(150)');
										Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
							onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('StartScrollUp')"
							onmouseoutlua="UIManager.GetInterface('main'):HoNOptionsF('StopScroll')"
							onmouseldownlua="UIManager.GetInterface('main'):HoNOptionsF('MultiplyScrollSpeed', 3.0)"
							ondoubleclicklua="UIManager.GetInterface('main'):HoNOptionsF('MultiplyScrollSpeed', 3.0)"
							onmouseluplua="UIManager.GetInterface('main'):HoNOptionsF('MultiplyScrollSpeed', 1.0)"
						>
							<image name="options_scrollbox_scroller_up_arrow" y="-0.2h" width="2.2h" height="2.2h" align="center" valign="top" texture="/ui/elements/collapse_btn.tga" color="1 1 1 .3" noclick="true" />
						</panel>

						<panel name="options_wheel_cover" processonlyscroll="1" hover="0" color="invisible"
							onmousewheeluplua="UIManager.GetInterface('main'):HoNOptionsF('ScrollMain', 1)"
							onmousewheeldownlua="UIManager.GetInterface('main'):HoNOptionsF('ScrollMain', 0)"
						/>

						<!-- exit button -->
						<instance
							name="closex_btn"
							x="-0.5h" y="0.5h"
							width="2.1h" height="2.1h"
							align="right"
							onclick="Set('_mainmenu_currentpanel', 'game_options'); CallEvent('MainMenuPanelSwitcher');"
						/>
					</panel>

					<panel y="-0.8h" width="-3.0h" height="3.2h" align="center" valign="bottom" noclick="1">
						<panel grow="true" height="100%" align="right" float="right" padding="1.5h">
							<instance name="button2" button_name="unnamedButton149" height="2.6h" width="9h" valign="bottom" font="dyn_11" label="general_cancel"  borderthickness=".8h" onclick="OptionsCancel(); temp_gfxslider_int = ui_options_gfxslider;" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');" />
							<instance name="button2" button_name="unnamedButton150" height="2.6h" width="10h" valign="bottom" font="dyn_11" label="options_button_apply"  borderthickness=".8h" onclick="OptionsApply(); ui_options_gfxslider = temp_gfxslider_int; Call('option_gfx_slider_apply', 'SetEnabled(false);'); Call('options_graphics_apply_glow', 'SetVisible(0);');" onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
							onclicklua="
								if (GetCvarBool('host_cloudAutoUpload')) then
									Client.PostCloudConfig()
								end"
							/>
						</panel>
						<frame height="1" color="#0f1b24" valign="top" noclick="1"/>

						<!-- Search button -->
						<panel valign="bottom" width="2.1h" height="2.1h" x="0.5h" y="-0.3h"
							onclicklua="UIManager.GetInterface('main'):HoNOptionsF('SearchButton')"
							ontrigger="SetX(0); SetY(0);"
							onmouseover="
								Trigger('genericMainFloatingTip', true, '30h', '', 'general_search', 'options_search_tip', '', '', '3h', '-2h');
								GroupCall('option_search_button_jiggle', 'SetWatch(1, \'HostTime\')');
								Scale('2.6h', '2.6h', 250);
							"
							onmouseout="
								HideWidget('genericMainFloatingTip');
								GroupCall('option_search_button_jiggle', 'SetWatch(\'\'); SetWatch(1, \'\'); SetX(0); SetY(0); SetRotation(0);');
								Scale('2.1h', '2.1h', 250);
							"
							onhide="
								GroupCall('option_search_button_jiggle', 'SetWatch(\'\'); SetWatch(1, \'\'); SetX(0); SetY(0); SetRotation(0);');
								SetWidth('2.1h'); SetHeight('2.1h');
							"
						>
							<image noclick="1" texture="/ui/common/new_shop_interface/magnify.tga"
								watch="" ontrigger="SetRotation(Sin(((param % 300) / 300) * (3.14159265 * 2)) * 8);" group="option_search_button_jiggle"
								watch1="" ontrigger1="SetRotation(Sin(((param % 300) / 300) * (3.14159265 * 2)) * 4);"
							/>
						</panel>
					</panel>
				</panel>

				<!-- Menu -->
				<panel width="20.0h" noclick="1">
					<frame texture="/ui/frames/tabbox.tga" borderthickness="33%" noclick="true">

						<panel x="1.0h" width="1.9h" height="100%" align="right" color="#183042" noclick="1">
							<image visible="true" y="5.1h" x="2.8h" align="right" width="2.8h" height="5.6h" texture="/ui/frames/tabbox_arrow.tga" noclick="true" />
						</panel>

						<panel x="0.6h" height="-1.6h" valign="center" noclick="true">
							<panel height="4.2h" noclick="true" float="right">
								<image width="100@" height="100%" texture="/ui/elements/cc_config_gear.tga" />
								<label height="100%" textvalign="center" font="dyn_16" color="#ffaa00" outline="true" content="general_options" />
							</panel>
							<panel y="4.5h" x="0.5h" width="100%" height="-4.5h" float="bottom" padding="0.2h" noclick="1">

								<!-- Display -->
								<instance name="options_menu_cat" id="1" icon="display.tga" label="options_label_display" current="false" />
								<panel name="options_submenu1" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="1" id="1" label="options_button_graphics" />
										<instance name="options_sub_menu" cat="1" id="2" label="options_submen_video" />
										<instance name="options_sub_menu" cat="1" id="3" label="mainlobby_label_more" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Sound -->
								<instance name="options_menu_cat" id="2" icon="sound.tga" label="options_button_sound" current="false" />
								<panel name="options_submenu2" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="2" id="1" label="options_submen_vol" />
										<instance name="options_sub_menu" cat="2" id="2" label="options_button_sound" />
										<instance name="options_sub_menu" cat="2" id="3" label="options_button_voice" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Troubleshooting -->
								<instance name="options_menu_cat" id="3" icon="troubleshooting.tga" label="options_troubleshooting" current="false" />
								<panel name="options_submenu3" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="3" id="1" label="general_repair_install" />
										<instance name="options_sub_menu" cat="3" id="2" label="options_submen_faq" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Interface -->
								<instance name="options_menu_cat" id="4" icon="interface.tga" label="options_button_interface" current="false" />
								<panel name="options_submenu4" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="4" id="1" label="options_submen_gameoverlays" />
										<instance name="options_sub_menu" cat="4" id="2" label="options_submen_gameplay" />
										<instance name="options_sub_menu" cat="4" id="3" label="options_submen_chat" />
										<instance name="options_sub_menu" cat="4" id="4" label="options_submen_friendsclans" />
										<instance name="options_sub_menu" cat="4" id="5" label="options_submen_notifications" />
										<instance name="options_sub_menu" cat="4" id="6" label="options_submen_assistance" />
										<instance name="options_sub_menu" cat="4" id="7" label="options_submen_nameplates" />
										<instance name="options_sub_menu" cat="4" id="8" label="options_submen_buffs" />
										<instance name="options_sub_menu" cat="4" id="9" label="tpp_misc" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Controls -->
								<instance name="options_menu_cat" id="5" icon="controls.tga" label="options_button_controls" current="false" />
								<panel name="options_submenu5" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="5" id="1" label="options_submen_primary_keys" />
 										<instance name="options_sub_menu" cat="5" id="2" label="options_submen_cam" />
										<instance name="options_sub_menu" cat="5" id="3" label="options_submen_keybindings" />
										<instance name="options_sub_menu" cat="5" id="4" label="options_submen_keybindings_adv" />
										<if condition="StringEquals(host_os,'windows') and IsWindowsGreaterThanXP() and StringEquals(host_vidDriver,'vid_d3d9')">
											<instance name="options_sub_menu" cat="5" id="5" label="facebook_stream"
												onloadlua="self:SetVisible(GetCvarBool('cg_EnableFbStream'))"
												watch="DynamicCommandsExecuted"
												ontriggerlua="self:SetVisible(GetCvarBool('cg_EnableFbStream'))"
											/>
										</if>
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Mods -->
								<instance name="options_menu_cat" id="6" icon="mods.tga" label="options_button_mods" current="false" />
								<panel name="options_submenu6" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="6" id="1" label="options_submen_modopts" />
										<panel height="0.5h" noclick="1"/>
