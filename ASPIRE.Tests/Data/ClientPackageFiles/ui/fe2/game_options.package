					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".9 .7 .7 1" shadow="true" content="{sub_text3}" noclick="true" />
				</panel>

				<panel height="0.5h" noclick="true" sticky="true" stickytoinvis="false" />
			</panel>
		</panel>
	</template>

	<template name="option_dropdown_v3">
		<panel
			grow="true"
			width="{width=100%}"
			noclick="1"
			oninstantiate="{oninstantiate}" group="{group=options_options}"
			oninstantiatelua="{oninstantiatelua}"
			onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_dropdown_v3', '{category}', '{subcategory}', '{cvar}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}') end"
			onrefreshlua="{onrefreshlua}"
		>
			<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />
			<panel grow="true" growinvis="false" width="-1.6h" y="0.7h" align="center" float="bottom" padding="0.4h" noclick="true" reverse="true">

				<panel height="1.8h" noclick="true" sticky="true" stickytoinvis="false">
					<label width="-2.5h" height="100%" textvalign="center" font="dyn_14" color="#ffaa00" shadow="true" content="{title}" noclick="true" />
					<instance name="tip_mark" tip_id="{tip_id}" width="2.2h" height="2.2h" valign="center" align="right" visible="0"
						oninstantiatelua="self:SetVisible(NotEmpty('{tip_text1=}'))"
						onmouseover="Trigger('genericMainFloatingTip', true, '30h', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '3h', '-2h')"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');
									HideWidget('genericMainFloatingTip');"
					/>
				</panel>
				<panel height="0.7h" noclick="true" />

				<panel height="2.4h" noclick="true">
					<combobox
						name="otpwdg_{cvar}{nameid}"
						align="right"
						valign="center"
						color="invisible"
						itemwidth="100%"
						enabled="{enabled=true}"
						itemheight="2h"
						maxlistheight="{maxlistheight}"
						cvar="{cvar=}"
						exteriorscrollbars="false"
						scrolltexture="/ui/info/combobox.tga"
						handleheight="100@" handlewidth="100%"
						scrollbarsize="2h"
						scrollbaroffset="0"
						highlight="under"
						highlightcolor="invisible"
						highlightbordercolor="invisible"
						oninstantiate="game_options_ignore_change = true; ComboBoxCmd('clear'); CreateString('otpwdg_{cvar}{nameid}_sval', {cvar}); {populate=}; {data=}('{itemtemplate=Ncombobox_item}','{font=dyn_9}'); {onload=}
						game_options_ignore_change = false;"
						onload="ComboBoxCmd('clear'); CreateString('otpwdg_{cvar}{nameid}_sval', {cvar}); {populate=}; {data=}('{itemtemplate=Ncombobox_item}','{font=dyn_9}'); {onload=}"
						onselect="If(IsVisible(), PlaySound('/shared/sounds/ui/button_click_05.wav')); If(!StringEquals(otpwdg_{cvar}{nameid}_sval, {cvar}), DoEvent()); otpwdg_{cvar}{nameid}_sval = {cvar}; game_options_ignore_change = true; {onselect=}; game_options_ignore_change = false;"
						onevent="if(!game_options_ignore_change, host_pendingOptionsChanges = true); {onchange=}"
						oneventlua="{onchangelua=}"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
						watch="{onwatchrefilltrigger}"
						ontrigger="game_options_ignore_change = true; ComboBoxCmd('clear'); {onrefilltrigger} game_options_ignore_change = false;"
						watch2="{watch2}" ontrigger2="{ontrigger2}"
					>
						<instance name="Moptions_combobox_state" state="up" color="1 1 1 1" image="up"/>
						<instance name="Moptions_combobox_state" state="over" color="#69ccff" image="over"/>
						<instance name="Moptions_combobox_state" state="down" color="#69ccff" image="over"/>
						<instance name="Moptions_combobox_state" state="disabled" color="1 1 1 1" image="up" rendermode="grayscale" />
						<widgetstate statename="listbg">
							<frame height="+2.7h" y="-1.9h" texture="/ui/info/combobox_dropdown.tga" borderthickness="3h" color="white" />
						</widgetstate>
						<widgetstate statename="itembg">
							<panel width="{itemwidth}" />
						</widgetstate>
						<widgetstate statename="itemhighlight">
							<panel width="{itemwidth=100%}" texture="/ui/info/header_bar_c.tga">
								<panel width="100%" height="100%" >
									<image height="50%" width="32" align="left" valign="top" texture="/ui/info/header_bar_tl.tga" noclick="1"/>
									<image height="50%" width="32" align="left" valign="bottom" texture="/ui/info/header_bar_bl.tga" noclick="1"/>
									<image height="50%" width="32" align="right" valign="top" texture="/ui/info/header_bar_tr.tga" noclick="1"/>
									<image height="50%" width="32" align="right" valign="bottom" texture="/ui/info/header_bar_br.tga" noclick="1"/>
								</panel>
							</panel>
						</widgetstate>
					</combobox>
				</panel>
				<panel height="0" noclick="true" />

				<!-- Txt 1 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text1=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".75 .85 .75 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".75 .85 .75 1" shadow="true" content="{sub_text1}" noclick="true" />
				</panel>
				<!-- Txt 2 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text2=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".8 .8 .8 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".8 .8 .8 1" shadow="true" content="{sub_text2}" noclick="true" />
				</panel>
				<!-- Txt 3 -->
				<panel grow="true" width="100%" noclick="true" sticky="true" stickytoinvis="false" visible="0"
					oninstantiatelua="self:SetVisible(NotEmpty('{sub_text3=}'))"
				>
					<image y="0.3h" width="1.0h" height="1.0h" texture="/ui/fe2/elements/web_forward.tga" color=".9 .7 .7 1" noclick="true" />
					<label fity="true" width="-1.4h" align="right" wrap="true" textvalign="top" font="dyn_10" color=".9 .7 .7 1" shadow="true" content="{sub_text3}" noclick="true" />
				</panel>
				<panel height="0.9h" noclick="true" sticky="true" stickytoinvis="false" />
			</panel>
		</panel>
	</template>

	<template name="options_faq_entry">
		<panel grow="true" regrow="true" growinvis="false" width="100%" float="bottom" padding="0.6h"
		onclicklua="UIManager.GetInterface('main'):HoNOptionsF('ExpandCollapseFAQ', {id})"
		onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
		onmouseover="Call('faq_q{id}_question', 'SetColor(\'#9ED6E8\');');"
		onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
					Call('options_scrollbox_scroller_up', 'FadeOut(150)');
					Call('faq_q{id}_question', 'SetColor(\'#37b2d9\');');"
		>
			<label name="faq_q{id}_question" fity="true" wrap="true" font="dyn_14" color="#37b2d9" content="{question}" noclick="true" />
			<panel name="faq_q{id}" grow="true" regrow="1" growinvis="0" width="100%" noclick="true" float="bottom" padding="0.5h" visible="false">
				<panel grow="true" regrow="1" growinvis="0" visible="0" width="100%" noclick="true" oninstantiatelua="self:SetVisible(NotEmpty('{answer=}'))">
					<image y="0.3h" width="1.4h" height="1.4h" texture="/ui/fe2/elements/web_forward.tga" noclick="true" />
					<label fity="true" wrap="true" width="-2.0h" align="right" font="dyn_12" color=".8 .8 .8 1" content="{answer}" noclick="true"
						onshow="SetText(Translate('{answer}', 'value', Evaluate('{passvalue1}')));"
					/>
				</panel>
				<panel grow="true" regrow="1" growinvis="0" visible="0" width="100%" noclick="true" oninstantiatelua="self:SetVisible(NotEmpty('{answer2=}'))">
					<image y="0.3h" width="1.4h" height="1.4h" texture="/ui/fe2/elements/web_forward.tga" noclick="true" />
					<label fity="true" wrap="true" width="-2.0h" align="right" font="dyn_12" color=".8 .8 .8 1" content="{answer2}" noclick="true"
						onshow="SetText(Translate('{answer2}', 'value', Evaluate('{passvalue2}')));"
					/>
				</panel>
				<panel grow="true" regrow="1" growinvis="0" visible="0" width="100%" noclick="true" oninstantiatelua="self:SetVisible(NotEmpty('{answer3=}'))">
					<image y="0.3h" width="1.4h" height="1.4h" texture="/ui/fe2/elements/web_forward.tga" noclick="true" />
					<label fity="true" wrap="true" width="-2.0h" align="right" font="dyn_12" color=".8 .8 .8 1" content="{answer3}" noclick="true"
						onshow="SetText(Translate('{answer3}', 'value', Evaluate('{passvalue3}')));"
					/>
				</panel>
				<panel grow="true" regrow="1" growinvis="0" visible="0" width="100%" noclick="true" oninstantiatelua="self:SetVisible(NotEmpty('{answer4=}'))">
					<image y="0.3h" width="1.4h" height="1.4h" texture="/ui/fe2/elements/web_forward.tga" noclick="true" />
					<label fity="true" wrap="true" width="-2.0h" align="right" font="dyn_12" color=".8 .8 .8 1" content="{answer4}" noclick="true"
						onshow="SetText(Translate('{answer4}', 'value', Evaluate('{passvalue4}')));"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- vid driver & resolution confirm dialog for restart -->
	<template name="restart_confirm">
		<panel name="restart_confirm" watch="OptionsChangedNeedsRestart" ontrigger="SetVisible(true)" visible="{visible=0}" color="0 0 0 .7" onshow="BringToFront();" >
			<panel height="53h">
				<instance
						name="alert_box_growable"
						width="30.0h"
						align="center"
						label="options_label_vid"
						show_close="true"
						closebtn_click="Call('restart_confirm', 'FadeOut(250);')"
						body="restart_confirm_body"
						interactive="{interactive}"
				/>
			</panel>
		</panel>
	</template>

	<template name="restart_confirm_body">
		<panel width="100%" grow="true" align="center" float="bottom" padding="1.0h" noclick="true">
			<panel y="1.0h" grow="true" width="100%">
				<label fity="true" width="-1.0h" align="center" textalign="center" textvalign="top" font="dyn_11" color="white" shadow="true" wrap="true" content="main_vid_confirm_info"/>
			</panel>

			<panel height="2.4h" noclick="true" sticky="true" stickytoinvis="false">
				<instance
						name="button2" button_name="unnamedbutton267"
						x="-7.0h"
						width="12.0h" height="2.4h"
						align="center"
						valign="center"
						label="button_restart_later"
						onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
						onclick="Call('restart_confirm', 'FadeOut(250)')"
						interactive="{interactive}"
				/>
				<instance
						name="button2" button_name="unnamedbutton268"
						x="7.0h"
						width="12.0h" height="2.4h"
						align="center"
						valign="center"
						label="button_restart_now"
						onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
						onclick="Restart();"
						interactive="{interactive}"
				/>
			</panel>
			<panel height="0.5h" noclick="true"/>
		</panel>
	</template>

	<instance name="restart_confirm" interactive="true" visible="0" />

	<!-- Binders -->
	<!-- old stuff kept incase things elsewhere use it -->
	<template name="options_button_binder">
		<panel name="keybind_button_binder" visible="0">
			<buttoncatcher
				name="keybind_button_catcher"
				align="center" valign="top"
				height="101%"
				color="#000000c0"
				onbutton="
					HideWidget('keybind_button_binder');
					if(!StringEquals(_keybind_old_button, 'None'), Cmd('Unbind ' # _keybind_table # ' ' # _keybind_old_button));
					Cmd('BindButton ' # _keybind_table # ' ' # param # ' ' # _keybind_action # ' &quot;' # _keybind_param # '&quot; ' # _keybind_cloudsave);
					host_pendingOptionsChanges = true;
					host_pendingGameBindChanges = true;
					PlaySound('/shared/sounds/ui/tutorial/popup_show_1.mp3');
					Refresh();"
			/>

			<panel visible="1" blockinput="true" noclick="1">
				<instance
					name="alert_box"
					width="35.0h"
					height="11.0h"
					align="center"
					label="options_bind_header"
					show_close="0"
					body="button_instructions"
				/>
			</panel>

		</panel>
	</template>

