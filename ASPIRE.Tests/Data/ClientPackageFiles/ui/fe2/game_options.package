										<instance name="options_sub_menu" cat="7" id="1" label="options_submen_myrefs" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Cloud Saves -->
								<instance name="options_menu_cat" id="8" icon="cloudsaves.tga" label="options_cloud_opts" current="false" />
								<panel name="options_submenu8" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="8" id="1" label="options_submen_cloud_config" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Search -->
								<instance name="options_menu_cat" id="9" icon="search.tga" label="general_search" current="false" />
								<panel name="options_submenu9" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="9" id="1" label="general_search" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>

								<!-- Staff Commented out for now
								<instance name="options_menu_cat" id="10" icon="mods.tga" label="Staff" current="false" visible="0"
									watch="LoginStatus" ontrigger="SetVisible(IsStaff());"
									ontriggerlua="UIManager.GetInterface('main'):HoNOptionsF('CatTableUpdate', param2)"
									onshowlua="UIManager.GetInterface('main'):HoNOptionsF('SetStaffOffset', 10)"
								/>
								<panel name="options_submenu10" height="0" group="options_submenus" width="100%" noclick="true" visible="false" sticky="true" stickytoinvis="false">
									<panel width="-3.6h" align="right" padding="0.4h" noclick="true">
										<instance name="options_sub_menu" cat="10" id="1" label="Staff Options" />
										<panel height="0.5h" noclick="1"/>
									</panel>
								</panel>
								-->
							</panel>
						</panel>
					</frame>
					<!-- cover over the whole category side to catch scrolling -->
					<panel name="options_category_scroller" noclick="0" processonlyscroll="1" hover="0"
						onmousewheeluplua="UIManager.GetInterface('main'):HoNOptionsF('ScrollSub', 1)"
						onmousewheeldownlua="UIManager.GetInterface('main'):HoNOptionsF('ScrollSub', 0)"
					/>
				</panel>
			</panel>

			<instance name="options_v3_button_binder" />
