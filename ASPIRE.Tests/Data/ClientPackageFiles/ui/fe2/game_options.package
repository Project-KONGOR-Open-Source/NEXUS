	<template name="options_v3_button_instructions">
		<label y="0.0h" width="-1.0h" height="3.0h" textvalign="center" textalign="center" font="dyn_10" color="white" shadow="1" wrap="true" noclick="true">options_bind_instructions_button</label>
		<instance
			name="button2" button_name="unnamedButton144{index}"
			y="3.4h"
			x="1.0h"
			height="2.4h"
			width="10.0h"
			align="left"
			label="options_bind_button_default"
			onclick="
				HideWidget('options_v3_button_binder');
				HideWidget('options_v3_button_binder_impulse');
				HideWidget('options_v3_button_binder_nomod');
				HideWidget('options_v3_button_binder_impulse_nomod');
				Cmd('Unbind ' # _keybind_table # ' ' # _keybind_old_button);
				Cmd('DefaultGameBind ' # ' ' # _keybind_num # ' ' # _keybind_table # ' ' # _keybind_action # ' ' # _keybind_param);
				host_pendingOptionsChanges = true;
				host_pendingGameBindChanges = true;
				PlaySound('/shared/sounds/ui/tutorial/popup_show_1.mp3');
				Refresh();"
		/>

		<instance
			name="button2" button_name="unnamedButton145{index}"
			y="3.4h"
			height="2.4h"
			width="10.0h"
			align="center"
			label="options_bind_button_clear"
			onclick="
				HideWidget('options_v3_button_binder');
				HideWidget('options_v3_button_binder_impulse');
				HideWidget('options_v3_button_binder_nomod');
				HideWidget('options_v3_button_binder_impulse_nomod');
				Cmd('Unbind ' # _keybind_table # ' ' # _keybind_old_button);
				Cmd('BindButton ' # ' ' # _keybind_table # ' INVALID ' # _keybind_action # ' ' # _keybind_param # ' ' # _keybind_cloudsave);
				host_pendingOptionsChanges = true;
				host_pendingGameBindChanges = true;
				PlaySound('/shared/sounds/ui/tutorial/popup_show_1.mp3');
				Refresh();"
		/>

		<instance
			name="button2" button_name="unnamedButton146{index}"
			y="3.4h"
			x="-1.0h"
			height="2.4h"
			width="10.0h"
			align="right"
			label="general_cancel"
			onclick="HideWidget('options_v3_button_binder'); HideWidget('options_v3_button_binder_impulse'); HideWidget('options_v3_button_binder_nomod'); HideWidget('options_v3_button_binder_impulse_nomod');"
		/>
	</template>

	<template name="options_v3_keybind_button">
		<button x="{x=0}" y="-0.1h" width="10.0h" height="1.8h" valign="center" align="right" color="invisible"
			onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
			onclick="
				PlaySound('/shared/sounds/ui/button_click_01.wav');
				_keybind_command = '{command}';
				_keybind_table = '{table}';
				_keybind_action = '{action}';
				_keybind_param = '{param}';
				_keybind_num = '{num}';
				_keybind_old_button = GetKeybindButton('{table}', '{action}', '{param}', {num});
				_keybind_impulse = {impulse=false};
				_keybind_cloudsave = {cloudsave=true};
				If({impulse=false},
					If({usemodifiers=true},
						showWidget('options_v3_button_binder_impulse'),
						showWidget('options_v3_button_binder_impulse_nomod')
					),
					If({usemodifiers=true},
						showWidget('options_v3_button_binder'),
						showWidget('options_v3_button_binder_nomod')
					)
				);
				"
			onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
			onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
						Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
		>
			<instance name="keybind_button_state" state="up" frame="false" color="white" shadowcolor="black" table="{table}" action="{action}" param="{param}" num="{num}"/>
			<instance name="keybind_button_state" state="over" table="{table}" action="{action}" param="{param}" num="{num}"/>
			<instance name="keybind_button_state" state="down" x="1" y="1" table="{table}" action="{action}" param="{param}" num="{num}"/>
		</button>
	</template>

	<template name="option_primary_keybind_v3">
		<panel height="15h" width="15h" x="{x}" noclick="1"
			oninstantiate="SetCloudSave('{cvar}', true);">
			<label textalign="center" y="1.5h" font="dyn_14" color="#ffffff" shadow="1" content="{title}" noclick="1"/>
			<panel align="center" valign="center" width="12h" height="12h" noclick="1">
				<image texture="/ui/info/keyboard.tga" noclick="1" />
				<label name="options_checkbox_label_{cvar}" textalign="center" textvalign="center" color="#4b6d79" shadow="true" noclick="1" onloadlua="HoN_Options.SetPrimaryKeybindLabelName(self ,'{table}', '{action}', '{param}', {num=0})" onrefreshlua="HoN_Options.SetPrimaryKeybindLabelName(self ,'{table}', '{action}', '{param}', {num=0})"/>
				<instance name="option_primary_keybind_button_v3" num="0" command="{command}" table="{table}" action="{action}" param="{param=}" impulse="{impulse=false}" usemodifiers="{usemodifiers=true}" labelname="{cvar}" cloudsave="{cloudsave=true}"/>
			</panel>
			<panel width="2h" height="2h" y="12h" align="center" noclick="1" ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav');">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1"/>
				<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
				<panel name="options_checkbox_check_pk_{cvar}" valign="bottom" align="center" width="125@" height="125%" nolclick="true" visible="false" noclick="1">
					<image x="1" y="1" texture="/ui/elements/check_mark_white.tga" color="0 0 0 1" noclick="1"/>
					<image texture="/ui/elements/check_mark_white.tga" color="#40cd3c" noclick="1"/>
				</panel>
				<button cvar="{cvar}" visible="1" noclick="0" color="invisible" numstates="2" onclick="PlaySound('/shared/sounds/ui/button_click_06.wav');" ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav');"
					onbutton="Call('options_checkbox_check_pk_{cvar}', 'SetVisible({cvar})');"
				/>
			</panel>
		</panel>
	</template>
	
	<template name="option_primary_keybind_v4">
		<panel height="15h" width="15h" x="{x}" noclick="1"
			oninstantiate="SetCloudSave('{cvar}', true);">
			<label textalign="center" y="1.5h" font="dyn_11" color="#ffffff" shadow="1" content="{title}" noclick="1"/>
			<panel align="center" valign="center" width="12h" height="12h" noclick="1">
				<image texture="/ui/info/keyboard.tga" noclick="1" />
				<label name="options_checkbox_label_{cvar}" textalign="center" textvalign="center" color="#4b6d79" shadow="true" noclick="1" onloadlua="HoN_Options.SetPrimaryKeybindLabelName(self ,'{table}', '{action}', '{param}', {num=0})" onrefreshlua="HoN_Options.SetPrimaryKeybindLabelName(self ,'{table}', '{action}', '{param}', {num=0})"/>
				<instance name="option_primary_keybind_button_v3" num="0" command="{command}" table="{table}" action="{action}" param="{param=}" impulse="{impulse=false}" usemodifiers="{usemodifiers=true}" labelname="{cvar}" cloudsave="{cloudsave=true}"/>
			</panel>
			<panel width="2h" height="2h" y="12h" align="center" noclick="1" ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav');">
				<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1"/>
				<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
				<panel name="options_checkbox_check_pk_{cvar}" valign="bottom" align="center" width="125@" height="125%" nolclick="true" visible="false" noclick="1">
					<image x="1" y="1" texture="/ui/elements/check_mark_white.tga" color="0 0 0 1" noclick="1"/>
					<image texture="/ui/elements/check_mark_white.tga" color="#40cd3c" noclick="1"/>
				</panel>
				<button cvar="{cvar}" visible="1" noclick="0" color="invisible" numstates="2" onclick="PlaySound('/shared/sounds/ui/button_click_06.wav');" ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav');"
					onbutton="Call('options_checkbox_check_pk_{cvar}', 'SetVisible({cvar})');"
				/>
			</panel>
		</panel>
	</template>

	<template name="option_primary_keybind_button_v3">
		<button width="6h" height="6h" valign="center"  noclick="0" align="center" color="invisible" visible="1"
				onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
				onclick="
				PlaySound('/shared/sounds/ui/button_click_01.wav');
				_keybind_command = '{command}';
				_keybind_table = '{table}';
				_keybind_action = '{action}';
				_keybind_param = '{param}';
				_keybind_num = '{num}';
				_keybind_old_button = GetKeybindButton('{table}', '{action}', '{param}', {num});
				_keybind_impulse = {impulse=false};
				_keybind_cloudsave = {cloudsave=true};
				If({impulse=false},
					If({usemodifiers=true},
						showWidget('options_v3_button_binder_impulse'),
						showWidget('options_v3_button_binder_impulse_nomod')
					),
					If({usemodifiers=true},
						showWidget('options_v3_button_binder'),
						showWidget('options_v3_button_binder_nomod')
					)
				);
				"
				onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
				onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
						Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
		>
		</button>
	</template>

	<template name="option_keybind_v3">
		<panel
			grow="true"
			width="{width=100%}"
			noclick="1"
			oninstantiate="{oninstantiate}" group="{group=options_options}"
			oninstantiatelua="
				if {setcloudsave=false} then
					SetBindCloudSave('{table}', '{action}', '{param}', true)
				end
				{oninstantiatelua}
			"
			onrefreshlua="{onrefreshlua}"
			onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_keybind_v3', '{category}', '{subcategory}', '{table}'..'{action}'..'{param}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}') end"
		>
			<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1">
				<panel height="2.4h" width="-1.8h" align="center" valign="center" float="right" padding="0" noclick="true">
					<label width="-24h" textvalign="center" font="{title_font=dyn_12}" color="1 1 1 1" shadow="true" content="{title}" noclick="true"/>
					<panel width="21h" noclick="true">
						<panel height="2.4h" width="100%" align="left" color="invisible">
							<frame texture="/ui/info/backdrop.tga" borderthickness="1.0h" color="1 1 1 .5" noclick="1" />
							<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
							<instance name="options_v3_keybind_button" x="-10.5h" num="0" command="{command}" table="{table}" action="{action}" param="{param=}" impulse="{impulse=false}" usemodifiers="{usemodifiers=true}" cloudsave="{cloudsave=true}"/>
							<instance name="options_v3_keybind_button" x="-0.4h" num="1" command="{command}" table="{table}" action="{action}" param="{param=}" impulse="{impulse=false}" usemodifiers="{usemodifiers=true}" cloudsave="{cloudsave=true}"/>
						</panel>
					</panel>
					<panel width="0.8h"/> <!-- padding -->
					<instance name="tip_mark" tip_id="{tip_id}" width="2.2h" height="2.2h" valign="center" align="right" visible="0"
						oninstantiatelua="self:SetVisible(NotEmpty('{tip_text1=}'))"
						onmouseover="Trigger('genericMainFloatingTip', true, '30h', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '3h', '-2h')"
						onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
						onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
									Call('options_scrollbox_scroller_up', 'FadeOut(150)');
									HideWidget('genericMainFloatingTip');"
					/>
				</panel>
			</frame>
		</panel>
	</template>

	<template name="option_keybind_checkbox_v3" >
		<panel name="{cvar}{nameid}_kcpanel"
			   grow="true"
			   width="{width=100%}"
			   noclick="1"
			   oninstantiatelua="{oninstantiatelua}"
			   onrefreshlua="{onrefreshlua}"
			   onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
			   onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
						Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
			   group="{group=options_options}"
			   onevent8lua="if ({register=true}) then HoN_Options.RegisterOption('option_keybind_checkbox_v3', '{category}', '{subcategory}', '{cvar}', '{title}', '{sub_text1}', '{sub_text2}', '{sub_text3}', '{tip_image}', '{tip_name}', '{tip_text1}', '{tip_text2}', '{tip_text3}', '{gradmark1_pos}', '{gradmark2_pos}', '{gradmark3_pos}', '{gradmark4_pos}', '{gradmark5_pos}', '{gradmark1_name}', '{gradmark2_name}', '{gradmark3_name}', '{gradmark4_name}', '{gradmark5_name}', '{slidefunction}', '{maxvalue=1}', '{data}', [=[{onchange}]=], [=[{onchangelua}]=], [=[{onselect}]=], [=[{populate}]=], '{maxlistheight}', '{pair=false}', '{inverted=false}', '{enforce}', '{enforce2}', '{enforce3}', '{enforce4}', '{precision=0}', '{numerictype=int}', '{percent=true}', '{round_var=true}', '{title_font=dyn_12}', [=[{command}]=], '{table}', '{action}', '{param=}', '{impulse=false}', [=[{onclick}]=], '{usemodifiers=true}') end"
				oninstantiate="SetCloudSave('{cvar}', true);"
		>
			<frame name="options_keybind_checkbox_frame_{cvar}{nameid}" height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1" />
			<panel height="2.4h" width="-1.8h" align="center" valign="center" float="right" padding="0" noclick="1">
				<label width="-24h" textvalign="center" font="{title_font=dyn_12}" color="1 1 1 1" shadow="true" content="{title}" noclick="1"/>
				<panel width="21h" noclick="1">
					<panel height="2.4h" width="100%" align="left" color="invisible">
						<frame name="options_keybind_checkbox_text_frame_{cvar}{nameid}"  texture="/ui/info/backdrop.tga" borderthickness="1.0h" color="1 1 1 .5" noclick="1" />
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
						<panel width="50%" align="left">
							<panel width="1.5h" height="1.5h" noclick="1" align="center" valign="center">
								<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="white" noclick="1"/>
								<frame texture="/ui/frames/roundframe.tga" color="#3abde7" borderthickness="0.5h" noclick="1"/>
								<panel name="options_checkbox_check_kc_{cvar}{nameid}" valign="bottom" align="center" width="125@" height="125%" nolclick="true" visible="false" noclick="1">
									<image x="1" y="1" texture="/ui/elements/check_mark_white.tga" color="0 0 0 1" noclick="1"/>
									<image texture="/ui/elements/check_mark_white.tga" color="#40cd3c" noclick="1"/>
								</panel>
							</panel>
						</panel>
						<panel width="50%" align="right">
							<label textalign="center" textvalign="center" font="dyn_9" color="#37b2d9" shadow="true" content="{sub_text1}" noclick="1"/>
						</panel>
					</panel>
				</panel>
			</panel>
			<button cvar="{cvar}" visible="1" noclick="0" color="invisible" numstates="2" onclick="PlaySound('/shared/sounds/ui/button_click_06.wav');" ondoubleclick="PlaySound('/shared/sounds/ui/button_click_06.wav');"
					onbutton="If(!StringEmpty('{cvar=}'),
		 				Split(
		 					Split(
		 						If(WidgetExists('options_keybind_checkbox_frame_{cvar}{nameid}'),
		 							If(!{inverted=false},
		 								If({cvar},
		 									Call('options_keybind_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'normal\')'),
		 									Call('options_keybind_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'grayscale\')')
		 								),
										If(!{cvar},
		 									Call('options_keybind_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'normal\')'),
		 									Call('options_keybind_checkbox_frame_{cvar}{nameid}', 'SetRenderMode(\'grayscale\')')
		 								)
		 							)
		 						),
		 						If(WidgetExists('options_checkbox_check_kc_{cvar}{nameid}'),
		 							If(!{inverted=false},
		 								Call('options_checkbox_check_kc_{cvar}{nameid}', 'SetVisible({cvar})'),
		 								Call('options_checkbox_check_kc_{cvar}{nameid}', 'SetVisible(!{cvar})')
		 							)
		 						)
		 					),
		 					If(WidgetExists('options_keybind_checkbox_text_frame_{cvar}{nameid}'),
		 						If(!{inverted=false},
		 							If({cvar},
		 								Call('options_keybind_checkbox_text_frame_{cvar}{nameid}', 'SetRenderMode(\'normal\')'),
		 								Call('options_keybind_checkbox_text_frame_{cvar}{nameid}', 'SetRenderMode(\'grayscale\')')
		 							),
									If(!{cvar},
		 								Call('options_keybind_checkbox_text_frame_{cvar}{nameid}', 'SetRenderMode(\'normal\')'),
		 								Call('options_keybind_checkbox_text_frame_{cvar}{nameid}', 'SetRenderMode(\'grayscale\')')
		 							)
		 						)
		 					),
		 					host_pendingOptionsChanges = true
		 				)
		 			 );"/>
		</panel>
	</template>

	<template name="sp_options_notifications_checkbox_item">
		<frame height="3.4h" texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="1"
			oninstantiatelua="
				if isNewUI() then
					systemMessages:InitOption('{option}')
				else
					HoN_Notifications.InitOption('{option}')
				end
			"
		>
			<label x="1%" width="36%" height="100%" textvalign="center" font="dyn_12" color="#59c3f8" shadow="1" content="{label}" noclick="1" />

			<instance name="Moptions_checkbox" lockcheck="1" enabled="{enabled1=1}" x="37%" width="20%" height="1.5h" valign="center" font="dyn_10"
				label="sp_notifications_options_btn_1"
				onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
				onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)'); Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
				onshowlua="
					if isNewUI() then
						systemMessages:InteractNotificationOption(self, false, '{option}', 1, self:GetButtonState())
					else
						HoN_Notifications.InteractNotificationOption(self, false, '{option}', 1, self:GetButtonState())
					end
				"
				onclicklua="
					if isNewUI() then
						systemMessages:InteractNotificationOption(self, true, '{option}', 1, self:GetButtonState())
					else
						HoN_Notifications.InteractNotificationOption(self, true, '{option}', 1, self:GetButtonState())
					end
				"
			/>
			<instance name="Moptions_checkbox" lockcheck="1" enabled="{enabled2=1}" x="57.0%" width="20%" height="1.5h" valign="center" font="dyn_10"
				label="sp_notifications_options_btn_2"
				onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
				onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)'); Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
				onshowlua="
					if isNewUI() then
						systemMessages:InteractNotificationOption(self, false, '{option}', 2, self:GetButtonState())
					else
						HoN_Notifications.InteractNotificationOption(self, false, '{option}', 2, self:GetButtonState())
					end
				"
				onclicklua="
					if isNewUI() then
						systemMessages:InteractNotificationOption(self, true, '{option}', 2, self:GetButtonState())
					else
						HoN_Notifications.InteractNotificationOption(self, true, '{option}', 2, self:GetButtonState())
					end
				"
			/>
			<instance name="Moptions_checkbox" lockcheck="1" enabled="{enabled3=1}" x="81.0%" width="20%" height="1.5h" valign="center" font="dyn_10"
				label="sp_notifications_options_btn_3"
				onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
				onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)'); Call('options_scrollbox_scroller_up', 'FadeOut(150)');"
				onshowlua="
					if isNewUI() then
						systemMessages:InteractNotificationOption(self, false, '{option}', 3, self:GetButtonState())
					else
						HoN_Notifications.InteractNotificationOption(self, false, '{option}', 3, self:GetButtonState())
					end
				"
				onclicklua="
					if isNewUI() then
						systemMessages:InteractNotificationOption(self, true, '{option}', 3, self:GetButtonState())
					else
						HoN_Notifications.InteractNotificationOption(self, true, '{option}', 3, self:GetButtonState())
					end
				"
			/>
		</frame>
	</template>

	<template name="game_options">
		<panel name="game_options" y="{y=-110%}" width="121.5h" align="center" visible="0" noclick="1" hotkey="ESC" onhotkey="Set('_mainmenu_currentpanel', 'game_options'); CallEvent('MainMenuPanelSwitcher');"
			onshowlua="UIManager.GetInterface('main'):HoNOptionsF('OnShow')"
			watch=""
			onevent2lua=""
			onhidelua="HoN_Options.DumpOptionsTable()"
			onhide="OptionsCancel()"
			watch0="CloudConfigRetrieved"
			ontrigger0lua="ApplyCloudSave() self:RefreshWidget()"
			onloadlua="Set('host_pendingOptionsChanges', false)"
		>
			<panel x="0" y="-100%" height="203.6%" width="90%" align="center" texture="mainmenu/upper_frame_center.tga" noclick="1"/>
			<panel x="18h" y="-100%" height="203.6%" width="50@" align="right" texture="mainmenu/upper_frame_right.tga" noclick="1"/>
			<panel x="-18h" y="-100%" height="203.6%" width="50@" align="left" texture="mainmenu/upper_frame_left.tga" noclick="1"/>

			<panel y="1.2h" height="-2.0h" width="-6.0h" align="center" noclick="1">
				<panel x="20.6h" width="-20.5h" noclick="0">
					<panel color="#183042" noclick="1"/>
					<panel width="-0.8h" height="-0.8h" align="center" valign="center" color="0 0 0 1" noclick="1"/>

					<!-- right side scroller -->
					<scrollbar name="options_scrollbar"
						x="-1.0h"
						y="1.2h"
						width="2.0h"
						height="-5.6h"
						align="right"
						scrollbarsize="1.8h"
						handlewidth="1.8h"
						handleheight="7.2h"
						texture="/ui/info/im.tga"
						minvalue="0"
						maxvalue="1"
						step="1"
						value="0"
						vertical="true"
						slotwidth="0.6h" slotheight="1"
						onslidelua="UIManager.GetInterface('main'):HoNOptionsF('SlideScroller', self:GetValue())"
					/>

					<!-- buttons that sit over the scrollbar buttons, I need to be able to do ldown and up on each button -->
					<button name="options_scrollbar_up"
						x="-1.0h"
						y="1.2h"
						width="2.0h"
						height="2.0h"
						align="right"
						valign="top"
						color="invisible"
						onmouseldownlua="UIManager.GetInterface('main'):HoNOptionsF('StartScrollUp')"
						onmouseluplua="UIManager.GetInterface('main'):HoNOptionsF('StopScroll')"
						ondoubleclicklua="UIManager.GetInterface('main'):HoNOptionsF('StartScrollUp')"
					>
						<widgetstate statename="up">
							<image texture="/ui/info/im_vmin_up.tga" noclick="true" />
						</widgetstate>
						<widgetstate statename="over">
							<image texture="/ui/info/im_vmin_over.tga" noclick="true" />
						</widgetstate>
						<widgetstate statename="down">
							<image texture="/ui/info/im_vmin_down.tga" noclick="true" />
						</widgetstate>
					</button>

					<button name="options_scrollbar_down"
						x="-1.0h"
						y="-4.3h"
						width="2.0h"
						height="2.0h"
						align="right"
						valign="bottom"
						color="invisible"
						onmouseldownlua="UIManager.GetInterface('main'):HoNOptionsF('StartScrollDown')"
						onmouseluplua="UIManager.GetInterface('main'):HoNOptionsF('StopScroll')"
						ondoubleclicklua="UIManager.GetInterface('main'):HoNOptionsF('StartScrollDown')"
					>
						<widgetstate statename="up">
							<image texture="/ui/info/im_vmax_up.tga" noclick="true" />
						</widgetstate>
						<widgetstate statename="over">
							<image texture="/ui/info/im_vmax_over.tga" noclick="true" />
						</widgetstate>
						<widgetstate statename="down">
							<image texture="/ui/info/im_vmax_down.tga" noclick="true" />
						</widgetstate>
					</button>

					<panel name="options_main_holder" clip="1" y="1.2h" width="-7.0h" height="-5.6h" align="center" valign="top" padding="0.5h" noclick="1">
						<!-- cover over the right side to catch scrolling  -->
						<panel name="options_main_scroller" processonlyscroll="1"
							onmouseoverlua="UIManager.GetInterface('main'):HoNOptionsF('HoverScroller')"
							onmouseout="Call('options_scrollbox_scroller_down', 'FadeOut(150)');
										Call('options_scrollbox_scroller_up', 'FadeOut(150)');
										"
						/>

						<!-- Display -->
						<panel name="options_main_category1" group="options_grow_panel_parent" width="100%" float="bottom" padding="1.0h" noclick="1" visible="0" reverse="true">

							<instance name="optionH1" label="options_display_opts" />

							<!-- Graphics -->
							<instance name="options_subcategory_header" cat="1" id="1" label="options_button_graphics" visible="false" />
							<panel group="options_grow_panel_child" width="100%" noclick="1">

								<!-- Graphics Scene Slider -->
								<panel group="options_grow_panel_child" width="69%" align="left" noclick="1">

									<frame texture="/ui/frames/togglebox.tga" borderthickness="1.3h" noclick="true" rendermode="{rendermode}" />

									<panel group="options_grow_panel_child" y="1.0h" width="-2.0h" align="center" float="bottom" padding="0.5h" noclick="true">

										<!-- Model Preview Land -->
										<panel height="27.0h" noclick="1" passivechildren="1">

											<image texture="/world/sky/legion/1_posy.tga" rotation="0" noclick="1" />

											<panel noclick="1" onshowlua="UIManager.GetInterface('main'):HoNOptionsF('PopulateModels')">
											<modelpanel
													onshow="SetAnim('1', 'idle'); SetAnim('2', 'idle');"
													name="ui_options_preview_low"
													visible="0"
													group="ui_dev_graphics_previews"
													resourcecontext="options2"
													noclick="true"
													anim="idle"
													cameranear="0.0"
													camerafar="110000.0"
													depthcompress="false"
													waterqualityhigh="false"
													lookat="false"
													posteffects="true"
													shadows="false"
													postoutline=""
													outline="false"
													reflections="false"
													scenebuffer="false"
													cameradistance="0"
													camerapos="-240 500 250"
													cameraangles="-20 0 180"
													camerafov="90"

													sunazimuth="120"
													sunaltitude="20"
													suncolor="0.9 0.9 0.9"
													ambientcolor="0.6 0.7 0.7"

													model="/ui/common/models/gfxpreview/well/low/water.mdf"
													modelpos="-250 0 0"
													modelangles="0.0 0 90.0"
													modelscale="1.5"

													model0="/buildings/legion/well/model.mdf"
													modelangles0="0.0 0 90"
													modelpos0="-250 0 -20"
													modelscale0="1.5"

													model1="/ui/common/models/gfxpreview/flint/low/preview_med.mdf"
													modelangles1="0.0 0 0"
													modelpos1="-375 165 -20"
													modelscale1="3.10"
													anim1="idle"


													model2="/ui/common/models/gfxpreview/scout/low/preview_med.mdf"
													modelangles2="0.0 0 0"
													modelpos2="-100 200 -20"
													modelscale2="3.10"
													anim2="idle"

													model3="/world/props/sol_ground/model.mdf"
													modelangles3="0.0 0 90"
													modelpos3="-250 25 -20"
													modelscale3="1.6"

													skybox="true"
													skyboxmaterial="world/sky/legion/legion.material"

													onload="
														SetEffect('0', '/buildings/legion/well/effects/healing_well_body.effect');
														SetEffect('1', GetHeroStorePassiveEffectPathFromProduct('Hero_FlintBeastwood.Alt2'));
														SetEffect('2', GetHeroStorePassiveEffectPathFromProduct('Hero_Scout.Alt');
														SetTeamColor('0.95 0.1 0');"
												/>

												<modelpanel
													onshow="SetAnim('1', 'idle'); SetAnim('2', 'idle');"
													name="ui_options_preview_med"
													visible="0"
													group="ui_dev_graphics_previews"
													resourcecontext="options2"
													noclick="true"
													anim="idle"
													cameranear="0.0"
													camerafar="110000.0"
													depthcompress="false"
													lookat="false"
													posteffects="false"
													shadows="true"
													postoutline=""
													outline="false"
													reflections="false"
													waterqualityhigh="false"
													scenebuffer="true"
													cameradistance="0"
													camerapos="-240 500 250"
													cameraangles="-20 0 180"
													camerafov="90"

													sunazimuth="120"
													sunaltitude="20"
													suncolor="0.9 0.9 0.9"
													ambientcolor="0.6 0.7 0.7"

