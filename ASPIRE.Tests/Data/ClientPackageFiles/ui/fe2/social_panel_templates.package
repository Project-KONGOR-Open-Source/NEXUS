<?xml version="1.0" encoding="UTF-8"?>
<package>

	<trigger name="SPClearUserEntries" />
	<trigger name="SPToggleUserEntries" />
	<trigger name="ShowCreateGroupPanel" />

	<template name="social_panel_group_creation" >
		<panel name="social_panel_create_group" height="24.0h" width="22h.0h" y="0.6h" color="invisible" visible="0" noclick="0" >

			<frame texture="/ui/frames/rounded_bg_doubleedge.tga" borderthickness="0.8h" color=".1 .1 .1 1" noclick="true"/>
			<frame texture="/ui/frames/roundframe.tga" borderthickness="0.8h" color=".2 .2 .2 1" noclick="true" />

			<panel y="0.4h" width="-1.2h" align="center" height="3.0h" valign="top" noclick="true" >
				<frame texture="/ui/frames/rounded_bg_flat.tga" borderthickness="0.6h" color="#192130" blockinput="false" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color="#30405d" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label textalign="center" height="100%" textvalign="center" font="dyn_14" color="1 1 1 1" shadow="true" content="social_assign_a_group" noclick="true"  />
				<!-- Close -->
				<button
					x="-0.4h"
					width="2.0h" height="2.0h"
					align="right"
					valign="center"
					color="invisible"
					onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); Call('social_panel_create_group', 'FadeOut(50);'); Call('generic_are_you_sure_no', 'DoEvent();');"
					onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				>
					<widgetstate statename="up">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
					</widgetstate>
					<widgetstate statename="over">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
					</widgetstate>
				</button>
			</panel>

			<panel name="sp_group_listbox_panel" y="4.0h" x="0" width="-1.6h" height="12.6h" align="center" valign="top">
				<listbox
					name="sp_group_listbox"
					x="0.3h"
					width="-2.7h" height="-0.6h"
					valign="center"
					color="invisible"
					font="dyn_10"
					itemwidth="100%"
					itemheight="2.5h"
					select="true"
					clearselection="true"
					hoverselect="true"
					hoverhighlight="true"
					highlight="under"
					highlightcolor="#46adff42"
					highlightbordercolor="invisible"
					selectedcolor="#346dff52"
					selectedbordercolor="invisible"
					backgroundimage="/ui/fe2/elements/comm_item_bg.tga"
					backgroundimagecolor="#1d2f3b"
					colortransition="true"
					colortransitiontime="250"
					exteriorscrollbars="true"
					scrollbarplaceholder="true"
					scrollbarsize="2.0h"
					scrolltexture="/ui/info/combobox.tga"
					handleheight="2.0h"
					onclick=""
					ondoubleclick=""
					onselectlua="UIManager.GetInterface('main'):HoNSocialPanelF('GroupListSelectInput', self:GetValue() )"
				/>
				<frame color="invisible" borderthickness="1" bordercolor="#2c3a53" noclick="true" />
			</panel>

			<panel visible="1" valign="bottom" y="-3.8h" width="-1.8h" height="2.4h" align="center" noclick="1" sticky="0" stickytoinvis="0" >
				<panel name="sp_group_dyn_button" noclick="0" align="center" onclick="" onmouseover="Call('sp_group_dyn_button_frame', 'SetVisible(1);');" onmouseout="Call('sp_group_dyn_button_frame', 'SetVisible(0);');" >
					<frame name="sp_group_dyn_button_frame" visible="0" texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.4h" color="#39c6ff44" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" valign="center" color="#39c6ff77" borderthickness="0.4h" blockinput="false" noclick="true"/>
					<label name="sp_group_dyn_label" width="100%" fity="1" valign="center" textalign="center" textvalign="center" font="dyn_10" color="#39c6ff" shadow="true" content="social_select_a_group" noclick="1" underline="1" />
				</panel>
			</panel>

			<panel x="1h" y="-0.8h" height="2.4h" valign="bottom" width="-1.8h" noclick="true">
				<frame texture="/ui/frames/rounded_bg_solid.tga" borderthickness="0.4h" color="0 0 0 0.6" blockinput="false" noclick="true"/>
				<frame texture="/ui/frames/roundframe.tga" color=".3 .3 .3 1" borderthickness="0.4h" blockinput="false" noclick="true"/>
				<textbox
					name="sp_textbox_group_input"
					hmargin="0.5h" vmargin="0.4h"
					maxlength="250"
					textalign="left" textvalign="center"
					font="dyn_10"
					textcolor="white"
					shadow="false"
					color="invisible"
					onenter="SetFocus(false);"
					onshow="EraseInputLine(); SetFocus(false);"
					onhide="EraseInputLine(); SetFocus(false); Call('sp_group_input_cover', 'SetVisible(1)');"
					onesc="EraseInputLine(); SetFocus(false);"
					onchangelua="
						UIManager.GetInterface('main'):HoNSocialPanelF('GroupInputBoxUpdate', self:GetValue() )"
					onfocus="
						Call('sp_group_input_cover', 'SetVisible(0)');
					"
					onlosefocus="
						if(StringEmpty(''#this),
							Call('sp_group_input_cover', 'SetVisible(1)')
						);
					"
					onlosefocuslua="UIManager.GetInterface('main'):HoNSocialPanelF('GroupInputBoxUpdate', nil )"
				/>
				<label name="sp_group_input_cover" x="1h" y="0" width="-0.5h" height="-0.4h" valign="center" align="center" textvalign="center" font="dyn_10" color="white" shadow="true" content="social_panel_enter_group" noclick="1" />

			</panel>

		</panel>
	</template>

	<template name="user_left_menu_item">
		<panel height="2.8h" width="98%" align="center"
			name="user_left_menu_item_{index}"
			onevent="SetVisible({condition=true});"
			oneventlua="if ({conditionlua=nil} ~= nil) then self:SetVisible({conditionlua=1}) end"
			visible="0"
			group="{group_name}"
			sticky="0" stickytoinvis="0"
			onclick="{command}; Call('{parent}', 'DoEvent(1);');"
			onclicklua="{commandlua}"
			onrightclick="Call('{parent}', 'DoEvent(1);');"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); Call('user_left_menu_item_{index}_highlight', 'FadeIn(75);');"
			onmouseout="Call('user_left_menu_item_{index}_highlight', 'FadeOut(75);');"
			noclick="0"
		>
			<panel width="-0.4h" height="100%" x="-0.1h" align="center" valign="top" name="user_left_menu_item_{index}_highlight" visible="0" noclick="1">
				<frame texture="/ui/frames/togglebox.tga" borderthickness="0.8h" color="1 1 1 1" noclick="1"/>
				<frame texture="/ui/frames/roundframe.tga" color="#0a4880" borderthickness="0.6h" noclick="1"/>
			</panel>
			<label x="1.0h" color="{textcolor=white}" font="dyn_10" outline="true" textvalign="center" noclick="1">{label}</label>
		</panel>
	</template>

	<template name="user_left_menu">
		<panel name="{panel_name}"
			x="{x=0}" y="{y=0}"
			width="{width}"
			align="{align}"
			valign="top"
			onevent="GroupCall('{group_name}', 'DoEvent();');"
			onevent1="SlideX(0, 200); FadeOut(200);"
			onevent3="SlideX(0, 200); FadeOut(200);"
			onevent1lua="UIManager.GetInterface('main'):HoNSocialPanelF('ClosedLeftMenu')"
			onevent2="SetX(0); SlideX('-100%', 200); FadeIn(200);"
			visible="0"
			noclick="0"
			color="invisible"
			grow="1" regrow="1" growinvis="0"
		>
 	 		<frame texture="/ui/frames/togglebox.tga" borderthickness="1.4h" color="1 1 1 1" noclick="1"/>

			<panel y="0.5h" float="bottom" grow="1" regrow="1" growinvis="0" width="100%">
				<!-- New Header -->
				<panel name="user_left_menu_header_new" height="2.8h" width="98%" align="center" float="right" padding="0.2h" noclick="true" visible="0" sticky="0" stickytoinvis="0"
					oneventlua="self:SetVisible(HoN_Social_Panel:IsPlayerNew(GetCvarString('ui_lastSelectedUser')))"
					group="{group_name}"
				>
					<panel x="0.2h" width="100@" height="100%" noclick="true">
						<image width="74@" height="74%" valign="center" align="center" texture="/ui/fe2/elements/social_marker_new.tga" color=".8 .8 .8 1" noclick="true" />
					</panel>
					<label font="dyn_11" color="#0cef57" outline="true" textvalign="center" content="sp_listlabel_newplayer" noclick="true" />
					<panel x="0" height="1" width="-1.0h" align="center" valign="bottom" color=".9 .9 1 .1"  noclick="true" />
				</panel>
				<instance name="user_left_menu_item" parent="{panel_name}" index="1" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatOpenMessage(ui_lastSelectedUser);" label="ui_items_cc_right_click_send_message" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatUserOnline(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="2" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Follow(StripClanTag(ui_lastSelectedUser)); Cmd('UICall * ChatRefresh()');" label="ui_items_cc_right_click_follow" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and !IsFollowing(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="3" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); UnFollow(StripClanTag(ui_lastSelectedUser)); Cmd('UICall * ChatRefresh()');" label="ui_items_cc_right_click_unfollow" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and IsFollowing(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="4" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatJoinGame(ui_lastSelectedUser);" label="ui_items_cc_right_click_joing_game" condition="(!ChatInGame() and ChatUserInGame(ui_lastSelectedUser) and ChatHasServerInfo(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="5" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatOpenClanMessage();" label="ui_items_cc_right_click_message_clan" condition="(0 and IsInClan() and IsClanMember(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="6" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Set('_player_stats_searchname', ui_lastSelectedUser); CallEvent('player_stats_submit'); Set('_mainmenu_currentpanel', 'player_stats'); If(!IsVisible('player_stats'), CallEvent('MainMenuPanelSwitcher'));" label="ui_items_cc_right_click_view_stats" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="7" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatAddBuddy(ui_lastSelectedUser);" label="ui_items_cc_right_click_add_buddy" condition="(!IsBuddy(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="8" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowRemoveBuddyPanel');" label="ui_items_cc_right_click_remove_buddy" condition="(IsBuddy(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="9" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); GameInvite(ui_lastSelectedUser);" label="ui_items_cc_right_click_invite_to_game" condition="(((IsPrivateGame() and IsHost()) or !IsPrivateGame()) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatUserOnline(ui_lastSelectedUser) and ChatInGame() and !ChatUserInGame(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="10" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); GetUserInfo(ui_lastSelectedUser);" label="ui_items_cc_right_click_user_info" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="11" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelKick(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_kick" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="12" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelBan(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_ban" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="13" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelSilence(ui_lastSelectedUser, ui_currentChannel, 5);" label="ui_items_cc_right_click_channel_silence" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="14" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowIgnorePanel');" label="ui_items_cc_right_click_ignore" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and !ChatIsIgnored(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="15" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatUnignore(ui_lastSelectedUser);" label="ui_items_cc_right_click_unignore" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatIsIgnored(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="16" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowAddBanPanel');" label="ui_items_cc_right_click_addban" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and !ChatIsBanned(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="17" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatRemoveBanlist(ui_lastSelectedUser);" label="ui_items_cc_right_click_remban" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatIsBanned(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="18" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelPromote(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_promote" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt (ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel) + 1))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="19" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelDemote(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_demote" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel) and ChatIsAdmin(ui_lastSelectedUser, ui_currentChannel))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="20" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatPromoteClanMember(ui_lastSelectedUser);" label="ui_items_cc_right_click_clan_promote" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and IsClanMember(ui_lastSelectedUser) and ChatIsClanLeader(GetAccountName()) and !ChatIsClanLeader(ui_lastSelectedUser) and !ChatIsClanOfficer(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="21" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatDemoteClanMember(ui_lastSelectedUser);" label="ui_items_cc_right_click_clan_demote" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and IsClanMember(ui_lastSelectedUser) and ChatIsClanLeader(GetAccountName()) and !ChatIsClanLeader(ui_lastSelectedUser) and ChatIsClanOfficer(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="22" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowRemoveFromClanPanel');" label="ui_items_cc_right_click_clan_remove" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and IsClanMember(ui_lastSelectedUser) and (ChatIsClanLeader(GetAccountName()) or ChatIsClanOfficer(GetAccountName())) and !ChatIsClanLeader(ui_lastSelectedUser) and !ChatIsClanOfficer(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="23" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatInviteUserToClan(ui_lastSelectedUser);" label="ui_items_cc_right_click_clan_invite" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and !ChatUserIsInClan(ui_lastSelectedUser) and (ChatIsClanLeader(GetAccountName()) or ChatIsClanOfficer(GetAccountName())))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="24" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowLeaveClanPanel');" label="ui_items_cc_right_click_clan_leave" condition="(StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and IsInClan(ui_lastSelectedUser))"/>
				<instance name="user_left_menu_item" parent="{panel_name}" index="25" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav');" commandlua="HoN_Matchmaking:InvitePlayerName(self, GetCvarString('ui_lastSelectedUser'))" label="ui_items_cc_right_click_invite_to_tmm" condition="(!StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser) and ChatUserOnline(ui_lastSelectedUser) and !ChatInGame() and (IsInGroup() or IsVisible('matchmaking')) and !IsInQueue() and !ChatUserInGame(ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="26" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); If(!WidgetExists('watch_user_box_' # StripClanTag(ui_lastSelectedUser)) and (watch_user_activeWatches lt 3), Call('watch_user_main', 'Instantiate( \'watch_user_box\', \'user\', \'' # StripClanTag(ui_lastSelectedUser) # '\' );' )); " label="ui_items_cc_right_click_watch_game" condition="((IsBuddy(ui_lastSelectedUser) or IsClanMember(ui_lastSelectedUser) or IsStaff()) and ChatUserInGame(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="27" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatSpectatePlayer(ui_lastSelectedUser, false);" label="ui_items_cc_right_click_spectate_player" condition="(!ChatInGame() and ChatUserInGame(ui_lastSelectedUser) and ChatHasServerInfo(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="28" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatSpectatePlayer(ui_lastSelectedUser, true);" label="ui_items_cc_right_click_mentor_player" condition="(!ChatInGame() and ChatUserInGame(ui_lastSelectedUser) and ChatHasServerInfo(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="29" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowCreateGroupPanel');" label="sp_group_rclick" condition="(IsBuddy(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<instance name="user_left_menu_item" parent="{panel_name}" index="30" group_name="{group_name}" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatJoinGameAsStaff(ui_lastSelectedUser);" label="ui_items_cc_right_click_staff_spectate" condition="((IsStaff() or IsCaster()) and !ChatInGame() and ChatUserInGame(ui_lastSelectedUser) and ChatHasServerInfo(ui_lastSelectedUser) and !StringEquals(StripClanTag(GetAccountName()), ui_lastSelectedUser))" />
				<panel height="0.5h" noclick="1"/>
			</panel>

			<button
				x="-0.7h" y="0.8h"
				width="1.7h" height="1.7h"
				align="right"
				valign="top"
				color="invisible"
				onclicklua="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav') self:GetParent():DoEventN(1)"
				onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav')"
			>
				<widgetstate statename="up">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
					<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
					<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
				</widgetstate>
			</button>

		</panel>
	</template>

