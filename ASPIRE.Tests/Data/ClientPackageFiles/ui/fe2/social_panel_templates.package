			<instance name="rightclick_menu_item3" index="28" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowCreateGroupPanel');" label="sp_group_rclick" condition="(IsBuddy(ui_lastSelectedUser) and !StringEquals(GetAccountName(), ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="29" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatJoinGameAsStaff(ui_lastSelectedUser);" label="ui_items_cc_right_click_staff_spectate" condition="(IsStaff() and !ChatInGame() and ChatUserInGame(ui_lastSelectedUser) and ChatHasServerInfo(ui_lastSelectedUser) and !StringEquals(GetAccountName(), ui_lastSelectedUser))" />
