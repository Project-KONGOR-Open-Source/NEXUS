			<instance name="rightclick_menu_item3" index="1" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Follow(StripClanTag(ui_lastSelectedUser)); Cmd('UICall * ChatRefresh()');" label="ui_items_cc_right_click_follow" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and !IsFollowing(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="2" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); UnFollow(StripClanTag(ui_lastSelectedUser)); Cmd('UICall * ChatRefresh()');" label="ui_items_cc_right_click_unfollow" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and IsFollowing(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="3" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatJoinGame(ui_lastSelectedUser);" label="ui_items_cc_right_click_joing_game" condition="(!ChatInGame() and ChatUserInGame(ui_lastSelectedUser) and ChatHasServerInfo(ui_lastSelectedUser) and !StringEquals(GetAccountName(), ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="4" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatOpenClanMessage();" label="ui_items_cc_right_click_message_clan" condition="(0 and IsInClan() and IsClanMember(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="5" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Set('_player_stats_searchname', ui_lastSelectedUser); CallEvent('player_stats_submit'); Set('_mainmenu_currentpanel', 'player_stats'); If(!IsVisible('player_stats'), CallEvent('MainMenuPanelSwitcher'));" label="ui_items_cc_right_click_view_stats" condition="" />
			<instance name="rightclick_menu_item3" index="6" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatAddBuddy(ui_lastSelectedUser);" label="ui_items_cc_right_click_add_buddy" condition="(!IsBuddy(ui_lastSelectedUser) and !StringEquals(GetAccountName(), ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="7" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowRemoveBuddyPanel');" label="ui_items_cc_right_click_remove_buddy" condition="(IsBuddy(ui_lastSelectedUser) and !StringEquals(GetAccountName(), ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="8" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); GameInvite(ui_lastSelectedUser);" label="ui_items_cc_right_click_invite_to_game" condition="(((IsPrivateGame() and IsHost()) or !IsPrivateGame()) and !StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatUserOnline(ui_lastSelectedUser) and ChatInGame() and !ChatUserInGame(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="9" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); GetUserInfo(ui_lastSelectedUser);" label="ui_items_cc_right_click_user_info" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="10" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelKick(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_kick" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel))" />
			<instance name="rightclick_menu_item3" index="11" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelBan(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_ban" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel))" />
			<instance name="rightclick_menu_item3" index="12" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelSilence(ui_lastSelectedUser, ui_currentChannel, 5);" label="ui_items_cc_right_click_channel_silence" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel))" />
			<instance name="rightclick_menu_item3" index="13" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowIgnorePanel');" label="ui_items_cc_right_click_ignore" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and !ChatIsIgnored(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="14" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatUnignore(ui_lastSelectedUser);" label="ui_items_cc_right_click_unignore" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatIsIgnored(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="15" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowAddBanPanel');" label="ui_items_cc_right_click_addban" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and !ChatIsBanned(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="16" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatRemoveBanlist(ui_lastSelectedUser);" label="ui_items_cc_right_click_remban" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatIsBanned(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="17" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelPromote(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_promote" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt (ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel) + 1))" />
			<instance name="rightclick_menu_item3" index="18" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatChannelDemote(ui_lastSelectedUser, ui_currentChannel);" label="ui_items_cc_right_click_channel_demote" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatGetAdminLevel(GetAccountName(), ui_currentChannel) gt ChatGetAdminLevel(ui_lastSelectedUser, ui_currentChannel) and ChatIsAdmin(ui_lastSelectedUser, ui_currentChannel))" />
			<instance name="rightclick_menu_item3" index="19" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatPromoteClanMember(ui_lastSelectedUser);" label="ui_items_cc_right_click_clan_promote" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and IsClanMember(ui_lastSelectedUser) and ChatIsClanLeader(GetAccountName()) and !ChatIsClanLeader(ui_lastSelectedUser) and !ChatIsClanOfficer(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="20" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatDemoteClanMember(ui_lastSelectedUser);" label="ui_items_cc_right_click_clan_demote" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and IsClanMember(ui_lastSelectedUser) and ChatIsClanLeader(GetAccountName()) and !ChatIsClanLeader(ui_lastSelectedUser) and ChatIsClanOfficer(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="21" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowRemoveFromClanPanel');" label="ui_items_cc_right_click_clan_remove" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and IsClanMember(ui_lastSelectedUser) and (ChatIsClanLeader(GetAccountName()) or ChatIsClanOfficer(GetAccountName())) and !ChatIsClanLeader(ui_lastSelectedUser) and !ChatIsClanOfficer(ui_lastSelectedUser))" />
			<instance name="rightclick_menu_item3" index="22" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); ChatInviteUserToClan(ui_lastSelectedUser);" label="ui_items_cc_right_click_clan_invite" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and !ChatUserIsInClan(ui_lastSelectedUser) and (ChatIsClanLeader(GetAccountName()) or ChatIsClanOfficer(GetAccountName())))" />
			<instance name="rightclick_menu_item3" index="23" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); Trigger('ShowLeaveClanPanel');" label="ui_items_cc_right_click_clan_leave" condition="(StringEquals(GetAccountName(), ui_lastSelectedUser) and IsInClan(ui_lastSelectedUser))"/>
			<instance name="rightclick_menu_item3" index="24" command="PlaySound('/shared/sounds/ui/ccpanel/button_click_01.wav'); InviteToTMMGroup(ui_lastSelectedUser);" label="ui_items_cc_right_click_invite_to_tmm" condition="(!StringEquals(GetAccountName(), ui_lastSelectedUser) and ChatUserOnline(ui_lastSelectedUser) and !ChatInGame() and IsInGroup() and !IsInQueue() and !ChatUserInGame(ui_lastSelectedUser))" />
