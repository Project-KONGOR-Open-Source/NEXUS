						step="0.01"
						value="1"
						vertical="true"
						slotwidth="0.6h" 
						slotheight="1"
						visible="true"
					    onslidelua="
					    	local y = (1.0 - self:GetValue()) * 3
					   		GetWidget('stats_mastery_hero_proficiencies'):SetY(y..'h')
					   	"
						onevent0lua="self:SetValue(math.max(1, self:GetValue() - 1))"
						onevent1lua="self:SetValue(math.min(3, self:GetValue() + 1))"
					   	/>
		    	</panel>

