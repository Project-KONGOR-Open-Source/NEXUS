		    			<instance name="stats_mastery_levelup_single" index="1"/>
		    			<panel height="1" color="#16252c"/>
		    			<instance name="stats_mastery_levelup_single" index="2"/>
		    			<panel height="1" color="#16252c"/>
		    			<instance name="stats_mastery_levelup_single" index="3"/>
		    			<panel height="1" color="#16252c"/>
		    			<instance name="stats_mastery_levelup_single" index="4"/>
		    			<panel height="1" color="#16252c"/>
		    			<instance name="stats_mastery_levelup_single" index="5"/>
		    		</panel>
		    	</panel>

                	<panel name="stats_mastery_error_popup" y="4h" width="30h" height="20h" align="center" valign="center" visible="0"
                	   watch="PlayerStatsMasteryError" ontriggerlua="self:SetVisible(true)">
                 		<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
		    		<instance name="header_bar" height="2.4h" lbl="mastery_error_popup_title" lbl_font="dyn_11" show_close="1" onclicklua="GetWidget('stats_mastery_error_popup'):SetVisible(false)"/>
		    		<panel width="-1h" height="-3.5h" y="-0.5h" align="center" valign="bottom">
		    			<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />

						<panel width="-1h" height="-6h" y="1h" color="1 1 1 .5" align="center" >
							<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
							<panel width="-2h" height="-2h" align="center" valign="center">
								<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" content="" wrap="1"
									   watch="PlayerStatsMasteryError" ontriggerlua="self:SetText(param)"/>
							</panel>
						</panel>

						<instance name="button2" y="-1.5h" width="7h" height="2.5h" label="mastery_error_popup_confirm" align="center" valign="bottom" onclicklua="GetWidget('stats_mastery_error_popup'):SetVisible(false)"/>
		    		</panel>
       			</panel>
		    </panel>

			<button y="3h"
				    width="6.2h"
					height="22.0h"
					color="invisible"
					onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
					onclicklua="GetWidget('player_stats_mastery'):SetVisible(0)"
			>
				<widgetstate statename="up">
				    <image name="playstats_mastery_tab_stats_up" texture="/ui/fe2/elements/aftermatch/matchtab_selected.tga" rotation="180" />
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/fe2/elements/aftermatch/matchtab_hover.tga" rotation="180" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<image texture="/ui/fe2/elements/aftermatch/matchtab_unselected.tga" rotation="180" />
				</widgetstate>
				<image y="2h" texture="/ui/fe2/mastery/tab_stats.tga" width="6h" height="6h" noclick="1" />
				<label x="0.2h" y="3.5h" font="dyn_12" textvalign="center" textalign="center" noclick="true" color="1 1 1 1" content="" onload="SetText(FormatStringNewLine(Translate('mastery_stats_tabs_stats')));" />
		    </button>

			<button y="25h"
					width="6.2h"
					height="22.0h"
					color="invisible"
					onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');"
					onclicklua="GetWidget('player_stats_mastery'):SetVisible(1)"
			>
				<widgetstate statename="up">
					<image name="playstats_mastery_tab_mastery_up" texture="/ui/fe2/elements/aftermatch/matchtab_unselected.tga" rotation="180" />
				</widgetstate>
				<widgetstate statename="over">
					<image texture="/ui/fe2/elements/aftermatch/matchtab_hover.tga" rotation="180" />
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<image texture="/ui/fe2/elements/aftermatch/matchtab_unselected.tga" rotation="180" />
				</widgetstate>
				<image y="2h" texture="/ui/fe2/mastery/tab_mastery.tga" width="4h" height="4h" noclick="1" align="center"/>
				<label x="0.2h" y="3h" font="dyn_12" textvalign="center" textalign="center" noclick="true" color="1 1 1 1" content="" onload="SetText(FormatStringNewLine(Translate('mastery_stats_tabs_mastery')));" />
			</button>

			<!-- Load Progress -->
			<panel width="-2.0h" align="center" visible="1" blockinput="true" watch="EntityDefinitionsLoaded" ontrigger="SetVisible(false);" color="0 0 0 .7">
				<panel align="center" valign="center" width="25.0h" height="5h" y=".5h">
					<image height="100%" texture="../mainmenu/update_bar_bg.tga" />

					<panel watch="EntityDefinitionsProgress" width="1" ontrigger="If(param1 gt 0, SetWidth(((param0 / param1) * 100) # '%')); SetWidth(Max(GetWidth(), 32));">
						<image watch="EntityDefinitionsProgress" ontrigger="If(param1 gt 0 and param0 gt 0, SetUScale(1 / (param0 / param1)));" texture="../mainmenu/update_bar_fg.tga"/>
						<image width="32" texture="../loadingscreens/loading_bar_fg_l.tga"/>
						<image width="32" align="right" texture="../loadingscreens/loading_bar_fg_r.tga"/>
					</panel>
				</panel>
				<image align="center" valign="center" width="31.5h" height="9h" x="-.8h" color="1 1 1 1" texture="elements/loading_bar_frame.tga" />
				<panel color="invisible" y=".5h">
					<label width="-10.0h" height="100%" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="general_wait" />
				</panel>
			</panel>

		</panel>

	</template>

	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_1" title="mastery_levelreward_1" label="mastery_levelreward_desc_1" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_2" title="mastery_levelreward_2" label="mastery_levelreward_desc_2" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_3" title="mastery_levelreward_3" label="mastery_levelreward_desc_3" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_5" title="mastery_levelreward_5" label="mastery_levelreward_desc_5" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_7" title="mastery_levelreward_7" label="mastery_levelreward_desc_7" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_10" title="mastery_levelreward_10" label="mastery_levelreward_desc_10" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_11" title="mastery_levelreward_11" label="mastery_levelreward_desc_11" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_13" title="mastery_levelreward_13" label="mastery_levelreward_desc_13" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_hero_proficiency_tip_15" title="mastery_levelreward_15" label="mastery_levelreward_desc_15" />
	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="stats_mastery_superboost_tip" title="mastery_reward_superboost_title" label="mastery_reward_superboost_desc" />


	<panel watch="PlayerStatsResultMastery" ontriggerlua="if IsMe(param0) then SetMyMasteryExp(param10) end" />
</package>