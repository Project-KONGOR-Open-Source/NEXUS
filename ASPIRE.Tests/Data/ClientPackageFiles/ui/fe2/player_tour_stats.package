<?xml version="1.0" encoding="UTF-8"?>
<package>

	<template name="player_tour_stats">
		<panel name="player_tour_stats" y="-210%" align="center" width="-2.7h" visible="{visible=0}" valign="center" noclick="0"
			onhidelua="if isNewUI() then Homepage_V2:InitMotd() end"
			hotkey="ESC" onhotkey="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); Set('_mainmenu_currentpanel', 'player_tour_stats'); CallEvent('MainMenuPanelSwitcher');"
		>
			<panel x="0" y="-100%" height="203.6%" width="-15@" align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel y="100%" passivechildren="true" noclick="1" onloadlua="self:SetHeight(isNewUI() and '97.5%' or '100%')">
				<panel valign="bottom" y="-2.5h" width="+2h" x="-0.75h">
					<panel width="3.125@" texture="/ui/fe2/frames/slideout_frame_l.tga"/>
					<panel width="3.125@" texture="/ui/fe2/frames/slideout_frame_r.tga" align="right"/>
					<panel width="3.125@" height="3.125%" x="3.125@" valign="bottom" texture="/ui/fe2/frames/slideout_frame_bl.tga"/>
					<panel width="3.125@" height="3.125%" x="-3.125@" valign="bottom" texture="/ui/fe2/frames/slideout_frame_br.tga" align="right"/>
					<panel hmargin="6.25@" height="3.125%" valign="bottom" texture="/ui/fe2/frames/slideout_frame_b.tga"/>
				</panel>
			</panel>

			<panel x="20h" y="-100%" height="203.6%" width="50@" align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-20h" y="-100%" height="203.6%" width="50@" align="left" texture="mainmenu/upper_frame_left.tga"/>

			<panel color="black" y="95%" height="90%" align="center" width="-0.2h" x="0.15h"/>

			<panel height="193%" noclick="1" onloadlua="self:SetHeight(isNewUI() and '191%' or '193%')">
				<panel name="player_tour_stats_parent" align="right" visible="true" noclick="1">
					<panel name="web_browser_player_tour_stats" x="1h" y="-0.6h" width="-2.0h" height="-2.0h" align="left" valign="bottom" noclick="1">
						<panel name="web_browser_player_tour_stats_insert" noclick="1"/>

						<if condition="!ui_webBrowser" >
							<panel color="0 0 0 1" noclick="1">
								<label x="2" y="2" font="dyn_10" color="1 1 1 1" shadow="true" content="Your client does not support this feature." noclick="1"/>
							</panel>
						</if>
					</panel>
				</panel>
			</panel>

			<panel width="2.0h" y="2.2h" x="-2.5h" height="2.0h" align="right" noclick="1">
				<button
					color="invisible"
					onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); Set('_mainmenu_currentpanel', 'player_tour_stats'); CallEvent('MainMenuPanelSwitcher');"
					onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
				>
					<widgetstate statename="up">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#520000" blockinput="false" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="1"/>
					</widgetstate>
					<widgetstate statename="over">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#c50000" blockinput="false" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="1"/>
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#9c0000" blockinput="false" noclick="1"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="1"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="1"/>
					</widgetstate>
				</button>
			</panel>

		</panel>
	</template>
</package>