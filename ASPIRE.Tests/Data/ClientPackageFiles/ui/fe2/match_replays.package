	<template name="teamconcede">
		<panel name="{id}" y="{y}" height="16.8h" width="-1.0h" align="center" color="invisible" noclick="1" visible="0">
			<label x="-0.5h" height="1.9h" width="100%" font="dyn_9" textalign="right" textvalign="center" content="game_end_stats_concede" />
			<panel height="12.5h" valign="bottom" color="0 0 0 .3" noclick="1"/>
		</panel>
	</template>

	<template name="match_list_entry">
		<panel texture="/ui/elements/line_break.tga" color="1 1 1 .1" align="left" valign="center" float="right" padding="10@" passivechildren="true">
			<label y="-0.1h" textalign="left" textvalign="center" font="dyn_12" color="white" outline="true" content="{matchid}"/>
		</panel>
	</template>

	<template name="midwars_award_scrollBtn">
		<button
			name="{id}"
			x="{x}"
			width="60@" height="60%"
			align="{align}" valign="center"
			color="invisible"
			visible="{visible}"
			watch="{watch=}"
			onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); {onmouseover}"
			onclick="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav}');"
			onenter="PlaySound('{sound='/shared/sounds/ui/ccpanel/button_click_02.wav}');"
		>
			<widgetstate statename="up">
				<image texture="/ui/fe2/elements/motd_ad_rotate_{align}.tga" color="1 1 1 .4" />
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/fe2/elements/motd_ad_rotate_{align}.tga" color="1 1 1 1" />
			</widgetstate>
			<widgetstate statename="down" x="{shiftdir}1" y="1">
				<image texture="/ui/fe2/elements/motd_ad_rotate_{align}.tga" color="1 1 1 1" />
			</widgetstate>
		</button>
	</template>

	<template name="match_stats_midwars_player_item" >
		<panel name="match_stats_simple_player_item_{team}_{index}" noclick="1" width="18h" visible="0" sticky="0" stickytoinvis="0"
			watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetVisible(!StringEmpty(param0)));"
			onevent0="
				Call('match_stats_maximise_hover_frame', 'SetVisible(1)');

				##
				If(GetAbsoluteX() le (GetScreenWidth()/2),
					Call('match_stats_maximise_hover_frame',
						'SetX(\'-49.5h\');'
					),
					Call('match_stats_maximise_hover_frame',
						'SetX(\'-97h\');'
					)
				);
				If({team} == 1,
					Call('match_stats_maximise_hover_frame',
						'SetVAlign(\'bottom\'); SetY(\'3h\');'
					),
					Call('match_stats_maximise_hover_frame',
						'SetVAlign(\'top\'); SetY(\'25h\');'
					)
				);
				##

			"
			onevent0lua="Match_Stats.ExpandAward({position}, param0)"
			onevent1="
				Call('match_stats_maximise_hover_frame', 'FadeOut(150)');
			"
		>
			<frame texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.7h" color=".5 .5 .5 1" blockinput="false" />
			<frame texture="/ui/frames/roundframe.tga" color="#074880" borderthickness="0.7h" blockinput="false" />

			<label y="3%" width="100%" height="14%" textvalign="center" textalign="center" valign="top" align="center" font="dyn_12" color="1 1 1 1" outline="true" noclick="1" visible="1"
				name="match_stats_simple_view_player_{team}_{index}" content="Player {team}_{index}"
				watch="MatchInfoPlayer{index}"
				ontrigger="
					If(param1 == 0 or param1 == {team},
						Split(
							If(GetStringWidth('dyn_10', If(!StringEmpty(param57), '['#param57#']'#param0, param0)) gt GetWidth(),
								SetText(SubString(If(!StringEmpty(param57), '['#param57#']'#param0, param0), 0, Round(StringLength(If(!StringEmpty(param57), '['#param57#']'#param0, param0))*(GetWidth()/GetStringWidth('dyn_10', If(!StringEmpty(param57), '['#param57#']'#param0, param0)))))),
								SetText(If(!StringEmpty(param57), '['#param57#']'#param0, param0))
							),
							SetColor(GetColorFromPosition(param2))
						)

					);"
			/>

			<label y="17%" textalign="center" font="dyn_11" color="{color}" outline="true" content="{hero_name}" noclick="true"
				watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, Split(SetText(GetEntityDisplayName(param20)), SetColor(GetColorFromPosition(param2))));"
			/>

			<panel y="30%" width="-8.0%" height="36%" align="center" noclick="true">

				<!-- Hero Icon -->
				<panel width="100@" height="100%" noclick="true">
					<image noclick="0"
						texture="/ui/elements/hero_picker_icon.tga"
						watch="MatchInfoPlayer{index}"
						ontrigger="
							If(param1 == 0,
								SetVisible(false),
								If(param1 == {team},
									If(!StringEquals(param10, ''),
										Split(SetVisible(true),
											SetOnMouseOver('
												ShowWidget(\'hero_info\');
												GetHeroInfo(\'' # param20 # '\');
											'),
											SetTexture(param10),
											CreateString('ui_MatchStatsName_' # {team} # '_' # {index}, param0)
										),
										SetVisible(false)
									)
								)
							);
						"
						onmouseover="ShowWidget('hero_info');"
						onmouseout="HideWidget('hero_info');"
						onevent1="CreateString('compendium_heroLastViewed', 'Hero_Accursed'); SetSave('compendium_heroLastViewed');"
					/>
					<frame color="invisible" borderthickness="1" bordercolor="{color}" noclick="true"
						watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0 or param1 == {team}, SetBorderColor(GetColorFromPosition(param2)));"
					/>
				</panel>
				<!-- Inventory -->
				<panel width="-110@" x="-7@" align="right" noclick="true">
					<panel height="50%" valign="top" float="right" noclick="true">
						<panel noclick="1" width="100@" height="100%" texture="/ui/elements/empty_pack.tga" >
							<image width="-2" height="-2" align="center" valign="center" watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param11#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param11#'\')); '), SetVisible(!StringEquals(param11, '')), SetTexture(GetEntityIconPath(param11)))));" onmouseover="ShowWidget('endgameItemTooltip');" onmouseout="HideWidget('endgameItemTooltip');"/>
						</panel>
						<panel noclick="1" width="100@" height="100%" texture="/ui/elements/empty_pack.tga" >
							<image width="-2" height="-2" align="center" valign="center" watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param12#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param12#'\')); '), SetVisible(!StringEquals(param12, '')), SetTexture(GetEntityIconPath(param12)))));" onmouseover="ShowWidget('endgameItemTooltip');" onmouseout="HideWidget('endgameItemTooltip');"/>
						</panel>
						<panel noclick="1" width="100@" height="100%" texture="/ui/elements/empty_pack.tga" >
							<image width="-2" height="-2" align="center" valign="center" watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param13#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param13#'\')); '), SetVisible(!StringEquals(param13, '')), SetTexture(GetEntityIconPath(param13)))));" onmouseover="ShowWidget('endgameItemTooltip');" onmouseout="HideWidget('endgameItemTooltip');"/>
						</panel>
					</panel>
					<panel height="50%" valign="bottom" float="right" noclick="true">
						<panel noclick="1" width="100@" height="100%" texture="/ui/elements/empty_pack.tga" >
							<image width="-2" height="-2" align="center" valign="center" watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param14#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param14#'\')); '), SetVisible(!StringEquals(param14, '')), SetTexture(GetEntityIconPath(param14)))));" onmouseover="ShowWidget('endgameItemTooltip');" onmouseout="HideWidget('endgameItemTooltip');"/>
						</panel>
						<panel noclick="1" width="100@" height="100%" texture="/ui/elements/empty_pack.tga" >
							<image width="-2" height="-2" align="center" valign="center" watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param15#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param15#'\')); '), SetVisible(!StringEquals(param15, '')), SetTexture(GetEntityIconPath(param15)))));" onmouseover="ShowWidget('endgameItemTooltip');" onmouseout="HideWidget('endgameItemTooltip');"/>
						</panel>
						<panel noclick="1" width="100@" height="100%" texture="/ui/elements/empty_pack.tga" >
							<image width="-2" height="-2" align="center" valign="center" watch="MatchInfoPlayer{index}" ontrigger="If(param1 == 0, SetVisible(false), If(param1 == {team}, Split(SetOnMouseOver('TriggerItemTooltip(\'MSPlayerInventoryTip\',  \''#param16#'\', 0); ShowWidget(\'endgameItemTooltip\'); Trigger(\'MSPlayerInventoryTipIcon\', GetEntityIconPath(\''#param16#'\')); '), SetVisible(!StringEquals(param16, '')), SetTexture(GetEntityIconPath(param16)))));" onmouseover="ShowWidget('endgameItemTooltip');" onmouseout="HideWidget('endgameItemTooltip');"/>
						</panel>
					</panel>
				</panel>
			</panel>

			<panel y="70%" width="-14%" height="26%" align="center" noclick="true">
				<frame texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.5h" color="1 1 1 .2"/>
				<frame texture="/ui/frames/roundframe.tga" color="#052c4e" borderthickness="0.5h"/>

				<panel width="-90@" align="center" noclick="true">
					<image name="match_stats_player_award_1_{position}" x="-50@" width="76@" height="76%" align="center" valign="center" texture="$invis"
						onmouseover="
							CallEventParamsX('match_stats_simple_player_item_{team}_{index}', 0, 1);
							"
						onmouseout="
							CallEventParamsX('match_stats_simple_player_item_{team}_{index}', 1, 1);
							"
						resourcecontext="endstats"
					/>
					<image name="match_stats_player_award_2_{position}" x="50@" width="76@" height="76%" align="center" valign="center" texture="$invis"
						onmouseover="
							CallEventParamsX('match_stats_simple_player_item_{team}_{index}', 0, 2);
							"
						onmouseout="
							CallEventParamsX('match_stats_simple_player_item_{team}_{index}', 1, 2);
							"
						resourcecontext="endstats"
					/>
				</panel>
			</panel>
		</panel>
	</template>

	<!-- rewards templates -->
	<template name="match_stats_hover_question_btn" >
		<button name="match_stats_hover_question_btn_{id}"
			x="{x=-0.8h}" y="{y=0.7h}" height="1.4h" width="1.4h" align="{align=right}" color="invisible"
			onmouseover="
				PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav');
				Trigger('genericMainFloatingTip', true, '25h', '{tticon}', 'ms_toolip_{id}', 'ms_toolip_desc_{id}', '', '', '3h', '-2h')
			"
			onmouseout="Trigger('genericMainFloatingTip', false, '', '', '', '', '', '', '', '');"
		>
			<widgetstate statename="up">
				<image texture="/ui/elements/tip_mark_up.tga"/>
			</widgetstate>
			<widgetstate statename="over">
				<image texture="/ui/elements/tip_mark_over.tga"/>
			</widgetstate>
			<widgetstate statename="down" x="1" y="1">
				<image texture="/ui/elements/tip_mark_up.tga"/>
			</widgetstate>
		</button>
	</template>

	<template name="stats_progress_bar_template" >
		<panel name="progbar_{id}" noclick="1" height="{height=100%}" width="{width=100%}" x="{x=0}" y="{y=0}" valign="{valign=top}" align="{align=left}" visible="1" >
			<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
			<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
			<panel width="-0.5h" align="center" height="-0.5h" valign="center" color="#000000">
				<panel name="progbar_{id}_new_bg"  width="60%" color="{newbgcolor=#FF9C00}" visible="1" >
					<panel name="progbar_{id}_new_fog" width="100%" visible="1" watch="" ontrigger="DoEvent();" onload="DoEvent();" onevent="SetUScale(GetHeight() * 32 # 'p'); SetVScale(GetHeight() # 'p');" utile="true" vtile="true"
						texture="/ui/fe2/elements/bar_fog_megacontrast.tga" rendermode="additive" color="{newfogcolor=#FFCC00}" noclick="1" uspeed="-.5" uscale="64p" vscale="64p" />
					<image name="progbar_{id}_new_glow" visible="0" width="170@" height="210%" texture="/ui/fe2/elements/bar_glow_grayscale.tga" rendermode="additive" color="{newglowcolor=#FFCC00}" align="right" valign="center" x="50@"/>
				</panel>
				<panel name="progbar_{id}_cur_bg"  width="50%" color="{curbgcolor=#68007B}" visible="1" >
					<panel name="progbar_{id}_cur_fog" width="100%" visible="1" watch="" ontrigger="DoEvent();" onload="DoEvent();" onevent="SetUScale(GetHeight() * 32 # 'p'); SetVScale(GetHeight() # 'p');" utile="true" vtile="true"
						texture="/ui/fe2/elements/bar_fog_megacontrast.tga" rendermode="additive" color="{curfogcolor=#ff1cd7}" noclick="1" uspeed="-.5" uscale="64p" vscale="64p" />
					<image name="progbar_{id}_cur_glow" visible="0" width="170@" height="210%" texture="/ui/fe2/elements/bar_glow_grayscale.tga" rendermode="additive" color="{curglowcolor=#ff1cd7}" align="right" valign="center" x="50@"/>
				</panel>
				<image texture="/ui/legion/behind_bar.tga" rendermode="overlay"/>
				<image width="-2" align="center" texture="/ui/elements/bar_highlight_subtle.tga" color="1 1 1 1" />
				<frame bordercolor="#455166" color="invisible" borderthickness="1" noclick="1" />
				<label name="progbar_{id}_label_left"  x="0.8h" font="dyn_10" shadow="1" textalign="left"  textvalign="center" noclick="true" color="1 1 1 1" content="" valign="center" />
				<label name="progbar_{id}_label_right" x="-0.8h" font="dyn_10" shadow="1" textalign="right" textvalign="center" noclick="true" color="1 1 1 1" content="" valign="center" />
			</panel>
		</panel>
	</template>

