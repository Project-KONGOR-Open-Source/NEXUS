				<label width="100%" height="100%" textvalign="center" textalign="center" valign="center" font="dyn_10" color="white" outline="true"  watch1="MatchInfoPlayer{index}"
					ontrigger1="
						If(
							param1 == 0 or param1 == {team},
							if(
								StringLength(param4) gt 0,
								SetText(Translate('game_end_stats_kda', 'kills', param4, 'deaths', param17, 'assists', param18)),
								ClearText()
							)
						);
					"
				/>
				<!-- RMM -->
				<image x="-5@" align="left" height="65%" width="45@" noclick="1" texture="/ui/elements/ui_downarrow.tga" valign="center"  visible="0"
					watch1="MatchInfoPlayer{index}"
					ontrigger1="
						If((param1 == 0 or param1 == {team}),
							If(!StringEmpty(param0),
								Split(
									If(param59 gt 0,
										If((param63 ge param59) or (param63 == 0 and param4 gt 0),
											Split(
												SetColor('green'),
												SetTexture('/ui/elements/ui_uparrow.tga')
											),
											Split(
												SetColor('red'),
												SetTexture('/ui/elements/ui_downarrow.tga')
											)
										),
										Split(
											SetColor('invisible'),
											SetTexture('/ui/elements/ui_uparrow.tga')
										)
									),
									If(StringEquals(StripClanTag(param0), StripClanTag(GetAccountName()))  or (StringEquals(param0, StripClanTag(_player_stats_searchname)) and !StringEmpty(_player_stats_searchname)),
										Split(SetWatch(''), SetVisible(1), Trigger('RMMStats', param58, param59, param60, param61, param62, param63, param64, param65, param66)),
										Split(SetWatch('MatchInfoPlayerHover'), SetVisible(0))
									)
								),
								SetVisible(0)
							)
						);
						##
						SetX('-' # (( GetStringWidth('dyn_10', param4#'_'#param17#'_'#param18) / 2 ) + 8) );
						##
					"
					watch=""
					ontrigger="If(param0 == {team}{index}, SetVisible(1), SetVisible(0) );"
				/>
			</panel>

