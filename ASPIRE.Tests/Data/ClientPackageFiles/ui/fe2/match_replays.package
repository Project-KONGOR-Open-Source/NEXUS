							<panel color="1 0 0 0" width="24h" height="21h" valign="center" float="bottom">
								<panel color="1 1 0 0" height="7h">
									<panel height="2h" y="0.5h">
										<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="#b4b4b4" content="mastery_replay_main_matchexp"/>
									</panel>
									<panel height="3h" y="3.1h">
										<label name="mastery_match_experience" font="dyn_24" textvalign="center" textalign="center" noclick="true" color="white" content="-"/>
										<image name="mastery_match_experience_winicon" x="5.5h" y="-0.05h" align="center" valign="center" width="3h" height="3h" texture="/ui/fe2/mastery/win.tga" noclick="1" visible="0"/>
									</panel>
								</panel>
								<panel height="7h">
									<panel height="2h" y="0.5h">
										<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="#b4b4b4" content="mastery_replay_main_bonusexp"/>
										<button name="mastery_match_bonus_tipbutton" x="-2.3h" y="0.5h" height="1.4h" width="1.4h" align="right" color="invisible"
												onmouseoverlua="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav')
																local desc = ''
																local alreadyhas = false

																if Match_Stats.MasteryInfo.maxleveladdon > 0 then
																	local value =  Match_Stats.MasteryInfo.maxleveladdonPercent
																	if value > 50 then value = 50 end
																	desc = Translate('mastery_replay_bonustip_maxleveladdon', 'heronum', tostring(Match_Stats.MasteryInfo.maxlevelcount), 'value', tostring(value))
																	alreadyhas = true
																end

																if Match_Stats.MasteryInfo.bonusExp > 0 or Match_Stats.MasteryInfo.eventBonus > 0 then
																	if alreadyhas then desc = desc..'\n\n' end

																	desc = desc..'^852'..Translate('mastery_replay_bonustip_other', 'value', tostring(math.floor((Match_Stats.MasteryInfo.bonusExp + Match_Stats.MasteryInfo.eventBonus)/ Match_Stats.MasteryInfo.matchExp * 100)))..'^*'
																end

														        Trigger('genericMainFloatingTip', 'true', '25h', '', '', desc, '', '', '3h', '-2h')
															   "
												onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
										>
											<widgetstate statename="up">
												<image texture="/ui/elements/tip_mark_up.tga"/>
											</widgetstate>
											<widgetstate statename="over">
												<image texture="/ui/elements/tip_mark_over.tga"/>
											</widgetstate>
											<widgetstate statename="down" x="1" y="1">
												<image texture="/ui/elements/tip_mark_up.tga"/>
											</widgetstate>
										</button>
									</panel>
									<panel height="3h" y="3.1h">
										<label name="mastery_bonus_experience" font="dyn_24" textvalign="center" textalign="center" noclick="true" color="white" content="-"/>
									</panel>
								</panel>
								<panel color="1 1 1 0" height="7h">
									<panel height="2h" y="0.5h">
										<label font="dyn_12" textvalign="center" textalign="center" noclick="true" color="#b4b4b4" content="mastery_replay_main_boostexp"/>
									</panel>
									<panel height="3h" y="3.1h">
										<label name="mastery_boost_experience" font="dyn_24" textvalign="center" textalign="center" noclick="true" color="white" content="-" outline="true" outlinecolor="blue"/>
									</panel>
								</panel>
							</panel>

							<panel color="0 1 0 0" x="24.5h" width="29h">
								<panel height="3h" y="5h">
									<label font="dyn_16" textvalign="center" textalign="center" noclick="true" color="#b4b4b4" content="mastery_replay_main_totalexp"/>
								</panel>
								<panel height="12h" y="8h">
									<label name="mastery_total_experience" font="dyn_60_numeric" textvalign="center" textalign="center" noclick="true"  color="white" content="-"/>
								</panel>
							</panel>

							<!-- mastery boost -->
							<panel name="mastery_boost_panel" color="0 0 1 0" width="14h" align="right" valign="center">
								<button name="mastery_boost_btn"
									    align="center"
									    valign="center"
									    y="-20@"
									    width="84.56%"
							            height="84.56@"
						             	color="invisible"
							            onclicklua="
							            	if not GetCvarBool('cg_masteryuidebug') then
								    			if Match_Stats.MasteryInfo.boostNum > 0 then
								    				GetWidget('use_mastery_boost_confirm'):SetVisible(1)
									    		else
					                            	Trigger('Confirm_Purchase_Other', 'mstore_product'..Match_Stats.MasteryInfo.productId..'_name', 'mstore_buyitem_confirm', Match_Stats.MasteryInfo.boostPriceGold, Match_Stats.MasteryInfo.boostPriceSilver, 'MASTERY', tostring(Match_Stats.MasteryInfo.productId), Translate('mastery_replay_main_buy_tip'))
					                       		end
								            else
												if Match_Stats.MasteryInfo.boostNum > 0 then
													Match_Stats.OnMasteryBoost(0)
								                else
													Trigger('Confirm_Purchase_Other', 'mstore_product'..Match_Stats.MasteryInfo.productId..'_name', 'mstore_buyitem_confirm', Match_Stats.MasteryInfo.boostPriceGold, Match_Stats.MasteryInfo.boostPriceSilver, 'MASTERY', tostring(Match_Stats.MasteryInfo.productId), Translate('mastery_replay_main_buy_tip'))
												end
											end"
							            watch="MasteryBoost"
							            ontriggerlua="
							            	GetWidget('mastery_operation_mask'):SetVisible(false)
								    		if tonumber(param0) == 0 then
												Match_Stats.OnMasteryBoost(param0)
											else
												Trigger('ReplayMasteryError', Translate('mastery_error_popup_masteryboost', 'value', param0))
											end"
							            watch1="MicroStoreResults"
							            ontrigger1lua="
							            	Echo('Already Buy the mastery boost, id is :'..param78)
								    		GetWidget('mastery_operation_mask'):SetVisible(false)
											if tonumber(param78) == Match_Stats.MasteryInfo.productId and self:IsVisible() then
												Cmd('UseMasteryBoost '..Match_Stats.MasteryInfo.matchId)
												GetWidget('mastery_operation_mask'):SetVisible(true)
												Match_Stats.MasteryInfo.masktimer = GetTime()
											end"
								    	watch2="Confirm_Purchase_Other_Start"
							            ontrigger2lua="
							            	if (tonumber(param0) == Match_Stats.MasteryInfo.productId) then
				                               GetWidget('mastery_operation_mask'):SetVisible(true)
				                               Match_Stats.MasteryInfo.masktimer = GetTime()
				                           	end"
							            onmouseover="ShowWidget('mastery_boost_tip')"
				  						onmouseout="HideWidget('mastery_boost_tip')"
				  						onmouseoverlua="Match_Stats.UpdateBoostExpUI(true, false)"
				  						onmouseoutlua="Match_Stats.UpdateBoostExpUI(false, false)"
				  						onshowlua="Trigger('SetMasteryBoostTipText', Translate('mastery_replay_main_boosttip_text'))"
							            >
							        <widgetstate statename="up">
							       		<image name="mastery_boost_btn_up" y="0.5h" align="center" valign="center" width="200%" height="200%" texture="/ui/fe2/mastery/boost_iron_up.tga" />
									</widgetstate>
									 <widgetstate statename="over">
							       		<image name="mastery_boost_btn_over" y="0.5h" align="center" valign="center" width="200%" height="200%" texture="/ui/fe2/mastery/boost_iron_over.tga" />
									</widgetstate>
									 <widgetstate statename="down">
							       		<image name="mastery_boost_btn_down" y="0.5h" align="center" valign="center" width="200%" height="200%" texture="/ui/fe2/mastery/boost_iron_down.tga" />
									</widgetstate>
									 <widgetstate statename="disabled">
							       		<image name="mastery_boost_btn_disable" y="0.5h" align="center" valign="center" width="200%" height="200%" texture="/ui/fe2/mastery/boost_disable.tga" />
									</widgetstate>
							    </button>
								<panel width="69%" height="18@" x="15.5%" y="0" noclick="1" valign="center">
									<label name="mastery_boost_number" font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" content=""/>
								</panel>
								<panel height="18@" y="33.3@" noclick="1" valign="center">
									<label name="mastery_boost_btn_text" font="dyn_10" textvalign="center" textalign="center" noclick="true" color="white" shadow="true" content="mastery_replay_main_masteryboost"/>
								</panel>
								<panel name="mastery_boost_disable_tip" align="center" valign="center"
									   y="-20@" width="84.56%" height="84.56@" onmouseover="ShowWidget('mastery_boost_tip')" onmouseout="HideWidget('mastery_boost_tip')"/>
							</panel>

							<!-- super mastery boost -->
							<panel name="mastery_super_boost_panel" color="0 0 1 0" width="14h" align="right" valign="center" x="-18i">
								<button name="mastery_super_boost_btn"
									    align="center"
									    valign="center"
									    y="-30i"
									    width="128i"
							            height="128i"
						             	color="invisible"
							            onclicklua="
							            	if Match_Stats.MasteryInfo.superBoostNum > 0 then
								    			GetWidget('use_mastery_super_boost_confirm'):SetVisible(1)
				                       		end"
							            onmouseover="ShowWidget('mastery_super_boost_tip')"
				  						onmouseout="HideWidget('mastery_super_boost_tip')"
				  						onmouseoverlua="Match_Stats.UpdateBoostExpUI(true, true)"
				  						onmouseoutlua="Match_Stats.UpdateBoostExpUI(false, true)"
				  						onshowlua="Trigger('SetSuperMasteryBoostTipText', Translate('mastery_replay_main_superboosttip_text'))"
							            >
							        <widgetstate statename="up">
							       		<image name="mastery_super_boost_btn_up" y="0.5h" align="center" valign="center" width="256i" height="256i" texture="/ui/fe2/mastery/super_boost_up.tga" />
									</widgetstate>
									 <widgetstate statename="over">
							       		<image name="mastery_super_boost_btn_over" y="0.5h" align="center" valign="center" width="256i" height="256i" texture="/ui/fe2/mastery/super_boost_over.tga" />
									</widgetstate>
									 <widgetstate statename="down">
							       		<image name="mastery_super_boost_btn_down" y="0.5h" align="center" valign="center" width="256i" height="256i" texture="/ui/fe2/mastery/super_boost_down.tga" />
									</widgetstate>
									 <widgetstate statename="disabled">
							       		<image name="mastery_super_boost_btn_disable" y="0.5h" align="center" valign="center" width="256i" height="256i" texture="/ui/fe2/mastery/super_boost_disable.tga" />
									</widgetstate>
							    </button>
								<panel width="69%" height="18@" x="15.5%" y="0" noclick="1" valign="center">
									<label name="mastery_super_boost_number" font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" content=""/>
								</panel>
								<panel height="18@" y="33.3@" noclick="1" valign="center">
									<label name="mastery_super_boost_btn_text" font="dyn_10" textvalign="center" textalign="center" noclick="true" color="white" shadow="true" content="mastery_replay_main_masterysuperboost"/>
								</panel>
								<panel name="mastery_super_boost_disable_tip" align="center" valign="center"
									   y="-20@" width="128i" height="128i" onmouseover="ShowWidget('mastery_super_boost_tip')" onmouseout="HideWidget('mastery_super_boost_tip')"/>
							</panel>
						</panel>

						<panel color="1 1 1 0" x="1.5h" y="-1h" width="112h" height="16h" valign="bottom" noclick="1">
							<image name="mastery_progress_bg" align="center" valign="center" width="189.6h" height="24h" texture="/ui/fe2/mastery/pb_bg_iron.tga" noclick="1"/>
							<panel x="1h" y="4.5h" width="12h" height="10h">
								<label name="mastery_level" font="dyn_72_numeric" textvalign="center" textalign="center" noclick="true" color="white" shadow="true" content=""/>
							</panel>
							<panel x="13h" y="4.5h" width="16h" height="3h">
								<label name="mastery_xp" font="dyn_14" textvalign="center" textalign="left" noclick="true" color="white" shadow="true" content=""/>
							</panel>
							<panel x="-11h" y="2.5h" width="16h" height="6h" align="right">
								<label name="mastery_progress_reward_name" font="dyn_12" textvalign="center" textalign="center" noclick="true" color="white" wrap="1" shadow="true" content=""/>
							</panel>
							<panel name="mastery_progress_reward_bg" x="-2h" y="4.6h" width="9.5h" height="9.5h" align="right" >
								<image texture="/ui/fe2/mastery/bjk.tga" align="center" valign="center"/>
								<image name="mastery_progress_reward" texture="$invis" width="-0.8h" height="-0.8h" align="center" valign="center"/>
							</panel>
							<panel x="13.4h" y="8.2h" width="85.4h" height="5.3h">
								<panel name="mastery_progress_boostvalue" align="left" clip="1">
								    <modelpanel x="0h" y="-8h" align="right" valign="top" height="18h" width="100%" visible="1"
												noclick="1"
												model="/ui/fe2/mastery/models/exp_bar.mdf"
												anim="idle"
												camerapos="0 -1000 3"
												cameraangles="0 0 0"
												camerafov="4.42"
