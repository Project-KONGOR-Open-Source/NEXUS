						<label y="-20%" color="#4c0e0e" font="dyn_14" shadow="true" shadowcolor="#a8815b" textalign="center" textvalign="top" content="ms_stats_tabs_valued_over"/>
						<panel x="20%" y="18%" height="2.0h" name="gold_amount" float="right">
							<label color="#f3b003" font="dyn_14" width="6.0h" shadow="true" textalign="center" textvalign="top" content="2,500"/>
							<image width="1.4h" height="1.4h" valign="center" texture="/ui/fe2/store/gold_coins.tga" />
