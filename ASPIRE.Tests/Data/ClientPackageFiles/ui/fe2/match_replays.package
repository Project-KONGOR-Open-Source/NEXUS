	<template name="ms_rewards_prog_bar_template" >
		<panel name="ms_rewards_{id}_prog_bar" height="15%" noclick="true">
			<frame y="0" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".3 .3 .3 .9" noclick="1" />
			<frame texture="/ui/frames/roundframe.tga" color="0 0 0 .4" borderthickness="0.6h" blockinput="false" noclick="true"/>
			<instance name="match_stats_hover_question_btn" id="{id}" align="left" x="0.5h" y="0.6h"	/>
			<label name="ms_rewards_{id}_prog_bar_title" x="2.1h" y="0.4h" font="dyn_10" align="left" noclick="true" style="rewards_title_2" content="match_stat_rewards_title_label_{id}"/>
			<label name="ms_rewards_{id}_prog_bar_goal" x="-0.5h" y="0.5h" font="dyn_8" align="right" textalign="right" noclick="true" style="rewards_title_4" content=""/>
			<panel y="-0.4h" height="45%" width="95%" align="center" valign="bottom" noclick="true" color="0 0 0 1">
				<instance name="stats_progress_bar_new_template" id="{id}"
					curbgcolor="#086500" curfogcolor="#086500" curglowcolor="#187510"
					newbgcolor="#00CCFF" newglowcolor="#22ACFF" newfogcolor="#22ACFF"
				/>
			</panel>
			<label name="ms_rewards_{id}_breakdown_item_xp_label" x="-8.5h" font="dyn_14" align="right" textalign="right" textvalign="top" noclick="true" style="rewards_xp_text" content="" />
			<instance name="stats_icon_pulse_template_dev" id="{id}_breakdown_item_xp_icon" icon="/ui/fe2/elements/diamond.tga"  x="-6.5h" y="0.5h" height="1.7h" width="1.7h" align="right" valign="top" />
			<label name="ms_rewards_{id}_breakdown_item_sc_label" x="-2.3h" shadow="1" font="dyn_14" align="right" textalign="right" textvalign="top" noclick="true" style="rewards_silver_text" content="" />
			<animatedimage name="ms_rewards_{id}_breakdown_item_sc_icon"
				x="-0.3h" y="-1.7h" height="4.4h" width="2.2h" align="right"
				visible="0" fps="30" loop="true" startframe="5" numframes="-1" loopbackframe="-1" texture="/ui/common/gold/gold.tga" rendermode="grayscale" noclick="1"
			/>
		</panel>
	</template>

	<template name="ms_match_breakdown_item_template">
		<panel name="ms_rewards_{id}_breakdown_item" width="95%" height="2.8h" align="center" noclick="true" float="bottom" grow="1" regrow="1" growinvis="0" sticky="true" stickytoinvis="false">
			<frame y="0" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".3 .3 .3 .9" noclick="1" />
			<frame y="0" texture="/ui/frames/roundframe.tga" color="0 0 0 .4" borderthickness="0.6h" blockinput="false" noclick="true"/>
			<instance name="match_stats_hover_question_btn" id="{id}" align="left" x="0.5h" y="0.6h"	/>
			<panel y="0" noclick="1" height="2.8h">
				<label name="ms_rewards_{id}_breakdown_item_title" x="2.1h" font="dyn_11" align="left" textvalign="center" noclick="true" style="rewards_title_3" content="ms_match_breakdown_item_{id}" />

				<label name="ms_rewards_{id}_breakdown_item_xp_label" x="-9.5h" font="dyn_16" align="right" textalign="right" textvalign="top" noclick="true" style="rewards_xp_text" content="" />
				<instance name="stats_icon_pulse_template_dev" id="{id}_breakdown_item_xp_icon" icon="/ui/fe2/elements/diamond.tga"  x="-7.5h" y="0.5h" height="1.7h" width="1.7h" align="right" valign="top" />
				<panel name="ms_rewards_{id}_breakdown_item_coinroot1">
					<label name="ms_rewards_{id}_breakdown_item_sc_label" x="-3.0h" shadow="1" font="dyn_16" align="right" textalign="right" textvalign="top" noclick="true" style="rewards_silver_text" content="" />
					<animatedimage name="ms_rewards_{id}_breakdown_item_sc_icon"
						x="-0.4h" y="-1.7h" height="4.4h" width="2.2h" align="right"
						visible="0" fps="30" loop="true" startframe="5" numframes="-1" loopbackframe="-1" texture="/ui/common/gold/gold.tga" rendermode="grayscale" noclick="1"
					/>
					<image x="7h" texture="/ui/fe2/elements/gca/icon_1.tga" width="10h" height="2.5h" valign="center" align="center" visible="{gca=false}"/>
				</panel>
				<panel name="ms_rewards_{id}_breakdown_item_coinroot2" visible="0">
					<label name="ms_rewards_{id}_breakdown_item_sc_label2" x="-3.0h" shadow="1" font="dyn_16" align="right" textalign="right" textvalign="top" noclick="true" style="rewards_silver_text" content="+23" />
					<animatedimage name="ms_rewards_{id}_breakdown_item_sc_icon2"
						x="-0.4h" y="-1.7h" height="4.4h" width="2.2h" align="right"
						fps="30" loop="true" startframe="5" numframes="-1" loopbackframe="-1" texture="/ui/common/gold/gold.tga" rendermode="grayscale" noclick="1"
					/>
					<image x="8.5h" texture="/ui/fe2/elements/cyber_set.tga" width="12h" height="1.5h" valign="center" align="center" noclick="1"/>
				</panel>
			</panel>
			<label name="ms_rewards_{id}_breakdown_item_x1_label" visible="{x1vis=false}" fity="1" fitypadding="0.4h" font="dyn_8" textvalign="top" width="-0.7h" align="right" noclick="true" style="rewards_title_5" content="{x1label}"
				onload="SetText(Translate('{x1label}'));"
			/>
			<label name="ms_rewards_{id}_breakdown_item_x2_label" visible="{x2vis=false}" fity="1" fitypadding="0.4h" font="dyn_8" textvalign="top" width="-0.7h" align="right" noclick="true" style="rewards_title_5" content="{x2label}"
				onload="SetText(Translate('{x2label}'));"
			/>
		</panel>
	</template>

	<template name="ms_rewards_reward_page_earning_template" >
