				<!-- Comment Box -->
				<panel
					name="comment_box"
					visible="0"
				>
					<panel color="0 0 0 .7" blockinput="true"/>

					<panel width="35.0h" height="18.0h" align="center" valign="center" noclick="0" cangrab="1">
					<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
						<panel y="-0.5h" width="-1.0h" height="-3.4h" align="center" valign="bottom" noclick="1">
							<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
							<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
							<panel width="-1.0h" height="-1.0h" align="center" valign="center" color="invisible" noclick="1">

								<panel height="-3.0h" noclick="1">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#171a28"/>
									<frame texture="/ui/frames/roundframe.tga" color="#bbdefa" borderthickness="0.5h"/>
									<textbuffer name="match_comments" width="-1.0h" height="-1.0h" align="center" valign="center" maxlength="250" usescrollbar="false" textalign="left" font="dyn_9" textcolor="white" shadow="false" color="#0e121b" wrap="true" editable="true" />
								</panel>

								<panel height="2.4h" valign="bottom" color="invisible" noclick="1">
									<instance
										name="button2" button_name="unnamedButton198"
										width="10.0h" height="2.4h"
										align="left"
										valign="center"
										label="general_cancel"
										onclick="Call('comment_box', 'FadeOut(250);');"
									/>

									<instance
										name="button2" button_name="unnamedButton199"
										width="16.0h" height="2.4h"
										align="right"
										valign="center"
										label="endstats_button_submit_comment"
										onclick=""
									/>
								</panel>


							</panel>
						</panel>
						<instance
							name="header_bar"
							buttonsize="1.8h"
							height="2.4h"
							width="-2"
							y="1"
							align="center"
							lbl="game_end_stats_comment_btn"
							show_close="1"
							onclick="PlaySound('/shared/sounds/ui/button_click.mp3'); Call('comment_box', 'FadeOut(250);');"
						/>
					</panel>
				</panel>


				<!-- Load Progress -->
				<panel name="loadentityprogress" visible="1" blockinput="true" watch="EntityDefinitionsLoaded" ontrigger="SetVisible(false);" color="0 0 0 .7">
					<panel align="center" valign="center" width="25.0h" height="5h" y=".5h">
						<image height="100%" texture="../mainmenu/update_bar_bg.tga" />

						<panel watch="EntityDefinitionsProgress" width="1" ontrigger="If(param1 gt 0, SetWidth(((param0 / param1) * 100) # '%')); SetWidth(Max(GetWidth(), 32));">
							<image watch="EntityDefinitionsProgress" ontrigger="If(param1 gt 0 and param0 gt 0, SetUScale(1 / (param0 / param1)));" texture="../mainmenu/update_bar_fg.tga"/>
							<image width="32" texture="../loadingscreens/loading_bar_fg_l.tga"/>
							<image width="32" align="right" texture="../loadingscreens/loading_bar_fg_r.tga"/>
						</panel>
					</panel>
					<image align="center" valign="center" width="31.5h" height="9h" x="-.8h" color="1 1 1 1" texture="elements/loading_bar_frame.tga" />
					<panel color="invisible" y=".5h">
						<label width="-10.0h" height="100%" align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="game_end_stats_progress_bar" />
					</panel>
				</panel>

				<!-- Replay download  v2 -->
				<panel name="main_stats_download_box" color="0 0 0 .5" blockinput="true" visible="false" watch="MatchInfoSummary" ontrigger="CreateString('_stats_last_replay_host', param18); CreateString('_stats_last_replay_name', param19);">
					<panel y="3.5h" x="20.0h" width="-42.0h" height="41.5h" align="left" noclick="1">

						<panel x="-20.5h" height="18.5h" width="26.0h" align="right" valign="bottom" noclick="1">
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="0 0 0 1"/>
							<frame texture="/ui/frames/roundframe.tga" color=".6 .6 .6 1" borderthickness="0.5h"/>

							<!-- Info -->
							<panel y="0.5h" height="-7.0h" width="-1.0h" align="center" color="invisible" noclick="1">
								<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
								<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

								<panel y="0.5h" height="4.2h" width="-1.0h" align="center">
									<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="0 0 0 .2"/>
									<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness="0.5h"/>
									<label width="100%" textvalign="center" textalign="center" wrap="true" shadow="true" font="dyn_10" color="#3abde7" noclick="1" onframe="If(ReplayDownloadErrorEncountered(), Split(SetText(Translate('main_stats_error_downloading_replay')), ShowWidget('main_stats_replay_retry')), Split(HideWidget('main_stats_replay_retry'), If(ReplayDownloadInProgress(), SetText(Translate('main_stats_downloading_replay')), Call('main_stats_download_box', 'HideWidget();'), Call('stats_downloading_replay', 'HideWidget();'))));">main_stats_downloading_replay</label>
								</panel>
								<panel height="-5.2h" align="center" valign="bottom" noclick="true" float="bottom" padding="0.2h" passivechildren="true">
									<label fity="true" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_10" color="1 0.7 0" watch="ReplayDownloadProgress" ontrigger="SetText(Translate('main_stats_download_replay_progress', 'count', param0, 'total', param1));"  />
									<label fity="true" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_10" color="1 0.7 0" watch="ReplayDownloadSpeed" ontrigger="SetText(Translate('main_stats_download_replay_speed', 'speed', param));"  />
									<label fity="true" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_10" color="1 0.7 0" watch="ReplayDownloadTime" ontrigger="SetText(Translate('main_stats_download_replay_remaining', 'time', param));"  />
								</panel>
							</panel>

							<!-- Progress Bar -->
							<panel height="2.4h" y="-3.4h" width="-1.0h" align="center" valign="bottom" color=".1 .1 .1 1" noclick="1">

								<panel watch="ReplayDownloadPercent" ontrigger="SetWidth(FtoP(param0));" noclick="1">
									<image watch="ReplayDownloadPercent" ontrigger="SetUScale(1 / param);" texture="loadingscreens/loading_bar_fg.tga" noclick="1" />
								</panel>

								<label color="white" font="dyn_10" shadow="true" textalign="center" textvalign="center" watch="ReplayDownloadPercent" ontrigger="SetText(FtoP(param0, 0, 2));"/>

								<frame texture="/ui/frames/black_corners.tga" color="1 1 1 1" borderthickness="0.8h"/>
								<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness="0.6h"/>
							</panel>

							<!-- Control Buttons -->
							<panel y="-0.5h" width="-1.0h" height="2.4h" valign="bottom" align="center" color="invisible" noclick="1">
								<instance
									name="button2"
									width="48%"
									align="left"
									valign="center"
									visible="true"
									label="main_stats_retry"
									button_name="main_stats_replay_retry"
									onclick="StopReplayDownload(); DownloadReplay(_stats_last_replay_url); HideWidget();"
								/>

								<instance
									name="button2" button_name="unnamedButton200"
									width="48%"
									align="right"
									valign="center"
									label="main_stats_cancel"
									onclick="StopReplayDownload(); Call('main_stats_download_box', 'FadeOut(250);');"
								/>
							</panel>

						</panel>

					</panel>

				</panel>

			</panel>

			<panel name="matchstats_slider_insertion_point" y="1.0h" width="-6.0h" align="center" noclick="true" color="1 1 0 0.0" >

			</panel>

