						<image align="center" valign="center" color="1 1 1 1" texture="/ui/fe2/season/close_over.tga" noclick="true" />
					</widgetstate>
				</button>
			</panel>
		</panel>
	</template>

    <template name="mastery_operation_mask">
    	<panel name="mastery_operation_mask" visible="0" color="0 0 0 .6">
    		<panel noclick="1" y="-17h" >
				<label width="-10.0h" y="4h" height="100%" align="center" textalign="center" textvalign="center" wreferral="1" font="dyn_10" color="white" shadow="1" content="mstore_processing_elipses" noclick="1" />
				<animatedimage width="4.5h" height="4.5h" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" visible="1" align="center" valign="center" />
			</panel>
    	</panel>
    </template>

    <template name="match_glimmer_drop_popup">
		<panel name="match_glimmer_drop_popup" color="0 0 0 0.8" visible="0">
			<panel width="48h" align="center" valign="center" grow="true">
				<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
				<instance name="header_bar" height="2.5h" lbl="match_glimmer_drop_popup_title" lbl_font="dyn_12" show_close="1" onclicklua="GetWidget('match_glimmer_drop_popup'):SetVisible(false)"/>
				<panel grow="true" width="-1h" align="center" float="bottom" noclick="1">
					<panel height="3h" noclick="1"/>
					<panel grow="true" width="100%" >
						<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
						<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
						<panel grow="true" width="100%" float="bottom">
							<panel height="2h" />
							<panel height="3h" >
								<panel width="16h" x="2h" >
									<label font="dyn_16" textvalign="center" textalign="left" noclick="true" color="white" content="match_glimmer_drop_popup_got" />
								</panel>
								<panel width="11h" x="2h" align="center" >
									<panel width="3h" align="left" >
										<image texture="/ui/fe2/elements/diamond_season.tga" align="center" valign="center" noclick="1"/>
									</panel>
									<panel width="7h" align="right" >
										<label name="match_glimmer_drop_popup_got" font="dyn_16" textvalign="center" textalign="left" noclick="true" color="#0dcdfa" content="+140" />
									</panel>
								</panel>
							</panel>
							<panel height="1h" />
							<panel height="1">
								<panel color=".6 .6 .6 .3" align="center" width="43h" />
							</panel>
							<panel height="0.5h" />
							<panel height="3h" >
								<panel width="16h" x="2h" >
									<label font="dyn_14" textvalign="center" textalign="left" noclick="true" color="white" content="match_glimmer_drop_popup_own" />
								</panel>
								<panel width="11h" height="3h" x="-2h" align="right" >
									<panel width="2.5h" height="2.5h" align="left" >
										<image texture="/ui/fe2/elements/diamond_season.tga" align="center" valign="center" noclick="1"/>
									</panel>
									<panel width="7h" align="right" >
										<label name="match_glimmer_drop_popup_own" font="dyn_14" textvalign="center" textalign="left" noclick="true" color="white" content="123412" />
									</panel>
								</panel>
							</panel>
							<panel height="9h">
								<panel width="-4h" align="center">
									<label name="match_glimmer_drop_popup_desc" font="dyn_12" textvalign="center" textalign="left" noclick="true" color="gray" wrap="1" content="match_glimmer_drop_popup_desc" />
								</panel>
							</panel>

							<panel height="6h" float="right" padding="3.9h">
								<button x="1.3h" width="12h" height="8h" valign="center" color="invisible" onclicklua="GetWidget('match_glimmer_drop_popup'):SetVisible(false) Player_Tour.OpenPage('treasure')">
									<widgetstate statename="up">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box001.tga" />
									</widgetstate>
									<widgetstate statename="over">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box001_hover.tga" />
									</widgetstate>
									<widgetstate statename="down" x="1" y="1">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box001_hover.tga" />
									</widgetstate>
								</button>
								<button width="12h" height="8h" valign="center" color="invisible" onclicklua="GetWidget('match_glimmer_drop_popup'):SetVisible(false) Player_Tour.OpenPage('treasure')">
									<widgetstate statename="up">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box002.tga" />
									</widgetstate>
									<widgetstate statename="over">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box002_hover.tga" />
									</widgetstate>
									<widgetstate statename="down" x="1" y="1">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box002_hover.tga" />
									</widgetstate>
								</button>
								<button width="12h" height="8h" valign="center" color="invisible" onclicklua="GetWidget('match_glimmer_drop_popup'):SetVisible(false) Player_Tour.OpenPage('treasure')">
									<widgetstate statename="up">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box003.tga" />
									</widgetstate>
									<widgetstate statename="over">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box003_hover.tga" />
									</widgetstate>
									<widgetstate statename="down" x="1" y="1">
										<image width="12h" height="12h" align="center" valign="cener" texture="/ui/fe2/elements/box003_hover.tga" />
									</widgetstate>
								</button>
							</panel>

							<panel name="match_glimmer_drop_popup_chestnumber" height="3h" noclick="1" float="right" padding="3.9h">
								<panel x="1.3h" width="12h" height="3h" valign="center" noclick="1">
									<panel x="-1h" width="1.5h" height="1.5h" align="center" valign="center" noclick="1">
										<image texture="/ui/fe2/elements/chen.tga" align="center" valign="center" noclick="1"/>
									</panel>
									<panel x="0h" width="6h" align="right" noclick="1">
										<label name="match_glimmer_drop_popup_chestnumber_chest1" font="dyn_14" textvalign="center" textalign="left" noclick="true" color="#DDDDDD" content="0" />
									</panel>
								</panel>
								<panel width="12h" height="3h" valign="center" noclick="1">
									<panel x="-1h" width="1.5h" height="1.5h" align="center" valign="center" noclick="1">
										<image texture="/ui/fe2/elements/chen.tga" align="center" valign="center" noclick="1"/>
									</panel>
									<panel x="0h" width="6h" align="right" noclick="1">
										<label name="match_glimmer_drop_popup_chestnumber_chest2" font="dyn_14" textvalign="center" textalign="left" noclick="true" color="#DDDDDD" content="0" />
									</panel>
								</panel>
								<panel width="12h" height="3h" valign="center" noclick="1">
									<panel x="-1h" width="1.5h" height="1.5h" align="center" valign="center" noclick="1">
										<image texture="/ui/fe2/elements/chen.tga" align="center" valign="center" noclick="1"/>
									</panel>
									<panel x="0h" width="6h" align="right" noclick="1">
										<label name="match_glimmer_drop_popup_chestnumber_chest3" font="dyn_14" textvalign="center" textalign="left" noclick="true" color="#DDDDDD" content="0" />
									</panel>
								</panel>
							</panel>

							<panel height="1.2h">
								<panel color=".6 .6 .6 .3" height="1" align="center" valign="center" width="43h" />
							</panel>

							<panel height="5h">
								<instance name="button2" width="14h" height="3h" label="match_glimmer_drop_popup_confirm" font="dyn_12" align="center" valign="center" onclicklua="GetWidget('match_glimmer_drop_popup'):SetVisible(false)"/>
							</panel>
							<panel height="0.5h" >
							</panel>
						</panel>
					</panel>
					<panel height="0.5h"/>
				</panel>
			</panel>
		</panel>
	</template>

	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="mastery_boost_tip" title="mastery_replay_main_boosttip_title" label_watch="SetMasteryBoostTipText" label_ontrigger="SetText(FormatStringNewLine(param0));"/>

	<instance name="generic_tooltip_floater" icony="0.4h" iconheight="1.8h" iconwidth="1.8h" tip_id="mastery_super_boost_tip" title="mastery_replay_main_superboosttip_title" label_watch="SetSuperMasteryBoostTipText" label_ontrigger="SetText(FormatStringNewLine(param0));"/>

	<template name="use_mastery_boost_body">
		<panel width="100%" grow="true" align="center" float="bottom" padding="1.0h" noclick="true">

			<panel grow="true" y="1.0h" width="100%">
				<label y="0.8h" fity="true" width="-2h" align="center" textalign="center" textvalign="top" font="dyn_11" color="white" shadow="true" wrap="true" content="confirm_use_mastery_boost_msg"/>
			</panel>
			<panel height="2.4h" noclick="true">
				<instance
					name="button2" button_name="confirm_use_mastery_boost_cancel"
					x="8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					label="general_cancel" font="dyn_10"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclick="Call('use_mastery_boost_confirm', 'FadeOut(250);');"
					interactive="{interactive}"
				/>
				<instance
					name="button2" button_name="confirm_use_mastery_boost_ok"
					x="-8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					label="general_ok" font="dyn_10"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclick="Call('use_mastery_boost_confirm', 'FadeOut(250);');"
					onclicklua="
            			Match_Stats.MasteryInfo.boostType = 'normal'
						Cmd('UseMasteryBoost '..Match_Stats.MasteryInfo.matchId)
						GetWidget('mastery_operation_mask'):SetVisible(true)
						Match_Stats.MasteryInfo.masktimer = GetTime()
					"
				/>
			</panel>
			<panel height="0.2h" />
		</panel>
	</template>

	<panel name="use_mastery_boost_confirm" visible="{visible=0}" color="0 0 0 .7" onshow="BringToFront();">
		<panel height="53h">
			<instance
				name="alert_box_growable"
				width="33.0h"
				align="center"
				label="general_confirm"
				show_close="true"
				closebtn_click="Call('use_mastery_boost_confirm', 'FadeOut(250);');"
				body="use_mastery_boost_body"
				interactive="{interactive}"
			/>
		</panel>
	</panel>

	<template name="use_mastery_super_boost_body">
		<panel width="100%" grow="true" align="center" float="bottom" padding="1.0h" noclick="true">

			<panel grow="true" y="1.0h" width="100%">
				<label y="0.8h" fity="true" width="-2h" align="center" textalign="center" textvalign="top" font="dyn_11" color="white" shadow="true" wrap="true" content="confirm_use_mastery_super_boost_msg"/>
			</panel>
			<panel height="2.4h" noclick="true">
				<instance
					name="button2" button_name="confirm_use_mastery_super_boost_cancel"
					x="8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					label="general_cancel" font="dyn_10"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclick="Call('use_mastery_super_boost_confirm', 'FadeOut(250);');"
					interactive="{interactive}"
				/>
				<instance
					name="button2" button_name="confirm_use_mastery_super_boost_ok"
					x="-8.0h"
					width="14.0h" height="2.4h"
					align="center"
					valign="center"
					label="general_ok" font="dyn_10"
					onmouseover="PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onclick="Call('use_mastery_super_boost_confirm', 'FadeOut(250);');"
					onclicklua="
	            		Match_Stats.MasteryInfo.boostType = 'super'
						Cmd('UseMasteryBoost '..Match_Stats.MasteryInfo.matchId..' true')
						GetWidget('mastery_operation_mask'):SetVisible(true)
						Match_Stats.MasteryInfo.masktimer = GetTime()
					"
				/>
			</panel>
			<panel height="0.2h" />
		</panel>
	</template>

	<panel name="use_mastery_super_boost_confirm" visible="{visible=0}" color="0 0 0 .7" onshow="BringToFront();">
		<panel height="53h">
			<instance
				name="alert_box_growable"
				width="33.0h"
				align="center"
				label="general_confirm"
				show_close="true"
				closebtn_click="Call('use_mastery_super_boost_confirm', 'FadeOut(250);');"
				body="use_mastery_super_boost_body"
				interactive="{interactive}"
			/>
		</panel>
	</panel>
</package>
