	<template name="stat_column_header_nosort">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true" style="{style}" sticky="true" stickytoinvis="false">
			<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
			<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
		</panel>
	</template>

	<template name="stat_column_header_nosort_regular">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true" style="stats_row_regular" sticky="true" stickytoinvis="false">
			<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
			<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
		</panel>
	</template>

	<template name="stat_column_header_nosort_ctf">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true" style="stats_row_ctf" sticky="true" stickytoinvis="false">
			<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
			<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
		</panel>
