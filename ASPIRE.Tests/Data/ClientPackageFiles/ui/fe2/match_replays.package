<?xml version="1.0" encoding="UTF-8"?>
<package>
	<!-- RMM
		<include file="/ui/RMM_form.package" />
	 -->

	<lua file="/ui/scripts/match_stats.lua" />
	<style name="rewards_bg_1" color="#142129"/>
	<style name="rewards_bg_2" texture="/ui/info/backdrop.tga" color="1 1 1 .4" />
	<style name="rewards_bg_3" color="0 0 0 0" bordercolor="#404c5b" borderthickness="1" />
	<style name="rewards_title_1" shadow="1" color="#00baff" shadowcolor="0 0 0 1" />
	<style name="rewards_title_2" color="#00ff0c" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_title_3" color="#ffba00" shadowcolor="0 0 0 1" shadow="1" />
	<style name="rewards_title_4" color="#00baff" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_title_5" color="#eaeaea" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_xp_text" color="#ec28f6" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_xp_diamond" color="#0dcdfa" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_reward_text" color="#581212" shadowcolor="#b38b64" shadow="1"  />
	<style name="rewards_silver_text" color="#b9f9f8" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_header_earning" color="#ffba00" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_subheader_earning" color="#ffdc7c" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_header_normal" color="1 1 1 1" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_subheader_normal" color="#ededed" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_header_earned" color="1 1 1 1" shadowcolor="0 0 0 1" shadow="1"  />
	<style name="rewards_page_subheader_earned" color="#ededed" shadowcolor="0 0 0 1" shadow="1"  />

	<style name="stats_row_regular" watch="MatchInfoSummary" ontriggerlua="self:SetVisible((param25 ~= 'capturetheflag') and (param25 ~= 'soccer'))"/>
	<style name="stats_row_ctf" watch="MatchInfoSummary" ontriggerlua="self:SetVisible(param25 == 'capturetheflag')" visible="false"/>
	<style name="stats_row_soccer" watch="MatchInfoSummary" ontriggerlua="self:SetVisible(param25 == 'soccer')" visible="false"/>

	<trigger name="RMMStats" />
	<trigger name="matchstats_viewuser"/>

	<cvar name="_stats_last_match_id" type="string" value="" />

	<trigger name="PlayerRecentGamesListStatus"/>
	<trigger name="PlayerRecentGamesListResult"/>
	<trigger name="MatchEntry2"/>
	<trigger name="MatchEntriesFinished2"/>
	<trigger name="MatchInfoPlayerHover" />
	<trigger name="SetMasteryBoostTipText" />
	<trigger name="SetSuperMasteryBoostTipText" />
	<trigger name="ReplayMasteryError"/>

	<form
		name="PlayerRecentGamesList"
		host="!masterserver"
		method="post"
		target="/client_requester.php"
		statustrigger="PlayerRecentGamesListStatus"
		resulttrigger="PlayerRecentGamesListResult"
		resultparam0="last_stats"
		resultparam1="success"
	/>

	<template name="matchStatsTotalsPlayerStatRow">
		<panel height="3h">
			<panel width="11h">
				<frame y="0" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".3 .3 .3 .9" noclick="1" />
				<frame y="0" texture="/ui/frames/roundframe.tga" color="0 0 0 .4" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label textalign="center" textvalign="center" color="#adc0cf" font="dyn_12" content="{label=---}"/>
			</panel>
			<panel align="right" width="-12h">
				<frame y="0" texture="/ui/frames/rounded_bg_blue.tga" borderthickness="0.6h" color=".3 .3 .3 .9" noclick="1" />
				<frame y="0" texture="/ui/frames/roundframe.tga" color="0 0 0 .4" borderthickness="0.6h" blockinput="false" noclick="true"/>
				<label name="{id}" textalign="center" textvalign="center" color="{#a6bcc7}" font="dyn_12" watch="{watch}" ontrigger="{ontrigger}" ontriggerlua="{ontriggerlua}" content="-"/>
			</panel>
		</panel>
	</template>

	<template name="stat_column_header">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true" style="{style}" sticky="true" stickytoinvis="false">
			<button
				group="{group}"
				name="{button_name}"
				color="invisible"
				visible="{visible=true}"
				watch="{watch=}"
				enabled="{enabled=true}"
				ontrigger="{ontrigger=}"
				onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_02.wav'); {onmouseover}"
				onmouseout="{onmouseout}"
				onclick="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav}'); {onclick}"
				onclicklua="{onclicklua}"
				onenter="PlaySound('{sound='/shared/sounds/ui/ccpanel/button_click_02.wav}'); {onenter}"
				onshow="{onshow}"
				onload="{onload}"
				hotkey="{hotkey}"
				onhotkey="PlaySound('{sound=/shared/sounds/ui/ccpanel/button_click_02.wav'}'); {onhotkey}"
				numstates="3"
			>
				<widgetstate statename="up">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<label x="{labelx=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>
				<widgetstate statename="over">
					<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
					<label x="{labelx=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>
				<widgetstate statename="down" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>
					<label x="{labelx=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="#FFFF00" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>
				<widgetstate statename="disabled">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label x="{labelx=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="#494c5f" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
				</widgetstate>

				<widgetstate statename="up2">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="over2">
					<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="down2" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="#FFFF00" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="disabled2">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="#494c5f" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>

				<widgetstate statename="up3">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
				<widgetstate statename="over3">
					<frame texture="/ui/info/button_over.tga" borderthickness="{borderthickness=0.8h}" />
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
				<widgetstate statename="down3" x="1" y="1">
					<frame texture="/ui/info/button_down.tga" borderthickness="{borderthickness=0.8h}" color="white"/>
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="#FFFF00" shadow="true" shadowcolor="#7F6E00" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
				<widgetstate statename="disabled3">
					<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
					<frame texture="/ui/frames/rounded_button_bg_white.tga" borderthickness="0.8h" color=".3 .3 .3 .7"/>
					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="#494c5f" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_down.tga" />
				</widgetstate>
			</button>
		</panel>
	</template>

