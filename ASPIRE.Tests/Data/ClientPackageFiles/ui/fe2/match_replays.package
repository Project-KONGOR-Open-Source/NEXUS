												depthclear="false"
												depthcompress="true"
												sunazimuth="140"
												sunaltitude="10"
												suncolor="1 1 1 1"
												onshow="SetEffect('/ui/fe2/mastery/models/exp_bar.effect');"
												onhide="SetEffect('');"
								    />
