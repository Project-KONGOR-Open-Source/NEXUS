	<template name="ms_rewards_reward_page_template" >
		<panel name="ms_rewards_reward_page_template_parent_{index}" noclick="1" height="17.8h" passivechildren="1" group="ms_reward_temporary_widgets">
			<panel x="2%" width="98%" align="left" y="0.9h" height="16.9h" noclick="true">
				<image y="5.0h" height="12.8h" width="57.6h" texture="/ui/fe2/elements/aftermatch/rewards_footer.tga" noclick="1"/>
				<image y="-0.9h" height="7.8h" width="57.6h" texture="/ui/fe2/elements/aftermatch/rewards_header_{type}.tga" noclick="1"/>
				<instance name="ms_rewards_reward_page_{type}_template" header="{header}" subheader="{subheader}" startdate="{startdate}" checkmark="{checkmark}" />
			</panel>
			<panel x="3.7h" y="7.9h" width="7.4h" height="7.4h" align="left" noclick="1" texture="{icon=/heroes/forsaken_archer/alt2/icon.tga}" />
			<panel x="11.2h" y="7.9h" width="75%" height="7.4h" align="left" noclick="1">
				<label x="0.2h" y="1.0h" font="dyn_12" align="left" noclick="1" style="rewards_page_reward_text" content="{rewardinfo1}"/>
				<label x="0.2h" y="2.6h" font="dyn_18" align="left" noclick="1" style="rewards_page_reward_text" content="{rewardinfo2}" wrap="1"/>
				<label x="0.2h" y="5.4h" font="dyn_10" align="left" noclick="1" style="rewards_page_reward_text" content="{rewardinfo3}" wrap="1"/>
				<label x="-1.8h" y="6.6h" font="dyn_8" align="right" textalign="right" noclick="1" color="#581212" content="{enddate}"/>
			</panel>
		</panel>
	</template>

	<template name="ms_rewards_reward_page_template_s_2" >
		<panel name="ms_rewards_reward_page_template_parent_{index}" noclick="1" height="17.8h" passivechildren="0" group="ms_reward_temporary_widgets">
			<panel x="2%" width="98%" align="left" y="0.9h" height="16.9h" noclick="true">
				<image y="5.0h" height="12.8h" width="57.6h" texture="/ui/fe2/elements/aftermatch/rewards_footer.tga" noclick="1"/>
				<image y="-0.9h" height="7.8h" width="57.6h" texture="/ui/fe2/elements/aftermatch/rewards_header_{type}.tga" noclick="1"/>
				<instance name="ms_rewards_reward_page_{type}_template" header="{header}" subheader="{subheader}" startdate="{startdate}" checkmark="{checkmark}" />

				<panel x="2.7h" y="7.0h" float="right" padding="0.6h" height="5.0h" noclick="1" passivechildren="1">
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/panda/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/behemoth/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/legionnaire/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/gauntlet/alt/icon.tga" />

					<panel width="11.5h" noclick="1" passivechildren="1">
						<label y="-20%" color="#4c0e0e" font="dyn_14" shadow="true" shadowcolor="#a8815b" textalign="center" textvalign="top" content="ms_stats_tabs_valued_over"/>
						<panel x="20%" y="18%" height="2.0h" name="gold_amount" float="right">
							<label color="#f3b003" font="dyn_14" width="6.0h" shadow="true" textalign="center" textvalign="top" content="3,000"/>
							<image width="1.4h" height="1.4h" valign="center" texture="/ui/fe2/store/gold_coins.tga" />
						</panel>

						<panel x="12%" y="58%" height="2.0h" name="silver_amount" float="right">
