								<panel name="mastery_progress_value" color="#b809ea" align="left"
									   onshowlua="Match_Stats.MasteryInfo.step = 0
									              Match_Stats.MasteryInfo.timer = GetTime()
									              Match_Stats.MasteryInfo.displayExp = Match_Stats.MasteryInfo.originalExp
									              Match_Stats.MasteryInfo.originalLevel = nil
    												GetWidget('mastery_progress_value_mask'):SetTexture('/ui/fe2/mastery/progressbar_mask.tga')
									              "
									   onframelua="Match_Stats.UpdateMastery()" clip="1">
									    <image name="mastery_progress_value_mask" x="-18h" texture="/ui/fe2/mastery/progressbar_mask.tga" width="122h" height="6.5h" align="left" valign="center" noclick="1"/>
							    </panel>
