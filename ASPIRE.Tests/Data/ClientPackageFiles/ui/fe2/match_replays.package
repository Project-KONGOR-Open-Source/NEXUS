					<label x="{labelx2=0.8h}" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
					<image x="-25@" width="50@" height="50%" align="right" valign="center" texture="/ui/elements/arrow_up.tga" />
				</widgetstate>
				<widgetstate statename="over2">
