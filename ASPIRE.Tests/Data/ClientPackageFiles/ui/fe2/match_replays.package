	<template name="stat_column_header_nosort_soccer">
		<panel x="{x=}" y="{y=}" width="{width=100%}" height="{height=100%}" align="{align=}" valign="{valign=}" noclick="true" style="stats_row_soccer" sticky="true" stickytoinvis="false">
			<frame texture="/ui/info/button.tga" borderthickness="{borderthickness=0.8h}" color="1 1 1 1"/>
			<label x="0.8h" width="100%" height="100%" textvalign="center" textalign="{textalign=left}" valign="center" align="center" font="{font=dyn_9}" color="white" shadow="true" shadowcolor="black" watch="{labelwatch}" ontrigger="{labelontrigger}">{label}</label>
		</panel>
	</template>

	<template name="award">
		<panel width="10.0h" align="center" noclick="1">
			<frame texture="/ui/info/backdrop.tga" borderthickness="2.0h" color="1 1 1 .7" noclick="1" />
			<panel color="invisible" noclick="1" float="bottom">
				<label y="0.3h" width="-1.0h" height="1.8h" align="center" textalign="center" textvalign="center" font="dyn_10" color="#ffaa00" shadow="1" noclick="1" content="{award_name}"/>
				<label width="100%" height="1.4h" align="center" textalign="center" textvalign="center" font="dyn_8" color="white" noclick="1" shadow="1" content="{description}"/>
				<image
					width="6.0h" height="6.0h"
					align="center"
					texture="/ui/elements/{iconfile}"
				/>
				<label width="-1.0h" height="2.0h" align="center" textalign="center" textvalign="center" font="dyn_10" color="#3abde7" shadow="1" noclick="1" content="Player Name"/>
			</panel>
		</panel>
	</template>

	<template name="match_info_entry">
		<panel height="2.2h" width="100%" color="invisible" noclick="1">
			<label height="100%" width="44%" textvalign="center" font="dyn_10" color="#ffaa00" noclick="1">{label}</label>
			<image x="40%" width="36@" height="36%" valign="center" texture="/ui/info/arrow.tga" />
			<label y="3%" x="43%" width="60%" height="100%" textalign="right" textvalign="center" font="dyn_10" color="white" noclick="1" watch="MatchInfoSummary" ontriggerlua="local str = {str} if (NotEmpty(str)) then self:SetFont(GetFontSizeForWidth(str, self:GetWidth(), 10)) self:SetText(str) else self:SetText('') end"/>
		</panel>
	</template>

	<template name="playerstats_item">
		<panel
			height="2.8h" noclick="1"
			float="right"
			padding="0"
			color="1 1 1 .6"
			texture="/ui/info/tab_bar_c.tga"
			watch="MatchInfoPlayer{index}"
			oninstantiate="CreateString('ui_MatchStatsName_{team}_{index}');"
			ontrigger="
				If(
					param1 == {team},
					Set('ui_MatchStatsName_{team}_{index}', param0)
				);

			"
			onhide="GroupCall('match_replays_self_highlight_effect', 'SetVisible(0);');"
			onshow="SleepWidget(250, 'GroupCall(\'match_replays_self_highlight_effect\', \'SetVisible(1);\');');"
		>

			<!-- Self highlighting -->
			<panel color="1 1 1 0.1" watch="MatchInfoPlayer{index}"
					ontriggerlua="local searchName = GetCvarString('_player_stats_searchname')
								  if not Match_Stats.OtherPlayerMatch or not NotEmpty(searchName) then
								  	  searchName = GetAccountName()
								  end
								  if param1 == '{team}' or param1 == '0' then self:SetVisible(string.lower(param0) == string.lower(StripClanTag(searchName))) end"
					visible="0"  x="0" y="0" align="left" noclick="1" group="matchInfoPlayerRowHighlights" sticky="true" stickytoinvis="false">
				<panel noclick="1" group="match_replays_self_highlight_effect" visible="0" >
					<modelpanel
						noclick="true"
						model="/ui/common/models/main/button.mdf"
						anim="idle"
						camerapos="0 -1500 2"
						cameraangles="0 0 0"
						camerafov="4.42"
						carmerafar="7000"
						depthclear="false"
						depthcompress="true"
						sunazimuth="140"
						sunaltitude="10"
						suncolor="1.4 1.3 1"
						onshow="SetEffect('/ui/common/models/main/button.effect'));"
					/>
					<frame x="0" y="0" align="left" color="invisible" borderthickness="1" bordercolor="0 0 0 1" blockinput="false" noclick="true"/>
				</panel>
			</panel>


			<panel x="0" width="7.0%" color="invisible" noclick="1" sticky="true" stickytoinvis="false">

				<!-- View Stats -->
				<button
					x="0.2h"
					width="1.7h" height="1.7h"
					align="left" valign="center"
					color="invisible"
					onmouseover="Trigger('genericMainFloatingTip', true, '20h', '/ui/fe2/systembar/icons/stats.tga', 'tooltip_viewstats', 'tooltip_viewstats_details', '', '', '-20h', '-2h'); PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onmouseout="Trigger('genericMainFloatingTip', '', '', '', '', '', '', '', '', '', '', '');"
					watch="MatchInfoPlayer{index}"
					ontrigger="If(param1 == {team} or param1 == 0, SetVisible(!StringEmpty(param0)));"
					onclick="HideWidget('sysbar_stats_tip'); Set('_player_stats_searchname', ui_MatchStatsName_{team}_{index}); CallEvent('player_stats_submit'); Set('_mainmenu_currentpanel', 'player_stats'); CallEvent('MainMenuPanelSwitcher');"
				>
					<widgetstate statename="up">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" style="sysbar_btn_up" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.4h" blockinput="false" noclick="true"/>
						<image width="70@" height="70%" align="center" valign="center" texture="systembar/icons/stats.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
					<widgetstate statename="over">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" style="sysbar_btn_overdn" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.4h" blockinput="false" noclick="true"/>
						<image width="70@" height="70%" align="center" valign="center" texture="systembar/icons/stats.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.4h" style="sysbar_btn_overdn" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.4h" blockinput="false" noclick="true"/>
						<image width="70@" height="70%" align="center" valign="center" texture="systembar/icons/stats.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
				</button>

				<!-- RAP - Disabled if not in match, or other criteria -->
				<button
					name="match_stats_rap_{team}_{index}"
					visible="false"
					x="-0.1h"
					width="2.0h" height="2.0h"
					align="center" valign="center"
					color="invisible"
					onmouseover="Trigger('genericMainFloatingTip', true, '20h', '/ui/icons/ban_hammer.tga', 'game_menu_report_a_player', 'game_menu_report_a_player_tip', '', '', '-20h', '-2h'); PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onmouseout="Trigger('genericMainFloatingTip', '', '', '', '', '', '', '', '', '', '', '');"
					watch="MatchInfoPlayer{index}"
					ontriggerlua=
					"
						if(param1 == '{team}' or param1 == '0') then
							local rap2Enable = GetCvarBool('cl_Rap2Enable')
							if rap2Enable then
								if param1 == '0' then
									Rap_Info.ResetCurrentPlayerTeam()
								end
							end
							Rap_Info.SetVisibleRapButtonPlayer(self, {team}, {index}, param0)
						end
					"
					watch2="MatchInfoSummary"
					ontrigger2lua=
					"
						Rap_Info.SetVisibleRapButtonSummary(self, {team}, {index}, param37, param1, param40, param25)
					"
					onclicklua="Rap_Info.MatchStatsReport('{team}', '{index}', GetCvarString('ui_MatchStatsName_{team}_{index}'))"
					enabled="true"
				>
					<widgetstate statename="up">
						<image texture="/ui/icons/ban_hammer.tga" color=".9 .9 .9 1" />
					</widgetstate>
					<widgetstate statename="over">
						<image texture="/ui/icons/ban_hammer.tga" color=".8 .8 1 1" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image texture="/ui/icons/ban_hammer.tga" color=".8 .8 1 1" />
					</widgetstate>
					<widgetstate statename="disabled">
						<image texture="/ui/icons/ban_hammer.tga" color=".8 .8 .8 .5" rendermode="grayscale" />
					</widgetstate>
				</button>

				<!-- Add/Remove Friend -->
				<button
					x="-0.1h"
					width="2.0h" height="2.0h"
					align="right" valign="center"
					color="invisible"
					onmouseover="Trigger('genericMainFloatingTip', true, '20h', '/ui/fe2/elements/btn_cplus_up.tga', 'general_add_friend', 'general_add_friend_details', '', '', '-20h', '-2h'); PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onmouseout="Trigger('genericMainFloatingTip', '', '', '', '', '', '', '', '', '', '', '');"
					watch="MatchInfoPlayer{index}"
					name="MatchStatsAddBuddy{team}_{index}"
					oninstantiate="CreateString('ui_MatchStatsName_{team}_{index}');"
					ontrigger="If(param1 == {team} or param1 == 0, SetVisible(!StringEquals(StripClanTag(GetAccountName()), StripClanTag(param0)) and !StringEmpty(param0) and !IsBuddy(param0)));"
					onclick="HideWidget('match_replay_add_friend'); If(!IsBuddy(ui_MatchStatsName_{team}_{index}) and !StringEquals(StripClanTag(GetAccountName()), StripClanTag(ui_MatchStatsName_{team}_{index})), Split(ChatAddBuddy(ui_MatchStatsName_{team}_{index}),ShowWidget('MatchStatsRemoveBuddy{team}_{index}'),HideWidget('MatchStatsAddBuddy{team}_{index}')));"
				>
					<widgetstate statename="up">
						<image align="center" valign="center" texture="elements/btn_cplus_up.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
					<widgetstate statename="over">
						<image align="center" valign="center" texture="elements/btn_cplus_over.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image align="center" valign="center" texture="elements/btn_cplus_down.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
				</button>
				<button
					x="-0.1h"
					width="2.0h" height="2.0h"
					align="right" valign="center"
					color="invisible"
					onmouseover="Trigger('genericMainFloatingTip', true, '20h', '/ui/fe2/elements/btn_cminus_up.tga', 'general_remove_friend', 'general_remove_friend_details', '', '', '-20h', '-2h'); PlaySound('/shared/sounds/ui/button_over_01.wav');"
					onmouseout="Trigger('genericMainFloatingTip', '', '', '', '', '', '', '', '', '', '', '');"
					watch="MatchInfoPlayer{index}"
					name="MatchStatsRemoveBuddy{team}_{index}"
					ontrigger="If(param1 == {team} or param1 == 0, SetVisible(!StringEquals(StripClanTag(GetAccountName()), StripClanTag(param0)) and !StringEmpty(param0) and IsBuddy(param0)));"
					onclick="HideWidget('match_replay_add_friend'); If(IsBuddy(ui_MatchStatsName_{team}_{index}), Split(ChatRemoveBuddy(ui_MatchStatsName_{team}_{index}),ShowWidget('MatchStatsAddBuddy{team}_{index}'),HideWidget('MatchStatsRemoveBuddy{team}_{index}')));"
				>
					<widgetstate statename="up">
						<image align="center" valign="center" texture="elements/btn_cminus_up.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
					<widgetstate statename="over">
						<image align="center" valign="center" texture="elements/btn_cminus_over.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<image align="center" valign="center" texture="elements/btn_cminus_down.tga" color="1 1 1 1" noclick="true" />
					</widgetstate>
				</button>

			</panel>

			<!-- Player Name -->
			<panel width="22.0%" color="invisible" noclick="1" sticky="true" stickytoinvis="false"
				watch="MatchInfoSummary"
				ontriggerlua="
					if param25 == 'capturetheflag' then
						self:SetWidth('22%')
					elseif param25 == 'soccer' then
						self:SetWidth('22%')
					else
						self:SetWidth('22%')
					end
				"
			>
				<!-- Make temporary variables to store the player names here for use in the View Stats button above -->
				<image x="5@" width="86@" height="86%" valign="center" texture="/ui/elements/hero_picker_icon.tga"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0,
							SetVisible(false),
							If(param1 == {team},
								If(!StringEquals(param10, ''),
									Split(SetVisible(true),
										SetOnMouseOver('
											ShowWidget(\'hero_info\');
											GetHeroInfo(\'' # param20 # '\');
										'),
										SetTexture(param10),
										CreateString('ui_MatchStatsName_' # {team} # '_' # {index}, param0)
									),
									SetVisible(false)
								)
							)
						);
						If(param1 != 0 and param1 == {team},
							SetOnClick('
								Trigger(\'matchstats_hero_helper\', \'' # param20 # '\');
							')
						);
					"
					ontriggerlua="if(param10 ~= '' and param1 == '{team}') then Rap_Info.StorePlayerIcon(({team}-1)*5+{index}, param10) end"

					onmouseover="ShowWidget('hero_info');"
					onmouseout="HideWidget('hero_info');"
					noclick="0"
					onevent1="CreateString('compendium_heroLastViewed', 'Hero_Accursed'); SetSave('compendium_heroLastViewed');"
				/>
				<!-- +clan tag, no truncation -->
				<label width="-110@" height="100%" textvalign="center" textalign="left" valign="center" align="right" font="dyn_10" color="white" outline="true" noclick="1"
					name="MatchStatsPlayerName{team}_{index}"
					watch="MatchInfoPlayer{index}"
					ontrigger="
						If(param1 == 0 or param1 == {team},
							Split(
								If(GetStringWidth('dyn_10', If(!StringEmpty(param57), '['#param57#']'#param0, param0)) gt GetWidth(),
									SetText(SubString('['#param57#']'#param0, param0)),
									SetText(If(!StringEmpty(param57), '['#param57#']'#param0, param0))
								),
								SetColor(GetColorFromPosition(param2))
							)

						);"
				 >
				</label>
			</panel>

			<!-- Rank -->
			<panel style="stats_row_regular" width="6.0%" noclick="1" sticky="true" stickytoinvis="false">
