	<template name="mastery_pop">
		<panel name="mastery_pop_levelup" color="0 0 0 0.8" visible="0"
			   onframelua="Match_Stats.OnMasteryPopupFrame()">
			<effectpanel  name="mastery_pop_levelup_backeffect_iron"
				          camerawidth="100a"
			              cameraheight="100"
			              noclick="true"
			              onloadlua="self:StartEffect('/ui/fe2/mastery/effects/popup_back_iron.effect', 0.5, 0.5, '1 1 1', 1)"
			              visible="0"
			/>
			<effectpanel  name="mastery_pop_levelup_backeffect_silver"
				          camerawidth="100a"
			              cameraheight="100"
			              noclick="true"
			              onloadlua="self:StartEffect('/ui/fe2/mastery/effects/popup_back_silver.effect', 0.5, 0.5, '1 1 1', 1)"
			              visible="0"
			/>
			<effectpanel  name="mastery_pop_levelup_backeffect_gold"
				          camerawidth="100a"
			              cameraheight="100"
			              noclick="true"
			              onloadlua="self:StartEffect('/ui/fe2/mastery/effects/popup_back_gold.effect', 0.5, 0.5, '1 1 1', 1)"
			              visible="0"
			/>
			<effectpanel  name="mastery_pop_levelup_backeffect_goldenred"
				          camerawidth="100a"
			              cameraheight="100"
			              noclick="true"
			              onloadlua="self:StartEffect('/ui/fe2/mastery/effects/popup_back_goldenred.effect', 0.5, 0.5, '1 1 1', 1)"
			              visible="0"
			/>
			<panel name="mastery_pop_levelup_anim" align="center" valign="center" color="1 1 1 0" width="96h" height="96h">
				<panel name="mastery_pop_levelup_bgcolor1" y="16%" width="75%" height="12.6%" align="center" valign="top" color="0 0 0 1"/>
				<panel name="mastery_pop_levelup_bgcolor2" y="28.6%" width="75%" height="40%" align="center" valign="top" color="0 0 0 1"/>
				<image name="mastery_pop_bg" align="center" valign="center" width="100%" height="100%" texture="/ui/fe2/mastery/pop_iron.tga" />
				<panel color="black" width="8.3%" height="8.3%" x="14.6%" y="17.7%">
					<image name="mastery_pop_avatar" texture="$invis" align="center" valign="center" width="-2" height="-2"/>
				</panel>
				<panel color="1 0 1 0" align="center" y="18.2%" width="33.3%h" height="9.3%">
					<label font="dyn_18" textvalign="center" textalign="center" noclick="true" color="white" content="mastery_replay_pop_title"/>
				</panel>

				<button align="right"
						x="-14%"
						y="17.7%"
						width="2.5h"
						height="2.5h"
						color="invisible"
						onclicklua="Match_Stats.MasteryInfo.popupTimer = GetTime()
    	                            Match_Stats.MasteryInfo.popupShow = false
    	                            GetWidget('mastery_pop_levelup_anim'):FadeOut(200)" >
					<widgetstate statename="up">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color=".75 .75 .75 1" texture="/ui/elements/closex.tga" noclick="true" />
					</widgetstate>
					<widgetstate statename="over">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#dc0000" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
					</widgetstate>
					<widgetstate statename="down" x="1" y="1">
						<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#910000" blockinput="false" noclick="true"/>
						<frame texture="/ui/frames/roundframe.tga" color="0 0 0 1" borderthickness="0.5h" blockinput="false" noclick="true"/>
						<image width="1.3h" height="1.3h" align="center" valign="center" color="1 1 1 1" texture="/ui/elements/closex.tga" noclick="true" />
					</widgetstate>
				</button>

				<panel width="16.7%" height="16.7%" align="center" valign="center" y="-12%">
					<image name="mastery_pop_heroicon" texture="$invis" />
					<modelpanel name="mastery_pop_levelup_fronteffect" align="center" valign="center" visible="1"
							noclick="1"
							model="/ui/fe2/mastery/models/icon_highlight.mdf"
							anim="idle"
							camerapos="0 -1000 3"
							cameraangles="0 0 0"
							camerafov="4.42"
							carmerafar="5000"
							depthclear="false"
							depthcompress="true"
							sunazimuth="140"
							sunaltitude="10"
							suncolor="1 1 1 1"
					/>
				</panel>

				<panel width="80%" height="4.16%" align="center" valign="center" y="-1%">
					<label name="mastery_pop_nickname" font="dyn_16" textvalign="center" textalign="center" noclick="true" color="white" content="-"/>
				</panel>

				<panel width="80%" height="4.16%" align="center" valign="center" y="4.16%">
					<label name="mastery_pop_heroname1" font="dyn_12" textvalign="left" textalign="center" noclick="true" color="#dfdfdf" content="-"/>
				</panel>

				<panel width="50%" height="6%" align="center" valign="center" y="9.3%">
					<label name="mastery_pop_heroname2" font="dyn_12" wrap="1" textvalign="left" textalign="top" noclick="true" color="#dfdfdf" content="-"/>
				</panel>

				<panel width="60%" height="9%" align="center" valign="center" y="16%" >
					<label name="mastery_pop_tips" font="dyn_12" wrap="1" textvalign="top" textalign="center" noclick="true" color="#dfdfdf" content="-"/>
				</panel>
			</panel>
        </panel>
	</template>

