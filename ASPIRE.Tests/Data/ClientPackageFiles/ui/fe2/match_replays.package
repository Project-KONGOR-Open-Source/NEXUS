	<template name="ms_rewards_reward_spacer_template">
		<panel height="0.9h" noclick="1" group="ms_reward_temporary_widgets" />
	</template>

	<template name="ms_rewards_reward_line_template">
		<panel height="1" align="left" noclick="1" group="ms_reward_temporary_widgets" >
			<panel width="96%" align="center" color="#445a69" noclick="1" />
		</panel>
	</template>

	<template name="ms_rewards_reward_header_template">
		<panel height="8%" align="left" noclick="1" group="ms_reward_temporary_widgets" >
			<label x="2%" width="50%" font="dyn_12" align="left" textvalign="center" noclick="1" style="rewards_title_1" content="{title}" />
			<label x="-8%" fitx="1" width="30%" font="dyn_12" align="right" textvalign="bottom" noclick="1" style="rewards_title_2" content="{extralabel}" />
			<label x="-2%" width="6%" font="dyn_18" align="right" textalign="right" textvalign="bottom" noclick="1" style="rewards_title_2" content="{value}" />
		</panel>
	</template>

	<template name="rank_reward_placement_matches_item">
		<panel name="rank_reward_placement_matches_item{id}" width="170i" height="16i">
			<image texture="/ui/fe2/season/l1.tga" width="256i" height="16i" align="center" valign="center" color="#666f7c" noclick="1"/>
			<panel name="rank_reward_placement_matches_item{id}_line1" align="left" width="100%" clip="1">
				<image name="rank_reward_placement_matches_item{id}_line1_color" texture="/ui/fe2/season/l1.tga" x="-42i" width="256i" height="16i" align="left" valign="center" color="#ffc600" noclick="1"/>
			</panel>
			<image name="rank_reward_placement_matches_item{id}_line2" texture="/ui/fe2/season/l2.tga" x="12i" width="8i" height="16i" align="right" valign="center" color="#ffc600" noclick="1" />

			<panel name="rank_reward_placement_matches_item{id}_number" x="40i" y="-40i" align="right" valign="center" width="64i" height="64i" noclick="1">
				<panel width="50%" height="75%" align="left" valign="top">
					<label textalign="right" textvalign="bottom" color="#6a777e" font="dyn_24" noclick="true" content="{id}"/>
				</panel>
				<panel width="45%" height="65%" align="right" valign="top">
					<label textalign="left" textvalign="bottom" color="#6a777e" font="dyn_10" noclick="true" content="{suffix}"/>
				</panel>
				<panel y="3%" width="100%" height="35%" align="center" valign="bottom">
					<label textalign="center" textvalign="top" color="#6a777e" font="dyn_10" noclick="true" content="Match"/>
				</panel>
			</panel>

		 	<image name="rank_reward_placement_matches_item{id}_tick" texture="/ui/fe2/season/dag.tga" x="40i" y="-38i" width="64i" height="64i" align="right" valign="center" noclick="1" visible="0"/>
		</panel>
	</template>

	<template name="match_stats">
		<panel name="match_stats" y="-110%" width="100%" align="center" color=".1 .1 .1 1" visible="{visible=0}" noclick="true"
			onload="CreateBool('ui_match_replays_blockSimpleStats', false); CreateBool('ui_match_stats_waitingToShow', false);"
			watch5="ChatShowPostGameStats"
			ontrigger5="##Echo('ChatShowPostGameStats');##"
			onshowlua="Match_Stats.OpenedMatchStats()"
			onshow="##Echo('onshow - Match_Stats.OpenedMatchStats() ');##"
			onhidelua="Match_Stats.ClosedMatchStats()"
			onhide="##Echo('onhide - Match_Stats.ClosedMatchStats() ');## HideWidget('match_replays_reward_event01'); HideWidget('match_replays_reward_event02');"
			watch6="EntityDefinitionsLoaded"
			ontrigger6="##Echo('EntityDefinitionsLoaded');##"
		>

			<panel x="0" y="-100%" height="203.6%" width="90%"  align="center" texture="mainmenu/upper_frame_center.tga"/>
			<panel x="18h" y="-100%" height="203.6%" width="50@"  align="right" texture="mainmenu/upper_frame_right.tga"/>
			<panel x="-18h" y="-100%" height="203.6%" width="50@"  align="left" texture="mainmenu/upper_frame_left.tga"/>

			<panel name="match_stats_detailed_view" y="1.0h" width="-6.0h" align="center" noclick="true" visible="1" >

				<!-- Center Col -->
				<panel name="match_stats_detailed_view_center_col"
					y="3.4h"
					x="24h"
					width="-24.0h"
					height="44.1h"
					align="left"
					color="invisible"
					noclick="1"
				>

					<!-- Detailed Game Stats -->
					<panel width="100%" height="-3.0h" noclick="1" color="invisible">
						<instance height="2.4h" name="header_bar" lbl="endstats_header_player_statistics" lbl_font="dyn_10" show_close="0" />
						<panel name="match_stats_simple_diamond_value_parent" x="-18h" align="right" height="2.4h" visible="0" width="9.0h">
							<panel name="match_stats_simple_diamond_value_haslocalplayer_parent" noclick="true">
								<frame texture="/ui/frames/rounded_bg_green.tga" borderthickness="0.5h" color="1 1 1 1"/>
								<frame texture="/ui/frames/roundframe.tga" color="#535353" borderthickness="0.5h"/>
								<image x="5%" width="90@" height="90%" valign="center" texture="/ui/fe2/elements/diamond_season.tga" noclick="true" />
								<label name="match_stats_simple_diamond_value" width="-90@" height="100%" align="right" textvalign="center" textalign="center" font="dyn_12" color="#0dcdfa" shadow="true" content="-" noclick="true" />
							</panel>
						</panel>

						<panel name="match_stats_simple_silver_value_parent" x="-10.5h" align="right" height="2.4h" visible="0" width="7.0h">
							<panel name="match_stats_simple_silver_value_haslocalplayer_parent" noclick="true">
							<frame texture="/ui/frames/rounded_bg_green.tga" borderthickness="0.5h" color="1 1 1 1"/>
								<frame texture="/ui/frames/roundframe.tga" color="#535353" borderthickness="0.5h"/>
								<image x="5%" width="90@" height="90%" valign="center" texture="/ui/fe2/store/silver_coins.tga" noclick="true" />
								<label name="match_stats_simple_silver_value" width="-90@" height="100%" align="right" textvalign="center" textalign="center" font="dyn_12" color="1 1 1 1" shadow="true" content="+10" noclick="true" />
							</panel>
						</panel>

						<!-- Swap button -->
						<panel height="2.4h" width="10h" noclick="1" align="right">
							<instance
								name="button2" button_name="matchStatsSwitchView"
								height="2.2h" width="9.5h"
								valign="center" align="center"
								label="ms_switch_view"
								onloadlua="
									local isCTF = false
									local isSoccer = false

									self:RegisterWatch('MatchInfoSummary', function(widget, ...)
										isCTF = false
										isSoccer = false
										if (arg[26] == 'capturetheflag') then
											isCTF = true
										end
										if (arg[26] == 'soccer') then
											isSoccer = true
										end
										Echo('matchStatsSwitchView isCTF = ' .. tostring(isCTF) .. '; isSoccer = ' .. tostring(isSoccer))
									end)

									self:SetCallback('onclick', function(widget)
										local simple = GetWidget('match_stats_simple_view')

										if (simple:IsVisible()) then
											HoN_Database:SetDBEntry('show_detailed_matchstats', true)
											simple:FadeOut(100)
										else
											if isCTF then
												Echo('Show up ctfEndSplash')
												GetWidget('ctfEndSplash'):FadeIn(100)
											elseif isSoccer then
												Echo('Show up soccerEndSplash')
												GetWidget('soccerEndSplash'):FadeIn(100)
											else
												HoN_Database:SetDBEntry('show_detailed_matchstats', false)
												simple:FadeIn(100)
											end
										end
									end)
								"

								onmouseoverlua="Trigger('genericMainFloatingTip', 'true', '20h', '', 'ms_switch_view', 'endstats_swap_tip', '', '', '-20h', '-2h')"
								onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"
							/>
						</panel>

						<panel y="2.6h" height="-3.0h" noclick="1">
							<frame color="0 0 0 1" bordercolor="#455166" borderthickness="1" noclick="1" />

							<panel y="0.5h" width="-1.0h" align="center" color="invisible" noclick="1" float="bottom" padding="0.2h">
								<instance height="2.2h" name="header_bar" color="#b3a4a4" lbl="endstats_header_legion_statistics" lbl_font="dyn_10" show_close="0" />
								<instance name="playerstats_table" team="1"/>
							</panel>
							<instance name="teamconcede" y="0.5h" id="legion_concede" />

							<panel y="19.3h" width="-1.0h" align="center" color="invisible" noclick="1" float="bottom" padding="0.2h">
								<instance height="2.2h" name="header_bar" color="#b3a4a4" lbl="endstats_header_hellbourne_statistics" lbl_font="dyn_10" show_close="0" />
								<instance name="playerstats_table" team="2"/>
							</panel>
							<instance name="teamconcede" y="18.4h" id="hellbourne_concede"/>

						</panel>

						<panel name="match_stats_simple_view" y="2.6h" height="-3.0h" noclick="1" clip="1" color="black">
							<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />

							<panel width="-2" height="-2" align="center" valign="center" clip="1" color="black">
								<image name="match_stats_simple_midwars_bg" texture="$invis" width="100%" height="84@" color="1 1 1 .25" noclick="true" visible="0"
									ontrigger9lua="ResourceManager.RegisterTexture('/ui/fe2/elements/midwars_stats_bg.tga', 'endstats', self)" resourcecontext="endstats" watch9="MainRegisterTextures"
								/>

								<panel noclick="1" float="right" padding="1%" height="49%" valign="top" grow="1" growinvis="0" regrow="1" align="center">
									<instance name="match_stats_midwars_player_item" index="0" team="1" position="0" hero_icon="bomb" hero_name="Mr Bomb Man" color="#0042ff" />
									<instance name="match_stats_midwars_player_item" index="1" team="1" position="1" hero_icon="accursed" hero_name="Accursed" color="#1ce2b9" />
									<instance name="match_stats_midwars_player_item" index="2" team="1" position="2" hero_icon="aluna" hero_name="Aluna" color="#9000c0" />
									<instance name="match_stats_midwars_player_item" index="3" team="1" position="3" hero_icon="blitz" hero_name="Blitz" color="#fffc01" />
									<instance name="match_stats_midwars_player_item" index="4" team="1" position="4" hero_icon="defiler" hero_name="Defiler" color="#fe8a0e" />
								</panel>
								<panel noclick="1" float="right" padding="1%" height="49%" valign="bottom" grow="1" growinvis="0" regrow="1" align="center">
									<instance name="match_stats_midwars_player_item" index="0" team="2" position="5" hero_icon="fade" hero_name="Fayde" color="#e55bb0" />
									<instance name="match_stats_midwars_player_item" index="1" team="2" position="6" hero_icon="empath" hero_name="Empath" color="#959697" />
									<instance name="match_stats_midwars_player_item" index="2" team="2" position="7" hero_icon="flux" hero_name="Flux" color="#7ebef1" />
									<instance name="match_stats_midwars_player_item" index="3" team="2" position="8" hero_icon="gauntlet" hero_name="Gauntlet" color="#0f5d42" />
									<instance name="match_stats_midwars_player_item" index="4" team="2" position="9" hero_icon="treant" hero_name="Keeper of the Forest" color="#8b4513" />
								</panel>

							</panel>
						</panel>
					</panel>

					<instance
						name="button2" button_name="unnamedButton183"
						x="-15.2h"
						height="2.6h" width="13.0h"
						align="right"
						valign="bottom"
						label="general_refresh"
						onclicklua="local searchName = GetCvarString('_player_stats_searchname')
									if not Match_Stats.OtherPlayerMatch or not NotEmpty(searchName) then
										searchName = GetAccountName()
									end

									SubmitForm('PlayerRecentGamesList', 'f', 'grab_last_matches_from_nick', 'nickname', StripClanTag(searchName), 'hosttime', HostTime())"
					/>

					<instance
						name="button2" button_name="unnamedButton184"
						x="-0.5h"
						height="2.6h" width="13.0h"
						align="right"
						valign="bottom"
						label="game_end_stats_close_button"
						onclick="Set('_mainmenu_currentpanel', 'match_stats'); CallEvent('MainMenuPanelSwitcher');"
					/>

					<!-- ID Fetch -->
					<panel x="0" grow="true" height="2.6h" valign="bottom" float="right" padding="0.2h" noclick="1">
						<label height="100%" fitx="true" fitxpadding="0.5h" textvalign="center" font="dyn_10" color="white" content="replayv_label_match_id"/>
						<panel width="11.0h" noclick="1">
							<frame texture="/ui/frames/rounded_bg_white.tga" borderthickness="0.5h" color="#171a28"/>
							<frame texture="/ui/frames/roundframe.tga" color="#bbdefa" borderthickness="0.5h"/>
							<textbox
								name="gamestats_fetch_id"
								y="0.3h"
								width="-1.0h"
								align="center"
								onenter="
								Set('ui_match_replays_blockSimpleStats', false);
								_stats_last_match_id = this;
								If(!StringEmpty(_stats_last_match_id) and IsVisible('match_stats'), GetMatchInfo(_stats_last_match_id)); EraseInputLine();"
								font="dyn_12"
								color="invisible"
								textcolor="white"
								onchange="If(StringLength(this) gt 0, Call('post_game_stats_fetch_button', 'SetEnabled(true);'), Call('post_game_stats_fetch_button', 'SetEnabled(false);'));"
							/>
						</panel>

						<instance
							name="button2"
							align="right"
							width="7.0h"
							label="ccstats_button_fetch"
							button_name="post_game_stats_fetch_button"
							enabled="false"
							onclick="Set('ui_match_replays_blockSimpleStats', false); Call('gamestats_fetch_id', '_stats_last_match_id = this; If(!StringEmpty(_stats_last_match_id) and IsVisible(\'match_stats\'), GetMatchInfo(_stats_last_match_id)); EraseInputLine();');"
						/>

						<instance name="tip_mark" tip_id="endgame_fetch_tip" width="2.3h" height="2.3h" valign="center" />
					</panel>

					<!-- Compatibilty archive calculating -->
					<panel name="replays_archive_calc" width="100%" height="100%" visible="false" color="0.0 0.0 0.0 0.66" align="center" noclick="1" watch="CompatCalculating" ontrigger="SetVisible(param);">
						<panel width="24h" height="9.5h" align="center" valign="center" color="invisible" noclick="1">
							<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
							<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

							<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
								<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_calculating" />
								<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" content="replay_compat_version" />

								<instance
									name="button2" button_name="unnamedButton185"
									id="replay_compat_button2"
									y="-0.5h"
									width="13h"
									height="2.2h"
									align="center"
									valign="bottom"
									font="dyn_9"
									label="general_cancel"
									onclick="CancelCompat(); Call('replays_archive_calc', 'SetVisible(0);');"
									enabled="false"
								/>
							</panel>
						</panel>
					</panel>

					<!-- Compatibilty archive downloading -->
					<panel name="replays_archive_dl" width="100%" height="100%" visible="false" color="0.0 0.0 0.0 0.66" align="center" noclick="1" watch="CompatDownloading" ontrigger="SetVisible(param);">
						<panel width="24h" height="22h" align="center" valign="center" color="invisible" noclick="1">
							<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
							<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

							<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
								<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_downloading" />
								<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" />

								<panel x="1.0h" y="5.0h" width="100%" height="0" align="right" color="invisible" noclick="true" passivechildren="true">
									<label y="0.1h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatFilesLeft" ontrigger="SetText(Translate('replay_compat_files', 'count', param0, 'total', param1));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);"  />
									<label y="1.9h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatProgress" ontrigger="SetText(Translate('replay_compat_progress', 'count', param0, 'total', param1));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
									<label y="3.8h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatSpeed" ontrigger="SetText(Translate('replay_compat_speed', 'speed', param));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
									<label y="5.7h" height="1.1h" textvalign="center" shadow="true" font="dyn_9" color="1 0.7 0" watch="CompatTime" ontrigger="SetText(Translate('replay_compat_time', 'time', param));" watch1="CompatMessage" ontrigger1="SetVisible(param != 1 and param != 7);" />
								</panel>

								<frame
									y="-4.5h"
									width="90%" height="3h"
									align="center" valign="bottom"
									borderthickness="0.3h"
									color="invisible" bordercolor="white"
									watch="CompatPercent" ontrigger="SetVisible(param != 2);"
								>
									<panel x="0.7h" y="0.7h" width="-1.4h" height="-1.4h">
										<panel
											width="50%"
											color="white"
											watch="CompatPercent"
											ontrigger="SetWidth(FtoP(param));"
										/>
									</panel>
								</frame>

								<instance
									name="button2" button_name="unnamedButton186"
									id="replay_compat_button"
									y="-0.5h"
									width="13h"
									height="2.2h"
									align="center"
									valign="bottom"
									font="dyn_9"
									label="general_cancel"
									onclick="CancelCompat(); Call('replays_archive_dl', 'SetVisible(0);');"
								/>
							</panel>
						</panel>
					</panel>

					<!-- Compatibilty archive writing -->
					<panel name="replays_archive_write" width="100%" height="100%" visible="false" color="0.0 0.0 0.0 0.66" align="center" noclick="1" watch="CompatWriting" ontrigger="SetVisible(param);">
						<panel width="24h" height="13.5h" align="center" valign="center" color="invisible" noclick="1">
							<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" borderthickness=".6h" align="left" valign="top"/>
							<frame texture="/ui/frames/roundframe.tga" color="#2c4b6c" borderthickness=".6h"/>

							<panel x="0.5h" height="-1.0h" width="-1.0h" valign="center" color="invisible">
								<label y="0.5h" height="1.3h" width="100%" textvalign="center" textalign="center" shadow="true" font="dyn_12" color="#3abde7" noclick="1" content="replay_compat_writing" />
								<label y="2.4h" height="1.1h" width="100%" textvalign="center" textalign="center" align="center" shadow="true" font="dyn_9" color="1 0.7 0 1" noclick="1" watch="CompatVersion" ontrigger="SetText(Translate('replay_compat_version', 'version', param));" content="replay_compat_version" />

								<frame
									y="-4.5h"
									width="90%" height="3h"
									align="center" valign="bottom"
									borderthickness="0.3h"
									color="invisible" bordercolor="white"
									watch="CompatWritePercent" ontrigger="SetVisible(param != 2);"
								>
									<panel x="0.7h" y="0.7h" width="-1.4h" height="-1.4h">
										<panel
											width="50%"
											color="white"
											watch="CompatWritePercent"
											ontrigger="SetWidth(FtoP(param));"
										/>
									</panel>
								</frame>

								<instance
									name="button2" button_name="unnamedButton187"
									id="replay_compat_button2"
									y="-0.5h"
									width="13h"
									height="2.2h"
									align="center"
									valign="bottom"
									font="dyn_9"
									label="general_cancel"
									onclick="CancelCompat(); Call('replays_archive_write', 'SetVisible(0);');"
								/>
							</panel>
						</panel>
					</panel>

					<!-- Download -->
					<panel name="match_replays_download_replay_btn" x="-29.0h" height="2.4h" width="19.0h" align="right" valign="bottom" noclick="1">
						<instance
							name="button2" button_name="unnamedButton188"
							width="-2.5h"
							label="game_end_stats_download_btn"
							onclick="DownloadReplay(_stats_last_replay_url); ShowWidget('main_stats_download_box'); ShowWidget('stats_downloading_replay'); ShowWidget('download_progress_bar'); ShowWidget('cancel_download_btn');"
							watch="MatchInfoSummary"
							ontrigger="SetEnabled(param20 gt 0);"
							watch1="ReplayURLStatus"
							ontrigger1="
								If(param == 1, SetEnabled(false));
								If(param == 2, SetEnabled(true), SetEnabled(false));
								If(param == 3, ShowWidget('download_replay_refresh_btn'));
								If(param == 4, SetEnabled(false));
							"
						/>

						<panel visible="false" name="download_progress_bar" width="-2.5h" watch="MatchInfoSummary"
							onload="
								CreateInt('_stats_last_replay_id', -1);
								CreateString('_stats_last_replay_url', '');
								CreateString('_stats_last_replay_version', '');
								CreateString('_stats_last_replay_path', '');
							"
							ontrigger="
								If(!StringEmpty(param1), Set('_stats_last_replay_id', param1));
								Set('_stats_last_replay_url', param19);
								Set('_stats_last_replay_version', param18);
								Set('_stats_last_replay_path', param23);
								HideWidget();
							"
							onframe="
								If(ReplayDownloadErrorEncountered(), Split(HideWidget(), ShowWidget('download_replay_retry_btn'))); If(!ReplayDownloadInProgress(), HideWidget());
							"
						>
						</panel>

						<instance
							name="button2"
							width="-2.5h"
							visible="false"
							label="game_end_stats_download_retry_btn"
							button_name="download_replay_retry_btn"
							onclick="StopReplayDownload(); DownloadReplay(_stats_last_replay_url); HideWidget(); ShowWidget('main_stats_download_box'); ShowWidget('stats_downloading_replay'); ShowWidget('download_progress_bar');"
							watch="MatchInfoSummary"
							ontrigger="HideWidget();"
						/>

						<instance
							name="button2" button_name="unnamedButton189"
							width="-2.5h"
							label="game_end_stats_compat_btn"
							onclick="DownloadCompat(_stats_last_replay_version);"
							visible="false"
							watch="MatchInfoSummary"
							ontrigger="SetVisible(param22 and !param24);"
							watch1="ReplayDownloadFinished"
							ontrigger1="Set('ui_match_replays_blockSimpleStats', false); If(IsVisible('match_stats') and _stats_last_replay_id gt 0, GetMatchInfo(_stats_last_replay_id));"
							watch2="CompatMessage"
							ontrigger2="Set('ui_match_replays_blockSimpleStats', false); If(param == 2 and IsVisible('match_stats') and _stats_last_replay_id gt 0, GetMatchInfo(_stats_last_replay_id));"
						/>

						<instance
							name="button2" button_name="unnamedButton190"
							width="-2.5h"
							label="game_end_stats_watch_replay_btn"
							onclick="Trigger('ViewReplayDelayed', _stats_last_replay_path); Set('_mainmenu_currentpanel', 'match_stats'); CallEvent('MainMenuPanelSwitcher');"
							watch="MatchInfoSummary"
							ontrigger="SetVisible(param22 and param24);"
							visible="false"
						/>

						<instance
							name="button2"
							width="-2.5h"
							label="game_end_stats_refresh_btn"
							onclick="Set('ui_match_replays_blockSimpleStats', false); ClearEndGameStats(); If(!StringEmpty(_stats_last_replay_id) and IsVisible('match_stats'), GetMatchInfo(_stats_last_replay_id));"
							watch="MatchInfoSummary"
							ontriggerlua="self:SetVisible(Empty(param25))"
							visible="false"
							button_name="download_replay_refresh_btn"
						/>

						<instance name="tip_mark" tip_id="endgame_download_tip" width="2.3h" height="2.3h" valign="center" align="right" />
						<instance name="tip_mark" tip_id="endgame_download_waiting_tip" width="2.3h" height="2.3h" valign="center" align="right" watch="ReplayURLStatus" ontrigger="SetVisible(param == 1);" />
						<instance name="tip_mark" tip_id="endgame_download_retry_tip" width="2.3h" height="2.3h" valign="center" align="right" watch="ReplayURLStatus" ontrigger="SetVisible(param == 3);" />
						<instance name="tip_mark" tip_id="endgame_download_unav_tip" width="2.3h" height="2.3h" valign="center" align="right" watch="MatchInfoSummary" ontrigger="SetVisible(param20 le 0);" />
						<instance name="tip_mark" tip_id="endgame_download_compat_tip" width="2.3h" height="2.3h" valign="center" align="right" watch="MatchInfoSummary" ontrigger="SetVisible(param22 and !param24);" />

						<button
							visible="false"
							width="2.3h" height="2.3h"
							align="right"
							valign="center"
							color="1 1 1 1"
							texture="/ui/info/close_button.tga"
							onclick="PlaySound('/shared/sounds/ui/ccpanel/button_close_02.wav'); StopReplayDownload(); HideWidget();"
							onmouseover="PlaySound('/shared/sounds/ui/ccpanel/button_over_01.wav');"
							name="cancel_download_btn"
							onframe="If(!ReplayDownloadInProgress(), HideWidget());"
						/>
					</panel>
					<!-- On-Demand downloads -->
					<panel name="match_replays_ondemand_download" x="-29.0h" height="2.4h" width="19.0h" align="right" valign="bottom" noclick="1" color="0 0 0" visible="0"
						watch="ReplayURLStatus"
						ontriggerlua="
							if ((tonumber(param) == 3) and OnDemandReplaysEnabled()) then
								self:SetVisible(1)
							else
								self:SetVisible(0)
							end
						"
						watch2=""
					>
						<instance
							name="button2"
							button_name="game_end_stats_request_btn"
							width="-2.5h"
							label="game_end_stats_request_btn"
							onclicklua="Match_Stats:RequestUpload(GetCvarString('_stats_last_replay_id'))"
							labelgroup="game_end_request_group"
							onshowlua="Match_Stats:UpdateOnDemandLabel()"
						/>
						<panel color="invisible" width="2.3h" height="2.3h" valign="center" align="right" noclick="true" >
							<button
								color="invisible"
								onmouseoverlua="
									PlaySound('/shared/sounds/ui/button_over_01.wav')
									Match_Stats:HoverReplayStatus()
								"
								onmouseoutlua="GetWidget('genericMainFloatingTip'):SetVisible(0)"
							>
								<widgetstate statename="up">
									<image width="100%" height="100%" valign="center" align="center" texture="/ui/elements/tip_mark_up.tga" />
								</widgetstate>
								<widgetstate statename="over">
									<image width="100%" height="100%" valign="center" align="center" texture="/ui/elements/tip_mark_over.tga" />
								</widgetstate>
							</button>
						</panel>
					</panel>
				</panel>

				<!-- Right column was here -->

				<!-- popup -->
				<panel name="main_stats_info_box" color="0 0 0 .7" blockinput="true" visible="false" watch="MatchInfoSummary" ontrigger="SetVisible(!StringEquals(param0, ''));"
					onshow="Call('match_stats_retry_btn', 'SetVisible(0); SleepWidget(3000, \'SetVisible(1)\'); ');"
				>
					<panel width="34.0h" height="10.5h" align="center" valign="center" noclick="0" cangrab="1">
					<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
						<panel y="-0.5h" width="-1.0h" height="-3.4h" align="center" valign="bottom" noclick="1">
							<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
							<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />
							<panel width="-1.0h" height="-1.0h" align="center" valign="center" color="invisible" noclick="1">

								<panel height="3.0h" align="center" float="right" padding=".5h" grow="true">
									<!--<animatedimage width="100@" height="100%" texture="/ui/elements/throb/throb.tga" noclick="true" loop="1" fps="30" onshow="StartAnim(1);" />-->
									<label height="100%" fitx="true" valign="center" textalign="left" textvalign="center" font="dyn_10" textcolor="white" shadow="false" color="white" watch="MatchInfoSummary" ontrigger="if(!stringempty(param0), SetText(Translate(param0)));">main_stats_retrieving_match</label>
								</panel>

								<panel height="2.4h" valign="bottom" color="invisible" noclick="1" watch="MatchInfoSummary" ontrigger="SetVisible(param21);">
									<instance
										name="button2" button_name="unnamedButton191"
										width="10.0h" height="2.4h"
										align="left"
										valign="center"
										label="main_stats_cancel"
										onclick="Call('main_stats_info_box', 'FadeOut(250);');"
									/>

									<instance
										name="button2" button_name="match_stats_retry_btn" visible="0"
										width="10.0h" height="2.4h"
										align="right"
										valign="center"
										label="main_stats_retry"
									/><!-- Moved to match_stats2.lua -->
								</panel>


							</panel>
						</panel>
						<instance
							name="header_bar"
							buttonsize="1.8h"
							height="2.4h"
							width="-2"
							y="1"
							align="center"
							lbl=""
							show_close="1"
							onclick="Call('main_stats_info_box', 'FadeOut(250);');"
						/>
					</panel>
				</panel>

				<!-- Left Col -->
				<panel x="4.3h" y="3.4h" width="19.2h" height="44.1h" align="left" color="invisible" noclick="1">

					<!-- Game Info -->
					<panel width="100%" height="18.8h" noclick="1" color="invisible">
						<frame color="0 0 0 1" bordercolor="#455166" borderthickness="1" noclick="1" />
						<panel y="0.2h" width="-1.8h" align="center" color="invisible" float="bottom" noclick="1">
							<label height="3.0h" textvalign="center" textalign="center" font="dyn_9" color="yellow" noclick="1" watch="MatchInfoSummary" ontrigger="if(StringEquals(param17, ''), ClearText()); if(param17 == 1, SetText(Translate('game_end_stats_victory_legion'))); if(param17 == 2, SetText(Translate('game_end_stats_victory_hellbourne')));"/>
							<instance name="match_info_entry" label="endstats_label_match_id" str="param1"/>
							<instance name="match_info_entry" label="endstats_label_map" str="TranslateOrEmpty('map_'..param25)" />
							<instance name="match_info_entry" label="endstats_label_date" str="param2"/>
							<instance name="match_info_entry" label="endstats_label_time" str="param3"/>
							<instance name="match_info_entry" label="endstats_label_server" str="param4"/>
							<instance name="match_info_entry" label="endstats_label_match_length" str="'' local p5 = tonumber(param5) if (p5 and (p5 > 0)) then str = FtoT(param5, 2) end"/>
							<instance name="match_info_entry" label="endstats_label_match_ver" str="param18"/>
						</panel>
						<panel
							name="winner_hidden"
							y="0.6h"
							width="-1.5h"
							height="2.4h"
							align="center"
							visible="1"
							color="invisible"
							noclick="1"
						>
							<instance
								name="button2" button_name="unnamedButton192"
								label="game_end_stats_show_winner"
								onclick="HideWidget('winner_hidden'); If(_end_game_stats_winner == 1, PlaySound('/shared/sounds/announcer/legion_wins.wav')); If(_end_game_stats_winner == 2, PlaySound('/shared/sounds/announcer/hellbourne_wins.wav'));"
								watch="MatchInfoSummary"
								ontrigger="
									ShowWidget('winner_hidden');
									Call('legion_concede', 'FadeOut(250);');
									Call('hellbourne_concede', 'FadeOut(250);');
									CreateInt('_end_game_stats_winner', param17);
									SetEnabled(param17 gt 0);
								"
							/>
						</panel>

					</panel>

					<!-- Previous Game List -->
					<panel width="100%" height="-19.5h" valign="bottom" noclick="1" color="invisible">
						<instance height="2.4h" name="header_bar" lbl="game_end_stats_recentgames" lbl_font="dyn_10" show_close="0" />
						<panel y="2.6h" height="-2.6h">
							<frame color="0 0 0 1" bordercolor="#455166" borderthickness="1" noclick="1" />

							<panel height="-1.0h" width="-1.0h" valign="center" align="center">
								<frame texture="/ui/info/backdrop.tga" borderthickness="4.0h" color="1 1 1 .5" noclick="1" />
								<listbox
									name="main_stats_listbox"
									x="0.1h"
									width="-2.1h"
									height="-0.4h"
									valign="center"
									color="invisible"
									font="dyn_10"
									itemwidth="100%"
									itemheight="2.5h"
									select="true"
									clearselection="true"
									hoverselect="false"
									hoverhighlight="true"
									highlight="under"
									highlightcolor="#46adff42"
									highlightbordercolor="invisible"
									selectedcolor="#346dff52"
									selectedbordercolor="invisible"
									backgroundimage="/ui/fe2/elements/comm_item_bg.tga"
									backgroundimagecolor="#1d2f3b"
									colortransition="true"
									colortransitiontime="250"
									exteriorscrollbars="true"
									scrollbarplaceholder="true"
									scrollbarsize="2.0h"
									scrolltexture="/ui/info/combobox.tga"
									handleheight="2.0h"
								/><!-- All actions moved to match_stats2.lua -->
							</panel>

						</panel>

						<panel name="stats_downloading_replay" color="0 0 0 0.9" visible="false" onframe="If(!ReplayDownloadInProgress(), HideWidget());" blockinput="true">
							<label align="center" textalign="center" textvalign="center" wrap="1" font="dyn_10" color="white" shadow="1" content="game_end_stats_download_in_progress" />
						</panel>
					</panel>
				</panel>

				<!-- Header Bar / Match ID / Options -->
				<panel y="0.2h" height="3.0h" align="center">
					<instance name="header_bar" show_close="1" onclick="PlaySound('/shared/sounds/ui/slide2.wav'); Set('_mainmenu_currentpanel', 'match_stats'); CallEvent('MainMenuPanelSwitcher');"/>
					<panel x="0.5h" height="100%" float="right" padding="1.0h" color="invisible" noclick="1">

						<panel align="left" width="50h" valign="center"  float="right" height="100%" padding="0.5h" x="3.5h" >
							<panel width="6h" sticky="true" stickytoinvis="false"
								visible="false"
								watch="matchstats_viewuser"
								ontrigger="
									SetVisible(
										!StringEmpty(param0)
									);
								"
								ontriggerlua="Match_Stats.OtherPlayerMatch = NotEmpty(param0)"
							>
								<instance
									name="button2" button_name="unnamedButton193"
									valign="center" height="-0.5h"
									label="general_back"
									onclick="Set('_mainmenu_currentpanel', 'player_stats'); CallEvent('MainMenuPanelSwitcher');"
								/>
							</panel>
							<label sticky="true" stickytoinvis="false" width="-6h" textvalign="center" font="dyn_12" color="white" shadow="1" noclick="1" watch="MatchInfoSummary" ontrigger="If(!StringEquals(param16, ''), SetText(Translate('endstats_label_match_name') # ' ' # param16), ClearText());"/>
						</panel>

						<panel name="endgame_stats_mode_panel" y="0.3h" x="-3.5h" width="100@" height="100%" align="right" color="invisible" noclick="1" float="right" padding="0.5h">
							<panel align="right" grow="true" regrow="true" growinvis="false" float="right" padding="0.5h" x="-0.5h" height="75%" valign="center">
								<image width="100@" height="100%" visible="false" sticky="true" stickytoinvis="false" watch="MatchInfoSummary" ontrigger="SetVisible(1); If(param33, Split(SetOnMouseover('ShowWidget(\'general_verified\');'), SetTexture('/ui/icons/verified.tga')), Split(SetOnMouseover('ShowWidget(\'general_basic\');'), SetTexture('/ui/icons/basic.tga')));" texture="/ui/icons/basic.tga"  onmouseout="HideWidget('general_verified'); HideWidget('general_basic');" onhide="HideWidget('general_verified'); HideWidget('general_basic');"/>
