							<image width="1.4h" height="1.4h" valign="center" rendermode="grayscale" texture="/ui/fe2/store/gold_coins.tga" />
						</panel>
					</panel>

					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/soulstealer/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/nomad/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/pollywogpriest/alt/hero.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/armadon/alt/icon.tga" />
				</panel>

				<label noclick="1" y="12.0h" color="#4c0e0e" font="dyn_9" shadow="true" shadowcolor="#a8815b" textalign="center" textvalign="top" content="ms_match_reward_special_2_3_page" />

				<instance
					name="button2" button_name="unnamedButton180"
					width="10.0h"
					height="2.0h"
					y="13.8h"
					align="center"
					label="ms_stats_tabs_view_all_items"
					onclick="ToggleWidget('match_replays_reward_event01');"
				/>

			</panel>
		</panel>
	</template>

	<template name="ms_rewards_reward_page_template_s_3" >
