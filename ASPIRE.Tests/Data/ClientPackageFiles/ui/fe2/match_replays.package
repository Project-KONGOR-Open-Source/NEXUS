						</panel>

						<panel y="7h" width="34h" height="3.5h" align="center" valign="center">
							<instance
									name="button2"
									align="center"
									valign="center"
									font="dyn_12"
									label="mastery_replay_jumptoplayerstats"
									onclick="Set('_player_stats_searchname', GetAccountName()); CallEvent('player_stats_submit');"
									onclicklua="Player_Stats.ClickedMyStats(true) GetWidget('player_stats_mastery'):SetVisible(1)"
									watch="HasValidMasteryReward"
									ontriggerlua="self:SetVisible(AtoB(param))"
									visible="0"
							/>
						</panel>

						<panel name="replay_mastery_error_popup" y="4h" width="30h" height="20h" align="center" valign="center" visible="0" watch="ReplayMasteryError" ontriggerlua="self:SetVisible(true)">
                 			<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
		    				<instance name="header_bar" height="2.4h" lbl="mastery_error_popup_title" lbl_font="dyn_11" show_close="1" onclicklua="GetWidget('replay_mastery_error_popup'):SetVisible(false)"/>
		    				<panel width="-1h" height="-3.5h" y="-0.5h" align="center" valign="bottom">
		    					<frame texture="/ui/frames/tooltip_bg.tga" color="#2c4b6c" noclick="1"/>
								<frame color="invisible" bordercolor="#455166" borderthickness="1" noclick="1" />

								<panel width="-1h" height="-6h" y="1h" color="1 1 1 .5" align="center" >
									<frame color="0 0 0 .8" bordercolor="#455166" borderthickness="1" noclick="1" />
									<panel width="-2h" height="-2h" align="center" valign="center">
										<label font="dyn_11" textvalign="center" textalign="center" noclick="true" color="white" content="" wrap="1" watch="ReplayMasteryError" ontriggerlua="self:SetText(param)"/>
									</panel>
								</panel>

								<instance name="button2" y="-1.5h" width="7h" height="2.5h" label="mastery_error_popup_confirm" align="center" valign="bottom" onclicklua="GetWidget('replay_mastery_error_popup'):SetVisible(false)"/>
		    				</panel>
       					</panel>
       				</panel>

       				<panel name="rank_reward" y="-5h" width="-4h" height="42.5h" noclick="1" align="right" color="0 0 0 1" valign="bottom" visible="1"
       					   onshowlua="GetWidget('mastery_reward_tabs_rewards_up'):SetTexture('/ui/fe2/mastery/tab_down.tga')
						   			  GetWidget('mastery_reward_tabs_rank_up'):SetTexture('/ui/fe2/mastery/tab_up.tga')
						              GetWidget('mastery_reward_tabs_mastery_up'):SetTexture('/ui/fe2/mastery/tab_down.tga')
						              GetWidget('mastery_reward_tabs_rewards_up_text'):SetColor('#595959')
						              GetWidget('mastery_reward_tabs_rank_up_text'):SetColor('white')
						              GetWidget('mastery_reward_tabs_mastery_up_text'):SetColor('#595959')

						              Match_Stats.RankInfo.step = 0
						              Match_Stats.RankInfo.timer = GetTime()
						              Match_Stats.RankInfo.displayMMR = Match_Stats.RankInfo.mmr_before
						              Match_Stats.RankInfo.displayMedal = Match_Stats.RankInfo.medal_before
						              Match_Stats.RankInfo.displayPlacement = 0
						              Match_Stats.RankInfo.displayLevelUp = false
						              Match_Stats.RankInfo.showRankPanel = Match_Stats.RankInfo.showRankPanel_origial
						              GetWidget('rank_reward_hasrank'):SetVisible(Match_Stats.RankInfo.showRankPanel)
						              GetWidget('rank_reward_hasnorank'):SetVisible(not Match_Stats.RankInfo.showRankPanel)"
						    onframelua="if Match_Stats.RankInfo.showRankPanel then
						    				Match_Stats.UpdateRankInfoPanel()
						    			else
						    				Match_Stats.UpdatePlacementMatchesPanel()
						    			end"
						    onhidelua="Match_Stats.RankInfo.needPopup = false">
       					<image texture="/ui/fe2/season/bg2.tga" align="center" valign="center" width="-4" height="-4"/>
       					<panel name="rank_reward_hasrank">
       						<image width="1024i" height="512i" texture="/ui/fe2/season/bg.tga" align="center" valign="center" noclick="1"/>

       						<panel height="40i" y="20i">
       							<image x="-140i" width="64i" height="64i" valign="center" align="center" texture="/ui/fe2/season/ms.tga" />
       							<image x="140i" width="64i" height="64i" valign="center" align="center" texture="/ui/fe2/season/ms.tga" hflip="1"/>
       							<label name="rank_reward_curret_text" font="dyn_24" textalign="center" textvalign="center" color="#ffbc3cbb"/>
       						</panel>
       						<panel align="center" valign="top" y="50i" width="308i" height="308i">
       							<panel name="rank_reward_curret_effect" noclick="1" visible="0">
									<modelpanel align="center"
												valign="center"
												height="300h"
												width="300h"
												noclick="true"
												anim="idle"
												camerapos="0 -1800 00"
												cameraangles="0 0 0"
												camerafov="35"
												modelangles="0 0 180"
												modelpos="0 0 0"
												lookat="0"
												visible="1"
												model="/shared/models/invis.mdf"
												effect="elements/store2/selectedeffect/item_image_bg.effect"
									/>
       							</panel>
       							<image name="rank_reward_curret_icon" texture="$invis" />
       						</panel>

       						<panel name="rank_reward_nextlevel_root" width="128i" height="128i" align="right" valign="center" x="-80i" y="70i">
       							<panel height="32i" y="-35i" align="center" valign="top">
       								<label content="mm3_season_next_rank" font="dyn_12" textalign="center" textvalign="center" color="#ffbc3cbb"/>
       							</panel>
       							<image texture="/ui/fe2/season/di.tga" />
       							<image name="rank_reward_next_text" width="+10i" height="+10i" align="center" valign="top" texture="$invis" />
       							<panel name="rank_reward_nextlevel_tips" onmouseoverlua="" onmouseoutlua="Trigger('genericMainFloatingTip', 'false', '', '', '', '', '', '', '', '')"/>
       						</panel>
       					<!-- progress bar -->
							<panel name="rank_reward_progressbar_root" width="1060i" height="32i" align="center" valign="bottom" y="-50i" noclick="1">
								<panel name="rank_reward_progressbar" y="9i" align="left" color="#7e35c2" width="100%" noclick="1"/>
								<image width="2048i" height="128i" align="center" valign="center" texture="/ui/fe2/season/jdt.tga" noclick="1" />
							</panel>

							<label name="rank_reward_debug" align="left" valign="bottom" x="5h" y="-85i" width="70h" height="4h" textvalign="center" textalign="left" font="dyn_14" noclick="1" color="white" content="abcde"/>
						</panel>
						<panel name="rank_reward_hasnorank" visible="0">
							<panel height="40i" y="20i">
       							<image width="1024i" height="64i" valign="center" align="center" texture="/ui/fe2/season/title.tga" />
       						</panel>
       						<panel align="center" valign="top" y="50i" width="308i" height="308i">
       							<image texture="/ui/fe2/season/nolevel.tga" rendermode="grayscale" />
