	<template name="playerstats_table">
		<panel width="100%" align="center" color="invisible" noclick="1">
			<panel
				height="2.0h"
				float="right"
				color="invisible"
				onload="CreateInt('_prev_button_state', 0);"
				noclick="1"
			>

				<instance
					name="stat_column_header_nosort"
					group="playerstats_header"
					width="7.0%"
					font="dyn_9"
					borderthickness=".4h"
				/>
				<instance
					name="stat_column_header_regular"
