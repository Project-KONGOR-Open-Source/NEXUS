					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/arachna/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/parasite/alt/icon.tga" />
					<image valign="center" width="4.5h" height="4.5h" texture="/heroes/monarch/alt2/icon.tga" />
				</panel>

				<label noclick="1" y="12.0h" color="#4c0e0e" font="dyn_9" shadow="true" shadowcolor="#a8815b" textalign="center" textvalign="top" content="ms_match_reward_special_3_3_page" />

				<instance
					name="button2" button_name="unnamedButton181"
					width="10.0h"
					height="2.0h"
					y="13.8h"
					align="center"
					label="ms_stats_tabs_view_all_items"
