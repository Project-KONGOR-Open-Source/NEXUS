@page "/password/update/{Token}"

@inject PortalAuthenticationService AuthenticationService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Confirm Password Update</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="portal-form-page">

    <MudText Typo="Typo.h4" Class="portal-form-page-title">Confirm Password Update</MudText>

    <MudCard Elevation="2" Class="portal-form-card">
        <MudCardContent>

            <MudText Typo="Typo.body2" Class="mb-4">
                Click the button below to confirm and activate your new password.
            </MudText>

        </MudCardContent>
        <MudCardActions Class="pa-4">
            <MudSpacer />
            <MudButton Disabled="Processing"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       OnClick="HandleConfirm">
                @if (Processing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processing ...</MudText>
                }
                else
                {
                    <MudText>Confirm Password Update</MudText>
                }
            </MudButton>
        </MudCardActions>
    </MudCard>

</MudContainer>

@code {

    [Parameter]
    public string? Token { get; set; }

    private bool Processing { get; set; }

    private async Task HandleConfirm()
    {
        Processing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAnonymousClient();

            ConfirmAccountPasswordUpdateRequest request = new(Token ?? string.Empty);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Update/Confirm", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                Snackbar.Add("Password successfully updated", Severity.Success);
                NavigationManager.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            Processing = false;
        }
    }
}
