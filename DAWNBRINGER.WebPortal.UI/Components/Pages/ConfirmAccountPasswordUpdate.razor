@page "/password/update/{Token}"

@inject PortalAuthenticationService AuthenticationService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Confirm Password Update - Project KONGOR</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Elevation="2" Class="pa-6">
        <MudCardContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5">Confirm Password Update</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    Click the button below to activate your new password for all future sign-ins.
                </MudText>
            </MudStack>

            <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="Processing"
                           OnClick="HandleConfirm">
                    @if (Processing)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <MudText>Confirming...</MudText>
                    }
                    else
                    {
                        <MudText>Confirm Password Update</MudText>
                    }
                </MudButton>
            </MudStack>
        </MudCardContent>
    </MudCard>

    <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4">
        <MudLink Href="/login">Return to log in</MudLink>
    </MudText>
</MudContainer>

@code {

    [Parameter]
    public string? Token { get; set; }

    private bool Processing { get; set; }

    private async Task HandleConfirm()
    {
        Processing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAnonymousClient();

            ConfirmAccountPasswordUpdateRequest request = new(Token ?? string.Empty);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Update/Confirm", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                Snackbar.Add("Password updated successfully.", Severity.Success);
                NavigationManager.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            Processing = false;
        }
    }
}
