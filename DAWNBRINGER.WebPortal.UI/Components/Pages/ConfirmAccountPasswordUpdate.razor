@page "/password/update/{Token}"

@inject PortalAuthenticationService AuthenticationService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Confirm Password Update</PageTitle>

<div class="portal-auth-page">
    <section class="portal-auth-shell">
        <div class="portal-auth-aside">
            <div class="portal-auth-crest-row">
                <div class="portal-auth-crest-shell">
                    <img src="images/portal-crest.svg" alt="Project KONGOR crest" class="portal-auth-crest" />
                </div>
                <div>
                    <div class="portal-auth-kicker">Project KONGOR Access</div>
                    <div class="portal-brand-title">Security Confirmation</div>
                </div>
            </div>

            <h1 class="portal-auth-display">Confirm Your New Password</h1>
            <p class="portal-auth-summary">
                Confirm the password change to activate your new password for all future sign-ins.
            </p>

            <ul class="portal-auth-points">
                <li>Your new password will become active after confirmation.</li>
                <li>You will be redirected to the sign-in page once complete.</li>
            </ul>
        </div>

        <div class="portal-auth-main">
            <div class="portal-auth-panel-heading">
                <div class="portal-section-kicker">Security</div>
                <h2 class="portal-form-page-title">Confirm Password Update</h2>
                <p class="portal-auth-panel-copy">Click the button below to confirm and activate your new password.</p>
            </div>

            <MudCard Elevation="0" Class="portal-form-card">
                <MudCardActions Class="pa-4">
                    <MudSpacer />
                    <MudButton Disabled="Processing"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               OnClick="HandleConfirm">
                        @if (Processing)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2">Processing ...</MudText>
                        }
                        else
                        {
                            <MudText>Confirm Password Update</MudText>
                        }
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </div>
    </section>
</div>

@code {

    [Parameter]
    public string? Token { get; set; }

    private bool Processing { get; set; }

    private async Task HandleConfirm()
    {
        Processing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAnonymousClient();

            ConfirmAccountPasswordUpdateRequest request = new(Token ?? string.Empty);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Update/Confirm", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                Snackbar.Add("Password successfully updated", Severity.Success);
                NavigationManager.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            Processing = false;
        }
    }
}
