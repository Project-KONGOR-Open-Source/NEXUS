@page "/account"

@attribute [Authorize]

@inject PortalAuthenticationService AuthenticationService
@inject ISnackbar Snackbar

<PageTitle>Account</PageTitle>

<div class="portal-account-page">
    <AuthorizeView Context="userContext">
        <Authorized>
            <section class="portal-account-shell">
                <div class="portal-account-hero">
                    <div class="portal-account-header">
                        <div class="portal-account-crest-shell">
                            <img src="images/portal-crest.svg" alt="Project KONGOR crest" class="portal-account-crest" />
                        </div>
                        <div>
                            <div class="portal-account-kicker">Project KONGOR Account</div>
                            <div class="portal-brand-title">Command Centre</div>
                        </div>
                    </div>

                    <h1 class="portal-account-title">@GetClaimValue("sub")</h1>
                    <p class="portal-account-summary">
                        Review your identity details, request credential changes, and keep your portal access aligned with the rebuilt shell.
                    </p>

                    <ul class="portal-account-points">
                        <li>Primary e-mail and role details are surfaced at a glance.</li>
                        <li>Security requests remain protected behind your current credentials.</li>
                        <li>All actions still use the same verified backend flows.</li>
                    </ul>

                    <div class="portal-account-stat-grid">
                        <article class="portal-account-stat-card">
                            <span class="portal-account-stat-label">Account Name</span>
                            <strong class="portal-account-stat-value">@GetClaimValue("sub")</strong>
                        </article>

                        <article class="portal-account-stat-card">
                            <span class="portal-account-stat-label">E-mail Address</span>
                            <strong class="portal-account-stat-value">@GetClaimValue("email")</strong>
                        </article>

                        <article class="portal-account-stat-card">
                            <span class="portal-account-stat-label">User Role</span>
                            <strong class="portal-account-stat-value">@GetClaimValue("user_role")</strong>
                        </article>

                        <article class="portal-account-stat-card">
                            <span class="portal-account-stat-label">Clan</span>
                            <strong class="portal-account-stat-value">@(string.IsNullOrWhiteSpace(GetClaimValue("clan_name")) ? "None" : GetClaimValue("clan_name"))</strong>
                        </article>
                    </div>
                </div>

                <div class="portal-account-management-grid">
                    <section class="portal-management-card">
                        <div>
                            <div class="portal-management-kicker">Identity</div>
                            <h2 class="portal-management-title">Update E-mail Address</h2>
                            <p class="portal-management-copy">Enter a new e-mail address below. A verification link will be sent to your new e-mail address.</p>
                        </div>

                        <EditForm Model="EmailUpdateFormModel" OnValidSubmit="HandleEmailUpdateSubmit">
                            <DataAnnotationsValidator />

                            <MudCard Elevation="0" Class="portal-form-card portal-account-card-surface">
                                <MudCardContent>
                                    <MudTextField Label="New Email Address"
                                                  HelperText="Enter your new email address"
                                                  Class="mt-3"
                                                  @bind-Value="EmailUpdateFormModel.EmailAddress"
                                                  For="() => EmailUpdateFormModel.EmailAddress"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Email"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Email" />

                                    <MudTextField Label="Confirm New Email Address"
                                                  HelperText="Type your new email address again for confirmation"
                                                  Class="mt-3"
                                                  @bind-Value="EmailUpdateFormModel.ConfirmEmailAddress"
                                                  For="() => EmailUpdateFormModel.ConfirmEmailAddress"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Email"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Email" />

                                    <MudTextField Label="Current Password"
                                                  HelperText="Enter your current password to confirm the change"
                                                  Class="mt-3"
                                                  @bind-Value="EmailUpdateFormModel.Password"
                                                  For="() => EmailUpdateFormModel.Password"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Password"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Lock" />
                                </MudCardContent>
                                <MudCardActions Class="pa-4">
                                    <MudSpacer />
                                    <MudButton Disabled="EmailUpdateProcessing"
                                               ButtonType="ButtonType.Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary">
                                        @if (EmailUpdateProcessing)
                                        {
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Processing ...</MudText>
                                        }
                                        else
                                        {
                                            <MudText>Request E-mail Update</MudText>
                                        }
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </EditForm>
                    </section>

                    <section class="portal-management-card">
                        <div>
                            <div class="portal-management-kicker">Security</div>
                            <h2 class="portal-management-title">Update Password</h2>
                            <p class="portal-management-copy">Choose a new password below. A confirmation link will be sent to your e-mail address to activate the change.</p>
                        </div>

                        <EditForm Model="PasswordUpdateFormModel" OnValidSubmit="HandlePasswordUpdateSubmit">
                            <DataAnnotationsValidator />

                            <MudCard Elevation="0" Class="portal-form-card portal-account-card-surface">
                                <MudCardContent>
                                    <MudTextField Label="Current Password"
                                                  HelperText="Enter your current password"
                                                  Class="mt-3"
                                                  @bind-Value="PasswordUpdateFormModel.CurrentPassword"
                                                  For="() => PasswordUpdateFormModel.CurrentPassword"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Password"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Lock" />

                                    <MudTextField Label="New Password"
                                                  HelperText="Choose a strong password at least 8 characters long"
                                                  Class="mt-3"
                                                  @bind-Value="PasswordUpdateFormModel.Password"
                                                  For="() => PasswordUpdateFormModel.Password"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Password"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.VpnKey" />

                                    <MudTextField Label="Confirm New Password"
                                                  HelperText="Type your new password again for confirmation"
                                                  Class="mt-3"
                                                  @bind-Value="PasswordUpdateFormModel.ConfirmPassword"
                                                  For="() => PasswordUpdateFormModel.ConfirmPassword"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Password" />
                                </MudCardContent>
                                <MudCardActions Class="pa-4">
                                    <MudSpacer />
                                    <MudButton Disabled="PasswordUpdateProcessing"
                                               ButtonType="ButtonType.Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary">
                                        @if (PasswordUpdateProcessing)
                                        {
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Processing ...</MudText>
                                        }
                                        else
                                        {
                                            <MudText>Request Password Update</MudText>
                                        }
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </EditForm>
                    </section>
                </div>
            </section>
        </Authorized>
    </AuthorizeView>
</div>

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private RequestEmailAddressUpdateFormModel EmailUpdateFormModel { get; set; } = new();
    private RequestAccountPasswordUpdateFormModel PasswordUpdateFormModel { get; set; } = new();

    private bool EmailUpdateProcessing { get; set; }
    private bool PasswordUpdateProcessing { get; set; }

    private string GetClaimValue(string claimType)
    {
        if (AuthenticationStateTask is null)
            return string.Empty;

        AuthenticationState authenticationState = AuthenticationStateTask.Result;

        return authenticationState.User.Claims
            .SingleOrDefault(claim => claim.Type.Equals(claimType))?.Value ?? string.Empty;
    }

    private async Task HandleEmailUpdateSubmit()
    {
        EmailUpdateProcessing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();

            RequestEmailAddressUpdateRequest request = new(EmailUpdateFormModel.EmailAddress, EmailUpdateFormModel.Password);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Email/Update/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                EmailUpdateFormModel = new RequestEmailAddressUpdateFormModel();
                Snackbar.Add("Email address update successfully requested", Severity.Success);
                Snackbar.Add("Check your email inbox to continue", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            EmailUpdateProcessing = false;
        }
    }

    private async Task HandlePasswordUpdateSubmit()
    {
        PasswordUpdateProcessing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();

            RequestAccountPasswordUpdateRequest request = new(PasswordUpdateFormModel.CurrentPassword, PasswordUpdateFormModel.Password, PasswordUpdateFormModel.ConfirmPassword);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Update/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                PasswordUpdateFormModel = new RequestAccountPasswordUpdateFormModel();
                Snackbar.Add("Password update successfully requested", Severity.Success);
                Snackbar.Add("Check your email inbox to continue", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            PasswordUpdateProcessing = false;
        }
    }
}
