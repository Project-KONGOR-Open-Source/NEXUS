@page "/account"

@attribute [Authorize]

@inject PortalAuthenticationService AuthenticationService
@inject ISnackbar Snackbar

<PageTitle>Account</PageTitle>

<div class="portal-account-page">
    <AuthorizeView Context="userContext">
        <Authorized>
            @if (LoadingAccountOverview)
            {
                <section class="portal-account-shell">
                    <div class="portal-account-hero portal-account-hero-loading">
                        <MudProgressCircular Size="Size.Large" Color="Color.Primary" Indeterminate="true" />
                        <p class="portal-account-summary">Loading your account overview.</p>
                    </div>
                </section>
            }
            else if (AccountOverview is null)
            {
                <section class="portal-account-shell">
                    <div class="portal-account-hero portal-account-hero-loading">
                        <h1 class="portal-account-title">Account Unavailable</h1>
                        <p class="portal-account-summary">The account overview could not be loaded right now. Please refresh and try again.</p>
                    </div>
                </section>
            }
            else
            {
                <section class="portal-account-shell">
                    <div class="portal-account-hero">
                        <div class="portal-account-hero-top">
                            <div>
                                <div class="portal-account-kicker">Current Account</div>
                                <h1 class="portal-account-title">@AccountOverview.CurrentAccountName</h1>
                            </div>
                        </div>

                        <div class="portal-account-stat-grid">
                            <article class="portal-account-stat-card">
                                <span class="portal-account-stat-label">E-mail Address</span>
                                <strong class="portal-account-stat-value">@AccountOverview.EmailAddress</strong>
                            </article>

                            <article class="portal-account-stat-card">
                                <span class="portal-account-stat-label">User Role</span>
                                <strong class="portal-account-stat-value">@AccountOverview.Role</strong>
                            </article>

                            <article class="portal-account-stat-card">
                                <span class="portal-account-stat-label">Member Since</span>
                                <strong class="portal-account-stat-value">@FormatTimestamp(AccountOverview.TimestampCreated)</strong>
                            </article>

                            <article class="portal-account-stat-card">
                                <span class="portal-account-stat-label">Account Level</span>
                                <strong class="portal-account-stat-value">@AccountOverview.CurrentAccountLevel</strong>
                            </article>
                        </div>
                    </div>

                    <section class="portal-management-card portal-account-overview-card">
                        <div>
                            <h2 class="portal-management-title">Sibling Accounts</h2>
                            <p class="portal-management-copy">All accounts linked to this user, including whether each account is the main account and which clan it belongs to.</p>
                        </div>

                        <div class="portal-account-table-wrapper">
                            <table class="portal-account-table">
                                <thead>
                                    <tr>
                                        <th>Account Name</th>
                                        <th>Main Account</th>
                                        <th>Clan</th>
                                        <th>Clan Tag</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (UserAccountResponse account in AccountOverview.Accounts)
                                    {
                                        <tr>
                                            <td>@account.Name</td>
                                            <td>
                                                <span class="portal-account-table-badge @(account.IsMain ? "portal-account-table-badge-main" : "portal-account-table-badge-secondary")">
                                                    @GetMainAccountLabel(account.IsMain)
                                                </span>
                                            </td>
                                            <td>@GetDisplayValue(account.ClanName)</td>
                                            <td>@GetDisplayValue(account.ClanTag)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <div class="portal-account-management-grid">
                        <section class="portal-management-card">
                        <div>
                            <h2 class="portal-management-title">Update E-mail Address</h2>
                            <p class="portal-management-copy">Enter a new e-mail address below. A verification link will be sent to your new e-mail address.</p>
                        </div>

                        <EditForm Model="EmailUpdateFormModel" OnValidSubmit="HandleEmailUpdateSubmit">
                            <DataAnnotationsValidator />

                            <MudCard Elevation="0" Class="portal-form-card portal-account-card-surface">
                                <MudCardContent>
                                    <MudTextField Label="New E-mail Address"
                                                  HelperText="Enter your new e-mail address"
                                                  Class="mt-3"
                                                  @bind-Value="EmailUpdateFormModel.EmailAddress"
                                                  For="() => EmailUpdateFormModel.EmailAddress"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Email"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Email" />

                                    <MudTextField Label="Confirm New E-mail Address"
                                                  HelperText="Type your new e-mail address again for confirmation"
                                                  Class="mt-3"
                                                  @bind-Value="EmailUpdateFormModel.ConfirmEmailAddress"
                                                  For="() => EmailUpdateFormModel.ConfirmEmailAddress"
                                                  Variant="Variant.Outlined"
                                                  InputType="InputType.Email"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Email" />

                                    <div class="portal-input-with-visibility mt-3">
                                        <MudTextField Label="Current Password"
                                                      HelperText="Enter your current password to confirm the change"
                                                      @bind-Value="EmailUpdateFormModel.Password"
                                                      For="() => EmailUpdateFormModel.Password"
                                                      Variant="Variant.Outlined"
                                                      InputType="@GetPasswordInputType(EmailUpdatePasswordVisible)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Lock" />
                                        <button type="button" class="portal-password-visibility-button" @onclick="ToggleEmailUpdatePasswordVisibility" aria-label="Toggle current password visibility">
                                            <MudIcon Icon="@GetPasswordVisibilityIcon(EmailUpdatePasswordVisible)" />
                                        </button>
                                    </div>
                                </MudCardContent>
                                <MudCardActions Class="pa-4">
                                    <MudSpacer />
                                    <MudButton Disabled="EmailUpdateProcessing"
                                               ButtonType="ButtonType.Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary">
                                        @if (EmailUpdateProcessing)
                                        {
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Processing ...</MudText>
                                        }
                                        else
                                        {
                                            <MudText>Request E-mail Update</MudText>
                                        }
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </EditForm>
                        </section>

                        <section class="portal-management-card">
                        <div>
                            <h2 class="portal-management-title">Update Password</h2>
                            <p class="portal-management-copy">Choose a new password below. A confirmation link will be sent to your e-mail address to activate the change.</p>
                        </div>

                        <EditForm Model="PasswordUpdateFormModel" OnValidSubmit="HandlePasswordUpdateSubmit">
                            <DataAnnotationsValidator />

                            <MudCard Elevation="0" Class="portal-form-card portal-account-card-surface">
                                <MudCardContent>
                                    <div class="portal-input-with-visibility mt-3">
                                        <MudTextField Label="Current Password"
                                                      HelperText="Enter your current password"
                                                      @bind-Value="PasswordUpdateFormModel.CurrentPassword"
                                                      For="() => PasswordUpdateFormModel.CurrentPassword"
                                                      Variant="Variant.Outlined"
                                                      InputType="@GetPasswordInputType(CurrentPasswordVisible)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Lock" />
                                        <button type="button" class="portal-password-visibility-button" @onclick="ToggleCurrentPasswordVisibility" aria-label="Toggle current password visibility">
                                            <MudIcon Icon="@GetPasswordVisibilityIcon(CurrentPasswordVisible)" />
                                        </button>
                                    </div>

                                    <div class="portal-input-with-visibility mt-3">
                                        <MudTextField Label="New Password"
                                                      HelperText="Choose a strong password at least 8 characters long"
                                                      @bind-Value="PasswordUpdateFormModel.Password"
                                                      For="() => PasswordUpdateFormModel.Password"
                                                      Variant="Variant.Outlined"
                                                      InputType="@GetPasswordInputType(NewPasswordVisible)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.VpnKey" />
                                        <button type="button" class="portal-password-visibility-button" @onclick="ToggleNewPasswordVisibility" aria-label="Toggle new password visibility">
                                            <MudIcon Icon="@GetPasswordVisibilityIcon(NewPasswordVisible)" />
                                        </button>
                                    </div>

                                    <div class="portal-input-with-visibility mt-3">
                                        <MudTextField Label="Confirm New Password"
                                                      HelperText="Type your new password again for confirmation"
                                                      @bind-Value="PasswordUpdateFormModel.ConfirmPassword"
                                                      For="() => PasswordUpdateFormModel.ConfirmPassword"
                                                      Variant="Variant.Outlined"
                                                      InputType="@GetPasswordInputType(ConfirmPasswordVisible)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.VpnKey" />
                                        <button type="button" class="portal-password-visibility-button" @onclick="ToggleConfirmPasswordVisibility" aria-label="Toggle confirm new password visibility">
                                            <MudIcon Icon="@GetPasswordVisibilityIcon(ConfirmPasswordVisible)" />
                                        </button>
                                    </div>
                                </MudCardContent>
                                <MudCardActions Class="pa-4">
                                    <MudSpacer />
                                    <MudButton Disabled="PasswordUpdateProcessing"
                                               ButtonType="ButtonType.Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary">
                                        @if (PasswordUpdateProcessing)
                                        {
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Processing ...</MudText>
                                        }
                                        else
                                        {
                                            <MudText>Request Password Update</MudText>
                                        }
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </EditForm>
                        </section>
                    </div>
                </section>
            }
        </Authorized>
    </AuthorizeView>
</div>

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private RequestEmailAddressUpdateFormModel EmailUpdateFormModel { get; set; } = new();
    private RequestAccountPasswordUpdateFormModel PasswordUpdateFormModel { get; set; } = new();

    private UserResponse? AccountOverview { get; set; }

    private bool EmailUpdateProcessing { get; set; }
    private bool PasswordUpdateProcessing { get; set; }
    private bool LoadingAccountOverview { get; set; } = true;

    private bool EmailUpdatePasswordVisible { get; set; }
    private bool CurrentPasswordVisible { get; set; }
    private bool NewPasswordVisible { get; set; }
    private bool ConfirmPasswordVisible { get; set; }

    private static InputType GetPasswordInputType(bool passwordVisible)
    {
        return passwordVisible ? InputType.Text : InputType.Password;
    }

    private static string GetPasswordVisibilityIcon(bool passwordVisible)
    {
        return passwordVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    }

    private void ToggleEmailUpdatePasswordVisibility()
    {
        EmailUpdatePasswordVisible = !EmailUpdatePasswordVisible;
    }

    private void ToggleCurrentPasswordVisibility()
    {
        CurrentPasswordVisible = !CurrentPasswordVisible;
    }

    private void ToggleNewPasswordVisibility()
    {
        NewPasswordVisible = !NewPasswordVisible;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        ConfirmPasswordVisible = !ConfirmPasswordVisible;
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null)
        {
            LoadingAccountOverview = false;
            return;
        }

        AuthenticationState authenticationState = await AuthenticationStateTask;

        string? userIDClaimValue = authenticationState.User.Claims.SingleOrDefault(claim => claim.Type.Equals("user_id"))?.Value;

        if (int.TryParse(userIDClaimValue, out int userID).Equals(false))
        {
            LoadingAccountOverview = false;
            Snackbar.Add("Unable to determine the authenticated user.", Severity.Error);
            return;
        }

        await LoadAccountOverview(userID);
    }

    private async Task LoadAccountOverview(int userID)
    {
        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();
            HttpResponseMessage response = await client.GetAsync($"/User/{userID}");

            if (response.StatusCode is HttpStatusCode.OK)
            {
                AccountOverview = await response.Content.ReadFromJsonAsync<UserResponse>();
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        catch (NotSupportedException)
        {
            Snackbar.Add("The account overview response format is not supported.", Severity.Error);
        }
        catch (JsonException)
        {
            Snackbar.Add("The account overview response could not be read.", Severity.Error);
        }
        finally
        {
            LoadingAccountOverview = false;
        }
    }

    private static string GetDisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string GetMainAccountLabel(bool isMain)
    {
        return isMain ? "Yes" : "No";
    }

    private static string FormatTimestamp(DateTimeOffset timestamp)
    {
        return timestamp.ToString("dd MMM yyyy");
    }

    private async Task HandleEmailUpdateSubmit()
    {
        EmailUpdateProcessing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();

            RequestEmailAddressUpdateRequest request = new(EmailUpdateFormModel.EmailAddress, EmailUpdateFormModel.Password);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Email/Update/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                EmailUpdateFormModel = new RequestEmailAddressUpdateFormModel();
                Snackbar.Add("Email address update successfully requested", Severity.Success);
                Snackbar.Add("Check your email inbox to continue", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            EmailUpdateProcessing = false;
        }
    }

    private async Task HandlePasswordUpdateSubmit()
    {
        PasswordUpdateProcessing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();

            RequestAccountPasswordUpdateRequest request = new(PasswordUpdateFormModel.CurrentPassword, PasswordUpdateFormModel.Password, PasswordUpdateFormModel.ConfirmPassword);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Update/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                PasswordUpdateFormModel = new RequestAccountPasswordUpdateFormModel();
                Snackbar.Add("Password update successfully requested", Severity.Success);
                Snackbar.Add("Check your email inbox to continue", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            PasswordUpdateProcessing = false;
        }
    }
}
