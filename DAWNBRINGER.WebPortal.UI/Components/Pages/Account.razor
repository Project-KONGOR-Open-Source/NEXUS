@page "/account"

@attribute [Authorize]

@inject PortalAuthenticationService AuthenticationService
@inject ISnackbar Snackbar

<PageTitle>Account - Project KONGOR</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="px-4 px-sm-6 pt-8">
    <AuthorizeView Context="authContext">
        <Authorized>
            @if (LoadingAccountOverview)
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-16">
                    <MudProgressCircular Size="Size.Large" Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary">Loading account overview...</MudText>
                </MudStack>
            }
            else if (AccountOverview is null)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                    Unable to load account overview. Please refresh the page and try again.
                </MudAlert>
            }
            else
            {
                @* Account Header *@
                <MudCard Class="glass-card pa-6 mb-6 animate-fade-in" Elevation="0">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Current Account</MudText>
                        <MudText Typo="Typo.h4" Class="account-name-glow" Color="Color.Primary">@DisplayName</MudText>

                        <MudGrid Spacing="3" Class="mt-4">
                            <MudItem xs="6" sm="3">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Email Address</MudText>
                                    <MudText Typo="Typo.body1">@AccountOverview.EmailAddress</MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">User Role</MudText>
                                    <MudText Typo="Typo.body1">@AccountOverview.Role</MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Member Since</MudText>
                                    <MudText Typo="Typo.body1">@FormatTimestamp(AccountOverview.TimestampCreated)</MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Account Level</MudText>
                                    <MudText Typo="Typo.body1">@AccountOverview.CurrentAccountLevel</MudText>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudStack>
                </MudCard>

                @* Sibling Accounts Table *@
                <MudCard Class="glass-card pa-6 mb-6 animate-fade-in-delay-1" Elevation="0">
                    <MudStack Spacing="2" Class="mb-4">
                        <MudText Typo="Typo.h6">Sibling Accounts</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            All accounts linked to this user, including clan membership.
                        </MudText>
                    </MudStack>

                    <MudTable Items="@AccountOverview.Accounts" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Account Name</MudTh>
                            <MudTh>Account Type</MudTh>
                            <MudTh>Main Account</MudTh>
                            <MudTh>Clan</MudTh>
                            <MudTh>Clan Tag</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Account Name">@context.Name</MudTd>
                            <MudTd DataLabel="Account Type">@context.AccountType.ToUpperInvariant()</MudTd>
                            <MudTd DataLabel="Main Account">
                                @if (context.IsMain)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Yes</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">No</MudChip>
                                }
                            </MudTd>
                            <MudTd DataLabel="Clan">@GetDisplayValue(context.ClanName)</MudTd>
                            <MudTd DataLabel="Clan Tag">@GetDisplayValue(context.ClanTag)</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudCard>

                @* Update Forms Row *@
                <MudGrid Spacing="4">
                    @* Update Email Form *@
                    <MudItem xs="12" md="6">
                        <MudCard Class="glass-card pa-4 animate-fade-in-delay-2" Elevation="0" Style="height: 100%;">
                            <MudCardContent>
                                <MudStack Spacing="2" Class="mb-4">
                                    <MudText Typo="Typo.h6">Update Email Address</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        A verification link will be sent to your new email address.
                                    </MudText>
                                </MudStack>

                                <EditForm Model="EmailUpdateFormModel" OnValidSubmit="HandleEmailUpdateSubmit">
                                    <DataAnnotationsValidator />

                                    <MudStack Spacing="3">
                                        <MudTextField @bind-Value="EmailUpdateFormModel.EmailAddress"
                                                      For="@(() => EmailUpdateFormModel.EmailAddress)"
                                                      Label="New Email Address"
                                                      HelperText="A valid email address you have access to."
                                                      Variant="Variant.Outlined"
                                                      InputType="InputType.Email"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Email" />

                                        <MudTextField @bind-Value="EmailUpdateFormModel.ConfirmEmailAddress"
                                                      For="@(() => EmailUpdateFormModel.ConfirmEmailAddress)"
                                                      Label="Confirm New Email Address"
                                                      HelperText="Enter the same email address again for confirmation."
                                                      Variant="Variant.Outlined"
                                                      InputType="InputType.Email"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Email" />

                                        <MudTextField @bind-Value="EmailUpdateFormModel.Password"
                                                      For="@(() => EmailUpdateFormModel.Password)"
                                                      Label="Current Password"
                                                      HelperText="Your current password to confirm the change."
                                                      Variant="Variant.Outlined"
                                                      InputType="@EmailPasswordInputType"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@EmailPasswordVisibilityIcon"
                                                      OnAdornmentClick="ToggleEmailPasswordVisibility"
                                                      AdornmentAriaLabel="Toggle password visibility" />

                                        <MudStack Row="true" Justify="Justify.FlexEnd">
                                            <MudButton ButtonType="ButtonType.Submit"
                                                       Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Class="glow-button"
                                                       Disabled="EmailUpdateProcessing">
                                                @if (EmailUpdateProcessing)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                                    <MudText>Requesting...</MudText>
                                                }
                                                else
                                                {
                                                    <MudText>Request Email Update</MudText>
                                                }
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>
                                </EditForm>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    @* Update Password Form *@
                    <MudItem xs="12" md="6">
                        <MudCard Class="glass-card pa-4 animate-fade-in-delay-2" Elevation="0" Style="height: 100%;">
                            <MudCardContent>
                                <MudStack Spacing="2" Class="mb-4">
                                    <MudText Typo="Typo.h6">Update Password</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        A confirmation link will be sent to your email address.
                                    </MudText>
                                </MudStack>

                                <EditForm Model="PasswordUpdateFormModel" OnValidSubmit="HandlePasswordUpdateSubmit">
                                    <DataAnnotationsValidator />

                                    <MudStack Spacing="3">
                                        <MudTextField @bind-Value="PasswordUpdateFormModel.CurrentPassword"
                                                      For="@(() => PasswordUpdateFormModel.CurrentPassword)"
                                                      Label="Current Password"
                                                      HelperText="Your current password."
                                                      Variant="Variant.Outlined"
                                                      InputType="@CurrentPasswordInputType"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@CurrentPasswordVisibilityIcon"
                                                      OnAdornmentClick="ToggleCurrentPasswordVisibility"
                                                      AdornmentAriaLabel="Toggle password visibility" />

                                        <MudTextField @bind-Value="PasswordUpdateFormModel.Password"
                                                      For="@(() => PasswordUpdateFormModel.Password)"
                                                      Label="New Password"
                                                      HelperText="At least 8 characters long."
                                                      Variant="Variant.Outlined"
                                                      InputType="@NewPasswordInputType"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@NewPasswordVisibilityIcon"
                                                      OnAdornmentClick="ToggleNewPasswordVisibility"
                                                      AdornmentAriaLabel="Toggle password visibility" />

                                        <MudTextField @bind-Value="PasswordUpdateFormModel.ConfirmPassword"
                                                      For="@(() => PasswordUpdateFormModel.ConfirmPassword)"
                                                      Label="Confirm New Password"
                                                      HelperText="Enter the same password again for confirmation."
                                                      Variant="Variant.Outlined"
                                                      InputType="@ConfirmPasswordInputType"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@ConfirmPasswordVisibilityIcon"
                                                      OnAdornmentClick="ToggleConfirmPasswordVisibility"
                                                      AdornmentAriaLabel="Toggle password visibility" />

                                        <MudStack Row="true" Justify="Justify.FlexEnd">
                                            <MudButton ButtonType="ButtonType.Submit"
                                                       Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Class="glow-button"
                                                       Disabled="PasswordUpdateProcessing">
                                                @if (PasswordUpdateProcessing)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                                    <MudText>Requesting...</MudText>
                                                }
                                                else
                                                {
                                                    <MudText>Request Password Update</MudText>
                                                }
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>
                                </EditForm>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            }
        </Authorized>
    </AuthorizeView>
</MudContainer>

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private RequestEmailAddressUpdateFormModel EmailUpdateFormModel { get; set; } = new ();
    private RequestAccountPasswordUpdateFormModel PasswordUpdateFormModel { get; set; } = new ();

    private UserResponse? AccountOverview { get; set; }

    private bool EmailUpdateProcessing { get; set; }
    private bool PasswordUpdateProcessing { get; set; }
    private bool LoadingAccountOverview { get; set; } = true;

    private bool EmailPasswordVisible { get; set; }
    private bool CurrentPasswordVisible { get; set; }
    private bool NewPasswordVisible { get; set; }
    private bool ConfirmPasswordVisible { get; set; }

    private string DisplayName => string.IsNullOrWhiteSpace(AccountOverview?.CurrentClanTag)
        ? AccountOverview?.CurrentAccountName ?? string.Empty
        : $"[{AccountOverview.CurrentClanTag}]{AccountOverview.CurrentAccountName}";

    private InputType EmailPasswordInputType => EmailPasswordVisible ? InputType.Text : InputType.Password;
    private InputType CurrentPasswordInputType => CurrentPasswordVisible ? InputType.Text : InputType.Password;
    private InputType NewPasswordInputType => NewPasswordVisible ? InputType.Text : InputType.Password;
    private InputType ConfirmPasswordInputType => ConfirmPasswordVisible ? InputType.Text : InputType.Password;

    private string EmailPasswordVisibilityIcon => EmailPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string CurrentPasswordVisibilityIcon => CurrentPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string NewPasswordVisibilityIcon => NewPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string ConfirmPasswordVisibilityIcon => ConfirmPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private void ToggleEmailPasswordVisibility() => EmailPasswordVisible = !EmailPasswordVisible;
    private void ToggleCurrentPasswordVisibility() => CurrentPasswordVisible = !CurrentPasswordVisible;
    private void ToggleNewPasswordVisibility() => NewPasswordVisible = !NewPasswordVisible;
    private void ToggleConfirmPasswordVisibility() => ConfirmPasswordVisible = !ConfirmPasswordVisible;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null)
        {
            LoadingAccountOverview = false;
            return;
        }

        AuthenticationState authenticationState = await AuthenticationStateTask;

        string? userIDClaimValue = authenticationState.User.Claims.SingleOrDefault(claim => claim.Type.Equals("user_id"))?.Value;

        if (int.TryParse(userIDClaimValue, out int userID) is false)
        {
            LoadingAccountOverview = false;
            Snackbar.Add("Unable to determine the authenticated user.", Severity.Error);
            return;
        }

        await LoadAccountOverview(userID);
    }

    private async Task LoadAccountOverview(int userID)
    {
        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();
            HttpResponseMessage response = await client.GetAsync($"/User/{userID}");

            if (response.StatusCode is HttpStatusCode.OK)
            {
                AccountOverview = await response.Content.ReadFromJsonAsync<UserResponse>();
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        catch (NotSupportedException)
        {
            Snackbar.Add("The account overview response format is not supported.", Severity.Error);
        }
        catch (JsonException)
        {
            Snackbar.Add("The account overview response could not be read.", Severity.Error);
        }
        finally
        {
            LoadingAccountOverview = false;
        }
    }

    private static string GetDisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string FormatTimestamp(DateTimeOffset timestamp)
    {
        return timestamp.ToString("dd MMM yyyy");
    }

    private async Task HandleEmailUpdateSubmit()
    {
        EmailUpdateProcessing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();

            RequestEmailAddressUpdateRequest request = new (EmailUpdateFormModel.EmailAddress, EmailUpdateFormModel.Password);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Email/Update/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                string newEmailAddress = EmailUpdateFormModel.EmailAddress;
                EmailUpdateFormModel = new RequestEmailAddressUpdateFormModel();
                Snackbar.Add("Email update requested successfully.", Severity.Success);
                Snackbar.Add($"A verification link has been sent to {newEmailAddress}.", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            EmailUpdateProcessing = false;
        }
    }

    private async Task HandlePasswordUpdateSubmit()
    {
        PasswordUpdateProcessing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAuthenticatedClient();

            RequestAccountPasswordUpdateRequest request = new (PasswordUpdateFormModel.CurrentPassword, PasswordUpdateFormModel.Password, PasswordUpdateFormModel.ConfirmPassword);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Update/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                PasswordUpdateFormModel = new RequestAccountPasswordUpdateFormModel();
                Snackbar.Add("Password update requested successfully.", Severity.Success);
                Snackbar.Add($"A confirmation link has been sent to {AccountOverview!.EmailAddress}.", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            PasswordUpdateProcessing = false;
        }
    }
}
