@page "/recover"

@inject PortalAuthenticationService AuthenticationService
@inject ISnackbar Snackbar

<PageTitle>Forgotten Password - Project KONGOR</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudCard Elevation="2" Class="pa-6">
        <MudCardContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5">Forgotten Password</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    Enter your email address to receive a new password. A confirmation link will be sent to your inbox.
                </MudText>
            </MudStack>

            <EditForm Model="FormModel" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <MudTextField @bind-Value="FormModel.EmailAddress"
                                  For="@(() => FormModel.EmailAddress)"
                                  Label="Email Address"
                                  HelperText="The email address associated with your account."
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email" />

                    <MudTextField @bind-Value="FormModel.ConfirmEmailAddress"
                                  For="@(() => FormModel.ConfirmEmailAddress)"
                                  Label="Confirm Email Address"
                                  HelperText="Enter the same email address again for confirmation."
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email" />

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudLink Href="/login" Typo="Typo.body2">Back to log in</MudLink>
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="Processing">
                            @if (Processing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <MudText>Requesting...</MudText>
                            }
                            else
                            {
                                <MudText>Request Password Reset</MudText>
                            }
                        </MudButton>
                    </MudStack>
                </MudStack>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {

    private RequestPasswordResetFormModel FormModel { get; set; } = new();

    private bool Processing { get; set; }

    private async Task HandleValidSubmit()
    {
        Processing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAnonymousClient();

            RequestAccountPasswordResetRequest request = new(FormModel.EmailAddress);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Reset/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                FormModel = new RequestPasswordResetFormModel();
                Snackbar.Add("Password reset requested successfully.", Severity.Success);
                Snackbar.Add("Check your inbox for the new password and confirmation link.", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            Processing = false;
        }
    }
}
