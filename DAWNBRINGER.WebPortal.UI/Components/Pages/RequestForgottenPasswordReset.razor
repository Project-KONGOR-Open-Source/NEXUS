@page "/recover"

@inject PortalAuthenticationService AuthenticationService
@inject ISnackbar Snackbar

<PageTitle>Request Forgotten Password Reset</PageTitle>

<div class="portal-auth-page">
    <section class="portal-auth-shell">
        <div class="portal-auth-aside">
            <div class="portal-auth-crest-row">
                <div class="portal-auth-crest-shell">
                    <img src="images/portal-crest.svg" alt="Project KONGOR crest" class="portal-auth-crest" />
                </div>
                <div>
                    <div class="portal-auth-kicker">Project KONGOR Access</div>
                    <div class="portal-brand-title">Account Recovery</div>
                </div>
            </div>

            <h1 class="portal-auth-display">Reset Your Password</h1>
            <p class="portal-auth-summary">
                Forgotten your password? Enter the e-mail address linked to your account and a new password will be generated and sent to you.
            </p>

            <ul class="portal-auth-points">
                <li>Enter the e-mail address associated with your account.</li>
                <li>A new password will be generated and sent to your inbox.</li>
                <li>Confirm the reset from your e-mail to activate the new password.</li>
            </ul>
        </div>

        <div class="portal-auth-main">
            <div class="portal-auth-panel-heading">
                <div class="portal-section-kicker">Recovery</div>
                <h2 class="portal-form-page-title">Forgotten Password</h2>
                <p class="portal-auth-panel-copy">Enter the e-mail address associated with your account. A new random password will be generated and sent to your inbox along with a confirmation link.</p>
            </div>

            <EditForm Model="FormModel" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <MudCard Elevation="0" Class="portal-form-card">
                    <MudCardContent>
                        <MudTextField Label="Email Address"
                                      HelperText="Enter the email address associated with your account"
                                      Class="mt-3"
                                      @bind-Value="FormModel.EmailAddress"
                                      For="() => FormModel.EmailAddress"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Email"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email" />

                        <MudTextField Label="Confirm Email Address"
                                      HelperText="Type your email address again for confirmation"
                                      Class="mt-3"
                                      @bind-Value="FormModel.ConfirmEmailAddress"
                                      For="() => FormModel.ConfirmEmailAddress"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Email"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email" />
                    </MudCardContent>
                    <MudCardActions Class="pa-4">
                        <MudButton Href="/login"
                                   Variant="Variant.Text"
                                   Color="Color.Default"
                                   Size="Size.Small">
                            Back To Log In
                        </MudButton>
                        <MudSpacer />
                        <MudButton Disabled="Processing"
                                   ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large">
                            @if (Processing)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">Processing ...</MudText>
                            }
                            else
                            {
                                <MudText>Request Password Reset</MudText>
                            }
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </EditForm>
        </div>
    </section>
</div>

@code {

    private RequestPasswordResetFormModel FormModel { get; set; } = new();

    private bool Processing { get; set; }

    private async Task HandleValidSubmit()
    {
        Processing = true;

        try
        {
            HttpClient client = AuthenticationService.CreateAnonymousClient();

            RequestAccountPasswordResetRequest request = new(FormModel.EmailAddress);

            HttpResponseMessage response = await client.PostAsJsonAsync("/Password/Reset/Request", request);

            if (response.StatusCode is HttpStatusCode.OK)
            {
                FormModel = new RequestPasswordResetFormModel();
                Snackbar.Add("Password reset successfully requested", Severity.Success);
                Snackbar.Add("Check your email inbox to continue", Severity.Info);
            }
            else
            {
                string errorMessage = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to reach the server. Please try again later.", Severity.Error);
        }
        finally
        {
            Processing = false;
        }
    }
}
