@page "/"

<PageTitle>Project KONGOR</PageTitle>

<HeadContent>
    <meta name="description" content="Project KONGOR is a community-driven revival of Heroes of Newerth. Create an account, download the client, and join the community." />
</HeadContent>

<div class="portal-home-page">
    <section class="portal-hero-section" id="top">
        <div class="portal-hero-copy">
            <div class="portal-section-kicker">Project KONGOR</div>
            <h1 class="portal-hero-title">Welcome To Project KONGOR</h1>
            <p class="portal-hero-summary">
                The community-driven revival of Heroes of Newerth. Create an account, download the client, and return to the land of Newerth.
            </p>

            <div class="portal-hero-actions">
                <AuthorizeView>
                    <NotAuthorized>
                        <a href="/register" class="portal-call-to-action">Create Account</a>
                        <a href="/login" class="portal-secondary-action">Log In</a>
                    </NotAuthorized>

                    <Authorized>
                        <a href="/account" class="portal-call-to-action">Open Account</a>
                        <a href="https://discord.gg/QjMBn5Wkzz" target="_blank" rel="noreferrer" class="portal-secondary-action">Join Community</a>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="portal-hero-caption">Kept alive by the community, for the community.</div>
        </div>

        <div class="portal-hero-visual" aria-hidden="true">
            <div class="portal-hero-emblem-card">
                <img src="images/portal-crest.svg" alt="" class="portal-hero-emblem" />
                <div class="portal-hero-emblem-copy">
                    <div>Account management</div>
                    <div>Secure by default</div>
                    <div>Community powered</div>
                </div>
            </div>

            <div class="portal-hero-stat-grid">
                <article class="portal-hero-stat-card">
                    <span>01</span>
                    <strong>Create your account</strong>
                    <p>Register, sign in, and manage your credentials from a single portal.</p>
                </article>

                <article class="portal-hero-stat-card">
                    <span>02</span>
                    <strong>Download the client</strong>
                    <p>Get the launcher or full distribution for your platform and jump straight in.</p>
                </article>

                <article class="portal-hero-stat-card">
                    <span>03</span>
                    <strong>Join the community</strong>
                    <p>Connect with other players on Discord and Reddit to stay in the loop.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="portal-final-call">
        <div class="portal-section-kicker">Stay Connected</div>
        <h2>Need More Information?</h2>
        <p>Join the community to stay up to date with the latest news, get support, and connect with other players.</p>
        <div class="portal-hero-actions portal-hero-actions-centred">
            <a href="https://discord.gg/QjMBn5Wkzz" target="_blank" rel="noreferrer" class="portal-call-to-action">Join Discord Server</a>
            <a href="https://www.reddit.com/r/HeroesOfNewerth/" target="_blank" rel="noreferrer" class="portal-secondary-action">Join Reddit Community</a>
        </div>
    </section>
</div>

