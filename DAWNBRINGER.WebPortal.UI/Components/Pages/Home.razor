@page "/"

@inject PortalAuthenticationService AuthenticationService

<PageTitle>Project KONGOR</PageTitle>

<!-- Full-Viewport Hero Section — Edge-to-Edge, Viewport-Matched -->
<section class="portal-hero">

    <!-- Caldavar Background Image -->
    <img src="img/caldavar.jpg" alt="" class="portal-hero-image" />

    <!-- Dark Tint Overlay -->
    <div class="portal-hero-overlay"
         style="@HeroOverlayStyle" />

    <!-- Bottom Fade Gradient -->
    <div class="portal-hero-fade"
         style="@HeroFadeStyle" />

    <!-- Hero Content -->
    <div class="portal-hero-content">

        <MudText Typo="Typo.h2" Align="Align.Center"
                 Class="scurlock portal-hero-title portal-glow-text portal-hero-title-text"
                 Style="color: #FFFFFF; font-size: 60px; letter-spacing: 4px;">
            Project KONGOR
        </MudText>

        <MudText Typo="Typo.h5" Align="Align.Center"
                 Class="scurlock portal-hero-subtitle portal-hero-subtitle-text mb-2"
                 Style="color: #E0E0E0; font-size: 48px; opacity: 0.9;">
            Coming Soon To A Fountain Near You
        </MudText>

        <MudText Typo="Typo.body1" Align="Align.Center"
                 Class="portal-hero-description mb-10"
                 Style="color: rgba(224, 224, 224, 0.75); max-width: 480px;">
            Stay up to speed with the updates on
            <MudLink Href="https://discord.gg/QjMBn5Wkzz" Target="_blank" Typo="Typo.body1"
                     Style="color: #9B8FFF; font-weight: 600;">
                our Discord server
            </MudLink>
        </MudText>

        <AuthorizeView>
            <NotAuthorized>
                <div class="portal-hero-cta">
                    <MudButton Href="/register"
                               Variant="Variant.Outlined"
                               Size="Size.Large"
                               EndIcon="@Icons.Material.Filled.AppRegistration"
                               Class="portal-cta-button"
                               Style="width: 240px; height: 56px; font-size: 1.1rem; font-weight: 600; color: #FFFFFF; border-color: rgba(119, 107, 231, 0.7);">
                        Register
                    </MudButton>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </div>

</section>

<!-- Timeline Section -->
<MudContainer MaxWidth="MaxWidth.Large" Class="portal-timeline-section">

    <MudText Typo="Typo.h4" Align="Align.Center" Class="portal-timeline-heading">
        Project KONGOR Timeline
    </MudText>

    <MudTimeline TimelineAlign="TimelineAlign.Default" TimelinePosition="TimelinePosition.Alternate" Class="my-6">

        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
            <ItemOpposite>
                <MudText Color="Color.Primary" Typo="Typo.h6" Class="portal-timeline-date">
                    September 16th 2022
                </MudText>
            </ItemOpposite>
            <ItemContent>
                <MudCard Outlined="true" Elevation="0" Class="portal-timeline-card">
                    <MudCardContent>
                        <MudText Align="Align.Right" Color="Color.Secondary" Typo="Typo.h6" GutterBottom="true"
                                 Style="font-weight: 700;">
                            GOPO™ Retires From The Development Team
                        </MudText>
                        <MudText Align="Align.Right" Typo="Typo.body2">
                            Having built Project KONGOR into the canonical HoN successor, the original project founder steps down to focus more on his personal life.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </ItemContent>
        </MudTimelineItem>

        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
            <ItemOpposite>
                <MudText Color="Color.Primary" Typo="Typo.h6" Class="portal-timeline-date">
                    August 5th 2022
                </MudText>
            </ItemOpposite>
            <ItemContent>
                <MudCard Outlined="true" Elevation="0" Class="portal-timeline-card">
                    <MudCardContent>
                        <MudText Align="Align.Left" Color="Color.Secondary" Typo="Typo.h6" GutterBottom="true"
                                 Style="font-weight: 700;">
                            Project KONGOR Enters Open Beta Testing
                        </MudText>
                        <MudText Align="Align.Left" Typo="Typo.body2">
                            Project KONGOR publicly invites all players to start using the service.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </ItemContent>
        </MudTimelineItem>

        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
            <ItemOpposite>
                <MudText Color="Color.Primary" Typo="Typo.h6" Class="portal-timeline-date">
                    June 20th 2022
                </MudText>
            </ItemOpposite>
            <ItemContent>
                <MudCard Outlined="true" Elevation="0" Class="portal-timeline-card">
                    <MudCardContent>
                        <MudText Align="Align.Right" Color="Color.Secondary" Typo="Typo.h6" GutterBottom="true"
                                 Style="font-weight: 700;">
                            Official HoN Servers Shut Down
                        </MudText>
                        <MudText Align="Align.Right" Typo="Typo.body2">
                            The game first launched on May 12th 2010, running for a little over 13 years, before finally shutting down.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </ItemContent>
        </MudTimelineItem>

        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
            <ItemOpposite>
                <MudText Color="Color.Primary" Typo="Typo.h6" Class="portal-timeline-date">
                    December 13th 2021
                </MudText>
            </ItemOpposite>
            <ItemContent>
                <MudCard Outlined="true" Elevation="0" Class="portal-timeline-card">
                    <MudCardContent>
                        <MudText Align="Align.Left" Color="Color.Secondary" Typo="Typo.h6" GutterBottom="true"
                                 Style="font-weight: 700;">
                            Project KONGOR Development Begins
                        </MudText>
                        <MudText Align="Align.Left" Typo="Typo.body2">
                            Packet capturing starts and the first proof-of-concept is released. The proof-of-concept consisted of logging in and playing Plinko.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </ItemContent>
        </MudTimelineItem>

        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
            <ItemOpposite>
                <MudText Color="Color.Primary" Typo="Typo.h6" Class="portal-timeline-date">
                    December 13th 2021
                </MudText>
            </ItemOpposite>
            <ItemContent>
                <MudCard Outlined="true" Elevation="0" Class="portal-timeline-card">
                    <MudCardContent>
                        <MudText Align="Align.Right" Color="Color.Secondary" Typo="Typo.h6" GutterBottom="true"
                                 Style="font-weight: 700;">
                            HoN's End-Of-Life Is Announced
                        </MudText>
                        <MudText Align="Align.Right" Typo="Typo.body2">
                            Frostburn announces that the game will shut down on June 20th 2022.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </ItemContent>
        </MudTimelineItem>

    </MudTimeline>

</MudContainer>

@code {

    [CascadingParameter(Name = "IsDarkMode")]
    private bool IsDarkMode { get; set; }

    private string HeroOverlayStyle => IsDarkMode
        ? "background: rgba(13, 13, 26, 0.6);"
        : "background: rgba(13, 13, 26, 0.5);";

    private string HeroFadeStyle => IsDarkMode
        ? "background: linear-gradient(to bottom, transparent 10%, #0D0D1A);"
        : "background: linear-gradient(to bottom, transparent 10%, #F8F9FC);";
}
