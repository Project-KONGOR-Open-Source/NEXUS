@page "/"

<PageTitle>Project KONGOR</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="px-4 px-sm-6 py-0">

    @* Hero Section *@
    <div class="hero-section animate-fade-in">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="4">
            <MudText Typo="Typo.h1" Align="Align.Center" Class="font-scurlock hero-title" Color="Color.Primary">Project KONGOR</MudText>
            <MudText Typo="Typo.h5" Align="Align.Center">A community-driven revival of Heroes Of Newerth</MudText>
            <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Secondary">By the community, for the community.</MudText>
            <MudStack Row="true" Spacing="3" Justify="Justify.Center" Class="mt-2">
                <MudButton Href="/downloads" Variant="Variant.Filled" Color="Color.Primary" Class="glow-button" EndIcon="@Icons.Material.Filled.Download">
                    Download Now
                </MudButton>
                <MudButton Href="https://discord.com/invite/N6pKzGDqUH" Target="_blank" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Custom.Brands.Discord">
                    Join Discord
                </MudButton>
            </MudStack>
        </MudStack>
    </div>

    @* Downloads & Community Section *@
    <MudGrid Spacing="4" Class="mb-6 animate-fade-in-delay-1">
        <MudItem xs="12" md="6">
            <MudCard Class="glass-card pa-4" Elevation="0" Style="height: 100%;">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h5">Downloads</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            Get the tools and distributions you need to start playing Heroes Of Newerth or host your own match servers.
                            Choose from client launchers, server launchers, and full client and server distributions for Windows, Linux, and macOS.
                        </MudText>
                    </MudStack>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="/downloads" Variant="Variant.Filled" Color="Color.Primary" Class="glow-button" EndIcon="@Icons.Material.Filled.ArrowForward">
                        Browse Downloads
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Class="glass-card pa-4" Elevation="0" Style="height: 100%;">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h5">Community</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            Join fellow players and contributors in our community spaces. Get help, share strategies,
                            find matches, and stay up to date with the latest Project KONGOR news and updates.
                        </MudText>
                    </MudStack>
                </MudCardContent>
                <MudCardActions Class="gap-2">
                    <MudButton Href="https://discord.com/invite/N6pKzGDqUH" Target="_blank" Variant="Variant.Filled" Color="Color.Primary" Class="glow-button" StartIcon="@Icons.Custom.Brands.Discord">
                        Discord
                    </MudButton>
                    <MudButton Href="https://www.reddit.com/r/newerth/" Target="_blank" Variant="Variant.Filled" Color="Color.Primary" Class="glow-button" StartIcon="@Icons.Custom.Brands.Reddit">
                        Reddit
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    <hr class="section-divider" />

    @* Source Code Section *@
    <MudCard Class="glass-card pa-6 mb-6 animate-fade-in-delay-2" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5" Align="Align.Center" Class="section-header">Source Code</MudText>
            </MudStack>
            <MudText Typo="Typo.body1" Align="Align.Center" Style="max-width: 600px;">
                Project KONGOR is open source. Explore our repositories, contribute code, report issues, or fork the projects to run your own services.
            </MudText>
        </MudStack>

        <MudGrid Spacing="3" Class="mt-4" Justify="Justify.Center">
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="glass-card-inner pa-3" Elevation="0" Style="height: 100%;">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">NEXUS</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Open-Source Project KONGOR Re-Write</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="https://github.com/Project-KONGOR-Open-Source/NEXUS" Target="_blank" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.OpenInNew">
                            View
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="glass-card-inner pa-3" Elevation="0" Style="height: 100%;">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">WILLOWMAKER</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Heroes Of Newerth Client Launcher</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="https://github.com/Project-KONGOR-Open-Source/WILLOWMAKER" Target="_blank" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.OpenInNew">
                            View
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="glass-card-inner pa-3" Elevation="0" Style="height: 100%;">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">COMPEL</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Heroes Of Newerth Match Server Launcher</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="https://github.com/Project-KONGOR-Open-Source/COMPEL" Target="_blank" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.OpenInNew">
                            View
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="glass-card-inner pa-3" Elevation="0" Style="height: 100%;">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">CODEX</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Project KONGOR Knowledge Base</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="https://github.com/Project-KONGOR-Open-Source/CODEX" Target="_blank" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.OpenInNew">
                            View
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudCard>

    <hr class="section-divider" />

    @* Knowledge Base Section *@
    <MudCard Class="glass-card pa-6 mb-6 animate-fade-in-delay-3" Elevation="0">
        <MudCardContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="section-header">Knowledge Base</MudText>
                </MudStack>
                <MudText Typo="Typo.body1" Align="Align.Center" Style="max-width: 600px;">
                    Find comprehensive documentation on all aspects of Project KONGOR. From self-hosting guides for technical users
                    to in-depth game mechanics for hardcore players, the Knowledge Base has you covered.
                </MudText>
            </MudStack>
        </MudCardContent>
        <MudCardActions Class="justify-center">
            <MudButton Href="https://codex.kongor.net" Target="_blank" Variant="Variant.Filled" Color="Color.Primary" Class="glow-button" EndIcon="@Icons.Material.Filled.OpenInNew">
                Visit Knowledge Base
            </MudButton>
        </MudCardActions>
    </MudCard>

    <hr class="section-divider" />

    @* Timeline Section *@
    <MudCard Class="glass-card pa-6 mb-6 animate-fade-in-delay-4" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5" Align="Align.Center" Class="section-header">Timeline</MudText>
            </MudStack>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">Key milestones in Project KONGOR's journey</MudText>
        </MudStack>

        <MudTimeline TimelinePosition="TimelinePosition.Alternate">
            <MudTimelineItem Color="Color.Primary" Variant="Variant.Filled">
                <ItemOpposite>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">TODO Date</MudText>
                </ItemOpposite>
                <ItemContent>
                    <MudCard Class="timeline-card pa-3" Elevation="0">
                        <MudText Typo="Typo.h6">TODO #1</MudText>
                        <MudText Typo="Typo.body2">Placeholder event description. Replace with actual milestone.</MudText>
                    </MudCard>
                </ItemContent>
            </MudTimelineItem>

            <MudTimelineItem Color="Color.Secondary" Variant="Variant.Filled">
                <ItemOpposite>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">TODO Date</MudText>
                </ItemOpposite>
                <ItemContent>
                    <MudCard Class="timeline-card pa-3" Elevation="0">
                        <MudText Typo="Typo.h6">TODO #2</MudText>
                        <MudText Typo="Typo.body2">Placeholder event description. Replace with actual milestone.</MudText>
                    </MudCard>
                </ItemContent>
            </MudTimelineItem>

            <MudTimelineItem Color="Color.Primary" Variant="Variant.Filled">
                <ItemOpposite>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">TODO Date</MudText>
                </ItemOpposite>
                <ItemContent>
                    <MudCard Class="timeline-card pa-3" Elevation="0">
                        <MudText Typo="Typo.h6">TODO #3</MudText>
                        <MudText Typo="Typo.body2">Placeholder event description. Replace with actual milestone.</MudText>
                    </MudCard>
                </ItemContent>
            </MudTimelineItem>

            <MudTimelineItem Color="Color.Secondary" Variant="Variant.Filled">
                <ItemOpposite>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">TODO Date</MudText>
                </ItemOpposite>
