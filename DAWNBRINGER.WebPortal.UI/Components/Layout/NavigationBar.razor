@inject NavigationManager NavigationManager
@inject PortalAuthenticationService AuthenticationService

<header class="portal-site-header">
    <div class="portal-site-header-inner">
        <a href="/" class="portal-brand-link" aria-label="Project KONGOR home">
            <img src="images/portal-crest.svg" alt="Project KONGOR crest" class="portal-brand-crest" />
            <span class="portal-brand-copy">
                <span class="portal-brand-kicker portal-brand-wordmark">Project KONGOR</span>
                <span class="portal-brand-title">User Portal</span>
            </span>
        </a>

        <nav class="portal-primary-navigation" aria-label="Primary navigation">
            <a href="/">Home</a>
            <details class="portal-nav-disclosure">
                <summary>
                    Community
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Class="portal-nav-disclosure-icon" />
                </summary>

                <div class="portal-nav-disclosure-panel">
                    <section class="portal-nav-disclosure-group">
                        <a href="https://discord.gg/QjMBn5Wkzz" target="_blank" rel="noreferrer">Discord</a>
                        <a href="https://www.reddit.com/r/HeroesOfNewerth/" target="_blank" rel="noreferrer">Reddit</a>
                    </section>
                </div>
            </details>
            <details class="portal-nav-disclosure">
                <summary>
                    Download
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Class="portal-nav-disclosure-icon" />
                </summary>

                <div class="portal-nav-disclosure-panel">
                    @foreach (DownloadGroup downloadGroup in DownloadGroups)
                    {
                        <section class="portal-nav-disclosure-group">
                            <div class="portal-nav-disclosure-title">@downloadGroup.Title</div>

                            @foreach (DownloadEntry downloadEntry in downloadGroup.Entries)
                            {
                                <a href="@downloadEntry.Link" target="_blank" rel="noreferrer">@downloadEntry.Title</a>
                            }
                        </section>
                    }
                </div>
            </details>
            <a href="https://codex.kongor.net" target="_blank" rel="noreferrer">Knowledge Base</a>
        </nav>

        <div class="portal-header-actions">
            <AuthorizeView>
                <NotAuthorized>
                    <div class="portal-header-action-group" aria-label="Account actions">
                        <a href="/register" class="portal-call-to-action portal-call-to-action-compact">Create Account</a>
                        <a href="/login" class="portal-header-pill portal-utility-link">Log In</a>
                    </div>
                </NotAuthorized>

                <Authorized>
                    <div class="portal-header-action-group" aria-label="Account actions">
                        <a href="/account" class="portal-header-pill portal-utility-link">Account</a>
                        <button type="button" class="portal-header-pill portal-utility-button" @onclick="HandleLogOut">Log Out</button>
                    </div>
                </Authorized>
            </AuthorizeView>

            <div class="portal-header-theme-group" aria-label="Appearance">
                <button type="button" class="portal-header-pill portal-theme-button" @onclick="HandleThemeSelection" aria-label="Toggle colour theme">
                    <MudIcon Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" />
                </button>
            </div>

            <button type="button" class="portal-mobile-toggle" @onclick="ToggleMobileMenu" aria-expanded="@IsMobileMenuOpen.ToString().ToLowerInvariant()" aria-label="Toggle navigation menu">
                <MudIcon Icon="@(IsMobileMenuOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Menu)" />
            </button>
        </div>
    </div>

    @if (IsMobileMenuOpen)
    {
        <div class="portal-mobile-panel">
            <a href="/" @onclick="CloseMobileMenu">Home</a>
            <details class="portal-mobile-disclosure">
                <summary>Community</summary>

                <div class="portal-mobile-disclosure-panel">
                    <section class="portal-mobile-disclosure-group">
                        <a href="https://discord.gg/QjMBn5Wkzz" target="_blank" rel="noreferrer" @onclick="CloseMobileMenu">Discord</a>
                        <a href="https://www.reddit.com/r/HeroesOfNewerth/" target="_blank" rel="noreferrer" @onclick="CloseMobileMenu">Reddit</a>
                    </section>
                </div>
            </details>
            <details class="portal-mobile-disclosure">
                <summary>Download</summary>

                <div class="portal-mobile-disclosure-panel">
                    @foreach (DownloadGroup downloadGroup in DownloadGroups)
                    {
                        <section class="portal-mobile-disclosure-group">
                            <div class="portal-mobile-disclosure-title">@downloadGroup.Title</div>

                            @foreach (DownloadEntry downloadEntry in downloadGroup.Entries)
                            {
                                <a href="@downloadEntry.Link" target="_blank" rel="noreferrer" @onclick="CloseMobileMenu">@downloadEntry.Title</a>
                            }
                        </section>
                    }
                </div>
            </details>
            <a href="https://codex.kongor.net" target="_blank" rel="noreferrer" @onclick="CloseMobileMenu">Knowledge Base</a>

            <AuthorizeView>
                <NotAuthorized>
                    <a href="/register" class="portal-call-to-action" @onclick="CloseMobileMenu">Create Account</a>
                    <a href="/login" @onclick="CloseMobileMenu">Log In</a>
                </NotAuthorized>

                <Authorized>
                    <a href="/account" @onclick="CloseMobileMenu">Account</a>
                    <button type="button" class="portal-utility-button portal-utility-button-mobile" @onclick="HandleMobileLogOut">Log Out</button>
                </Authorized>
            </AuthorizeView>
        </div>
    }
</header>

@code {

    [Parameter]
    public bool IsDarkMode { get; set; }

    [Parameter]
    public EventCallback OnThemeToggle { get; set; }

    private static readonly DownloadGroup[] DownloadGroups =
    [
        new DownloadGroup("Launcher",
        [
            new DownloadEntry("Client", "https://example.com/kongor/launcher/client"),
            new DownloadEntry("Server", "https://example.com/kongor/launcher/server")
        ]),
        new DownloadGroup("Distribution",
        [
            new DownloadEntry("Windows", "https://example.com/kongor/distribution/windows"),
            new DownloadEntry("Linux", "https://example.com/kongor/distribution/linux"),
            new DownloadEntry("macOS", "https://example.com/kongor/distribution/macos")
        ])
    ];

    private bool IsMobileMenuOpen { get; set; }

    private Task HandleThemeSelection()
    {
        return OnThemeToggle.InvokeAsync();
    }

    private void ToggleMobileMenu()
    {
        IsMobileMenuOpen = IsMobileMenuOpen is false;
    }

    private void CloseMobileMenu()
    {
        IsMobileMenuOpen = false;
    }

    private async Task HandleLogOut()
    {
        CloseMobileMenu();
        await AuthenticationService.ClearToken();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private Task HandleMobileLogOut()
    {
        return HandleLogOut();
    }

    private sealed record DownloadGroup(string Title, DownloadEntry[] Entries);

    private sealed record DownloadEntry(string Title, string Link);
}
