    private MudThemeProvider ThemeProvider { get; set; } = null!;

    private bool IsDarkMode { get; set; } = true;

    private bool DrawerOpen { get; set; }

    private string ThemeIcon => IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;

    private Color AppBarButtonColour => Color.Primary;

    private string ThemeClass => IsDarkMode ? "dark-mode" : "light-mode";

    private string ContentStyle => IsDarkMode
        ? "padding-top: 64px; min-height: 100vh; background: linear-gradient(rgba(10, 15, 13, 0.82), rgba(10, 15, 13, 0.92)), url('images/caldavar.jpg') center/cover no-repeat fixed;"
        : "padding-top: 64px; min-height: 100vh; background: linear-gradient(rgba(241, 248, 233, 0.88), rgba(241, 248, 233, 0.94)), url('images/caldavar.jpg') center/cover no-repeat fixed;";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            IsDarkMode = await ThemeProvider.GetSystemDarkModeAsync();
            StateHasChanged();
        }
    }

    private void ToggleTheme()
    {
        IsDarkMode = !IsDarkMode;
    }

    private void ToggleDrawer()
    {
        DrawerOpen = !DrawerOpen;
    }

    private async Task HandleLogOut()
    {
        await AuthenticationService.ClearToken();
        NavigationManager.NavigateTo("/");
    }
