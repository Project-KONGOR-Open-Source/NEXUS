@inherits LayoutComponentBase

@inject IJSRuntime JavaScript

<MudThemeProvider @bind-IsDarkMode="IsDarkMode" Theme="Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <NavigationBar IsDarkMode="@IsDarkMode" IsDarkModeChanged="@ToggleDarkMode" />
    <MudMainContent Class="portal-main-content">
        <CascadingValue Value="IsDarkMode" Name="IsDarkMode">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

@code {

    private static readonly MudTheme Theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#776BE7",
            Secondary = "#FF4081",
            Tertiary = "#5C6BC0",
            AppbarBackground = "rgba(255, 255, 255, 0.85)",
            AppbarText = "#1A1A2E",
            Background = "#F8F9FC",
            Surface = "#FFFFFF",
            TextPrimary = "#1A1A2E",
            TextSecondary = "#5A5A7A",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#1A1A2E",
            ActionDefault = "#5A5A7A",
            ActionDisabled = "#9E9E9E",
            Divider = "rgba(0, 0, 0, 0.08)"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#776BE7",
            Secondary = "#FF4081",
            Tertiary = "#7C4DFF",
            AppbarBackground = "rgba(15, 15, 26, 0.85)",
            AppbarText = "#FFFFFF",
            Background = "#0D0D1A",
            Surface = "#1A1A2E",
            TextPrimary = "#E8E8F0",
            TextSecondary = "#A0A0C0",
            DrawerBackground = "#1A1A2E",
            DrawerText = "#E8E8F0",
            ActionDefault = "#A0A0C0",
            ActionDisabled = "#4A4A6A",
            Divider = "rgba(119, 107, 231, 0.12)"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Inter", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"]
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px"
        }
    };

    private bool IsDarkMode { get; set; } = true;

    private bool ThemeInitialised { get; set; }

    private void ToggleDarkMode()
    {
        IsDarkMode = !IsDarkMode;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ThemeInitialised is false)
        {
            try
            {
                IsDarkMode = await JavaScript.InvokeAsync<bool>("portalTheme.getPreferredColourScheme");
                ThemeInitialised = true;
                StateHasChanged();
            }
            catch
            {
                // If JS Interop Fails, Default To Dark Mode
                ThemeInitialised = true;
            }
        }
    }
}
