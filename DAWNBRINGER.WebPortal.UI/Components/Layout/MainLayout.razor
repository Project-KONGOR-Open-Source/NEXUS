@implements IAsyncDisposable
@inherits LayoutComponentBase

@inject IJSRuntime JavaScript

<MudThemeProvider IsDarkMode="IsDarkMode" Theme="Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="portal-shell @(IsDarkMode ? "portal-theme-dark" : "portal-theme-light")">
    <div class="portal-background" aria-hidden="true">
        <div class="portal-background-orb portal-background-orb-left"></div>
        <div class="portal-background-orb portal-background-orb-right"></div>
        <div class="portal-background-grid"></div>
    </div>

    <NavigationBar IsDarkMode="IsDarkMode" OnThemeToggle="HandleThemeToggle" />

    <main class="portal-site-main">
        <CascadingValue Name="IsDarkMode" Value="IsDarkMode">
            @Body
        </CascadingValue>
    </main>

    <footer class="portal-site-footer">
        <div class="portal-site-footer-inner">
            <div class="portal-site-footer-brand">
                <img src="images/portal-crest.svg" alt="Project KONGOR crest" class="portal-site-footer-crest" />
                <div>
                    <div class="portal-site-footer-title">Project KONGOR</div>
                    <div class="portal-site-footer-copy">A modern front door for the community portal.</div>
                </div>
            </div>

            <div class="portal-site-footer-links">
                <a href="/#features">Features</a>
                <a href="/#heroes">Heroes</a>
                <a href="https://codex.kongor.net" target="_blank" rel="noreferrer">Knowledge Base</a>
                <a href="/#timeline">Timeline</a>
                <a href="https://discord.gg/QjMBn5Wkzz" target="_blank" rel="noreferrer">Community</a>
            </div>
        </div>
    </footer>
</div>

@code {

    private static readonly MudTheme Theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#a53d2d",
            Secondary = "#355f87",
            Tertiary = "#c4a46d",
            AppbarBackground = "rgba(246, 240, 230, 0.88)",
            AppbarText = "#231a14",
            Background = "#f6f0e6",
            Surface = "#fffaf2",
            TextPrimary = "#231a14",
            TextSecondary = "#5d4e40",
            DrawerBackground = "#fffaf2",
            DrawerText = "#231a14",
            ActionDefault = "#5d4e40",
            ActionDisabled = "#a7998c",
            Divider = "rgba(35, 26, 20, 0.12)"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#d06a3c",
            Secondary = "#7aa4d2",
            Tertiary = "#d5bc83",
            AppbarBackground = "rgba(10, 17, 27, 0.86)",
            AppbarText = "#f6efe4",
            Background = "#0b111b",
            Surface = "#121c29",
            TextPrimary = "#f6efe4",
            TextSecondary = "#b8c0cb",
            DrawerBackground = "#121c29",
            DrawerText = "#f6efe4",
            ActionDefault = "#b8c0cb",
            ActionDisabled = "#5c6470",
            Divider = "rgba(245, 197, 122, 0.12)"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Inter", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"]
            },
            H1 = new H1Typography
            {
                FontFamily = ["Cinzel", "Georgia", "serif"],
                FontWeight = "700"
            },
            H2 = new H2Typography
            {
                FontFamily = ["Cinzel", "Georgia", "serif"],
                FontWeight = "700"
            },
            H3 = new H3Typography
            {
                FontFamily = ["Cinzel", "Georgia", "serif"],
                FontWeight = "700"
            },
            H4 = new H4Typography
            {
                FontFamily = ["Cinzel", "Georgia", "serif"],
                FontWeight = "700"
            },
            H5 = new H5Typography
            {
                FontFamily = ["Cinzel", "Georgia", "serif"],
                FontWeight = "700"
            },
            H6 = new H6Typography
            {
                FontFamily = ["Cinzel", "Georgia", "serif"],
                FontWeight = "700"
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "18px"
        }
    };

    private IJSObjectReference? ThemeModule { get; set; }

    private bool IsDarkMode { get; set; } = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender is false)
        {
            return;
        }

        ThemeModule = await JavaScript.InvokeAsync<IJSObjectReference>("import", "./js/portalTheme.js");

        ThemePreference themePreference = await ThemeModule.InvokeAsync<ThemePreference>("getThemePreference");
        IsDarkMode = themePreference.Mode.Equals("dark", StringComparison.Ordinal);

        StateHasChanged();
    }

    private async Task HandleThemeToggle()
    {
        IsDarkMode = IsDarkMode is false;

        if (ThemeModule is not null)
        {
            await ThemeModule.InvokeVoidAsync("setThemePreference", IsDarkMode ? "dark" : "light");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (ThemeModule is null)
        {
            return;
        }

        try
        {
            await ThemeModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private sealed class ThemePreference
    {
        public string Mode { get; set; } = "dark";

        public string Source { get; set; } = "system";
    }
}
